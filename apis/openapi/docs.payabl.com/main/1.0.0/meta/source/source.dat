{
  "openapi": "3.0.3",
  "info": {
    "title": "Payabl SPEI Payment API",
    "description": "Payabl API for processing SPEI (Sistema de Pagos Electronicos Interbancarios) electronic bank transfers in Mexico, including transaction requests, refunds, and payouts.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.payabl.com/docs/spei"
  },
  "servers": [
    {
      "url": "https://sandbox.payabl.com",
      "description": "Sandbox"
    },
    {
      "url": "https://gateway.payabl.com",
      "description": "Production"
    }
  ],
  "security": [
    {
      "signatureAuth": []
    }
  ],
  "tags": [
    { "name": "Transactions", "description": "SPEI transaction operations" },
    { "name": "Refunds", "description": "Refund operations" },
    { "name": "Payouts", "description": "Payout operations" }
  ],
  "paths": {
    "/pay/backoffice/payment_preauthorize": {
      "post": {
        "operationId": "createSpeiTransaction",
        "summary": "Create SPEI transaction",
        "description": "Initiate a SPEI transaction request to process electronic bank transfers in Mexico.",
        "tags": ["Transactions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/SpeiTransactionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpeiTransactionResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "description": "Authentication failure" }
        }
      }
    },
    "/backoffice/payment_refund": {
      "post": {
        "operationId": "createSpeiRefund",
        "summary": "Create SPEI refund",
        "description": "Process a full or partial refund via wire transfer. Customer receives notification with payment details.",
        "tags": ["Refunds"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/SpeiRefundRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpeiRefundResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "description": "Authentication failure" }
        }
      }
    },
    "/pay/backoffice/payment_cft": {
      "post": {
        "operationId": "createSpeiPayout",
        "summary": "Create SPEI payout",
        "description": "Send merchant funds to customer bank accounts via wire transfer.",
        "tags": ["Payouts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/SpeiPayoutRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payout response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpeiPayoutResponse" }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "description": "Authentication failure" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "signatureAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "signature",
        "description": "SHA-1 hexadecimal signature (40 characters) calculated from merchant credentials and transaction parameters"
      }
    },
    "schemas": {
      "SpeiTransactionRequest": {
        "type": "object",
        "required": ["merchantid", "amount", "currency", "payment_method", "email", "custom2", "nationalid", "nationaltype", "signature"],
        "properties": {
          "merchantid": { "type": "string", "description": "Merchant identification number" },
          "orderid": { "type": "string", "description": "Optional merchant order reference" },
          "amount": { "type": "string", "description": "Transaction total amount" },
          "currency": { "type": "string", "description": "ISO 4217 code (MXN for SPEI)", "example": "MXN" },
          "payment_method": { "type": "string", "description": "Payment method code (130 or 126)", "example": "130" },
          "email": { "type": "string", "format": "email", "description": "Customer email address" },
          "custom2": { "type": "string", "description": "Payment method name", "example": "spei" },
          "nationalid": { "type": "string", "description": "Consumer national ID (RFC: 13 chars or CURP: 18 chars)" },
          "nationaltype": { "type": "string", "enum": ["RFC", "CURP"], "description": "Identification type" },
          "signature": { "type": "string", "description": "40-character hexadecimal SHA-1 checksum" }
        }
      },
      "SpeiTransactionResponse": {
        "type": "object",
        "properties": {
          "transactionid": { "type": "string" },
          "transid": { "type": "string" },
          "status": { "type": "string" },
          "errormessage": { "type": "string" },
          "amount": { "type": "string" },
          "currency": { "type": "string" },
          "orderid": { "type": "string" },
          "user_id": { "type": "string" },
          "redirect_url": { "type": "string", "format": "uri" }
        }
      },
      "SpeiRefundRequest": {
        "type": "object",
        "required": ["merchantid", "transactionid", "amount", "currency", "signature"],
        "properties": {
          "merchantid": { "type": "string", "description": "Merchant identification number" },
          "transactionid": { "type": "string", "description": "Original transaction ID to refund" },
          "amount": { "type": "string", "description": "Refund amount" },
          "currency": { "type": "string", "description": "ISO 4217 code", "example": "MXN" },
          "language": { "type": "string", "description": "Language preference code" },
          "signature": { "type": "string", "description": "40-character hexadecimal SHA-1 checksum" }
        }
      },
      "SpeiRefundResponse": {
        "type": "object",
        "properties": {
          "transactionid": { "type": "string" },
          "transid": { "type": "string" },
          "status": { "type": "string" },
          "amount": { "type": "string" },
          "currency": { "type": "string" },
          "orderid": { "type": "string" }
        }
      },
      "SpeiPayoutRequest": {
        "type": "object",
        "required": ["merchantid", "amount", "currency", "account", "document_id", "document_type", "bankcountry", "bank_code", "account_type", "payment_method", "signature"],
        "properties": {
          "merchantid": { "type": "string", "description": "Merchant identification number" },
          "amount": { "type": "string", "description": "Payout amount" },
          "currency": { "type": "string", "example": "MXN" },
          "account": { "type": "string", "description": "Customer account (10-18 digits)" },
          "document_id": { "type": "string", "description": "Customer identification document" },
          "document_type": { "type": "string", "enum": ["RFC", "CURP"], "description": "Document type" },
          "bankcountry": { "type": "string", "example": "MEX", "description": "Bank country code" },
          "bank_code": { "type": "string", "description": "Mexican bank identifier" },
          "account_type": { "type": "string", "enum": ["debit", "phone", "clabe"], "description": "Account type" },
          "payment_method": { "type": "string", "example": "130" },
          "custom3": { "type": "string", "description": "Payment reason (mandatory for payouts)" },
          "signature": { "type": "string", "description": "40-character hexadecimal SHA-1 checksum" }
        }
      },
      "SpeiPayoutResponse": {
        "type": "object",
        "properties": {
          "transactionid": { "type": "string" },
          "transid": { "type": "string" },
          "status": { "type": "string" },
          "errormessage": { "type": "string" },
          "amount": { "type": "string" },
          "currency": { "type": "string" },
          "orderid": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "errormessage": { "type": "string" }
        }
      }
    }
  }
}