  "definitions": {
    "search_parameters": {
      "type": "object",
      "properties": {
        "max_record": {
          "type": "integer",
          "description": "number of address record returned",
          "example": 5
        },
        "country_code": {
          "type": "string",
          "description": "Country of the address ISO-Alpha2",
          "maxLength": 2
        },
        "address_search": {
          "type": "string",
          "description": "Address fragment used to query for suggestions"
        }
      },
      "required": [
        "country_code",
        "max_record"
      ],
      "example": {
        "max_record": 10,
        "country_code": "AUS",
        "address_search": "20 george str"
      }
    },
    "address_suggestions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/address_suggestion"
      },
      "example": [
        {
          "address_suggestion": {
            "address_description": "20 george street, Sydney, NSW, 2000",
            "address_id": "20 george street, Sydney, NSW, 2000"
          }
        },
        {
          "address_suggestion": {
            "address_description": "20 george avenue, Melbourne, VIC, 3000",
            "address_id": "654321"
          }
        }
      ]
    },
    "address_suggestion": {
      "type": "object",
      "properties": {
