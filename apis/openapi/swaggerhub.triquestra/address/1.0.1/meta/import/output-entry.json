  "components": {
    "schemas": {
      "address_base": {
        "allOf": [
          {
            "$ref": "https://api.swaggerhub.com/domains/Triquestra/infinityapi_common_models/1.5.4#/definitions/address_common_fields"
          },
          {
            "properties": {
              "is_rural_delivery": {
                "example": false,
                "type": "boolean"
              }
            },
            "type": "object"
          }
        ]
      },
      "address_id": {
        "type": "string"
      },
      "address_suggestion": {
        "properties": {
          "address_description": {
            "type": "string"
          },
          "address_id": {
            "$ref": "#/components/schemas/address_id"
          }
        },
        "type": "object"
      },
      "address_suggestions": {
        "example": [
          {
            "address_suggestion": {
              "address_description": "20 george street, Sydney, NSW, 2000",
              "address_id": "20 george street, Sydney, NSW, 2000"
            }
          },
          {
            "address_suggestion": {
              "address_description": "20 george avenue, Melbourne, VIC, 3000",
              "address_id": "654321"
            }
          }
        ],
        "items": {
          "$ref": "#/components/schemas/address_suggestion"
        },
        "type": "array"
      },
      "search_parameters": {
        "example": {
          "address_search": "20 george str",
          "country_code": "AUS",
          "max_record": 10
        },
        "properties": {
          "address_search": {
            "description": "Address fragment used to query for suggestions",
            "type": "string"
          },
          "country_code": {
            "description": "Country of the address ISO-Alpha2",
            "maxLength": 2,
            "type": "string"
          },
          "max_record": {
            "description": "number of address record returned",
            "example": 5,
            "type": "integer"
          }
        },
        "required": [
          "country_code",
          "max_record"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "application": {
        "flows": {
