            "name": "User-Agent",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/address_suggestions"
                }
              }
            },
            "description": "Status 200. \n\n <b>Note:</b> where the address provider does not supply an index (address_id), the address id will be a duplicate of the address description"
          },
          "400": {
