        "tags": [
          "Addresses"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/search_parameters"
              }
            }
          },
          "required": true
        },
        "summary": "Search for existing address"
      }
    },
    "/address/{address_id}": {
      "parameters": [
        {
          "description": "The unique identifier of the address",
          "in": "path",
          "name": "address_id",
          "required": true,
          "schema": {
            "type": "string"
          }
        },
        {
          "description": "country code of the address ISO-Alpha2",
          "in": "query",
          "name": "country_code",
          "required": true,
          "schema": {
            "maxLength": 2,
            "type": "string"
          }
        }
      ],
      "get": {
        "parameters": [
          {
            "description": "The value of x-logging-id will be included in all log entries generated by this request.",
            "example": "c3992e83-f622-4151-b585-ae3a832bab78",
