{
  "openapi": "3.0.3",
  "info": {
    "title": "Repology API",
    "version": "v1",
    "description": "Repology API provides access to package and project data across software repositories. It allows querying projects, packages, and repository problems.",
    "x-jentic-source-url": "https://repology.org/api"
  },
  "servers": [
    {
      "url": "https://repology.org",
      "description": "Repology production server"
    }
  ],
  "paths": {
    "/api/v1/project/{projectName}": {
      "get": {
        "operationId": "getProject",
        "summary": "Get packages for a single project",
        "description": "Retrieve all packages associated with a specific project name.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "projectName",
            "in": "path",
            "required": true,
            "description": "The project name to look up",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved project packages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Package"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Project not found"
          }
        }
      }
    },
    "/api/v1/projects/": {
      "get": {
        "operationId": "listProjects",
        "summary": "List projects",
        "description": "Retrieve up to 200 projects, optionally filtered by various criteria.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Project name substring to search for",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maintainer",
            "in": "query",
            "description": "Filter by maintainer email",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Filter by package category",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "inrepo",
            "in": "query",
            "description": "Filter to projects present in this repository",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "notinrepo",
            "in": "query",
            "description": "Filter to projects not present in this repository",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repos",
            "in": "query",
            "description": "Filter by number of repositories (e.g. '1', '5-', '-5', '2-7')",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "families",
            "in": "query",
            "description": "Filter by number of repository families",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repos_newest",
            "in": "query",
            "description": "Filter by number of repos where the project is up-to-date",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "families_newest",
            "in": "query",
            "description": "Filter by number of families where the project is up-to-date",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "newest",
            "in": "query",
            "description": "Filter to newest projects only",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "outdated",
            "in": "query",
            "description": "Filter to outdated projects only",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "problematic",
            "in": "query",
            "description": "Filter to problematic projects only",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved projects",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectsMap"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/{startName}/": {
      "get": {
        "operationId": "listProjectsFromName",
        "summary": "List projects starting from a name",
        "description": "Retrieve up to 200 projects starting from the specified name (inclusive). Supports the same query filters as the projects list endpoint.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "startName",
            "in": "path",
            "required": true,
            "description": "Starting project name (inclusive)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Project name substring to search for",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maintainer",
            "in": "query",
            "description": "Filter by maintainer email",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Filter by package category",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "inrepo",
            "in": "query",
            "description": "Filter to projects present in this repository",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "notinrepo",
            "in": "query",
            "description": "Filter to projects not present in this repository",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved projects",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectsMap"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/projects/..{endName}/": {
      "get": {
        "operationId": "listProjectsUntilName",
        "summary": "List projects ending at a name",
        "description": "Retrieve up to 200 projects ending at the specified name (inclusive).",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "endName",
            "in": "path",
            "required": true,
            "description": "Ending project name (inclusive)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved projects",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectsMap"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/repository/{repoName}/problems": {
      "get": {
        "operationId": "getRepositoryProblems",
        "summary": "Get problems for a repository",
        "description": "Retrieve the list of problems found in a specific repository.",
        "tags": ["Problems"],
        "parameters": [
          {
            "name": "repoName",
            "in": "path",
            "required": true,
            "description": "Repository name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Pagination start project name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved repository problems",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Problem"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Repository not found"
          }
        }
      }
    },
    "/api/v1/maintainer/{maintainer}/problems-for-repo/{repoName}": {
      "get": {
        "operationId": "getMaintainerProblemsForRepo",
        "summary": "Get maintainer problems for a repository",
        "description": "Retrieve problems for a specific maintainer in a given repository.",
        "tags": ["Problems"],
        "parameters": [
          {
            "name": "maintainer",
            "in": "path",
            "required": true,
            "description": "Maintainer identifier (URL-encoded email)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repoName",
            "in": "path",
            "required": true,
            "description": "Repository name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Pagination start project name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved maintainer problems",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Problem"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Maintainer or repository not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Package": {
        "type": "object",
        "properties": {
          "repo": {
            "type": "string",
            "description": "Repository name"
          },
          "srcname": {
            "type": "string",
            "description": "Source package name"
          },
          "binname": {
            "type": "string",
            "description": "Binary package name"
          },
          "binnames": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of binary package names"
          },
          "visiblename": {
            "type": "string",
            "description": "Visible package name"
          },
          "version": {
            "type": "string",
            "description": "Package version"
          },
          "origversion": {
            "type": "string",
            "description": "Original version string"
          },
          "status": {
            "type": "string",
            "description": "Version status",
            "enum": ["newest", "outdated", "legacy", "noscheme", "rolling", "devel", "unique", "ignored"]
          },
          "summary": {
            "type": "string",
            "description": "Package summary/description"
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Package categories"
          },
          "licenses": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Package licenses"
          },
          "maintainers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Package maintainer emails"
          }
        }
      },
      "ProjectsMap": {
        "type": "object",
        "description": "Map of project names to arrays of packages",
        "additionalProperties": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/Package"
          }
        }
      },
      "Problem": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Problem type"
          },
          "data": {
            "type": "object",
            "description": "Problem-specific data"
          },
          "project_name": {
            "type": "string",
            "description": "Project name"
          },
          "version": {
            "type": "string",
            "description": "Package version"
          },
          "binname": {
            "type": "string",
            "description": "Binary package name"
          },
          "srcname": {
            "type": "string",
            "description": "Source package name"
          },
          "rawversion": {
            "type": "string",
            "description": "Raw version string"
          }
        }
      }
    }
  }
}