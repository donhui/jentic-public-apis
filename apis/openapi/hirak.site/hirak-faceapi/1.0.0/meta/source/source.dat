{
  "openapi": "3.0.3",
  "info": {
    "title": "Hirak FaceAPI",
    "description": "Hirak FaceAPI provides face detection and recognition capabilities via a REST API hosted on RapidAPI. The API can detect faces in images, recognize facial landmarks, compare faces for similarity, and perform face-based analysis including age, gender, and emotion detection.",
    "version": "1.0.0",
    "contact": {
      "name": "Hirak FaceAPI",
      "url": "https://faceapi.hirak.site/"
    },
    "x-jentic-source-url": "https://faceapi.hirak.site/"
  },
  "servers": [
    {
      "url": "https://hirak-face-api.p.rapidapi.com",
      "description": "RapidAPI Production Server"
    }
  ],
  "tags": [
    {
      "name": "Face Detection",
      "description": "Detect faces in images"
    },
    {
      "name": "Face Recognition",
      "description": "Compare and recognize faces"
    },
    {
      "name": "Face Analysis",
      "description": "Analyze facial attributes"
    }
  ],
  "paths": {
    "/detect": {
      "post": {
        "operationId": "detectFaces",
        "summary": "Detect faces in an image",
        "description": "Detects all faces in the provided image and returns bounding box coordinates and confidence scores for each detected face.",
        "tags": ["Face Detection"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageUrlInput"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Faces detected successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaceDetectionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "RapidAPIKey": [] }]
      }
    },
    "/landmarks": {
      "post": {
        "operationId": "detectLandmarks",
        "summary": "Detect facial landmarks",
        "description": "Detects facial landmarks (eyes, nose, mouth, jawline, etc.) for each face found in the image.",
        "tags": ["Face Detection"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageUrlInput"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Landmarks detected successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LandmarksResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "RapidAPIKey": [] }]
      }
    },
    "/compare": {
      "post": {
        "operationId": "compareFaces",
        "summary": "Compare two faces for similarity",
        "description": "Compares two face images and returns a similarity score indicating how likely they belong to the same person.",
        "tags": ["Face Recognition"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FaceCompareInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Face comparison completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaceCompareResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "RapidAPIKey": [] }]
      }
    },
    "/analyze": {
      "post": {
        "operationId": "analyzeFace",
        "summary": "Analyze facial attributes",
        "description": "Analyzes detected faces for attributes including estimated age, gender, emotion, and other facial characteristics.",
        "tags": ["Face Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageUrlInput"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Face analysis completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaceAnalysisResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "RapidAPIKey": [] }]
      }
    },
    "/encode": {
      "post": {
        "operationId": "encodeFace",
        "summary": "Generate face encoding",
        "description": "Generates a numerical face encoding (embedding vector) that can be used for face comparison and recognition tasks.",
        "tags": ["Face Recognition"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageUrlInput"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Face encoding generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaceEncodingResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "RapidAPIKey": [] }]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "RapidAPIKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-RapidAPI-Key",
        "description": "RapidAPI API key. Subscribe at https://rapidapi.com/nickhiraksite/api/hirak-face-api"
      }
    },
    "schemas": {
      "ImageUrlInput": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the image to process"
          }
        }
      },
      "ImageFileInput": {
        "type": "object",
        "required": ["image"],
        "properties": {
          "image": {
            "type": "string",
            "format": "binary",
            "description": "Image file to process (JPEG, PNG)"
          }
        }
      },
      "FaceCompareInput": {
        "type": "object",
        "required": ["image1_url", "image2_url"],
        "properties": {
          "image1_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the first face image"
          },
          "image2_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the second face image"
          }
        }
      },
      "FaceDetectionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "faces_detected": {
            "type": "integer",
            "description": "Number of faces detected"
          },
          "faces": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DetectedFace"
            }
          }
        }
      },
      "DetectedFace": {
        "type": "object",
        "properties": {
          "face_id": {
            "type": "integer"
          },
          "confidence": {
            "type": "number",
            "format": "float",
            "description": "Detection confidence score"
          },
          "bounding_box": {
            "$ref": "#/components/schemas/BoundingBox"
          }
        }
      },
      "BoundingBox": {
        "type": "object",
        "properties": {
          "x": { "type": "integer", "description": "Top-left x coordinate" },
          "y": { "type": "integer", "description": "Top-left y coordinate" },
          "width": { "type": "integer" },
          "height": { "type": "integer" }
        }
      },
      "LandmarksResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "faces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "face_id": { "type": "integer" },
                "landmarks": {
                  "type": "object",
                  "properties": {
                    "left_eye": { "$ref": "#/components/schemas/Point" },
                    "right_eye": { "$ref": "#/components/schemas/Point" },
                    "nose_tip": { "$ref": "#/components/schemas/Point" },
                    "mouth_left": { "$ref": "#/components/schemas/Point" },
                    "mouth_right": { "$ref": "#/components/schemas/Point" },
                    "chin": { "$ref": "#/components/schemas/Point" }
                  }
                },
                "bounding_box": { "$ref": "#/components/schemas/BoundingBox" }
              }
            }
          }
        }
      },
      "Point": {
        "type": "object",
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" }
        }
      },
      "FaceCompareResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "similarity": {
            "type": "number",
            "format": "float",
            "description": "Similarity score between 0 and 1"
          },
          "is_same_person": {
            "type": "boolean",
            "description": "Whether the faces likely belong to the same person"
          },
          "confidence": {
            "type": "number",
            "format": "float"
          }
        }
      },
      "FaceAnalysisResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "faces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "face_id": { "type": "integer" },
                "age": {
                  "type": "integer",
                  "description": "Estimated age"
                },
                "gender": {
                  "type": "string",
                  "enum": ["male", "female"],
                  "description": "Predicted gender"
                },
                "emotion": {
                  "type": "string",
                  "enum": ["happy", "sad", "angry", "surprise", "fear", "disgust", "neutral"],
                  "description": "Dominant emotion detected"
                },
                "emotion_confidence": {
                  "type": "number",
                  "format": "float"
                },
                "bounding_box": { "$ref": "#/components/schemas/BoundingBox" }
              }
            }
          }
        }
      },
      "FaceEncodingResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "faces": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "face_id": { "type": "integer" },
                "encoding": {
                  "type": "array",
                  "items": { "type": "number", "format": "float" },
                  "description": "128-dimensional face encoding vector"
                },
                "bounding_box": { "$ref": "#/components/schemas/BoundingBox" }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid image or missing parameters",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing RapidAPI key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - subscription required or exceeded plan limits",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "RateLimited": {
        "description": "Too many requests - rate limit exceeded",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  },
  "security": [
    {
      "RapidAPIKey": []
    }
  ]
}
