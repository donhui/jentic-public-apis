{
  "openapi": "3.0.3",
  "info": {
    "title": "Klardenker_Meet_API",
    "version": "0.1",
    "x-jentic-source-url": "http://ap1-st.klar.land/docs/api-docs.json"
  },
  "servers": [
    {
      "url": "https://api.dev.klar.land"
    }
  ],
  "paths": {
    "/test": {
      "get": {
        "tags": [
          "Test"
        ],
        "summary": "Test",
        "description": "Muliple tags can be provided with comma separated strings. Use tag1, tag2, tag3 for testing.",
        "operationId": "Test",
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "400": {
            "description": "Invalid tag value"
          }
        },
        "security": [
          {
            "token": []
          }
        ]
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Login",
        "description": "",
        "operationId": "AuthLogin",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "description": "email",
            "required": true,
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "john@doe.com"
          },
          {
            "name": "password",
            "in": "query",
            "description": "password",
            "required": true,
            "explode": true,
            "schema": {
              "type": "string"
            },
            "example": "john@doe.com"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "400": {
            "description": "Invalid tag value"
          }
        }
      }
    },
    "/workspace/users_get": {
      "post": {
        "tags": [
          "Workspace"
        ],
        "summary": "get all users workspace",
        "description": "",
        "operationId": "getAllUsersWorkspace",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "workspace_id": {
                    "type": "string",
                    "example": "59e87911-4fb3-4a63-abd7-c56cd90e2ffb"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "400": {
            "description": "Invalid tag value"
          }
        },
        "security": [
          {
            "token": []
          }
        ]
      }
    },
    "/meeting": {
      "post": {
        "tags": [
          "Meeting"
        ],
        "summary": "get all meeting",
        "description": "",
        "operationId": "getAllMeeting",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "document": {
                    "properties": {
                      "workspace_id": {
                        "type": "string",
                        "example": "9596deed-feee-458a-9757-9ecd494fe889"
                      }
                    },
                    "type": "object"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "400": {
            "description": "Invalid tag value"
          }
        },
        "security": [
          {
            "token": []
          }
        ]
      }
    },
    "/calendar/get": {
      "post": {
        "tags": [
          "Calendar"
        ],
        "summary": "get a Calendar",
        "description": "",
        "operationId": "getCalendar",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "calendar": {
                    "properties": {
                      "uuid": {
                        "type": "string",
                        "example": "bfd65d5b-4dfa-49cf-91f5-dd0d9ca3ed3b"
                      }
                    },
                    "type": "object"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "400": {
            "description": "Invalid tag value"
          }
        },
        "security": [
          {
            "token": []
          }
        ]
      }
    },
    "/workspace/users/invite": {
      "post": {
        "tags": [
          "Workspace"
        ],
        "summary": "Create workspaces from csv a document",
        "description": "",
        "operationId": "inviteUserWorkspace",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "workspace": {
                    "properties": {
                      "uuid": {
                        "type": "string",
                        "example": "9596deed-feee-458a-9757-9ecd494fe889"
                      },
                      "email": {
                        "type": "string",
                        "example": "john@acme.com"
                      },
                      "firstname": {
                        "type": "string",
                        "example": "John"
                      },
                      "lastname": {
                        "type": "string",
                        "example": "Doe"
                      }
                    },
                    "type": "object"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "400": {
            "description": "Invalid tag value"
          }
        },
        "security": [
          {
            "token": []
          }
        ]
      }
    },
    "/meeting/create": {
      "post": {
        "tags": [
          "Meeting"
        ],
        "summary": "create a meeting",
        "description": "",
        "operationId": "createMeeting",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "meeting": {
                    "properties": {
                      "name": {
                        "type": "string",
                        "example": "Acme Inc."
                      },
                      "description": {
                        "type": "string",
                        "example": "description"
                      },
                      "subtitle": {
                        "type": "string",
                        "example": "subtitle"
                      },
                      "short_description": {
                        "type": "string",
                        "example": "short description"
                      },
                      "publich_hash": {
                        "type": "string",
                        "example": ""
                      },
                      "type": {
                        "type": "string",
                        "enum": [
                          "call",
                          "conference",
                          "broadcast"
                        ]
                      },
                      "is_public": {
                        "type": "boolean",
                        "example": "false"
                      },
                      "workspace_id": {
                        "type": "string",
                        "example": "_"
                      },
                      "password": {
                        "type": "string",
                        "example": "R:F_|65w'l>)82Gf"
                      },
                      "start_time": {
                        "type": "string",
                        "example": "2021-03-10 21:59:48"
                      },
                      "duration": {
                        "type": "integer",
                        "example": "300"
                      },
                      "role": {
                        "properties": {
                          "id": {
                            "type": "string",
                            "example": "2"
                          },
                          "value": {
                            "type": "integer",
                            "example": "10"
                          },
                          "name": {
                            "type": "string",
                            "example": "Owner"
                          }
                        },
                        "type": "object"
                      }
                    },
                    "type": "object"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "400": {
            "description": "Invalid tag value"
          }
        },
        "security": [
          {
            "token": []
          }
        ]
      }
    },
    "/calendar/zapier/add": {
      "post": {
        "tags": [
          "Calendar"
        ],
        "summary": "add entry to a Calendar",
        "description": "",
        "operationId": "calendarSwagerLume",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "calendar": {
                    "properties": {
                      "uuid": {
                        "type": "string",
                        "example": "bfd65d5b-4dfa-49cf-91f5-dd0d9ca3ed3b"
                      },
                      "user": {
                        "properties": {
                          "email": {
                            "type": "string",
                            "example": "test@gmail.com"
                          },
                          "firstname": {
                            "type": "string",
                            "example": "test"
                          },
                          "lastname": {
                            "type": "string",
                            "example": "test"
                          }
                        },
                        "type": "object"
                      },
                      "entry": {
                        "properties": {
                          "table": {
                            "type": "string",
                            "example": "meeting"
                          },
                          "data": {
                            "properties": {
                              "name": {
                                "type": "string",
                                "example": "Meeting 1"
                              }
                            },
                            "type": "object"
                          }
                        },
                        "type": "object"
                      }
                    },
                    "type": "object"
                  }
                },
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "successful operation"
          },
          "400": {
            "description": "Invalid tag value"
          }
        },
        "security": [
          {
            "token": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "api_key_security_example": {
        "type": "apiKey",
        "description": "A short description for security scheme",
        "name": "token",
        "in": "header"
      }
    }
  }
}