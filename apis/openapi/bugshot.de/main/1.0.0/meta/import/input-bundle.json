{
  "openapi": "3.0.3",
  "info": {
    "title": "BugShot API",
    "description": "BugShot bug tracking API for Zapier integration, supporting bug management, comments, status updates, and project management.",
    "version": "1.0.0",
    "contact": {
      "name": "BugShot",
      "url": "https://dev-interface-zapier.bugshot.de/request-docs"
    },
    "x-jentic-source-url": "https://raw.githubusercontent.com/aislingbyrnemc-sudo/openapis-specs/refs/heads/import/bugshot.de/bugshot/1.0.0/openapi.json"
  },
  "servers": [
    {
      "url": "https://dev-interface-zapier.bugshot.de",
      "description": "Production server"
    }
  ],
  "paths": {
    "/api/zapier/action/create-bug": {
      "post": {
        "operationId": "createBug",
        "summary": "Create Bug",
        "description": "Create a new bug report.",
        "tags": [
          "Bugs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBugRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bug created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bug"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/action/get-bugs-of-status": {
      "post": {
        "operationId": "getBugsOfStatus",
        "summary": "Get Bugs of Status",
        "description": "List bugs filtered by status.",
        "tags": [
          "Bugs"
        ],
        "responses": {
          "200": {
            "description": "List of bugs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Bug"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/action/get-comments": {
      "post": {
        "operationId": "getComments",
        "summary": "Get Comments",
        "description": "Get comments for a specific bug.",
        "tags": [
          "Comments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "bug_id"
                ],
                "properties": {
                  "bug_id": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comments list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/action/get-status-of-bug": {
      "post": {
        "operationId": "getBugStatus",
        "summary": "Get Bug Status",
        "description": "Get the current status of a bug.",
        "tags": [
          "Bugs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "bug_id"
                ],
                "properties": {
                  "bug_id": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bug status"
          }
        }
      }
    },
    "/api/zapier/action/get-users": {
      "post": {
        "operationId": "getUsers",
        "summary": "Get Users",
        "description": "Get list of project users.",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Users list"
          }
        }
      }
    },
    "/api/zapier/action/get-whole-project": {
      "post": {
        "operationId": "getWholeProject",
        "summary": "Get Whole Project",
        "description": "Get complete project data.",
        "tags": [
          "Projects"
        ],
        "responses": {
          "200": {
            "description": "Complete project data"
          }
        }
      }
    },
    "/api/zapier/action/invite-users": {
      "post": {
        "operationId": "inviteUsers",
        "summary": "Invite Users",
        "description": "Invite users to the project.",
        "tags": [
          "Users"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "users": {
                    "type": "string"
                  },
                  "role": {
                    "type": "integer",
                    "minimum": 2,
                    "maximum": 3
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invitation sent"
          }
        }
      }
    },
    "/api/zapier/action/search-bug": {
      "post": {
        "operationId": "searchBug",
        "summary": "Search Bug",
        "description": "Search for bugs by designation.",
        "tags": [
          "Bugs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "bug_designation"
                ],
                "properties": {
                  "bug_designation": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matching bugs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Bug"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/action/search-status": {
      "post": {
        "operationId": "searchStatus",
        "summary": "Search Status",
        "description": "Search for statuses by designation.",
        "tags": [
          "Statuses"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "status_designation"
                ],
                "properties": {
                  "status_designation": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matching statuses"
          }
        }
      }
    },
    "/api/zapier/action/update-bug-comment": {
      "post": {
        "operationId": "updateBugComment",
        "summary": "Update Bug Comment",
        "description": "Add or update a comment on a bug.",
        "tags": [
          "Comments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "bug_id",
                  "content"
                ],
                "properties": {
                  "bug_id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "content": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comment updated"
          }
        }
      }
    },
    "/api/zapier/action/update-bug-info": {
      "post": {
        "operationId": "updateBugInfo",
        "summary": "Update Bug Info",
        "description": "Update bug details.",
        "tags": [
          "Bugs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "bug_id"
                ],
                "properties": {
                  "bug_id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "designation": {
                    "type": "string",
                    "maxLength": 70
                  },
                  "description": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "operating_system": {
                    "type": "string"
                  },
                  "browser": {
                    "type": "string"
                  },
                  "resolution": {
                    "type": "string"
                  },
                  "deadline": {
                    "type": "string",
                    "format": "date"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bug updated"
          }
        }
      }
    },
    "/api/zapier/action/update-bug-sc": {
      "post": {
        "operationId": "updateBugScreenshot",
        "summary": "Update Bug Screenshot",
        "description": "Update a bug's screenshot.",
        "tags": [
          "Bugs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "bug_id",
                  "base64"
                ],
                "properties": {
                  "bug_id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "position_x": {
                    "type": "number"
                  },
                  "position_y": {
                    "type": "number"
                  },
                  "base64": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Screenshot updated"
          }
        }
      }
    },
    "/api/zapier/action/update-bug-status": {
      "post": {
        "operationId": "updateBugStatus",
        "summary": "Update Bug Status",
        "description": "Change the status of a bug.",
        "tags": [
          "Bugs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "bug_id"
                ],
                "properties": {
                  "bug_id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "order_id": {
                    "type": "integer"
                  },
                  "status_id": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status changed"
          }
        }
      }
    },
    "/api/zapier/action/update-project-info": {
      "post": {
        "operationId": "updateProjectInfo",
        "summary": "Update Project Info",
        "description": "Update project details.",
        "tags": [
          "Projects"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "designation"
                ],
                "properties": {
                  "designation": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 70
                  },
                  "url": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project updated"
          }
        }
      }
    },
    "/api/zapier/trigger/bug-created": {
      "post": {
        "operationId": "triggerBugCreated",
        "summary": "Bug Created Trigger",
        "description": "Trigger when a bug is created.",
        "tags": [
          "Triggers"
        ],
        "responses": {
          "200": {
            "description": "Bug created event",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bug"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/trigger/bug-updated-comment": {
      "post": {
        "operationId": "triggerBugUpdatedComment",
        "summary": "Bug Comment Updated Trigger",
        "tags": [
          "Triggers"
        ],
        "responses": {
          "200": {
            "description": "Comment updated event"
          }
        }
      }
    },
    "/api/zapier/trigger/bug-updated-info": {
      "post": {
        "operationId": "triggerBugUpdatedInfo",
        "summary": "Bug Info Updated Trigger",
        "tags": [
          "Triggers"
        ],
        "responses": {
          "200": {
            "description": "Bug info updated event"
          }
        }
      }
    },
    "/api/zapier/trigger/bug-updated-sc": {
      "post": {
        "operationId": "triggerBugUpdatedScreenshot",
        "summary": "Bug Screenshot Updated Trigger",
        "tags": [
          "Triggers"
        ],
        "responses": {
          "200": {
            "description": "Screenshot updated event"
          }
        }
      }
    },
    "/api/zapier/trigger/bug-updated-status": {
      "post": {
        "operationId": "triggerBugUpdatedStatus",
        "summary": "Bug Status Updated Trigger",
        "tags": [
          "Triggers"
        ],
        "responses": {
          "200": {
            "description": "Status updated event"
          }
        }
      }
    },
    "/api/zapier/trigger/project-updated-info": {
      "post": {
        "operationId": "triggerProjectUpdatedInfo",
        "summary": "Project Info Updated Trigger",
        "tags": [
          "Triggers"
        ],
        "responses": {
          "200": {
            "description": "Project updated event"
          }
        }
      }
    },
    "/api/zapier/get-sample-data/{action}": {
      "get": {
        "operationId": "getSampleData",
        "summary": "Get Sample Data",
        "description": "Get sample payload for a specified action.",
        "tags": [
          "Utility"
        ],
        "parameters": [
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sample data"
          }
        }
      }
    },
    "/api/zapier/subscription/{action}": {
      "post": {
        "operationId": "subscribeWebhook",
        "summary": "Subscribe to Webhook",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "webhook_url"
                ],
                "properties": {
                  "webhook_url": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscribed"
          }
        }
      },
      "delete": {
        "operationId": "unsubscribeWebhook",
        "summary": "Unsubscribe from Webhook",
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "action",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "webhook_url"
                ],
                "properties": {
                  "webhook_url": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Unsubscribed"
          }
        }
      }
    },
    "/api/zapier/test": {
      "get": {
        "operationId": "testConnection",
        "summary": "Test Connection",
        "description": "Test the API connection.",
        "tags": [
          "Utility"
        ],
        "responses": {
          "200": {
            "description": "Connection successful"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "Bug": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "designation": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "priority_id": {
            "type": "integer"
          },
          "operating_system": {
            "type": "string"
          },
          "browser": {
            "type": "string"
          },
          "resolution": {
            "type": "string"
          },
          "deadline": {
            "type": "string",
            "format": "date"
          },
          "order_number": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateBugRequest": {
        "type": "object",
        "required": [
          "designation",
          "priority_id"
        ],
        "properties": {
          "designation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 70
          },
          "description": {
            "type": "string",
            "maxLength": 1500
          },
          "url": {
            "type": "string"
          },
          "priority_id": {
            "type": "integer",
            "minimum": 1,
            "maximum": 4
          },
          "operating_system": {
            "type": "string"
          },
          "browser": {
            "type": "string"
          },
          "selector": {
            "type": "string"
          },
          "resolution": {
            "type": "string"
          },
          "deadline": {
            "type": "string",
            "format": "date"
          },
          "order_number": {
            "type": "integer"
          }
        }
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}