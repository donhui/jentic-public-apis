  "components": {
    "schemas": {
      "ZonesResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "zones": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Zone"
                }
              }
            }
          }
        }
      },
      "ZoneResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "zone": {
                "$ref": "#/components/schemas/Zone"
              }
            }
          }
        }
      },
      "Zone": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "pull",
              "push"
            ]
          },
          "originurl": {
            "type": "string"
          },
          "expire": {
            "type": "integer"
          },
          "gzip": {
            "type": "boolean"
          },
          "cors": {
            "type": "boolean"
          },
          "securetoken": {
            "type": "boolean"
          },
          "forcessl": {
            "type": "boolean"
          }
        }
      },
      "ZoneInput": {
        "type": "object",
        "required": [
          "name",
          "type"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "pull",
              "push"
            ]
          },
          "originurl": {
            "type": "string"
          },
          "expire": {
            "type": "integer"
          },
          "gzip": {
            "type": "boolean"
          },
          "cors": {
            "type": "boolean"
          },
          "securetoken": {
            "type": "boolean"
          },
          "forcessl": {
            "type": "boolean"
          }
        }
      },
      "PurgeUrlRequest": {
        "type": "object",
        "properties": {
          "urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ZoneAliasesResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "zonealiases": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ZoneAlias"
                }
              }
            }
          }
        }
      },
      "ZoneAlias": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "zone_id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ZoneAliasInput": {
        "type": "object",
        "required": [
          "zone_id",
          "name"
        ],
        "properties": {
          "zone_id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ReportResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth with API key as username and empty password"
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ]
}