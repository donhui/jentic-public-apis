{
  "openapi": "3.0.3",
  "info": {
    "title": "KeyCDN API",
    "version": "1.0.0",
    "description": "KeyCDN management API for managing CDN zones, zone aliases, zone referrers, cache purging, and reporting. Uses HTTP Basic Auth with API key.",
    "x-jentic-source-url": "https://www.keycdn.com/api"
  },
  "servers": [
    {
      "url": "https://api.keycdn.com"
    }
  ],
  "paths": {
    "/zones.json": {
      "get": {
        "operationId": "listZones",
        "summary": "List all zones",
        "tags": [
          "Zones"
        ],
        "responses": {
          "200": {
            "description": "List of zones",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZonesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createZone",
        "summary": "Create a new zone",
        "tags": [
          "Zones"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ZoneInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Zone created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZoneResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/zones/{zoneId}.json": {
      "get": {
        "operationId": "getZone",
        "summary": "Get a zone",
        "tags": [
          "Zones"
        ],
        "parameters": [
          {
            "name": "zoneId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Zone details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZoneResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "put": {
        "operationId": "updateZone",
        "summary": "Update a zone",
        "tags": [
          "Zones"
        ],
        "parameters": [
          {
            "name": "zoneId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ZoneInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Zone updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZoneResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteZone",
        "summary": "Delete a zone",
        "tags": [
          "Zones"
        ],
        "parameters": [
          {
            "name": "zoneId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Zone deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/zones/purge/{zoneId}.json": {
      "get": {
        "operationId": "purgeZoneCache",
