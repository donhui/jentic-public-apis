  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key obtained from https://app.transkriptor.com/account"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "TranscriptionSegment": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Transcribed text content"
          },
          "StartTime": {
            "type": "integer",
            "description": "Start timestamp in milliseconds"
          },
          "EndTime": {
            "type": "integer",
            "description": "End timestamp in milliseconds"
          },
          "VoiceStart": {
            "type": "integer",
            "description": "Voice start timestamp in milliseconds"
          },
          "VoiceEnd": {
            "type": "integer",
            "description": "Voice end timestamp in milliseconds"
          },
          "Speaker": {
            "type": "string",
            "description": "Speaker identifier (e.g., SPK_1)"
          }
        }
      },
      "Meeting": {
        "type": "object",
        "properties": {
          "event_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "date": {
            "type": "number",
            "description": "Timestamp"
          },
          "status": {
            "type": "string"
          },
          "video_url": {
            "type": "string"
          },
          "transcription_order_id": {
            "type": "string"
          },
          "meeting_settings": {
            "type": "object",
            "properties": {
              "auto_join_microsoft": {
                "type": "boolean"
              },
              "meeting_bot_name": {
                "type": "string"
              },
              "meetingtor_auto_transcribe": {
                "type": "boolean"
              },
              "delete_after_14_days": {
                "type": "boolean"
              },
              "ai_summary_template_id": {
                "type": "string"
              },
              "meeting_language": {
                "type": "string"
              },
              "join_direction": {
                "type": "string"
              },
              "join_minutes": {
                "type": "string"
              },
              "keep_video": {
                "type": "boolean"
              },
              "meetingtor_auto_join_option": {
                "type": "string"
              },
              "keep_audio": {
                "type": "boolean"
              },
              "meetingtor_share_settings": {
                "type": "string"
              },
              "keep_transcript": {
                "type": "boolean"
              },
              "auto_join_google": {
                "type": "boolean"
              },
              "keep_summary": {
                "type": "boolean"
              },
              "meetingtor_auto_transcribe_language": {
                "type": "string"
              }
            }
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "HashedId": {
            "type": "string"
          },
          "webhookType": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "exportFormat": {
            "type": "string"
          },
          "includeTimestamps": {
            "type": "boolean"
          },
          "includeSpeakerNames": {
            "type": "boolean"
          },
          "mergeSameSpeakerSegments": {
            "type": "boolean"
          },
          "isSingleParagraph": {
            "type": "boolean"
          },
          "paragraphSize": {
            "type": "integer"
          },
          "folderId": {
            "type": "string"
          }
        }
      },
      "Knowledgebase": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Transcription",
      "description": "Transcribe audio/video from local files, URLs, or live meetings"
    },
    {
      "name": "Files",
      "description": "Manage transcription files and folders"
    },
    {
      "name": "Meetings",
      "description": "Manage meeting transcriptions"
    },
    {
      "name": "Users",
      "description": "User account operations"
    },
    {
      "name": "Webhooks",
      "description": "Manage webhook notifications for transcription events"
    },
    {
      "name": "Advanced",
      "description": "Custom vocabulary and advanced features"
    },
