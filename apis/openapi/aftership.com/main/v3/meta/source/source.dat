  "components": {
    "schemas": {
      "EnvelopeResponse": {
        "type": "object",
        "description": "Standard API response envelope.",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "object",
            "description": "Response data."
          }
        }
      },
      "Meta": {
        "type": "object",
        "description": "Response metadata.",
        "properties": {
          "code": {
            "type": "integer",
            "description": "HTTP status code."
          },
          "message": {
            "type": "string",
            "description": "Status message."
          },
          "type": {
            "type": "string",
            "description": "Response type."
          }
        }
      },
      "RateCalculationRequest": {
        "type": "object",
        "description": "Request to calculate shipping rates.",
        "properties": {
          "shipper_accounts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Shipper account ID."
                }
              }
            },
            "description": "List of shipper accounts to calculate rates for."
          },
          "shipment": {
            "$ref": "#/components/schemas/Shipment"
          }
        },
        "required": ["shipper_accounts", "shipment"]
      },
      "RateResponse": {
        "type": "object",
        "description": "Rate calculation response.",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "object",
            "properties": {
              "rates": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Rate"
                }
              }
            }
          }
        }
      },
      "RatesListResponse": {
        "type": "object",
        "description": "List of rates response.",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "object",
            "properties": {
              "rates": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Rate"
                }
              }
            }
          }
        }
      },
      "Rate": {
        "type": "object",
        "description": "A shipping rate.",
        "properties": {
          "service_type": {
            "type": "string"
          },
          "service_name": {
            "type": "string"
          },
          "total_charge": {
            "$ref": "#/components/schemas/Money"
          }
        }
      },
      "LabelCreateRequest": {
        "type": "object",
        "description": "Request to create a shipping label.",
        "properties": {
          "shipper_account": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Shipper account ID."
              }
            }
          },
          "service_type": {
            "type": "string",
            "description": "Service type for the label."
          },
          "shipment": {
            "$ref": "#/components/schemas/Shipment"
          }
        },
        "required": ["shipper_account", "service_type", "shipment"]
      },
      "LabelResponse": {
        "type": "object",
        "description": "Label response.",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "tracking_numbers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "files": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "object",
                    "properties": {
                      "paper_size": {
                        "type": "string"
                      },
                      "url": {
                        "type": "string",
                        "format": "uri"
                      },
                      "file_type": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "LabelsListResponse": {
        "type": "object",
        "description": "List of labels response.",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "type": "object",
            "properties": {
              "labels": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/LabelResponse"
                }
              }
            }
          }
        }
      },
      "Shipment": {
        "type": "object",
        "description": "Shipment details.",
        "properties": {
          "ship_from": {
            "$ref": "#/components/schemas/Address"
          },
          "ship_to": {
            "$ref": "#/components/schemas/Address"
          },
          "parcels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Parcel"
            }
          }
        },
        "required": ["ship_from", "ship_to", "parcels"]
      },
      "Address": {
        "type": "object",
        "description": "Shipping address.",
        "properties": {
          "contact_name": {
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "street1": {
            "type": "string"
          },
          "street2": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "postal_code": {
            "type": "string"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-3 country code."
          },
          "phone": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": ["street1", "city", "country"]
      },
      "Parcel": {
        "type": "object",
        "description": "Parcel details.",
        "properties": {
          "description": {
            "type": "string"
          },
          "box_type": {
            "type": "string"
          },
          "weight": {
            "$ref": "#/components/schemas/Weight"
          },
          "dimension": {
            "$ref": "#/components/schemas/Dimension"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            }
          }
        },
        "required": ["weight"]
      },
      "Weight": {
        "type": "object",
        "properties": {
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string",
            "enum": ["kg", "lb", "oz", "g"]
          }
        },
        "required": ["value", "unit"]
      },
      "Dimension": {
        "type": "object",
        "properties": {
          "width": {
            "type": "number"
          },
          "height": {
            "type": "number"
          },
          "depth": {
            "type": "number"
          },
          "unit": {
            "type": "string",
            "enum": ["cm", "in", "mm", "m"]
          }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "integer"
          },
          "price": {
            "$ref": "#/components/schemas/Money"
          },
          "weight": {
            "$ref": "#/components/schemas/Weight"
          }
        }
      },
      "Money": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code."
          }
        }
      },
      "ShipperAccountRequest": {
        "type": "object",
        "description": "Shipper account creation/update request.",
        "properties": {
          "slug": {
            "type": "string",
            "description": "Courier slug identifier."
          },
          "description": {
            "type": "string"
          },
          "credentials": {
            "type": "object",
            "description": "Carrier-specific credentials.",
            "additionalProperties": true
          }
        }
      },
      "AddressValidationRequest": {
        "type": "object",
        "description": "Address validation request.",
        "properties": {
          "address": {
            "$ref": "#/components/schemas/Address"
          }
        },
        "required": ["address"]
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "as-api-key",
        "description": "AfterShip Shipping API key. Generate from the AfterShip Shipping admin settings page."
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}
