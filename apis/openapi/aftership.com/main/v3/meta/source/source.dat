{
  "openapi": "3.0.3",
  "info": {
    "title": "AfterShip Shipping API",
    "version": "v3",
    "description": "AfterShip Shipping (formerly Postmen) API for calculating rates, generating labels, creating manifests, and managing shipments across multiple couriers. Integrates multiple carrier APIs into one unified interface.",
    "x-jentic-source-url": "https://www.aftership.com/docs/postmen/quickstart/api-quick-start"
  },
  "servers": [
    {
      "url": "https://api.aftership.com/shipping/v3"
    }
  ],
  "paths": {
    "/rates": {
      "get": {
        "operationId": "getRates",
        "summary": "Get rates",
        "description": "Retrieve a list of previously calculated shipping rates.",
        "tags": ["Rates"],
        "responses": {
          "200": {
            "description": "List of rates returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RatesListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          },
          "401": {
            "description": "Unauthorized. Invalid or missing API key."
          }
        }
      },
      "post": {
        "operationId": "calculateRates",
        "summary": "Calculate rates",
        "description": "Calculate shipping rates for a shipment across one or more couriers.",
        "tags": ["Rates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RateCalculationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rates calculated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Missing or invalid fields."
          },
          "401": {
            "description": "Unauthorized. Invalid or missing API key."
          }
        }
      }
    },
    "/rates/{rateId}": {
      "get": {
        "operationId": "getRate",
        "summary": "Get a rate",
        "description": "Retrieve a specific rate calculation by ID.",
        "tags": ["Rates"],
        "parameters": [
          {
            "name": "rateId",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the rate.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Rate details returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          },
          "401": {
            "description": "Unauthorized."
          }
        }
      }
    },
    "/labels": {
      "get": {
