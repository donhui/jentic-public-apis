{
  "openapi": "3.0.3",
  "info": {
    "title": "Nyckel API",
    "description": "Nyckel Machine Learning API for classification, tagging, search, detection, and OCR. Classify images and text in minutes.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.nyckel.com/docs",
    "contact": {
      "name": "Nyckel",
      "url": "https://www.nyckel.com"
    }
  },
  "servers": [
    {
      "url": "https://www.nyckel.com",
      "description": "Nyckel Production API"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "OAuth2 token management" },
    { "name": "Classification", "description": "Invoke classification functions" },
    { "name": "Fields", "description": "Manage function fields" },
    { "name": "Labels", "description": "Manage function labels" },
    { "name": "Samples", "description": "Manage training samples" },
    { "name": "Annotations", "description": "Manage sample annotations" },
    { "name": "Functions", "description": "Function summary and metadata" },
    { "name": "Search", "description": "Search via text or image" },
    { "name": "Detection", "description": "Object detection in images" },
    { "name": "OCR", "description": "Optical character recognition" }
  ],
  "paths": {
    "/connect/token": {
      "post": {
        "operationId": "createAccessToken",
        "summary": "Create access token",
        "description": "Obtain a bearer token using client credentials",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "client_id", "client_secret"],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": ["client_credentials"]
                  },
                  "client_id": {
                    "type": "string",
                    "description": "OAuth2 client ID"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "OAuth2 client secret"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/v1/functions/{functionId}/invoke": {
      "post": {
        "operationId": "invokeFunction",
        "summary": "Invoke classification function",
        "description": "Classify text, image, or tabular data using a trained function",
        "tags": ["Classification"],
        "parameters": [
          {
            "name": "functionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "labelCount",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Number of label predictions to return"
          },
          {
            "name": "includeMetadata",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "Include label metadata in response"
          },
          {
            "name": "capture",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "Capture the input as a sample"
          },
          {
            "name": "externalId",
            "in": "query",
            "schema": { "type": "string" },
            "description": "External ID for the captured sample"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InvokeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Classification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvokeResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Rate limit exceeded" }
        }
      }
    },
    "/v1/functions/{functionId}/fields": {
      "get": {
        "operationId": "listFields",
        "summary": "List fields",
        "tags": ["Fields"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "count", "in": "query", "schema": { "type": "integer" } },
          { "name": "startIndex", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of fields",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Field" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createField",
        "summary": "Create field",
        "tags": ["Fields"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FieldCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Field created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Field" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/fields/{fieldId}": {
      "get": {
        "operationId": "readField",
        "summary": "Read field",
        "tags": ["Fields"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "fieldId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Field details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Field" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateField",
        "summary": "Update field",
        "tags": ["Fields"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "fieldId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FieldCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Field updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Field" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteField",
        "summary": "Delete field",
        "tags": ["Fields"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "fieldId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Field deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/labels": {
      "get": {
        "operationId": "listLabels",
        "summary": "List labels",
        "tags": ["Labels"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of labels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Label" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createLabel",
        "summary": "Create label",
        "tags": ["Labels"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LabelCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Label created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Label" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/labels/{labelId}": {
      "get": {
        "operationId": "readLabel",
        "summary": "Read label",
        "tags": ["Labels"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "labelId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Label details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Label" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateLabel",
        "summary": "Update label",
        "tags": ["Labels"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "labelId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LabelCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Label updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Label" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteLabel",
        "summary": "Delete label",
        "tags": ["Labels"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "labelId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Label deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/samples": {
      "get": {
        "operationId": "listSamples",
        "summary": "List samples",
        "tags": ["Samples"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "count", "in": "query", "schema": { "type": "integer" } },
          { "name": "startIndex", "in": "query", "schema": { "type": "integer" } },
          { "name": "externalId", "in": "query", "schema": { "type": "string" } },
          { "name": "createdBefore", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "createdAfter", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "origin", "in": "query", "schema": { "type": "string" } },
          { "name": "annotated", "in": "query", "schema": { "type": "boolean" } },
          { "name": "predicted", "in": "query", "schema": { "type": "boolean" } },
          { "name": "annotationLabelId", "in": "query", "schema": { "type": "string" } },
          { "name": "predictionLabelId", "in": "query", "schema": { "type": "string" } },
          { "name": "predictionAndAnnotationAgree", "in": "query", "schema": { "type": "boolean" } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string" } },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] } }
        ],
        "responses": {
          "200": {
            "description": "List of samples",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Sample" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createSample",
        "summary": "Create sample",
        "description": "Create a text, image, or tabular sample",
        "tags": ["Samples"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SampleCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sample created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sample" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/samples/{sampleId}": {
      "get": {
        "operationId": "readSample",
        "summary": "Read sample",
        "tags": ["Samples"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "sampleId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Sample details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Sample" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteSample",
        "summary": "Delete sample",
        "tags": ["Samples"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "sampleId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Sample deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/samples/{sampleId}/annotation": {
      "put": {
        "operationId": "annotateSample",
        "summary": "Annotate sample",
        "tags": ["Annotations"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "sampleId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AnnotationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Annotation set",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Annotation" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "removeAnnotation",
        "summary": "Remove annotation",
        "tags": ["Annotations"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "sampleId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Annotation removed" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/summary": {
      "get": {
        "operationId": "getFunctionSummary",
        "summary": "Get function summary",
        "tags": ["Functions"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Function summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FunctionSummary" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/search": {
      "post": {
        "operationId": "searchFunction",
        "summary": "Search via text or image",
        "tags": ["Search"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/InvokeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/SearchResult" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/locate": {
      "post": {
        "operationId": "locateObjects",
        "summary": "Locate objects in image",
        "tags": ["Detection"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/InvokeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Detection results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DetectionResult" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/functions/{functionId}/ocr-image": {
      "post": {
        "operationId": "ocrImage",
        "summary": "Extract text from image",
        "tags": ["OCR"],
        "parameters": [
          { "name": "functionId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/InvokeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OCR results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OcrResult" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained via OAuth2 client credentials flow at /connect/token"
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "token_type": { "type": "string", "example": "Bearer" },
          "expires_in": { "type": "integer", "description": "Token expiry in seconds" }
        }
      },
      "InvokeRequest": {
        "type": "object",
        "properties": {
          "data": {
            "description": "Text string, image URL, data URI, or tabular JSON object"
          }
        }
      },
      "InvokeResponse": {
        "type": "object",
        "properties": {
          "labelName": { "type": "string" },
          "labelId": { "type": "string" },
          "confidence": { "type": "number", "format": "double" },
          "labelConfidences": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LabelConfidence" }
          },
          "labelMetadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "LabelConfidence": {
        "type": "object",
        "properties": {
          "labelName": { "type": "string" },
          "labelId": { "type": "string" },
          "confidence": { "type": "number", "format": "double" }
        }
      },
      "Field": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["Text", "Number", "Image"] }
        }
      },
      "FieldCreate": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["Text", "Number", "Image"] }
        }
      },
      "Label": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "metadata": { "type": "object", "additionalProperties": true }
        }
      },
      "LabelCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "metadata": { "type": "object", "additionalProperties": true }
        }
      },
      "Sample": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "data": { "description": "Text, image URL, or tabular data" },
          "externalId": { "type": "string" },
          "annotation": { "$ref": "#/components/schemas/Annotation" }
        }
      },
      "SampleCreate": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": { "description": "Text string, image URL/data URI, or tabular JSON object" },
          "externalId": { "type": "string" },
          "annotation": {
            "type": "object",
            "properties": {
              "labelId": { "type": "string" },
              "labelName": { "type": "string" }
            }
          }
        }
      },
      "Annotation": {
        "type": "object",
        "properties": {
          "labelId": { "type": "string" }
        }
      },
      "AnnotationRequest": {
        "type": "object",
        "properties": {
          "labelId": { "type": "string" },
          "labelName": { "type": "string" }
        }
      },
      "FunctionSummary": {
        "type": "object",
        "properties": {
          "sampleCount": { "type": "integer" },
          "annotatedSampleCount": { "type": "integer" },
          "annotatedSampleCountByLabelId": {
            "type": "object",
            "additionalProperties": { "type": "integer" }
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "sampleId": { "type": "string" },
