{
  "openapi": "3.0.3",
  "info": {
    "title": "Rarible NFT API",
    "description": "Multi-chain NFT API providing unified access to NFT items, collections, activities, metadata, orders, and analytics across multiple blockchains.",
    "version": "0.1.0",
    "x-jentic-source-url": "https://docs.rarible.org/"
  },
  "servers": [
    {
      "url": "https://api.rarible.org/v0.1",
      "description": "Rarible API v0.1"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {"name": "Items", "description": "NFT item operations"},
    {"name": "Collections", "description": "NFT collection operations"},
    {"name": "Orders", "description": "Order and trading operations"},
    {"name": "Search", "description": "Search operations"},
    {"name": "Analytics", "description": "Analytics and statistics"}
  ],
  "paths": {
    "/items/search": {
      "post": {
        "operationId": "searchItems",
        "summary": "Search NFTs",
        "description": "Search NFT items across supported blockchains.",
        "tags": ["Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/ItemSearchRequest"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ItemList"}
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/ownerships/search": {
      "post": {
        "operationId": "searchOwnerships",
        "summary": "Search NFT ownerships",
        "description": "Search NFT ownership records.",
        "tags": ["Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"type": "object"}
            }
          }
        },
        "responses": {
          "200": {"description": "Ownership search results"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/activities/search": {
      "post": {
        "operationId": "searchActivities",
        "summary": "Search activities",
        "description": "Search NFT activities such as transfers, sales, and listings.",
        "tags": ["Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"type": "object"}
            }
          }
        },
        "responses": {
          "200": {"description": "Activity search results"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/collections/search": {
      "post": {
        "operationId": "searchCollections",
        "summary": "Search NFT collections",
        "description": "Search NFT collections across supported blockchains.",
        "tags": ["Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"type": "object"}
            }
          }
        },
        "responses": {
          "200": {"description": "Collection search results"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/items/{itemId}": {
      "get": {
        "operationId": "getItemById",
        "summary": "Get NFT item by ID",
        "description": "Retrieve a specific NFT item by its ID.",
        "tags": ["Items"],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "NFT item ID (blockchain:contract:tokenId)"
          }
        ],
        "responses": {
          "200": {
            "description": "NFT item details",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/Item"}
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Item not found"}
        }
      }
    },
    "/items/byIds": {
      "post": {
        "operationId": "getItemsByIds",
        "summary": "Get NFT items by IDs",
        "description": "Retrieve multiple NFT items by their IDs.",
        "tags": ["Items"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "NFT items",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ItemList"}
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/items/byOwner": {
      "get": {
        "operationId": "getItemsByOwner",
        "summary": "Get NFTs by owner",
        "description": "Retrieve NFT items owned by a specific address.",
        "tags": ["Items"],
        "parameters": [
          {
            "name": "owner",
            "in": "query",
            "required": true,
            "schema": {"type": "string"},
            "description": "Owner address"
          },
          {"$ref": "#/components/parameters/ContinuationParam"},
          {"$ref": "#/components/parameters/SizeParam"}
        ],
        "responses": {
          "200": {
            "description": "NFT items",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ItemList"}
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/items/byCreator": {
      "get": {
        "operationId": "getItemsByCreator",
        "summary": "Get NFTs by creator",
        "description": "Retrieve NFT items created by a specific address.",
        "tags": ["Items"],
        "parameters": [
          {
            "name": "creator",
            "in": "query",
            "required": true,
            "schema": {"type": "string"},
            "description": "Creator address"
          },
          {"$ref": "#/components/parameters/ContinuationParam"},
          {"$ref": "#/components/parameters/SizeParam"}
        ],
        "responses": {
          "200": {"description": "NFT items"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/items/byCollection": {
      "get": {
        "operationId": "getItemsByCollection",
        "summary": "Get NFTs by collection",
        "description": "Retrieve NFT items from a specific collection.",
        "tags": ["Items"],
        "parameters": [
          {
            "name": "collection",
            "in": "query",
            "required": true,
            "schema": {"type": "string"},
            "description": "Collection ID"
          },
          {"$ref": "#/components/parameters/ContinuationParam"},
          {"$ref": "#/components/parameters/SizeParam"}
        ],
        "responses": {
          "200": {"description": "NFT items"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/items/{itemId}/royalties": {
      "get": {
        "operationId": "getItemRoyaltiesById",
        "summary": "Get item royalties",
        "description": "Retrieve royalty information for an NFT item.",
        "tags": ["Items"],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Royalty information"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Item not found"}
        }
      }
    },
    "/orders/{orderId}": {
      "get": {
        "operationId": "getOrderById",
        "summary": "Get order by ID",
        "description": "Retrieve order details by order ID.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Order ID"
          }
        ],
        "responses": {
          "200": {"description": "Order details"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Order not found"}
        }
      }
    },
    "/orders/prepare": {
      "post": {
        "operationId": "prepareOrderTransaction",
        "summary": "Prepare order transaction",
        "description": "Prepare a sale or bid transaction.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"type": "object"}
            }
          }
        },
        "responses": {
          "200": {"description": "Prepared transaction"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/orders": {
      "post": {
        "operationId": "upsertOrder",
        "summary": "Create or update order",
        "description": "Create a new order or update an existing one.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"type": "object"}
            }
          }
        },
        "responses": {
          "200": {"description": "Order created or updated"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/orders/sell/byItem": {
      "get": {
        "operationId": "getSellOrdersByItem",
        "summary": "Get sell orders by item",
        "description": "Retrieve sell orders for a specific NFT item.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "itemId",
            "in": "query",
            "required": true,
            "schema": {"type": "string"}
          },
          {"$ref": "#/components/parameters/ContinuationParam"},
          {"$ref": "#/components/parameters/SizeParam"}
        ],
        "responses": {
          "200": {"description": "Sell orders"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/orders/bids/byItem": {
      "get": {
        "operationId": "getOrderBidsByItem",
        "summary": "Get bids by item",
        "description": "Retrieve bid orders for a specific NFT item.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "itemId",
            "in": "query",
            "required": true,
            "schema": {"type": "string"}
          },
          {"$ref": "#/components/parameters/ContinuationParam"},
          {"$ref": "#/components/parameters/SizeParam"}
        ],
        "responses": {
          "200": {"description": "Bid orders"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/collections/{collectionId}": {
      "get": {
        "operationId": "getCollectionById",
        "summary": "Get collection by ID",
        "description": "Retrieve details for a specific NFT collection.",
        "tags": ["Collections"],
        "parameters": [
          {
            "name": "collectionId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"},
            "description": "Collection ID"
          }
        ],
        "responses": {
          "200": {"description": "Collection details"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Collection not found"}
        }
      }
    },
    "/collections/byOwner": {
      "get": {
        "operationId": "getCollectionsByOwner",
        "summary": "Get collections by owner",
        "description": "Retrieve collections owned by a specific address.",
        "tags": ["Collections"],
        "parameters": [
          {
            "name": "owner",
            "in": "query",
            "required": true,
            "schema": {"type": "string"},
            "description": "Owner address"
          },
          {"$ref": "#/components/parameters/ContinuationParam"},
          {"$ref": "#/components/parameters/SizeParam"}
        ],
        "responses": {
          "200": {"description": "Collections"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/analytics/users/ranking/volume": {
      "get": {
        "operationId": "getUserRankingByVolume",
        "summary": "Get user ranking by volume",
        "description": "Retrieve users ranked by transaction volume.",
        "tags": ["Analytics"],
        "parameters": [
          {"$ref": "#/components/parameters/ContinuationParam"},
          {"$ref": "#/components/parameters/SizeParam"}
        ],
        "responses": {
          "200": {"description": "User rankings"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/collections/{collectionId}/statistics": {
      "get": {
        "operationId": "getCollectionStatistics",
        "summary": "Get collection statistics",
        "description": "Retrieve statistics and metrics for a collection.",
        "tags": ["Analytics"],
        "parameters": [
          {
            "name": "collectionId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Collection statistics"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/collections/{collectionId}/floorPrice": {
      "get": {
        "operationId": "getFloorPrice",
        "summary": "Get collection floor price",
        "description": "Retrieve the floor price for a collection.",
        "tags": ["Analytics"],
        "parameters": [
          {
            "name": "collectionId",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Floor price data"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "Rarible API key"
      }
    },
    "parameters": {
      "ContinuationParam": {
        "name": "continuation",
        "in": "query",
        "schema": {"type": "string"},
        "description": "Continuation token for pagination"
      },
      "SizeParam": {
        "name": "size",
        "in": "query",
        "schema": {"type": "integer", "default": 50},
        "description": "Number of items to return"
      }
    },
    "schemas": {
      "Item": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "blockchain": {"type": "string"},
          "collection": {"type": "string"},
          "contract": {"type": "string"},
          "tokenId": {"type": "string"},
          "creators": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Creator"}
          },
          "owners": {
            "type": "array",
            "items": {"type": "string"}
          },
          "supply": {"type": "string"},
          "meta": {"$ref": "#/components/schemas/ItemMeta"}
        }
      },
      "ItemList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Item"}
          },
          "continuation": {"type": "string"}
        }
      },
      "ItemSearchRequest": {
        "type": "object",
        "properties": {
          "filter": {"type": "object"},
          "continuation": {"type": "string"},
          "size": {"type": "integer"}
        }
      },
      "Creator": {
        "type": "object",
        "properties": {
          "account": {"type": "string"},
          "value": {"type": "integer"}
        }
      },
      "ItemMeta": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"},
          "image": {"type": "string"},
          "attributes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {"type": "string"},
                "value": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}