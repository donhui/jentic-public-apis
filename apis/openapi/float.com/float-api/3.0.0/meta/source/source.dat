            "in": "path",
            "description": "client id to delete",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Delete successful, if this `client_id` is currently used in any project it will be set to `null`."
          },
          "404": {
