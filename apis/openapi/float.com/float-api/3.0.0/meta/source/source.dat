  "components": {
    "schemas": {
      "Department": {
        "type": "object",
        "required": [
          "department_id"
        ],
        "properties": {
          "department_id": {
            "type": "integer",
            "example": 123,
            "description": "The ID of this department"
          },
          "parent_id": {
            "type": "integer",
            "example": 123,
            "description": "The ID of this department's parent department (identifies this as a sub-department if not `null`)",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "example": "Engineers",
            "description": "The name of the department",
            "maxLength": 200,
            "readOnly": true
          }
        },
        "title": "Department"
      },
      "ReportsListPeople": {
        "type": "object",
        "properties": {
          "people": {
            "type": "array",
            "description": "A list of report data per person",
            "items": {
              "$ref": "#/components/schemas/ReportsPeople"
            }
          }
        }
      },
      "ReportsPeople": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Erin Riggins",
            "description": "The name of the person"
          },
          "people_id": {
            "type": "integer",
            "example": 12325,
            "description": "The person id"
          },
          "department_id": {
            "type": "integer",
            "example": 23250,
            "description": "The department id that this person belongs to"
          },
          "department": {
            "type": "string",
            "example": "Design",
            "description": "The name of the matching department"
          },
          "people_type_id": {
            "type": "integer",
            "example": 1,
            "description": "Is this person an `1` = Employee (default), `2` = Contractor, `3` = Placeholder, `4`= Role placeholder"
          },
          "wk_day_hrs": {
            "type": "object",
            "description": "(Deprecated) array of working hours per day (Sun-Sat), using the effective from date YYYY-MM-DD as the field name",
            "example": {
              "1970-01-01": [
                0,
                8,
                8,
                4,
                8,
                8,
                0
              ]
            }
          },
          "capacity": {
            "type": "number",
            "example": 152,
            "description": "Total of all work hours, based on set availability plus any non-work days if scheduled, for this person within the duration (`timeoff` & holidays reduces capacity)"
          },
          "timeoff": {
            "type": "number",
            "example": 12,
            "description": "Total of time off hours scheduled for this person within the duration"
          },
          "scheduled": {
            "type": "number",
            "example": 44,
            "description": "Total of allocated hours (`billable + nonBillable`) on the schedule for this person within the duration"
          },
          "billable": {
            "type": "number",
            "example": 40,
            "description": "Total of billable hours allocated on the schedule for this person within the duration"
          },
          "nonBillable": {
            "type": "number",
            "example": 14,
            "description": "Total of non-billable hours allocated on the schedule for this person within the duration"
          },
          "overtime": {
            "type": "number",
            "example": 2,
            "description": "Total of overtime hours allocated on the schedule for this person within the duration"
          },
          "unscheduled": {
            "type": "number",
            "example": 40,
            "description": "Total of unscheduled hours (`capacity + overtime - scheduled`) for this person within the duration"
          }
        }
      },
      "ReportsListProjects": {
        "type": "object",
        "properties": {
          "projects": {
            "type": "array",
            "description": "A list of report data per project",
            "items": {
              "$ref": "#/components/schemas/ReportsProjects"
            }
          }
        }
      },
      "ReportsProjects": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Website Design",
            "description": "The name of the project"
          },
          "project_id": {
            "type": "integer",
            "example": 12325,
            "description": "The project id"
          },
          "client_id": {
            "type": "integer",
            "example": 23250,
            "description": "The client id that this project belongs to"
          },
          "scheduled": {
            "type": "number",
            "example": 152,
            "description": "Total of allocated hours scheduled on this project within the duration"
          },
          "billable": {
            "type": "number",
            "example": 100,
            "description": "Total of billable allocated hours scheduled on this project within the duration"
          },
          "nonBillable": {
            "type": "number",
            "example": 52,
            "description": "Total of non-billable allocated hours scheduled on this project within the duration"
          }
        }
      },
      "ProjectExpenseExpanded": {
        "type": "object",
        "title": "ProjectExpense",
        "required": [
          "name",
          "date",
          "cost",
          "project_id"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "The ID of the project expense",
            "readOnly": true,
            "example": 32198
          },
          "name": {
            "type": "string",
            "description": "The name of the project expense",
            "maxLength": 200,
            "example": "Equipment rental"
          },
          "date": {
            "type": "string",
            "description": "The date of the project expense",
            "format": "date",
            "example": "2025-07-01"
          },
          "cost": {
            "type": "string",
            "description": "The cost of the project expense",
            "example": "1500.0000"
          },
          "billable": {
            "type": "integer",
            "description": "Whether this expense is billable. Only billable projects can have billable expenses. `1` = Billable, `0` = Non-billable",
            "example": 1
          },
          "markup": {
            "type": "string",
            "description": "The markup percentage as a decimal string. Only billable expenses can be marked up",
            "example": "25.0000"
          },
          "markup_type": {
            "type": "integer",
            "description": "The type of markup applied. `0` = Percentage, `1` = Fixed amount",
            "example": 0
          },
          "quantity": {
            "type": "integer",
            "description": "The quantity of this expense",
            "minimum": 1,
            "example": 1
          }
        }
      },
      "ProjectTeamMemberExpanded": {
        "type": "object",
        "title": "ProjectTeamMember",
        "properties": {
          "people_id": {
            "type": "integer",
            "description": "The ID of the person",
            "example": 17391001
          },
          "role_id": {
            "type": "integer",
            "description": "The ID of a role",
            "example": 17391001
          },
          "hourly_rate": {
            "type": "number",
            "description": "The project hourly rate for this team member",
            "format": "float",
            "example": 75.0
          },
          "phase_id": {
            "type": "integer",
            "description": "The phase ID, `0` indicates it does not belong to a phase",
            "example": 0
          }
        }
      },
      "ProjectTaskExpanded": {
        "type": "object",
        "title": "ProjectTask",
        "properties": {
          "task_meta_id": {
            "type": "integer",
            "example": 4567,
            "description": "The ID of the project task (named for backwards compatibility)",
            "readOnly": true
          },
          "project_id": {
            "type": "integer",
            "example": 32154,
            "description": "The ID of the project the project task belongs to"
          },
          "phase_id": {
            "type": "integer",
            "example": 123,
            "description": "The ID of the phase the project task belongs to; `0` indicates it does not belong to a phase",
            "default": 0
          },
          "task_name": {
            "type": "string",
            "example": "Design",
            "description": "The name of the project task, an empty string is valid and is the default on the UI when a project task has not been chosen",
            "minLength": 0,
            "maxLength": 200
          },
          "billable": {
            "type": "integer",
            "example": 1,
            "description": "`1` = Billable, `0` = Non-billable - Billable project tasks may not belong to non-billable projects or phases"
          },
          "budget": {
            "type": "number",
            "example": 100.99,
            "description": "The budget amount for 'hours by task' or 'fee by task' project budgets"
          },
          "count_tasks": {
            "type": "integer",
            "example": 150,
            "description": "The number of allocations (`task_id`) this project task is associated with.",
            "readOnly": true
          },
          "count_logged_time": {
            "type": "integer",
            "example": 100,
            "description": "The number of logged time entries (`logged_time_id`) this project task is associated with.",
            "readOnly": true
          },
          "created": {
            "type": "string",
            "example": "2023-10-22 23:11:23.578",
            "description": "Date this record was created",
            "readOnly": true
          },
          "modified": {
            "type": "string",
            "example": "2023-11-11 07:38:44",
            "description": "Date this record was last modified",
            "readOnly": true
          }
        }
      },
      "Project": {
        "type": "object",
        "title": "Project",
        "required": [
          "name"
        ],
        "properties": {
          "project_id": {
            "type": "integer",
            "example": 4567,
            "description": "The ID of the project",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "example": "Website Redesign",
            "description": "The name of the project",
            "maxLength": 200
          },
          "project_code": {
            "type": "string",
            "example": "PRJ-123456",
            "description": "An optional third-party identifier unique across all projects enforced using case-insensitive comparison",
            "maxLength": 32
          },
          "client_id": {
            "type": "integer",
            "example": 45672,
            "description": "The ID of the project's client"
          },
          "color": {
            "type": "string",
            "example": "0095D7",
            "description": "Project's color in hexadecimal"
          },
          "notes": {
            "type": "string",
            "example": "Due at the start of July. Paul to present",
            "description": "Notes for this project"
          },
          "tags": {
            "type": "array",
            "example": [
              "digital",
              "pitch"
            ],
            "description": "List of tags",
            "items": {
              "type": "string"
            }
          },
          "budget_type": {
            "type": "integer",
            "example": 1,
            "description": "Is there a project budget? `1` = Total hours, `2` = Total fee, `3` = Hourly fee"
          },
          "budget_total": {
            "type": "number",
            "example": 1000.5,
            "description": "The budget amount for Total hours or Total fee project budgets. Displays as `null` for Hourly fee, Phase and Task budgets, also see `budget_priority`"
          },
          "budget_per_phase": {
            "type": "integer",
            "example": 1,
            "description": "(**Deprecated** - see `budget_priority`): Is the budget set per Phase? `1` = Yes, `0` = No"
          },
          "budget_priority": {
            "type": "integer",
            "example": 0,
            "description": "Defines which level the budget will be determined from; `0` = Project, `1` = Phase, `2` = Task. For non-project levels, the total budget can be calculated from the sum of budgets in each Phase or Task"
          },
          "default_hourly_rate": {
            "type": "string",
            "example": "55.50",
            "description": "The default hourly rate for fee-based budgets, the request also accepts a decimal `number`"
          },
          "non_billable": {
            "type": "integer",
            "example": 1,
            "description": "Is this project billable? `0` = Billable, `1` = Non-billable"
          },
          "status": {
            "type": "integer",
            "example": 2,
            "description": "The status of the project `0` = Draft, `1` = Tentative, `2` = Confirmed, `3` = Completed, `4` = Canceled. If both `status` and `stage_id` are provided, `stage_id` takes precedence. If only `status` is provided, the first available stage for that status will be automatically selected."
          },
          "stage_id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the project stage for this project. This field takes precedence over `status` when both are provided. If omitted, the first available stage related to the project's `status` will be used."
          },
          "tentative": {
            "type": "integer",
            "example": 0,
            "description": "(**Deprecated** - see `status`): Is this project tentative? `1` = Yes, `0` = No"
          },
          "locked_task_list": {
            "type": "integer",
            "example": 1,
            "description": "Are members locked from adding project tasks (Only Project Managers can add to this list)? 1 = Yes, locked to project editors, 0 = No, anyone can add tasks"
          },
          "active": {
            "type": "integer",
            "example": 1,
            "description": "Is this project active or archived? `1` = Active, `0` = Archived"
          },
          "project_manager": {
            "type": "integer",
            "example": 17393464,
            "description": "Account ID of the assigned project manager"
          },
          "all_pms_schedule": {
            "type": "integer",
            "example": 0,
            "description": "Do all project managers have scheduling rights? `1` = Yes, `0` = No"
          },
          "created": {
            "type": "string",
            "example": "2024-10-30 02:40:40.000",
            "description": "Date this record was created",
            "readOnly": true
          },
          "modified": {
            "type": "string",
            "example": "2024-11-14 03:02:05.000",
            "description": "Date this record was last modified",
            "readOnly": true
          },
          "start_date": {
            "type": "string",
            "example": "2024-11-07",
            "description": "The start date of this project which is either manually set or calculated from the earliest phase, milestone, allocation, or logged time"
          },
          "end_date": {
            "type": "string",
            "example": "2025-01-18",
            "description": "The end date of this project which is either manually set or calculated from the latest phase, milestone, allocation, or logged time"
          },
          "expenses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectExpenseExpanded"
            },
            "description": "`expand` field. The expenses assigned to this project"
          },
          "project_tasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectTaskExpanded"
            },
            "description": "`expand` field. A list of the project tasks available in this project"
          },
          "project_team": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProjectTeamMemberExpanded"
            },
            "description": "`expand` field. A list of people by `people_id` and their project `hourly_rate`, the `phase_id` will be `0`, the list may be empty"
          }
        }
      },
      "ProjectWithProjectTeam": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Project"
          },
          {
            "properties": {
              "project_team": {
                "type": "object",
                "description": "Manages the composition and details of the project team.",
                "properties": {
                  "set": {
                    "type": "array",
                    "description": "Replaces the entire current project team with the provided team. Using this will ignore `add` and `del` actions. Caution: This action removes all members not in the `set` list, along with their associated items",
                    "items": {
                      "type": "object",
                      "required": [
                        "people_id"
                      ],
                      "properties": {
                        "people_id": {
                          "type": "integer",
                          "description": "Unique identifier for a team member",
                          "example": 17391001
                        },
                        "role_id": {
                          "type": "integer",
                          "description": "The ID of a role",
                          "example": 17391001
                        },
                        "hourly_rate": {
                          "type": "number",
                          "description": "Hourly rate for the team member. This field is optional",
                          "format": "float",
                          "example": 75.0
                        }
                      }
                    }
                  },
                  "add": {
                    "type": "array",
                    "description": "Adds new team members to the project",
                    "items": {
                      "type": "object",
                      "required": [
                        "people_id"
                      ],
                      "properties": {
                        "people_id": {
                          "type": "integer",
                          "description": "Unique identifier for a team member",
                          "example": 17391002
                        },
                        "role_id": {
                          "type": "integer",
                          "description": "The ID of a role",
                          "example": 17391001
                        },
                        "hourly_rate": {
                          "type": "number",
                          "description": "Hourly rate for the team member. This field is optional",
                          "format": "float",
                          "example": 65.0
                        }
                      }
                    }
                  },
                  "del": {
                    "type": "array",
                    "description": "Removes team members from the project using their 'people_id'. Caution: Removing members will delete their associated items",
                    "example": [
                      17391002,
                      17391003
                    ],
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "ProjectStage": {
        "type": "object",
        "title": "ProjectStage",
        "required": [
          "name",
          "project_status"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the project stage",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "example": "Likely",
            "description": "The name of the project stage, must be unique across all stages",
            "maxLength": 50
          },
          "description": {
            "type": "string",
            "example": "Set expectations without notifications or time tracking. Team allocations are visible everywhere.",
            "description": "A description of the project stage",
            "maxLength": 100
          },
          "project_status": {
            "type": "integer",
            "example": 1,
            "description": "The project status associated with this stage `0` = Draft, `1` = Tentative, `2` = Confirmed, `3` = Completed, `4` = Canceled. Required to create a stage and cannot be changed later"
          },
          "active": {
            "type": "integer",
            "example": 1,
            "description": "Is this project stage active? `1` = Active, `0` = Archived"
          },
          "sort_order": {
            "type": "integer",
            "example": 1,
            "description": "The sort order for displaying project stages, defaults to `10` if not provided"
          },
          "color": {
            "type": "string",
            "example": "0B752E",
            "description": "Hex color for the project stage. Allowed values: `344765` (Grey blue, default for draft & canceled), `0B752E` (Green, default for confirmed), `BD4B00` (Orange, default for tentative), `2E5FE8` (Bright blue, default for complete), `9D1010` (Red). If `null` or omitted, the default color from the project_status will apply."
          },
          "created": {
            "type": "string",
            "example": "2024-10-30 02:40:40",
            "description": "Date this record was created",
            "readOnly": true
          },
          "modified": {
            "type": "string",
            "example": "2024-11-14 03:02:05",
            "description": "Date this record was last modified",
            "readOnly": true
          },
          "created_by": {
            "type": "integer",
            "example": 80851,
            "description": "Account ID of the person who created this project stage",
            "readOnly": true
          },
          "modified_by": {
            "type": "integer",
            "example": 80851,
            "description": "Account ID of the person who last modified this project stage",
            "readOnly": true
          },
          "project_count": {
            "type": "integer",
            "example": 15,
            "description": "`expand` field. Number of projects currently using this project stage",
            "readOnly": true
          }
        }
      },
      "Phase": {
        "type": "object",
        "required": [
          "name",
          "project_id",
          "start_date",
          "end_date"
        ],
        "properties": {
          "phase_id": {
            "type": "integer",
            "example": 6754,
            "description": "The ID of this phase",
            "readOnly": true
          },
          "project_id": {
            "type": "integer",
            "example": 4567,
            "description": "The ID of the project to which this phase belongs"
          },
          "name": {
            "type": "string",
            "example": "Design",
            "description": "The name of the phase",
            "maxLength": 200
          },
          "color": {
            "type": "string",
            "example": "0095D7",
            "description": "Phase's color in hexadecimal (defaults to project color)"
          },
          "notes": {
            "type": "string",
            "example": "Due at the start of July. Paul to present",
            "description": "Notes for this phase"
          },
          "start_date": {
            "type": "string",
            "format": "date:YYYY-MM-DD",
            "example": "2024-12-12",
            "description": "The start date of this phase which is either manually set or calculated from the earliest milestone, allocation, or logged time within this phase"
          },
          "end_date": {
            "type": "string",
            "format": "date:YYYY-MM-DD",
            "example": "2025-02-23",
            "description": "The end date of this phase which is either manually set or calculated from the latest milestone, allocation, or logged time within this phase"
          },
          "budget_total": {
            "type": "number",
            "example": 1000.5,
            "description": "The budget amount for 'hours by phase' or 'fee by phase' project budgets"
          },
          "default_hourly_rate": {
            "type": "string",
            "example": "55.50",
            "description": "The default hourly rate for fee-based budgets, the request also accepts a decimal `number`"
          },
          "non_billable": {
            "type": "integer",
            "example": 1,
            "description": "Is this phase billable? `0` = Billable, `1` = Non-billable"
          },
          "status": {
            "type": "integer",
            "example": 2,
            "description": "The status of the phase `0` = Draft, `1` = Tentative, `2` = Confirmed. Draft phases must belong to draft projects, tentative phase can belong to tentative or confirmed projects, confirmed phases must belong to confirmed projects"
          },
          "tentative": {
            "type": "integer",
            "example": 0,
            "description": "(**Deprecated** - see `status`): Is this phase tentative? `1` = Yes, `0` = No"
          },
          "active": {
            "type": "integer",
            "example": 1,
            "description": "Is this phase active or archived? `1` = Active, `0` = Archived"
          },
          "created": {
            "type": "string",
            "example": "2025-01-03 07:45:37",
            "description": "Date this record was created",
            "readOnly": true
          },
          "modified": {
            "type": "string",
            "example": "2025-01-11 06:38:44",
            "description": "Date this record was last modified",
            "readOnly": true
          }
        },
        "title": "Phase"
      },
      "PhaseWithPhaseTeam": {
        "allOf": [
          {
