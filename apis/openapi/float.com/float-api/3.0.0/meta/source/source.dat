    "/status": {
      "get": {
        "summary": "List statuses",
        "description": "An individual Status is determined by a date range for a single person and linked to a status type which can only be defined in Admin Settings area of the UI, the default values are `1` = Home, `2` = Travel, `3` = Custom and `4` = Office.\n**Note:** repeating statues will also be returned if `repeat_end_date` is within the date range specified.",
        "operationId": "getStatuses",
        "tags": [
          "Statuses"
        ],
        "parameters": [
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/people_id"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/start_date"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/end_date"
          },
          {
            "name": "status_type_id",
            "in": "query",
            "description": "A status type ID to filter the response on",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/per-page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/fields"
          }
        ],
        "responses": {
          "200": {
            "description": "List of statuses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "title": "Array of statuses",
                  "items": {
                    "$ref": "#/components/schemas/Status"
                  }
                }
              }
            }
          },
          "204": {
            "description": "No statuses found"
          }
        }
      },
      "post": {
        "summary": "Add a new status",
        "description": "Creating a new status requires a valid `status_type_id` which can be matched from the UI.",
        "operationId": "addStatus",
        "tags": [
          "Statuses"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Status"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "If the status was successfully created, the response returns the full information about that status. If a status is created that replaces an existing status, the previous instance is first deleted and is returned in the response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusArrayResponse"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      }
    },
    "/status/{status_id}": {
      "get": {
