          },
          "locked_date": {
            "type": "string",
            "format": "date:YYYY-MM-DD",
            "example": "2025-04-01",
            "description": "Date this logged time entry was last locked",
            "readOnly": true
          },
          "created": {
            "type": "string",
            "format": "ISODate",
            "example": "2025-04-01T13:02:00+00:00",
            "description": "Date/time this record was created",
            "readOnly": true
          },
          "created_by": {
            "type": "integer",
