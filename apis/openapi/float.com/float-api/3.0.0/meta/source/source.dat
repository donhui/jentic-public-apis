      "ProjectTask": {
        "type": "object",
        "required": [
          "project_id",
          "task_name"
        ],
        "properties": {
          "task_meta_id": {
            "type": "integer",
            "example": 4567,
            "description": "The ID of the project task (named for backwards compatibility)",
            "readOnly": true
          },
          "project_id": {
            "type": "integer",
            "example": 32154,
            "description": "The ID of the project the project task belongs to"
          },
          "phase_id": {
            "type": "integer",
            "example": 123,
            "description": "The ID of the phase the project task belongs to; `0` indicates it does not belong to a phase",
            "default": 0
          },
          "task_name": {
            "type": "string",
            "example": "Design",
            "description": "The name of the project task, an empty string is valid and is the default on the UI when a project task has not been chosen",
            "minLength": 0,
            "maxLength": 200
          },
          "billable": {
            "type": "integer",
            "example": 1,
            "description": "`1` = Billable, `0` = Non-billable - Billable project tasks may not belong to non-billable projects or phases"
          },
          "budget": {
            "type": "number",
            "example": 100.99,
            "description": "The budget amount for 'hours by task' or 'fee by task' project budgets"
          },
          "count_tasks": {
            "type": "integer",
            "example": 150,
            "description": "The number of allocations (`task_id`) this project task is associated with.",
            "readOnly": true
          },
          "count_logged_time": {
            "type": "integer",
            "example": 100,
            "description": "The number of logged time entries (`logged_time_id`) this project task is associated with.",
            "readOnly": true
          },
          "created": {
            "type": "string",
            "example": "2023-10-22 23:11:23.578",
            "description": "Date this record was created",
            "readOnly": true
          },
          "modified": {
            "type": "string",
            "example": "2023-11-11 07:38:44",
            "description": "Date this record was last modified",
            "readOnly": true
          }
        },
        "title": "Project task"
      },
      "MergeList": {
        "type": "object",
        "required": [
          "task_meta_ids",
          "task_name"
        ],
        "title": "Merge list request body",
        "properties": {
          "task_meta_ids": {
            "type": "array",
            "example": [
              12345,
              67890
            ],
            "description": "List of project task IDs as described by `task_meta_id`",
            "items": {
              "type": "integer"
            }
          },
          "task_name": {
            "type": "string",
            "example": "Design",
            "description": "The final name of the merged project task, an empty strings is valid. The final merged task will attempt to match existing names and if found merge into that `task_meta_id`",
            "minLength": 0,
            "maxLength": 200
          },
          "billable": {
            "type": "integer",
            "example": 1,
            "description": "The final state of the merged project tasks; `1` = Billable, `0` = Non-billable"
          }
        }
      },
      "PeopleTag": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "east coast",
            "description": "The name of the tag",
            "maxLength": 64
          }
        },
        "title": "PeopleTag"
      },
      "Contract": {
        "type": "object",
        "properties": {
          "effective_date": {
            "example": "2023-01-01",
            "type": "string",
            "format": "date",
            "description": "The date the contract starts; defaults to the person's start_date"
          },
          "role_id": {
            "type": "integer",
            "example": 7891,
            "description": "The ID of the role the contract is for (`null` if the person has no role)"
          },
          "role_name": {
            "type": "string",
            "example": "Software Engineer",
            "description": "The name of the role the contract is for (`null` if the person has no role)"
          },
          "cost_rate": {
            "type": "string",
            "example": "100.50",
            "description": "The effective cost rate for the contract (`null` if there are no cost rates)"
          },
          "cost_rate_from": {
            "type": "string",
            "example": "role",
            "description": "The entity that the cost rate is derived from either role, person, or `null` (if there are no cost rates)."
          }
        },
        "required": [
          "effective_date"
        ]
      },
      "Account": {
        "type": "object",
        "required": [
          "email",
          "name"
        ],
        "properties": {
          "account_id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of this account",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "example": "Donna Nobel",
            "description": "The name of the account",
            "maxLength": 200
          },
          "email": {
            "type": "string",
            "example": "donna@example.com",
            "description": "Email address for this account",
            "maxLength": 200
          },
          "timezone": {
            "type": "string",
            "description": "Timezone as a TZ identifier, set when using the time logging timer function",
            "example": "America/New_York"
          },
          "avatar": {
            "type": "string",
            "format": "uri",
            "description": "URL of an image file representing the account as an avatar",
            "example": "https://floatcdn.com/icons/avatar1-80.png"
          },
          "account_type": {
            "type": "integer",
            "example": 7,
            "description": "High level permissions of the account; `1` = Account Owner, `2` = Admin, `4` = Member, `5` = Billing, `7` = Manager"
          },
          "access": {
            "type": "integer",
            "example": 3,
            "description": "Used in conjunction with `account_type` to determine granular permissions, see response description"
          },
          "department_filter_id": {
            "type": "integer",
            "example": 443,
            "description": "The department ID if this account is filtered by a department"
          },
          "view_rights": {
            "type": "integer",
            "example": 1,
            "description": "(**Deprecated** - see `access`) Do they have rights to view the team? `1` = Yes, `0` = No"
          },
          "edit_rights": {
            "type": "integer",
            "example": 1,
            "description": "(**Deprecated** - see `access`) If a Member, do they have rights to edit their schedule? `1` = Yes, `0` = No"
          },
          "active": {
            "type": "integer",
            "example": 1,
            "description": "Is this account active? `1` = Yes, `0` = No"
          },
          "created": {
            "type": "string",
            "example": "2019-02-05",
            "description": "Date this record was created",
            "readOnly": true
          },
          "modified": {
            "type": "string",
            "example": "2019-08-02 09:21:13",
            "description": "Date this record was last modified",
            "readOnly": true
          }
        },
        "title": "Account"
      },
      "Person": {
        "title": "Person",
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "people_id": {
            "type": "integer",
            "example": 1,
            "description": "The unique identifier for this person. Ignored when creating a person",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "example": "Sarah-Jane Smith",
            "description": "The person's full name",
            "maxLength": 150
          },
          "email": {
            "type": "string",
            "example": "sarahjane@example.com",
            "description": "Email address for this person",
            "maxLength": 200
          },
          "job_title": {
            "type": "string",
            "example": "Designer",
            "description": "The name of the person's role as defined by their `role_id`",
            "maxLength": 200
          },
          "role_id": {
            "type": "integer",
            "example": 0,
            "description": "ID of a role associated with this person, `role.name` is used for `job_title`, during updates `role_id` is higher order"
          },
          "department": {
            "$ref": "#/components/schemas/Department",
            "description": "The current department the person belongs to"
          },
          "notes": {
            "type": "string",
            "example": "Sarah-Jane can't work on weekends.",
            "description": "Any notes related to this person",
            "maxLength": 65535
          },
          "avatar_file": {
            "type": "string",
            "example": "",
            "description": "Filename of thumbnail image for this person",
            "maxLength": 40,
            "readOnly": true
          },
          "auto_email": {
            "type": "integer",
            "example": 0,
            "description": "Should this person's schedule be emailed at start of week? 1 = Yes, 0 = No"
          },
          "employee_type": {
            "type": "integer",
            "example": 0,
            "description": "Full-time or part-type. `1` = Full-time, `0`  = Part-time"
          },
          "work_days_hours": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "format": "float",
            "example": [
              0,
              8,
              8,
              8,
              8,
              4,
              0
            ],
            "description": "Hours that a part-time person is available for scheduling each day in order from Sunday to Saturday"
          },
          "active": {
            "type": "integer",
            "example": 1,
            "description": "Is this person active or archived? `1` = Active, `0` = Archived. Archived people do not show on the schedule or contribute to billing seats and will have their access removed"
          },
          "people_type_id": {
            "type": "integer",
            "example": 1,
            "description": "Is this person an `1` = Employee (default), `2` = Contractor, `3` = Placeholder, `4` = Role placeholder? Type `4` is not returned by default when listing people."
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PeopleTag"
            }
          },
          "start_date": {
            "type": "string",
            "example": "2019-05-20",
            "description": "Date the person started"
          },
          "end_date": {
            "type": "string",
            "example": "2019-11-11",
            "description": "Date the person finished"
          },
          "default_hourly_rate": {
            "type": "string",
            "example": "100.50",
            "description": "Default hourly rate applied when the person is added to a fee-based project, the request also accepts a decimal `number`"
          },
          "region_id": {
            "type": "integer",
            "example": 1234,
            "description": "ID of the public holiday region to which the person belongs"
          },
          "created": {
            "type": "string",
            "example": "2019-05-07 10:26:49",
            "description": "Date this record was created",
            "readOnly": true
          },
          "modified": {
            "type": "string",
            "example": "2019-05-07 11:26:49",
            "description": "Date this record was last modified",
            "readOnly": true
          },
          "contracts": {
            "type": "array",
            "description": "`expand` field. List of applicable contracts determined for the person based on effective dates",
            "items": {
              "$ref": "#/components/schemas/Contract"
            },
            "readOnly": true
          },
          "account": {
            "$ref": "#/components/schemas/Account",
            "description": "`expand` field. Details of an account linked to this person including permissions on this team, or `null` if none",
            "readOnly": true
          },
          "managers": {
            "description": "`expand` field. List of accounts by `account_id` that manage this person, multiple managers are possible using departments. `null` if none",
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              123456,
              4567892
            ],
            "readOnly": true
          }
        }
      },
