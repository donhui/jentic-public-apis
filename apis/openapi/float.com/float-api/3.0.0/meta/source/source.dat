    "/phases/{phase_id}": {
      "get": {
        "summary": "Retrieve a single phase.",
        "description": "Retrieve a single phase",
        "operationId": "getPhase",
        "tags": [
          "Phases"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/phase_id"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "Details of a single phase",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Phase"
                }
              }
            }
          },
          "404": {
            "description": "The phase does not exist."
          }
        }
      },
      "patch": {
        "summary": "Update a phase's details",
        "description": "To update the phase team there are 3 actions on the `phase_team` field; `set`, `add` and `del`:\n  * Use `set` as an array of phase team objects of `people_id` and `hourly_rate` to replace all people and their phase rates\n  * Use `add` as an array of phase team objects of `people_id` and `hourly_rate` to add additional people and their rates\n  * Use `del` as an array of `people_id` to remove people from the phase_team\n\nCAUTION: `set` and `del` actions that remove people will cascade delete all associated Allocations (`task_id`) and Logged time for that person on the phase.\n",
        "operationId": "updatePhase",
        "tags": [
          "Phases"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/phase_id"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PhaseWithPhaseTeam"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "On a successful update of a phase, the response returns the full information about that phase.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Phase"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      },
      "delete": {
        "summary": "Delete a phase",
        "description": "Deleting a phase will delete all associated allocations (`task_id`) and logged time, this is an irreversible action",
        "operationId": "deletePhase",
        "tags": [
          "Phases"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/phase_id"
          }
        ],
        "responses": {
          "204": {
            "description": "Delete successful, all associated allocations and logged time for this `phase_id` have also been deleted"
          },
          "404": {
            "description": "The phase does not exist."
          }
        }
      }
    },
    "/project-tasks": {
      "get": {
        "summary": "List project tasks",
        "description": "Project tasks are used in Projects and Phases to associate allocations and logged time, e.g. Design, Admin etc\n\nA `task_name` with an empty string is the default for allocations and logged time when a project task has not been selected.\n\nThey may be set to non-billable if the Project or Phase is billable (otherwise the non-billable status cascades). ",
        "operationId": "getProjectTasks",
        "tags": [
          "Project Tasks"
        ],
        "parameters": [
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/project_id"
          },
          {
            "name": "billable",
            "in": "query",
            "description": "Filter response on `1` = billable or `0` = non-billable entities",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/per-page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/sort"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/fields"
          }
        ],
        "responses": {
          "200": {
            "description": "The list of project tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "title": "Array of project tasks",
                  "items": {
                    "$ref": "#/components/schemas/ProjectTask"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new project task",
        "description": "Create project tasks to pre-configure a project before scheduling.\n\n**Note:** project tasks may be created automatically through `/tasks` (allocations) and `/logged-time` when a new name is used in the request. ",
        "operationId": "addProjectTask",
        "tags": [
          "Project Tasks"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectTask"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The project task was successfully created, and the response returns the full information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectTask"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      }
    },
    "/project-tasks/{project_task_id}": {
      "get": {
        "summary": "Retrieve a single project task.",
        "operationId": "getProjectTask",
        "tags": [
          "Project Tasks"
        ],
        "parameters": [
          {
            "name": "project_task_id",
            "in": "path",
            "description": "The project tasks ID as described in the `task_meta_id` field",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Details of a single project task",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectTask"
                }
              }
            }
          },
          "404": {
            "description": "The project task does not exist."
          }
        }
      },
      "patch": {
        "summary": "Update a project tasks details",
        "operationId": "updateProjectTask",
        "tags": [
          "Project Tasks"
        ],
        "parameters": [
          {
            "name": "project_task_id",
            "in": "path",
            "description": "The project tasks ID as described in the `task_meta_id` field",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectTask"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "A successful update of a project task, the response returns the full information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectTask"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      },
      "delete": {
        "summary": "Delete a project task",
        "description": "Project Tasks may only be deleted if there are zero count associations. To remove associations, filter using the `task_meta_id` on the respective endpoints (`/tasks` or `/logged-time`) to update individually, before retrying this delete operation.",
        "operationId": "deleteProjectTask",
        "tags": [
          "Project Tasks"
        ],
        "parameters": [
          {
            "name": "project_task_id",
            "in": "path",
            "description": "The project tasks ID as described in the `task_meta_id` field",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful deletion will return a 204 response status."
          },
          "404": {
            "description": "The project task does not exist."
          },
          "422": {
            "description": "The project task has associations that must be updated."
          }
        }
      }
    },
    "/project-tasks/merge": {
      "post": {
        "summary": "Merges project tasks and all associations into a single, new or existing, project task",
        "operationId": "mergeProjectTasks",
        "tags": [
          "Project Tasks"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MergeList"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "All provided Project Tasks have successfully merged and all associated allocations and logged time are updated. The response returns the full information of the final Project Task.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectTask"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      }
    },
    "/people": {
      "get": {
        "summary": "List people",
        "description": "Search for all people in your organization.\nPeople are a distinct entity from Accounts. People exist on the schedule and will only have a linked account if they are invited to sign in. Each active person contributes to a billing seat.\nArchived people do not show on the schedule, they also do not contribute towards billing seats.",
        "operationId": "getPeople",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/active"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/department_id"
          },
          {
            "$ref": "#/components/parameters/email"
          },
          {
            "$ref": "#/components/parameters/people_type_id"
          },
          {
            "$ref": "#/components/parameters/employee_type"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/tag_name"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/per-page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/sort"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/modified_since"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/fields"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "The list of people",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "title": "Array of people",
                  "items": {
                    "$ref": "#/components/schemas/Person"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new person",
        "description": "Creating a person does not create an account (can only be done through the UI). Each active person contributes to a billing seat. The `role_id` is a higher order than `job_title`, `job_title` will attempt to match on an existing `role.name` and create a new role if none exist.\nCost rates may be set on a person using the `cost_rate` field and can include an `effective_date` field in the format; e.g. `2025-06-10`.\n- If `effective_date` is omitted when the first `cost_rate` is added, the date will default to the person's `start_date`, or fallback to `1970-01-01`.\n- When a further `cost_rate` is added and the `effective_date` omitted, the date will default to today.\n\nThese will be reflected in the person's `contracts` when expanded in the response. ",
        "operationId": "addPerson",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Person"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The person was successfully created, the response returns the full information about that person.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      }
    },
    "/people/{people_id}": {
      "get": {
        "summary": "Retrieve a single person",
        "operationId": "getPerson",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "people_id",
            "in": "path",
            "description": "The person's id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "Details of a single person",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          },
          "404": {
            "description": "The person does not exist."
          }
        }
      },
      "patch": {
        "summary": "Update a person's details, read-only fields are ignored",
        "description": "If a person is changed to archived (`active = 0`) then their access to the team is revoked by deleting the account and this can only be re-established through the UI.\nThe `role_id` is a higher order than `job_title`, `job_title` will attempt to match on an existing `role.name` and create a new role if none exist.\n\nCost rates may be updated on a person using the `cost_rate` field and Role changes may be updated using the `role_id` field along with the `effective_date` field with the format example `2025-06-10` (defaults to today if omitted).\nThese will be reflected in the person's `contracts` available to be expanded on the response. ",
        "operationId": "updatePerson",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "people_id",
            "in": "path",
            "description": "The person's id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "On a successful update of a person, the response returns thefull information about that person.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Person"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure.    \n"
          }
        }
      },
      "delete": {
        "summary": "Delete a person",
        "description": "Deleting a person will delete all their allocations (`task_id`) and logged time, this is an irreversible action",
        "operationId": "deletePerson",
        "tags": [
          "People"
        ],
        "parameters": [
          {
            "name": "people_id",
            "in": "path",
            "description": "people id to delete",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Delete successful, all associated allocations and logged time for this `people_id` have also been deleted"
          },
          "404": {
            "description": "The person does not exist."
          }
        }
      }
    },
