      "name": "Phases",
      "description": "The /phases endpoint"
    },
    {
      "name": "Project Tasks",
      "description": "The /project-tasks endpoint"
    },
    {
      "name": "Milestones",
      "description": "The /milestones endpoint"
    },
    {
      "name": "Allocations",
      "description": "The /tasks endpoint describes allocations"
    },
    {
      "name": "Logged Time",
      "description": "The /logged-time endpoint"
    },
    {
      "name": "Reports",
      "description": "The /reports endpoint"
    }
  ],
  "paths": {
    "/departments": {
      "get": {
        "summary": "List departments",
        "operationId": "getDepartments",
        "tags": [
          "Departments"
        ],
        "parameters": [
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/per-page"
          }
        ],
        "responses": {
          "200": {
            "description": "List of departments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "title": "Array of departments",
                  "items": {
                    "$ref": "#/components/schemas/Department"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new department",
        "operationId": "addDepartment",
        "tags": [
          "Departments"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Department"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "If the department was successfully created, the response returns the full information about that department.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Department"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      }
    },
    "/departments/{department_id}": {
      "get": {
        "summary": "Retrieve a single department",
        "description": "Returns a single department.",
        "operationId": "getDepartment",
        "tags": [
          "Departments"
        ],
        "parameters": [
          {
            "name": "department_id",
            "in": "path",
            "description": "The department's id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Details of a single department.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Department"
                }
              }
            }
          },
          "404": {
            "description": "The department does not exist."
          }
        }
      },
      "patch": {
        "summary": "Update a department's details, read-only fields are ignored",
        "operationId": "updateDepartment",
        "tags": [
          "Departments"
        ],
        "parameters": [
          {
            "name": "department_id",
            "in": "path",
            "description": "The department's id",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "On a successful update of a department, the response returns the full information about that department.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Department"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      },
      "delete": {
        "summary": "Delete a department",
        "operationId": "deleteDepartment",
        "tags": [
          "Departments"
        ],
        "parameters": [
          {
            "name": "department_id",
            "in": "path",
            "description": "department id to delete",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Delete successful, if this `department_id` is currently used in any people it will be set to `null`."
          },
          "404": {
            "description": "The department does not exist."
          }
        }
      }
    },
    "/reports/people": {
      "get": {
        "summary": "Retrieve report data for a list of people",
        "description": "Returns an array of people with aggregated data alongside person-specific attributes.\nThe **start_date** and **end_date** query parameters are required to set the duration of the report, and the response can be filtered per person.\n**Note:** Pagination is not available, and request limits are lower for report endpoints.",
        "operationId": "getReportPeople",
        "tags": [
          "Reports"
        ],
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "description": "**Required:** Start date of the report duration in the format YYYY-MM-DD.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "description": "**Required:** End date of the report duration in the format YYYY-MM-DD.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/people_id"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of people reports between two dates.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportsListPeople"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable entity. Required query parameters are either missing or incomplete."
          }
        }
      }
    },
    "/reports/projects": {
      "get": {
        "summary": "Retrieve report data for a list of projects",
        "description": "Returns an array of projects with aggregated data alongside project-specific attributes.\nThe **start_date** and **end_date** query parameters are required to set the duration of the report, and the response can be filtered per project.\n**Note:** Pagination is not available, and request limits are lower for report endpoints.",
        "operationId": "getReportProjects",
        "tags": [
          "Reports"
        ],
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "description": "**Required:** Start date of the report duration in the format YYYY-MM-DD.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "description": "**Required:** End date of the report duration in the format YYYY-MM-DD.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/project_id"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of project reports between two dates.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportsListProjects"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable entity. Required query parameters are either missing, incomplete or the project_id is not found"
          }
        }
      }
    },
    "/projects": {
      "get": {
        "summary": "List projects",
        "operationId": "getProjects",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/project_code"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/client_id"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/active"
          },
          {
            "$ref": "#/components/parameters/non_billable"
          },
          {
            "$ref": "#/components/parameters/status"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/tag_name"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/per-page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/sort"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/modified_since"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/fields"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "The list of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "title": "Array of projects",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new project",
        "operationId": "addProject",
        "tags": [
          "Projects"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Project"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "If the project was successfully created, the response returns the full information about that project.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      }
    },
    "/projects/{project_id}": {
      "get": {
        "summary": "Retrieve a single project.",
        "description": "Retrieve a single project",
        "operationId": "getProject",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/project_id"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "Details of a single project",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "404": {
            "description": "The project does not exist."
          }
        }
      },
      "patch": {
        "summary": "Update a project's details, read-only fields are ignored",
        "description": "To update the project team including unassigned roles there are 3 actions on the `project_team` field; `set`, `add` and `del`:\n  * Use `set` as an array of project team objects of `people_id`,`role_id` and `hourly_rate` to replace all people and their project rates\n  * Use `add` as an array of project team objects of `people_id`, `role_id` and `hourly_rate` to add additional people and their roles & rates\n  * Use `del` as an array of `people_id` to remove people from the project_team\n\n  To assign a role to a project, `set` or `add` a `role_id` to the project_team object without a `people_id`. An unassigned role placeholder will be returned in the response. See the [Using unassigned roles](/tutorial_unassigned_roles.html) tutorial for more details.\n\nCAUTION: `set` and `del` actions that remove people will **cascade-delete** all associated Allocations (`task_id`) and Logged time for that person on the project.\n",
        "operationId": "updateProject",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/project_id"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectWithProjectTeam"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "On a successful update of a project, the response returns the full information about that project.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure, see error for details"
          }
        }
      },
      "delete": {
        "summary": "Delete a project",
        "description": "Deleting a project will delete all associated allocations (`task_id`) and logged time, as well as any phases and associations, this is an irreversible action",
        "operationId": "deleteProject",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/project_id"
          }
        ],
        "responses": {
          "204": {
            "description": "Delete successful, all associated allocations, logged time and phases for this `project_id` have also been deleted"
          },
          "404": {
            "description": "The project does not exist."
          }
        }
      }
    },
    "/project-stages": {
      "get": {
        "summary": "List project stages",
        "operationId": "getProjectStages",
        "tags": [
          "Project Stages"
        ],
        "parameters": [
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/active"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/per-page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/sort"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/fields"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "The list of project stages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "title": "Array of project stages",
                  "items": {
                    "$ref": "#/components/schemas/ProjectStage"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new project stage",
        "operationId": "addProjectStage",
        "tags": [
          "Project Stages"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectStage"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "If the project stage was successfully created, the response returns the full information about that project stage.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectStage"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      }
    },
    "/project-stages/{id}": {
      "get": {
        "summary": "Retrieve a single project stage.",
        "description": "Retrieve a single project stage",
        "operationId": "getProjectStage",
        "tags": [
          "Project Stages"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/id"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "Details of a single project stage",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectStage"
                }
              }
            }
          },
          "404": {
            "description": "The project stage does not exist."
          }
        }
      },
      "patch": {
        "summary": "Update a project stage's details, read-only fields are ignored",
        "description": "Stages may be updated or archived, `project_status` cannot be changed",
        "operationId": "updateProjectStage",
        "tags": [
          "Project Stages"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/id"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectStage"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "On a successful update of a project stage, the response returns the full information about that project stage.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectStage"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      },
      "delete": {
        "summary": "Delete a project stage",
        "description": "Deleting a project stage will remove it from the available stages for projects, this is an irreversible action",
        "operationId": "deleteProjectStage",
        "tags": [
          "Project Stages"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/id"
          }
        ],
        "responses": {
          "204": {
            "description": "Delete successful, the project stage has been removed"
          },
          "404": {
            "description": "The project stage does not exist."
          },
          "422": {
            "description": "Data validation failure. The project stage cannot be deleted if it is currently linked to projects."
          }
        }
      }
    },
    "/phases": {
      "get": {
        "summary": "List phases",
        "operationId": "getPhases",
        "tags": [
          "Phases"
        ],
        "parameters": [
