    },
    "/accounts": {
      "get": {
        "summary": "List accounts",
        "operationId": "getAccounts",
        "tags": [
          "Accounts"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/expand"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/per-page"
          }
        ],
        "responses": {
          "200": {
            "description": "Accounts are required to access a team. An account may be linked to a person on the schedule; if not, they are a guest.\n**Note:** the API does not currently support account creation.\n\nHigh-level permissions are denoted by `account_type`; `1` = Account Owner, `2` = Admin, `4` = Member, `5` = Billing, `7` = Manager\n\nGranular permissions are denoted by `access`:\n  * Where `account_type` is `1`, `2` or `5` (Account Owner, Admin or Billing); `access` is always `0`\n  * Where `account_type` is `4` (Member); `1` = View all, `2` = Self-edit.\n  * Where `account_type` is `7` (Manager); `0` = No schedule management, `1` = Manage Projects, `2` = Manage People, `3` = Manage Projects & People.\n  * Additionally for any manager `access` values; `+4` = Create & edit People, `+8` = View rates & budgets e.g. `9` = Manager of projects that can view rates & budgets\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "title": "Array of accounts",
                  "items": {
                    "$ref": "#/components/schemas/Account"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{account_id}": {
      "get": {
        "summary": "Retrieve a single account",
        "operationId": "getAccount",
        "tags": [
          "Accounts"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/account_id"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "Accounts are required to access a team. An account may be linked to a person on the schedule; if not, they are a guest.\n**Note:** the API does not currently support account creation.\nHigh-level permissions are denoted by `account_type`; `1` = Account Owner, `2` = Admin, `4` = Member, `5` = Billing, `7` = Manager\nGranular permissions are denoted by `access`:\n  * Where `account_type` is `1`, `2` or `5` (Account Owner, Admin or Billing); access is always `0`\n  * Where `account_type` is `4` (Member); `1` = View all, `2` = Self-edit.\n  * Where `account_type` is `7` (Manager); `0` = No schedule management, `1` = Manage Projects, `2` = Manage People, `3` = Manage Projects & People.\n  * Additionally for any manager `access` values; `+4` = Create & edit People, `+8` = View rates & budgets e.g. `9` = Manager of projects that can view rates & budgets\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          }
        }
      }
    },
