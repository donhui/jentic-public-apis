    "/tasks": {
      "get": {
        "summary": "List allocations as tasks",
        "description": "This version of the API references a `task` object as an allocation.\n**Note:** repeating allocations will also be returned if `repeat_end_date` is within the date range specified.",
        "operationId": "getTasks",
        "tags": [
          "Allocations"
        ],
        "parameters": [
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/client_id"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/project_id"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/phase_id"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/task_meta_id"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/people_id"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/start_date"
          },
          {
            "name": "end_date",
            "in": "query",
            "description": "End of date range in format YYYY-MM-DD. Must be used together with `start_date`. Will be inclusive of `repeat_end_date` date.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "billable",
            "in": "query",
            "description": "Filter response on `0` = non-billable or `1` = billable",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter response on the Status. `1` = Tentative, `2` = Confirmed, `3` = Complete\"",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "repeat_state",
            "in": "query",
            "description": "Filter response on the repeat state. `0` = No repeat, `1` = Weekly, `2` = Monthly, `3` = Every two weeks, `4` = Every three weeks, `5` = Every six weeks, `6` = Every two months, `7` = Every three months, `8` = Every six months, `9` = Yearly",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/per-page"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/sort"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/modified_since"
          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/fields"
          },
          {
            "name": "expand",
            "in": "query",
            "description": "Use `task_days` to return an additional array of dates `[YYYY-MM-DD]` calculated by taking into account the date range & `repeat_end_date` of each `task_id` plus holidays & availability of all associated people. (e.g. weekends and holidays dates will not be returned). By default, a date is returned if any person is available, the `people_id` filter may be used to limit this. The `start_date` and `end_date` filters must always be provided.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of allocations as tasks.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "title": "Array of tasks",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new allocation as a task, read-only fields are ignored",
        "operationId": "addTask",
        "tags": [
          "Allocations"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Task"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "If the allocation was successfully created, the response returns the full information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
      }
    },
