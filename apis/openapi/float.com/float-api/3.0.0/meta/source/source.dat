          },
          {
            "$ref": "../swagger-api-v3.yaml#/components/parameters/fields"
          },
          {
            "$ref": "#/components/parameters/expand"
          }
        ],
        "responses": {
          "200": {
            "description": "The list of phases",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "title": "Array of phases",
                  "items": {
                    "$ref": "#/components/schemas/Phase"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new phase",
        "operationId": "addPhase",
        "tags": [
          "Phases"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Phase"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "If the phase was successfully created, the response returns the full information about that phase.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Phase"
                }
              }
            }
          },
          "422": {
            "description": "Data validation failure."
          }
        }
