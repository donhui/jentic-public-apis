{
  "openapi": "3.0.3",
  "info": {
    "title": "itch.io Server-Side API",
    "description": "Server-side API for itch.io, the open marketplace for independent digital creators. Provides access to user profiles, game listings, download keys, and purchase information.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://itch.io/docs/api/serverside"
  },
  "servers": [
    {
      "url": "https://itch.io/api/1"
    }
  ],
  "paths": {
    "/{auth_type}/credentials/info": {
      "get": {
        "operationId": "getCredentialsInfo",
        "summary": "Get credentials information including scopes and expiration",
        "tags": ["Credentials"],
        "parameters": [
          {
            "name": "auth_type",
            "in": "path",
            "required": true,
            "description": "Authentication type: 'key' for API keys or 'jwt' for JWT tokens",
            "schema": { "type": "string", "enum": ["key", "jwt"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Credentials information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CredentialsInfo" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Invalid or expired credentials" }
        }
      }
    },
    "/{auth_type}/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get the authenticated user's profile",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "auth_type",
            "in": "path",
            "required": true,
            "description": "Authentication type: 'key' for API keys or 'jwt' for JWT tokens",
            "schema": { "type": "string", "enum": ["key", "jwt"] }
          }
        ],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Invalid credentials or insufficient scope" }
        }
      }
    },
    "/{auth_type}/my-games": {
      "get": {
        "operationId": "getMyGames",
        "summary": "List games owned by the authenticated user",
        "tags": ["Games"],
        "parameters": [
          {
            "name": "auth_type",
            "in": "path",
            "required": true,
            "description": "Authentication type: 'key' for API keys or 'jwt' for JWT tokens",
            "schema": { "type": "string", "enum": ["key", "jwt"] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of games",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "games": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Game" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Invalid credentials or insufficient scope" }
        }
      }
    },
    "/{auth_type}/game/{game_id}/download_keys": {
      "get": {
        "operationId": "getDownloadKeys",
        "summary": "Look up download keys for a game",
        "tags": ["Games"],
        "parameters": [
          {
            "name": "auth_type",
            "in": "path",
            "required": true,
            "description": "Authentication type",
            "schema": { "type": "string", "enum": ["key", "jwt"] }
          },
          {
            "name": "game_id",
            "in": "path",
            "required": true,
            "description": "The game ID",
            "schema": { "type": "integer" }
          },
          {
            "name": "download_key",
            "in": "query",
            "description": "Look up by download key string",
            "schema": { "type": "string" }
          },
          {
            "name": "user_id",
            "in": "query",
            "description": "Look up by user ID",
            "schema": { "type": "integer" }
          },
          {
            "name": "email",
            "in": "query",
            "description": "Look up by email address",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Download key information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "download_key": { "$ref": "#/components/schemas/DownloadKey" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Invalid credentials or insufficient scope" }
        }
      }
    },
    "/{auth_type}/game/{game_id}/purchases": {
      "get": {
        "operationId": "getGamePurchases",
        "summary": "Look up purchases for a game",
        "tags": ["Games"],
        "parameters": [
          {
            "name": "auth_type",
            "in": "path",
            "required": true,
            "description": "Authentication type",
            "schema": { "type": "string", "enum": ["key", "jwt"] }
          },
          {
            "name": "game_id",
            "in": "path",
            "required": true,
            "description": "The game ID",
            "schema": { "type": "integer" }
          },
          {
            "name": "email",
            "in": "query",
            "description": "Look up by email address",
            "schema": { "type": "string" }
          },
          {
            "name": "user_id",
            "in": "query",
            "description": "Look up by user ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Purchase information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "purchases": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Purchase" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Invalid credentials or insufficient scope" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CredentialsInfo": {
        "type": "object",
        "properties": {
          "scopes": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of scopes granted to the credentials"
          },
          "expires_at": {
            "type": "string",
            "description": "Expiration date for JWT tokens"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "display_name": { "type": "string" },
          "cover_url": { "type": "string", "description": "Profile image URL" },
          "url": { "type": "string", "description": "Profile URL on itch.io" },
          "gamer": { "type": "boolean" },
          "developer": { "type": "boolean" },
          "press_user": { "type": "boolean" }
        }
      },
      "Game": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "cover_url": { "type": "string" },
          "url": { "type": "string" },
          "created_at": { "type": "string", "description": "Date in YYYY-MM-DD HH:MM:ss format" },
          "downloads_count": { "type": "integer" },
          "purchases_count": { "type": "integer" },
          "views_count": { "type": "integer" },
          "min_price": { "type": "integer", "description": "Minimum price in cents" },
          "published": { "type": "boolean" },
          "p_android": { "type": "boolean", "description": "Available on Android" },
          "p_linux": { "type": "boolean", "description": "Available on Linux" },
          "p_osx": { "type": "boolean", "description": "Available on macOS" },
          "p_windows": { "type": "boolean", "description": "Available on Windows" },
          "earnings": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Earning" }
          }
        }
      },
      "Earning": {
        "type": "object",
        "properties": {
          "currency": { "type": "string" },
          "amount_formatted": { "type": "string" },
          "amount": { "type": "integer" }
        }
      },
      "DownloadKey": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "key": { "type": "string" },
          "created_at": { "type": "string" },
          "downloads": { "type": "integer" },
          "game_id": { "type": "integer" },
          "owner": { "$ref": "#/components/schemas/User" }
        }
      },
      "Purchase": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "donation": { "type": "boolean" },
          "email": { "type": "string" },
          "created_at": { "type": "string" },
          "source": { "type": "string" },
          "currency": { "type": "string" },
          "price": { "type": "string" },
          "sale_rate": { "type": "integer" },
          "game_id": { "type": "integer" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key or JWT token passed as Bearer token"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}