{
  "openapi": "3.0.3",
  "info": {
    "title": "PAGEDIUM API",
    "description": "REST API for PAGEDIUM financial alerts and trading automation platform. Manage crypto, stock, and forex alerts, API keys, notification settings, and automated trades.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://pagedium.com/docs/rest"
  },
  "servers": [
    {
      "url": "https://pagedium.com/api/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/user/user-info": {
      "get": {
        "operationId": "getuserinfo",
        "summary": "Get User Info",
        "description": "Get current authenticated user info",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "User info retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfo"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
