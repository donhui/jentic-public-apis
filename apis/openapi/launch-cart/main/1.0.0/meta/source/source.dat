  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "errors": { "type": "object" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" }
        }
      },
      "StoreSettings": {
        "type": "object",
        "additionalProperties": true
      },
      "TaxGroup": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "priority": { "type": "integer" },
          "rules": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TaxRule" }
          }
        }
      },
      "TaxRule": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "country_code": { "type": "string", "maxLength": 2 },
          "tax_percent": { "type": "number" }
        }
      },
      "CreateTaxGroupRequest": {
        "type": "object",
        "required": ["name", "priority"],
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 255 },
          "priority": { "type": "integer" },
          "rules": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TaxRule" }
          }
        }
      },
      "StoreLocation": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "address_line": { "type": "string" },
          "address_line2": { "type": "string" },
          "city": { "type": "string" },
          "postal_code": { "type": "string" },
          "country_code": { "type": "string", "maxLength": 3 },
          "state": { "type": "string" },
          "phone_number": { "type": "string", "maxLength": 50 }
        }
      },
      "CreateStoreLocationRequest": {
        "type": "object",
        "required": ["name", "address_line", "city", "postal_code", "country_code", "phone_number"],
        "properties": {
          "name": { "type": "string" },
          "address_line": { "type": "string" },
          "address_line2": { "type": "string" },
          "city": { "type": "string" },
          "postal_code": { "type": "string" },
          "country_code": { "type": "string", "maxLength": 3 },
          "state": { "type": "string" },
          "phone_number": { "type": "string", "maxLength": 50 }
        }
      },
      "ShippingProfile": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "settings": { "type": "object" }
        }
      },
      "Currency": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "code": { "type": "string" },
          "is_base": { "type": "boolean" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "sku": { "type": "string" },
          "upc": { "type": "string" },
          "price": { "type": "number" },
          "quantity": { "type": "integer" },
          "vendor": { "type": "string" },
          "type": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ProductInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "sku": { "type": "string" },
          "upc": { "type": "string" },
          "price": { "type": "number" },
          "quantity": { "type": "integer" },
          "vendor": { "type": "string" },
          "type": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ProductVariant": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "product_id": { "type": "integer" },
          "sku": { "type": "string" },
          "upc": { "type": "string" },
          "name": { "type": "string" },
          "quantity": { "type": "integer" },
          "price": { "type": "number" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": { "type": "string" },
          "total": { "type": "number" },
          "customer_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      },
      "CustomerInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      },
      "Subscriber": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "email": { "type": "string", "format": "email" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "PromotionalBar": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "settings": { "type": "object" },
          "is_active": { "type": "boolean" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" }
        }
      },
      "PromotionalBarInput": {
        "type": "object",
        "required": ["name", "settings"],
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 255 },
          "settings": { "type": "array", "items": { "type": "string" } },
          "is_active": { "type": "boolean" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" }
        }
      },
      "Popup": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "settings": { "type": "object" }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "hook": { "type": "string" },
          "callback": { "type": "string", "format": "uri" },
          "type": { "type": "string" }
        }
      },
      "CreateWebhookRequest": {
        "type": "object",
        "required": ["hook", "callback", "type"],
        "properties": {
          "hook": { "type": "string" },
          "callback": { "type": "string", "format": "uri" },
          "type": { "type": "string", "enum": ["json"] }
        }
      }
    }
  }
}