{
  "openapi": "3.0.3",
  "info": {
    "title": "Launch Cart API",
    "version": "1.0.0",
    "description": "Launch Cart is an ecommerce SaaS platform to empower small business owners to build and sell online.",
    "x-jentic-source-url": "https://app.launchcart.com/api/v1/docs"
  },
  "servers": [
    {
      "url": "https://app.launchcart.com/api/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Settings", "description": "Store settings management" },
    { "name": "Tax", "description": "Tax configuration" },
    { "name": "StoreLocations", "description": "Store location management" },
    { "name": "Shipping", "description": "Shipping configuration" },
    { "name": "Currency", "description": "Currency management" },
    { "name": "Products", "description": "Product management" },
    { "name": "Inventory", "description": "Inventory management" },
    { "name": "Orders", "description": "Order management" },
    { "name": "Customers", "description": "Customer management" },
    { "name": "Marketing", "description": "Promotional bars and popups" },
    { "name": "Webhooks", "description": "Webhook management" },
    { "name": "Reviews", "description": "Review management" },
    { "name": "Templates", "description": "Custom template management" },
    { "name": "Subscribers", "description": "Subscriber management" }
  ],
  "paths": {
    "/store/{storeId}/settings": {
      "get": {
        "operationId": "getStoreSettings",
        "summary": "Get store settings",
        "tags": ["Settings"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Store settings", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StoreSettings" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "updateStoreSettings",
        "summary": "Update store settings",
        "tags": ["Settings"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object", "properties": { "settings": { "type": "array", "items": { "type": "string" } } } } } }
        },
        "responses": {
          "200": { "description": "Settings updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StoreSettings" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/tax/groups": {
      "get": {
        "operationId": "listTaxGroups",
        "summary": "List tax groups",
        "tags": ["Tax"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Tax groups", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TaxGroup" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createTaxGroup",
        "summary": "Create a tax group",
        "tags": ["Tax"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateTaxGroupRequest" } } }
        },
        "responses": {
          "200": { "description": "Tax group created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaxGroup" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/tax/groups/{group}": {
      "get": {
        "operationId": "getTaxGroup",
        "summary": "Get a specific tax group",
        "tags": ["Tax"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "group", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Tax group details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaxGroup" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteTaxGroup",
        "summary": "Delete a tax group",
        "tags": ["Tax"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "group", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Tax group deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/storeLocation": {
      "get": {
        "operationId": "listStoreLocations",
        "summary": "List store locations",
        "tags": ["StoreLocations"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Store locations", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/StoreLocation" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createStoreLocation",
        "summary": "Create a store location",
        "tags": ["StoreLocations"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateStoreLocationRequest" } } }
        },
        "responses": {
          "200": { "description": "Location created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StoreLocation" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/storeLocation/{locationId}": {
      "delete": {
        "operationId": "deleteStoreLocation",
        "summary": "Delete a store location",
        "tags": ["StoreLocations"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "locationId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Location deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/shipping/profiles": {
      "get": {
        "operationId": "listShippingProfiles",
        "summary": "List shipping profiles",
        "tags": ["Shipping"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Shipping profiles", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ShippingProfile" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createShippingProfile",
        "summary": "Create a shipping profile",
        "tags": ["Shipping"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object", "properties": { "settings": { "type": "array", "items": { "type": "string" } } } } } }
        },
        "responses": {
          "200": { "description": "Profile created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ShippingProfile" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/shipping/profiles/{profileId}": {
      "get": {
        "operationId": "getShippingProfile",
        "summary": "Get a shipping profile",
        "tags": ["Shipping"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "profileId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Shipping profile", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ShippingProfile" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteShippingProfile",
        "summary": "Delete a shipping profile",
        "tags": ["Shipping"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "profileId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Profile deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/currency": {
      "get": {
        "operationId": "listCurrencies",
        "summary": "List store currencies",
        "tags": ["Currency"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Currency list", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Currency" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/currency/attach": {
      "post": {
        "operationId": "attachCurrency",
        "summary": "Attach a currency to the store",
        "tags": ["Currency"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["code"], "properties": { "code": { "type": "string", "minLength": 3, "maxLength": 3 } } } } }
        },
        "responses": {
          "200": { "description": "Currency attached", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/currency/base": {
      "post": {
        "operationId": "setBaseCurrency",
        "summary": "Set base currency",
        "tags": ["Currency"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["code"], "properties": { "code": { "type": "string", "minLength": 3, "maxLength": 3 } } } } }
        },
        "responses": {
          "200": { "description": "Base currency set", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/domains": {
      "get": {
        "operationId": "getStoreDomains",
        "summary": "Get store domains",
        "tags": ["Settings"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Store domains", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/settings/storeInfo": {
      "get": {
        "operationId": "getStoreInfo",
        "summary": "Get store information",
        "tags": ["Settings"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Store information", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "List products",
        "tags": ["Products"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Product list", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createProduct",
        "summary": "Create a product",
        "tags": ["Products"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProductInput" } } }
        },
        "responses": {
          "200": { "description": "Product created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/products/{productId}": {
      "get": {
        "operationId": "getProduct",
        "summary": "Get a product",
        "tags": ["Products"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "productId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Product details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "patch": {
        "operationId": "updateProduct",
        "summary": "Update a product",
        "tags": ["Products"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "productId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProductInput" } } }
        },
        "responses": {
          "200": { "description": "Product updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/products/{productId}/inventory": {
      "put": {
        "operationId": "updateProductInventory",
        "summary": "Update product inventory",
        "tags": ["Inventory"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "productId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "quantity": { "type": "integer" } } } } }
        },
        "responses": {
          "200": { "description": "Inventory updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/products/sku/{sku}/inventory": {
      "put": {
        "operationId": "updateInventoryBySku",
        "summary": "Update inventory by SKU",
        "tags": ["Inventory"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "sku", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "quantity": { "type": "integer" } } } } }
        },
        "responses": {
          "200": { "description": "Inventory updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/products/inventory": {
      "get": {
        "operationId": "getInventory",
        "summary": "Get product inventory",
        "tags": ["Inventory"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Inventory list", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/products/variants": {
      "get": {
        "operationId": "listProductVariants",
        "summary": "List product variants",
        "tags": ["Products"],
        "parameters": [
          { "name": "storeId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "filterBy", "in": "query", "schema": { "type": "string", "enum": ["sku", "upc", "name", "quantity", "vendor", "type", "tag"] } },
          { "name": "comparison", "in": "query", "schema": { "type": "string", "enum": ["eq", "neq", "gt", "lt"] } },
          { "name": "sortDirection", "in": "query", "schema": { "type": "string", "enum": ["DESC", "ASC"] } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string" } },
          { "name": "variants", "in": "query", "schema": { "type": "string", "enum": ["simple", "grouped"] } }
        ],
        "responses": {
          "200": { "description": "Product variants", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ProductVariant" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/store/{storeId}/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "List orders",
