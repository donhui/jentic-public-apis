{
  "openapi": "3.0.3",
  "info": {
    "title": "SITA Airport Reference API",
    "description": "API for retrieving airport reference data including airport lookup by code, name matching, distance calculations, nearest airport, and country comparison.",
    "version": "3.0.0",
    "x-jentic-source-url": "https://www.developer.aero/api-catalog/airport-api-overview"
  },
  "servers": [
    {
      "url": "https://sitaopen.api.aero/data",
      "description": "SITA Airport API Server"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Airports",
      "description": "Airport data lookup and search"
    },
    {
      "name": "Distance",
      "description": "Distance calculations between airports"
    },
    {
      "name": "Geolocation",
      "description": "Location-based airport search"
    },
    {
      "name": "Comparison",
      "description": "Airport comparison operations"
    }
  ],
  "paths": {
    "/v3/airports": {
      "get": {
        "operationId": "getAllAirports",
        "tags": ["Airports"],
        "summary": "Get all airports",
        "responses": {
          "200": {
            "description": "List of all airports",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AirportListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v3/airports/{code}": {
      "get": {
        "operationId": "getAirportByCode",
        "tags": ["Airports"],
        "summary": "Get airport by IATA or ICAO code",
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA or ICAO airport code"
          }
        ],
        "responses": {
          "200": {
            "description": "Airport details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AirportListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v3/airports/match/{airportNamePartial}": {
      "get": {
        "operationId": "matchAirports",
        "tags": ["Airports"],
        "summary": "Search airports by partial name or code",
        "parameters": [
          {
            "name": "airportNamePartial",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Text to match against IATA/ICAO codes, city, and airport name"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching airports",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AirportListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v3/airports/distance/{code1}/{code2}": {
      "get": {
        "operationId": "getDistanceBetweenAirports",
        "tags": ["Distance"],
        "summary": "Calculate distance between two airports",
        "parameters": [
          {
            "name": "code1",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "First airport code"
          },
          {
            "name": "code2",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Second airport code"
          }
        ],
        "responses": {
          "200": {
            "description": "Distance between airports",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DistanceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v3/airports/nearest/{latitude}/{longitude}": {
      "get": {
        "operationId": "getNearestAirport",
        "tags": ["Geolocation"],
        "summary": "Find the nearest airport to coordinates",
        "parameters": [
          {
            "name": "latitude",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Latitude coordinate"
          },
          {
            "name": "longitude",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Longitude coordinate"
          }
        ],
        "responses": {
          "200": {
            "description": "Nearest airport",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AirportListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v3/airports/samecountry/{code1}/{code2}": {
      "get": {
        "operationId": "checkSameCountry",
        "tags": ["Comparison"],
        "summary": "Check if two airports are in the same country",
        "parameters": [
          {
            "name": "code1",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "First airport code"
          },
          {
            "name": "code2",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Second airport code"
          }
        ],
        "responses": {
          "200": {
            "description": "Same country check result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SameCountryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://sitaopen.api.aero/data/oauth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "AirportListResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "airports": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Airport"
            }
          }
        }
      },
      "Airport": {
        "type": "object",
        "properties": {
          "icaoCode": {
            "type": "string"
          },
          "iataCode": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "countryCode": {
            "type": "string"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "elevation": {
            "type": "number"
          },
          "timezone": {
            "type": "string"
          },
          "continent": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "ident": {
            "type": "string"
          },
          "localCode": {
            "type": "string"
          }
        }
      },
      "DistanceResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "distance": {
            "type": "string"
          },
          "units": {
            "type": "string"
          }
        }
      },
      "SameCountryResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "sameCountry": {
            "type": "boolean"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}