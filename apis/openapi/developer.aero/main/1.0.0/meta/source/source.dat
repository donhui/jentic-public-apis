{
  "openapi": "3.0.3",
  "info": {
    "title": "SITA Flight Schedule API",
    "description": "API for retrieving flight schedule data by route, airline, flight number, and airport direction.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.developer.aero/api-catalog/flight-schedule-overview"
  },
  "servers": [
    {
      "url": "https://sitaopen.api.aero/schedule/v1",
      "description": "SITA Flight Schedule API Server"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Routes",
      "description": "Schedule lookup by departure and arrival airports"
    },
    {
      "name": "Airlines",
      "description": "Schedule lookup by airline"
    },
    {
      "name": "Airports",
      "description": "Schedule lookup by airport and direction"
    },
    {
      "name": "Authentication",
      "description": "OAuth token management"
    }
  ],
  "paths": {
    "/route/departure/{departure}/arrival/{arrival}": {
      "get": {
        "operationId": "getScheduleByRoute",
        "tags": ["Routes"],
        "summary": "Get schedule by departure and arrival airports",
        "parameters": [
          {
            "name": "departure",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA or ICAO departure airport code"
          },
          {
            "name": "arrival",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA or ICAO arrival airport code"
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (yyyy-MM-dd)"
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (yyyy-MM-dd)"
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Whether to group marketing carriers"
          }
        ],
        "responses": {
          "200": {
            "description": "Flight schedule records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightScheduleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/route/departure/{departure}/arrival/{arrival}/airline/{airline}": {
      "get": {
        "operationId": "getScheduleByRouteAndAirline",
        "tags": ["Routes"],
        "summary": "Get schedule by route filtered by airline",
        "parameters": [
          {
            "name": "departure",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA or ICAO departure airport code"
          },
          {
            "name": "arrival",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA or ICAO arrival airport code"
          },
          {
            "name": "airline",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA or ICAO airline code"
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Flight schedule records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightScheduleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/route/departure/{departure}/arrival/{arrival}/airline/{airline}/flightNumber/{flightNumber}": {
      "get": {
        "operationId": "getScheduleByRouteAirlineAndFlight",
        "tags": ["Routes"],
        "summary": "Get schedule by route, airline, and flight number",
        "parameters": [
          {
            "name": "departure",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "arrival",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "airline",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flightNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Flight number"
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Flight schedule record",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightScheduleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/airline/{airline}": {
      "get": {
        "operationId": "getScheduleByAirline",
        "tags": ["Airlines"],
        "summary": "Get all schedules for an airline",
        "parameters": [
          {
            "name": "airline",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA or ICAO airline code"
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All airline schedules",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightScheduleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/airline/{airline}/flightNumber/{flightNumber}": {
      "get": {
        "operationId": "getScheduleByAirlineAndFlight",
        "tags": ["Airlines"],
        "summary": "Get schedule for a specific airline flight",
        "parameters": [
          {
            "name": "airline",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flightNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Flight schedule records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightScheduleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/airport/{airport}/direction/{adi}": {
      "get": {
        "operationId": "getScheduleByAirportDirection",
        "tags": ["Airports"],
        "summary": "Get arrivals or departures for an airport",
        "parameters": [
          {
            "name": "airport",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA or ICAO airport code"
          },
          {
            "name": "adi",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["A", "D"]
            },
            "description": "Direction: A for arrivals, D for departures"
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Airport schedule records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightScheduleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://sitaopen.api.aero/schedule/oauth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "FlightScheduleResponse": {
        "type": "object",
        "properties": {
          "schedules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FlightSchedule"
            }
          },
          "continuationToken": {
            "type": "string",
            "description": "Token for paginating through results"
          }
        }
      },
      "FlightSchedule": {
        "type": "object",
        "properties": {
          "flightDesignator": {
            "$ref": "#/components/schemas/FlightDesignator"
          },
          "departureStation": {
            "$ref": "#/components/schemas/Station"
          },
          "arrivalStation": {
            "$ref": "#/components/schemas/Station"
          },
          "aircraft": {
            "$ref": "#/components/schemas/Aircraft"
          },
          "marketingCarriers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MarketingCarrier"
            }
          },
          "mealService": {
            "type": "string"
          }
        }
      },
      "FlightDesignator": {
        "type": "object",
        "properties": {
          "airlineCode": {
            "type": "string"
          },
          "flightNumber": {
            "type": "string"
          },
          "operationDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "Station": {
        "type": "object",
        "properties": {
          "airportCode": {
            "type": "string"
          },
          "terminal": {
            "type": "string"
          },
          "scheduledTime": {
            "type": "string",
            "format": "date-time"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "timezone": {
            "type": "string"
          }
        }
      },
      "Aircraft": {
        "type": "object",
        "properties": {
          "iataCode": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "MarketingCarrier": {
        "type": "object",
        "properties": {
          "airlineCode": {
            "type": "string"
          },
          "flightNumber": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}