            }
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
