    "/airport/{airportCode}/direction/{adi}": {
      "get": {
        "operationId": "getschedulebyairportanddirection",
        "summary": "Schedule By Airport and Direction",
        "description": "Returns active schedules for airport filtered by departure/arrival direction.",
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "airportCode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA/ICAO airport code"
          },
          {
            "name": "adi",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "A",
                "D"
              ]
            },
            "description": "Direction: A (arrival) or D (departure)"
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Flight schedules",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ScheduleResponse": {
        "type": "object",
        "properties": {
          "departure": {
            "type": "string"
          },
          "arrival": {
            "type": "string"
          },
          "airline": {
            "type": "string"
          },
          "flightNumber": {
            "type": "string"
          },
          "schedules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FlightSchedule"
            }
          },
          "continuationToken": {
            "type": "string"
          }
        }
      },
      "FlightSchedule": {
        "type": "object",
        "properties": {
          "aircraft": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "owner": {
                "type": "string"
              }
            }
          },
          "std": {
            "type": "string",
            "description": "Scheduled time of departure"
          },
          "sta": {
            "type": "string",
            "description": "Scheduled time of arrival"
          },
          "terminal": {
            "type": "string"
          },
          "daysOfOperation": {
            "type": "string"
          },
          "marketingCarriers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "station": {
            "type": "object",
            "properties": {
              "city": {
                "type": "string"
              },
              "country": {
                "type": "string"
              },
              "timezone": {
                "type": "string"
              },
              "latitude": {
                "type": "number"
              },
              "longitude": {
                "type": "number"
              }
            }
          },
          "mealServices": {
            "type": "object"
          },
          "inFlightServices": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "object",
            "properties": {
              "error": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer"
                    },
                    "description": {
                      "type": "string"
                    },
                    "invalidParam": {
                      "type": "string"
                    },
                    "invalidValue": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://sitaopen.api.aero/schedule/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Schedules",
      "description": "Operations related to Schedules"
    }
  ]
}