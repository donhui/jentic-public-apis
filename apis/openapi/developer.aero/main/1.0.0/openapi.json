{
  "openapi": "3.0.3",
  "info": {
    "title": "SITA Flight Schedule API",
    "version": "1.0.0",
    "description": "SITA Flight Schedule API for retrieving flight schedules by route, airline, flight number, and airport direction.",
    "x-jentic-source-url": "https://www.developer.aero/api-catalog/flight-schedule-overview"
  },
  "servers": [
    {
      "url": "https://sitaopen.api.aero/schedule/v1"
    }
  ],
  "paths": {
    "/route/departure/{departureAirport}/arrival/{arrivalAirport}": {
      "get": {
        "operationId": "getschedulebyroute",
        "summary": "Schedule By Route",
        "description": "Returns flight schedules based on departure and arrival airports.",
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "departureAirport",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA/ICAO departure airport code"
          },
          {
            "name": "arrivalAirport",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA/ICAO arrival airport code"
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (yyyy-MM-dd)"
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (yyyy-MM-dd)"
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Group marketing/operating carriers"
          }
        ],
        "responses": {
          "200": {
            "description": "Flight schedules",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/route/departure/{departureAirport}/arrival/{arrivalAirport}/airline/{airline}": {
      "get": {
        "operationId": "getschedulebyrouteandairline",
        "summary": "Schedule By Route and Airline",
        "description": "Returns flight schedules for specified route and airline.",
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "departureAirport",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA/ICAO departure airport code"
          },
          {
            "name": "arrivalAirport",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA/ICAO arrival airport code"
          },
          {
            "name": "airline",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "IATA/ICAO airline code"
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "airline",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The airline"
          }
        ],
        "responses": {
          "200": {
            "description": "Flight schedules",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScheduleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
