        }
      }
    },
    "/airline/{airline}/flightNumber/{flightNumber}": {
      "get": {
        "operationId": "getschedulebyairlineandflight",
        "summary": "Schedule By Airline and Flight Number",
        "description": "Returns all active schedules for airline and specific flight number.",
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "airline",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flightNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "operationDateFrom",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "operationDateTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "groupMarketingCarriers",
            "in": "query",
