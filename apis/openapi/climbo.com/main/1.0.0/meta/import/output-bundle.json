{
  "openapi": "3.0.3",
  "info": {
    "title": "Climbo API",
    "version": "1.0.0",
    "description": "Climbo 2.0 is a white-label review management platform that helps businesses collect, manage, and showcase online reviews. The API provides both Agency Mode and Clients Mode endpoints for managing clients, locations, reviews, templates, campaigns, contacts, and feedback.",
    "x-jentic-source-url": "https://climbo.readme.io"
  },
  "servers": [
    {
      "url": "https://api.climbo.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/client": {
      "post": {
        "operationId": "addClient",
        "summary": "Add client",
        "description": "Create a new client in agency mode",
        "tags": [
          "Agency - Clients"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Client created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          }
        }
      }
    },
    "/client/{client_id}": {
      "get": {
        "operationId": "getClient",
        "summary": "Get client",
        "description": "Retrieve a specific client by ID",
        "tags": [
          "Agency - Clients"
        ],
        "parameters": [
          {
            "name": "client_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "login_link",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Include a login link in the response"
          }
        ],
        "responses": {
          "200": {
            "description": "Client details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteClient",
        "summary": "Delete client",
        "description": "Remove a client",
        "tags": [
          "Agency - Clients"
        ],
        "parameters": [
          {
            "name": "client_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Client deleted"
          }
        }
      }
    },
    "/client/{client_id}/change-plan": {
      "post": {
        "operationId": "changeClientPlan",
        "summary": "Change client plan",
        "description": "Modify a client's subscription plan",
        "tags": [
          "Agency - Clients"
