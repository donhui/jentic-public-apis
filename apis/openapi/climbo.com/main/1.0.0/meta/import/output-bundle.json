  "components": {
    "schemas": {
      "CreateClientRequest": {
        "type": "object",
        "required": [
          "email",
          "plan_id"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email of the customer"
          },
          "plan_id": {
            "type": "string",
            "description": "Plan ID to associate to the customer"
          },
          "user_name": {
            "type": "string",
            "description": "Name of the customer"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "description": "Must be at least 8 characters"
          },
          "welcome": {
            "type": "string",
            "description": "Enables welcome email dispatch with login link",
            "default": "true"
          }
        }
      },
      "Client": {
