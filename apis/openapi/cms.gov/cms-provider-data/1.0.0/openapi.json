  "components": {
    "securitySchemes": {},
    "schemas": {
      "QueryRequest": {
        "type": "object",
        "description": "Request body for querying provider data.",
        "properties": {
          "conditions": {
            "type": "array",
            "description": "Filter conditions for the query.",
            "items": {
              "type": "object",
              "properties": {
                "resource": { "type": "string", "description": "Resource identifier." },
                "property": { "type": "string", "description": "Field name to filter on." },
                "value": { "type": "string", "description": "Value to match." },
                "operator": { "type": "string", "description": "Comparison operator.", "enum": ["=", "!=", "<", ">", "<=", ">=", "LIKE", "IN"] }
              }
            }
          },
          "limit": { "type": "integer", "description": "Maximum results to return.", "default": 50 },
          "offset": { "type": "integer", "description": "Number of results to skip.", "default": 0 },
          "sort": {
            "type": "object",
            "properties": {
              "property": { "type": "string" },
              "order": { "type": "string", "enum": ["asc", "desc"] }
            }
          },
          "properties": {
            "type": "array",
            "description": "Specific fields to include in results.",
            "items": { "type": "string" }
          }
        }
      },
      "QueryResponse": {
        "type": "object",
        "description": "Response from a datastore query.",
        "properties": {
          "results": {
            "type": "array",
            "description": "Array of result records.",
            "items": { "type": "object" }
          },
          "count": { "type": "integer", "description": "Total number of matching records." },
          "schema": {
            "type": "object",
            "description": "Schema information for the returned fields."
          },
          "query": {
            "type": "object",
            "description": "Echo of the query that was executed."
          }
        }
      },
      "DatasetMetadata": {
        "type": "object",
        "description": "Metadata describing a CMS Provider Data dataset.",
        "properties": {
          "identifier": { "type": "string", "description": "Unique dataset identifier." },
          "title": { "type": "string", "description": "Human-readable dataset title." },
          "description": { "type": "string", "description": "Dataset description." },
          "keyword": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Tags/keywords for the dataset."
          },
          "theme": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Thematic categories."
          },
          "modified": { "type": "string", "description": "Last modification date." },
          "publisher": {
            "type": "object",
            "properties": {
              "name": { "type": "string" }
            }
          },
          "contactPoint": {
            "type": "object",
            "properties": {
              "fn": { "type": "string" },
              "hasEmail": { "type": "string" }
            }
          },
          "distribution": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "downloadURL": { "type": "string", "format": "uri" },
                "mediaType": { "type": "string" },
                "title": { "type": "string" }
              }
            }
          }
        }
      },
      "DatastoreImport": {
        "type": "object",
        "description": "Datastore import status and details.",
        "properties": {
          "identifier": { "type": "string" },
          "status": { "type": "string" },
          "records_imported": { "type": "integer" },
          "created": { "type": "string" },
          "updated": { "type": "string" }
        }
      },
      "DatastoreImportRequest": {
        "type": "object",
        "description": "Request to start a datastore import.",
        "properties": {
          "resource": { "type": "string", "description": "Resource identifier to import." }
        },
        "required": ["resource"]
      },
      "SearchResponse": {
        "type": "object",
        "description": "Search results from the catalog.",
