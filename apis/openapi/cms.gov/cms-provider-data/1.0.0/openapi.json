        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "SQL-like query string (e.g., [SELECT * FROM distributionId][WHERE field = 'value'][ORDER BY field ASC][LIMIT 10][OFFSET 0]).",
