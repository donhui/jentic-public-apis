{
  "openapi": "3.0.3",
  "info": {
    "title": "CMS Provider Data API",
    "description": "The CMS Provider Data API provides access to Medicare provider data, including information about hospitals, nursing homes, dialysis facilities, home health agencies, hospices, physicians, and other healthcare providers. It supports querying, searching, and downloading datasets using DKAN-based endpoints.",
    "version": "1.0.0",
    "contact": {
      "name": "CMS Provider Data Support",
      "url": "https://data.cms.gov/provider-data/"
    },
    "license": {
      "name": "Public Domain",
      "url": "https://www.usa.gov/government-works"
    },
    "x-jentic-source-url": "https://data.cms.gov/provider-data/"
  },
  "servers": [
    {
      "url": "https://data.cms.gov/provider-data/api/1",
      "description": "CMS Provider Data API v1"
    }
  ],
  "security": [],
  "tags": [
    {
      "name": "Datastore Query",
      "description": "Query provider data datasets"
    },
    {
      "name": "Datastore SQL",
      "description": "Execute SQL-like queries against datasets"
    },
    {
      "name": "Datastore Import",
      "description": "Manage datastore imports"
    },
    {
      "name": "Metastore",
      "description": "Access dataset metadata schemas and items"
    },
    {
      "name": "Search",
      "description": "Search the dataset catalog"
    }
  ],
  "paths": {
    "/datastore/query": {
      "get": {
        "operationId": "queryMultipleResourcesGet",
        "summary": "Query multiple resources",
        "description": "Query across multiple provider data resources using GET parameters.",
        "tags": ["Datastore Query"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return.",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of results to skip.",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Field to sort by.",
            "schema": { "type": "string" }
          },
          {
            "name": "sort_order",
            "in": "query",
            "description": "Sort order.",
            "schema": { "type": "string", "enum": ["asc", "desc"], "default": "asc" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful query response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QueryResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "post": {
        "operationId": "queryMultipleResourcesPost",
        "summary": "Query multiple resources",
        "description": "Query across multiple provider data resources using a POST body with query parameters.",
        "tags": ["Datastore Query"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/QueryRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful query response.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QueryResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/datastore/query/download": {
      "get": {
        "operationId": "downloadQueryResultsGet",
        "summary": "Download query results",
        "description": "Download the results of a multi-resource query as a file.",
        "tags": ["Datastore Query"],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "description": "Download format.",
            "schema": { "type": "string", "enum": ["csv", "json"], "default": "csv" }
          }
        ],
        "responses": {
          "200": {
            "description": "File download.",
            "content": {
              "text/csv": { "schema": { "type": "string" } },
              "application/json": { "schema": { "type": "array", "items": { "type": "object" } } }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "post": {
        "operationId": "downloadQueryResultsPost",
        "summary": "Download query results via POST",
        "description": "Download the results of a multi-resource query as a file using POST body.",
        "tags": ["Datastore Query"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/QueryRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File download.",
            "content": {
              "text/csv": { "schema": { "type": "string" } },
              "application/json": { "schema": { "type": "array", "items": { "type": "object" } } }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
