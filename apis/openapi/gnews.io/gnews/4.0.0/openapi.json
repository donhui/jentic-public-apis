{
  "openapi": "3.0.3",
  "info": {
    "title": "GNews API",
    "description": "GNews API allows you to search for news articles from various sources across the web. It provides access to top headlines based on Google News rankings and a powerful search endpoint for finding articles by keywords, with filtering by language, country, date range, and topic.",
    "version": "4.0.0",
    "contact": {
      "name": "GNews",
      "url": "https://gnews.io"
    },
    "x-jentic-source-url": "https://gnews.io/"
  },
  "servers": [
    {
      "url": "https://gnews.io/api/v4",
      "description": "GNews API v4 production server"
    }
  ],
  "security": [
    {
      "ApiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Headlines",
      "description": "Trending articles and top headlines"
    },
    {
      "name": "Search",
      "description": "Search for news articles by keywords"
    }
  ],
  "paths": {
    "/top-headlines": {
      "get": {
        "operationId": "getTopHeadlines",
        "summary": "Get top headlines",
        "description": "Retrieve trending articles based on Google News rankings. Can be filtered by category, language, country, and date range. Supports optional keyword search within top headlines.",
        "tags": ["Headlines"],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "Your GNews API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "description": "News category to filter by",
            "schema": {
              "type": "string",
              "enum": ["general", "world", "nation", "business", "technology", "entertainment", "sports", "science", "health"],
              "default": "general"
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "2-letter language code for filtering articles",
            "schema": {
              "type": "string",
              "enum": ["ar", "bn", "bg", "ca", "zh", "cs", "nl", "en", "et", "fi", "fr", "de", "el", "gu", "he", "hi", "hu", "id", "it", "ja", "ko", "lv", "lt", "ml", "mr", "no", "pl", "pt", "pa", "ro", "ru", "sk", "sl", "es", "sv", "ta", "te", "th", "tr", "uk", "vi"]
            }
          },
          {
            "name": "country",
            "in": "query",
            "required": false,
            "description": "2-letter country code for filtering articles",
            "schema": {
              "type": "string",
              "enum": ["ar", "au", "at", "bd", "be", "bw", "br", "bg", "ca", "cl", "cn", "co", "cu", "cz", "eg", "ee", "et", "fi", "fr", "de", "gh", "gr", "hk", "hu", "in", "id", "ie", "il", "it", "jp", "ke", "lv", "lb", "lt", "my", "mx", "ma", "na", "nl", "nz", "ng", "no", "pk", "pe", "ph", "pl", "pt", "ro", "ru", "sa", "sn", "sg", "sk", "si", "za", "kr", "es", "se", "ch", "tw", "tz", "th", "tr", "ug", "ua", "ae", "gb", "us", "ve", "vn", "zw"]
            }
          },
          {
            "name": "max",
            "in": "query",
            "required": false,
            "description": "Maximum number of articles to return (depends on subscription tier)",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Optional search keywords to filter within top headlines (max 200 characters). Supports boolean operators: AND, OR, NOT, and phrase matching with quotes.",
            "schema": {
              "type": "string",
              "maxLength": 200
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "description": "Filter articles published after this date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "description": "Filter articles published before this date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "nullable",
            "in": "query",
            "required": false,
            "description": "Allow null values in specified fields (comma-separated: description, content, image)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination (max 1000 articles accessible)",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with top headlines",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Feature not available on your plan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests - Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "searchArticles",
        "summary": "Search for articles",
        "description": "Find articles matching keywords with advanced filtering options including language, country, date range, and field targeting. Supports boolean search operators (AND, OR, NOT) and phrase matching.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "Your GNews API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search keywords (max 200 characters). Supports boolean operators: AND (or space), OR, NOT, phrase matching with quotes, and grouping with parentheses.",
            "schema": {
              "type": "string",
              "maxLength": 200
            }
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "2-letter language code for filtering articles",
            "schema": {
              "type": "string",
              "enum": ["ar", "bn", "bg", "ca", "zh", "cs", "nl", "en", "et", "fi", "fr", "de", "el", "gu", "he", "hi", "hu", "id", "it", "ja", "ko", "lv", "lt", "ml", "mr", "no", "pl", "pt", "pa", "ro", "ru", "sk", "sl", "es", "sv", "ta", "te", "th", "tr", "uk", "vi"]
            }
          },
          {
            "name": "country",
            "in": "query",
            "required": false,
            "description": "2-letter country code for filtering articles",
            "schema": {
              "type": "string",
              "enum": ["ar", "au", "at", "bd", "be", "bw", "br", "bg", "ca", "cl", "cn", "co", "cu", "cz", "eg", "ee", "et", "fi", "fr", "de", "gh", "gr", "hk", "hu", "in", "id", "ie", "il", "it", "jp", "ke", "lv", "lb", "lt", "my", "mx", "ma", "na", "nl", "nz", "ng", "no", "pk", "pe", "ph", "pl", "pt", "ro", "ru", "sa", "sn", "sg", "sk", "si", "za", "kr", "es", "se", "ch", "tw", "tz", "th", "tr", "ug", "ua", "ae", "gb", "us", "ve", "vn", "zw"]
            }
          },
          {
            "name": "max",
            "in": "query",
            "required": false,
            "description": "Maximum number of articles to return",
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "in",
            "in": "query",
            "required": false,
            "description": "Specify which fields to search in (comma-separated: title, description, content)",
            "schema": {
              "type": "string",
              "default": "title,description"
            }
          },
          {
            "name": "sortby",
            "in": "query",
            "required": false,
            "description": "Sort order for results",
            "schema": {
              "type": "string",
              "enum": ["publishedAt", "relevance"],
              "default": "publishedAt"
            }
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "description": "Filter articles published after this date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "description": "Filter articles published before this date (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "nullable",
            "in": "query",
            "required": false,
            "description": "Allow null values in specified fields (comma-separated: description, content, image)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination (max 1000 articles accessible)",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArticleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Feature not available on your plan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too Many Requests - Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "apikey",
        "description": "API key obtained by registering at https://gnews.io/register"
      }
    },
    "schemas": {
      "Article": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Article headline"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Short article description"
          },
          "content": {
            "type": "string",
            "nullable": true,
            "description": "Article content (may be truncated on free plans)"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the original article"
          },
          "image": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL of the article's featured image"
          },
          "publishedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Publication date and time in ISO 8601 format"
          },
          "source": {
            "$ref": "#/components/schemas/Source"
          }
        }
      },
      "Source": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Source name"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Source website URL"
          }
        }
      },
      "ArticleResponse": {
        "type": "object",
        "properties": {
          "totalArticles": {
            "type": "integer",
            "description": "Total number of articles matching the query"
          },
          "articles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Article"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of error messages"
          }
        }
      }
    }
  }
}
