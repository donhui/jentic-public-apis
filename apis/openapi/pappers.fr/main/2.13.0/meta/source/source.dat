            "description": "Code postal de l'\u00e9tablissement.",
            "type": "string",
            "format": "nullable",
            "example": "75009"
          },
          "ville": {
            "description": "Ville de l'\u00e9tablissement.",
            "type": "string",
            "format": "nullable",
