          },
          "libelle_voie": {
            "description": "Libell\u00e9 de la voie de l'\u00e9tablissement.",
            "type": "string",
            "format": "nullable",
            "example": "DE LONDRES"
          },
          "complement_adresse": {
            "description": "Compl\u00e9ment d'adresse de l'\u00e9tablissement.",
            "type": "string",
            "format": "nullable",
            "example": null
          },
          "adresse_ligne_1": {
