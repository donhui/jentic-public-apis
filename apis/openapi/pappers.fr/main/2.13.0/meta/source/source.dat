              "devise": {
                "description": "Devise des comptes.",
                "type": "string",
                "example": "EUR"
              },
              "devise_origine": {
                "description": "Devise d'origine en cas de conversion.",
                "type": "string",
                "format": "nullable"
              },
              "confidentialite": {
                "description": "Confidentialit\u00e9 totale des comptes.",
                "type": "boolean"
              },
              "confidentialite_compte_de_resultat": {
                "description": "Confidentialit\u00e9 partielle des comptes (seul le compte de r\u00e9sultat est confidentiel, le reste des comptes sont disponibles).",
                "type": "boolean"
