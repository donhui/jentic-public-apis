          "date_de_creation": {
            "type": "string",
            "format": "nullable",
            "example": "2011-05-12T22:00:00.000Z"
          },
          "numero_voie": {
            "description": "Num\u00e9ro de voie de l'\u00e9tablissement.",
            "type": "integer",
            "format": "nullable",
            "example": 8
          },
          "indice_repetition": {
