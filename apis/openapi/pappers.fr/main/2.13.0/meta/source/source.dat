          },
          "pays": {
            "description": "Pays de l'\u00e9tablissement",
            "type": "string",
            "format": "nullable",
            "example": "France"
          },
          "code_pays": {
            "description": "Code du pays de l'\u00e9tablissement",
            "type": "string",
            "format": "nullable",
