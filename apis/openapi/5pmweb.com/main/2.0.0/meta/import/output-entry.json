{
  "openapi": "3.0.3",
  "info": {
    "title": "5pm Project Management API",
    "version": "2.0.0",
    "description": "REST-style API for 5pm project management platform. Provides access to projects, tasks, activity, users, and project groups. Supports XML and JSON response formats.",
    "x-jentic-source-url": "https://www.5pmweb.com/5pm_api.php"
  },
  "servers": [
    {
      "url": "https://{host}/api/v2",
      "description": "5pm API server",
      "variables": {
        "host": {
          "default": "demo.5pmweb.com",
          "description": "Your 5pm instance hostname"
        }
      }
    }
  ],
  "paths": {
    "/service/get/authentication/signIn": {
      "get": {
        "operationId": "signin",
        "summary": "Sign in and obtain a session ID",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "login",
            "in": "query",
            "required": true,
            "description": "User email/login",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "password",
            "in": "query",
            "required": true,
            "description": "User password",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "retType",
            "in": "query",
            "required": false,
            "description": "Response type (xml or json)",
            "schema": {
              "type": "string",
              "enum": [
                "xml",
                "json"
              ],
              "default": "xml"
            }
          }
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Session ID returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignInResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid credentials"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/service/get/projects/getAll": {
      "get": {
        "operationId": "listprojects",
        "summary": "Get all projects",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "sessionId",
            "in": "query",
            "required": false,
            "description": "Session ID from sign in",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_login",
            "in": "query",
            "required": false,
            "description": "Alternative auth: user login",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_password",
            "in": "query",
            "required": false,
            "description": "Alternative auth: user password",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "retType",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "xml",
                "json"
              ],
              "default": "xml"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
