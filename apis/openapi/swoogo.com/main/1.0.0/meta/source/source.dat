          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/submissions/update/{submission_id}": {
      "put": {
        "operationId": "updateSubmission",
        "summary": "Update a submission",
        "tags": ["Submissions"],
        "parameters": [
          { "name": "submission_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SubmissionUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Submission" } } }
