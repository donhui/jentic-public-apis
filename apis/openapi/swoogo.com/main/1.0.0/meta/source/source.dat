{
  "openapi": "3.0.3",
  "info": {
    "title": "Swoogo Events API",
    "description": "Swoogo event management API for managing contacts, submissions, reviews, and contact fields.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://swoogo.readme.io/"
  },
  "servers": [
    {
      "url": "https://api.swoogo.com/api/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "OAuth2 token management"
    },
    {
      "name": "CFS Contacts",
      "description": "Call for Speaker contact management"
    },
    {
      "name": "CFS Reviews",
      "description": "Call for Speaker review management"
    },
    {
      "name": "Submissions",
      "description": "Call for Speaker submission management"
    },
    {
      "name": "Contacts",
      "description": "Contact management"
    },
    {
      "name": "Contact Fields",
      "description": "Contact field definitions"
    }
  ],
  "paths": {
    "/oauth2/token": {
      "post": {
        "operationId": "createAccessToken",
        "summary": "Generate an OAuth2 access token",
        "tags": ["Authentication"],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type"],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": ["client_credentials"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cfs-contacts": {
      "get": {
        "operationId": "listCfsContacts",
        "summary": "List call for speaker contacts",
        "tags": ["CFS Contacts"],
        "parameters": [
          {
            "name": "event_id",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          { "name": "fields", "in": "query", "schema": { "type": "string" } },
          { "name": "expand", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per-page", "in": "query", "schema": { "type": "integer" } },
          { "name": "sort", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of CFS contacts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedCfsContactResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/cfs-contacts/{contact_id}": {
      "get": {
        "operationId": "getCfsContact",
        "summary": "Get a specific CFS contact",
        "tags": ["CFS Contacts"],
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "fields", "in": "query", "schema": { "type": "string" } },
          { "name": "expand", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "CFS contact details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CfsContact" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/cfs-contacts/create": {
      "post": {
        "operationId": "createCfsContact",
        "summary": "Create a CFS contact",
        "tags": ["CFS Contacts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CfsContactCreateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CfsContact" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/cfs-contacts/update/{contact_id}": {
      "put": {
        "operationId": "updateCfsContact",
        "summary": "Update a CFS contact",
        "tags": ["CFS Contacts"],
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CfsContactUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CfsContact" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/cfs-contacts/delete/{contact_id}": {
      "delete": {
        "operationId": "deleteCfsContact",
        "summary": "Delete a CFS contact",
        "tags": ["CFS Contacts"],
        "parameters": [
          { "name": "contact_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Contact deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/cfs-reviews": {
      "get": {
        "operationId": "listCfsReviews",
        "summary": "List call for speaker reviews",
        "tags": ["CFS Reviews"],
        "parameters": [
          { "name": "event_id", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "fields", "in": "query", "schema": { "type": "string" } },
          { "name": "expand", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per-page", "in": "query", "schema": { "type": "integer" } },
          { "name": "sort", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of reviews",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedCfsReviewResponse" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/cfs-reviews/{review_id}": {
      "get": {
        "operationId": "getCfsReview",
        "summary": "Get a specific CFS review",
        "tags": ["CFS Reviews"],
        "parameters": [
          { "name": "review_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "fields", "in": "query", "schema": { "type": "string" } },
          { "name": "expand", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Review details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CfsReview" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/cfs-reviews/create": {
      "post": {
        "operationId": "createCfsReview",
        "summary": "Create a CFS review",
        "tags": ["CFS Reviews"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CfsReviewCreateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Review created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CfsReview" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/cfs-reviews/update/{review_id}": {
      "put": {
        "operationId": "updateCfsReview",
        "summary": "Update a CFS review",
        "tags": ["CFS Reviews"],
        "parameters": [
          { "name": "review_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CfsReviewUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Review updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CfsReview" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/cfs-reviews/delete/{review_id}": {
      "delete": {
        "operationId": "deleteCfsReview",
        "summary": "Delete a CFS review",
        "tags": ["CFS Reviews"],
        "parameters": [
          { "name": "review_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Review deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/submissions": {
      "get": {
        "operationId": "listSubmissions",
        "summary": "List CFS submissions",
        "tags": ["Submissions"],
        "parameters": [
          { "name": "event_id", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "fields", "in": "query", "schema": { "type": "string" } },
          { "name": "expand", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per-page", "in": "query", "schema": { "type": "integer" } },
          { "name": "sort", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of submissions",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedSubmissionResponse" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/submissions/{submission_id}": {
      "get": {
        "operationId": "getSubmission",
        "summary": "Get a specific submission",
        "tags": ["Submissions"],
        "parameters": [
          { "name": "submission_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "fields", "in": "query", "schema": { "type": "string" } },
          { "name": "expand", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Submission details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Submission" } } }
          },
