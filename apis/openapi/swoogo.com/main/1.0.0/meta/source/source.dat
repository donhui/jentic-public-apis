        "tags": ["Submissions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SubmissionCreateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Submission" } } }
