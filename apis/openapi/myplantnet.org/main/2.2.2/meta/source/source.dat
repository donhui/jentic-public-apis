{
  "openapi": "3.0.3",
  "info": {
    "title": "Pl@ntNet API",
    "version": "2.2.2",
    "description": "Pl@ntNet API Service for developers. Provides plant identification, species data, disease identification, variety identification, and botanical resources.",
    "x-jentic-source-url": "https://my.plantnet.org/doc/api/openapi"
  },
  "servers": [
    {
      "url": "https://my-api.plantnet.org",
      "description": "Pl@ntNet API"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    { "name": "Health", "description": "API health check" },
    { "name": "Identification", "description": "Plant identification" },
    { "name": "Species", "description": "Species data" },
    { "name": "Projects", "description": "Project management" },
    { "name": "Diseases", "description": "Disease identification" },
    { "name": "Varieties", "description": "Variety identification" },
    { "name": "Quota", "description": "Quota management" },
    { "name": "Account", "description": "Account and subscription" },
    { "name": "Embeddings", "description": "Image embeddings" }
  ],
  "paths": {
    "/v2/_status": {
      "get": {
        "operationId": "checkApiHealth",
        "summary": "Check API health",
        "description": "Returns current health status of the Pl@ntNet API and infrastructure",
        "tags": ["Health"],
        "security": [],
        "responses": {
          "200": {
            "description": "Success, all systems are up and running",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthStatus" }
              }
            }
          },
          "500": { "description": "Internal Server Error, at least one component is down" }
        }
      }
    },
    "/v2/languages": {
      "get": {
        "operationId": "getLanguages",
        "summary": "Get available languages",
        "description": "Get the list of available languages (ISO 639-1)",
        "tags": ["Projects"],
        "responses": {
          "200": {
            "description": "List of available languages",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LanguagesList" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/projects": {
      "get": {
        "operationId": "listProjects",
        "summary": "Get available projects",
        "description": "Get the list of projects that can be used for identification",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "description": "Language code (ISO 639-1)",
            "schema": { "type": "string", "default": "en" }
          },
          {
            "name": "lat",
            "in": "query",
            "description": "Latitude (WGS 84 decimal degrees) to filter by geolocation",
            "schema": { "type": "number", "minimum": -90, "maximum": 90 }
          },
          {
            "name": "lon",
            "in": "query",
            "description": "Longitude (WGS 84 decimal degrees) to filter by geolocation",
            "schema": { "type": "number", "minimum": -180, "maximum": 180 }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Projects type",
            "schema": { "type": "string", "default": "kt", "enum": ["kt", "legacy"] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProjectsList" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/projects/{project}/species": {
      "get": {
        "operationId": "listProjectSpecies",
        "summary": "Get species for a specific project",
        "tags": ["Species"],
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "description": "Project identifier",
            "schema": { "type": "string" }
          },
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of results per page",
            "schema": { "type": "string", "default": "100" }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number starting at 1",
            "schema": { "type": "string", "default": "1" }
          },
          {
            "name": "prefix",
            "in": "query",
            "description": "Return only species starting with given prefix",
            "schema": { "type": "string" }
          },
          {
            "name": "images",
            "in": "query",
            "description": "Include illustrations (pro plan only)",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "Species list for project",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpeciesList" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/species": {
      "get": {
        "operationId": "listSpecies",
        "summary": "Get identifiable species",
        "description": "Get the list of species that can be identified",
        "tags": ["Species"],
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" }
          },
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string", "default": "kt", "enum": ["kt", "legacy"] }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "string", "default": "100" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "string", "default": "1" }
          },
          {
            "name": "prefix",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "images",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "Species list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SpeciesList" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/identify/{project}": {
      "get": {
        "operationId": "identifyPlantByUrl",
        "summary": "Identify a plant using image URLs",
        "tags": ["Identification"],
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "description": "Project to use for identification",
            "schema": { "type": "string" }
          },
          {
            "name": "images",
            "in": "query",
            "required": true,
            "description": "Image URLs (can be repeated)",
            "schema": { "type": "array", "items": { "type": "string", "format": "uri" } },
            "style": "form",
            "explode": true
          },
          {
            "name": "organs",
            "in": "query",
            "required": true,
            "description": "Organ tags for images (flower, leaf, fruit, bark, habit, other)",
            "schema": { "type": "array", "items": { "type": "string", "enum": ["flower", "leaf", "fruit", "bark", "habit", "other"] } },
            "style": "form",
            "explode": true
          },
          {
            "name": "include-related-images",
            "in": "query",
            "description": "Include related images in results",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "no-reject",
            "in": "query",
            "description": "Disable rejection of low-confidence results",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "nb-results",
            "in": "query",
            "description": "Number of results to return",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" }
          },
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string", "default": "kt", "enum": ["kt", "legacy"] }
          },
          {
            "name": "detailed",
            "in": "query",
            "description": "Include detailed information",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "Identification result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IdentificationResult" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "414": { "description": "URI Too Long" },
          "429": { "description": "Too Many Requests" }
        }
      },
      "post": {
        "operationId": "identifyPlantByImage",
        "summary": "Identify a plant using uploaded images",
        "tags": ["Identification"],
        "parameters": [
          {
            "name": "project",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "include-related-images",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "no-reject",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "nb-results",
            "in": "query",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" }
          },
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string", "default": "kt", "enum": ["kt", "legacy"] }
          },
          {
            "name": "detailed",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["images", "organs"],
                "properties": {
                  "images": {
                    "type": "array",
                    "items": { "type": "string", "format": "binary" },
                    "description": "Plant images to identify"
                  },
                  "organs": {
                    "type": "array",
                    "items": { "type": "string", "enum": ["flower", "leaf", "fruit", "bark", "habit", "other"] },
                    "description": "Organ tags for corresponding images"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Identification result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IdentificationResult" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too Many Requests" }
        }
      }
    },
    "/v2/diseases": {
      "get": {
        "operationId": "listDiseases",
        "summary": "Get identifiable diseases",
        "description": "Get the list of diseases (EPPO codes) that can be identified",
        "tags": ["Diseases"],
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" }
          },
          {
            "name": "prefix",
            "in": "query",
            "description": "Return only diseases with name/label starting with given prefix",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of diseases",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DiseasesList" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/diseases/identify": {
      "post": {
        "operationId": "identifyDisease",
        "summary": "Identify a plant disease from images",
        "tags": ["Diseases"],
        "parameters": [
          {
            "name": "include-related-images",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "no-reject",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "nb-results",
            "in": "query",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["images", "organs"],
                "properties": {
                  "images": {
                    "type": "array",
                    "items": { "type": "string", "format": "binary" }
                  },
                  "organs": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Disease identification result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IdentificationResult" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too Many Requests" }
        }
      }
    },
    "/v2/varieties": {
      "get": {
        "operationId": "listVarieties",
        "summary": "Get identifiable varieties",
        "tags": ["Varieties"],
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" }
          },
          {
            "name": "prefix",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of varieties",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VarietiesList" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/varieties/identify": {
      "post": {
        "operationId": "identifyVariety",
        "summary": "Identify a plant variety from images",
        "tags": ["Varieties"],
        "parameters": [
          {
            "name": "include-related-images",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "no-reject",
            "in": "query",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "nb-results",
            "in": "query",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "lang",
            "in": "query",
            "schema": { "type": "string", "default": "en" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["images", "organs"],
                "properties": {
                  "images": {
                    "type": "array",
                    "items": { "type": "string", "format": "binary" }
                  },
                  "organs": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Variety identification result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IdentificationResult" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too Many Requests" }
        }
      }
    },
    "/v2/quota": {
      "get": {
        "operationId": "getQuota",
        "summary": "Check quota consumption",
        "description": "Returns number of requests and remaining quota for your account",
        "tags": ["Quota"],
        "responses": {
          "200": {
            "description": "Quota information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuotaInfo" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/quota/daily": {
      "get": {
        "operationId": "getDailyQuota",
        "summary": "Get daily quota details",
        "tags": ["Quota"],
        "parameters": [
          {
            "name": "day",
            "in": "query",
            "description": "Date (YYYY-MM-DD)",
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily quota details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuotaInfo" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/quota/history": {
      "get": {
        "operationId": "getQuotaHistory",
        "summary": "Get quota usage history",
        "tags": ["Quota"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "description": "Year (YYYY)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Quota history",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuotaHistory" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/subscription": {
      "get": {
        "operationId": "getSubscription",
        "summary": "Check subscription status and details (pro)",
        "description": "Returns status, details and statistics for your account",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Subscription details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SubscriptionInfo" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v2/embeddings": {
      "post": {
        "operationId": "getImageEmbeddings",
        "summary": "Get image embeddings",
        "tags": ["Embeddings"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["image"],
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image file"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image embeddings",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EmbeddingsResult" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "429": { "description": "Too Many Requests" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api-key",
        "description": "Your private Pl@ntNet API key"
      }
    },
    "schemas": {
      "HealthStatus": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "components": { "type": "object" }
        }
      },
      "LanguagesList": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "name": { "type": "string" }
          }
        }
      },
      "ProjectsList": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/Project" }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "speciesCount": { "type": "integer" }
        }
      },
      "SpeciesList": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/Species" }
      },
      "Species": {
        "type": "object",
        "properties": {
          "scientificNameWithoutAuthor": { "type": "string" },
          "scientificNameAuthorship": { "type": "string" },
          "scientificName": { "type": "string" },
          "genus": { "type": "object", "properties": { "scientificNameWithoutAuthor": { "type": "string" } } },
          "family": { "type": "object", "properties": { "scientificNameWithoutAuthor": { "type": "string" } } },
          "commonNames": { "type": "array", "items": { "type": "string" } }
        }
      },
      "DiseasesList": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "name": { "type": "string" },
            "label": { "type": "string" }
          }
        }
      },
      "VarietiesList": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "label": { "type": "string" }
          }
        }
      },
      "IdentificationResult": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object",
            "properties": {
              "project": { "type": "string" },
              "images": { "type": "array", "items": { "type": "string" } },
              "organs": { "type": "array", "items": { "type": "string" } },
              "includeRelatedImages": { "type": "boolean" }
            }
          },
          "language": { "type": "string" },
          "preferedReferential": { "type": "string" },
          "bestMatch": { "type": "string" },
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/IdentificationResultItem" }
          },
          "version": { "type": "string" },
          "remainingIdentificationRequests": { "type": "integer" }
        }
      },
      "IdentificationResultItem": {
        "type": "object",
        "properties": {
          "score": { "type": "number" },
          "species": { "$ref": "#/components/schemas/Species" },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "organ": { "type": "string" },
                "author": { "type": "string" },
                "license": { "type": "string" },
                "date": { "type": "object" },
                "url": { "type": "object" },
                "citation": { "type": "string" }
              }
            }
          },
          "gbif": { "type": "object", "properties": { "id": { "type": "string" } } },
          "powo": { "type": "object", "properties": { "id": { "type": "string" } } },
          "iucn": { "type": "object", "properties": { "id": { "type": "string" }, "category": { "type": "string" } } }
        }
      },
      "QuotaInfo": {
        "type": "object",
        "properties": {
          "quota": { "type": "integer" },
          "count": { "type": "integer" },
          "remaining": { "type": "integer" }
        }
      },
      "QuotaHistory": {
        "type": "object",
        "properties": {
          "history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": { "type": "string" },
                "count": { "type": "integer" }
              }
            }
          }
