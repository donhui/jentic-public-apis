{
    "openapi": "3.0.0",
    "info": {
        "description": "Information regarding AU Hackathon-APIs",
        "version": "1.0.0",
        "title": "AU Hackathon APIs",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "email": "mohit.gadkari@capitalone.com"
        },
        "license": {
            "name": "Capital One",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/AU_HACKATHON8/accounts/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "Account API",
            "description": "For Account"
        }
    ],
    "paths": {
        "/au-hackathon/accounts/": {
            "post": {
                "summary": "Get Account Details",
                "description": "returns list of AUs and primary User for account",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/au_account"
                            }
                        }
                    },
                    "description": "Account post body"
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/response"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid status value"
                    }
                }
            }
        }
    },
    "externalDocs": {
        "description": "Find out more about Swagger",
        "url": "http://swagger.io"
    },
    "servers": [
        {
            "url": "http://3hkaob4gkc.execute-api.us-east-1.amazonaws.com/prod"
        }
    ],
    "components": {
        "schemas": {
            "au_account": {
                "properties": {
                    "account_id": {
                        "type": "integer",
                        "description": "Account id"
                    },
                    "card_type": {
                        "type": "string",
                        "description": "Type of card"
                    },
                    "team_name": {
                        "type": "string",
                        "description": "Optional team name filter"
                    }
                }
            },
            "response": {
                "properties": {
                    "account_id": {
                        "type": "integer",
                        "description": "customer account Id"
                    },
                    "primary_customer_id": {
                        "type": "integer",
                        "description": "primary cardholder's Id"
                    },
                    "au": {
                        "properties": {
                            "customer_id": {
                                "type": "string",
                                "description": "authorized user id"
                            },
                            "au_card_number": {
                                "type": "string",
                                "description": "authorized user card number"
                            }
                        }
                    },
                    "credit_limit": {
                        "type": "integer",
                        "description": "credit limit for account"
                    },
                    "balance": {
                        "type": "integer",
                        "description": "account balance"
                    },
                    "card_type": {
                        "type": "string",
                        "description": "type of card"
                    },
                    "card_number": {
                        "type": "string",
                        "description": "primary card number"
                    },
                    "total_rewards_earned": {
                        "type": "integer",
                        "description": "rewards earned"
                    },
                    "total_rewards_used": {
                        "type": "integer",
                        "description": "rewards used"
                    }
                }
            }
        }
    }
}