{
  "openapi": "3.0.1",
  "info": {
    "title": "Summaries API",
    "description": "API para consulta de sum\u00e1rios de chamadas e de agentes",
    "contact": {
      "email": "nathalia@vonix.com.br"
    },
    "version": "1.0.1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/vonix-tecnologia/api-summaries/1.0.1/swagger.json"
  },
  "servers": [
    {
      "url": "https://{customer}.api.vonixcc.com.br/cc/summaries",
      "variables": {
        "customer": {
          "description": "this value is assigned by the service provider, in this example",
          "default": "algarlab"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/calls": {
      "get": {
        "summary": "Returns a list of calls",
        "description": "Retorna os primeiros 50 registros e suas respectivas informa\u00e7\u00f5es de tabula\u00e7\u00e3o e classifica\u00e7\u00e3o de chamadas quando existentes e o total de resultados ap\u00f3s o per\u00edodo informado",
        "parameters": [
          {
            "name": "timestamp",
            "in": "query",
            "description": "Search results from that period",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Specifies the page number of the calls to be displayed",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully returned a list of calls",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/inline_response_400"
                }
              }
            }
          }
        }
      }
    },
    "/agents": {
      "get": {
        "summary": "Returns a list of summarie agents",
        "description": "Returns the first 50 values",
        "parameters": [
          {
            "name": "timestamp",
            "in": "query",
            "description": "Search results from that period",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Specifies the page number of the calls to be displayed",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully returned a list of agents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/inline_response_400_1"
                }
              }
            }
          }
        }
      }
    },
    "/emails": {
      "get": {
        "summary": "Returns a list of emails attendances",
        "parameters": [
          {
            "name": "timestamp",
            "in": "query",
            "description": "Search results from that period",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Specifies the page number of the calls to be displayed",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully returned a list of emails",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/inline_response_400_2"
                }
              }
            }
          }
        }
      }
    },
    "/pauses": {
      "get": {
        "summary": "Returns a list of summarie pauses",
        "description": "Returns the first 50 values",
        "parameters": [
          {
            "name": "timestamp",
            "in": "query",
            "description": "Search results from that period",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Specifies the page number of the calls to be displayed",
            "required": false,
            "style": "form",
            "explode": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully returned a list of agents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PauseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/inline_response_400_1"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CallResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "description": "Cont\u00e9m a lista de chamadas filtradas",
            "items": {
              "$ref": "#/components/schemas/CallItem"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/CallResponse_meta"
          }
        },
        "description": "Objeto de resposta do endpoint /calls"
      },
      "AgentResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "description": "Cont\u00e9m a Lista de agentes Filtrados",
            "items": {
              "$ref": "#/components/schemas/AgentItem"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/AgentResponse_meta"
          }
        },
        "description": "Objeto de resposta do endpoint /agents"
      },
      "EmailResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "description": "Cont\u00e9m a Lista de e-mails filtrados",
            "items": {
              "$ref": "#/components/schemas/EmailItem"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/EmailResponse_meta"
          }
        },
        "description": "Objeto de resposta do endpoint /emails"
      },
      "PauseResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "description": "Cont\u00e9m a Lista de pausas do per\u00edodo Filtrado",
            "items": {
              "$ref": "#/components/schemas/PauseItem"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PauseResponse_meta"
          }
        },
        "description": "Objeto de resposta do endpoint /pauses"
      },
      "CallItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Identificador da chamada"
          },
          "direction": {
            "type": "string",
            "description": "Apresenta a dire\u00e7\u00e3o da chamada filtrada",
            "enum": [
              "Receptiva",
              "Ativa",
              "Autom\u00e1tica"
            ]
          },
          "callerNumber": {
            "type": "string",
            "description": "N\u00famero identificador da chamada"
          },
          "callerInfo": {
            "type": "string",
            "description": "Nome do contato inserido no mailing para chamadas autom\u00e1ticas "
          },
          "status": {
            "type": "string",
            "description": "Status em que a chamada se encontra no sistema no momento da filtragem",
            "enum": [
              "Discando",
              "Em Espera",
              "Em Atendimento",
              "Completada",
              "Abandonada",
              "Descartada"
            ]
          },
          "reason": {
            "type": "string",
            "description": "Motivo pelo qual a chamada foi completada ou abandonada",
            "enum": [
              "Com tecla",
              "Desligamento do Agente",
              "Desligamento do Cliente",
              "Fila sem Agentes",
              "Tempo esgotado",
              "Transferida"
            ]
          },
          "ringSecs": {
            "type": "integer",
            "description": "Tempo de toque da chamada"
          },
          "holdSecs": {
            "type": "integer",
            "description": "Tempo de espera da chamada"
          },
          "talkSecs": {
            "type": "integer",
            "description": "Tempo de conversa da chamada"
          },
          "queueId": {
            "type": "string",
            "description": "Identificador da Fila em que a chamada se encontra"
          },
          "queueName": {
            "type": "string",
            "description": "Nome da Fila em que a chamada se encontra"
          },
          "agentId": {
            "type": "integer",
            "description": "Matr\u00edcula do Agente"
          },
          "agentName": {
            "type": "string",
            "description": "Nome do Agente"
          },
          "trunkingId": {
            "type": "integer",
            "description": "Identificador do entroncamento em que uma chamada ativa saiu"
          },
          "trunkingName": {
            "type": "string",
            "description": "Nome do entroncamento em que uma chamada ativa saiu"
          },
          "localityId": {
            "type": "string",
            "description": "DDD da Localidade de chamada ativa"
          },
          "callTypeId": {
            "type": "integer",
            "description": "Identificador do Tipo da chamada"
          },
          "callTypeName": {
            "type": "string",
            "description": "Nome do Tipo da Chamada",
            "enum": [
              "LDN Fixo",
              "LDN Cod. Especial",
              "LDI",
              "Local",
              "Local Cod. Especial",
              "Nao Geografico Gratuito",
              "Nao Geografico Tarifado",
              "VC1",
              "VC2",
              "VC3"
            ]
          },
          "hangupCauseId": {
            "type": "integer",
            "description": "Identificador da causa de desligamento"
          },
          "createdAt": {
            "type": "number",
            "description": "Timestamp em UTC da chamada",
            "format": "timestamp"
          },
          "answerAt": {
            "type": "number",
            "description": "Timestamp em UTC em que a chamada foi atendida",
            "format": "timestamp"
          },
          "hangupAt": {
            "type": "number",
            "description": "Timestamp em UTC do desligamento da chamada",
            "format": "timestamp"
          },
          "agentOffers": {
            "type": "integer",
            "description": "Quantidade de oferecimentos de uma chamada"
          },
          "initialPosition": {
            "type": "integer",
            "description": "Posi\u00e7\u00e3o da chamada na Fila de espera"
          },
          "abandonKey": {
            "type": "integer",
            "description": "Tecla digitada pelo callerNumber para sair da Fila"
          },
          "abandonPosition": {
            "type": "integer",
            "description": "Posi\u00e7\u00e3o da chamada no momento do abandono"
          },
          "transferredTo": {
            "type": "string",
            "description": "Apresenta o n\u00famero para onde a chamada foi transferida"
          },
          "bridgedCallId": {
            "type": "string",
            "description": "Informa\u00e7\u00f5es de Transfer\u00eancia"
          },
          "callRatings": {
            "type": "array",
            "description": "Lista contendo as informa\u00e7\u00f5es de pesquisa de satisfa\u00e7\u00e3o da chamada de voz",
            "items": {
              "$ref": "#/components/schemas/SurveyResponseItem"
            }
          },
          "profilers": {
            "type": "array",
            "description": "Lista que cont\u00e9m o perfilamento das chamadas filtradas",
            "items": {
              "$ref": "#/components/schemas/ProfilerFieldResponseItem"
            }
          },
          "trees": {
            "type": "array",
            "description": "Lista que cont\u00e9m a \u00e1rvore perfilada da chamada fitrada",
            "items": {
              "$ref": "#/components/schemas/ProfilerTreeResponseItem"
            }
          }
        },
        "description": "Objeto que representa uma chamada"
      },
      "SurveyResponseItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Pergunta"
          },
          "value": {
            "type": "string",
            "description": "Nota dada pela chamada que participou da pesquisa"
          },
          "createdAt": {
            "type": "number",
            "description": "Timestamp em UTC da Resposta",
            "format": "timestamp"
          }
        },
        "description": "Objeto que representa a resposta da Pesquisa de Satisfa\u00e7\u00e3o"
      },
      "ProfilerFieldResponseItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Idenficador do perfilamento da chamada"
          },
          "name": {
            "type": "string",
            "description": "Nome do campo do Perfilador"
          },
          "type": {
            "type": "string",
            "description": "Tipo do campo",
            "enum": [
              "DATE",
              "FLOAT",
              "INTEGER",
              "TEXT"
            ]
          },
          "value": {
            "type": "object",
            "description": "Op\u00e7\u00e3o escolhida pelo agente ao perfilar a chamada"
          },
          "createdAt": {
            "type": "number",
            "description": "Timestamp em UTC do perfilamento",
            "format": "timestamp"
          }
        },
        "description": "Objeto representando a resposta de um campo do perfilador"
      },
      "ProfilerTreeResponseItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Identificador da \u00e1rvore de perfilamento"
          },
          "label": {
            "type": "string",
            "description": "Nome da \u00c1rvore de Perfilamento"
          }
        },
        "description": "Objeto representando perfil respondido no perfilador"
      },
      "AgentItem": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "integer",
            "description": "Matr\u00edcula do Agente"
          },
          "agentName": {
            "type": "string",
            "description": "Nome do Agente"
          },
          "queueId": {
            "type": "string",
            "description": "Identificador da Fila em que o agente foi atrelado"
          },
          "period": {
            "type": "string",
            "description": "Date-time da altera\u00e7\u00e3o do agente",
            "format": "date-time"
          },
          "inCompleted": {
            "type": "integer",
            "description": "Quantidade de chamadas Receptivas atendidas pelo Agente Filtrado"
          },
          "outCompleted": {
            "type": "integer",
            "description": "Quantidade de chamadas Ativas completadas pelo Agente Filtrado"
          },
          "outDiscarded": {
            "type": "integer",
            "description": "Quantidade de chamadas Ativas descartadas pelo Agente Filtrado"
          },
          "autoCompleted": {
            "type": "integer",
            "description": "Quantidade de chamadas autom\u00e1ticas atendidas no Agente Filtrado"
          },
          "rejections": {
            "type": "integer",
            "description": "Quantidade de vezes em que chamadas foram rejeitadas pelo Agente Filtrado"
          },
          "loginSecs": {
            "type": "integer",
            "description": "Tempo total de login do Agente no per\u00edodo filtrado"
          },
          "pauseSecs": {
            "type": "integer",
            "description": "Tempo em segundos de pausa do agente Filtrado"
          },
          "inRingSecs": {
            "type": "integer",
            "description": "Tempo em segundos de espera receptiva"
          },
          "outRingSecs": {
            "type": "integer",
            "description": "Tempo em segundos de toque chamada ativa"
          },
          "inCallSecs": {
            "type": "integer",
            "description": "Tempo em segundos de conversa receptiva"
          },
          "outCallSecs": {
            "type": "integer",
            "description": "Tempo em segundos de conversa ativa"
          },
          "autoCallSecs": {
            "type": "integer",
            "description": "Tempo em segundos de conversa receptiva autom\u00e1tica"
          },
          "callSecs": {
            "type": "integer",
            "description": "Tempo em segundos de conversa"
          },
          "ringSecs": {
            "type": "integer",
            "description": "Tempo em segundos de espera"
          },
          "agentDefaultQueueId": {
            "type": "string",
            "description": "Fila Padr\u00e3o do Agente"
          },
          "loginExtension": {
            "type": "string",
            "description": "Ramal do Agente"
          },
          "loginAt": {
            "type": "string",
            "description": "Date-time do \u00faltimo login do Agente",
            "format": "date-time"
          },
          "pauseAt": {
            "type": "string",
            "description": "Date-time da \u00faltima pausa do Agente",
            "format": "date-time"
          },
          "logoutAt": {
            "type": "string",
            "description": "Date-time do \u00faltimo Logout do Agente",
            "format": "date-time"
          },
          "talkingSince": {
            "type": "string",
            "description": "Tempo ativo da chamada atual em segundos",
            "format": "date-time"
          },
          "talkingCallId": {
            "type": "string",
            "description": "Identificador da Chamada atual"
          },
          "lastCallAnsweredAt": {
            "type": "string",
            "description": "Date-time do \u00faltimo atendimento",
            "format": "date-time"
          },
          "lastCallRejectedAt": {
            "type": "string",
            "description": "Date-time da \u00faltima rejei\u00e7\u00e3o de chamada no ramal do agente",
            "format": "date-time"
          },
          "lastPauseAt": {
            "type": "string",
            "description": "Date-time da finaliza\u00e7\u00e3o da \u00faltima pausa do Agente",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "description": "Status do Agente",
            "enum": [
              "OFFLINE",
              "ONLINE",
              "RINGING",
              "DIALING",
              "ONTHEPHONE",
              "PAUSED"
            ]
          },
          "active": {
            "type": "integer",
            "description": "Situa\u00e7\u00e3o do agente: ativo(1) ou inativo(0)"
          },
          "createdAt": {
            "type": "string",
            "description": "Date-time da cria\u00e7\u00e3o do agente",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "description": "Date-time da \u00faltima altera\u00e7\u00e3o do Agente",
            "format": "date-time"
          },
          "pauseReasonId": {
            "type": "integer",
            "description": "Identificador da Pausa que o Agente realizou"
          }
        },
        "description": "Objeto representando Agentes Filtrados"
      },
      "EmailItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Identificador do Email"
          },
          "botName": {
            "type": "string",
            "description": "Nome do Bot de e-mail"
          },
          "botId": {
            "type": "integer",
            "description": "Identificador do Bot de e-mail"
          },
          "agentName": {
            "type": "string",
            "description": "Nome do Agente que realizou o atendimento"
          },
          "agentId": {
            "type": "integer",
            "description": "Matr\u00edcula do Agente que realizou o atendimento"
          },
          "queueName": {
            "type": "string",
            "description": "Nome da Fila de atendimento do e-mail"
          },
          "queueId": {
            "type": "string",
            "description": "Identificador da Fila de atendimento do e-mail"
          },
          "createdAt": {
            "type": "number",
            "description": "Timestamp em UTC do Atendimento do e-mail",
            "format": "timestamp"
          },
          "finishedAt": {
            "type": "number",
            "description": "Timestamp em UTC da Finaliza\u00e7\u00e3o do Atendimento de e-mail",
            "format": "timestamp"
          },
          "direction": {
            "type": "string",
            "description": "Dire\u00e7\u00e3o do Atendimento",
            "enum": [
              "ativo",
              "Receptivo"
            ]
          },
          "status": {
            "type": "string",
            "description": "Status do atendimento",
            "enum": [
              "Aguardando Resposta",
              "Envio Realizado",
              "Envio Pendente",
              "Resposta Realizada",
              "Transferido"
            ]
          },
          "transferAttendanceId": {
            "type": "integer",
            "description": "Identificador do Atendimento transferido"
          },
          "messages": {
            "type": "array",
            "description": "Lista que cont\u00e9m as mensagens do atendimento filtrado",
            "items": {
              "$ref": "#/components/schemas/EmailMessageItem"
            }
          }
        },
        "description": "Objeto representando E-mails"
      },
      "PauseItem": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "integer",
            "description": "Matr\u00edcula do Agente"
          },
          "agentName": {
            "type": "string",
            "description": "Nome do Agente"
          },
          "queueId": {
            "type": "string",
            "description": "Identificador da Fila do Agente"
          },
          "queueName": {
            "type": "string",
            "description": "Nome da Fila do Agente"
          },
          "pauseReasonId": {
            "type": "integer",
            "description": "Motivo de pausa que o Agente realizou"
          },
          "pauseName": {
            "type": "string",
            "description": "Nome da Pausa"
          },
          "period": {
            "type": "number",
            "description": "Timestamp em UTC da pausa realizada",
            "format": "timestamp"
          },
          "pauseSecs": {
            "type": "integer",
            "description": "Tempo em segundos da pausa realizada"
          }
        },
        "description": "Objeto representando o sum\u00e1rio de um per\u00edodo de pausas"
      },
      "EmailMessageItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Identificador da mensagem"
          },
          "attendanceId": {
            "type": "integer",
            "description": "Identificador do Atendimento"
          },
          "agentId": {
            "type": "integer",
            "description": "Matr\u00edcula do Agente"
          },
          "parentId": {
            "type": "integer",
            "description": "Identificador da Mensagem"
          },
          "answerId": {
            "type": "integer",
            "description": "Identificador do e-mail respondido"
          },
          "direction": {
            "type": "string",
            "description": "Dire\u00e7\u00e3o do Atendimento",
            "enum": [
              "Ativo",
              "Receptivo"
            ]
          },
          "status": {
