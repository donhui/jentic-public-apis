{
  "openapi": "3.0.0",
  "info": {
    "title": "API de calculo de sess\u00f5es",
    "description": "A API disponibiliza relat\u00f3rios em cima do c\u00e1lculo das sess\u00f5es dos agentes. O objetivo \u00e9 informar os ramais utilizados, por quais agentes e em quais dias durante o per\u00edodo informado.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/vonix-tecnologia/api-cron-biller/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://${customerId}.api.vonixcc.com.br/meter",
      "variables": {
        "customer": {
          "description": "cron-meter",
          "default": "blackbox"
        }
      }
    }
  ],
  "paths": {
    "/reprocess": {
      "get": {
        "summary": "Reprocessa todos os eventos",
        "description": "Esse endpoint \u00e9 utilizado apenas para sincronizar as bases do cliente com o meter, reprocessando os eventos a partir do periodo informado at\u00e9 o momento",
        "parameters": [
          {
            "name": "startPeriod",
            "in": "query",
            "description": "Reprocessa os eventos a partir desse timestamp",
            "required": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          },
          {
            "name": "customer",
            "in": "query",
            "description": "Especifica o clienteId que ser\u00e1 reprocessado",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/summary/period": {
      "get": {
        "summary": "Retorna uma lista com todos os dias dentro do periodo informado",
        "description": "Retorna todos os ramais utilizados por dia e todos os agentes que utilizaram aquele ramal naquele dia",
        "parameters": [
          {
            "name": "customer",
            "in": "query",
            "description": "Especifica o cliente",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startPeriod",
            "in": "query",
            "description": "Inicio do periodo a ser calculado",
            "required": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          },
          {
            "name": "endPeriod",
            "in": "query",
            "description": "Final do periodo a ser calculado",
            "required": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Retorna a lista com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "description": "Cont\u00e9m a lista por per\u00edodo",
                      "items": {
                        "type": "object",
                        "properties": {
                          "period": {
                            "type": "string",
                            "description": "Identificador do Periodo"
                          },
                          "extension": {
                            "type": "integer",
                            "description": "N\u00famero do Ramal"
                          },
                          "sessions": {
                            "type": "string",
                            "description": "Quantidade de Sess\u00f5es naquele ramal naquele dia"
                          },
                          "onlineSecs": {
                            "type": "integer",
                            "description": "Tempo de utiliza\u00e7\u00e3o do Ramal em segundos"
                          },
                          "agents": {
                            "type": "string",
                            "description": "Lista dos agentes que utilizaram o ramal"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "$errors": {
                      "type": "object",
                      "properties": {
                        "period": {
                          "type": "string",
                          "example": "startPeriod are required"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/summary/extensions": {
      "get": {
        "summary": "Retorna uma lista dos ramais utilizados no Periodo",
        "description": "Retorna todos os ramais utilizados dentro do per\u00edodo informado com uma lista dos agentes que os utilizaram.",
        "parameters": [
          {
            "name": "customer",
            "in": "query",
            "description": "Especifica o cliente",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startPeriod",
            "in": "query",
            "description": "Inicio do periodo a ser calculado",
            "required": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          },
          {
            "name": "endPeriod",
            "in": "query",
            "description": "Final do periodo a ser calculado",
            "required": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Retorna a lista dos ramais",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "description": "Cont\u00e9m a lista por per\u00edodo",
                      "items": {
                        "type": "object",
                        "properties": {
                          "extension": {
                            "type": "integer",
                            "description": "N\u00famero do Ramal"
                          },
                          "agents": {
                            "type": "string",
                            "description": "Lista dos agentes que utilizaram o ramal"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "$errors": {
                      "type": "object",
                      "properties": {
                        "period": {
                          "type": "string",
                          "example": "customer are required"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/summary/total": {
      "get": {
        "summary": "Retorna uma lista dos ramais utilizados por dia e com um totalizador final",
        "description": "Retorna todos os ramais utilizados por dia dentro do periodo informado e o total dos ramais por dia e por todo o periodo.",
        "parameters": [
          {
            "name": "customer",
            "in": "query",
            "description": "Especifica o cliente",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "startPeriod",
            "in": "query",
            "description": "Inicio do periodo a ser calculado",
            "required": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          },
          {
            "name": "endPeriod",
            "in": "query",
            "description": "Final do periodo a ser calculado",
            "required": true,
            "schema": {
              "type": "number",
              "format": "timestamp"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Retorna a lista dos ramais",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "string": {
                          "type": "object",
                          "properties": {
                            "total": {
                              "type": "integer"
                            },
                            "extensions": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "$errors": {
                      "type": "object",
                      "properties": {
                        "period": {
                          "type": "string",
                          "example": "customer are required"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}