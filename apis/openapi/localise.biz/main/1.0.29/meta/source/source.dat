    "/import/{ext}": {
      "post": {
        "operationId": "importFile",
        "summary": "Import assets and translations from a language pack file",
        "tags": [
          "Import"
        ],
        "parameters": [
          {
            "name": "ext",
            "in": "path",
            "required": true,
            "description": "File format extension (e.g. json, po, pot, xml, yml, xlf, csv, strings, etc.)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "index",
            "in": "query",
            "description": "Specify how file is indexed: id or text",
            "schema": {
              "type": "string",
              "enum": [
                "id",
                "text"
              ]
            }
          },
          {
            "name": "locale",
            "in": "query",
            "description": "Locale code for the imported translations",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Disambiguate generic format (e.g. multi, rails, symfony, jed)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "async",
            "in": "query",
            "description": "Set to true for asynchronous import of large files",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "tag-new",
            "in": "query",
            "description": "Tag to apply to new assets",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag-updated",
            "in": "query",
            "description": "Tag to apply to updated assets",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "delete-absent",
            "in": "query",
            "description": "Whether to delete assets not present in the import",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "ignore-new",
            "in": "query",
            "description": "Ignore new assets in the file, only update existing",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "ignore-existing",
            "in": "query",
            "description": "Ignore existing translations, only add new",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Raw file content to import",
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportResult"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "description": "Unprocessable file",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/import/progress/{id}": {
      "get": {
        "operationId": "getImportProgress",
        "summary": "Check the progress of an asynchronous import",
        "tags": [
          "Import"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
