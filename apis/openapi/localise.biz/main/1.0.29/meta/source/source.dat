    "/export/all.{ext}": {
      "get": {
        "operationId": "exportAll",
        "summary": "Export whole project to a multi-locale language pack",
        "tags": [
          "Export"
        ],
        "parameters": [
          {
            "name": "ext",
            "in": "path",
            "required": true,
            "description": "Target file format extension (e.g. json, xml, yml, po, xlf, tmx, strings, etc.)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Specific format style (e.g. multi, rails, symfony, chrome, i18next4, jed)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Filter assets by tag",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "index",
            "in": "query",
            "description": "Override default key indexing, e.g. id or text",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fallback",
            "in": "query",
            "description": "Fallback locale for untranslated strings",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Order of asset keys, e.g. id or text",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter translations by status",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "no-folding",
            "in": "query",
            "description": "Disable YAML folding",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Exported language pack file",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/export/archive/{ext}.zip": {
      "get": {
        "operationId": "exportArchive",
