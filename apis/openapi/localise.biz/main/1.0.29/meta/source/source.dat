                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "Tag not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "API key sent as HTTP Basic Auth username with an empty password. Example: -u <api_key>:"
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "message": {
            "type": "string",
            "description": "Descriptive message"
          }
        }
      },
      "Credentials": {
        "type": "object",
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string"
              }
            }
          },
          "project": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            }
          }
        }
      },
      "Asset": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique asset identifier"
          },
          "type": {
            "type": "string",
            "description": "Asset type, e.g. text"
          },
          "context": {
            "type": "string",
            "description": "Optional context for translators"
          },
          "notes": {
            "type": "string",
            "description": "Optional notes for translators"
          },
          "modified": {
            "type": "string",
            "format": "date-time",
            "description": "Last modification timestamp"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of tags applied to the asset"
          },
          "progress": {
            "type": "object",
            "properties": {
              "translated": {
                "type": "integer",
                "description": "Number of locales with translations"
              },
              "untranslated": {
                "type": "integer",
                "description": "Number of locales without translations"
              },
              "flagged": {
                "type": "integer",
                "description": "Number of flagged translations"
              }
            }
          },
          "plurals": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of linked plural form assets"
          }
        }
      },
      "Locale": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Locale code, e.g. en, fr"
          },
          "name": {
            "type": "string",
            "description": "Human-readable locale name"
          },
          "native": {
            "type": "string",
            "description": "Native name of the locale"
          },
          "plurals": {
            "type": "object",
            "properties": {
              "length": {
                "type": "integer",
                "description": "Number of plural forms"
              },
              "equation": {
                "type": "string",
                "description": "Plural form equation"
              },
              "forms": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Plural form names, e.g. one, other"
              }
            }
          },
          "progress": {
            "$ref": "#/components/schemas/Progress"
          }
        }
      },
      "Progress": {
        "type": "object",
        "properties": {
          "translated": {
            "type": "integer",
            "description": "Number of translated assets"
          },
          "untranslated": {
            "type": "integer",
            "description": "Number of untranslated assets"
          },
          "flagged": {
            "type": "integer",
            "description": "Number of flagged translations"
          },
          "total": {
            "type": "integer",
            "description": "Total number of assets"
          }
        }
      },
      "Translation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Asset ID"
          },
          "locale": {
            "type": "string",
            "description": "Locale code"
          },
          "translation": {
            "type": "string",
            "description": "Translated text"
          },
          "translated": {
            "type": "boolean",
            "description": "Whether a translation exists"
          },
          "flagged": {
            "type": "string",
            "description": "Flag status, e.g. fuzzy"
          },
          "revision": {
            "type": "integer",
            "description": "Revision number"
          },
          "modified": {
            "type": "string",
            "format": "date-time",
            "description": "Last modification timestamp"
          }
        }
      },
      "ImportResult": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Summary message"
          },
          "locales": {
            "type": "integer",
            "description": "Number of locales affected"
          },
          "assets": {
            "type": "integer",
            "description": "Number of new assets imported"
          },
          "translations": {
            "type": "integer",
            "description": "Number of translations imported"
          }
        }
      },
      "ImportProgress": {
        "type": "object",
        "properties": {
          "progress": {
            "type": "integer",
            "description": "Progress percentage 0-100"
          },
          "success": {
            "type": "string",
            "description": "Completion status message"
          },
          "error": {
            "type": "string",
            "description": "Error message if failed"
          }
        }
      }
    }
  }
}