{
  "openapi": "3.0.3",
  "info": {
    "title": "NeuronWriter API",
    "version": "0.5.0",
    "description": "NeuronWriter API for SEO content optimization. Manage projects, create content analysis queries, retrieve content recommendations, and import/evaluate content scores programmatically.",
    "x-jentic-source-url": "https://contadu.crisp.help/en/article/neuronwriter-api-how-to-use-2ds6hx/"
  },
  "servers": [
    {
      "url": "https://app.neuronwriter.com/neuron-api/0.5/writer",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    { "name": "Projects", "description": "Project management operations" },
    { "name": "Queries", "description": "Content analysis query operations" },
    { "name": "Content", "description": "Content retrieval and management" }
  ],
  "paths": {
    "/list-projects": {
      "post": {
        "operationId": "listProjects",
        "summary": "List all projects",
        "description": "Retrieves all projects within the account.",
        "tags": ["Projects"],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Project" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/new-query": {
      "post": {
        "operationId": "createQuery",
        "summary": "Create a new content analysis query",
        "description": "Creates a new content analysis query for a keyword. The query will be processed asynchronously, typically taking about 60 seconds.",
        "tags": ["Queries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NewQueryRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NewQueryResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/get-query": {
      "post": {
        "operationId": "getQuery",
        "summary": "Get content recommendations for a query",
        "description": "Retrieves content recommendations for a query. Processing typically takes approximately 60 seconds after creation.",
        "tags": ["Queries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Query identifier"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query recommendations",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QueryResult" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/list-queries": {
      "post": {
        "operationId": "listQueries",
        "summary": "List queries matching criteria",
        "description": "Lists queries matching specified criteria within a project.",
        "tags": ["Queries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ListQueriesRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of matching queries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/QueryListItem" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/get-content": {
      "post": {
        "operationId": "getContent",
        "summary": "Get saved content for a query",
        "description": "Retrieves the last saved content revision for a query.",
        "tags": ["Content"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Query identifier"
                  },
                  "revision_type": {
                    "type": "string",
                    "description": "Revision type filter",
                    "example": "all"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Content revision",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ContentRevision" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/import-content": {
      "post": {
        "operationId": "importContent",
        "summary": "Import content into the editor",
        "description": "Updates editor content via API, creating a new revision. Content can be provided as HTML or fetched from a URL.",
        "tags": ["Content"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ImportContentRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Content imported successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ContentScoreResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/evaluate-content": {
      "post": {
        "operationId": "evaluateContent",
        "summary": "Evaluate content score without saving",
        "description": "Evaluates the content score without saving a new revision. Same parameters as import-content but does not persist changes.",
        "tags": ["Content"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ImportContentRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Content score evaluation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ContentScoreResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "name": "X-API-KEY",
        "in": "header",
        "description": "API key for authentication. Requires Gold plan or higher."
      }
    },
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "project": { "type": "string", "description": "Project identifier" },
          "name": { "type": "string", "description": "Project name" },
          "language": { "type": "string", "description": "Project language" },
          "engine": { "type": "string", "description": "Search engine" }
        }
      },
      "NewQueryRequest": {
        "type": "object",
        "required": ["project", "keyword", "engine", "language"],
        "properties": {
          "project": { "type": "string", "description": "Project identifier", "example": "e95fdd229fd98c10" },
          "keyword": { "type": "string", "description": "Target keyword to analyze", "example": "trail running shoes" },
          "engine": { "type": "string", "description": "Search engine to target", "example": "google.co.uk" },
          "language": { "type": "string", "description": "Content language", "example": "English" },
          "additional_keywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional related keywords",
            "example": ["off-road shoes"]
          },
          "competitors_mode": {
            "type": "string",
            "description": "Competitor analysis mode",
            "example": "top-intent"
          }
        }
      },
      "NewQueryResponse": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Query identifier" },
          "query_url": { "type": "string", "description": "URL to access the query" },
          "share_url": { "type": "string", "description": "Shareable URL" },
          "readonly_url": { "type": "string", "description": "Read-only URL" }
        }
      },
      "QueryResult": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "description": "Query processing status" },
          "metrics": {
            "type": "object",
            "properties": {
              "word_count": { "type": "object" },
              "readability": { "type": "object" }
            }
          },
          "terms_txt": { "type": "object", "description": "Recommended terms in text format" },
          "terms": { "type": "object", "description": "Recommended terms with weights" },
          "ideas": { "type": "object", "description": "Content ideas and suggestions" },
          "competitors": {
            "type": "array",
            "items": { "type": "object" },
            "description": "Competitor analysis data"
          },
          "serp_summary": { "type": "object", "description": "SERP analysis summary" }
        }
      },
      "ListQueriesRequest": {
        "type": "object",
        "required": ["project"],
        "properties": {
          "project": { "type": "string", "description": "Project identifier", "example": "0c30b6a4f8b2b412" },
          "status": { "type": "string", "description": "Filter by status", "example": "ready" },
          "source": { "type": "string", "description": "Filter by source", "example": "neuron-api" },
          "keyword": { "type": "string", "description": "Filter by keyword", "example": "trail running shoes" },
          "language": { "type": "string", "description": "Filter by language", "example": "English" },
          "engine": { "type": "string", "description": "Filter by search engine", "example": "google.com" },
          "tags": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ],
            "description": "Filter by tags",
            "example": "Done"
          }
        }
      },
      "QueryListItem": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Query identifier" },
          "created": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
          "updated": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
          "keyword": { "type": "string", "description": "Target keyword" },
          "language": { "type": "string", "description": "Content language" },
          "engine": { "type": "string", "description": "Search engine" },
          "source": { "type": "string", "description": "Query source" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Query tags"
          }
        }
      },
      "ContentRevision": {
        "type": "object",
        "properties": {
          "content": { "type": "string", "description": "HTML content" },
          "title": { "type": "string", "description": "Content title" },
          "description": { "type": "string", "description": "Meta description" },
          "created": { "type": "string", "format": "date-time", "description": "Revision timestamp" },
          "type": { "type": "string", "description": "Revision type" }
        }
      },
      "ImportContentRequest": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": { "type": "string", "description": "Query identifier", "example": "32dee2a89374a722" },
          "html": { "type": "string", "description": "HTML content to import", "example": "<h1>Title</h1>" },
          "title": { "type": "string", "description": "Article title", "example": "Article Title" },
          "description": { "type": "string", "description": "Meta description", "example": "Meta description" },
          "url": { "type": "string", "description": "URL to fetch content from", "example": "https://example.com" },
          "id": { "type": "string", "description": "HTML element ID to extract from URL", "example": "main-content" },
          "class": { "type": "string", "description": "HTML class to extract from URL", "example": "article-content" }
        }
      },
      "ContentScoreResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok", "error"],
            "description": "Operation status"
          },
          "content_score": {
            "type": "number",
            "description": "Content optimization score"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "Error type" },
          "message": { "type": "string", "description": "Error message" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    }
  }
}