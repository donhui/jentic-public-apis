{
  "openapi": "3.0.3",
  "info": {
    "title": "NeuronWriter API",
    "version": "0.5",
    "description": "NeuronWriter API gives you programmatic access to SEO content recommendations. You can add new queries in bulk, retrieve share URLs, and integrate NeuronWriter recommendations in your content generation process. Requires Gold plan or higher.",
    "x-jentic-source-url": "https://contadu.crisp.help/en/article/neuronwriter-api-how-to-use-2ds6hx/"
  },
  "servers": [
    {
      "url": "https://app.neuronwriter.com/neuron-api/0.5/writer",
      "description": "NeuronWriter API v0.5"
    }
  ],
  "paths": {
    "/list-projects": {
      "post": {
        "operationId": "listProjects",
        "summary": "List Projects",
        "description": "Retrieves a list of projects within the used account.",
        "responses": {
          "200": {
            "description": "A list of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/new-query": {
      "post": {
        "operationId": "createQuery",
        "summary": "Create New Query",
        "description": "Creates a new content writer query for a given keyword, language and search engine. API requests consume your monthly limits.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewQueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New query created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewQueryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/get-query": {
      "post": {
        "operationId": "getQuery",
        "summary": "Get Query Recommendations",
        "description": "Retrieves content recommendations for a given query. After creating a new query with /new-query it usually takes around 60 seconds until recommendations are prepared. Check whether status=='ready' to see if recommendations are available.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "The ID of the query",
                    "example": "32dee2a89374a722"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query recommendations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryRecommendations"
                }
              }
            }
          }
        }
      }
    },
    "/list-queries": {
      "post": {
        "operationId": "listQueries",
        "summary": "List Queries",
        "description": "Retrieves queries within a project matching your criteria and provides information about their status.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListQueriesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "A list of queries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/QueryListItem"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/get-content": {
      "post": {
        "operationId": "getContent",
        "summary": "Get Content",
        "description": "Retrieves the last content revision saved for a given query. You can choose between manually saved revisions (default) or all (including autosave revisions).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "The ID of your query",
                    "example": "32dee2a89374a722"
                  },
                  "revision_type": {
                    "type": "string",
                    "description": "Whether autosave revisions should be considered or not",
                    "enum": ["manual", "all"],
                    "default": "manual"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Content revision",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentResponse"
                }
              }
            }
          }
        }
      }
    },
    "/import-content": {
      "post": {
        "operationId": "importContent",
        "summary": "Import Content",
        "description": "Allows you to update the editor content via API for a given query. You can either import HTML or send a URL that will be auto-imported and parsed. Creates a new content revision.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportContentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportContentResponse"
                }
              }
            }
          }
        }
      }
    },
    "/evaluate-content": {
      "post": {
        "operationId": "evaluateContent",
        "summary": "Evaluate Content",
        "description": "Same as /import-content but does not save anything, just evaluates the content score. Input and output parameters are the same as /import-content.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportContentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Evaluation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportContentResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "project": {
            "type": "string",
            "description": "Project ID",
            "example": "ed0b47151fb35b02"
          },
          "name": {
            "type": "string",
            "description": "Project name",
            "example": "adidas.com"
          },
          "language": {
            "type": "string",
            "description": "Project language",
            "example": "English"
          },
          "engine": {
            "type": "string",
            "description": "Search engine",
            "example": "google.co.uk"
          }
        }
      },
      "NewQueryRequest": {
        "type": "object",
        "required": ["project", "keyword", "engine", "language"],
        "properties": {
          "project": {
            "type": "string",
            "description": "The ID of your project taken from the project URL",
            "example": "e95fdd229fd98c10"
          },
          "keyword": {
            "type": "string",
            "description": "The keyword to generate a query and recommendations for",
            "example": "trail running shoes"
          },
          "engine": {
            "type": "string",
            "description": "Preferred search engine",
            "example": "google.co.uk"
          },
          "language": {
            "type": "string",
            "description": "Content language",
            "example": "English"
          },
          "additional_keywords": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional additional supporting keywords",
            "example": ["off-road running shoes", "mountain running shoes"]
          },
          "competitors_mode": {
            "type": "string",
            "description": "Affects how competitors are selected for recommendations calculation",
            "enum": ["top10", "top30", "top-intent"],
            "default": "top10"
          }
        }
      },
      "NewQueryResponse": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The ID of your new query",
            "example": "32dee2a89374a722"
          },
          "query_url": {
            "type": "string",
            "description": "The URL of your query (accessible from browser)",
            "example": "https://app.neuronwriter.com/analysis/view/32dee2a89374a722"
          },
          "share_url": {
            "type": "string",
            "description": "URL for sharing the query with edit and save access"
          },
          "readonly_url": {
            "type": "string",
            "description": "URL for sharing the query (readonly preview)"
          }
        }
      },
      "QueryRecommendations": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Whether the query has been processed",
            "enum": ["not found", "waiting", "in progress", "ready"]
          },
          "metrics": {
            "type": "object",
            "description": "General recommendations such as typical content length",
            "properties": {
              "word_count": {
                "type": "object",
                "properties": {
                  "median": { "type": "integer" },
                  "target": { "type": "integer" }
                }
              },
              "readability": {
                "type": "object",
                "properties": {
                  "median": { "type": "integer" },
                  "target": { "type": "integer" }
                }
              }
            }
          },
          "terms_txt": {
            "type": "object",
            "description": "Content term suggestions in text format, useful for ChatGPT prompts",
            "properties": {
              "title": { "type": "string" },
              "desc_title": { "type": "string" },
              "h1": { "type": "string" },
              "h2": { "type": "string" },
              "content_basic": { "type": "string" },
              "content_extended": { "type": "string" }
            }
          },
          "terms": {
            "type": "object",
            "description": "Detailed information about content terms with usage percentages",
            "additionalProperties": true
          },
          "ideas": {
            "type": "object",
            "description": "Questions related to the topic",
            "properties": {
              "suggest_questions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "q": { "type": "string" }
                  }
                }
              },
              "people_also_ask": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "q": { "type": "string" }
                  }
                }
              },
              "content_questions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "q": { "type": "string" }
                  }
                }
              }
            }
          },
          "competitors": {
            "type": "array",
            "description": "Basic information about the SERP competitors",
            "items": {
              "type": "object",
              "properties": {
                "rank": { "type": "integer" },
                "url": { "type": "string" },
                "title": { "type": "string" },
                "desc": { "type": "string" }
              }
            }
          },
          "serp_summary": {
            "type": "object",
            "description": "User intent associated with Google search results and content type statistics",
            "properties": {
              "top_intent": { "type": "string" },
              "intent_stats": {
                "type": "object",
                "additionalProperties": { "type": "number" }
              },
              "top_content_type": { "type": "string" },
              "content_type_stats": {
                "type": "object",
                "additionalProperties": { "type": "number" }
              }
            }
          }
        }
      },
      "ListQueriesRequest": {
        "type": "object",
        "required": ["project"],
        "properties": {
          "project": {
            "type": "string",
            "description": "The ID of your project",
            "example": "0c30b6a4f8b2b412"
          },
          "status": {
            "type": "string",
            "description": "Query status filter",
            "enum": ["waiting", "in progress", "ready"]
          },
          "source": {
            "type": "string",
            "description": "How the query was created",
            "enum": ["neuron", "neuron-api"]
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Creation date for a query"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "Query update date (when ready)"
          },
          "keyword": {
            "type": "string",
            "description": "Main keyword for the query"
          },
          "language": {
            "type": "string",
            "description": "Language used during analysis"
          },
          "engine": {
            "type": "string",
            "description": "Search engine used during analysis"
          },
          "tags": {
            "description": "Limit results to queries with one or more tags",
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          }
        }
      },
      "QueryListItem": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Query ID",
            "example": "a6d0fb2bf9a7a2be"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Creation date"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "Update date"
          },
          "keyword": {
            "type": "string",
            "description": "Main keyword"
          },
          "language": {
            "type": "string",
            "description": "Language"
          },
          "engine": {
            "type": "string",
            "description": "Search engine"
          },
          "source": {
            "type": "string",
            "description": "How query was created"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Tags"
          }
        }
      },
      "ContentResponse": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "Content in HTML format"
          },
          "title": {
            "type": "string",
            "description": "Title"
          },
          "description": {
            "type": "string",
            "description": "Meta description"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Revision date"
          },
          "type": {
            "type": "string",
            "description": "Revision type",
            "enum": ["manual", "autosave"]
          }
        }
      },
      "ImportContentRequest": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {
            "type": "string",
            "description": "The ID of your query",
            "example": "32dee2a89374a722"
          },
          "html": {
            "type": "string",
            "description": "HTML content to import"
          },
          "title": {
            "type": "string",
            "description": "Title of your article. If provided, overwrites the title found in HTML or imported via URL"
          },
          "description": {
            "type": "string",
            "description": "Meta description. If provided, overwrites the description found in HTML or imported via URL"
          },
          "url": {
            "type": "string",
            "description": "URL to auto-import and parse content from"
          },
          "id": {
            "type": "string",
            "description": "When providing URL, the id of the container that contains the content in the HTML structure"
          },
          "class": {
            "type": "string",
            "description": "When providing URL, the class of the container that contains the content in the HTML structure"
          }
        }
      },
      "ImportContentResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Import status",
            "example": "ok"
          },
          "error": {
            "type": "string",
            "description": "Error message if there was an issue during the import"
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "Your Neuron API key, obtained from your profile under the 'Neuron API access' tab"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}