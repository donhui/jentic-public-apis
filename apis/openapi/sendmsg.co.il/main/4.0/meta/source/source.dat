{
  "openapi": "3.0.3",
  "info": {
    "title": "Sendmsg API",
    "description": "Sendmsg is an all-in-one marketing platform for newsletters providing email automation, landing pages, SMS, digital courses and more. This API manages mailing lists, newsletters, SMS campaigns, user management, and analytics.",
    "version": "4.0",
    "x-jentic-source-url": "https://sendmsgapi.docs.apiary.io/"
  },
  "servers": [
    {
      "url": "https://gconvertrest.sendmsg.co.il/api/Sendmsg"
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "Authentication and token management" },
    { "name": "Users", "description": "User management operations" },
    { "name": "Email Campaigns", "description": "Email campaign and message operations" },
    { "name": "SMS Campaigns", "description": "SMS campaign operations" },
    { "name": "Mailing Lists", "description": "Mailing list management" },
    { "name": "Fields", "description": "Custom field management" },
    { "name": "Analytics", "description": "Statistics and analytics" },
    { "name": "SMS Verification", "description": "SMS sender number verification" }
  ],
  "paths": {
    "/token": {
      "post": {
        "operationId": "getToken",
        "summary": "Get authentication token",
        "description": "Authenticate with site ID and password to receive a token valid for 12 hours.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "500": {
            "description": "Authentication error"
          }
        }
      }
    },
    "/ping": {
      "post": {
        "operationId": "pingAuth",
        "summary": "Test authentication",
        "description": "Validate that the authorization token is still active.",
        "tags": ["Authentication"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Token is valid"
          }
        }
      }
    },
    "/AddUsersOnly": {
      "post": {
        "operationId": "addOrUpdateUsers",
        "summary": "Add or update users",
        "description": "Add new users or update existing users by email or user ID. Supports custom fields.",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddUsersRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Users added or updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AddUsersResponse" }
              }
            }
          }
        }
      }
    },
    "/AddUsersToLists": {
      "post": {
        "operationId": "addUsersToLists",
        "summary": "Add users to mailing lists",
        "description": "Add users (by email or user ID) to one or more mailing lists.",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddUsersToListsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Users added to lists successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AddUsersToListsResponse" }
              }
            }
          }
        }
      }
    },
    "/GetUserDetails/{userID}": {
      "get": {
        "operationId": "getUserDetails",
        "summary": "Get user details",
        "description": "Retrieve detailed information about a user by user ID.",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "userID",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "User details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserDetails" }
              }
            }
          },
          "410": {
            "description": "User not found"
          }
        }
      }
    },
    "/GetMailingListByID/{listID},{type}": {
      "get": {
        "operationId": "getMailingListById",
        "summary": "Get mailing list by ID",
        "description": "Retrieve users in a mailing list filtered by type (0=Active, 1=Inactive, 2=AskedRemoval, 3=BadEmail, 4=All).",
        "tags": ["Mailing Lists"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "listID",
            "in": "path",
            "required": true,
            "description": "Mailing list ID",
            "schema": { "type": "integer" }
          },
          {
            "name": "type",
            "in": "path",
            "required": true,
            "description": "User type filter (0=Active, 1=Inactive, 2=AskedRemoval, 3=BadEmail, 4=All)",
            "schema": { "type": "integer", "enum": [0, 1, 2, 3, 4] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of users in the mailing list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/UserDetails" }
                }
              }
            }
          }
        }
      }
    },
    "/GetSystemUsers": {
      "post": {
        "operationId": "getSystemUsers",
        "summary": "Get system users by type",
        "description": "Retrieve users by system type: SelfRemUsers, DelUsers, or wrongMails.",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["requestType"],
                "properties": {
                  "requestType": {
                    "type": "string",
                    "enum": ["SelfRemUsers", "DelUsers", "wrongMails"],
                    "description": "Type of system users to retrieve"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Array of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/UserDetails" }
                }
              }
            }
          }
        }
      }
    },
    "/ChangeUpdateStatus": {
      "post": {
        "operationId": "changeUserStatus",
        "summary": "Change user status",
        "description": "Change the email status of a user.",
        "tags": ["Users"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChangeStatusRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status changed successfully"
          }
        }
      }
    },
    "/AddUsersAndSend": {
      "post": {
        "operationId": "addUsersAndSendEmail",
        "summary": "Add users and send email",
        "description": "Add users and send them an email campaign. Supports new messages, past messages, or draft messages.",
        "tags": ["Email Campaigns"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddUsersAndSendRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email sent successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResponse" }
              }
            }
          }
        }
      }
    },
    "/SendEmailToMailingLists": {
      "post": {
        "operationId": "sendEmailToMailingLists",
        "summary": "Send email to mailing lists",
        "description": "Send an email campaign to one or more mailing lists.",
        "tags": ["Email Campaigns"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SendToListsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email sent to mailing lists",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResponse" }
              }
            }
          }
        }
      }
    },
    "/CreateMessage": {
      "post": {
        "operationId": "createMessage",
        "summary": "Create a message",
        "description": "Create a new email message or draft. Optionally schedule it for future sending.",
        "tags": ["Email Campaigns"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMessageRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateMessageResponse" }
              }
            }
          }
        }
      }
    },
    "/DelMessage/{MsgID}": {
      "get": {
        "operationId": "deleteMessage",
        "summary": "Delete a message",
        "description": "Delete a message by its ID.",
        "tags": ["Email Campaigns"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "MsgID",
            "in": "path",
            "required": true,
            "description": "Message ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Message deleted"
          }
        }
      }
    },
    "/AddUsersAndSendSMS": {
      "post": {
        "operationId": "addUsersAndSendSms",
        "summary": "Add users and send SMS",
        "description": "Add users and send them an SMS message.",
        "tags": ["SMS Campaigns"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddUsersAndSendSmsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResponse" }
              }
            }
          }
        }
      }
    },
    "/SendSmsToMailingLists": {
      "post": {
        "operationId": "sendSmsToMailingLists",
        "summary": "Send SMS to mailing lists",
        "description": "Send an SMS campaign to one or more mailing lists.",
        "tags": ["SMS Campaigns"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SendSmsToListsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent to mailing lists",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendResponse" }
              }
            }
          }
        }
      }
    },
    "/CheckingSmsBalances": {
      "get": {
        "operationId": "checkSmsBalances",
        "summary": "Check SMS balances",
        "description": "Retrieve current short and long SMS message balances.",
        "tags": ["SMS Campaigns"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "SMS balance information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SmsBalancesResponse" }
              }
            }
          }
        }
      }
    },
    "/GetMailingListNames": {
      "post": {
        "operationId": "getMailingListNames",
        "summary": "Get all mailing lists",
        "description": "Retrieve all mailing lists with user counts and descriptions.",
        "tags": ["Mailing Lists"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of mailing lists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MailingListInfo" }
                }
              }
            }
          }
        }
      }
    },
    "/CreateMalingList": {
      "post": {
        "operationId": "createMailingList",
        "summary": "Create a mailing list",
        "description": "Create a new mailing list.",
        "tags": ["Mailing Lists"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMailingListRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mailing list created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateMailingListResponse" }
              }
            }
          }
        }
      }
    },
    "/TruncateMailingLists": {
      "post": {
        "operationId": "truncateMailingLists",
        "summary": "Delete all users from mailing lists",
        "description": "Remove all users from one or more mailing lists.",
        "tags": ["Mailing Lists"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "listIDs": {
                    "type": "array",
                    "items": { "type": "integer" },
                    "description": "Array of mailing list IDs to truncate"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mailing lists truncated"
          }
        }
      }
    },
    "/RemoveFromMailingLists/ManyToMany": {
      "post": {
        "operationId": "removeUsersFromMailingLists",
        "summary": "Remove users from mailing lists",
        "description": "Remove specific users from specific mailing lists.",
        "tags": ["Mailing Lists"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RemoveUsersFromListsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Users removed from mailing lists"
          }
        }
      }
    },
    "/GetAllFields": {
      "post": {
        "operationId": "getAllFields",
        "summary": "Get all fields",
        "description": "Retrieve all system and custom fields.",
        "tags": ["Fields"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Dictionary of all fields",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": { "$ref": "#/components/schemas/FieldInfo" }
                }
              }
            }
          }
        }
      }
    },
    "/CreateField": {
      "post": {
        "operationId": "createField",
        "summary": "Create a custom field",
        "description": "Create a new custom field. Types: 1=Text, 2=Yes/No, 3=Dropdown, 4=Date, 7=Long text, 8=Number.",
        "tags": ["Fields"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateFieldRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Field created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateFieldResponse" }
              }
            }
          }
        }
      }
    },
    "/GetMsgFullStatistics/{messageID}": {
      "get": {
        "operationId": "getMessageStatistics",
        "summary": "Get message statistics",
        "description": "Retrieve full statistics for a specific message.",
        "tags": ["Analytics"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "messageID",
            "in": "path",
            "required": true,
            "description": "Message ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Message statistics",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageStatistics" }
              }
            }
          }
        }
      }
    },
    "/GetNumberOfJoinersToSystem": {
      "post": {
        "operationId": "getSubscribersByTimeline",
        "summary": "Get subscribers by timeline",
        "description": "Retrieve subscriber counts for specified date ranges.",
        "tags": ["Analytics"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/DateRange" }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscriber counts per timeframe",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/SubscriberCount" }
                }
              }
            }
          }
        }
      }
    },
    "/VerificationOfSenderNumberBySMS": {
      "post": {
        "operationId": "getVerificationCode",
        "summary": "Get SMS verification code",
        "description": "Send a verification code to a phone number for sender verification.",
        "tags": ["SMS Verification"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["SenderNumber"],
                "properties": {
                  "SenderNumber": { "type": "string", "description": "Phone number to verify" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification code sent"
          }
        }
      }
    },
    "/AuthenticateOfSenderNumberBySMS": {
      "post": {
        "operationId": "authenticateSenderNumber",
        "summary": "Authenticate sender phone number",
        "description": "Verify a phone number using the code received via SMS.",
        "tags": ["SMS Verification"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["SenderNumber", "Code"],
                "properties": {
                  "SenderNumber": { "type": "string", "description": "Phone number to authenticate" },
                  "Code": { "type": "string", "description": "Verification code received via SMS" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication confirmation"
          }
        }
      }
    },
    "/IsAllowedOfSenderNumberBySMS": {
      "post": {
        "operationId": "checkSenderVerificationStatus",
        "summary": "Check sender number verification status",
        "description": "Check whether a phone number has been verified as a sender.",
        "tags": ["SMS Verification"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["SenderNumber"],
                "properties": {
                  "SenderNumber": { "type": "string", "description": "Phone number to check" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification status"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token obtained from the /token endpoint"
      }
    },
    "schemas": {
      "TokenRequest": {
        "type": "object",
        "required": ["siteID", "password"],
        "properties": {
          "siteID": { "type": "integer", "description": "Site ID" },
          "password": { "type": "string", "description": "API password" }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "description": "Authentication token valid for 12 hours" }
        }
      },
      "AddUsersRequest": {
        "type": "object",
        "properties": {
          "Users": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserInput" }
          }
        }
      },
      "UserInput": {
        "type": "object",
        "properties": {
          "Email": { "type": "string", "format": "email" },
          "UserID": { "type": "string" },
          "Cellphone": { "type": "string" },
          "FirstName": { "type": "string" },
          "LastName": { "type": "string" }
        }
      },
      "AddUsersResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "userCount": { "type": "integer" },
          "messageID": { "type": "integer" }
        }
      },
      "AddUsersToListsRequest": {
        "type": "object",
        "properties": {
          "Users": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserInput" }
          },
          "ListIDs": {
            "type": "array",
            "items": { "type": "integer" },
            "description": "Mailing list IDs"
          }
        }
      },
      "AddUsersToListsResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "Users": { "type": "array", "items": { "type": "object" } },
          "Lists": { "type": "array", "items": { "type": "object" } }
        }
      },
      "UserDetails": {
        "type": "object",
        "properties": {
          "UserID": { "type": "string" },
          "Email": { "type": "string", "format": "email" },
          "FirstName": { "type": "string" },
          "LastName": { "type": "string" },
          "Cellphone": { "type": "string" },
          "StatusEmail": { "type": "string" }
        }
      },
      "ChangeStatusRequest": {
        "type": "object",
        "properties": {
          "UserID": { "type": "string" },
          "EmailAddress": { "type": "string", "format": "email" },
          "StatusEmail": {
            "type": "string",
            "enum": ["Active", "Inactive", "AskedRemoval", "BadEmail"],
            "description": "New email status"
          }
        }
      },
      "AddUsersAndSendRequest": {
        "type": "object",
        "properties": {
          "Users": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserInput" }
          },
          "Message": { "$ref": "#/components/schemas/EmailMessage" }
        }
      },
      "EmailMessage": {
        "type": "object",
        "properties": {
          "Content": { "type": "string", "description": "HTML email content" },
          "Subject": { "type": "string" },
          "SenderEmail": { "type": "string", "format": "email" },
          "BackgroundColor": { "type": "string" },
          "Direction": { "type": "string", "enum": ["RTL", "LTR"] }
        }
      },
      "SendToListsRequest": {
        "type": "object",
        "properties": {
          "ListIDs": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "Message": { "$ref": "#/components/schemas/EmailMessage" }
        }
      },
      "SendResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "userCount": { "type": "integer" },
          "messageID": { "type": "integer" }
        }
      },
      "CreateMessageRequest": {
        "type": "object",
        "properties": {
          "Content": { "type": "string" },
          "Subject": { "type": "string" },
          "SenderEmail": { "type": "string", "format": "email" },
          "BackgroundColor": { "type": "string" },
          "Direction": { "type": "string", "enum": ["RTL", "LTR"] },
          "ScheduleDate": { "type": "string", "format": "date-time", "description": "Optional future send date" }
        }
      },
      "CreateMessageResponse": {
        "type": "object",
        "properties": {
          "messageID": { "type": "integer", "description": "New message ID" }
        }
      },
      "AddUsersAndSendSmsRequest": {
        "type": "object",
        "properties": {
          "Users": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserInput" }
          },
          "Content": { "type": "string", "description": "SMS message content" },
          "SenderPhone": { "type": "string", "description": "Sender phone number (max 11 chars, English letters only)" },
          "MessageType": { "type": "integer", "enum": [1], "description": "Message type (1)" },
          "SmsType": { "type": "integer", "enum": [1, 2], "description": "SMS type: 1=short, 2=long" }
        }
      },
      "SendSmsToListsRequest": {
        "type": "object",
        "properties": {
          "ListIDs": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "Content": { "type": "string" },
          "SenderPhone": { "type": "string" }
        }
      },
      "SmsBalancesResponse": {
        "type": "object",
        "properties": {
          "shortMessages": { "type": "integer", "description": "Short SMS balance" },
          "longMessages": { "type": "integer", "description": "Long SMS balance" }
        }
      },
      "MailingListInfo": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "userCount": { "type": "integer" }
        }
      },
      "CreateMailingListRequest": {
        "type": "object",
        "required": ["IsNewList", "name"],
        "properties": {
          "IsNewList": { "type": "boolean", "default": true },
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "CreateMailingListResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "listID": { "type": "integer" }
        }
      },
      "RemoveUsersFromListsRequest": {
        "type": "object",
        "properties": {
          "Users": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserInput" }
          },
          "ListIDs": {
            "type": "array",
            "items": { "type": "integer" }
          }
        }
      },
      "FieldInfo": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "CreateFieldRequest": {
        "type": "object",
        "required": ["FieldUserName", "FieldUserType"],
        "properties": {
          "FieldUserName": { "type": "string", "description": "Field name" },
          "FieldUserType": {
            "type": "integer",
            "enum": [1, 2, 3, 4, 7, 8],
            "description": "Field type: 1=Text, 2=Yes/No, 3=Dropdown, 4=Date, 7=Long text, 8=Number"
          },
          "OptionToDDR": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Options for dropdown fields (type 3)"
          }
        }
      },
      "CreateFieldResponse": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "MessageStatistics": {
        "type": "object",
        "properties": {
          "messageID": { "type": "integer" },
          "statistics": { "type": "object" }
        }
      },
      "DateRange": {
        "type": "object",
        "properties": {
          "From": { "type": "string", "format": "date" },
          "Until": { "type": "string", "format": "date" }
        }
      },
      "SubscriberCount": {
        "type": "object",
        "properties": {
          "from": { "type": "string", "format": "date" },
          "until": { "type": "string", "format": "date" },
          "count": { "type": "integer" }
        }
      }
    }
  }
}