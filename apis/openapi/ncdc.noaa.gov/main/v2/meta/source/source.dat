          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/datacategories/{datacategoryid}": {
      "get": {
        "operationId": "getDataCategory",
        "summary": "Get a specific data category by ID",
        "parameters": [
          {
            "name": "datacategoryid",
