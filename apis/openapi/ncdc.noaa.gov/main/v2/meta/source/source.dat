              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/data": {
      "get": {
        "operationId": "getData",
        "summary": "Get observed data values",
        "parameters": [
          {
            "name": "datasetid",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Required dataset identifier"
          },
          {
            "$ref": "#/components/parameters/datatypeid"
          },
          {
            "$ref": "#/components/parameters/locationid"
          },
          {
            "$ref": "#/components/parameters/stationid"
          },
          {
            "name": "startdate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date in ISO format (YYYY-MM-DD)"
          },
          {
            "name": "enddate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date in ISO format (YYYY-MM-DD)"
          },
          {
            "name": "units",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "standard",
                "metric"
              ]
            }
          },
          {
            "$ref": "#/components/parameters/sortfield"
          },
          {
            "$ref": "#/components/parameters/sortorder"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "$ref": "#/components/parameters/offset"
          },
          {
            "name": "includemetadata",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing required parameters"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "token",
        "description": "CDO API token"
      }
    },
    "parameters": {
      "datatypeid": {
        "name": "datatypeid",
        "in": "query",
        "schema": {
          "type": "string"
        }
      },
      "locationid": {
        "name": "locationid",
        "in": "query",
        "schema": {
          "type": "string"
        }
      },
      "stationid": {
        "name": "stationid",
        "in": "query",
        "schema": {
          "type": "string"
        }
      },
      "startdate": {
        "name": "startdate",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date"
        },
        "description": "Start date in ISO format (YYYY-MM-DD)"
      },
      "enddate": {
        "name": "enddate",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date"
        },
        "description": "End date in ISO format (YYYY-MM-DD)"
      },
      "sortfield": {
        "name": "sortfield",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "id",
            "name",
            "mindate",
            "maxdate",
            "datacoverage"
          ]
        }
      },
      "sortorder": {
        "name": "sortorder",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ]
        }
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 25,
          "maximum": 1000
        },
        "description": "Number of results per response"
      },
      "offset": {
        "name": "offset",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 0
        },
        "description": "Starting record number"
      }
    },
    "schemas": {
      "PaginationMetadata": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          },
          "count": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        }
      },
      "Dataset": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "datacoverage": {
            "type": "number"
          },
          "mindate": {
            "type": "string",
            "format": "date"
          },
          "maxdate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "DatasetListResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "resultset": {
                "$ref": "#/components/schemas/PaginationMetadata"
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Dataset"
            }
          }
        }
      },
      "DataCategory": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "DataCategoryListResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "resultset": {
                "$ref": "#/components/schemas/PaginationMetadata"
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataCategory"
            }
          }
        }
      },
      "DataType": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "datacoverage": {
            "type": "number"
          },
          "mindate": {
            "type": "string",
            "format": "date"
          },
          "maxdate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "DataTypeListResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "resultset": {
                "$ref": "#/components/schemas/PaginationMetadata"
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataType"
            }
          }
        }
      },
      "LocationCategory": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "LocationCategoryListResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "resultset": {
                "$ref": "#/components/schemas/PaginationMetadata"
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LocationCategory"
            }
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "datacoverage": {
            "type": "number"
          },
          "mindate": {
            "type": "string",
            "format": "date"
          },
          "maxdate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "LocationListResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "resultset": {
                "$ref": "#/components/schemas/PaginationMetadata"
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Location"
            }
          }
        }
      },
      "Station": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "datacoverage": {
            "type": "number"
          },
          "mindate": {
            "type": "string",
            "format": "date"
          },
          "maxdate": {
            "type": "string",
            "format": "date"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "elevation": {
            "type": "number"
          },
          "elevationUnit": {
            "type": "string"
          }
        }
      },
      "StationListResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "resultset": {
                "$ref": "#/components/schemas/PaginationMetadata"
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Station"
            }
          }
        }
      },
      "DataRecord": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "datatype": {
            "type": "string"
          },
          "station": {
            "type": "string"
          },
          "attributes": {
            "type": "string"
          },
          "value": {
            "type": "number"
          }
        }
      },
      "DataListResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "resultset": {
                "$ref": "#/components/schemas/PaginationMetadata"
              }
            }
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataRecord"
            }
          }
        }
      }
    }
  }
}