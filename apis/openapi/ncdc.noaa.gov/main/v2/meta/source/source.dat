{
  "openapi": "3.0.3",
  "info": {
    "title": "Climate Data Online Web Services",
    "description": "NOAA Climate Data Online (CDO) Web Services v2 API provides access to climate and weather datasets, data categories, data types, location categories, locations, stations, and observed data values.",
    "version": "v2",
    "x-jentic-source-url": "https://www.ncdc.noaa.gov/cdo-web/webservices/v2"
  },
  "servers": [
    {
      "url": "https://www.ncei.noaa.gov/cdo-web/api/v2"
    }
  ],
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "paths": {
    "/datasets": {
      "get": {
        "operationId": "listDatasets",
        "summary": "List all available datasets",
        "parameters": [
          {
            "$ref": "#/components/parameters/datatypeid"
          },
          {
            "$ref": "#/components/parameters/locationid"
          },
          {
            "$ref": "#/components/parameters/stationid"
          },
          {
            "$ref": "#/components/parameters/startdate"
          },
          {
            "$ref": "#/components/parameters/enddate"
          },
          {
            "$ref": "#/components/parameters/sortfield"
          },
          {
            "$ref": "#/components/parameters/sortorder"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
          {
            "$ref": "#/components/parameters/offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing token"
          }
        }
      }
    },
    "/datasets/{datasetid}": {
      "get": {
        "operationId": "getDataset",
        "summary": "Get a specific dataset by ID",
        "parameters": [
          {
            "name": "datasetid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Dataset"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/datacategories": {
      "get": {
        "operationId": "listDataCategories",
        "summary": "List all available data categories",
