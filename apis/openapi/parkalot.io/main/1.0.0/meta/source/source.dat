{
  "openapi": "3.0.3",
  "info": {
    "title": "Parkalot API",
    "description": "Parkalot Open API for managing parking reservations and retrieving parking reports.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://parkalot.io/open-api/"
  },
  "servers": [
    {
      "url": "https://parkalotapi.io",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Reports",
      "description": "Parking report retrieval"
    },
    {
      "name": "Reservations",
      "description": "Retrieve, update, delete, and monitor reservations"
    }
  ],
  "paths": {
    "/reports/{facilityId}/readable/{fromDay}/{toDay}": {
      "get": {
        "operationId": "queryParkingReports",
        "summary": "Query parking reports",
        "description": "Retrieve parking reports for a specified date range. Query only needed dates for optimal performance.",
        "tags": ["Reports"],
        "security": [
          {
            "ApiKeyAuth": ["reports-exact-read"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/facilityId"
          },
          {
            "$ref": "#/components/parameters/fromDay"
          },
          {
            "$ref": "#/components/parameters/toDay"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with parking report data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "facilityId": {
                      "type": "string"
                    },
                    "fromDay": {
                      "type": "string",
                      "format": "date"
                    },
                    "toDay": {
                      "type": "string",
                      "format": "date"
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ItemState"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reservations/{facilityId}/nested-day/{fromDay}/{toDay}": {
      "get": {
        "operationId": "queryReservationsNested",
        "summary": "Query reservations (nested format)",
        "description": "Retrieve reservations in a nested structure grouped by day and item. Maximum 31-day range.",
        "tags": ["Reservations"],
        "security": [
          {
            "ApiKeyAuth": ["users-read", "reservations-read"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/facilityId"
          },
          {
            "$ref": "#/components/parameters/fromDay"
          },
          {
            "$ref": "#/components/parameters/toDay"
          },
          {
            "name": "item_tags",
            "in": "query",
            "description": "Include item tags in response",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "item_description",
            "in": "query",
            "description": "Include item description in response",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "item_group_id",
            "in": "query",
            "description": "Include item group ID in response",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "item_group_name",
            "in": "query",
            "description": "Include item group name in response",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with nested reservation data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "facilityId": {
                      "type": "string"
                    },
                    "fromDay": {
                      "type": "string",
                      "format": "date"
                    },
                    "toDay": {
                      "type": "string",
                      "format": "date"
                    },
                    "reservations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ReservationNested"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reservations/{facilityId}/flat/{fromDay}/{toDay}": {
      "get": {
        "operationId": "queryReservationsFlat",
        "summary": "Query reservations (flat format)",
        "description": "Retrieve reservations in a flat structure. Maximum 31-day range.",
        "tags": ["Reservations"],
        "security": [
          {
            "ApiKeyAuth": ["users-read", "reservations-read"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/facilityId"
          },
          {
            "$ref": "#/components/parameters/fromDay"
          },
          {
            "$ref": "#/components/parameters/toDay"
          },
          {
            "name": "item_tags",
            "in": "query",
            "description": "Include item tags in response",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "item_description",
            "in": "query",
            "description": "Include item description in response",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "item_group_id",
            "in": "query",
            "description": "Include item group ID in response",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "item_group_name",
            "in": "query",
            "description": "Include item group name in response",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with flat reservation data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "facilityId": {
                      "type": "string"
                    },
                    "fromDay": {
                      "type": "string",
                      "format": "date"
                    },
                    "toDay": {
                      "type": "string",
                      "format": "date"
                    },
                    "reservations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ReservationFlat"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reservations/{facilityId}/did-change/{fromDay}/{toDay}": {
      "get": {
        "operationId": "checkReservationChanges",
        "summary": "Check reservation changes",
        "description": "Check if reservations or parking setup changed in the specified date range since the given timestamp.",
        "tags": ["Reservations"],
        "security": [
          {
            "ApiKeyAuth": ["users-read", "reservations-read"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/facilityId"
          },
          {
            "$ref": "#/components/parameters/fromDay"
          },
          {
            "$ref": "#/components/parameters/toDay"
          },
          {
            "name": "since",
            "in": "query",
            "description": "Unix timestamp in milliseconds to check changes since",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response indicating whether changes occurred",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "hasChanges": {
                      "type": "boolean",
                      "description": "Whether any changes occurred since the given timestamp"
                    },
                    "days": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DayChange"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reservations/{facilityId}": {
      "put": {
        "operationId": "updateReservations",
        "summary": "Update reservations (batch)",
        "description": "Create or release parking spot reservations in batch. A non-null uid reserves the spot; a null uid unreserves it.",
        "tags": ["Reservations"],
        "security": [
          {
            "ApiKeyAuth": ["reservations-write"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/facilityId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PublicReserveRequest"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response with results for each reservation request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReserveResponse"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/reservations/{facilityId}/{fromDay}/{toDay}": {
      "delete": {
        "operationId": "deleteReservations",
        "summary": "Delete reservations",
        "description": "Delete user reservations for a date range. Maximum 31-day limit. At least one user identifier (uid, externalId, or email) is required.",
        "tags": ["Reservations"],
        "security": [
          {
            "ApiKeyAuth": ["reservations-write"]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/facilityId"
          },
          {
            "$ref": "#/components/parameters/fromDay"
          },
          {
            "$ref": "#/components/parameters/toDay"
          },
          {
            "name": "uid",
            "in": "query",
            "description": "User ID whose reservations to delete",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "externalId",
            "in": "query",
            "description": "External user ID whose reservations to delete",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "description": "User email whose reservations to delete",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "withWaitlist",
            "in": "query",
            "description": "Whether to trigger waitlist processing on unreserve",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful deletion",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key with scoped permissions: setup-read, setup-write, reservations-read, reservations-write, reports-exact-read, reports-anonymized-read, confirmation-settings-read, confirmation-settings-write, integrations-settings-read, integrations-settings-write, users-read, users-write, spots-read, spots-write, access-write"
      }
    },
    "parameters": {
      "facilityId": {
        "name": "facilityId",
        "in": "path",
        "description": "Facility identifier",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "fromDay": {
        "name": "fromDay",
        "in": "path",
        "description": "Start date (must be less than or equal to toDay)",
        "required": true,
        "schema": {
          "type": "string",
          "format": "date"
        }
      },
      "toDay": {
        "name": "toDay",
        "in": "path",
        "description": "End date (must be greater than or equal to fromDay)",
        "required": true,
        "schema": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "details": {
            "type": "string",
            "description": "Additional error details",
            "nullable": true
          }
        },
        "required": ["message"]
      },
      "RelativeTime": {
        "type": "object",
        "description": "A relative time representation",
        "properties": {
          "relative_millis": {
            "type": "integer",
            "format": "int64",
            "description": "Relative time in milliseconds"
          },
          "day_time": {
            "type": "string",
            "description": "Time of day"
          },
          "day_offset": {
            "type": "integer",
            "description": "Day offset"
          }
        }
      },
      "ItemState": {
        "type": "object",
        "description": "Parking report record representing the state of a parking item",
        "properties": {
          "day": {
            "type": "string",
            "format": "date",
            "description": "Date of the record"
          },
          "start_time": {
            "type": "string",
            "description": "Start time of the period"
          },
          "end_time": {
            "type": "string",
            "description": "End time of the period"
          },
          "item_name": {
            "type": "string",
            "description": "Name of the parking item"
          },
          "item_id": {
            "type": "string",
            "description": "Identifier of the parking item"
          },
          "item_group_id": {
            "type": "string",
            "nullable": true,
            "description": "Identifier of the item group"
          },
          "item_group_name": {
            "type": "string",
            "nullable": true,
            "description": "Name of the item group"
          },
          "user_id": {
            "type": "string",
            "nullable": true,
            "description": "ID of the user who reserved the spot"
          },
          "user_name": {
            "type": "string",
            "nullable": true,
            "description": "Name of the user who reserved the spot"
          },
          "owner_id": {
            "type": "string",
            "nullable": true,
            "description": "ID of the spot owner"
          },
          "owner_name": {
            "type": "string",
            "nullable": true,
            "description": "Name of the spot owner"
          },
          "released_at": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/RelativeTime"
              }
            ],
            "description": "When the spot was released"
          },
          "reserved_at": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/RelativeTime"
              }
            ],
            "description": "When the spot was reserved"
          }
        }
      },
      "ReservationUser": {
        "type": "object",
        "description": "User information in a reservation",
        "properties": {
          "user_id": {
            "type": "string",
            "description": "User identifier"
          },
          "user_name": {
            "type": "string",
            "description": "User display name"
          },
          "user_external_id": {
            "type": "string",
            "nullable": true,
            "description": "External user identifier"
          },
          "user_plates": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "License plate numbers associated with the user"
          }
        }
      },
      "ReservationTime": {
        "type": "object",
        "description": "A time period within a reservation with user info",
        "properties": {
          "start_time": {
            "type": "string",
            "description": "Start time of the reservation period"
          },
          "end_time": {
            "type": "string",
            "description": "End time of the reservation period"
          },
          "user": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/ReservationUser"
              }
            ],
            "description": "User who holds this reservation"
          }
        }
      },
      "ReservationNested": {
        "type": "object",
        "description": "Reservation record in nested format, grouped by day and item with time periods",
        "properties": {
          "day": {
            "type": "string",
            "format": "date",
            "description": "Date of the reservation"
          },
          "item_id": {
            "type": "string",
            "description": "Parking item identifier"
          },
          "item_name": {
            "type": "string",
            "description": "Parking item name"
          },
          "item_tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true,
            "description": "Tags associated with the item (included when item_tags=true)"
          },
          "item_description": {
            "type": "string",
            "nullable": true,
            "description": "Item description (included when item_description=true)"
          },
          "item_group_id": {
            "type": "string",
            "nullable": true,
            "description": "Item group identifier (included when item_group_id=true)"
          },
          "item_group_name": {
            "type": "string",
            "nullable": true,
            "description": "Item group name (included when item_group_name=true)"
          },
          "times": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReservationTime"
            },
            "description": "Array of time periods with reservation details"
          }
        }
      },
      "ReservationFlat": {
        "type": "object",
        "description": "Reservation record in flat format with one time period per record",
        "properties": {
          "day": {
            "type": "string",
            "format": "date",
            "description": "Date of the reservation"
          },
          "item_id": {
            "type": "string",
            "description": "Parking item identifier"
          },
          "item_name": {
            "type": "string",
            "description": "Parking item name"
          },
          "item_tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true,
            "description": "Tags associated with the item (included when item_tags=true)"
          },
          "item_description": {
            "type": "string",
            "nullable": true,
            "description": "Item description (included when item_description=true)"
          },
          "item_group_id": {
            "type": "string",
            "nullable": true,
            "description": "Item group identifier (included when item_group_id=true)"
          },
          "item_group_name": {
            "type": "string",
            "nullable": true,
            "description": "Item group name (included when item_group_name=true)"
          },
          "start_time": {
            "type": "string",
            "description": "Start time of the reservation period"
          },
          "end_time": {
            "type": "string",
            "description": "End time of the reservation period"
          },
          "user": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/ReservationUser"
              }
            ],
            "description": "User who holds this reservation"
          }
        }
      },
      "DayChange": {
        "type": "object",
        "description": "Indicates whether changes occurred on a specific day",
        "properties": {
          "day": {
            "type": "string",
            "format": "date",
            "description": "The date"
          },
          "changed": {
            "type": "boolean",
            "description": "Whether changes occurred on this day"
          }
        }
      },
      "PublicReserveRequest": {
        "type": "object",
        "description": "Request to reserve or unreserve a parking spot",
        "required": ["spotId", "day", "shifts"],
        "properties": {
          "uid": {
            "type": "string",
            "nullable": true,
            "description": "User ID to reserve for. Set to null to unreserve."
          },
          "spotId": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              }
            ],
            "description": "Parking spot identifier"
          },
          "day": {
            "type": "string",
            "format": "date",
            "description": "Reservation date"
          },
          "shifts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Time shift codes for the reservation"
          },
          "withWaitlist": {
            "type": "boolean",
            "nullable": true,
            "description": "Whether to trigger waitlist processing on unreserve"
          }
        }
      },
      "ReserveResponse": {
        "type": "object",
        "description": "Result of a single reservation request",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the reservation operation succeeded"
          },
          "data": {
            "type": "object",
            "nullable": true,
            "description": "Reservation data on success"
          },
          "error": {
            "type": "object",
            "nullable": true,
            "description": "Error details on failure",
            "properties": {
              "message": {
                "type": "string"
              },
              "details": {
                "type": "string",
                "nullable": true
              }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - missing or invalid API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - API key lacks required permissions",
        "content": {
