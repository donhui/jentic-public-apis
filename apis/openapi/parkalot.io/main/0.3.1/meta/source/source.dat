{
  "openapi": "3.0.3",
  "info": {
    "title": "Parkalot Open API",
    "description": "Parkalot parking management API for querying reports, reservations, and managing parking spot bookings.",
    "version": "0.3.1",
    "x-jentic-source-url": "https://parkalot.io/open-api/"
  },
  "servers": [
    {
      "url": "https://parkalotapi.io",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Reports",
      "description": "Parking report queries"
    },
    {
      "name": "Reservations",
      "description": "Reservation management"
    }
  ],
  "paths": {
    "/reports/{facilityId}/readable/{fromDay}/{toDay}": {
      "get": {
        "operationId": "getReadableReports",
        "summary": "Query parking reports in readable format",
        "tags": ["Reports"],
        "parameters": [
          {
            "name": "facilityId",
            "in": "path",
            "required": true,
            "description": "Site identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromDay",
            "in": "path",
            "required": true,
            "description": "Start date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "toDay",
            "in": "path",
            "required": true,
            "description": "End date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with parking report data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadableReportResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - missing required permission scope (reports-exact-read)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests - rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reservations/{facilityId}/nested-day/{fromDay}/{toDay}": {
      "get": {
        "operationId": "getNestedReservations",
        "summary": "Query reservations in nested day structure",
        "description": "Maximum 31 days range allowed.",
        "tags": ["Reservations"],
        "parameters": [
          {
            "name": "facilityId",
            "in": "path",
            "required": true,
            "description": "Site identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromDay",
            "in": "path",
            "required": true,
            "description": "Start date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "toDay",
            "in": "path",
            "required": true,
            "description": "End date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "item_tags",
            "in": "query",
            "required": false,
            "description": "Include item tags",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "item_description",
            "in": "query",
            "required": false,
            "description": "Include item description",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "item_group_id",
            "in": "query",
            "required": false,
            "description": "Include item group ID",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "item_group_name",
            "in": "query",
            "required": false,
            "description": "Include item group name",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with nested reservation data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NestedReservationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reservations/{facilityId}/flat/{fromDay}/{toDay}": {
      "get": {
        "operationId": "getFlatReservations",
        "summary": "Query reservations in flat structure",
        "description": "Returns single-level records. Maximum 31 days range.",
        "tags": ["Reservations"],
        "parameters": [
          {
            "name": "facilityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromDay",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "toDay",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "item_tags",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "item_description",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "item_group_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "item_group_name",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with flat reservation data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlatReservationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reservations/{facilityId}/did-change/{fromDay}/{toDay}": {
      "get": {
        "operationId": "checkReservationChanges",
        "summary": "Check if reservations changed since a given timestamp",
        "tags": ["Reservations"],
        "parameters": [
          {
            "name": "facilityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromDay",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "toDay",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "since",
            "in": "query",
            "required": true,
            "description": "Unix timestamp in milliseconds",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Change detection result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangeDetectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reservations/{facilityId}": {
      "put": {
        "operationId": "updateReservations",
        "summary": "Batch update reservations",
        "description": "Requires reservations-write permission.",
        "tags": ["Reservations"],
        "parameters": [
          {
            "name": "facilityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ReservationUpdateRequest"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch update results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReservationUpdateResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reservations/{facilityId}/{fromDay}/{toDay}": {
      "delete": {
        "operationId": "deleteReservations",
        "summary": "Delete reservations for a user in a date range",
        "description": "Requires reservations-write permission. Maximum 31 days range. At least one of uid, externalId, or email is required.",
        "tags": ["Reservations"],
        "parameters": [
          {
            "name": "facilityId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromDay",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "toDay",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "uid",
            "in": "query",
            "required": false,
            "description": "User ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "externalId",
            "in": "query",
            "required": false,
            "description": "External user ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "required": false,
            "description": "User email",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "withWaitlist",
            "in": "query",
            "required": false,
            "description": "Include waitlist entries",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ReadableReportResponse": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object",
            "properties": {
              "facilityId": { "type": "string" },
              "fromDay": { "type": "string" },
              "toDay": { "type": "string" }
            }
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReportEntry"
            }
          }
        }
      },
      "ReportEntry": {
        "type": "object",
        "properties": {
          "day": { "type": "string", "format": "date" },
          "times": {
            "type": "array",
            "items": { "type": "string" }
          },
          "item_id": { "type": "string" },
          "item_name": { "type": "string" },
          "user_name": { "type": "string" },
          "user_email": { "type": "string" },
          "owner_name": { "type": "string" },
          "owner_email": { "type": "string" },
          "released_at": { "type": "string" },
          "reserved_at": { "type": "string" }
        }
      },
      "NestedReservationResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NestedReservation"
            }
          }
        }
      },
      "NestedReservation": {
        "type": "object",
        "properties": {
          "day": { "type": "string", "format": "date" },
          "item_id": { "type": "string" },
          "item_name": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": { "type": "string" },
          "times": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "start_time": { "type": "string" },
                "end_time": { "type": "string" },
                "user_name": { "type": "string" },
                "user_email": { "type": "string" }
              }
            }
          }
        }
      },
      "FlatReservationResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FlatReservation"
            }
          }
        }
      },
      "FlatReservation": {
        "type": "object",
        "properties": {
          "day": { "type": "string", "format": "date" },
          "item_id": { "type": "string" },
          "item_name": { "type": "string" },
          "start_time": { "type": "string" },
          "end_time": { "type": "string" },
          "user_name": { "type": "string" },
          "user_email": { "type": "string" }
        }
      },
      "ChangeDetectionResponse": {
        "type": "object",
        "properties": {
          "hasChanges": { "type": "boolean" },
          "changes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "day": { "type": "string", "format": "date" },
                "changed": { "type": "boolean" }
              }
            }
          }
        }
      },
      "ReservationUpdateRequest": {
        "type": "object",
        "required": ["uid", "spotId", "day", "shifts"],
        "properties": {
          "uid": { "type": "string" },
          "spotId": { "type": "string" },
          "day": { "type": "string", "format": "date" },
          "shifts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "withWaitlist": { "type": "boolean" }
        }
      },
      "ReservationUpdateResult": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "error": { "type": "string" }
        }
      },
      "DeleteResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" }
        }
      }
    }
  }
}