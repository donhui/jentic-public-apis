                      "example": "Webhook subscription deleted"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errors"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - Webhook subscription not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errors"
                },
                "example": {
                  "errors": [
                    "Webhook subscription not found"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
