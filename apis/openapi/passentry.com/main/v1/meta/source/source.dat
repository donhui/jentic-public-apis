    "/api/v1/passes/{id}": {
      "patch": {
        "summary": "Update pass",
        "tags": [
          "Passes"
        ],
        "operationId": "updatePass",
        "security": [
          {
            "api_key": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Pass UUID or External ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includePassDesign",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
