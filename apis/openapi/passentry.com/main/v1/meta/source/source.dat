              },
              "successful": {
                "type": "boolean",
                "description": "Whether the tap was successful"
              }
            }
          },
          "relationships": {
            "type": "object",
            "description": "Relationships to other resources.",
            "allOf": [
              {
                "$ref": "#/components/schemas/passRelationship"
              },
              {
                "$ref": "#/components/schemas/readerRelationship"
              }
            ]
          }
        }
      },
      "serializedScanObject": {
        "type": "object",
