                "example": {
                  "errors": [
                    "Access denied"
                  ]
                },
                "schema": {
                  "$ref": "#/components/schemas/errors"
                }
              }
            }
          },
          "404": {
            "description": "Error: Not Found",
            "content": {
              "application/json": {
                "example": {
                  "errors": [
                    "Pass with provided id not found"
                  ]
                },
                "schema": {
                  "$ref": "#/components/schemas/errors"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/pass"
              },
              "examples": {
                "0": {
                  "summary": "Update pass",
                  "value": {
                    "pass": {
                      "nfc": {
                        "enabled": false
                      },
                      "fullName": {
                        "value": "Jane Roberts"
                      }
                    },
                    "message": "Your pass details have been updated. Click to show pass",
                    "locations": [
                      {
                        "name": "Venue",
