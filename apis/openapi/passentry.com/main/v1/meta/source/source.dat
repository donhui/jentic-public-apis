          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "name,description,templateType"
            },
            "description": "Returns a partial response (Sparse fieldset), instead of the whole record. Set one or many comma separated record attributes",
