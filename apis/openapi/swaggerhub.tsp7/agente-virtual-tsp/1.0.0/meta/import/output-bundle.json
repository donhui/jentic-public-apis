          },
          "400": {
            "description": "bad input parameter"
          }
        },
        "tags": [
          "Negociação"
        ],
        "description": "Emite o acordo de forma parcelada, mediante quantidade de parcelas e valor de entrada informados. O percentual de desconto aplicado é de 80%.",
        "operationId": "geraNegociacaoParcelada",
        "summary": "geraNegociacaoParcelada"
      }
    },
