    "/detalhes_divida_parcelado/{id_contrato}/{qntd_parcelas}/{valor_entrada}": {
      "get": {
        "parameters": [
          {
            "description": "informar o ID do contrato",
            "in": "path",
            "name": "id_contrato",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "informar a quantidade de parcelas a ser calculado",
            "in": "path",
            "name": "qntd_parcelas",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "informar o valor da entrada",
            "in": "path",
            "name": "valor_entrada",
            "required": true,
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetalhesDividaParcelado"
                }
              }
            },
            "description": "Exemplo de retorno bem sucedido"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetalhesDividaParceladoErro"
                }
              }
            },
            "description": "Exemplo de retorno mal sucedido"
          }
        },
        "tags": [
          "Dados"
        ],
        "description": "Informa os valores da opção parcelada do contrato, baseando-se na quantidade de parcelas e valor de entrada informados.",
        "operationId": "detalhesDividaParcelado",
        "summary": "detalhesDividaParelado"
      }
    },
    "/gera_acordo/{opcao}/{id_contrato}": {
      "get": {
        "parameters": [
          {
            "description": "informar a opção, a = atualização , q = quitação ou u = avulso",
            "in": "path",
            "name": "opcao",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "informar o ID do contrato para qual será formalizado a negociação",
            "in": "path",
            "name": "id_contrato",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GeraNegociacao"
                }
              }
            },
            "description": "Exemplo de retorno bem sucedido"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NaoPossivelNegociacao"
                }
              }
            },
            "description": "Não foi possível gerar uma negociação para este contrato"
          }
        },
        "tags": [
          "Negociação"
        ],
        "description": "Através da opção escolhida (a=atualização , q=quitação e u=avulso) é gerado um acordo pa o contrato informado. O percentual de desconto aplicado é de 80%.",
        "operationId": "geraNegociacao",
        "summary": "geraNegociacao"
      }
    },
    "/gera_negociacao_parcelado/{id_contrato}/{qntd_parcelas}/{valor_entrada}": {
