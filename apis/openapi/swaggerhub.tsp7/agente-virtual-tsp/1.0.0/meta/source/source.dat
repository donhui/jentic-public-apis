{
  "swagger": "2.0",
  "info": {
    "description": "Esta \u00e9 a documenta\u00e7\u00e3o disponibilizada para utiliza\u00e7\u00e3o da Talktelecom , para obten\u00e7\u00e3o de dados , gera\u00e7\u00e3o de acordos e inclus\u00e3o de hist\u00f3ricos.",
    "version": "1.0.0",
    "title": "Integra\u00e7\u00e3o Talktelecom TSP",
    "contact": {
      "email": "ti@tsprecuperadora.com.br"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/TSP7/Agente_Virtual_TSP/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "Dados",
      "description": "Dados do cliente"
    },
    {
      "name": "Negocia\u00e7\u00e3o",
      "description": "Valores para negocia\u00e7\u00e3o"
    },
    {
      "name": "Hist\u00f3rico",
      "description": "Adicionar hist\u00f3rico"
    }
  ],
  "paths": {
    "/valores_negociacao/{contrato}": {
      "get": {
        "tags": [
          "Dados"
        ],
        "summary": "valoresNegocia\u00e7\u00e3o",
        "operationId": "valoresNegocia\u00e7\u00e3o",
        "description": "Obt\u00e9m o CPF, os valores da d\u00edvida e de negocia\u00e7\u00e3o para quita\u00e7\u00e3o, atualiza\u00e7\u00e3o (caso n\u00e3o tenha essa op\u00e7\u00e3o o campo atualiza\u00e7\u00e3o \u00e9 retornado como Null) e acordo avulso, condiderando o vencimento D+2.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "contrato",
            "in": "path",
            "type": "string",
            "required": true,
            "description": "informar o n\u00famero do contrato"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/DetalhesDivida"
            }
          },
          "400": {
            "description": "N\u00e3o foi poss\u00edvel obter os valores da negocia\u00e7\u00e3o",
            "schema": {
              "$ref": "#/definitions/NaoPossivel"
            }
          }
        }
      }
    },
    "/detalhes_divida_parcelado/{id_contrato}/{qntd_parcelas}/{valor_entrada}": {
      "get": {
        "tags": [
          "Dados"
        ],
        "summary": "detalhesDividaParelado",
        "operationId": "detalhesDividaParcelado",
        "description": "Informa os valores da op\u00e7\u00e3o parcelada do contrato, baseando-se na quantidade de parcelas e valor de entrada informados.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id_contrato",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do contrato"
          },
          {
            "name": "qntd_parcelas",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar a quantidade de parcelas a ser calculado"
          },
          {
            "name": "valor_entrada",
            "in": "path",
            "type": "number",
            "required": true,
            "description": "informar o valor da entrada"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/DetalhesDividaParcelado"
            }
          },
          "400": {
            "description": "Exemplo de retorno mal sucedido",
            "schema": {
              "$ref": "#/definitions/DetalhesDividaParceladoErro"
            }
          }
        }
      }
    },
    "/gera_acordo/{opcao}/{id_contrato}": {
      "get": {
        "tags": [
          "Negocia\u00e7\u00e3o"
        ],
        "summary": "geraNegociacao",
        "operationId": "geraNegociacao",
        "description": "Atrav\u00e9s da op\u00e7\u00e3o escolhida (a=atualiza\u00e7\u00e3o , q=quita\u00e7\u00e3o e u=avulso) \u00e9 gerado um acordo pa o contrato informado. O percentual de desconto aplicado \u00e9 de 80%.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "opcao",
            "in": "path",
            "type": "string",
            "required": true,
            "description": "informar a op\u00e7\u00e3o, a = atualiza\u00e7\u00e3o , q = quita\u00e7\u00e3o ou u = avulso"
          },
          {
            "name": "id_contrato",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do contrato para qual ser\u00e1 formalizado a negocia\u00e7\u00e3o"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/GeraNegociacao"
            }
          },
          "400": {
            "description": "N\u00e3o foi poss\u00edvel gerar uma negocia\u00e7\u00e3o para este contrato",
            "schema": {
              "$ref": "#/definitions/NaoPossivelNegociacao"
            }
          }
        }
      }
    },
    "/gera_negociacao_parcelado/{id_contrato}/{qntd_parcelas}/{valor_entrada}": {
      "get": {
        "tags": [
          "Negocia\u00e7\u00e3o"
        ],
        "summary": "geraNegociacaoParcelada",
        "operationId": "geraNegociacaoParcelada",
        "description": "Emite o acordo de forma parcelada, mediante quantidade de parcelas e valor de entrada informados. O percentual de desconto aplicado \u00e9 de 80%.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id_contrato",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do contrato para qual ser\u00e1 formalizado a negocia\u00e7\u00e3o"
          },
          {
            "name": "qntd_parcelas",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar a quantidade de parcelas a ser calculado"
          },
          {
            "name": "valor_entrada",
            "in": "path",
            "type": "number",
            "required": true,
            "description": "informar o valor da entrada (primeira parcela)"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/GeraNegociacaoParcelada"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/historico/{id_contrato}/{id_ocorrencia}/{observacao}/{telefone}": {
      "get": {
        "tags": [
          "Hist\u00f3rico"
        ],
        "summary": "adicionaHistorico",
        "operationId": "adicionaHistorico",
        "description": "Adiciona um hist\u00f3rico informando o Id Contrato em quest\u00e3o, o Id da Ocorr\u00eancia e o texto que ser\u00e1 inclu\u00eddo na observa\u00e7\u00e3o.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id_contrato",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o id do contrato"
          },
          {
            "name": "id_ocorrencia",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o id da ocorr\u00eancia"
          },
          {
            "name": "observacao",
            "in": "path",
            "type": "string",
            "required": true,
            "description": "informar a observa\u00e7\u00e3o"
          },
          {
            "name": "telefone",
            "in": "path",
            "type": "string",
            "required": true,
            "description": "informar o telefone"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/Historico"
            }
          },
          "400": {
            "description": "N\u00e3o foi poss\u00edvel obter os valores da negocia\u00e7\u00e3o",
            "schema": {
              "$ref": "#/definitions/NaoPossivelHistorico"
            }
          }
        }
      }
    }
  },
