  "tags": [
    {
      "name": "Valida\u00e7\u00e3o",
      "description": "Valida\u00e7\u00e3o de acesso financiado"
    },
    {
      "name": "Dados",
      "description": "Retorno de dados do financiado"
    },
    {
      "name": "Negocia\u00e7\u00e3o",
      "description": "C\u00e1lculo e gera\u00e7\u00e3o de negocia\u00e7\u00e3o"
    },
    {
      "name": "Download",
      "description": "Downloads de arquivos"
    }
  ],
  "paths": {
    "/valida_documento/{cpf}/{data_nascimento}": {
      "get": {
        "tags": [
          "Valida\u00e7\u00e3o"
        ],
        "summary": "validaDocumento",
        "operationId": "validaDocumento",
        "description": "Informando o CPF e Data de Nascimento, ser\u00e1 feita a consulta em nossa base de dados com esses valores, e em caso positivo, ser\u00e3o retornados os dados deles.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "cpf",
            "in": "path",
            "type": "string",
            "required": true,
            "description": "informar o CPF do financiado"
          },
          {
            "name": "data_nascimento",
            "in": "path",
            "description": "informar a data de nascimento do financiado (yyyy-mm-dd)",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/PossuiContrato"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/contrato/{id_financiado}": {
      "get": {
        "tags": [
          "Dados"
        ],
        "summary": "dadosContrato",
        "operationId": "dadosContrato",
        "description": "Atrav\u00e9s de um id do financiado na nossa base, retorna informa\u00e7\u00f5es acerca de contratos que o mesmo possui em aberto em nossa base de dados.",
        "parameters": [
          {
            "name": "id_financiado",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do financiado"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/Contrato"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/boletos_financiado/{id_financiado}": {
      "get": {
        "tags": [
          "Dados"
        ],
        "summary": "boletosFinanciado",
        "operationId": "boletosFinanciado",
        "description": "Obt\u00e9m a listagem de boletos gerados em nossa base de dados para o financiado.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id_financiado",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do financiado"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/BoletosFinanciado"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/detalhes_divida/{id_contrato}": {
      "get": {
        "tags": [
          "Dados"
        ],
        "summary": "detalhesDivida",
        "operationId": "detalhesDivida",
        "description": "Obt\u00e9m dados referentes a d\u00edvida do contrato em quest\u00e3o, al\u00e9m valores de negocia\u00e7\u00e3o poss\u00edvel, tanto para quita\u00e7\u00e3o quanto para atualiza\u00e7\u00e3o.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id_contrato",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do contrato"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/DetalhesDivida"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/detalhes_divida_parcelado/{id_contrato}/{qntd_parcelas}/{valor_entrada}": {
      "get": {
        "tags": [
          "Dados"
        ],
        "summary": "detalhesDividaParelado",
        "operationId": "detalhesDividaParcelado",
        "description": "Obt\u00e9m dados referentes a d\u00edvida do contrato em quest\u00e3o, al\u00e9m valores de negocia\u00e7\u00e3o poss\u00edvel, tanto para quita\u00e7\u00e3o quanto para atualiza\u00e7\u00e3o.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id_contrato",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do contrato"
          },
          {
            "name": "qntd_parcelas",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar a quantidade de parcelas a ser calculado"
          },
          {
            "name": "valor_entrada",
            "in": "path",
            "type": "number",
            "required": true,
            "description": "informar o valor da entrada"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/DetalhesDividaParcelado"
            }
          },
          "400": {
            "description": "Exemplo de retorno mal sucedido",
            "schema": {
              "$ref": "#/definitions/DetalhesDividaParceladoErro"
            }
          }
        }
      }
    },
    "/listagem_quebras/{cpf}": {
      "get": {
        "tags": [
          "Dados"
        ],
        "summary": "listagemQuebras",
        "operationId": "listagemQuebras",
        "description": "Retorna id do contrato,  id do acordo e dados do(s) boleto(s) que est\u00e3o em atraso para o CPF do cliente informado na URL.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "cpf",
            "in": "path",
            "type": "string",
            "required": true,
            "description": "informar o CPF do contrato"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/ListagemQuebras"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/gera_negociacao/{opcao}/{id_contrato}": {
      "get": {
        "tags": [
          "Negocia\u00e7\u00e3o"
        ],
        "summary": "geraNegociacao",
        "operationId": "geraNegociacao",
        "description": "Atrav\u00e9s da op\u00e7\u00e3o escolhida (a=atualiza\u00e7\u00e3o ou q=quita\u00e7\u00e3o) \u00e9 gerado um acordo pa o contrato informado. O percentual de desconto aplicado \u00e9 de 80%.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "opcao",
            "in": "path",
            "type": "string",
            "required": true,
            "description": "informar a op\u00e7\u00e3o, a = atualiza\u00e7\u00e3o ou q = quita\u00e7\u00e3o"
          },
          {
            "name": "id_contrato",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do contrato para qual ser\u00e1 formalizado a negocia\u00e7\u00e3o"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/GeraNegociacao"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/gera_negociacao_parcelado/{id_contrato}/{qntd_parcelas}/{valor_entrada}": {
      "get": {
        "tags": [
          "Negocia\u00e7\u00e3o"
        ],
        "summary": "geraNegociacaoParcelada",
        "operationId": "geraNegociacaoParcelada",
        "description": "Atrav\u00e9s da op\u00e7\u00e3o escolhida (a=atualiza\u00e7\u00e3o ou q=quita\u00e7\u00e3o) \u00e9 gerado um acordo pa o contrato informado. O percentual de desconto aplicado \u00e9 de 80%.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id_contrato",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do contrato para qual ser\u00e1 formalizado a negocia\u00e7\u00e3o"
          },
          {
            "name": "qntd_parcelas",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar a quantidade de parcelas a ser calculado"
          },
          {
            "name": "valor_entrada",
            "in": "path",
            "type": "number",
            "required": true,
            "description": "informar o valor da entrada (primeira parcela)"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/GeraNegociacaoParcelada"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/revalida_boleto/{id_boleto}": {
      "get": {
        "tags": [
          "Negocia\u00e7\u00e3o"
        ],
        "summary": "revalidaBoleto",
        "operationId": "revalidaBoleto",
        "description": "Ao receber o ID de um boleto em atraso ele o revalida. Em casos Ita\u00fa (1 a 14 dias em atraso), ele cancela o boleto e emite outro com uma nova data de vencimento (D+2). Em casos BMG (1 a 20 dias em atraso), ele retorna os dados do boleto atual, mantendo a data de vencimento inicial.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id_boleto",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do boleto"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/RevalidaBoleto"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/proposta/{cpf}/{valor}/{data}": {
      "get": {
        "tags": [
          "Negocia\u00e7\u00e3o"
        ],
        "summary": "proposta",
        "operationId": "proposta",
        "description": "Recebe o valor e a data de pagamento ofertada pelo cliente, identificado por seu CPF, o qual \u00e9 armazenado em um arquivo, que ser\u00e1 disponibilizado \u00e0 opera\u00e7\u00e3o para an\u00e1lise e contato com o mesmo.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "cpf",
            "in": "path",
            "type": "string",
            "required": true,
            "description": "informar o CPF do financiado"
          },
          {
            "name": "valor",
            "in": "path",
            "type": "number",
            "required": true,
            "description": "informar o valor da proposta"
          },
          {
            "name": "data",
            "in": "path",
            "type": "string",
            "required": true,
            "description": "informar a data poss\u00edvel para pagamento"
          }
        ],
        "responses": {
          "200": {
            "description": "Exemplo de retorno bem sucedido",
            "schema": {
              "$ref": "#/definitions/Proposta"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    },
    "/download_boleto/{id_boleto}": {
      "get": {
        "tags": [
          "Download"
        ],
        "summary": "downloadBoleto",
        "operationId": "downloadBoleto",
        "description": "Retorna o boleto em formato PDF. O CPF do financiado \u00e9 requerido ao abrir o arquivo.",
        "produces": [
          "application/pdf"
        ],
        "parameters": [
          {
            "name": "id_boleto",
            "in": "path",
            "type": "integer",
            "required": true,
            "description": "informar o ID do boleto"
          }
        ],
        "responses": {
          "200": {
            "description": "Returna o arquivo em PDF",
            "schema": {
              "type": "file"
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      }
    }
  },
  "definitions": {
    "PossuiContrato": {
      "type": "object",
      "properties": {
        "sucesso": {
          "type": "boolean",
          "example": true
        },
