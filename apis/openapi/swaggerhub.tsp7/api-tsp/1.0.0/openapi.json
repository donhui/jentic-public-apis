            "description": "bad input parameter"
          }
        },
        "tags": [
          "Dados"
        ],
        "description": "Obtém a listagem de boletos gerados em nossa base de dados para o financiado.",
        "operationId": "boletosFinanciado",
        "summary": "boletosFinanciado"
      }
    },
    "/contrato/{id_financiado}": {
      "get": {
        "parameters": [
