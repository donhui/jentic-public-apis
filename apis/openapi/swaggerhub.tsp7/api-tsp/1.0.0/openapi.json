          },
          "400": {
            "description": "bad input parameter"
          }
        },
        "tags": [
          "Negociação"
        ],
        "description": "Através da opção escolhida (a=atualização ou q=quitação) é gerado um acordo pa o contrato informado. O percentual de desconto aplicado é de 80%.",
        "operationId": "geraNegociacao",
        "summary": "geraNegociacao"
      }
    },
