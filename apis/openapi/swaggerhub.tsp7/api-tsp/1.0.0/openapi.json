                }
              }
            },
            "description": "Exemplo de retorno bem sucedido"
          },
          "400": {
            "description": "bad input parameter"
          }
        },
        "tags": [
          "Validação"
        ],
        "description": "Informando o CPF e Data de Nascimento, será feita a consulta em nossa base de dados com esses valores, e em caso positivo, serão retornados os dados deles.",
        "operationId": "validaDocumento",
        "summary": "validaDocumento"
      }
    }
