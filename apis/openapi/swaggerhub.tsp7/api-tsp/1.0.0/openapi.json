          },
          "400": {
            "description": "bad input parameter"
          }
        },
        "tags": [
          "Negociação"
        ],
        "description": "Recebe o valor e a data de pagamento ofertada pelo cliente, identificado por seu CPF, o qual é armazenado em um arquivo, que será disponibilizado à operação para análise e contato com o mesmo.",
        "operationId": "proposta",
        "summary": "proposta"
      }
    },
    "/revalida_boleto/{id_boleto}": {
      "get": {
        "parameters": [
          {
            "description": "informar o ID do boleto",
            "in": "path",
            "name": "id_boleto",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RevalidaBoleto"
                }
              }
            },
            "description": "Exemplo de retorno bem sucedido"
          },
          "400": {
            "description": "bad input parameter"
          }
        },
        "tags": [
          "Negociação"
        ],
        "description": "Ao receber o ID de um boleto em atraso ele o revalida. Em casos Itaú (1 a 14 dias em atraso), ele cancela o boleto e emite outro com uma nova data de vencimento (D+2). Em casos BMG (1 a 20 dias em atraso), ele retorna os dados do boleto atual, mantendo a data de vencimento inicial.",
        "operationId": "revalidaBoleto",
        "summary": "revalidaBoleto"
      }
    },
