    "/api/v2/ml-scribe/open-api/templates/document-templates": {
      "get": {
        "tags": ["Heidi API"],
        "summary": "List Document Templates",
        "description": "Get templates for document generation.\n\nIf no user provided, specialty_id will be used in demo session.\nBoth of user and specialty_id can be none: there's no specialty selected in demo.\n\nall users: return all templates (note structure + document).\n\nReturns:\n    OpenAPIGetTemplatesResponseV2: templates for document gen",
        "operationId": "list_document_templates_api_v2_ml_scribe_open_api_templates_document_templates_get",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "specialty_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "example": "5eb7cf5a86d9755df3a6c593"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Specialty Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
