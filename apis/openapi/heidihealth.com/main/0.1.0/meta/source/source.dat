  "components": {
    "schemas": {
      "apis__v2__open_api__jwt_schema__GenerateJWTResponse": {
        "properties": {
          "token": {
            "type": "string",
            "title": "Token"
          },
          "expiration_time": {
            "type": "string",
            "format": "date-time",
            "title": "Expiration Time"
          }
        },
        "type": "object",
        "required": ["token", "expiration_time"],
        "title": "GenerateJWTResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      },
      "CreateSessionRequest": {
        "properties": {
          "timezone": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timezone"
          }
        },
        "type": "object",
        "title": "CreateSessionRequest"
      },
      "SessionStatus": {
        "type": "string",
        "enum": ["EMPTY", "DRAFT", "REVIEWED", "APPROVED", "SENT"],
        "title": "SessionStatus",
        "description": "Represents the review workflow status of a session's letter/document."
      },
      "apis__v2__open_api__sessions__sessions_schema__CreateSessionResponse": {
        "properties": {
          "session_id": {
            "type": "string",
            "title": "Session Id"
          },
          "is_consent": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Is Consent",
            "default": false
          }
        },
        "type": "object",
        "required": ["session_id"],
        "title": "CreateSessionResponse"
      },
      "OpenAPISessionResponseV2": {
        "properties": {
          "sessions": {
            "items": {
              "$ref": "#/components/schemas/SimpleSessionViewV2"
            },
            "type": "array",
            "title": "Sessions"
