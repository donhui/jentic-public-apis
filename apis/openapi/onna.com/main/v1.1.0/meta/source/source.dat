    "/resources/files": {
      "post": {
        "tags": [
          "Resources: Files"
        ],
        "summary": "Create File",
        "operationId": "ResourcesFiles_createNewFile",
        "security": [
          {
            "OAuth2": []
          }
        ],
        "description": "Create a file resource.",
