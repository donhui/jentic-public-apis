{
  "openapi": "3.0.3",
  "info": {
    "title": "Envoke API",
    "description": "Envoke REST API for managing contacts, tags, subscriptions, messages, and email reporting. Supports contact CRUD, message creation and sending, and email activity metrics.",
    "version": "1.0.0",
    "x-jentic-source-url": "http://support.envoke.com/api/api-overview"
  },
  "servers": [
    {
      "url": "https://e1.envoke.com",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/v1/contacts": {
      "get": {
        "operationId": "listcontacts",
        "summary": "List contacts",
        "description": "Retrieve a list of contacts with optional filtering by email.",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "description": "Filter by email address",
            "required": false,
            "schema": {
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contacts retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Contact"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createcontact",
        "summary": "Create a contact",
        "description": "Create a new contact in Envoke.",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "upsert",
            "in": "query",
            "description": "Set to 1 to upsert (create or update) the contact",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactMutationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "patch": {
        "operationId": "updatecontact",
        "summary": "Update a contact",
        "description": "Update an existing contact in Envoke.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactMutationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/contacts/{id}": {
      "get": {
        "operationId": "getcontact",
        "summary": "Get a single contact by ID",
        "description": "Retrieve a single contact by their ID.",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/contacts/import/upload/sync": {
      "post": {
        "operationId": "uploadcsvforsync",
        "summary": "CSV file upload for import sync",
        "description": "Upload a CSV file for contact import synchronization.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "CSV file for import"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/interests": {
      "get": {
        "operationId": "listtags",
        "summary": "List tags",
        "description": "Retrieve a list of tags/interests. Filter by group name or by type=subscription for subscriptions.",
        "tags": [
          "Tags"
        ],
        "parameters": [
          {
            "name": "group",
            "in": "query",
            "description": "Filter by group name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filter by type (e.g., 'subscription')",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tags retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tag"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/interests/{id}": {
      "get": {
        "operationId": "gettag",
        "summary": "Get a single tag by ID",
        "description": "Retrieve a single tag or subscription by ID.",
        "tags": [
          "Tags"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tag retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Tag"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/customfields": {
      "get": {
        "operationId": "listcustomfields",
        "summary": "List custom fields",
        "description": "Retrieve all custom fields and their IDs.",
        "tags": [
          "Custom Fields"
        ],
        "responses": {
          "200": {
            "description": "Custom fields retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/messages": {
      "get": {
        "operationId": "listmessages",
        "summary": "List messages",
        "description": "Retrieve a list of messages.",
        "tags": [
          "Messages"
        ],
        "responses": {
          "200": {
            "description": "Messages retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Message"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createmessage",
        "summary": "Create a message",
        "description": "Create a new message.",
        "tags": [
          "Messages"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MessageInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageMutationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/messages/{id}": {
      "get": {
        "operationId": "getmessage",
        "summary": "Get a single message by ID",
        "description": "Retrieve a single message by its ID.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "patch": {
        "operationId": "updatemessage",
        "summary": "Update a message",
        "description": "Update an existing message.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MessageInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageMutationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/messages/{id}/send": {
      "post": {
        "operationId": "sendmessage",
        "summary": "Send a message",
        "description": "Schedule a message for sending.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message scheduled for send",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/messages/{id}/cancel": {
      "post": {
        "operationId": "cancelmessage",
        "summary": "Cancel a scheduled message",
        "description": "Cancel a message that has been scheduled for sending.",
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message cancelled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/send": {
      "post": {
        "operationId": "sendtransactionalemail",
        "summary": "Send a transactional email",
        "description": "Send a transactional email to a contact or list.",
        "tags": [
          "Send"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransactionalSendInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message is sending",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionalSendResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/reports/emailActivityMetrics": {
      "get": {
        "operationId": "getemailactivitymetrics",
        "summary": "Get email activity metrics",
        "description": "Retrieve email campaign reports. Filter by message_id, date range, recipient tag, or recipient segment.",
        "tags": [
          "Reports"
        ],
        "parameters": [
          {
            "name": "message_id",
            "in": "query",
            "description": "Filter by message ID",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "description": "Start date (YYYY-MM-DD)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "description": "End date (YYYY-MM-DD)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "segment",
            "in": "query",
            "description": "Filter by segment (e.g., 'iid|TAG_ID' or 'fid|SEGMENT_ID')",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Email activity metrics retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EmailActivityMetric"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication. Obtain credentials from the Integrations section of Account Settings."
      }
    },
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "remote_id": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "ContactInput": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "title": {
            "type": "string"
          },
          "remote_id": {
            "type": "string"
          }
        }
      },
      "ContactMutationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "result_data": {
            "$ref": "#/components/schemas/Contact"
          }
        }
      },
      "FileUploadResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "result_data": {
            "type": "object",
            "properties": {
              "filepath": {
                "type": "string"
              }
            }
          },
          "result_text": {
            "type": "string"
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "interest",
              "subscription"
            ]
          },
          "name": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "external_id": {
            "type": "string"
          },
          "preview_url": {
            "type": "string",
            "format": "uri"
          },
          "subject": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "MessageInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "html_body": {
            "type": "string"
          },
          "text_body": {
            "type": "string"
          }
        }
      },
      "MessageMutationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "result_text": {
            "type": "string"
          },
          "result_data": {
            "$ref": "#/components/schemas/Message"
          }
        }
      },
      "SendMessageInput": {
        "type": "object",
        "properties": {
          "send_time": {
            "type": "string",
            "format": "date-time"
          },
          "recipients": {
            "type": "object",
            "properties": {
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "segments": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SendMessageResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "result_text": {
            "type": "string"
          },
          "result_data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "send_time": {
                "type": "string"
              },
              "recipients": {
                "type": "object"
              }
            }
          }
        }
      },
      "TransactionalSendInput": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "format": "email"
          },
          "message_id": {
            "type": "string"
          },
          "merge_fields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "TransactionalSendResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "result_text": {
            "type": "string"
          },
          "result_data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "new_contacts_created": {
                "type": "integer"
              },
              "summary": {
                "type": "object",
                "properties": {
                  "total_selected": {
                    "type": "integer"
                  },
                  "emails_to_be_sent": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        }
      },
      "EmailActivityMetric": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "string"
          },
          "message_name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "sends": {
            "type": "string"
          },
          "opens": {
            "type": "string"
          },
          "clicks": {
            "type": "string"
          },
          "bounces": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Contacts",
      "description": "Operations related to Contacts"
    },
    {
      "name": "Custom Fields",
      "description": "Operations related to Custom Fields"
    },
    {
      "name": "Messages",
      "description": "Operations related to Messages"
    },
    {
      "name": "Reports",
      "description": "Operations related to Reports"
    },
    {
      "name": "Send",
      "description": "Operations related to Send"
    },
    {
      "name": "Tags",
      "description": "Operations related to Tags"
    }
  ]
}