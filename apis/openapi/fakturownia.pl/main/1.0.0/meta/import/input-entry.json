  "components": {
    "parameters": {
      "ApiToken": {
        "name": "api_token",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "API authentication token"
      },
      "ResourceId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Resource ID"
      }
    },
    "schemas": {
      "Invoice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "number": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "description": "Invoice type (vat, proforma, estimate, etc.)"
          },
          "status": {
            "type": "string"
          },
          "issue_date": {
            "type": "string",
            "format": "date"
          },
          "sell_date": {
            "type": "string",
            "format": "date"
          },
          "payment_to": {
            "type": "string",
            "format": "date"
          },
          "seller_name": {
            "type": "string"
          },
          "buyer_name": {
            "type": "string"
          },
          "buyer_tax_no": {
            "type": "string"
          },
          "client_id": {
            "type": "integer"
          },
          "total_price_gross": {
            "type": "string"
          },
          "total_price_net": {
            "type": "string"
          },
          "tax_amount": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "positions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvoicePosition"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "InvoicePosition": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "tax": {
            "type": "string"
          },
          "total_price_gross": {
            "type": "string"
          },
          "total_price_net": {
            "type": "string"
          },
          "unit_price_gross": {
            "type": "string"
          },
          "unit_price_net": {
            "type": "string"
          }
        }
      },
      "InvoiceCreateRequest": {
        "type": "object",
        "properties": {
