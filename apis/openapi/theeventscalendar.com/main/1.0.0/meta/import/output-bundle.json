{
  "openapi": "3.0.0",
  "info": {
    "title": "Event Tickets REST API",
    "description": "Event Tickets REST API allows accessing ticket information easily and conveniently.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.theeventscalendar.com/rest-endpoints/"
  },
  "servers": [
    {
      "url": "https://docs.theeventscalendar.com/rest-site/index.php?rest_route=/tribe/tickets/v1/"
    }
  ],
  "paths": {
    "/tickets/{id}": {
      "get": {
        "summary": "Returns a single ticket data",
        "parameters": [
          {
            "in": "path",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "The ticket post ID",
            "required": true,
            "name": "id"
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the data of the ticket with the specified post ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticket"
                }
              }
            }
          },
          "400": {
            "description": "The ticket post ID is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "The ticket with the specified ID is not accessible.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "A ticket with the specified ID does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/tickets": {
      "get": {
        "parameters": [
          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "The page of results to return; defaults to 1",
            "required": false,
            "name": "page"
          },
          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": "10"
            },
            "description": "How many tickets to return per results page; defaults to posts_per_page.",
            "required": false,
            "name": "per_page"
          },
          {
            "in": "query",
            "schema": {
              "type": "string",
              "default": false
            },
            "description": "Limit results to tickets containing the specified string in the title or description.",
            "required": false,
            "name": "search"
          },
          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "Offset the results by a specific number of items.",
            "required": false,
            "name": "offset"
          },
          {
            "in": "query",
            "schema": {
              "type": "string",
              "default": false
            },
            "description": "Sort results in ASC or DESC order. Defaults to ASC.",
            "required": false,
            "name": "order"
          },
          {
            "in": "query",
            "schema": {
              "type": "string",
              "default": false
            },
            "description": "Order the results by one of date, relevance, id, include, title, or slug; defaults to title.",
            "required": false,
            "name": "orderby"
          },
          {
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Limit results to tickets that have or do not have capacity currently available.",
            "required": false,
            "name": "is_available"
          },
          {
            "in": "query",
            "schema": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "string"
                }
              ]
            },
            "description": "Limit results to tickets provided by one of the providers specified in the CSV list or array; defaults to all available.",
            "required": false,
            "name": "provider"
          },
          {
            "in": "query",
            "schema": {
              "type": "string",
              "default": false
            },
            "description": "Limit results to tickets created after or on the specified UTC date or timestamp.",
            "required": false,
            "name": "after"
          },
          {
            "in": "query",
            "schema": {
              "type": "string",
              "default": false
            },
            "description": "Limit results to tickets created before or on the specified UTC date or timestamp.",
            "required": false,
            "name": "before"
          },
          {
            "in": "query",
            "schema": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  }
                },
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "description": "Limit results to a specific CSV list or array of ticket IDs.",
            "required": false,
            "name": "include"
          },
          {
            "in": "query",
            "schema": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  }
                },
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "description": "Exclude a specific CSV list or array of ticket IDs from the results.",
            "required": false,
            "name": "exclude"
          },
          {
            "in": "query",
            "schema": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  }
                },
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "description": "Limit results to tickets that are assigned to one of the posts specified in the CSV list or array.",
            "required": false,
            "name": "include_post"
          },
          {
            "in": "query",
            "schema": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  }
                },
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "description": "Limit results to tickets that are not assigned to any of the posts specified in the CSV list or array.",
            "required": false,
            "name": "exclude_post"
          },
          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "Limit results to tickets that have at least this number or attendees.",
            "required": false,
            "name": "attendees_min"
          },
          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "Limit results to tickets that have at most this number of attendees.",
            "required": false,
            "name": "attendees_max"
          },
          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "Limit results to tickets that have at most this number of checked-in attendee.",
            "required": false,
            "name": "checkedin_min"
          },
          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "Limit results to tickets that have at least this number of checked-in attendees.",
            "required": false,
            "name": "checkedin_max"
          },
          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "Limit results to tickets that have at least this capacity.",
            "required": false,
            "name": "capacity_min"
          },
          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "Limit results to tickets that have at most this capacity.",
            "required": false,
            "name": "capacity_max"
          },
          {
            "in": "query",
            "schema": {
              "type": "string",
              "default": false
            },
            "description": "Limit results to tickets that will be available at or after the specified UTC date (parseable by strtotime) or timestamp.",
            "required": false,
            "name": "available_from"
          },
          {
            "in": "query",
            "schema": {
              "type": "string",
              "default": false
            },
            "description": "Limit results to tickets that will be available up to the specified UTC date (parseable by strtotime) or timestamp.",
            "required": false,
            "name": "available_until"
          },
          {
            "in": "query",
            "schema": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "string"
                }
              ]
            },
            "description": "Limit results to tickets assigned to posts that are in one of the post statuses specified in the CSV list or array; defaults to publish.",
            "required": false,
            "name": "post_status"
          },
          {
            "in": "query",
            "schema": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "string"
                }
              ]
            },
            "description": "Limit results to tickets that are in one of post statuses specified in the CSV list or array; defaults to publish.",
            "required": false,
            "name": "status"
          },
          {
            "in": "query",
            "schema": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "string"
                }
              ]
            },
            "description": "Limit results to tickets priced in one of the 3-letter currency codes specified in the CSV list or array.",
            "required": false,
            "name": "currency"
          },
          {
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Limit results to tickets that provide attendees the possibility to fill in additional information or not; requires ET+.",
            "required": false,
            "name": "attendee_information_available"
          }
        ],
        "responses": {
          "200": {
            "description": "Returns all the tickets matching the search criteria",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "rest_url": {
                      "type": "string",
                      "format": "uri",
                      "description": "This results page REST URL"
                    },
                    "total": {
                      "type": "integer",
                      "description": "The total number of results across all pages"
                    },
                    "total_pages": {
                      "type": "integer",
                      "description": "The total number of result pages matching the search criteria"
                    },
                    "tickets": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Ticket"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "One or more of the specified query variables has a bad format",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "The requested page was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
