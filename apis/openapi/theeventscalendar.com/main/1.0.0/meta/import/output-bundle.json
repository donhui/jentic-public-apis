          {
            "in": "query",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "The post ID",
            "required": false,
            "name": "post_id"
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the list of tickets in the cart",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tickets": {
                      "type": "array",
                      "description": "The list of tickets and their quantities in the cart"
                    },
                    "meta": {
                      "type": "array",
                      "description": "The list of meta for each ticket item in the cart"
                    },
                    "cart_url": {
                      "type": "string",
                      "description": "The provider cart URL"
                    },
                    "checkout_url": {
                      "type": "string",
                      "description": "The provider checkout URL"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "The post does not have any tickets"
          }
        }
      },
      "post": {
        "consumes": [
          "application/x-www-form-urlencoded"
        ],
        "parameters": [
          {
            "in": "formData",
            "schema": {
              "type": "string",
              "default": false
            },
            "description": "The cart provider",
            "required": true,
            "name": "provider"
          },
          {
            "in": "formData",
            "schema": {
              "type": "array",
              "default": false
            },
            "description": "List of tickets with their ID and quantity",
            "required": false,
            "name": "tickets"
          },
          {
            "in": "formData",
            "schema": {
              "type": "array",
              "default": false
            },
            "description": "List of meta for each ticket to be saved for Attendee Registration",
            "required": false,
            "name": "meta"
          },
          {
            "in": "formData",
            "schema": {
              "type": "integer",
              "default": false
            },
            "description": "The post ID",
            "required": false,
            "name": "post_id"
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the updated list of tickets in the cart and cart details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tickets": {
                      "type": "array",
                      "description": "The list of tickets and their quantities in the cart"
                    },
                    "meta": {
                      "type": "array",
                      "description": "The list of meta for each ticket item in the cart"
                    },
                    "cart_url": {
                      "type": "string",
                      "description": "The provider cart URL"
                    },
                    "checkout_url": {
                      "type": "string",
                      "description": "The provider checkout URL"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "The post ID is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "403": {
            "description": "The post does not have any tickets"
          }
        }
      }
    },
    "/doc": {
      "get": {
        "responses": {
          "200": {
            "description": "Returns the documentation for Event Tickets REST API in Swagger consumable format."
          }
        }
      }
    }
