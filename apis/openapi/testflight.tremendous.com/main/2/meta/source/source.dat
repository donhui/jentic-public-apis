                                  "MXN",
                                  "MYR",
                                  "MZN",
                                  "NAD",
                                  "NGN",
                                  "NIO",
                                  "NOK",
                                  "NPR",
                                  "NZD",
                                  "OMR",
                                  "PAB",
                                  "PEN",
                                  "PHP",
                                  "PKR",
                                  "PLN",
                                  "PYG",
                                  "QAR",
                                  "RON",
                                  "RSD",
                                  "RUB",
                                  "RWF",
