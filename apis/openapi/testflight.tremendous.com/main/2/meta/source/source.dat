            "example": "US,UK"
          },
          {
            "description": "Comma-separated list of [currency codes](https://www.iban.com/currency-codes), used to only retrieve products available in the provided currencies",
            "name": "currency",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "example": "USD,EUR"
          }
        ],
        "responses": {
          "200": {
            "description": "List of available products.",
            "content": {
