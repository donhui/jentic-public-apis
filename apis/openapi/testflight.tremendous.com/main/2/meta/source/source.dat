    "/products/{id}": {
      "get": {
        "tags": [
          "Products"
        ],
        "summary": "Retrieve product",
        "operationId": "Products_getById",
        "description": "Retrieve a product, identified by the given `id` in the URL\n",
        "parameters": [
          {
            "description": "ID of the product that should be retrieved",
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "[A-Z0-9]{4,20}",
              "example": "SOMEIDSOMEID"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Requested product",
