{
  "openapi": "3.0.0",
  "info": {
    "description": "Link shortener service API",
    "version": "1.0.0",
    "title": "Azul Link Shortener",
    "contact": {
      "email": "ant@kaula.ru"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/kettari/azul/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "authorized",
      "description": "Authorized requests"
    },
    {
      "name": "anonymous",
      "description": "Public calls available to everyone"
    }
  ],
  "paths": {
    "/api/v1/shortcut": {
      "post": {
        "tags": [
          "authorized"
        ],
        "summary": "Creates new short link",
        "security": [
          {
            "apiKeyAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UrlCollection"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Shortcut or shortucts successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UrlCollection"
                },
                "example": [
                  {
                    "url": "http://example.com/first_link",
                    "type": "permanent",
                    "expirationDate": null,
                    "title": "Some human-readable URL description",
                    "shortcut": "https://kau.la/yF2"
                  },
                  {
                    "url": "http://example.com/second_link",
                    "type": "temporary",
                    "expirationDate": "2019-12-03T00:00:00Z",
                    "title": "Some human-readable URL description",
                    "shortcut": "https://kau.la/1Kk"
                  }
                ]
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/api/v1/stats": {
      "get": {
        "tags": [
          "authorized"
        ],
        "summary": "Returns statistics for the service",
        "security": [
          {
            "apiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Statistics for the service",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Stats"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/{shortcut}": {
      "servers": [
        {
          "description": "SwaggerHub API Auto Mocking",
          "url": "https://virtserver.swaggerhub.com/kettari/azul/"
        }
      ],
      "get": {
        "tags": [
          "anonymous"
        ],
        "summary": "Redirects from shortcut to original URL",
        "parameters": [
          {
            "name": "shortcut",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^[0-9a-zA-Z-_]{3,100}$"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "URL by shortcut found, redirecting user to the original URL\n"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "410": {
            "$ref": "#/components/responses/Gone"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UrlCollection": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Url"
        },
        "minItems": 1
      },
      "Url": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "example": "http://example.com/some-string",
            "description": "URL to be shortened"
          },
          "type": {
            "type": "string",
            "pattern": "^permanent|temporary$",
            "default": "permanent",
            "example": "temporary",
            "description": "Type of the link -- permanent or temporary:\n  * Permanent link has no expiration date\n  * Temporary link will expire on expirationDate\n  and will return HTTP 410 Gone since then\n"
          },
          "expirationDate": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "default": null,
            "example": "2019-04-21T14:00:00Z"
          },
          "shortcut": {
            "type": "string",
            "pattern": "^[0-9a-zA-Z-_]{3,100}$",
            "example": "feedback-survey",
            "description": "Desirable shortcut to be assigned to the URL. If shortcut is already used, a HTTP 409 Conflict will be returned\n"
          },
          "shortcutUrl": {
            "type": "string",
            "nullable": true,
            "example": "https://kau.la/123",
            "description": "Ready-to-use shortcut URL\n"
          }
        },
        "required": [
          "url"
        ]
      },
      "Error": {
        "type": "object",
        "properties": {
          "errorCode": {
            "type": "integer"
          },
          "errorDescription": {
            "type": "string"
          }
        },
        "required": [
          "errorCode"
        ]
      },
      "Stats": {
        "type": "object",
        "properties": {
          "serverDate": {
            "type": "string",
            "format": "date-time",
            "example": "2019-03-28T18:22:19Z"
          },
          "last24hours": {
            "$ref": "#/components/schemas/StatsBlock"
          },
          "last30days": {
            "$ref": "#/components/schemas/StatsBlock"
          }
        },
        "required": [
          "serverDate",
          "last24hours",
          "last30days"
        ]
      },
      "StatsBlock": {
        "type": "object",
        "properties": {
          "shortcutsCreated": {
            "type": "integer",
            "format": "int32"
          },
          "shortcutsRequestsTotal": {
            "type": "integer",
            "format": "int32"
          }
        },
        "required": [
          "shortcutsCreated",
          "shortcutsRequestsTotal"
        ]
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request. For example, 'type' is specified as 'temporary' and 'expirationDate' is null or invalid. Also, JSON can be broken in the request body\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized. Provide valid apiKey",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden. Wrong apiKey provided",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "The specified resource was not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Conflict": {
        "description": "Desirable shortcut or shortcuts already exist",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Gone": {
        "description": "Link was present but is no longer available and will not be available again\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "apiKey"
      }
    }
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/kettari/azul/1.0.0"
    }
  ]
}