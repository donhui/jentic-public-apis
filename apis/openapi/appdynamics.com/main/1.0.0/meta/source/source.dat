    "/controller/rest/applications/{appId}/metric-data": {
      "get": {
        "summary": "Retrieve metric data for an application",
        "operationId": "getMetricData",
        "parameters": [
          {
            "name": "appId",
            "in": "path",
            "required": true,
            "description": "Application ID or name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "metric-path",
            "in": "query",
            "required": true,
            "description": "Metric path (e.g., Overall Application Performance|*|Average Response Time (ms))",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rollup",
            "in": "query",
            "required": false,
            "description": "Whether to rollup metric values",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "output",
            "in": "query",
            "required": false,
            "description": "Output format (JSON or XML)",
            "schema": {
              "type": "string",
              "enum": [
                "JSON",
                "XML"
              ],
              "default": "JSON"
            }
          },
          {
            "name": "time-range-type",
            "in": "query",
            "required": false,
            "description": "Time range type",
            "schema": {
              "type": "string",
              "enum": [
                "BEFORE_NOW",
                "BEFORE_TIME",
                "AFTER_TIME",
                "BETWEEN_TIMES"
              ]
            }
          },
          {
            "name": "duration-in-mins",
            "in": "query",
            "required": false,
            "description": "Duration in minutes (for BEFORE_NOW)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "start-time",
            "in": "query",
            "required": false,
            "description": "Start time in Unix epoch milliseconds",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "end-time",
            "in": "query",
            "required": false,
            "description": "End time in Unix epoch milliseconds",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Metric data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Classic_MetricData"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Classic_MetricData"
                }
              }
            }
          }
        },
        "tags": [
          "Classic-Metrics"
        ],
        "security": [
          {
            "basicAuth": []
          },
          {
            "oauthToken": []
          }
        ]
      }
    },
