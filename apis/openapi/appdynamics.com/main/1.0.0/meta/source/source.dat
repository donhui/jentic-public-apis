          "Classic-ServerMonitoring"
        ],
        "security": [
          {
            "basicAuth": []
          },
          {
            "oauthToken": []
          }
        ]
      }
    },
    "/controller/sim/v2/user/machines/{machineId}/containers": {
      "get": {
        "summary": "List containers on a machine",
        "operationId": "getMachineContainers",
        "parameters": [
          {
            "name": "machineId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Machine ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of containers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Classic-ServerMonitoring"
        ],
        "security": [
          {
            "basicAuth": []
          },
          {
            "oauthToken": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token authentication for cloud APIs"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication (user@account:password) for classic controller API"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key authentication for cloud APIs"
      },
      "oauthToken": {
        "type": "oauth2",
        "description": "OAuth2 token for classic controller API",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://{controller_host}/controller/api/oauth/access_token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "Conn_Description": {
        "required": [
          "displayName"
        ],
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "Name of the connection or configuration",
            "example": "AWS dev"
          },
          "description": {
            "type": "string",
            "description": "Description for this connection or configuration",
            "example": "AWS EC2 configuration"
          }
        }
      },
      "Conn_BaseEntity": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_Description"
          },
          {
            "required": [
              "type"
            ],
            "type": "object",
            "properties": {
              "type": {
                "$ref": "#/components/schemas/Conn_ProviderType"
              }
            },
            "discriminator": {
              "propertyName": "type"
            }
          }
        ]
      },
      "Conn_ConnectionAccessType": {
        "type": "string",
        "description": "Connection type discriminator",
        "default": "role_delegation",
        "enum": [
          "role_delegation",
          "access_key"
        ]
      },
      "Conn_AccessType": {
        "required": [
          "accessType"
        ],
        "type": "object",
        "properties": {
          "accessType": {
            "$ref": "#/components/schemas/Conn_ConnectionAccessType"
          }
        },
        "discriminator": {
          "propertyName": "accessType",
          "mapping": {
            "role_delegation": "#/components/schemas/AWSRoleDelegationCreationDetails",
            "access_key": "#/components/schemas/AWSAccessKeyDetails"
          }
        }
      },
      "Conn_AWSAccount": {
        "type": "string",
        "example": "258762700219"
      },
      "Conn_AWSRoleDelegationCreationDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_AccessType"
          },
          {
            "required": [
              "accountId"
            ],
            "type": "object",
            "properties": {
              "accountId": {
                "$ref": "#/components/schemas/Conn_AWSAccount"
              }
            }
          }
        ]
      },
      "Conn_AWSRoleDelegationUpdateDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_AWSRoleDelegationCreationDetails"
          },
          {
            "required": [
              "roleName"
            ],
            "type": "object",
            "properties": {
              "roleName": {
                "type": "string",
                "example": "example-role-name-update"
              }
            }
          }
        ]
      },
      "Conn_AWSAccessKeyDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_AccessType"
          },
          {
            "required": [
              "accessKeyId",
              "secretAccessKey"
            ],
            "type": "object",
            "properties": {
              "accessKeyId": {
                "type": "string",
                "description": "AWS Access keys are long-term credentials for an AWS IAM user, or account root user. The access key ID is one of two access keys needed to authenticate to AWS. The other is a secret access key. You need access keys to make programmatic calls using the AWS CLI, AWS Tools, or PowerShell.",
                "example": "AKBATYTCJY7XPKGABY5L"
              },
              "secretAccessKey": {
                "type": "string",
                "description": "The secret access key is one of two access keys needed to authenticate to AWS. The other is an access key ID. The secret access key is only available once, when you create it. Download the generated secret access key and save in a secure location. If the secret access key is lost or deleted, you must create a new one. You need access keys to make programmatic calls using the AWS CLI, AWS Tools, or PowerShell.",
                "format": "password",
                "example": "7ccw68gBKMMXUdXBut+7qC9CCr1brotxD5ClcGGE"
              }
            }
          }
        ]
      },
      "Conn_AzureBaseDetails": {
        "required": [
          "clientId",
          "clientSecret"
        ],
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string",
            "example": "17760330-4ecd-47d5-818b-40308d3e67d1"
          },
          "clientSecret": {
            "type": "string",
            "format": "password",
            "example": "k33C_.5b0VrXSiQIf1t-c--p18~Ea_L~2H"
          }
        }
      },
      "Conn_AzureDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_AzureBaseDetails"
          },
          {
            "required": [
              "clientId",
              "clientSecret",
              "subscriptionId",
              "tenantId"
            ],
            "type": "object",
            "properties": {
              "clientId": {
                "type": "string",
                "description": "Client IDs, also known as Application IDs, are long-term credentials for an Azure user, or account root user. The Client ID is one of three properties needed to authenticate to Azure, the other two being Client Secret and Tenant (Directory) ID",
                "example": "17760330-4ecd-47d5-818b-40308d3e67d1"
              },
              "clientSecret": {
                "type": "string",
                "description": "A Client Secret allows an Azure application to provide its identity when requesting an access token. The Client Secret is one of three properties needed to authenticate to Azure, the other two being Client ID (Application ID) and Tenant (Directory) ID",
                "format": "password",
                "example": "k33C_.5b0VrXSiQIf1t-c--p18~Ea_L~2H"
              },
              "tenantId": {
                "type": "string",
                "description": "The Azure AD Tenant (Directory) IDis one of three properties needed to authenticate to Azure. The other two are Client Secret and Client ID (Application ID).",
                "example": "5ae1af62-9505-4097-a69a-c1553ef7840e"
              },
              "subscriptionId": {
                "type": "string",
                "description": "Specify a GUID Subscription ID to monitor. If monitoring all subscriptions, do not specify a Subscription ID.",
                "example": "00000000-0000-0000-0000-000000000000"
              }
            }
          }
        ]
      },
      "Conn_GCPConnectionAccessType": {
        "type": "string",
        "description": "Connection type discriminator",
        "enum": [
          "service_account_key"
        ]
      },
      "Conn_GCPAccessType": {
        "required": [
          "accessType"
        ],
        "type": "object",
        "properties": {
          "accessType": {
            "$ref": "#/components/schemas/Conn_GCPConnectionAccessType"
          }
        }
      },
      "Conn_GCPServiceAccountKeyDetails": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "example": "sample-cloud-project-323134"
          },
          "clientEmail": {
            "type": "string",
            "example": "clientcontact@company.com"
          },
          "privateKey": {
            "type": "string",
            "example": "-----BEGIN PRIVATE KEY-----\\n avrf...sdf\\n-----END PRIVATE KEY-----\\n"
          }
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_GCPAccessType"
          },
          {
            "required": [
              "clientEmail",
              "privateKey",
              "projectId"
            ]
          }
        ]
      },
      "Conn_BaseConnection": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_BaseEntity"
          },
          {
            "type": "object",
            "properties": {
              "configurationId": {
                "type": "string",
                "description": "Configuration ID assigned to the connection",
                "format": "uuid",
                "example": "7c8c01e3-dc9a-4e7e-a536-7240c62af801"
              }
            }
          }
        ]
      },
      "Conn_ConnectionResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_ConnectionDetail"
          },
          {
            "required": [
              "details"
            ],
            "type": "object",
            "properties": {
              "details": {
                "$ref": "#/components/schemas/Conn_ConnectionResponseDetails"
              }
            }
          }
        ]
      },
      "Conn_AccessKeyConnectionResponseDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_AWSAccessKeyDetails"
          },
          {
            "required": [
              "accountId"
            ],
            "type": "object",
            "properties": {
              "accountId": {
                "$ref": "#/components/schemas/Conn_AWSAccount"
              }
            }
          }
        ]
      },
      "Conn_RoleDelegationConnectionResponseDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_AWSRoleDelegationCreationDetails"
          },
          {
            "$ref": "#/components/schemas/Conn_AWSRoleDelegationUpdateDetails"
          },
          {
            "type": "object",
            "properties": {
              "appDynamicsAwsAccountId": {
                "type": "string",
                "description": "Cloud Native Application Observability AWS Account ID. Delegates a user to an Identity Access Management (IAM) role in AWS. The AWS IAM role provides access to resources.",
                "example": "548762700219",
                "externalDocs": {
                  "url": "https://docs.aws.amazon.com/IAM/latest/UserGuide/id_roles_create_for-user_externalid.html"
                }
              },
              "externalId": {
                "type": "string",
                "description": "Returns an external ID for AWS role delegation connections",
                "format": "uuid",
                "example": "7c8c01e3-dc9a-4e7e-a536-7240c62af801",
                "externalDocs": {
                  "url": "https://docs.aws.amazon.com/IAM/latest/UserGuide/id_roles_create_for-user_externalid.html"
                }
              }
            }
          }
        ]
      },
      "Conn_ConnectionResponseDetails": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/Conn_AWSConnectionResponseDetails"
          },
          {
            "$ref": "#/components/schemas/Conn_AzureDetails"
          },
          {
            "$ref": "#/components/schemas/Conn_GCPConnectionResponseDetails"
          }
        ]
      },
      "Conn_AWSConnectionResponseDetails": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/Conn_RoleDelegationConnectionResponseDetails"
          },
          {
            "$ref": "#/components/schemas/Conn_AccessKeyConnectionResponseDetails"
          }
        ]
      },
      "Conn_AWSConnectionRequestDetails": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/Conn_AWSAccessKeyDetails"
          },
          {
            "$ref": "#/components/schemas/Conn_AWSRoleDelegationCreationDetails"
          }
        ]
      },
      "Conn_GCPConnectionResponseDetails": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/Conn_GCPServiceAccountKeyResponseDetails"
          }
        ]
      },
      "Conn_GCPConnectionRequestDetails": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/Conn_GCPServiceAccountKeyDetails"
          }
        ]
      },
      "Conn_GCPServiceAccountKeyResponseDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_GCPServiceAccountKeyDetails"
          }
        ]
      },
      "Conn_ConnectionRequestDetails": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/Conn_AWSConnectionRequestDetails"
          },
          {
            "$ref": "#/components/schemas/Conn_AzureDetails"
          },
          {
            "$ref": "#/components/schemas/Conn_GCPConnectionRequestDetails"
          }
        ]
      },
      "Conn_ConnectionRequest": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_Connection"
          },
          {
            "required": [
              "details"
            ],
            "type": "object",
            "properties": {
              "details": {
                "$ref": "#/components/schemas/Conn_ConnectionRequestDetails"
              }
            }
          }
        ]
      },
      "Conn_Connection": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_BaseConnection"
          },
          {
            "type": "object",
            "properties": {
              "state": {
                "type": "string",
                "description": "Set the state of the connection",
                "enum": [
                  "ACTIVE",
                  "INACTIVE"
                ]
              }
            }
          }
        ]
      },
      "Conn_ConnectionUpdate": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "Updated name for the connection",
            "example": "AWS dev"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "Updated description for this connection"
          },
          "configurationId": {
            "type": "string",
            "description": "Configuration ID assigned to the connection",
            "format": "uuid",
            "example": "7c8c01e3-dc9a-4e7e-a536-7240c62af801"
          },
          "state": {
            "type": "string",
            "description": "Set the state of the connection",
            "enum": [
              "ACTIVE",
              "INACTIVE"
            ]
          },
          "details": {
            "oneOf": [
              {
                "required": [
                  "roleName"
                ],
                "type": "object",
                "properties": {
                  "roleName": {
                    "type": "string",
                    "example": "AppDynamicsMonitoringRole"
                  }
                }
              },
              {
                "required": [
                  "accessKeyId",
                  "secretAccessKey"
                ],
                "type": "object",
                "properties": {
                  "accessKeyId": {
                    "type": "string",
                    "example": "AKBATYTCJY7XPKGABY5L"
                  },
                  "secretAccessKey": {
                    "type": "string",
                    "format": "password",
                    "example": "7ccw68gBKMMXUdXBut+7qC9CCr1brotxD5ClcGGE"
                  }
                }
              },
              {
                "required": [
                  "clientId",
                  "clientSecret"
                ],
                "type": "object",
                "properties": {
                  "clientId": {
                    "type": "string",
                    "example": "17760330-4ecd-47d5-818b-40308d3e67d1"
                  },
                  "clientSecret": {
                    "type": "string",
                    "format": "password",
                    "example": "k33C_.5b0VrXSiQIf1t-c--p18~Ea_L~2H"
                  }
                }
              },
              {
                "required": [
                  "clientEmail",
                  "privateKey"
                ],
                "type": "object",
                "properties": {
                  "privateKey": {
                    "type": "string",
                    "example": "-----BEGIN PRIVATE KEY-----\\n avrf...sdf\\n-----END PRIVATE KEY-----\\n"
                  },
                  "clientEmail": {
                    "type": "string",
                    "example": "clientcontact@company.com"
                  }
                }
              }
            ]
          }
        }
      },
      "Conn_ConnectionDetail": {
        "allOf": [
          {
            "required": [
              "createdAt",
              "id",
              "state",
              "stateMessage",
              "updatedAt"
            ],
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "7c8c01e3-dc9a-4e7e-a536-7240c62af801"
              },
              "createdAt": {
                "type": "string",
                "format": "date-time"
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time"
              },
              "state": {
                "type": "string",
                "description": "Connection state",
                "enum": [
                  "INACTIVE",
                  "ACTIVE",
                  "PENDING CONFIGURATION",
                  "INCOMPLETE",
                  "CONFIGURED",
                  "INSUFFICIENT LICENSE",
                  "ERROR",
                  "WARNING",
                  "CRITICAL"
                ]
              },
              "stateMessage": {
                "type": "object",
                "additionalProperties": false,
                "description": "Connection state message",
                "example": "Successfully connected"
              }
            }
          },
          {
            "$ref": "#/components/schemas/Conn_BaseConnection"
          }
        ]
      },
      "Conn_Connections": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Conn_ConnectionResponse"
            }
          }
        },
        "additionalProperties": false
      },
      "Conn_ProviderType": {
        "type": "string",
        "description": "Provider type (also known as Connection type)",
        "example": "aws",
        "enum": [
          "aws",
          "azure",
          "gcp"
        ]
      },
      "Conn_Error": {
        "required": [
          "detail",
          "title",
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "https://docs.appdynamics.com/errors/input-validation"
          },
          "title": {
            "type": "string",
            "example": "Invalid request"
          },
          "detail": {
            "type": "string",
            "example": "Invalid connection type 'foobar'"
          }
        }
      },
      "Conn_Configuration": {
        "discriminator": {
          "propertyName": "type"
        },
        "oneOf": [
          {
            "$ref": "#/components/schemas/Conn_AWSConfiguration"
          },
          {
            "$ref": "#/components/schemas/Conn_AzureConfiguration"
          },
          {
            "$ref": "#/components/schemas/Conn_GCPConfiguration"
          }
        ]
      },
      "Conn_ConfigurationUpdate": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "Name of the configuration",
            "example": "AWS dev"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "Updated description for this configuration"
          },
          "details": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Conn_AWSConfigurationDetails"
              },
              {
                "$ref": "#/components/schemas/Conn_AzureConfigurationDetails"
              },
              {
                "$ref": "#/components/schemas/Conn_GCPConfigurationDetails"
              }
            ]
          }
        }
      },
      "Conn_AWSConfiguration": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_BaseEntity"
          },
          {
            "required": [
              "details"
            ],
            "type": "object",
            "properties": {
              "details": {
                "$ref": "#/components/schemas/Conn_AWSConfigurationDetails"
              }
            },
            "example": {
              "displayName": "Example AWS Configuration",
              "description": "AWS Example Configuration",
              "type": "aws",
              "details": {
                "importTags": {
                  "enabled": true,
                  "excludedKeys": [
                    "local",
                    "sandbox"
                  ]
                },
                "tagFilter": "(tags(env) = 'prod' || tags(env) = 'production'))",
                "regions": [
                  "us-east-1",
                  "us-west-1"
                ],
                "polling": {
                  "interval": 5,
                  "unit": "minute"
                },
                "services": [
                  {
                    "name": "elb",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  },
                  {
                    "name": "ec2",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  }
                ]
              }
            }
          }
        ]
      },
      "Conn_AzureConfiguration": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_BaseEntity"
          },
          {
            "required": [
              "details"
            ],
            "type": "object",
            "properties": {
              "details": {
                "$ref": "#/components/schemas/Conn_AzureConfigurationDetails"
              }
            },
            "example": {
              "displayName": "Example Azure Configuration",
              "description": "Azure Example Configuration",
              "type": "azure",
              "details": {
                "regions": [
                  "westus"
                ],
                "importTags": {
                  "enabled": true,
                  "excludedKeys": [
                    "local",
                    "sandbox"
                  ]
                },
                "tagFilter": "(tags(env) = 'prod' || tags(env) = 'production'))",
                "services": [
                  {
                    "name": "vm",
                    "importTags": {
                      "enabled": true,
                      "excludedKeys": [
                        "dev"
                      ]
                    },
                    "tagFilter": "tags(project) = 'cloudcollectors' && tags(jira) IN ['XTNSBL','ACE'] && !(tags(region) IN ['US','IN']) && HAS tags(monitorEnabled) && !(HAS tags(restrictedUse)",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  },
                  {
                    "name": "mysql",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  }
                ]
              }
            }
          }
        ]
      },
      "Conn_GCPConfiguration": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_BaseEntity"
          },
          {
            "required": [
              "details"
            ],
            "type": "object",
            "properties": {
              "details": {
                "$ref": "#/components/schemas/Conn_GCPConfigurationDetails"
              }
            },
            "example": {
              "displayName": "Example GCP Configuration",
              "description": "GCP Example Configuration",
              "type": "gcp",
              "details": {
                "importTags": {
                  "enabled": true,
                  "excludedKeys": [
                    "local",
                    "sandbox"
                  ]
                },
                "tagFilter": "(tags(env) = 'prod' || tags(env) = 'production'))",
                "region": [
                  "us-west1",
                  "us-central1"
                ],
                "polling": {
                  "interval": 5,
                  "unit": "minute"
                },
                "services": [
                  {
                    "name": "vm",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  },
                  {
                    "name": "disk",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  }
                ]
              }
            }
          }
        ]
      },
      "Conn_BaseConfigurationDetails": {
        "type": "object",
        "properties": {
          "regions": {
            "type": "array",
            "description": "Geographic locations used to fetch metrics",
            "items": {
              "type": "string"
            }
          },
          "polling": {
            "$ref": "#/components/schemas/Conn_ScheduleInterval"
          },
          "importTags": {
            "$ref": "#/components/schemas/Conn_ImportTagConfiguration"
          },
          "tagFilter": {
            "$ref": "#/components/schemas/Conn_TagFilter"
          },
          "services": {
            "type": "array",
            "description": "services for which we will fetch metrics",
            "items": {
              "$ref": "#/components/schemas/Conn_Service"
            }
          }
        }
      },
      "Conn_AzureConfigurationDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_BaseConfigurationDetails"
          },
          {
            "type": "object",
            "properties": {
              "resourceGroups": {
                "type": "array",
                "description": "Azure Resource groups used to fetch metrics",
                "example": [
                  "resourceGroup1",
                  "resourceGroup2"
                ],
                "items": {
                  "type": "string"
                }
              },
              "services": {
                "example": [
                  {
                    "name": "vm",
                    "importTags": {
                      "enabled": true,
                      "excludedKeys": [
                        "dev"
                      ]
                    },
                    "tagFilter": "tags(project) = 'cloudcollectors' && tags(jira) IN ['XTNSBL','ACE'] && !(tags(region) IN ['US','IN']) && HAS tags(monitorEnabled) && !(HAS tags(restrictedUse)",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  },
                  {
                    "name": "mysql",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  }
                ]
              },
              "regions": {
                "example": [
                  "eastus",
                  "westus"
                ]
              }
            }
          }
        ]
      },
      "Conn_AWSConfigurationDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_BaseConfigurationDetails"
          },
          {
            "type": "object",
            "properties": {
              "services": {
                "example": [
                  {
                    "name": "ec2",
                    "importTags": {
                      "enabled": true,
                      "excludedKeys": [
                        "local",
                        "sandbox"
                      ]
                    },
                    "tagFilter": "(tags(env) = 'prod' || tags(env) = 'production')) && tags(project) = 'cloudcollectors' && tags(jira) IN ['XTNSBL','ACE'] && !(tags(region) IN ['US','IN']) && HAS tags(monitorEnabled) && !(HAS tags(restrictedUse))",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  },
                  {
                    "name": "aurora",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  }
                ]
              },
              "regions": {
                "example": [
                  "us-east-1",
                  "us-west-1"
                ]
              }
            }
          }
        ]
      },
      "Conn_GCPConfigurationDetails": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Conn_BaseConfigurationDetails"
          },
          {
            "type": "object",
            "properties": {
              "services": {
                "example": [
                  {
                    "name": "vm",
                    "importTags": {
                      "enabled": true,
                      "excludedKeys": [
                        "local",
                        "sandbox"
                      ]
                    },
                    "tagFilter": "(tags(env) = 'prod' || tags(env) = 'production')) && tags(project) = 'cloudcollectors' && tags(jira) IN ['XTNSBL','ACE'] && !(tags(region) IN ['us-central1','us-west1']) && HAS tags(monitorEnabled) && !(HAS tags(restrictedUse))",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  },
                  {
                    "name": "disk",
                    "polling": {
                      "interval": 5,
                      "unit": "minute"
                    }
                  }
                ]
              },
              "regions": {
                "example": [
                  "us-central1",
                  "us-west1"
                ]
              }
            }
          }
        ]
      },
      "Conn_Service": {
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "ec2"
          },
          "importTags": {
            "$ref": "#/components/schemas/Conn_ImportTagConfiguration"
          },
          "tagFilter": {
            "$ref": "#/components/schemas/Conn_TagFilter"
          },
          "polling": {
            "$ref": "#/components/schemas/Conn_ScheduleInterval"
          }
        }
      },
      "Conn_ScheduleInterval": {
        "required": [
          "interval",
          "unit"
        ],
        "type": "object",
        "properties": {
          "interval": {
            "type": "integer",
            "description": "The polling interval is five (5) minutes",
            "format": "int32",
            "default": 5
          },
          "unit": {
            "type": "string",
            "default": "minute",
            "enum": [
              "minute"
            ]
          }
        },
        "description": "How often the selected connection is polled for information",
        "example": {
          "interval": 5,
          "unit": "minute"
        }
      },
      "Conn_BaseConfigurationResource": {
        "required": [
          "displayName",
          "id"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "unique identifier for this resource"
          },
          "displayName": {
            "type": "string",
            "description": "display name for this resource"
          },
          "description": {
            "type": "string",
            "description": "a description of this resource"
          }
        }
      },
      "Conn_ConfigurationResourceList": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Conn_BaseConfigurationResource"
            }
          }
        }
      },
      "Conn_Configurations": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Conn_ConfigurationDetail"
            }
          }
        }
      },
      "Conn_ConfigurationDetail": {
        "allOf": [
          {
            "required": [
              "createdAt",
              "id",
              "updatedAt"
            ],
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "7c8c01e3-dc9a-4e7e-a536-7240c62af801"
              },
              "createdAt": {
                "type": "string",
                "format": "date-time"
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          {
            "discriminator": {
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/components/schemas/Conn_AWSConfiguration"
              },
              {
                "$ref": "#/components/schemas/Conn_AzureConfiguration"
              },
              {
                "$ref": "#/components/schemas/Conn_GCPConfiguration"
              }
            ]
          }
        ]
      },
      "Conn_ImportTagConfiguration": {
        "required": [
          "enabled"
        ],
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "It is true by default. Tags will be imported for all the resources that are being monitored by default",
            "default": true
          },
          "excludedKeys": {
            "type": "array",
            "description": "Array of that need to be excluded from being imported. It can be set only when enabled is true",
            "example": [
              "key1",
              "key2"
            ],
            "items": {
              "type": "string",
              "example": "key1"
            }
          }
        },
        "description": "Configuration for importing tags of resources that are being monitored",
        "example": {
          "enabled": true,
          "excludedKeys": [
            "key1, key2"
          ]
        }
      },
      "Conn_TagFilter": {
        "type": "string",
        "description": "expression for filtering resources to be monitored, based on tags",
        "example": "(tags(env) = 'prod' || tags(env) = 'production')) && tags(project) = 'cloudcollectors'"
      },
      "QS_QueryRequestBody": {
        "description": "Client request with a query.\nEither a plain UQL query, e.g. `FETCH events(logs:generic_record)[source = 'opentelemetry']`\nOR a parameterised UQL query where there may be parameters instead of filter values,\ne.g. `FETCH events(logs:generic_record)[source = $sourceName]`.\nSpecific values for the parameters are then provided separately from the UQL query itself.",
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "Query string.",
            "example": "FETCH events(logs:generic_record)[source IN $sourceName] // $sourceName is a query parameter"
          },
          "queryParameters": {
            "$ref": "#/components/schemas/QS_QueryRequestParameterArray"
          },
          "dryRun": {
            "type": "boolean",
            "description": "Execution plan should not run and call downstream stores."
          }
        }
      },
      "QS_BatchedQueryRequestBody": {
        "description": "MultiQuery body.",
        "type": "object",
        "required": [
          "queries"
        ],
        "properties": {
          "queries": {
            "type": "object",
            "description": "Map of named queries. Result chunks will associate with a query using these names.\nOnly alpha-numeric characters are allowed in the query names.",
            "example": {
              "queries": {
                "customQuery1Identifier": {
                  "query": "FETCH id FROM entities(apm:service_instance)"
                },
                "customQuery2Identifier": {
                  "query": "FETCH id FROM entities(apm:service)[attributes(service.namespace) = $namespace]",
                  "queryParameters": [
                    {
                      "name": "namespace",
                      "type": "string",
                      "value": "Levitate"
                    }
                  ]
                }
              },
              "dryRun": false
            },
            "additionalProperties": {
              "$ref": "#/components/schemas/QS_QueryRequestQuery"
            }
          },
          "dryRun": {
            "type": "boolean",
            "description": "Execution plan should not run and call downstream stores."
          }
        }
      },
      "QS_QueryRequestParameterArray": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/QS_QueryRequestParameterItem"
            }
          ]
        }
      },
      "QS_QueryRequestParameterItem": {
        "description": "Query parameter.",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of parameter. Provided here without leading $ sign.",
            "example": "sourceName"
          },
          "type": {
            "type": "string",
            "description": "Type of parameter value",
            "enum": [
              "string",
              "long",
              "boolean",
              "double",
              "timestamp",
              "duration",
              "typeId",
              "objectId",
              "any"
            ]
          },
          "value": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/QS_QueryRequestParameterSingleItem"
              },
              {
                "$ref": "#/components/schemas/QS_QueryRequestParameterItemArray"
              }
            ]
          }
        }
      },
      "QS_QueryRequestParameterItemArray": {
        "type": "array",
        "description": "Array of parameter values. Parameter is to be used with IN or !IN operator",
        "items": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/QS_QueryRequestParameterSingleItem"
            }
          ]
        }
      },
      "QS_QueryRequestParameterSingleItem": {
        "type": "object",
        "description": "Value of query parameter"
      },
      "QS_QueryRequestQuery": {
        "type": "object",
        "description": "Single UQL query with optional parameter values.",
        "properties": {
          "query": {
            "type": "string",
            "description": "Query string.",
            "example": "FETCH events(logs:generic_record)[source IN $sourceName] // $sourceName is a query parameter"
          },
          "queryParameters": {
            "$ref": "#/components/schemas/QS_QueryRequestParameterArray"
          }
        }
      },
      "QS_QueryResponseArrayBody": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/QS_ModelResultChunk"
            },
            {
              "$ref": "#/components/schemas/QS_DataResultChunk"
            },
            {
              "$ref": "#/components/schemas/QS_ErrorResultChunk"
            },
            {
              "$ref": "#/components/schemas/QS_HeartbeatResultChunk"
            },
            {
              "$ref": "#/components/schemas/QS_EndResultChunk"
            }
          ]
        },
        "description": "The ModelResultChunk will be always the first item in the response array. The rest of the items might be a mix of DataResultChunk, ErrorResultChunk, HeartbeatResultChunk and EndResultChunk."
      },
      "QS_ModelResultChunk": {
        "description": "A schema of the data to follow. This object can only be at the first position in the response.",
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Attribute identifying a response chunk as holding the response model.",
            "example": "model",
            "enum": [
              "model"
            ]
          },
          "queryId": {
            "type": "string",
            "description": "Associates the data chunk with specific query in case of a batched request.",
            "nullable": true
          },
          "model": {
            "$ref": "#/components/schemas/QS_Model"
          }
        }
      },
      "QS_DataResultChunk": {
        "description": "A part of the result data. There may be multiple chunks of this type in the response.",
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Attribute identifying a response chunk holding data.",
            "example": "data",
            "enum": [
              "data"
            ]
          },
          "queryId": {
            "type": "string",
            "description": "Associates the data chunk with specific query in case of a batched request.",
            "nullable": true
          },
          "_links": {
            "$ref": "#/components/schemas/QS_PaginationReference"
          },
          "dataset": {
            "type": "string",
            "description": "Name of the dataset. May be used as a reference in other datasets when returning multi dimensional data."
          },
          "model": {
            "$ref": "#/components/schemas/QS_ModelReference"
          },
          "metadata": {
            "$ref": "#/components/schemas/QS_MetadataResultItem"
          },
          "main": {
            "type": "boolean",
            "description": "A flag signalling whether this chunk is the main chunk (the root of the composite model). Only the main chunk has this property (and it is always \"true\"). None of the other chunks do."
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QS_DataResultItem"
            }
          }
        }
      },
      "QS_ErrorResultChunk": {
        "description": "A signal that an error occurred during query execution.",
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Attribute identifying a response chunk as holding information of an error.",
            "example": "error",
            "enum": [
              "error"
            ]
          },
          "queryId": {
            "type": "string",
            "description": "Associates the data chunk with specific query in case of a batched request.",
            "nullable": true
          },
          "error": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "URI to the documentation of the error.",
                "example": "https://developer.cisco.com/docs/appdynamics/errors/#!internal-server-error"
              },
              "errorCode": {
                "type": "string",
                "description": "The code of the error.",
                "example": "SC-001"
              },
              "timestamp": {
                "type": "string",
                "description": "Time and date the `ErrorResultChunk` was created.",
                "format": "date-time",
                "example": "2020-02-22T11:22:33.980629Z"
              },
              "traceId": {
                "description": "It correlates events and logs messages across dependent services for single business transaction.",
                "type": "string",
                "example": "fc3decb4bf674b7cb16c5f208fb1f18b"
              },
              "title": {
                "type": "string",
                "description": "Brief description of the error.",
                "example": "Unexpected error happened"
              },
              "detail": {
                "type": "string",
                "description": "Usually more detailed description of the error.",
                "example": "Unexpected error happened (logged as 224397de-5843-4954-b092-37c84aead3c9)"
              },
              "query": {
                "type": "string",
                "description": "The input query.",
                "example": "fetch id from entities since 2022-06-02 until 2022-06-01"
              },
              "queryParameters": {
                "$ref": "#/components/schemas/QS_QueryRequestParameterArray"
              }
            }
          }
        }
      },
      "QS_HeartbeatResultChunk": {
        "description": "An empty chunk sent to prevent the HTTP connection from being pre-maturely closed.",
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Attribute identifying a response chunk as a heartbeat.",
            "example": "heartbeat",
            "enum": [
              "heartbeat"
            ]
          }
        }
      },
      "QS_EndResultChunk": {
        "description": "An empty chunk indicating the completion of a query. It is included only in batched query responses.",
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Attribute identifying a response chunk as an end.",
            "example": "end",
            "enum": [
              "end"
            ]
          },
          "queryId": {
            "type": "string",
            "description": "Associates the data chunk with specific query in case of a batched request."
          }
        }
      },
      "QS_ModelResultItem": {
        "description": "A description of a simple data type of a single fetched expression in the result.",
        "type": "object",
        "properties": {
          "alias": {
            "type": "string"
          },
          "properties": {
            "$ref": "#/components/schemas/QS_ModelFieldProperties"
          },
          "type": {
            "type": "string",
            "description": "Specifies a type of the value in the JSON response.",
            "example": "'string', 'number', 'timestamp', ..."
          },
          "hints": {
            "$ref": "#/components/schemas/QS_Hints"
          }
        }
      },
      "QS_ComplexModelResultItem": {
        "description": "A description of a complex data type of a single fetched expression in the result.",
        "type": "object",
        "properties": {
          "alias": {
            "type": "string"
          },
          "properties": {
            "$ref": "#/components/schemas/QS_ModelFieldProperties"
          },
          "type": {
            "type": "string",
            "description": "Specifies a type of the complex value. Individual fields are described in the 'model'.",
            "example": "'complex', 'timeseries' specifically for time series."
          },
          "hints": {
            "$ref": "#/components/schemas/QS_Hints"
          },
          "form": {
            "type": "string",
            "description": "Describes where timeseries or complex objects are located in the response. Possible values are: inline, reference, link"
          },
          "model": {
            "$ref": "#/components/schemas/QS_Model"
          }
        }
      },
      "QS_Model": {
        "description": "A description of the schema of the data to follow in the DataResultChunks.",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "This name will be used by the following DataResultChunks as a reference to the description of their structure."
          },
          "resultType": {
            "description": "AGGREGATION if the model represents an aggregation result, LISTING otherwise.\nThe result is aggregated if any of the result fields are an aggregation (i.e. a computed values like summary, average, etc.).",
            "enum": [
              "LISTING",
              "AGGREGATION"
            ]
          },
          "fields": {
            "description": "An array of type descriptors for each fetched expression in the query.\nThe order of the array matches the order of values in the DataResultChunks with this schema model.'",
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/QS_ModelResultItem"
                },
                {
                  "$ref": "#/components/schemas/QS_ComplexModelResultItem"
                }
              ]
            }
          }
        }
      },
      "QS_Hints": {
        "description": "Additional information about a single fetched expression from the query.",
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "description": "Type of observed component from Cisco AppDynamics MELT Model.\nOptional, if applicable",
            "example": "'entity', 'metric', 'event', ..."
          },
          "field": {
            "type": "string",
            "description": "Name of the MELT model property mentioned in the 'kind' hint.\nOptional, if applicable (for example not for expression)",
            "example": "'value' when fetching a Property"
          },
          "type": {
            "type": "string",
            "description": "Full name with namespace of the type.",
            "example": "apm:service"
          }
        }
      },
      "QS_MetadataResultItem": {
        "description": "Additional information collected for the data contained in the data chunk.",
        "type": "object",
        "anyOf": [
          {
            "$ref": "#/components/schemas/QS_MainMetadataResultItem"
          },
          {
            "$ref": "#/components/schemas/QS_MetricMetadataResultItem"
          },
          {
            "$ref": "#/components/schemas/QS_EventMetadataResultItem"
          }
        ]
      },
      "QS_ModelFieldProperties": {
        "description": "Model field metadata properties",
        "type": "object",
        "required": [
          "functionType",
          "orderable"
        ],
        "properties": {
          "functionType": {
            "description": "AGGREGATION if the field represents an aggregated value, DIMENSION otherwise.\nThe field is aggregated if it represents a computed value (e.g. summary, average, etc.).",
            "enum": [
              "DIMENSION",
              "AGGREGATION"
            ]
          },
          "orderable": {
            "description": "true if the data may be ordered by this field, false otherwise",
            "type": "boolean"
          },
          "fieldCoordinates": {
            "description": "position of the snippet of query that represents this field. Only present for fields explicitly declared in the query.",
            "type": "object",
            "properties": {
              "from": {
                "description": "start line and start character index position of query snippet that represents this field. Pattern: line:characterIndex",
                "type": "string"
              },
              "to": {
                "description": "end line and end character index position of query snippet that represents this field. Pattern: line:characterIndex",
                "type": "string"
              }
            }
          },
          "querySnippet": {
            "description": "query snippet that represents this field (cleared of any comments or formatting). Only present for fields explicitly declared in the query.",
            "type": "string"
          },
          "ordering": {
            "description": "data ordering information. Only present if the data is ordered by this field.",
            "type": "object",
            "properties": {
              "direction": {
                "description": "ASC if the data is ordered in ascending fashion, DESC if the data is ordered in descending fashion",
                "enum": [
                  "ASC",
                  "DESC"
                ]
              },
              "orderIndex": {
                "description": "Ordering index, as in \"data is ordered first by duration, then by name, then...\" (first is index 0)"
              }
            }
          }
        }
      },
      "QS_MainMetadataResultItem": {
        "description": "Metadata for the main data chunk.",
        "type": "object",
        "properties": {
          "since": {
            "type": "string",
            "description": "Specifies the start of the time range which was used for querying.",
            "example": "2022-05-24T10:18:22.12Z",
            "format": "date-time"
          },
          "until": {
            "type": "string",
            "description": "Specifies the end of the time range which was used for querying.",
            "example": "2022-05-24T11:18:22.12Z",
            "format": "date-time"
          }
        }
      },
      "QS_MetricMetadataResultItem": {
        "description": "Metadata for a metric data chunk.",
        "type": "object",
        "properties": {
          "granularitySeconds": {
            "type": "number",
            "description": "Actual granularity of metric data points.\nThe value is the length of the time interval of a single data point."
          }
        }
      },
      "QS_EventMetadataResultItem": {
        "description": "Metadata for an event data chunk.",
        "type": "object",
        "properties": {
          "schema": {
            "type": "object",
            "description": "Arbitrary map of keys and values associated with the event data."
          },
          "statistics": {
            "type": "object",
            "description": "Arbitrary map of statistics associated with the event data."
          }
        }
      },
      "QS_DataResultItem": {
        "description": "A row of values with mixed data types based on the fetched expressions.",
        "type": "array",
        "items": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "$ref": "#/components/schemas/QS_DatasetReference"
            },
            {
              "type": "object"
            }
          ]
        }
      },
      "QS_DatasetReference": {
        "description": "A reference to a specific dataset.",
        "type": "object",
        "properties": {
          "$dataset": {
            "type": "string",
            "description": "Unique name of the dataset.",
            "example": "d:metrics-1"
          },
          "$jsonPath": {
            "type": "string",
            "description": "JSON Path that filters the correct dataset from the list of all datasets.",
            "example": "$..[?(@.type == 'data' && @.dataset == 'd:metrics-1')]"
          }
        }
      },
      "QS_PaginationReference": {
        "description": "A reference to the next page of results if there are more results.",
        "type": "object",
        "properties": {
          "next": {
            "type": "object",
            "description": "Holds the link to the next page of results.",
            "properties": {
              "href": {
                "type": "string",
                "description": "The effective link to the next result page",
                "example": "/monitoring/v1/query/continue?cursor=ewogICJza2lwIiA6IDEwMDAsCiAgInF1ZXJ5IiA6ICJGRVRDSFxuICAgIGlkLFxuICAgIGhlYWx0aF9hc19"
              }
            }
          }
        }
      },
      "QS_ModelReference": {
        "description": "A reference to a specific model.",
        "type": "object",
        "properties": {
          "$model": {
            "type": "string",
            "description": "A unique model name.",
            "example": "m:main"
          },
          "$jsonPath": {
            "type": "string",
            "description": "JSON Path that filters the correct model from the ModelResultChunk.",
            "example": "$..[?(@.type == 'model')]..[?(@.name == 'm:main')]"
          }
        }
      },
      "QS_ErrorResult": {
        "description": "A representation of an error that occurred during query execution. It contains at least brief a description\nof the error and contextual information of the corresponding request.",
        "type": "object",
        "required": [
          "type",
          "timestamp",
          "traceId",
          "title",
          "detail",
          "tenantId",
          "query"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "URI to the documentation of the error."
          },
          "errorCode": {
            "type": "string",
            "description": "The code of a error.",
            "example": "SC-001"
          },
          "timestamp": {
            "type": "string",
            "description": "Time and date the error occurred.",
            "format": "date-time",
            "example": "2020-02-22T11:22:33.980629Z"
          },
          "traceId": {
            "description": "Id to correlate events and logs across dependent services for a single query.",
            "type": "string",
            "example": "fc3decb4bf674b7cb16c5f208fb1f18b"
          },
          "title": {
            "type": "string",
            "description": "Brief description of the error.",
            "example": "Query compilation failure!"
          },
          "detail": {
            "type": "string",
            "description": "Usually a more detailed description of the error.",
            "example": "Unable to compile due to query semantic errors. (logged with TraceId: [467345r43535e4246f9a895c44636076bf0], SpanId: [8c3345345b273d43])"
          },
          "tenantId": {
            "type": "string",
            "description": "The id of a tenant for which the query was executed.",
            "example": "47a01df9-54a0-472b-96b8-7c8f64eb7cbf"
          },
          "query": {
            "type": "string",
            "description": "The input query.",
            "example": "fetch id from entities since 2022-06-02 until 2022-06-01"
          },
          "queryParameters": {
            "$ref": "#/components/schemas/QS_QueryRequestParameterArray"
          },
          "errorDetails": {
            "$ref": "#/components/schemas/QS_ErrorDetailsArray"
          }
        }
      },
      "QS_ErrorDetailsArray": {
        "description": "An array containing the details of an error.",
        "type": "array",
        "items": {
          "anyOf": [
            {
              "$ref": "#/components/schemas/QS_ErrorDetailItem"
            }
          ]
        }
      },
      "QS_ErrorDetailItem": {
        "description": "A detailed description of the error.",
        "type": "object",
        "required": [
          "message",
          "fixPossibilities",
          "errorType",
          "errorFrom",
          "errorTo"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "A short description on error cause.",
            "example": "Unknown alias 'id'"
          },
          "fixSuggestion": {
            "type": "string",
            "description": "A hint to resolve the error.",
            "example": "Did you mean 'apm:service_endpoint'?"
          },
          "fixPossibilities": {
            "type": "array",
            "description": "A list of fix possibilities to resolve the error.",
            "items": {
              "anyOf": [
                {
                  "type": "string",
                  "example": "apm:backend"
                }
              ]
            }
          },
          "errorType": {
            "type": "string",
            "description": "The type of the error.",
            "example": "SEMANTIC",
            "enum": [
              "SEMANTIC",
              "SYNTAX"
            ]
          },
          "errorFrom": {
            "type": "string",
            "description": "The start position of the error in format 'lineNum:charIdx'.",
            "example": "1:6"
          },
          "errorTo": {
            "type": "string",
            "description": "The end position of the error in format 'lineNum:charIdx'.",
            "example": "1:7"
          }
        }
      },
      "HR_EvaluationObjects": {
        "required": [
          "topologyExpression"
        ],
        "type": "object",
        "properties": {
          "topologyExpression": {
            "minLength": 1,
            "type": "string",
            "description": "Topology expression",
            "example": "entities('spacefleet:starship').out.to('spacefleet:torpedo_tube)"
          },
          "evaluationEntityType": {
            "type": "string",
            "description": "Evaluation Entity",
            "example": "spacefleet:torpedo_tube"
          }
        }
      },
      "HR_Criteria": {
        "required": [
          "conditions",
          "criteriaExpression"
        ],
        "type": "object",
        "properties": {
          "criteriaExpression": {
            "minLength": 1,
            "type": "string",
            "description": "Boolean expression on condition labels.",
            "example": "A OR (B AND C)",
            "externalDocs": {
              "url": "https://docs.appdynamics.com/observability/cisco-cloud-observability/en/entity-health-monitoring/create-health-rules-to-monitor-entities-or-group-of-entities/define-health-rule-evaluation-conditions"
            }
          },
          "conditions": {
            "minLength": 1,
            "type": "array",
            "description": "Array of conditions for health rule.",
            "items": {
              "$ref": "#/components/schemas/HR_LeafCondition"
            }
          }
        },
        "description": "The criteria configuration"
      },
      "HR_EntityType": {
        "required": [
          "displayName",
          "name",
          "namespace",
          "namespaceVersion"
        ],
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "The display name of the entity type",
            "example": "Service Instance"
          },
          "name": {
            "type": "string",
            "description": "The name of the entity type",
            "example": "service_instance"
          },
          "namespace": {
            "type": "string",
            "description": "The namespace of the entity type",
            "example": "apm"
          },
          "namespaceVersion": {
            "type": "integer",
            "description": "The version of the namespace",
            "format": "int32",
            "example": 1
          }
        },
        "description": "The entity type"
      },
      "HR_ErrorResponse": {
        "required": [
          "detail",
          "title",
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "http://www.docs.appdynamics.com/errors/example-error"
          },
          "title": {
            "type": "string",
            "example": "Invalid request."
          },
          "detail": {
            "type": "string",
            "example": "Invalid request. Please provide the correct payload."
          }
        }
      },
      "HR_RollupCriteria": {
        "required": [
          "threshold",
          "thresholdType"
        ],
        "type": "object",
        "properties": {
          "threshold": {
            "minLength": 1,
            "type": "integer",
            "format": "int32",
            "description": "The health rollup to the parent object happens when the threshold condition(combination of threshold and threshold type) of the participating child objects are met.",
            "example": 10
          },
          "thresholdType": {
            "$ref": "#/components/schemas/HR_ThresholdType"
          }
        }
      },
      "HR_HealthRollup": {
        "required": [
          "rollupTo",
          "criteria"
        ],
        "type": "object",
        "properties": {
          "rollupTo": {
            "minLength": 1,
            "type": "string",
            "description": "entity to rollup to",
            "example": "k8s:workload"
          },
          "criteria": {
            "$ref": "#/components/schemas/HR_RollupCriteria"
          },
          "rollupHealthConfig": {
            "$ref": "#/components/schemas/HR_HealthRollup"
          }
        }
      },
      "HR_HealthRule": {
        "allOf": [
          {
            "$ref": "#/components/schemas/HR_HealthRuleRequest"
          },
          {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique identifier",
                "example": "31vgC5nZS+GI/qGgkJtbiw"
              },
              "createdAt": {
                "minLength": 1,
                "type": "string",
                "description": "The created timestamp of the health rule according to RFC 3339. specification.",
                "format": "date-time",
                "example": "2020-12-19T16:39:57.000Z",
                "externalDocs": {
                  "url": "https://www.ietf.org/rfc/rfc3339.txt"
                }
              },
              "updatedAt": {
                "minLength": 1,
                "type": "string",
                "description": "The updated timestamp of the health rule according to RFC 3339. specification.",
                "format": "date-time",
                "example": "2020-12-19T17:04:57.000Z",
                "externalDocs": {
                  "url": "https://www.ietf.org/rfc/rfc3339.txt"
                }
              },
              "entityType": {
                "minLength": 1,
                "type": "string",
                "description": "The entity type for the health rule. Optional field whose value is derived from evaluationObjects.",
                "example": "apm:service_instance"
              }
            },
            "description": "The health rule configuration"
          }
        ]
      },
      "HR_HealthRuleListResponse": {
        "required": [
          "items",
          "total"
        ],
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "Count of items in the list"
          },
          "items": {
            "type": "array",
            "description": "The health rules.",
            "items": {
              "$ref": "#/components/schemas/HR_HealthRule"
            }
          }
        }
      },
      "HR_HealthRuleRequest": {
        "type": "object",
        "required": [
          "enabled",
          "evaluationObjects",
          "name",
          "waitTimeAfterViolation"
        ],
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string",
            "description": "The name of the health rule.",
            "example": "Sample Health Rule Configuration"
          },
          "description": {
            "type": "string",
            "description": "Optional additional information",
            "example": "This is a sample configuration of a health rule."
          },
          "scheduleName": {
            "minLength": 1,
            "type": "string",
            "description": "The name of the schedule configuration for the health rule. By default, it is enabled. You can define a custom schedule and refer by name.",
            "example": "Custom Schedule",
            "default": "Always"
          },
          "waitTimeAfterViolation": {
            "minLength": 1,
            "pattern": "\\d+m?",
            "type": "string",
            "description": "The health rule wait time setting enables you to control how often an event is generated while the conditions found to violate a health rule continue. The default and the only allowed unit is minutes(m). Specifying the unit is optional.",
            "example": "30m",
            "externalDocs": {
              "url": "https://docs.appdynamics.com/observability/cisco-cloud-observability/en/entity-health-monitoring/health-rules#HealthRules-Wait_Time_After_ViolationHealthRuleWaitTimeAfterViolation"
            }
          },
          "evaluationObjects": {
            "$ref": "#/components/schemas/HR_EvaluationObjects"
          },
          "criticalCriteria": {
            "$ref": "#/components/schemas/HR_Criteria"
          },
          "warningCriteria": {
            "$ref": "#/components/schemas/HR_Criteria"
          },
          "rollupHealthConfig": {
            "$ref": "#/components/schemas/HR_HealthRollup"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether health rule is enabled for evaluation",
            "default": true
          },
          "metadata": {
            "$ref": "#/components/schemas/HR_Metadata"
          }
        },
        "description": "The health rule request model used while creating or updating health rules."
      },
      "HR_HealthRuleUpdateStatusResponse": {
        "required": [
          "updateResults"
        ],
        "type": "object",
        "properties": {
          "updateResults": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/HR_UpdateResult"
            },
            "description": "Update result by the health rule ID."
          }
        }
      },
      "HR_HealthRulesRequest": {
        "type": "object",
        "properties": {
          "healthRuleIds": {
            "minItems": 1,
            "type": "array",
            "description": "The health rule identifiers.",
            "items": {
              "type": "string",
              "description": "The unique identifier of the health rule."
            }
          }
        }
      },
      "HR_LeafCondition": {
        "required": [
          "conditionExpression",
          "label",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string",
            "description": "The name of the condition.",
            "example": "Condition 1"
          },
          "label": {
            "minLength": 1,
            "type": "string",
            "description": "The label of condition. Used for combining condition names.",
            "example": "A"
          },
          "relatedObjectExpr": {
            "minLength": 1,
            "type": "string",
            "description": "The related objects for condition in UQL syntax.",
            "example": "this.service()",
            "externalDocs": {
              "url": "https://docs.appdynamics.com/observability/cisco-cloud-observability/en/entity-health-monitoring/create-health-rules-to-monitor-entities-or-group-of-entities/define-health-rule-evaluation-conditions"
            }
          },
          "conditionExpression": {
            "minLength": 1,
            "type": "string",
            "description": "The condition expression to be evaluated.",
            "example": "metrics(\"apm:calls_per_min\", \"apm\"))[timestamp > (now - 30m)].max() > 10",
            "externalDocs": {
              "url": "https://docs.appdynamics.com/observability/cisco-cloud-observability/en/entity-health-monitoring/create-health-rules-to-monitor-entities-or-group-of-entities/define-health-rule-evaluation-conditions"
            }
          },
          "evaluateToTrueOnNoData": {
            "type": "boolean",
            "description": "Whether the condition should evaluate to true if a required metric value is unknown.",
            "example": true,
            "default": false
          },
          "violationStatusOnNoData": {
            "$ref": "#/components/schemas/HR_ViolationStatus"
          }
        },
        "description": "The leaf condition."
      },
      "HR_Metadata": {
        "description": "Related Metadata like applications and namespace to which this health rule belongs and evaluation option.",
        "type": "object",
        "properties": {
          "applications": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "The list of applications to which the health rule belongs. If no application is given, this health rule would be shown in all applications."
          }
        }
      },
      "HR_RollupEntityType": {
        "required": [
          "displayName",
          "name",
          "namespace"
        ],
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "The display name of the entity type.",
            "example": "Service Instance"
          },
          "name": {
            "type": "string",
            "description": "The name of the entity type",
            "example": "service_instance"
          },
          "namespace": {
            "type": "string",
            "description": "The namespace of the entity type.",
            "example": "apm"
          }
        },
        "description": "The rollup entity type."
      },
      "HR_RollupPath": {
        "required": [
          "path"
        ],
        "type": "object",
        "properties": {
          "path": {
            "type": "array",
            "description": "A path from the target entity type, starting with that entity type.",
            "items": {
              "$ref": "#/components/schemas/HR_RollupEntityType"
            }
          }
        }
      },
      "HR_RollupPathsResponse": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "Count of items in the list"
          },
          "items": {
            "type": "array",
            "description": "The rollup paths.",
            "items": {
              "$ref": "#/components/schemas/HR_RollupPath"
            }
          }
        }
      },
      "HR_ThresholdType": {
        "type": "string",
        "enum": [
          "COUNT",
          "PERCENTAGE"
        ]
      },
      "HR_UpdateResult": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/HR_UpdateResultStatus"
          },
          "message": {
            "type": "string",
            "description": "Detail message for update operation",
            "example": "Invalid health rule ID."
          },
          "currentState": {
            "$ref": "#/components/schemas/HR_CurrentState"
          }
        }
      },
      "HR_UpdateResultStatus": {
        "type": "string",
        "enum": [
          "SUCCESS",
          "FAILURE",
          "NO_OP"
        ]
      },
      "HR_ViolationStatus": {
        "description": "Whether the condition should evaluate to unknown, healthy or unhealthy by default when the configured metric value is unknown.",
        "type": "string",
        "enum": [
          "UNKNOWN",
          "HEALTHY",
          "UNHEALTHY"
        ]
      },
      "HR_CurrentState": {
        "type": "string",
        "enum": [
          "ENABLED",
          "DISABLED"
        ]
      },
      "Act_AuditTimestamps": {
        "type": "object",
        "properties": {
          "createdAt": {
            "minLength": 1,
            "type": "string",
            "description": "The created timestamp of the entity according to RFC 3339 specification.",
            "format": "date-time",
            "example": "2020-12-19T16:39:57Z",
            "externalDocs": {
              "url": "https://www.ietf.org/rfc/rfc3339.txt"
            }
          },
          "updatedAt": {
            "minLength": 1,
            "type": "string",
            "description": "The updated timestamp of the entity according to RFC 3339 specification.",
            "format": "date-time",
            "example": "2020-12-19T17:04:57Z",
            "externalDocs": {
              "url": "https://www.ietf.org/rfc/rfc3339.txt"
            }
          }
        }
      },
      "Act_Metadata": {
        "type": "object",
        "properties": {
          "applications": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "app-cco"
            },
            "description": "the list of application names to which this config belongs."
          }
        }
      },
      "Act_ErrorResponse": {
        "required": [
          "detail",
          "title",
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "example": "http://www.docs.appdynamics.com/errors/example-error"
          },
          "title": {
            "type": "string",
            "example": "Invalid request."
          },
          "detail": {
            "type": "string",
            "example": "Invalid request. Please provide correct payload."
          }
        }
      },
      "Act_MatchingCondition": {
        "required": [
          "operator",
          "property",
          "values"
        ],
        "type": "object",
        "description": "Array of the matching conditions.",
        "properties": {
          "property": {
            "minLength": 1,
            "type": "string",
            "description": "The property to match the conditions.",
            "example": "eventType"
          },
          "operator": {
            "type": "string",
            "description": "The operator used for comparison.",
            "example": "CONTAINS",
            "enum": [
              "STARTS_WITH",
              "ENDS_WITH",
              "CONTAINS",
              "EQUALS",
              "MATCH_REG_EX"
            ]
          },
          "values": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "The array of the values."
          }
        }
      },
      "Act_TriggerListResponse": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "description": "Array of the triggers.",
            "items": {
              "$ref": "#/components/schemas/Act_TriggerResponse"
            }
          }
        }
      },
      "Act_Trigger": {
        "required": [
          "actionIds",
          "name",
          "triggerCriteria"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string",
            "description": "The name of the trigger.",
            "example": "Sample Trigger."
          },
          "triggerCriteria": {
            "minItems": 1,
            "maxItems": 1,
            "type": "array",
            "description": "Array of criteria for the triggers.",
            "items": {
              "$ref": "#/components/schemas/Act_TriggerCriteria"
            }
          },
          "actionIds": {
            "minItems": 1,
            "maxItems": 1,
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "The identifier (ID) of the action workflow.",
            "example": [
              "I+sfW0V3MDytvVmTm7HtLA"
            ]
          },
          "metadata": {
            "$ref": "#/components/schemas/Act_Metadata"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the trigger is enabled for evaluation.",
            "default": true
          },
          "id": {
            "type": "string",
            "description": "The identifier for the trigger.",
            "example": "31vgC5nZS+GI/qGgkJtbiw"
          }
        }
      },
      "Act_TriggerResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Act_Trigger"
          },
          {
            "$ref": "#/components/schemas/Act_AuditTimestamps"
          }
        ]
      },
      "Act_TriggerCriteria": {
        "required": [
          "eventType",
          "matchingConditions"
        ],
        "type": "object",
        "properties": {
          "eventType": {
            "$ref": "#/components/schemas/Act_TriggerEventType"
          },
          "matchingConditions": {
            "minItems": 1,
            "type": "array",
            "description": "Array of the matching conditions.",
            "items": {
              "$ref": "#/components/schemas/Act_MatchingCondition"
            }
          }
        },
        "description": "Array of criteria for the triggers."
      },
      "Act_Action": {
        "required": [
          "name",
          "type"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique identifier",
            "example": "31vgC5nZS+GI/qGgkJtbiw"
          },
          "name": {
            "minLength": 1,
            "type": "string",
            "description": "The name of the action.",
            "example": "Sample Action."
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the action is enabled for evaluation.",
            "default": true
          },
          "metadata": {
            "$ref": "#/components/schemas/Act_Metadata"
          },
          "type": {
            "$ref": "#/components/schemas/Act_ActionType"
          }
        },
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "EMAIL": "#/components/schemas/EmailAction",
            "HTTP_REQUEST": "#/components/schemas/HttpRequestAction"
          }
        }
      },
      "Act_EmailAction": {
        "description": "Email action with action type as EMAIL.",
        "allOf": [
          {
            "$ref": "#/components/schemas/Act_Action"
          },
          {
            "type": "object",
            "required": [
              "to",
              "subject",
              "body"
            ],
            "properties": {
              "to": {
                "$ref": "#/components/schemas/Act_EmailArray"
              },
              "cc": {
                "$ref": "#/components/schemas/Act_EmailArray"
              },
              "bcc": {
                "$ref": "#/components/schemas/Act_EmailArray"
              },
              "subject": {
                "minLength": 1,
                "type": "string",
                "description": "The subject of the email in the action.",
                "example": "Sample Subject"
              },
              "body": {
                "minLength": 1,
                "type": "string",
                "description": "The body of the email in the action.",
                "example": "Sample Email Content"
              },
              "headers": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Act_KeyValuePair"
                }
              },
              "customVariables": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Act_KeyValuePair"
                }
              },
              "smtpConfigurationId": {
                "type": "string",
                "format": "uuid",
                "description": "SMTP configuration ID foreign key."
              }
            }
          }
        ]
      },
      "Act_ActionsListResponse": {
        "required": [
          "items",
          "total"
        ],
        "type": "object",
        "properties": {
          "total": {
            "type": "integer",
            "description": "Count of the items in the list."
          },
          "items": {
            "type": "array",
            "description": "The list of the actions.",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/Act_EmailAction"
                },
                {
                  "$ref": "#/components/schemas/Act_HttpRequestAction"
                }
              ]
            }
          }
        }
      },
      "Act_HttpRequestAction": {
        "description": "HTTP request action with action type HTTP_REQUEST.",
        "allOf": [
          {
            "$ref": "#/components/schemas/Act_Action"
          },
          {
            "type": "object",
            "required": [
              "requestParameters",
              "authentication"
            ],
            "properties": {
              "requestParameters": {
                "$ref": "#/components/schemas/Act_HttpRequestParameters"
              },
              "authentication": {
                "$ref": "#/components/schemas/Act_HttpRequestAuthentication"
              },
              "requestHeaders": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Act_KeyValuePair"
                }
              },
              "requestPayload": {
                "$ref": "#/components/schemas/Act_HttpRequestPayload"
              },
              "successCriteria": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Act_HttpResponseCriteria"
                }
              },
              "failureCriteria": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Act_HttpResponseCriteria"
                }
              },
              "connectionTimeoutMillis": {
                "type": "integer",
                "description": "Maximum connection timeout in milliseconds.",
                "format": "int32",
                "example": 1000,
                "default": 1000
              },
              "socketTimeoutMillis": {
                "type": "integer",
                "description": "Maximum socket timeout in milliseconds.",
                "format": "int32",
                "example": 1000,
                "default": 1000
              },
              "overallTimeoutMillis": {
                "type": "integer",
                "description": "Maximum overall timeout in milliseconds.",
                "format": "int32",
                "example": 1000,
                "default": 2000
              },
              "maxRedirects": {
                "type": "integer",
                "description": "Maximum number of redirects allowed.",
                "format": "int32",
                "example": 5,
                "default": 5
              },
              "customVariables": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Act_KeyValuePair"
                }
              }
            }
          }
        ]
      },
      "Act_HttpResponseCriteria": {
        "required": [
          "statusCode"
        ],
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer",
            "description": "The expected status code.",
            "format": "int32",
            "example": 400
          },
          "expectPayload": {
            "type": "boolean",
            "description": "Flag to control whether to expect payload or not.",
            "example": true,
            "default": false
          },
          "contentType": {
            "type": "string",
            "description": "Payload content type if the payload is expected.",
            "example": "text/html"
          }
        }
      },
      "Act_EmailActionResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Act_EmailAction"
          },
          {
            "$ref": "#/components/schemas/Act_AuditTimestamps"
          }
        ]
      },
      "Act_HttpRequestActionResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Act_HttpRequestAction"
          },
          {
            "$ref": "#/components/schemas/Act_AuditTimestamps"
          }
        ]
      },
      "Act_HttpRequestParameters": {
        "required": [
          "requestType",
          "rawUrl"
        ],
        "type": "object",
        "properties": {
          "requestType": {
            "type": "string",
            "enum": [
              "GET",
              "PUT",
              "POST",
              "DELETE",
              "PATCH"
            ]
          },
          "rawUrl": {
            "minLength": 1,
            "type": "string",
            "description": "The request end point URL."
          },
          "encodingType": {
            "minLength": 1,
            "type": "string",
            "enum": [
              "UTF-8",
              "ISO-8859-1"
            ],
            "description": "The request encoding type.",
            "example": "UTF-8",
            "default": "UTF-8"
          }
        }
      },
      "Act_HttpRequestPayload": {
        "type": "object",
        "properties": {
          "contentType": {
            "minLength": 1,
            "type": "string",
            "description": "The payload content type.",
            "example": "application/json",
            "default": "text/plain"
          },
          "rawPayload": {
            "minLength": 1,
            "type": "string",
            "description": "The raw payload."
          },
          "formData": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Act_KeyValuePair"
            }
          },
          "encodingType": {
            "minLength": 1,
            "type": "string",
            "enum": [
              "UTF-8",
              "ISO-8859-1"
            ],
            "description": "The payload encoding type.",
            "example": "UTF-8",
            "default": "UTF-8"
          }
        }
      },
      "Act_HttpRequestAuthentication": {
        "required": [
          "authenticationType"
        ],
        "type": "object",
        "properties": {
          "authenticationType": {
            "type": "string",
            "description": "The authentication type.",
            "enum": [
              "NONE",
              "BASIC"
            ]
          },
          "username": {
            "type": "string",
            "description": "The username for authentication.",
            "example": "user1"
          },
          "password": {
            "type": "string",
            "description": "The password for authentication.",
            "example": "pass1"
          }
        },
        "description": "The parameters for the HTTP request authentication."
      },
      "Act_ActionType": {
        "type": "string",
        "enum": [
          "EMAIL",
          "HTTP_REQUEST"
        ]
      },
      "Act_KeyValuePair": {
        "type": "object",
        "required": [
