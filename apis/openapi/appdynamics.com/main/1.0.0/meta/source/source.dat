      "AD_ADConfigurationPatchRequest": {
        "type": "object",
        "description": "The AD Configuration",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of AD Configuration",
            "example": "Sample AD Configuration"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether AD Configuration is enabled",
            "default": true
          },
          "testMode": {
            "type": "boolean",
            "description": "Flag to enable/disable TEST sensitivity model for Anomaly Detection.",
            "default": false
          },
          "modelSensitivity": {
            "$ref": "#/components/schemas/AD_ModelSensitivityType"
          }
        }
      },
      "AD_ADConfiguration": {
        "required": [
          "enabled",
          "name",
          "domain",
          "entityTypes",
          "modelSensitivity"
        ],
        "type": "object",
        "description": "The AD Configuration",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string",
            "description": "The name of AD Configuration",
            "example": "Sample AD Configuration"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether AD Configuration is enabled",
            "default": true
          },
          "testMode": {
            "type": "boolean",
            "description": "Flag to enable/disable TEST sensitivity model for Anomaly Detection.",
            "default": false
          },
          "domain": {
            "minLength": 1,
            "type": "string",
            "description": "Domain",
            "enum": [
              "APM",
              "Infra",
              "AWS"
            ]
          },
          "entityTypes": {
            "type": "array",
            "minItems": 1,
            "description": "List of selected entity types.",
            "items": {
              "type": "string",
              "description": "Entity type",
              "example": "apm:service"
            }
          },
          "includeObjectFilter": {
            "type": "string",
            "description": "Include entity filter based on tags/attributes.",
            "example": "entities(apm:service)[attributes(\"service.name\") = 'valhalla']"
          },
          "excludeObjectFilter": {
            "type": "string",
            "description": "Exclude entity filter based on tags/attributes.",
            "example": "entities(apm:service)[attributes(\"service.name\") = 'valhalla']"
          },
          "modelSensitivity": {
            "$ref": "#/components/schemas/AD_ModelSensitivityType"
          }
        }
      },
      "AD_ADConfigurationResponse": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique identifier",
                "example": "31vgC5nZSGIqGgkJtbiw"
              },
              "updatedAt": {
                "description": "Updated time in rfc3339 format",
                "type": "string",
                "format": "date-time"
              },
              "createdAt": {
                "description": "Created time in rfc3339 format",
                "type": "string",
                "format": "date-time"
              }
            }
          },
          {
            "$ref": "#/components/schemas/AD_ADConfiguration"
          }
        ]
      },
