{
  "openapi": "3.0.3",
  "info": {
    "title": "AppDynamics API",
    "version": "1.0.0",
    "description": "Unified AppDynamics API specification covering both Cisco Cloud Native Observability Platform APIs and the classic on-premises Controller REST API.",
    "x-jentic-source-url": "https://docs.appdynamics.com/appd/onprem/latest/en/extend-appdynamics/appdynamics-apis"
  },
  "servers": [
    {
      "url": "https://{controller_host}",
      "variables": {
        "controller_host": {
          "default": "mycompany.saas.appdynamics.com",
          "description": "AppDynamics controller host"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "basicAuth": []
    },
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Cloud-Connections",
      "description": "Cloud Native Application Observability Connections API"
    },
    {
      "name": "Cloud-QueryService",
      "description": "Cisco Observability Platform Query Service API"
    },
    {
      "name": "Cloud-HealthRules",
      "description": "Cisco Observability Platform Health Rules API"
    },
    {
      "name": "Cloud-Actions",
      "description": "Cisco Observability Platform Actions API"
    },
    {
      "name": "Cloud-AnomalyDetection",
      "description": "Cisco Observability Platform Anomaly Detection Configuration API"
    },
    {
      "name": "Classic-Applications",
      "description": "Classic Controller REST API - Application management"
    },
    {
      "name": "Classic-BusinessTransactions",
      "description": "Classic Controller REST API - Business Transaction management"
    },
    {
      "name": "Classic-Tiers",
      "description": "Classic Controller REST API - Tier management"
    },
    {
      "name": "Classic-Nodes",
      "description": "Classic Controller REST API - Node management"
    },
    {
      "name": "Classic-Metrics",
      "description": "Classic Controller REST API - Metric data retrieval"
    },
    {
      "name": "Classic-Events",
      "description": "Classic Controller REST API - Event management"
    },
    {
      "name": "Classic-HealthRules",
      "description": "Classic Controller REST API - Health Rule management"
    },
    {
      "name": "Classic-Actions",
      "description": "Classic Controller REST API - Action management"
    },
    {
      "name": "Classic-Policies",
      "description": "Classic Controller REST API - Policy management"
    },
    {
      "name": "Classic-Snapshots",
      "description": "Classic Controller REST API - Request snapshot management"
    },
    {
      "name": "Classic-Backends",
      "description": "Classic Controller REST API - Backend management"
    },
    {
      "name": "Classic-Dashboards",
      "description": "Classic Controller REST API - Dashboard management"
    },
    {
      "name": "Classic-AlertRespond",
      "description": "Classic Controller REST API - Alerting and Response"
    },
    {
      "name": "Classic-RBAC",
      "description": "Classic Controller REST API - Users, Roles, and Access Control"
    },
    {
      "name": "Classic-Accounts",
      "description": "Classic Controller REST API - Account management"
    },
    {
      "name": "Classic-Configuration",
      "description": "Classic Controller REST API - Controller configuration"
    },
    {
      "name": "Classic-License",
      "description": "Classic Controller REST API - License management"
    },
    {
      "name": "Classic-Audit",
      "description": "Classic Controller REST API - Audit log"
    },
    {
      "name": "Classic-Synthetic",
      "description": "Classic Controller REST API - Synthetic monitoring"
    },
    {
      "name": "Classic-Database",
      "description": "Classic Controller REST API - Database monitoring"
    },
    {
      "name": "Classic-ServerMonitoring",
      "description": "Classic Controller REST API - Server Infrastructure Monitoring"
    }
  ],
  "paths": {
    "/cloud/connections/connections/{connectionId}": {
      "get": {
        "tags": [
          "Cloud-Connections"
        ],
        "summary": "Get a connection",
        "description": "Get an individual connection by ID",
        "operationId": "getConnection",
        "parameters": [
          {
            "name": "connectionId",
            "in": "path",
            "description": "Connection ID",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "7c8c01e3-dc9a-4e7e-a536-7240c62af801"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Requested connection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_ConnectionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "404": {
            "description": "A connection with this ID does not exist",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Cloud-Connections"
        ],
        "summary": "Delete connection",
        "description": "Delete a connection by ID",
        "operationId": "deleteConnection",
        "parameters": [
          {
            "name": "connectionId",
            "in": "path",
            "description": "Connection ID",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "7c8c01e3-dc9a-4e7e-a536-7240c62af801"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Connection successfully deleted"
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "404": {
            "description": "A connection with this ID does not exist",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ]
      },
      "patch": {
        "tags": [
          "Cloud-Connections"
        ],
        "summary": "Update a connection",
        "description": "Update a connection by ID",
        "operationId": "updateConnection",
        "parameters": [
          {
            "name": "connectionId",
            "in": "path",
            "description": "Connection ID",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "7c8c01e3-dc9a-4e7e-a536-7240c62af801"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Conn_ConnectionUpdate"
              },
              "examples": {
                "Update all fields": {
                  "value": {
                    "displayName": "AWS dev",
                    "description": "Description for this connection or configuration",
                    "details": {
                      "roleName": "AppDynamicsMonitoringRole"
                    },
                    "configurationId": "fd7bb1bd-f605-4eac-9ec9-32b7031d4576",
                    "state": "ACTIVE"
                  }
                },
                "Update some fields": {
                  "value": {
                    "description": "A description for this connection",
                    "configurationId": "fd7bb1bd-f605-4eac-9ec9-32b7031d4576"
                  }
                },
                "Update configurationId and activate": {
                  "value": {
                    "configurationId": "7c8c01e3-dc9a-4e7e-a536-7240c62af801",
                    "state": "ACTIVE"
                  }
                },
                "Update configurationId": {
                  "value": {
                    "configurationId": "7c8c01e3-dc9a-4e7e-a536-7240c62af801"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Connection updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_ConnectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "404": {
            "description": "A connection with this ID does not exist",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/cloud/connections/regions": {
      "get": {
        "tags": [
          "Cloud-Connections"
        ],
        "summary": "Get all supported hosting regions",
        "description": "Get all supported hosting regions for a given cloud provider",
        "operationId": "getRegions",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "Cloud hosting provider type",
            "required": true,
            "style": "form",
            "explode": true,
            "schema": {
              "$ref": "#/components/schemas/Conn_ProviderType"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved all supported hosting regions for the given cloud provider",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_ConfigurationResourceList"
                },
                "example": {
                  "items": [
                    {
                      "id": "us-gov-west-1",
                      "displayName": "AWS GovCloud (US)"
                    },
                    {
                      "id": "us-east-1",
                      "displayName": "US East (N. Virginia)"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Conn_Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
    "/cloud/connections/services": {
      "get": {
        "tags": [
          "Cloud-Connections"
        ],
        "summary": "Get all supported hosting services",
