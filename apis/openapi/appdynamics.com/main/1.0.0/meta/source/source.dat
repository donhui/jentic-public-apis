    "/controller/api/oauth/access_token": {
      "post": {
        "summary": "Generate OAuth access token",
        "operationId": "getAccessToken",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "client_credentials"
                    ]
                  },
                  "client_id": {
                    "type": "string",
                    "description": "user@account"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Password or API client secret"
                  }
                },
                "required": [
                  "grant_type",
                  "client_id",
                  "client_secret"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OAuth token response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    },
                    "expires_in": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Classic-Accounts"
        ],
        "security": [
          {
            "basicAuth": []
          },
          {
            "oauthToken": []
          }
        ]
      }
    },
