              "$ref": "#/components/schemas/AD_ADConfigurationBatchProperties"
            }
          }
        }
      },
      "AD_ADConfigurationBatchProperties": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "operation",
              "resource",
              "item"
            ],
            "properties": {
              "operation": {
                "type": "string",
                "description": "Operation to be performed in AD Configuration",
                "enum": [
                  "PATCH"
                ]
              },
              "resource": {
                "type": "string",
                "description": "AD Configuration Resource to be patched",
                "example": "/adConfig/31vgC5nZSGIqGgkJtbiw"
              },
              "item": {
                "$ref": "#/components/schemas/AD_ADConfigurationPatchRequest"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "operation",
              "resource"
            ],
            "properties": {
              "operation": {
                "type": "string",
                "description": "Operation to be performed in AD Configuration",
                "enum": [
                  "DELETE"
                ]
              },
              "resource": {
                "type": "string",
                "description": "AD Configuration Resource to be deleted",
                "example": "/adConfig/31vgC5nZSGIqGgkJtbiw"
              }
            }
          }
        ]
      },
      "AD_ADConfigurtionBatchListResponse": {
        "required": [
          "items",
          "total"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "description": "Response returned for batch operation performed on AD Configuration.",
            "items": {
              "$ref": "#/components/schemas/AD_ADConfigurationBatchResponse"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of AD Configurations on which batch operation are performed.",
            "example": 2
          }
        }
      },
      "AD_ADConfigurationBatchResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AD_ADConfigurationBatchProperties"
          },
          {
            "type": "object",
            "properties": {
              "status": {
                "type": "integer",
                "description": "Response status code for a given AD Configuration resource.",
                "example": 200
              },
              "reason": {
                "description": "Reason in case of failure in operation for a given AD Configuration resource.",
                "type": "string",
                "example": ""
              }
            }
          }
        ]
      },
      "AD_ModelSensitivityType": {
        "type": "string",
        "description": "Possible values are LOW, MEDIUM, HIGH and TEST. LOW - Generate less number of alerts. MEDIUM - Generate moderate number of alerts. HIGH - Generate high number of alerts. TEST - Evaluate AD features without waiting for the actual anomaly to be generated as per set configs.",
        "enum": [
          "LOW",
          "MEDIUM",
          "HIGH",
          "TEST"
        ]
      },
