    "/controller/rest/applications/{appId}/request-snapshots": {
      "get": {
        "summary": "List request snapshots for an application",
        "operationId": "getSnapshots",
        "parameters": [
          {
            "name": "appId",
            "in": "path",
            "required": true,
            "description": "Application ID or name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "guids",
            "in": "query",
            "required": false,
            "description": "Comma-separated snapshot GUIDs",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "business-transaction-ids",
            "in": "query",
            "required": false,
            "description": "Comma-separated BT IDs to filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user-experience",
            "in": "query",
            "required": false,
            "description": "Filter by user experience (NORMAL, SLOW, VERY_SLOW, STALL, ERROR)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "first-in-chain",
            "in": "query",
            "required": false,
            "description": "Only first-in-chain snapshots",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "need-props",
            "in": "query",
            "required": false,
            "description": "Include data collector properties",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "need-exit-calls",
            "in": "query",
            "required": false,
            "description": "Include exit call data",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "maximum-results",
            "in": "query",
            "required": false,
            "description": "Max results to return",
            "schema": {
              "type": "integer",
              "default": 600
            }
          },
          {
            "name": "output",
            "in": "query",
            "required": false,
            "description": "Output format (JSON or XML)",
            "schema": {
              "type": "string",
              "enum": [
                "JSON",
                "XML"
              ],
              "default": "JSON"
            }
          },
          {
            "name": "time-range-type",
            "in": "query",
            "required": false,
            "description": "Time range type",
            "schema": {
              "type": "string",
              "enum": [
                "BEFORE_NOW",
                "BEFORE_TIME",
                "AFTER_TIME",
                "BETWEEN_TIMES"
              ]
            }
          },
          {
            "name": "duration-in-mins",
            "in": "query",
            "required": false,
            "description": "Duration in minutes (for BEFORE_NOW)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "start-time",
            "in": "query",
            "required": false,
            "description": "Start time in Unix epoch milliseconds",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "end-time",
            "in": "query",
            "required": false,
            "description": "End time in Unix epoch milliseconds",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of request snapshots",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Classic_Snapshot"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/Classic_Snapshot"
                }
              }
            }
          }
        },
        "tags": [
          "Classic-Snapshots"
        ],
        "security": [
          {
            "basicAuth": []
          },
          {
            "oauthToken": []
          }
        ]
      }
    },
