    "/cloud/query-service/query/execute": {
      "post": {
        "tags": [
          "Cloud-QueryService"
        ],
        "summary": "Execute a query to fetch observation data.",
        "description": "Execute one or more queries to fetch observation data.",
        "operationId": "executeQuery",
        "parameters": [
          {
            "name": "dryRun",
            "in": "query",
            "description": "Execution plan should not run and call downstream stores",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "requestBody": {
          "description": "A simple JSON object containing a query string.",
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/QS_QueryRequestBody"
                  },
                  {
                    "$ref": "#/components/schemas/QS_BatchedQueryRequestBody"
                  }
                ]
              },
              "examples": {
                "Execute a query": {
                  "description": "Execute a simple query.",
                  "value": {
                    "query": "fetch id: id, name: attributes(service.name), cpm: metrics(apm:response_time) {source, timestamp, min, max} from entities(apm:service)[attributes(service.namespace) = 'Levitate'].out.to(apm:service_instance) since -3h"
                  }
                },
                "Execute a parameterized query": {
                  "description": "Execute a simple query with a parameter.",
                  "value": {
                    "query": "fetch id: id, name: attributes(service.name), cpm: metrics(apm:response_time) {source, timestamp, min, max} from entities(apm:service)[attributes(service.namespace) = $namespace].out.to(apm:service_instance) since -3h",
                    "queryParameters": [
                      {
                        "name": "namespace",
                        "type": "string",
                        "value": "Levitate"
                      }
                    ],
                    "dryRun": false
                  }
                },
                "Execute batched queries": {
                  "description": "Execute multiple queries at the same time with specific parameters for each query.",
                  "value": {
                    "queries": {
                      "customQuery1Identifier": {
                        "query": "FETCH id FROM entities(apm:service_instance)"
                      },
                      "customQuery2Identifier": {
                        "query": "FETCH id FROM entities(apm:service)[attributes(service.namespace) = $namespace]",
                        "queryParameters": [
                          {
                            "name": "namespace",
                            "type": "string",
                            "value": "Levitate"
                          }
                        ]
                      }
                    },
                    "dryRun": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/200"
          },
          "400": {
            "$ref": "#/components/responses/400"
          },
          "403": {
            "$ref": "#/components/responses/403"
          },
          "500": {
            "$ref": "#/components/responses/500"
          },
          "503": {
            "$ref": "#/components/responses/503"
          }
        },
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyAuth": []
          }
        ]
      }
    },
