    "/cloud/actions/triggers": {
      "get": {
        "tags": [
          "Cloud-Actions"
        ],
        "description": "List all the triggers for a given filter",
        "operationId": "getAllTriggers",
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "description": "The filter expression used. Currently, only metadata.applications is supported for key.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "metadata.applications co \"app-cco\""
          },
          {
            "name": "ids",
            "in": "query",
            "description": "The identities (IDs) of the triggers.",
            "schema": {
              "type": "string",
              "example": "60c19ec20557a143600c4cc8,60c19ec20557a143600c4cc9"
            }
          },
          {
            "name": "max",
            "in": "query",
            "description": "Maximum results to fetch.",
            "schema": {
              "type": "integer",
              "maximum": 40,
              "default": 40
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "The cursor ID for the pagination.",
            "schema": {
              "type": "string",
              "example": "I+sfW0V3MDytvVmTm7HtLA"
            }
          },
          {
            "name": "configIds",
            "in": "query",
            "description": "The comma seperated values of identifiers (IDs) for  configurations",
            "schema": {
              "type": "string",
              "example": "75dd5282-daae-49c1-a978-8ef75c20e38a,64da5282-dabe-56c1-a978-7ea77d20e36b"
            }
          },
          {
            "name": "eventType",
            "in": "query",
            "description": "The type of melt event",
            "schema": {
              "type": "string",
              "example": "alerting:healthrule.violation"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response containing a list of triggers.",
            "headers": {
              "Link": {
                "style": "simple",
                "schema": {
                  "type": "string",
                  "example": "</v1beta/triggers?cursor=sfgsrg>; rel=\"next\", </v1beta/triggers?cursor=mjfhku>; rel=\"last\""
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Act_TriggerListResponse"
