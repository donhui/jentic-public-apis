                        "description": "List of passwords to search for",
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "minItems": 1,
                        "maxItems": 50,
                        "example": [
                          "password123",
                          "qwerty"
                        ]
                      }
                    },
                    "required": [
