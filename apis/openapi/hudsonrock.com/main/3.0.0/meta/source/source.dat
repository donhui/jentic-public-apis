    "/search-by-stealer/infection-analysis": {
      "post": {
        "tags": [
          "Investigations"
        ],
        "summary": "Infection Analysis (NEW)",
        "description": "Get infection analysis for a stealer. This endpoint analyzes browser history to identify the likely infection source and infection flow. Currently only supported for stealers where we collect and store browsing history (mainly Lumma).",
        "operationId": "getInfectionAnalysis",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "stealer": {
                    "type": "string",
                    "description": "Stealer ID to get infection analysis for. Currently only supports stealers where we collect browsing history (mainly Lumma stealer)",
                    "example": "[IN]175.101.37.65"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "likely_infection_url": {
                          "type": "string",
                          "description": "URL identified as the most likely infection source",
                          "example": "https://www.mediafire.com/file_premium/psx65h6kf34z9lr/Adobe.Premiere.Pro.2025.v28.3.1.rar/file"
                        },
                        "infection_confidence": {
                          "type": "number",
                          "format": "float",
                          "description": "Confidence score for the infection analysis (0-1)",
                          "example": 0.95
                        },
                        "infection_reasoning": {
                          "type": "string",
                          "description": "Explanation of why the URL was identified as the infection source",
                          "example": "The URL is related to downloading movies and matches a pattern often associated with distributing pirated content, which is known for bundling malware."
                        },
                        "infection_flow": {
                          "type": "array",
                          "description": "Chronological sequence of URLs visited that led to the infection",
                          "items": {
                            "type": "object",
                            "properties": {
                              "timestamp": {
                                "type": "string",
                                "format": "date-time",
                                "description": "Timestamp of the infection event"
                              },
                              "url": {
                                "type": "string",
                                "description": "URL visited during the infection flow"
                              },
                              "notes": {
                                "type": "string",
                                "description": "Analysis notes about this specific URL in the infection chain"
                              }
                            }
                          }
                        },
                        "analyst_summary": {
                          "type": "string",
                          "description": "Concise summary of the infection analysis",
                          "example": "The user likely got infected by visiting 'vegamovies.af', a known site for pirated movie downloads."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "408": {
            "$ref": "#/components/responses/RequestTimeout"
          },
          "429": {
            "$ref": "#/components/responses/RateLimit"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/search-by-domain": {
      "post": {
        "tags": [
          "Domain Intelligence"
        ],
        "summary": "Search by Domains",
        "description": "Search for domain-wide compromises and intelligence",
        "operationId": "searchByDomain",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "title": "Domains",
                    "description": "Search for domain-wide compromises and intelligence",
                    "allOf": [
                      {
                        "type": "object",
                        "required": [
                          "domains"
                        ],
                        "properties": {
                          "domains": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "pattern": "^(((?!-))(xn--|_)?[a-z0-9-]{0,61}[a-z0-9]{1,1}\\.)*",
                              "example": "hpe.com"
                            },
                            "minItems": 1,
                            "maxItems": 50,
                            "example": [
                              "hpe.com"
                            ]
                          },
                          "subdomains": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "example": "auth"
                            },
                            "maxItems": 5,
                            "description": "\ud83d\udd0d Subdomain filters to match against subdomains in the URL field. Maximum 5 items allowed. \u26a0\ufe0f Cannot be used together with 'keywords' or 'keywords_match' parameters - these are mutually exclusive filtering options."
                          }
                        }
                      },
                      {
                        "$ref": "#/components/schemas/CommonParameters"
                      }
                    ]
                  },
                  {
                    "title": "External Domains (for users with whitelisted domains)",
                    "description": "Search for domains outside of your whitelisted domains",
                    "allOf": [
                      {
                        "type": "object",
                        "required": [
                          "external_domains"
                        ],
                        "properties": {
                          "external_domains": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "pattern": "^(((?!-))(xn--|_)?[a-z0-9-]{0,61}[a-z0-9]{1,1}\\.)*",
                              "example": "hpe.salesforce.com"
                            },
                            "minItems": 1,
                            "maxItems": 50,
                            "example": [
                              "hpe.salesforce.com"
                            ],
                            "description": "List of third-party domains associated with your organization to search for. Ideal for SaaS platforms (company.salesforce.com), cloud services, or other external services your organization uses. Limited to 50 domains per request for performance reasons."
                          },
                          "sort_by": {
                            "type": "string",
                            "enum": [
                              "date_compromised",
                              "date_uploaded"
                            ],
                            "example": "date_compromised",
                            "default": "date_compromised",
                            "description": "Field to sort external domain results by. 'date_compromised' sorts by when the infection occurred (best for threat timeline analysis), while 'date_uploaded' sorts by when the data was integrated into our platform (best for monitoring new additions)."
                          },
                          "sort_direction": {
                            "type": "string",
                            "enum": [
                              "asc",
                              "desc"
                            ],
                            "example": "desc",
                            "default": "desc",
                            "description": "Direction to sort external domain results. 'desc' returns newest records first (recommended for monitoring third-party risks), while 'asc' returns oldest records first (useful for establishing breach timelines)."
                          },
                          "filter_credentials": {
                            "type": "boolean",
                            "default": true,
                            "example": true,
                            "description": "Controls credential filtering for external domains. When true, returns only credentials matching the external domains. When false, returns all credentials from matching stealers, which may reveal additional third-party relationships and shadow IT usage."
                          },
                          "cursor": {
                            "type": "string",
                            "description": "Base64 encoded pagination cursor for retrieving the next set of external domain results. Obtained from the 'nextCursor' field in the previous response. Essential for processing results from popular SaaS platforms with many compromises."
                          },
                          "start_date": {
                            "type": "string",
                            "format": "date-time",
                            "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter external domain results from this date/time onward. Applies to the field specified in 'sort_by'. Useful for monitoring third-party risks since a specific date."
                          },
                          "end_date": {
                            "type": "string",
                            "format": "date-time",
                            "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter external domain results up to this date/time. Applies to the field specified in 'sort_by'. Useful for analyzing historical third-party exposures within specific timeframes."
                          },
                          "additional_fields": {
                            "type": "array",
                            "items": {
                              "type": "string",
                              "enum": [
                                "search_data",
                                "installed_software",
                                "employee_session_cookies",
                                "password_strength",
                                "sensitive_applications",
                                "dir_tree"
                              ]
                            },
                            "default": [],
                            "description": "Optional additional data to include in external domain results. 'search_data' adds information about the search terms found in the browsing history search engine results from infected devices. 'installed_software' adds information about software installed on compromised machines, which can help identify vulnerable third-party applications and potential attack vectors. 'employee_session_cookies' adds session cookies from employee credentials, which can help identify active sessions and potential unauthorized access. 'password_strength' adds password strength analysis for each password in the results. 'sensitive_applications' adds information about sensitive applications within the compromised URL structure, based on a predefined list of sensitive apps. 'dir_tree' adds information about the directory tree of the compromised machine, which can help identify potential attack vectors."
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SearchResponse"
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "408": {
            "$ref": "#/components/responses/RequestTimeout"
          },
          "429": {
            "$ref": "#/components/responses/RateLimit"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/search-by-company": {
      "post": {
        "tags": [
          "Domain Intelligence"
        ],
        "summary": "Search by Company",
        "description": "Search for compromises within a specific company's digital assets (domains, APKs, and external domains)",
        "operationId": "searchByCompany",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "type": "object",
                    "required": [
                      "company_id"
                    ],
                    "properties": {
                      "company_id": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]{24}$",
                        "description": "MongoDB ObjectId of the company to search within",
                        "example": "695cebd77ef1529e2862efea"
                      },
                      "company_asset_types": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "enum": [
                            "domains",
                            "apks",
                            "external_domains"
                          ]
                        },
                        "minItems": 1,
                        "description": "\ud83c\udfaf **Asset Type Filter**: Specify which types of company assets to search. If not provided, searches ALL company assets (domains + apks + external_domains). **\u26a0\ufe0f Important**: When searching all assets (default), the 'types' parameter cannot be used due to external_domains having different search logic.",
                        "example": [
                          "domains",
                          "apks"
                        ]
                      },
                      "subdomains": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "maxItems": 5,
                        "description": "Filter by specific subdomains within company domains",
                        "example": [
                          "auth",
                          "admin"
                        ]
                      }
                    }
                  },
                  {
                    "$ref": "#/components/schemas/CommonParameters"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SearchResponse"
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "408": {
            "$ref": "#/components/responses/RequestTimeout"
          },
          "429": {
            "$ref": "#/components/responses/RateLimit"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/search-by-domain/overview": {
      "post": {
        "tags": [
          "Domain Intelligence"
        ],
        "summary": "Domains Overview",
        "description": "Get overview about domain-wide compromises and intelligence",
        "operationId": "getDomainOverview",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domains": {
                    "description": "List of domains to retrieve compromise overview statistics for. Accepts root domains (example.com) and will aggregate data across all subdomains. Between 1-500 domains can be specified per request.",
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^(((?!-))(xn--|_)?[a-z0-9-]{0,61}[a-z0-9]{1,1}\\.)*"
                    },
                    "minItems": 1,
                    "maxItems": 500,
                    "example": [
                      "hpe.com"
                    ]
                  },
                  "min_employees_compromised": {
                    "type": "number",
                    "minimum": 0,
                    "example": 10,
                    "description": "Minimum threshold for employee compromises. Returns only domains with at least this many compromised employee accounts. Useful for filtering out domains with negligible compromise counts."
                  },
                  "max_employees_compromised": {
                    "type": "number",
                    "minimum": 0,
                    "example": 100,
                    "description": "Maximum threshold for employee compromises. Returns only domains with no more than this many compromised employee accounts. Useful for focusing on organizations within specific size ranges."
                  },
                  "min_users_compromised": {
                    "type": "number",
                    "minimum": 0,
                    "example": 5,
                    "description": "Minimum threshold for user compromises. Returns only domains with at least this many compromised user accounts. Helps identify domains with significant consumer impact."
                  },
                  "max_users_compromised": {
                    "type": "number",
                    "minimum": 0,
                    "example": 50,
                    "description": "Maximum threshold for user compromises. Returns only domains with no more than this many compromised user accounts. Helps focus on domains with specific consumer impact ranges."
                  },
                  "last_employee_compromised": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter for domains with employee compromises after this date. Identifies domains with recent corporate breaches."
                  },
                  "last_user_compromised": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter for domains with user compromises after this date. Identifies domains with recent consumer-facing breaches."
                  },
                  "last_employee_uploaded": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter for domains with employee data uploaded after this date. Reflects when the data became available in our system."
                  },
                  "last_user_uploaded": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter for domains with user data uploaded after this date. Reflects when the data became available in our system."
                  },
                  "sort_by": {
                    "type": "string",
                    "enum": [
                      "last_employee_compromised",
                      "last_user_compromised",
                      "last_employee_uploaded",
                      "last_user_uploaded",
                      "compromised_employees",
                      "compromised_users"
                    ],
                    "default": "last_employee_compromised",
                    "description": "Field to sort overview results by. Time-based sorting helps identify recent breaches, while count-based sorting identifies the most severely affected domains."
                  },
                  "sort_direction": {
                    "type": "string",
                    "enum": [
                      "asc",
                      "desc"
                    ],
                    "default": "desc",
                    "description": "Direction to sort overview results. 'desc' prioritizes recent breaches or highest compromise counts (recommended for threat monitoring), while 'asc' shows oldest breaches or lowest counts first."
                  },
                  "cursor": {
                    "type": "string",
                    "description": "Base64 encoded pagination cursor for retrieving the next set of overview results. Obtained from the 'nextCursor' field in the previous response. Essential for processing large domain lists."
                  }
                },
                "required": [
                  "domains"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": {
                            "type": "string",
                            "description": "Unique identifier for the domain"
                          },
                          "domain": {
                            "type": "string",
                            "description": "Domain"
                          },
                          "compromised_employees": {
                            "type": "number",
                            "description": "Number of compromised employees",
                            "example": 25
                          },
                          "compromised_users": {
                            "type": "number",
                            "description": "Number of compromised users",
                            "example": 120
                          },
                          "last_employee_compromised": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Last employee compromised date"
                          },
                          "last_user_compromised": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Last user compromised date"
                          },
                          "last_employee_uploaded": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Last employee uploaded date"
                          },
                          "last_user_uploaded": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Last user uploaded date"
                          },
                          "sensitive_applications": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "description": "Identifies sensitive applications within the compromised URL structure, based on a predefined list of sensitive apps."
                          }
                        }
                      }
                    },
                    "nextCursor": {
                      "type": "string",
                      "description": "Base64 encoded cursor for the next page"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "408": {
            "$ref": "#/components/responses/RequestTimeout"
          },
          "429": {
            "$ref": "#/components/responses/RateLimit"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/search-by-domain/discovery": {
      "post": {
        "tags": [
          "Domain Intelligence"
        ],
        "summary": "Assets Discovery",
        "description": "Perform a discovery search to identify potential compromises.",
        "operationId": "discovery",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domains": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^(((?!-))(xn--|_)?[a-z0-9-]{0,61}[a-z0-9]{1,1}\\.)*"
                    },
                    "minItems": 1,
                    "maxItems": 500,
                    "example": [
                      "hpe.com"
                    ],
                    "description": "List of domains to perform discovery on. Accepts root domains (example.com) and will match all subdomains. Between 1-500 domains can be specified per request. For large organizations, consider batching domains across multiple requests."
                  },
                  "types": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "employees",
                        "users"
                      ]
                    },
                    "default": [
                      "employees",
                      "users"
                    ],
                    "description": "Types of compromises to discover. 'employees' finds corporate email credentials (@company.com), while 'users' finds consumer credentials. Default includes both types for comprehensive discovery."
                  },
                  "cursor": {
                    "type": "string",
                    "description": "Base64 encoded pagination cursor for retrieving the next set of results. Obtained from the 'nextCursor' field in the previous response. Essential for processing large discovery results that span multiple pages."
                  },
                  "keywords": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Optional keywords to narrow discovery results to specific services or applications. Examples include ['vpn', 'admin', 'portal'] for critical infrastructure or ['salesforce', 'workday', 'office365'] for SaaS applications."
                  },
                  "keywords_match": {
                    "type": "string",
                    "enum": [
                      "any",
                      "all"
                    ],
                    "example": "any",
                    "description": "Determines how multiple keywords are matched during discovery. 'any' returns results matching at least one keyword (broader discovery), while 'all' requires all keywords to match (targeted discovery for specific services)."
                  }
                },
                "required": [
                  "domains"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/DiscoveryResponse"
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "408": {
            "$ref": "#/components/responses/RequestTimeout"
          },
          "429": {
            "$ref": "#/components/responses/RateLimit"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/search-by-domain/assessment": {
