      }
    },
    "/my-account": {
      "get": {
        "tags": [
          "Account Management"
        ],
        "summary": "Get Account Information",
        "description": "Retrieve current user's account information based on API key authentication",
        "operationId": "getMyAccount",
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "User's full name",
                      "example": "John Doe"
                    },
                    "email": {
                      "type": "string",
                      "format": "email",
                      "description": "User's email address",
                      "example": "john.doe@company.com"
                    },
                    "companies": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "List of companies (only present if user has companies configured)"
                    },
                    "domains": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "List of domains (only present if user doesn't have companies)"
                    },
                    "external_domains": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "List of external domains (only present if user doesn't have companies)"
                    },
                    "apps": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "List of apps (only present if user doesn't have companies)"
                    },
                    "alert_emails": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "format": "email"
                      },
                      "description": "List of email addresses for alerts"
                    },
                    "date_created": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Account creation date"
                    },
                    "permissions": {
                      "type": "object",
                      "description": "User's API permissions organized by category",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "label": {
                              "type": "string",
                              "example": "Data Access Permissions"
                            },
                            "permissions": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string"
                                  },
                                  "label": {
                                    "type": "string"
                                  },
                                  "description": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          }
                        },
                        "search": {
                          "type": "object",
                          "properties": {
                            "label": {
                              "type": "string",
                              "example": "Search Endpoint Permissions"
                            },
                            "permissions": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string"
                                  },
                                  "label": {
                                    "type": "string"
                                  },
                                  "description": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          }
                        },
                        "visibility": {
                          "type": "object",
                          "properties": {
                            "label": {
                              "type": "string",
                              "example": "Field Visibility Permissions"
                            },
                            "permissions": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "description": "Array of field names the user can access"
                            }
                          }
                        },
                        "filtering": {
                          "type": "object",
                          "properties": {
                            "label": {
                              "type": "string",
                              "example": "Filtering & Scope Controls"
                            },
                            "permissions": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string"
                                  },
                                  "label": {
                                    "type": "string"
                                  },
                                  "description": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "name",
                    "email",
                    "alert_emails",
                    "date_created"
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  }
