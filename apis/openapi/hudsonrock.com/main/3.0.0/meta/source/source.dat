    "/advanced-search": {
      "post": {
        "tags": [
          "Advanced Search"
        ],
        "summary": "Advanced Search",
        "description": "Perform an advanced search to identify potential compromises with multiple filters (domains, employees, users, last compromised, last uploaded, company size, industry, country).",
        "operationId": "advancedSearch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "domains": {
                    "description": "List of domains to search for. Accepts root domains (example.com) and will aggregate data across all subdomains. Between 1-500 domains can be specified per request.",
                    "type": "array",
                    "items": {
                      "type": "string",
                      "pattern": "^(((?!-))(xn--|_)?[a-z0-9-]{0,61}[a-z0-9]{1,1}\\.)*"
                    },
                    "minItems": 1,
                    "maxItems": 500,
                    "example": [
                      "hpe.com"
                    ]
                  },
                  "min_employees_compromised": {
                    "type": "number",
                    "minimum": 0,
                    "example": 10,
                    "description": "Minimum threshold for employee compromises. Returns only domains with at least this many compromised employee accounts. Useful for filtering out domains with negligible compromise counts."
                  },
                  "max_employees_compromised": {
                    "type": "number",
                    "minimum": 0,
                    "example": 100,
                    "description": "Maximum threshold for employee compromises. Returns only domains with no more than this many compromised employee accounts. Useful for focusing on organizations within specific size ranges."
                  },
                  "min_users_compromised": {
                    "type": "number",
                    "minimum": 0,
                    "example": 5,
                    "description": "Minimum threshold for user compromises. Returns only domains with at least this many compromised user accounts. Helps identify domains with significant consumer impact."
                  },
                  "max_users_compromised": {
                    "type": "number",
                    "minimum": 0,
                    "example": 50,
                    "description": "Maximum threshold for user compromises. Returns only domains with no more than this many compromised user accounts. Helps focus on domains with specific consumer impact ranges."
                  },
                  "last_employee_compromised": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter for domains with employee compromises after this date. Identifies domains with recent corporate breaches."
                  },
                  "last_user_compromised": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter for domains with user compromises after this date. Identifies domains with recent consumer-facing breaches."
                  },
                  "last_employee_uploaded": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter for domains with employee data uploaded after this date. Reflects when the data became available in our system."
                  },
                  "last_user_uploaded": {
                    "type": "string",
                    "format": "date-time",
                    "description": "ISO 8601 formatted timestamp (YYYY-MM-DDThh:mm:ssZ) to filter for domains with user data uploaded after this date. Reflects when the data became available in our system."
                  },
                  "company_sizes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of company sizes to filter for. Accepts 1-10, 11-50, 51-200, 201-500, 501-1000, 1001-5000, 5001-10000, 10001+."
                  },
                  "industries": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of industries to filter for. Accepts 147 industries - list can be found at https://api.hudsonrock.com/company-filters.json"
                  },
                  "countries": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of countries to filter for. Accepts 247 countries - list can be found at https://api.hudsonrock.com/company-filters.json"
                  },
                  "usa_regions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of USA regions to filter for. Accepts 57 regions - list can be found at https://api.hudsonrock.com/company-filters.json"
                  },
                  "sort_by": {
                    "type": "string",
                    "enum": [
                      "last_employee_compromised",
                      "last_user_compromised",
                      "last_employee_uploaded",
                      "last_user_uploaded",
                      "compromised_employees",
                      "compromised_users"
                    ],
                    "default": "last_employee_compromised",
                    "description": "Field to sort overview results by. Time-based sorting helps identify recent breaches, while count-based sorting identifies the most severely affected domains."
                  },
                  "sort_direction": {
                    "type": "string",
                    "enum": [
                      "asc",
                      "desc"
                    ],
                    "default": "desc",
                    "description": "Direction to sort overview results. 'desc' prioritizes recent breaches or highest compromise counts (recommended for threat monitoring), while 'asc' shows oldest breaches or lowest counts first."
                  },
                  "cursor": {
                    "type": "string",
                    "description": "Base64 encoded pagination cursor for retrieving the next set of overview results. Obtained from the 'nextCursor' field in the previous response. Essential for processing large domain lists."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": {
                            "type": "string",
                            "description": "Unique identifier for the domain"
                          },
                          "domain": {
                            "type": "string",
                            "description": "Domain"
                          },
                          "compromised_employees": {
                            "type": "number",
                            "description": "Number of compromised employees",
                            "example": 25
                          },
                          "compromised_users": {
                            "type": "number",
                            "description": "Number of compromised users",
                            "example": 120
                          },
                          "last_employee_compromised": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Last employee compromised date"
                          },
                          "last_user_compromised": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Last user compromised date"
                          },
                          "last_employee_uploaded": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Last employee uploaded date"
                          },
                          "last_user_uploaded": {
                            "type": "string",
                            "format": "date-time",
                            "description": "Last user uploaded date"
                          },
                          "company_size": {
                            "type": "string",
                            "description": "Company size"
                          },
                          "industry": {
                            "type": "string",
                            "description": "Industry"
                          },
                          "country": {
                            "type": "string",
                            "description": "Country"
                          },
                          "sensitive_applications": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "description": "Identifies sensitive applications within the compromised URL structure, based on a predefined list of sensitive apps."
                          }
                        }
                      }
                    },
                    "nextCursor": {
                      "type": "string",
                      "description": "Base64 encoded cursor for the next page"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
