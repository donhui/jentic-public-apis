{
  "openapi": "3.0.3",
  "info": {
    "title": "pretix API",
    "description": "pretix ticketing platform REST API for managing organizers, events, orders, and related resources.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.pretix.eu/en/latest/api/index.html"
  },
  "servers": [
    {
      "url": "https://pretix.eu/api/v1",
      "description": "pretix API server"
    }
  ],
  "paths": {
    "/organizers/": {
      "get": {
        "operationId": "listOrganizers",
        "summary": "List all organizers",
        "tags": ["Organizers"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "ordering", "in": "query", "schema": { "type": "string", "enum": ["slug", "name"] } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of organizers",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedOrganizerList" }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/organizers/{organizer}/": {
      "get": {
        "operationId": "getOrganizer",
        "summary": "Get organizer details",
        "tags": ["Organizers"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" }
        ],
        "responses": {
          "200": {
            "description": "Organizer details",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Organizer" } }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "patch": {
        "operationId": "updateOrganizer",
        "summary": "Update organizer",
        "tags": ["Organizers"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "plugins": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated organizer",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Organizer" } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/settings/": {
      "get": {
        "operationId": "getOrganizerSettings",
        "summary": "Get organizer settings",
        "tags": ["Organizers"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "name": "explain", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Settings key-value pairs",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "patch": {
        "operationId": "updateOrganizerSettings",
        "summary": "Update organizer settings",
        "tags": ["Organizers"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated settings",
            "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/": {
      "get": {
        "operationId": "listEvents",
        "summary": "List events",
        "tags": ["Events"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "is_public", "in": "query", "schema": { "type": "boolean" } },
          { "name": "live", "in": "query", "schema": { "type": "boolean" } },
          { "name": "testmode", "in": "query", "schema": { "type": "boolean" } },
          { "name": "has_subevents", "in": "query", "schema": { "type": "boolean" } },
          { "name": "is_future", "in": "query", "schema": { "type": "boolean" } },
          { "name": "is_past", "in": "query", "schema": { "type": "boolean" } },
          { "name": "ordering", "in": "query", "schema": { "type": "string", "enum": ["date_from", "slug"] } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of events",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedEventList" } }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "post": {
        "operationId": "createEvent",
        "summary": "Create an event",
        "tags": ["Events"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "name": "clone_from", "in": "query", "schema": { "type": "string" }, "description": "Clone from event slug" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/EventInput" } }
          }
        },
        "responses": {
          "201": {
            "description": "Event created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Event" } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/": {
      "get": {
        "operationId": "getEvent",
        "summary": "Get event details",
        "tags": ["Events"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" }
        ],
        "responses": {
          "200": {
            "description": "Event details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Event" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "patch": {
        "operationId": "updateEvent",
        "summary": "Update event",
        "tags": ["Events"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/EventInput" } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated event",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Event" } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "operationId": "deleteEvent",
        "summary": "Delete event",
        "tags": ["Events"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" }
        ],
        "responses": {
          "204": { "description": "Event deleted" },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/clone/": {
      "post": {
        "operationId": "cloneEvent",
        "summary": "Clone an event",
        "tags": ["Events"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/EventInput" } }
          }
        },
        "responses": {
          "201": {
            "description": "Event cloned",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Event" } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/settings/": {
      "get": {
        "operationId": "getEventSettings",
        "summary": "Get event settings",
        "tags": ["Events"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "name": "explain", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Event settings",
            "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "patch": {
        "operationId": "updateEventSettings",
        "summary": "Update event settings",
        "tags": ["Events"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "type": "object", "additionalProperties": true } }
          }
        },
        "responses": {
          "200": {
            "description": "Updated settings",
            "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/orders/": {
      "get": {
        "operationId": "listOrders",
        "summary": "List orders",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["n", "p", "e", "c"] } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "email", "in": "query", "schema": { "type": "string" } },
          { "name": "testmode", "in": "query", "schema": { "type": "boolean" } },
          { "name": "modified_since", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "ordering", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of orders",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedOrderList" } }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "post": {
        "operationId": "createOrder",
        "summary": "Create an order",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/OrderInput" } }
          }
        },
        "responses": {
          "201": {
            "description": "Order created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/orders/{code}/": {
      "get": {
        "operationId": "getOrder",
        "summary": "Get order details",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "$ref": "#/components/parameters/OrderCode" }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "patch": {
        "operationId": "updateOrder",
        "summary": "Update order",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "$ref": "#/components/parameters/OrderCode" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "phone": { "type": "string" },
                  "locale": { "type": "string" },
                  "comment": { "type": "string" },
                  "checkin_attention": { "type": "boolean" },
                  "checkin_text": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated order",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "operationId": "deleteOrder",
        "summary": "Delete order (testmode only)",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "$ref": "#/components/parameters/OrderCode" }
        ],
        "responses": {
          "204": { "description": "Order deleted" },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/orders/{code}/mark_paid/": {
      "post": {
        "operationId": "markOrderPaid",
        "summary": "Mark order as paid",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "$ref": "#/components/parameters/OrderCode" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "send_email": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order marked as paid",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "400": {
            "description": "Invalid state transition",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/orders/{code}/mark_canceled/": {
      "post": {
        "operationId": "markOrderCanceled",
        "summary": "Cancel order",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "$ref": "#/components/parameters/OrderCode" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "send_email": { "type": "boolean" },
                  "comment": { "type": "string" },
                  "cancellation_fee": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order canceled",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "400": {
            "description": "Invalid state transition",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/orders/{code}/reactivate/": {
      "post": {
        "operationId": "reactivateOrder",
        "summary": "Reactivate canceled order",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "$ref": "#/components/parameters/OrderCode" }
        ],
        "responses": {
          "200": {
            "description": "Order reactivated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "400": {
            "description": "Invalid state transition",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/orders/{code}/approve/": {
      "post": {
        "operationId": "approveOrder",
        "summary": "Approve order pending approval",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "$ref": "#/components/parameters/OrderCode" }
        ],
        "responses": {
          "200": {
            "description": "Order approved",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "400": {
            "description": "Invalid state",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/orders/{code}/deny/": {
      "post": {
        "operationId": "denyOrder",
        "summary": "Deny order pending approval",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "$ref": "#/components/parameters/OrderCode" }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "send_email": { "type": "boolean" },
                  "comment": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order denied",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "400": {
            "description": "Invalid state",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/orders/{code}/extend/": {
      "post": {
        "operationId": "extendOrder",
        "summary": "Extend order payment deadline",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "$ref": "#/components/parameters/OrderCode" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["expires"],
                "properties": {
                  "expires": { "type": "string", "format": "date" },
                  "force": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order extended",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/organizers/{organizer}/events/{event}/orderpositions/": {
      "get": {
        "operationId": "listOrderPositions",
        "summary": "List order positions",
        "tags": ["Orders"],
        "parameters": [
          { "$ref": "#/components/parameters/Organizer" },
          { "$ref": "#/components/parameters/Event" },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "schema": { "type": "string" } },
          { "name": "item", "in": "query", "schema": { "type": "integer" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of order positions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedList"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
