{
  "openapi": "3.0.3",
  "info": {
    "title": "The Old Reader API",
    "version": "1.0.0",
    "description": "A Google Reader-compatible RSS reader API with authentication, subscriptions, items, folders, friends, and comments management.",
    "x-jentic-source-url": "https://github.com/theoldreader/api"
  },
  "servers": [
    {
      "url": "https://theoldreader.com"
    }
  ],
  "paths": {
    "/accounts/ClientLogin": {
      "post": {
        "operationId": "clientLogin",
        "summary": "Authenticate and obtain auth token",
        "description": "Authenticate with email and password to receive an auth token for subsequent API calls.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["client", "Email", "Passwd", "accountType"],
                "properties": {
                  "client": { "type": "string", "description": "Application name" },
                  "Email": { "type": "string", "description": "User email" },
                  "Passwd": { "type": "string", "description": "User password" },
                  "accountType": { "type": "string", "enum": ["HOSTED_OR_GOOGLE"] },
                  "output": { "type": "string", "enum": ["json"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Authentication successful", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/reader/api/0/token": {
      "get": {
        "operationId": "getToken",
        "summary": "Get authentication token",
        "tags": ["Authentication"],
        "responses": {
          "200": { "description": "Token value", "content": { "text/plain": { "schema": { "type": "string" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/user-info": {
      "get": {
        "operationId": "getUserInfo",
        "summary": "Get authenticated user details",
        "tags": ["User"],
        "parameters": [
          { "name": "output", "in": "query", "schema": { "type": "string", "enum": ["json"] } }
        ],
        "responses": {
          "200": { "description": "User info", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserInfo" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/status": {
      "get": {
        "operationId": "getStatus",
        "summary": "Check API status",
        "tags": ["Status"],
        "parameters": [
          { "name": "output", "in": "query", "schema": { "type": "string", "enum": ["json"] } }
        ],
        "responses": {
          "200": { "description": "API status", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatusResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/subscription/list": {
      "get": {
        "operationId": "listSubscriptions",
        "summary": "List all subscriptions",
        "tags": ["Subscriptions"],
        "parameters": [
          { "name": "output", "in": "query", "schema": { "type": "string", "enum": ["json"] } }
        ],
        "responses": {
          "200": { "description": "List of subscriptions", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SubscriptionList" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/subscription/quickadd": {
      "post": {
        "operationId": "addSubscription",
        "summary": "Add a subscription",
        "tags": ["Subscriptions"],
        "parameters": [
          { "name": "quickadd", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Feed URL or search query" }
        ],
        "responses": {
          "200": { "description": "Subscription added", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/QuickAddResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/subscription/edit": {
      "post": {
        "operationId": "editSubscription",
        "summary": "Edit a subscription",
        "tags": ["Subscriptions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["ac", "s"],
                "properties": {
                  "ac": { "type": "string", "enum": ["subscribe", "unsubscribe", "edit"], "description": "Action" },
                  "s": { "type": "string", "description": "Stream ID" },
                  "t": { "type": "string", "description": "Title" },
                  "a": { "type": "string", "description": "Add to folder" },
                  "r": { "type": "string", "description": "Remove from folder" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Subscription edited" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/unread-count": {
      "get": {
        "operationId": "getUnreadCount",
        "summary": "Get unread counts",
        "tags": ["Items"],
        "parameters": [
          { "name": "output", "in": "query", "schema": { "type": "string", "enum": ["json"] } }
        ],
        "responses": {
          "200": { "description": "Unread counts", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/stream/items/ids": {
      "get": {
        "operationId": "getStreamItemIds",
        "summary": "Get item IDs for a stream",
        "tags": ["Items"],
        "parameters": [
          { "name": "s", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Stream ID" },
          { "name": "n", "in": "query", "schema": { "type": "integer", "default": 20, "maximum": 10000 }, "description": "Number of items" },
          { "name": "r", "in": "query", "schema": { "type": "string" }, "description": "Sort order (o for oldest first)" },
          { "name": "c", "in": "query", "schema": { "type": "string" }, "description": "Continuation token" },
          { "name": "xt", "in": "query", "schema": { "type": "string" }, "description": "Exclude stream" },
          { "name": "nt", "in": "query", "schema": { "type": "integer" }, "description": "Newer than timestamp" },
          { "name": "ot", "in": "query", "schema": { "type": "integer" }, "description": "Older than timestamp" },
          { "name": "output", "in": "query", "schema": { "type": "string", "enum": ["json"] } }
        ],
        "responses": {
          "200": { "description": "Item IDs", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ItemIdsResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/stream/items/contents": {
      "post": {
        "operationId": "getStreamItemContents",
        "summary": "Get item contents",
        "tags": ["Items"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["i"],
                "properties": {
                  "i": { "type": "array", "items": { "type": "string" }, "description": "Item IDs (max 1000)" },
                  "output": { "type": "string", "enum": ["json"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Item contents", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ItemContentsResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/stream/contents": {
      "get": {
        "operationId": "getStreamContents",
        "summary": "Get stream contents",
        "tags": ["Items"],
        "parameters": [
          { "name": "s", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Stream ID" },
          { "name": "n", "in": "query", "schema": { "type": "integer", "default": 20 }, "description": "Number of items" },
          { "name": "r", "in": "query", "schema": { "type": "string" }, "description": "Sort order" },
          { "name": "c", "in": "query", "schema": { "type": "string" }, "description": "Continuation token" },
          { "name": "xt", "in": "query", "schema": { "type": "string" }, "description": "Exclude stream" },
          { "name": "nt", "in": "query", "schema": { "type": "integer" }, "description": "Newer than timestamp" },
          { "name": "ot", "in": "query", "schema": { "type": "integer" }, "description": "Older than timestamp" },
          { "name": "output", "in": "query", "schema": { "type": "string", "enum": ["json"] } }
        ],
        "responses": {
          "200": { "description": "Stream contents with full items", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ItemContentsResponse" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/tag/list": {
      "get": {
        "operationId": "listTags",
        "summary": "List folders/tags",
        "tags": ["Folders"],
        "parameters": [
          { "name": "output", "in": "query", "schema": { "type": "string", "enum": ["json"] } }
        ],
        "responses": {
          "200": { "description": "List of tags/folders", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/rename-tag": {
      "post": {
        "operationId": "renameTag",
        "summary": "Rename a folder",
        "tags": ["Folders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["s", "dest"],
                "properties": {
                  "s": { "type": "string", "description": "Current tag/folder ID" },
                  "dest": { "type": "string", "description": "New name" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Folder renamed" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/disable-tag": {
      "post": {
        "operationId": "deleteTag",
        "summary": "Delete a folder",
        "tags": ["Folders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["s"],
                "properties": {
                  "s": { "type": "string", "description": "Tag/folder ID to delete" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Folder deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/mark-all-as-read": {
      "post": {
        "operationId": "markAllAsRead",
        "summary": "Mark stream items as read",
        "tags": ["Items"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["s"],
                "properties": {
                  "s": { "type": "string", "description": "Stream ID" },
                  "ts": { "type": "string", "description": "Timestamp cutoff" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Items marked as read" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/edit-tag": {
      "post": {
        "operationId": "editTag",
        "summary": "Update item read/starred states",
        "tags": ["Items"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["i"],
                "properties": {
                  "i": { "type": "array", "items": { "type": "string" }, "description": "Item IDs" },
                  "a": { "type": "string", "description": "State to add" },
                  "r": { "type": "string", "description": "State to remove" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Tags updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/friend/list": {
      "get": {
        "operationId": "listFriends",
        "summary": "Get friends list",
        "tags": ["Friends"],
        "parameters": [
          { "name": "output", "in": "query", "schema": { "type": "string", "enum": ["json"] } }
        ],
        "responses": {
          "200": { "description": "Friends list", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reader/api/0/friend/edit": {
      "post": {
        "operationId": "editFriend",
        "summary": "Follow or unfollow a friend",
        "tags": ["Friends"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["action", "u"],
                "properties": {
                  "action": { "type": "string", "enum": ["follow", "unfollow"] },
                  "u": { "type": "string", "description": "User ID" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Friend relationship updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "SID": { "type": "string" },
          "LSID": { "type": "string" },
          "Auth": { "type": "string", "description": "Auth token to use for subsequent requests" }
        }
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "userName": { "type": "string" },
          "userProfileId": { "type": "string" },
          "userEmail": { "type": "string" },
          "isPremium": { "type": "boolean" }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["up", "down"] },
          "description": { "type": "string" },
          "redirect": { "type": "string" }
        }
      },
      "SubscriptionList": {
        "type": "object",
        "properties": {
          "subscriptions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Subscription" }
          }
        }
      },
      "Subscription": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "htmlUrl": { "type": "string", "format": "uri" },
          "iconUrl": { "type": "string", "format": "uri" },
          "categories": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "label": { "type": "string" } } } }
        }
      },
      "QuickAddResponse": {
        "type": "object",
        "properties": {
          "numResults": { "type": "integer" },
          "streamId": { "type": "string" },
          "error": { "type": "string" }
        }
      },
      "ItemIdsResponse": {
        "type": "object",
        "properties": {
          "itemRefs": {
            "type": "array",
            "items": { "type": "object", "properties": { "id": { "type": "string" } } }
          },
          "continuation": { "type": "string" }
        }
      },
      "ItemContentsResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Item" }
          },
          "continuation": { "type": "string" }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "published": { "type": "integer" },
          "updated": { "type": "integer" },
          "canonical": { "type": "array", "items": { "type": "object", "properties": { "href": { "type": "string" } } } },
          "summary": { "type": "object", "properties": { "content": { "type": "string" } } },
          "author": { "type": "string" },
          "origin": { "type": "object", "properties": { "streamId": { "type": "string" }, "title": { "type": "string" }, "htmlUrl": { "type": "string" } } },
          "categories": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "securitySchemes": {
      "googleLogin": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "GoogleLogin auth=TOKEN"
      }
    }
  },
  "security": [
    {
      "googleLogin": []
    }
  ]
}
