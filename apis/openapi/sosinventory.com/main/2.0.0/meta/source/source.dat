{
  "openapi": "3.0.3",
  "info": {
    "title": "SOS Inventory API",
    "version": "2.0.0",
    "description": "SOS Inventory is a cloud-based inventory management system that provides APIs for managing inventory, orders, customers, vendors, and more.",
    "x-jentic-source-url": "https://developer.sosinventory.com",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.sosinventory.com",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://api.sosinventory.com/oauth2/authorize",
            "tokenUrl": "https://api.sosinventory.com/oauth2/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "sku": {
            "type": "string",
            "description": "Stock keeping unit"
          },
          "description": {
            "type": "string"
          },
          "syncToken": {
            "type": "string",
            "description": "Sync token for optimistic concurrency control"
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "Vendor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "number": {
            "type": "string"
          },
          "customerId": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "SalesOrder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "number": {
            "type": "string"
          },
          "customerId": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "PurchaseOrder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "number": {
            "type": "string"
          },
          "vendorId": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "Estimate": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "SalesReceipt": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "Shipment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "PickTicket": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "Adjustment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "Transfer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "syncToken": {
            "type": "string"
          }
        }
      },
      "Build": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "syncToken": {
            "type": "string"
          }
        }
