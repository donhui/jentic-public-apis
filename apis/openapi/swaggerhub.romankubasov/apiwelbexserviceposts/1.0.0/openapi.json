{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "API Welbex Service Posts",
    "description": "Welbex Test Assignment",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/ROMANKUBASOV/APIWelbexServicePosts/1.0.0/swagger.json"
  },
  "paths": {
    "/posts": {
      "get": {
        "tags": [
          "posts"
        ],
        "summary": "get all posts",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "description": "JWToken received after login/registration",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "$ref": "#/definitions/posts"
            }
          },
          "500": {
            "description": "Server error"
          }
        }
      },
      "post": {
        "tags": [
          "posts"
        ],
        "summary": "create new post (authorized users only)",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "description": "JWToken received after login/registration",
            "required": true
          },
          {
            "in": "body",
            "name": "body",
            "description": "post (text) to add",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "post": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "JWT_auth": []
          }
        ]
      },
      "put": {
        "tags": [
          "posts"
        ],
        "summary": "edit post (authorized users only)",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "description": "JWToken received after login/registration",
            "required": true
          },
          {
            "in": "body",
            "name": "body",
            "description": "post ID to edit and new post (text)",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64"
                },
                "post": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "The post does not belong to the User"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "JWT_auth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "posts"
        ],
        "summary": "delete post (authorized users only)",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "description": "JWToken received after login/registration",
            "required": true
          },
          {
            "in": "body",
            "name": "body",
            "description": "post ID to delete",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "description": "The post does not belong to the User"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "JWT_auth": []
          }
        ]
      }
    }
  },
  "securityDefinitions": {
    "JWT_auth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "definitions": {
    "posts": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64"
        },
        "login": {
          "type": "string"
        },
        "post": {
          "type": "string"
        },
        "user_id": {
          "type": "integer",
          "format": "int64"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}