{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "API Welbex Service Users",
    "description": "Welbex Test Assignment",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/ROMANKUBASOV/APIWelbexServiceUsers/1.0.0/swagger.json"
  },
  "paths": {
    "/register": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "register new user",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "new user login (must be unique), email and pass",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "login": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "pass": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "object",
              "properties": {
                "accesstoken": {
                  "type": "string"
                }
              }
            }
          },
          "201": {
            "description": "User with this login already exists"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "login user",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "user login and pass",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "login": {
                  "type": "string"
                },
                "pass": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "object",
              "properties": {
                "accesstoken": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Login is incorrect"
          },
          "401": {
            "description": "Password is incorrect"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/logout": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "logout user (authorized users only)",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "description": "JWToken received after login/registration",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Success. Token destroyed"
          },
          "402": {
            "description": "Token not found"
          },
          "403": {
            "description": "Token is incorrect"
          },
          "405": {
            "description": "Error. Token is still active"
          }
        },
        "security": [
          {
            "JWT_auth": []
          }
        ]
      }
    },
    "/auth": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "check validity of token and return User",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "description": "JWToken received after login/registration",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64"
                },
                "login": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "role_id": {
                  "type": "integer",
                  "format": "int64"
                }
              }
            }
          },
          "402": {
            "description": "Token not found"
          },
          "403": {
            "description": "Token is incorrect"
          },
          "500": {
            "description": "Server error"
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": [
          "users"
        ],
        "summary": "get all users (ADMIN only)",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "description": "JWToken received after login/registration",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64"
                },
                "login": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                }
              }
            }
          },
          "402": {
            "description": "Token not found"
          },
          "403": {
            "description": "Access denied"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "JWT_auth": []
          }
        ]
      },
      "put": {
        "tags": [
          "users"
        ],
        "summary": "edit user email (ADMIN only)",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "description": "JWToken received after login/registration",
            "required": true
          },
          {
            "in": "body",
            "name": "body",
            "description": "ID of user to change email, new email",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64"
                },
                "email": {
                  "type": "string"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully changed email"
          },
          "400": {
            "description": "User with this id not found"
          },
          "402": {
            "description": "Token not found"
          },
          "403": {
            "description": "Access denied"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "JWT_auth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "users"
        ],
        "summary": "delete user (ADMIN only)",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "description": "JWToken received after login/registration",
            "required": true
          },
          {
            "in": "body",
            "name": "body",
            "description": "ID of user to delete",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "format": "int64"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully changed email"
          },
          "400": {
            "description": "User with this id not found"
          },
          "401": {
            "description": "It's prohibited to remove Admin"
          },
          "402": {
            "description": "Token not found"
          },
          "403": {
            "description": "Access denied"
          },
          "500": {
            "description": "Server error"
          }
        },
        "security": [
          {
            "JWT_auth": []
          }
        ]
      }
    }
  },
  "securityDefinitions": {
    "JWT_auth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header"
    }
  },
  "definitions": {
    "users": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64"
        },
        "login": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "pass": {
          "type": "string"
        },
        "role_id": {
          "type": "integer",
          "format": "int64"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "roles": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64"
        },
        "role": {
          "type": "string"
        }
      }
    }
  }
}