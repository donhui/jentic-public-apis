                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "201": {
            "description": "User with this login already exists"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "login": {
                    "type": "string"
                  },
                  "pass": {
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "description": "new user login (must be unique), email and pass",
          "required": true
        },
        "summary": "register new user"
      }
