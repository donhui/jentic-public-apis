  "servers": [],
  "paths": {
    "/auth": {
      "post": {
        "parameters": [
          {
            "description": "JWToken received after login/registration",
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "email": {
                      "type": "string"
                    },
                    "id": {
                      "format": "int64",
                      "type": "integer"
                    },
                    "login": {
                      "type": "string"
                    },
                    "role_id": {
                      "format": "int64",
                      "type": "integer"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "402": {
            "description": "Token not found"
          },
          "403": {
            "description": "Token is incorrect"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "auth"
        ],
        "summary": "check validity of token and return User"
      }
    },
    "/login": {
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "accesstoken": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "description": "Login is incorrect"
          },
          "401": {
            "description": "Password is incorrect"
          },
          "500": {
            "description": "Server error"
          }
        },
        "tags": [
          "auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "login": {
                    "type": "string"
                  },
                  "pass": {
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "description": "user login and pass",
          "required": true
        },
        "summary": "login user"
      }
    },
    "/logout": {
      "post": {
        "parameters": [
          {
            "description": "JWToken received after login/registration",
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success. Token destroyed"
          },
          "402": {
            "description": "Token not found"
          },
          "403": {
            "description": "Token is incorrect"
          },
          "405": {
            "description": "Error. Token is still active"
          }
        },
        "security": [
          {
            "JWT_auth": []
          }
        ],
        "tags": [
          "auth"
        ],
        "summary": "logout user (authorized users only)"
      }
    },
    "/register": {
      "post": {
        "responses": {
          "200": {
