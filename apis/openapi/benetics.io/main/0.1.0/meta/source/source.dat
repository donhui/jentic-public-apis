      "FileUpload": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "The unique identifier of the file upload."
          },
          "filename": {
            "type": "string",
            "title": "Filename",
            "description": "The name of the file."
          },
          "content_type": {
            "type": "string",
            "pattern": ".+/.+",
            "title": "Content Type",
            "description": "The MIME type of the file."
          },
          "upload_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Upload Url",
            "description": "The URL to upload the file to. `null` if the file has already been uploaded."
          },
          "upload_fields": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Upload Fields",
            "description": "The form fields and respective values to use when submitting the post."
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "title": "Expires At",
            "description": "The expiration time of the file upload, in ISO 8601 format."
          },
          "state": {
            "$ref": "#/components/schemas/benetics__api__public__file_uploads__models__State",
            "description": "The state of the file upload."
          }
        },
        "type": "object",
        "required": [
          "id",
          "filename",
          "content_type",
          "upload_url",
          "upload_fields",
          "expires_at",
          "state"
        ],
        "title": "FileUpload",
        "description": "This object represents a file upload.\n\nUploaded files can be used to create e.g. documents or plans within\nprojects.",
        "example": {
          "content_type": "application/pdf",
          "expires_at": "2024-12-31T23:59:59Z",
          "filename": "file.pdf",
          "id": "ZIvhXd-5s-0",
          "state": "pending",
          "upload_fields": {
            "acl": "public-read",
            "key": "mykey",
            "policy": "mybase64 encoded policy",
            "signature": "mysignature"
          },
          "upload_url": "https://amzn-s3-demo-bucket.s3.amazonaws.com"
        }
      },
