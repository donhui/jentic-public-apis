          },
          "secret": {
            "type": "string",
            "minLength": 1,
            "title": "Secret",
            "description": "If provided, the secret will be used as the key to generate the HMAC hex digest value for [delivery signature headers](https://developer.benetics.io/reference#description/verify-webhook-signatures)."
          }
        },
        "type": "object",
        "required": [
          "url",
          "secret"
        ],
        "title": "CreateWebhook",
        "example": {
          "events": [
            "project.created",
            "task.updated"
          ],
