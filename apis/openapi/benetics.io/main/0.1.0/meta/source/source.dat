{
  "openapi": "3.0.3",
  "info": {
    "title": "Benetics API",
    "version": "0.1.0",
    "description": "Benetics is a construction efficiency platform built in the cloud. The API provides access to projects, documents, tasks, plans, reports, members, file uploads, exports, and webhooks.",
    "x-jentic-source-url": "https://developer.benetics.io"
  },
  "servers": [
    {
      "url": "https://public-api.benetics.io/v1",
      "description": "Production API Server"
    }
  ],
  "paths": {
    "/projects/{project_id}/documents": {
      "get": {
        "tags": [
          "Documents"
        ],
        "summary": "List documents",
        "description": "Lists all documents for the specified project.",
        "operationId": "get_documents_projects__project_id__documents_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Project Id"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "A limit on the number of objects to be returned. Limit can range\nbetween 1 and 100, and the default is 10.",
              "default": 10,
              "title": "Limit"
            },
            "description": "A limit on the number of objects to be returned. Limit can range\nbetween 1 and 100, and the default is 10."
          },
          {
            "name": "starting_after",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "description": "A cursor for use in pagination. `starting_after` is an\nobject ID that defines your place in the list. For instance, if you make a list\nrequest and receive 100 objects, ending with `obj_foo`, your subsequent call can\ninclude `starting_after=obj_foo` in order to fetch the next page of the list.\n",
              "default": "",
              "title": "Starting After"
            },
            "description": "A cursor for use in pagination. `starting_after` is an\nobject ID that defines your place in the list. For instance, if you make a list\nrequest and receive 100 objects, ending with `obj_foo`, your subsequent call can\ninclude `starting_after=obj_foo` in order to fetch the next page of the list.\n"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Documents"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Documents"
        ],
        "summary": "Create a document",
        "description": "Creates a document.\n\nThe `location` header from the response contains the URL of the created document.",
        "operationId": "create_document_projects__project_id__documents_post",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Project Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDocument"
              }
            }
          }
        },
        "responses": {
