      "benetics__api__public__webhooks__models__Event": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Unique identifier for the event."
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "title": "Created",
            "description": "The creation time of the event.\n\nUsing the date-time notation as defined by [RFC 3339, section\n5.6](https://tools.ietf.org/html/rfc3339#section-5.6), for example,\n2017-07-21T17:32:28Z.\n"
          },
          "payload": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/DocumentCreated"
              },
              {
                "$ref": "#/components/schemas/DocumentDeleted"
              },
              {
                "$ref": "#/components/schemas/DocumentUpdated"
              },
              {
                "$ref": "#/components/schemas/ExportCreated"
              },
              {
                "$ref": "#/components/schemas/ExportDeleted"
              },
              {
                "$ref": "#/components/schemas/ExportUpdated"
              },
              {
                "$ref": "#/components/schemas/PlanCreated"
              },
              {
                "$ref": "#/components/schemas/PlanDeleted"
              },
              {
                "$ref": "#/components/schemas/PlanUpdated"
              },
              {
                "$ref": "#/components/schemas/ProjectCreated"
              },
              {
                "$ref": "#/components/schemas/ProjectDeleted"
              },
              {
                "$ref": "#/components/schemas/ProjectUpdated"
              },
              {
                "$ref": "#/components/schemas/ProjectMemberAdded"
              },
              {
                "$ref": "#/components/schemas/ProjectMemberRemoved"
              },
              {
                "$ref": "#/components/schemas/ProjectMemberUpdated"
              },
              {
                "$ref": "#/components/schemas/ReportSubmissionCreated"
              },
              {
                "$ref": "#/components/schemas/ReportSubmissionDeleted"
              },
              {
                "$ref": "#/components/schemas/ReportSubmissionUpdated"
              },
              {
                "$ref": "#/components/schemas/TaskCreated"
              },
              {
                "$ref": "#/components/schemas/TaskDeleted"
              },
              {
                "$ref": "#/components/schemas/TaskUpdated"
              },
              {
                "$ref": "#/components/schemas/WebhookCreated"
              },
              {
                "$ref": "#/components/schemas/WebhookDeleted"
              },
              {
                "$ref": "#/components/schemas/WebhookUpdated"
              }
            ],
            "title": "Payload",
            "description": "Object containing data associated with the event.",
            "discriminator": {
              "propertyName": "event",
              "mapping": {
                "document.created": "#/components/schemas/DocumentCreated",
                "document.deleted": "#/components/schemas/DocumentDeleted",
                "document.updated": "#/components/schemas/DocumentUpdated",
                "export.created": "#/components/schemas/ExportCreated",
                "export.deleted": "#/components/schemas/ExportDeleted",
                "export.updated": "#/components/schemas/ExportUpdated",
                "plan.created": "#/components/schemas/PlanCreated",
                "plan.deleted": "#/components/schemas/PlanDeleted",
                "plan.updated": "#/components/schemas/PlanUpdated",
                "project.created": "#/components/schemas/ProjectCreated",
                "project.deleted": "#/components/schemas/ProjectDeleted",
                "project.updated": "#/components/schemas/ProjectUpdated",
                "project_member.added": "#/components/schemas/ProjectMemberAdded",
                "project_member.removed": "#/components/schemas/ProjectMemberRemoved",
                "project_member.updated": "#/components/schemas/ProjectMemberUpdated",
                "report_submission.created": "#/components/schemas/ReportSubmissionCreated",
                "report_submission.deleted": "#/components/schemas/ReportSubmissionDeleted",
                "report_submission.updated": "#/components/schemas/ReportSubmissionUpdated",
                "task.created": "#/components/schemas/TaskCreated",
                "task.deleted": "#/components/schemas/TaskDeleted",
                "task.updated": "#/components/schemas/TaskUpdated",
                "webhook.created": "#/components/schemas/WebhookCreated",
                "webhook.deleted": "#/components/schemas/WebhookDeleted",
                "webhook.updated": "#/components/schemas/WebhookUpdated"
              }
            }
          }
        },
        "type": "object",
        "required": [
          "id",
          "created",
          "payload"
        ],
        "title": "Event",
        "description": "An event that occured.\n\nThe content of the `payload` attribute differs depending on the type of the\nevent. The value of the `payload.event` attribute indicates what kind of\nevent it is. The `payload` is what's often referred to as a [tagged\nunion](https://en.wikipedia.org/wiki/Tagged_union)."
      },
      "benetics__db__models__org_webhooks__Event": {
        "type": "string",
        "enum": [
          "document.created",
          "document.deleted",
          "document.updated",
          "export.created",
          "export.deleted",
          "export.updated",
          "plan.created",
          "plan.deleted",
          "plan.updated",
          "project.created",
