            "description": "List of labels associated with the task."
          },
          "state": {
            "$ref": "#/components/schemas/benetics__api__public__shared_models__task__State"
          }
        },
        "type": "object",
        "title": "UpdateTask",
        "example": {
          "description": "Updated task description.",
          "due_at": "2024-12-31T17:00:00Z",
          "labels": [
            "Urgent",
            "Electrical"
          ],
          "name": "Updated task name",
          "state": "completed"
        }
      },
      "UpdateWebhook": {
        "properties": {
