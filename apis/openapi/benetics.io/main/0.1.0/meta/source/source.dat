  "components": {
    "schemas": {
      "AddMember": {
        "properties": {
          "user_id": {
            "type": "string",
            "minLength": 1,
            "title": "User Id",
            "description": "The unique identifier of the user to add."
          },
          "role": {
            "$ref": "#/components/schemas/Role",
            "description": "Role of the user in the project.",
            "default": "member"
          }
        },
        "type": "object",
        "required": [
          "user_id"
        ],
        "title": "AddMember",
        "example": {
          "role": "member",
          "user_id": "qUdwSAynDYE"
        }
      },
      "CheckboxField": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "The unique identifier of the field."
          },
          "label": {
            "type": "string",
            "title": "Label",
            "description": "The label of the field."
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description",
            "description": "The description of the field."
          },
          "required": {
            "type": "boolean",
            "title": "Required",
            "description": "Whether the field is required.",
            "default": false
          },
          "options": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Options",
            "description": "The options available for the field.",
            "default": []
          },
          "includes_other": {
            "type": "boolean",
            "title": "Includes Other",
            "description": "Whether the field includes an \"Other\" option.",
            "default": false
          },
          "type": {
            "type": "string",
            "title": "Type",
            "description": "The type of the field.",
            "default": "checkbox",
            "enum": [
              "checkbox"
            ]
          }
        },
        "type": "object",
        "required": [
          "id",
          "label"
        ],
        "title": "CheckboxField",
        "description": "A checkbox (i.e. multiple choice) field in a report.\n\nSubmission values are of type array of `string`."
      },
      "Completed": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "completed",
            "enum": [
              "completed"
            ]
          },
          "download_url": {
            "type": "string",
            "title": "Download Url",
            "description": "A URL to download the export."
          }
        },
        "type": "object",
        "required": [
          "download_url"
        ],
        "title": "Completed"
      },
      "CreateDocument": {
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "title": "Name",
            "description": "The name of the document."
          },
          "file_upload_id": {
            "type": "string",
            "title": "File Upload Id",
            "description": "The unique identifier of the file upload to use for the document."
          },
          "labels": {
            "items": {
              "$ref": "#/components/schemas/LabelValue"
            },
            "type": "array",
            "title": "Labels",
            "description": "List of labels associated with the document.",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "name",
          "file_upload_id"
        ],
        "title": "CreateDocument",
        "description": "Request model for creating a new document.",
        "example": {
          "file_upload_id": "FILE_UPLOAD_ID",
          "labels": [
            "Standards",
            "Electrical"
          ],
          "name": "ISO 9001 Certificate"
        }
      },
      "CreateFileUpload": {
        "properties": {
          "filename": {
            "type": "string",
            "minLength": 1,
            "title": "Filename",
            "description": "The name of the file."
          },
          "content_type": {
            "type": "string",
            "pattern": ".+/.+",
            "title": "Content Type",
            "description": "The MIME type of the file."
          }
        },
        "type": "object",
        "required": [
          "filename",
          "content_type"
        ],
        "title": "CreateFileUpload",
        "description": "Request model for creating a new file upload.",
        "example": {
          "content_type": "application/pdf",
          "name": "file.pdf"
        }
      },
      "CreatePlan": {
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "title": "Name",
            "description": "The name of the plan."
          },
          "file_upload_id": {
            "type": "string",
            "title": "File Upload Id",
            "description": "The unique identifier of the file upload to use for the plan."
          },
          "labels": {
            "items": {
              "$ref": "#/components/schemas/LabelValue"
            },
            "type": "array",
            "title": "Labels",
            "description": "List of labels associated with the plan.",
            "default": []
          },
          "types": {
            "items": {
              "$ref": "#/components/schemas/LabelValue"
            },
            "type": "array",
            "title": "Types",
            "description": "List of plan types associated with the plan.",
            "default": []
          },
          "floors": {
            "items": {
              "$ref": "#/components/schemas/LabelValue"
            },
            "type": "array",
            "title": "Floors",
            "description": "List of floors associated with the plan.",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "name",
          "file_upload_id"
        ],
        "title": "CreatePlan",
