      "ScalarField": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/DecimalField"
          },
          {
            "$ref": "#/components/schemas/IntField"
          },
          {
            "$ref": "#/components/schemas/StringField"
          },
          {
            "$ref": "#/components/schemas/DateField"
          },
          {
            "$ref": "#/components/schemas/PhotoField"
          },
          {
            "$ref": "#/components/schemas/RadioField"
          },
          {
            "$ref": "#/components/schemas/DropdownField"
          },
          {
            "$ref": "#/components/schemas/CheckboxField"
          },
          {
            "$ref": "#/components/schemas/PlanLocationField"
          },
          {
            "$ref": "#/components/schemas/DrawingField"
          },
          {
            "$ref": "#/components/schemas/UserField"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "checkbox": "#/components/schemas/CheckboxField",
            "date": "#/components/schemas/DateField",
            "decimal": "#/components/schemas/DecimalField",
            "drawing": "#/components/schemas/DrawingField",
            "dropdown": "#/components/schemas/DropdownField",
            "int": "#/components/schemas/IntField",
            "photo": "#/components/schemas/PhotoField",
            "plan_location": "#/components/schemas/PlanLocationField",
            "radio": "#/components/schemas/RadioField",
            "string": "#/components/schemas/StringField",
            "user": "#/components/schemas/UserField"
          }
        }
      },
      "ScalarFieldValue-Input": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
          },
          {
            "type": "integer"
          },
          {
            "type": "string"
          },
          {
            "type": "string",
            "format": "date"
          },
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          {
            "$ref": "#/components/schemas/User"
          },
          {
            "items": {
              "$ref": "#/components/schemas/benetics__api__public__shared_models__report_submission__Photo"
            },
            "type": "array"
          },
          {
            "$ref": "#/components/schemas/Drawing"
          }
        ]
      },
      "ScalarFieldValue-Output": {
        "anyOf": [
          {
            "type": "string",
            "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$"
          },
          {
            "type": "integer"
          },
          {
            "type": "string"
          },
          {
            "type": "string",
            "format": "date"
          },
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          {
            "$ref": "#/components/schemas/User"
          },
          {
            "items": {
              "$ref": "#/components/schemas/benetics__api__public__shared_models__report_submission__Photo"
            },
            "type": "array"
          },
          {
            "$ref": "#/components/schemas/Drawing"
          }
        ]
      },
