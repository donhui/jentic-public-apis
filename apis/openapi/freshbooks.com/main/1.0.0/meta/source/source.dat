                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/uploads/attachments/{jwt}": {
      "get": {
        "operationId": "getAttachment",
        "summary": "Get an uploaded attachment",
        "description": "Retrieve an uploaded attachment by its JWT token.",
        "tags": ["Uploads"],
        "parameters": [
          {
            "name": "jwt",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "JWT token provided when the file was uploaded"
          }
        ],
        "responses": {
          "200": {
            "description": "The file content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/uploads/account/{account_id}/images": {
      "post": {
        "operationId": "uploadImage",
        "summary": "Upload an image",
        "description": "Upload an image to FreshBooks.",
        "tags": ["Uploads"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": {
                    "type": "string",
                    "format": "binary",
                    "description": "The image file to upload"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/uploads/images/{jwt}": {
      "get": {
        "operationId": "getImage",
        "summary": "Get an uploaded image",
        "description": "Retrieve an uploaded image by its JWT token.",
        "tags": ["Uploads"],
        "parameters": [
          {
            "name": "jwt",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "JWT token provided when the image was uploaded"
          }
        ],
        "responses": {
          "200": {
            "description": "The image content",
            "content": {
              "image/*": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://auth.freshbooks.com/oauth/authorize",
            "tokenUrl": "https://api.freshbooks.com/auth/oauth/token",
            "scopes": {}
          }
        }
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "AccountId": {
        "name": "account_id",
        "in": "path",
        "required": true,
        "description": "The alpha-numeric account id",
        "schema": {
          "type": "string"
        }
      },
      "BusinessId": {
        "name": "business_id",
        "in": "path",
        "required": true,
        "description": "The business id",
        "schema": {
          "type": "integer"
        }
      },
      "ClientId": {
        "name": "client_id",
        "in": "path",
        "required": true,
        "description": "The client id",
        "schema": {
          "type": "integer"
        }
      },
      "InvoiceId": {
        "name": "invoice_id",
        "in": "path",
        "required": true,
        "description": "The invoice id",
        "schema": {
          "type": "integer"
        }
      },
      "ExpenseId": {
        "name": "expense_id",
        "in": "path",
        "required": true,
        "description": "The expense id",
        "schema": {
          "type": "integer"
        }
      },
      "PaymentId": {
        "name": "payment_id",
        "in": "path",
        "required": true,
        "description": "The payment id",
        "schema": {
          "type": "integer"
        }
      },
      "ProjectId": {
        "name": "project_id",
        "in": "path",
        "required": true,
        "description": "The project id",
        "schema": {
          "type": "integer"
        }
      },
      "Page": {
        "name": "page",
        "in": "query",
        "description": "Page number for pagination",
        "schema": {
          "type": "integer",
          "default": 1
        }
      },
      "PerPage": {
        "name": "per_page",
        "in": "query",
        "description": "Number of results per page",
        "schema": {
          "type": "integer",
          "default": 30
        }
      },
      "IncludesParam": {
        "name": "include[]",
        "in": "query",
        "description": "Include additional related data in the response",
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "explode": true
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Authentication error - invalid or missing access token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "properties": {
              "errors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "errno": { "type": "integer" },
                    "field": { "type": "string" },
                    "message": { "type": "string" },
                    "object": { "type": "string" },
                    "value": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "Identity": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string" },
          "confirmed_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" },
          "language": { "type": "string" },
          "currency_code": { "type": "string" },
          "setup_complete": { "type": "boolean" },
          "business_memberships": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "role": { "type": "string" },
                "business": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer" },
                    "name": { "type": "string" },
                    "account_id": { "type": "string" },
                    "business_uuid": { "type": "string", "format": "uuid" }
                  }
                }
              }
            }
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "token_type": { "type": "string" },
          "expires_in": { "type": "integer" },
          "refresh_token": { "type": "string" },
          "scope": { "type": "string" },
          "created_at": { "type": "integer" }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "pages": { "type": "integer" },
          "per_page": { "type": "integer" },
          "total": { "type": "integer" }
        }
      },
      "ClientInput": {
        "type": "object",
        "properties": {
          "fname": { "type": "string", "description": "First name" },
          "lname": { "type": "string", "description": "Last name" },
          "email": { "type": "string", "description": "Email address" },
          "organization": { "type": "string", "description": "Business name" },
          "p_street": { "type": "string", "description": "Street address" },
          "p_street2": { "type": "string", "description": "Street address line 2" },
          "p_city": { "type": "string", "description": "City" },
          "p_province": { "type": "string", "description": "Province/State" },
          "p_code": { "type": "string", "description": "Postal/Zip code" },
          "p_country": { "type": "string", "description": "Country" },
          "home_phone": { "type": "string" },
          "mob_phone": { "type": "string" },
          "bus_phone": { "type": "string" },
          "fax": { "type": "string" },
          "language": { "type": "string" },
          "currency_code": { "type": "string" },
          "note": { "type": "string" },
          "vat_name": { "type": "string" },
          "vat_number": { "type": "string" }
        }
      },
      "ClientResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "client": {
                    "$ref": "#/components/schemas/Client"
                  }
                }
              }
            }
          }
        }
      },
      "ClientListResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "clients": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Client" }
                  },
                  "page": { "type": "integer" },
                  "pages": { "type": "integer" },
                  "per_page": { "type": "integer" },
                  "total": { "type": "integer" }
                }
              }
            }
          }
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "userid": { "type": "integer" },
          "fname": { "type": "string" },
          "lname": { "type": "string" },
          "email": { "type": "string" },
          "organization": { "type": "string" },
          "p_street": { "type": "string" },
          "p_street2": { "type": "string" },
          "p_city": { "type": "string" },
          "p_province": { "type": "string" },
          "p_code": { "type": "string" },
          "p_country": { "type": "string" },
          "home_phone": { "type": "string" },
          "mob_phone": { "type": "string" },
          "bus_phone": { "type": "string" },
          "fax": { "type": "string" },
          "language": { "type": "string" },
          "currency_code": { "type": "string" },
          "note": { "type": "string" },
          "vat_name": { "type": "string" },
          "vat_number": { "type": "string" },
          "vis_state": { "type": "integer", "description": "0=active, 1=deleted, 2=archived" },
          "signup_date": { "type": "string", "format": "date-time" },
          "updated": { "type": "string", "format": "date-time" }
        }
      },
      "InvoiceInput": {
        "type": "object",
        "properties": {
          "customerid": { "type": "integer", "description": "Client id" },
          "create_date": { "type": "string", "format": "date" },
          "due_offset_days": { "type": "integer" },
          "discount_value": { "type": "string" },
          "notes": { "type": "string" },
          "terms": { "type": "string" },
          "currency_code": { "type": "string" },
          "language": { "type": "string" },
          "po_number": { "type": "string" },
          "lines": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/InvoiceLine" }
          }
        }
      },
      "InvoiceLine": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "qty": { "type": "string" },
          "unit_cost": {
            "type": "object",
            "properties": {
              "amount": { "type": "string" },
              "code": { "type": "string" }
            }
          },
          "taxName1": { "type": "string" },
          "taxAmount1": { "type": "string" },
          "taxName2": { "type": "string" },
          "taxAmount2": { "type": "string" },
          "type": { "type": "integer", "description": "0=normal, 1=rebilling" }
        }
      },
      "InvoiceResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "invoice": { "type": "object" }
                }
              }
            }
          }
        }
      },
      "InvoiceListResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "invoices": {
                    "type": "array",
                    "items": { "type": "object" }
                  },
                  "page": { "type": "integer" },
                  "pages": { "type": "integer" },
                  "per_page": { "type": "integer" },
                  "total": { "type": "integer" }
                }
              }
            }
          }
        }
      },
      "ExpenseInput": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "object",
            "properties": {
              "amount": { "type": "string" },
              "code": { "type": "string" }
            }
          },
          "categoryid": { "type": "integer" },
          "date": { "type": "string", "format": "date" },
          "vendor": { "type": "string" },
          "staffid": { "type": "integer" },
          "clientid": { "type": "integer" },
          "notes": { "type": "string" },
          "taxName1": { "type": "string" },
          "taxPercent1": { "type": "string" },
          "taxName2": { "type": "string" },
          "taxPercent2": { "type": "string" }
        }
      },
      "ExpenseResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "expense": { "type": "object" }
                }
              }
            }
          }
        }
      },
      "ExpenseListResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "object",
            "properties": {
              "result": {
                "type": "object",
                "properties": {
                  "expenses": {
                    "type": "array",
                    "items": { "type": "object" }
                  },
                  "page": { "type": "integer" },
                  "pages": { "type": "integer" },
                  "per_page": { "type": "integer" },
                  "total": { "type": "integer" }
                }
              }
            }
          }
        }
      },
      "PaymentInput": {
        "type": "object",
        "properties": {
          "invoiceid": { "type": "integer" },
          "amount": {
            "type": "object",
            "properties": {
              "amount": { "type": "string" },
              "code": { "type": "string" }
            }
          },
          "date": { "type": "string", "format": "date" },
          "type": { "type": "string", "description": "Payment type (e.g., Cash, Check, Credit Card)" },
          "note": { "type": "string" }
        }
      },
      "ItemInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "qty": { "type": "string" },
          "inventory": { "type": "string" },
          "unit_cost": {
            "type": "object",
            "properties": {
              "amount": { "type": "string" },
              "code": { "type": "string" }
            }
          },
          "tax1": { "type": "integer" },
          "tax2": { "type": "integer" }
        }
      },
      "TaxInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "amount": { "type": "string", "description": "Tax percentage" },
          "number": { "type": "string", "description": "Tax registration number" },
          "compound": { "type": "boolean" }
        }
      },
      "ProjectInput": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "client_id": { "type": "integer" },
          "due_date": { "type": "string", "format": "date" },
          "budget": { "type": "number" },
          "project_type": { "type": "string" },
          "fixed_price": { "type": "string" },
          "rate": { "type": "string" },
          "billing_method": { "type": "string" }
        }
      },
      "CallbackInput": {
        "type": "object",
        "properties": {
          "event": { "type": "string", "description": "The event to subscribe to (e.g., invoice.create, client.create)" },
          "uri": { "type": "string", "format": "uri", "description": "The URI to send webhook notifications to" }
        }
      },
      "UploadResponse": {
        "type": "object",
        "properties": {
          "jwt": { "type": "string", "description": "JWT token to access the uploaded file" },
          "link": { "type": "string", "format": "uri", "description": "Direct link to the uploaded resource (for images)" }
        }
      }
    }
  },
  "tags": [
    { "name": "Auth", "description": "Authentication and identity endpoints" },
    { "name": "Clients", "description": "Client management" },
    { "name": "Invoices", "description": "Invoice management" },
    { "name": "Invoice Profiles", "description": "Recurring invoice profile management" },
    { "name": "Expenses", "description": "Expense management" },
    { "name": "Estimates", "description": "Estimate management" },
    { "name": "Payments", "description": "Payment management" },
    { "name": "Items", "description": "Item/product management" },
    { "name": "Taxes", "description": "Tax management" },
    { "name": "Staff", "description": "Staff member management" },
    { "name": "Systems", "description": "System information" },
    { "name": "Gateways", "description": "Payment gateway management" },
    { "name": "Bills", "description": "Bills, bill payments, and bill vendors" },
    { "name": "Credit Notes", "description": "Credit note management" },
    { "name": "Other Income", "description": "Other income management" },
    { "name": "Tasks", "description": "Task management" },
    { "name": "Projects", "description": "Project management" },
    { "name": "Time Tracking", "description": "Time entry management" },
    { "name": "Services", "description": "Service and service rate management" },
    { "name": "Webhooks", "description": "Webhook callback management" },
    { "name": "Ledger Accounts", "description": "Ledger/chart of accounts management" },
    { "name": "Payment Options", "description": "Invoice payment options" },
    { "name": "Uploads", "description": "File and image upload management" }
  ]
}
