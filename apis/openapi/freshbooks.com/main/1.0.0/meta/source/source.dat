{
  "openapi": "3.0.3",
  "info": {
    "title": "FreshBooks API",
    "description": "FreshBooks cloud accounting API for managing invoices, clients, expenses, projects, time tracking, and more.",
    "version": "1.0.0",
    "contact": {
      "name": "FreshBooks",
      "url": "https://www.freshbooks.com/api"
    },
    "x-jentic-source-url": "https://www.freshbooks.com/api/start"
  },
  "servers": [
    {
      "url": "https://api.freshbooks.com",
      "description": "FreshBooks API"
    }
  ],
  "security": [
    {
      "OAuth2": []
    }
  ],
  "paths": {
    "/auth/api/v1/users/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user identity",
        "description": "Get the identity details of the currently authenticated user, including business memberships and roles.",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "$ref": "#/components/schemas/Identity"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/auth/oauth/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Get or refresh an access token",
        "description": "Exchange an authorization code for an access token, or refresh an existing token.",
        "tags": ["Auth"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id", "client_secret", "grant_type", "redirect_uri"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "The FreshBooks application client id"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "The FreshBooks application client secret"
                  },
                  "grant_type": {
                    "type": "string",
                    "enum": ["authorization_code", "refresh_token"],
                    "description": "The grant type"
                  },
                  "redirect_uri": {
                    "type": "string",
                    "description": "The registered redirect URI"
                  },
                  "code": {
                    "type": "string",
                    "description": "Authorization code (when grant_type is authorization_code)"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token (when grant_type is refresh_token)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          }
        }
      }
    },
    "/accounting/account/{account_id}/users/clients": {
      "get": {
        "operationId": "listClients",
        "summary": "List clients",
        "description": "Get a list of clients for the given account.",
