    "/events/account/{account_id}/events/callbacks/{callback_id}": {
      "get": {
        "operationId": "getCallback",
        "summary": "Get a webhook callback",
        "tags": ["Webhooks"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountId" },
          {
            "name": "callback_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "operationId": "updateCallback",
        "summary": "Update a webhook callback",
        "description": "Update a callback. Can also be used to verify a callback by sending the verifier, or to resend verification.",
        "tags": ["Webhooks"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountId" },
          {
            "name": "callback_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "callback": {
                    "type": "object",
                    "properties": {
                      "verifier": {
                        "type": "string",
                        "description": "The verifier string to confirm the webhook callback"
                      },
                      "resend": {
                        "type": "boolean",
                        "description": "Set to true to resend the verification webhook"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Callback updated" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "deleteCallback",
        "summary": "Delete a webhook callback",
        "tags": ["Webhooks"],
        "parameters": [
          { "$ref": "#/components/parameters/AccountId" },
          {
            "name": "callback_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Callback deleted" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
