{
  "openapi": "3.0.3",
  "info": {
    "title": "Thinger.io HTTP Devices API",
    "description": "API for sending data from HTTP devices to the Thinger.io IoT platform via device callbacks.",
    "version": "3.0.0",
    "x-jentic-source-url": "https://docs.thinger.io/http-devices"
  },
  "servers": [
    {
      "url": "https://{server}/v3",
      "description": "Thinger.io server",
      "variables": {
        "server": {
          "default": "backend.thinger.io",
          "description": "Thinger.io server domain"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "queryAuth": []
    }
  ],
  "tags": [
    {
      "name": "Device Callback",
      "description": "HTTP device callback endpoints for sending data to the platform"
    }
  ],
  "paths": {
    "/users/{username}/devices/{deviceId}/callback/data": {
      "post": {
        "operationId": "sendDeviceCallbackData",
        "summary": "Send device callback data",
        "description": "Send JSON-encoded data from an external HTTP device to the Thinger.io platform. The data will be stored and can trigger configured actions such as data bucket storage or endpoint forwarding.",
        "tags": ["Device Callback"],
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Thinger.io account username"
          },
          {
            "name": "deviceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "HTTP device identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeviceCallbackData"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data received successfully. May include response data if a Response Data callback is configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeviceCallbackResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid JSON data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing authorization token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT bearer token from the device Callback/Overview tab"
      },
      "queryAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "authorization",
        "description": "JWT authorization token passed as query parameter"
      }
    },
    "schemas": {
      "DeviceCallbackData": {
        "type": "object",
        "description": "Arbitrary JSON data to send to the device. Structure depends on the device configuration.",
        "additionalProperties": true,
        "example": {
          "temperature": 22.5,
          "humidity": 60.2
        }
      },
      "DeviceCallbackResponse": {
        "type": "object",
        "description": "Response data from the device, if a Response Data callback is configured. Empty otherwise.",
        "additionalProperties": true
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}