    "/api/generateHMACKey": {
      "post": {
        "tags": [
          "Event Subscription"
        ],
        "description": "Generate new secret key and applied immediately on callback messages.\n\nOnce secret key is generated, Curfex's callback messages are signed with Hash-based Message Authentication Code (HMAC) signature by using this secret key with SHA-512 algorithm hashing on message content.\n\nUser can compute and compare the HMAC singature (refer **X-HMAC-DIGEST-SHA512** in callback message header) to prove authenticity of the message.",
        "operationId": "generateHMACKey",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiGenerateHMACKeyResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiApiErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
