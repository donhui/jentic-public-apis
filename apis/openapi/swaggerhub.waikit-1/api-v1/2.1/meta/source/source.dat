    "/api/payoutInfo": {
      "post": {
        "tags": [
          "Enquiry"
        ],
        "description": "To obtain payout quotation and parameter values.\n\nThe quotation (queryId) is valid for 30 minutes (refer valid_till value in response).\n\nRefer to transfer (payout) bank list [here](https://www.notion.so/curfex/Transfer-payout-Bank-List-v1-and-v2-mapping-f94c11a3106b48ef99bd196f4b8e46c6) (with v1 and v2 mapping) if you are migrating from Curfex API v1.",
        "operationId": "payoutInfo",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiPayoutInfoRequestDto"
              }
            }
