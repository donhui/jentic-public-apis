    "/api/registerUser": {
      "post": {
        "tags": [
          "User Registration"
        ],
        "description": "Register User via API . \n\nOverview Status flow [here](https://curfex.notion.site/Registration-Statuses-cc452c9942d24856a7b039f55ee75b89)\n\nRegistration flow refer  [here](https://curfex.notion.site/Registration-API-Flow-66dcd52c72f84b5d9b054b72682bb03f) for details.\n\nAll date related fields, Format to use is **yyyy-mm-dd**\n\nCountry & Nationality list [here](https://curfex.notion.site/Registration-API-Country-Nationality-List-bd4cbad43d414ecab9479d5b55fc6d89)\n\nIntention list [here](https://curfex.notion.site/Registration-API-Intention-List-027c4bd99f514007b206d07ba44c91ad)\n\nLanguages [here] (https://curfex.notion.site/Registration-API-Default-lang-list-17285eacd612450ebb78b4ea866bcc99)\n\nCustomer Types [here] (https://curfex.notion.site/Registration-API-Customer-Type-c90f113834044176a6706b55cdb8add1)\n\nGender List [here] (https://curfex.notion.site/Registration-API-Gender-List-e43cefc229754a0d8bc113a8a3071ff9)\n\nOccupation List [here] (https://curfex.notion.site/Registration-API-Occupation-List-2c431691e8dd491b9ce3aa6cacc8a7df)",
        "operationId": "registerUser",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiRegisterUserRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiRegisterUserResponseDto"
                }
              }
            }
          },
          "400": {
