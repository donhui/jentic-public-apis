  "paths": {
    "/api/walletHistory": {
      "post": {
        "tags": [
          "Wallet"
        ],
        "description": "Retrieve wallet transaction history.\n\n**dateFrom** and **dateTo** are mandatory and must be in YYY-MM-DD format.",
        "operationId": "walletHistory",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiWalletHistoryRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiWalletHistoryResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiApiErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
