    "/api/signin": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "description": "Sign in with username and password to retrieve bearer access token.\n\nEach successful call generate the access token that will expire in 1 hour.\n\nUser may visit [Test environment](https://partner-uat.curfex.com/forgotPassword) or [Production environment](https://partner-prd.curfex.com/forgotPassword) if needed to reset password or password is forgoten.",
        "operationId": "signin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiSigninRequestDto"
              }
