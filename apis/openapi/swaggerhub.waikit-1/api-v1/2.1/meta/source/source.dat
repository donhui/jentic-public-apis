                "schema": {
                  "$ref": "#/components/schemas/ApiApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/payout": {
      "post": {
        "tags": [
          "Transfer"
        ],
        "description": "Submit payout transfer request. Optional queryId value can be obtained by calling `/api/payoutInfo`. Refer [required fields](https://curfex.notion.site/Payout-required-fields-5146b1bf36994c918459fb56804b640c) based on receiveCurrency.",
        "operationId": "payout",
        "requestBody": {
          "content": {
            "application/json": {
