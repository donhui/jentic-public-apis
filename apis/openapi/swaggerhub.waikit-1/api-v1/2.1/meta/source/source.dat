    "/api/subscribeTransferStatus": {
      "post": {
        "tags": [
          "Event Subscription"
        ],
        "description": "Subscribe to transfer request (payout or collection) event.\n\nPlease call `POST /api/generateHMACKey` and use the generated secret key to prove authenticity of callback messages.\n\nAvailable transfer status:\n* AWAITING_PAYMENT\n* QUOTE_EXPIRED\n* TRX_EXPIRED\n* REVIEW_TRANSFER\n* INFORMATION_REQUIRED\n* PENDING_PAYOUT\n* REVIEW_UNSUCCESSFUL\n* AWAITING_PAYOUT_CONFIRMATION\n* PAYOUT_FAILED\n* TRANSFER_COMPLETED\n* TRANSACTION_UNSUCCESSFUL\n* PURGED\n\nPlease refer [transfer flow](https://curfex.notion.site/Transfer-Flow-53411d506d614b6e975e2a43a51e86b5) for more details.\n\nFor callback details, please refer [here](https://curfex.notion.site/Transfer-Callback-d854cfff9b93416084f00251ecbfac6c).",
        "operationId": "subscribeTransferStatus",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiEventSubscriptionRequestDto"
              }
            }
          },
          "required": true
        },
        "callbacks": {
          "transferStatusEvent": {
            "{$request.body#/payload/callbackUrl}": {
              "post": {
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/json": {
                      "schema": {
                        "$ref": "#/components/schemas/ApiTransferStatusEventResponseDto"
                      }
                    }
                  }
                },
                "responses": {
                  "200": {
                    "description": "Return status code 200 if callback is accepted successfully. Any non-200 status code is treated as callback failure."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiEventSubscriptionResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiApiErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
