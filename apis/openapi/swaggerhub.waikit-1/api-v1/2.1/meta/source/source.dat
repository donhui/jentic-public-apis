{
  "openapi": "3.0.1",
  "info": {
    "title": "Curfex API",
    "description": "Curfex integration API for business partner. This is a v2 version (released on 2022) replacing existing production version [Curfex API v1](https://app.swaggerhub.com/apis/curfex/curfex_api_v1).\n\nAll listed APIs are [rate limited](https://www.notion.so/curfex/Rate-Limiting-def3bf1a33e345c4b34580ea282f3deb)\n\nPlease contact us at tech@curfex.com if you need any help.",
    "termsOfService": "https://www.curfex.com/tnc",
    "contact": {
      "name": "Curfex technical support",
      "url": "https://www.curfex.com/contact",
      "email": "tech@curfex.com"
    },
    "version": "2.1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/WAIKIT_1/API_V1/2.1/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/curfex/curfex_api_v2/2.1"
    },
    {
      "url": "https://partner-uat.curfex.com",
      "description": "Test environment"
    },
    {
      "url": "https://partner-prd.curfex.com",
      "description": "Production (live) environment"
    }
  ],
  "tags": [
    {
      "name": "Event Subscription"
    },
