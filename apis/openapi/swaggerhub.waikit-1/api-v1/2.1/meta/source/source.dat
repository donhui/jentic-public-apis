    "/api/transferHistory": {
      "post": {
        "tags": [
          "Enquiry"
        ],
        "description": "Retrieve transfer records with filter options.\n\n**dateFrom** and **dateTo** are inclusive in search range.\n\nOptional trxStatus value:\n* AWAITING_PAYMENT\n* QUOTE_EXPIRED\n* TRX_EXPIRED\n* REVIEW_TRANSFER\n* INFORMATION_REQUIRED\n* PENDING_PAYOUT\n* REVIEW_UNSUCCESSFUL\n* AWAITING_PAYOUT_CONFIRMATION\n* PAYOUT_FAILED\n* TRANSFER_COMPLETED\n* TRANSACTION_UNSUCCESSFUL\n* PURGED",
        "operationId": "transferHistory",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiTransferHistoryRequestDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiTransferHistoryResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiApiErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiApiErrorResponse"
                }
              }
            }
          }
        }
      }
    },
