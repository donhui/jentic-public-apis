        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" }, "assignedTo": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Issue updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
