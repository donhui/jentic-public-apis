        ],
        "responses": {
          "200": { "description": "List of comments" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "addIssueComment",
        "summary": "Add a comment to an issue",
