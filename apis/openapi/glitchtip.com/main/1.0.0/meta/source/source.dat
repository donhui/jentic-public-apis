        "tags": ["Issues"],
        "parameters": [
          { "name": "org", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of issues", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Issue" } } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "bulkUpdateOrganizationIssues",
        "summary": "Bulk update issues",
        "tags": ["Issues"],
        "parameters": [
          { "name": "org", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": { "description": "Issues updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "bulkDeleteOrganizationIssues",
        "summary": "Bulk delete issues",
        "tags": ["Issues"],
        "parameters": [
          { "name": "org", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Issues deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
