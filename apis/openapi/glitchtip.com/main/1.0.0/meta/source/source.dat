        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "text": { "type": "string" } }, "required": ["text"] } } }
        },
        "responses": {
          "201": { "description": "Comment added" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
