{
  "openapi": "3.0.3",
  "info": {
    "title": "AlphaInsider Trading API",
    "description": "AlphaInsider is a trading strategy marketplace for crypto and stocks. This integration allows you to track strategy performance and receive trade signals through paper trading only. No real trades are executed.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.alphainsider.com/resources/webhooks/neworderwebhook"
  },
  "servers": [
    {
      "url": "https://alphainsider.com/api",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Orders",
      "description": "Trading order operations"
    }
  ],
  "paths": {
    "/newOrderWebhook": {
      "post": {
        "tags": ["Orders"],
        "summary": "Submit new trading order",
        "description": "Submit new trading orders via webhook integration, primarily for TradingView automation. You can only go fully in or out of a position.",
        "operationId": "createNewOrder",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            }
          },
          "400": {
            "description": "Request failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token with newOrderWebhook permission. Include in the request body as api_token field."
      }
    },
    "schemas": {
      "NewOrderRequest": {
        "type": "object",
        "required": ["strategy_id", "stock_id", "action", "api_token"],
        "properties": {
          "strategy_id": {
            "type": "string",
            "description": "Strategy identifier"
          },
          "stock_id": {
            "type": "string",
            "description": "Stock/asset identifier in format 'stock:exchange' or stock_id"
          },
          "action": {
            "type": "string",
            "enum": ["buy", "long", "sell", "short", "close", "flat"],
            "description": "Order action type"
          },
          "leverage": {
            "type": "number",
            "minimum": 0,
            "maximum": 2,
            "default": 1,
            "multipleOf": 0.01,
            "description": "Trading leverage in increments of 0.01"
          },
          "api_token": {
            "type": "string",
            "format": "jwt",
            "description": "JWT token with newOrderWebhook permission"
          }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string",
            "description": "Unique order identifier"
          },
          "strategy_id": {
            "type": "string",
            "description": "Strategy identifier"
          },
          "strategy_name": {
            "type": "string",
            "description": "Strategy name"
          },
          "stock_id": {
            "type": "string",
            "description": "Stock/asset identifier"
          },
          "symbol": {
            "type": "string",
            "description": "Trading symbol"
          },
          "exchange": {
            "type": "string",
            "description": "Exchange name"
          },
          "action": {
            "type": "string",
            "description": "Order action executed"
          },
          "leverage": {
            "type": "number",
            "description": "Applied leverage"
          },
          "pricing": {
            "type": "object",
            "properties": {
              "bid": {
                "type": "number",
                "description": "Bid price"
              },
              "ask": {
                "type": "number",
                "description": "Ask price"
              },
              "last": {
                "type": "number",
                "description": "Last traded price"
              }
            }
          },
          "fees": {
            "type": "object",
            "properties": {
              "commission": {
                "type": "number",
                "description": "Commission fee"
              },
              "total": {
                "type": "number",
                "description": "Total fees"
              }
            }
          },
          "slippage": {
            "type": "number",
            "description": "Slippage metrics"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Order execution timestamp"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
