{
  "openapi": "3.0.3",
  "info": {
    "title": "Visible API",
    "version": "1.0.0",
    "description": "Investor relations and reporting API (Apiary documentation TLS certificate issue)",
    "x-jentic-source-url": "http://docs.visible.apiary.io/",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.visible.vc/v1",
      "description": "Visible API"
    }
