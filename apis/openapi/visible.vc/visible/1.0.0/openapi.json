  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/updates": {
      "get": {
        "summary": "List Updates",
        "operationId": "listUpdates",
        "description": "Retrieve investor updates",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Update"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "tags": [
          "updates"
        ]
      },
      "post": {
        "summary": "Create Update",
        "operationId": "createUpdate",
        "description": "Create a new investor update",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Update"
                }
              }
            }
          }
        },
        "tags": [
          "updates"
        ]
      }
    },
    "/updates/{id}": {
      "get": {
        "summary": "Get Update",
        "operationId": "getUpdate",
        "description": "Retrieve a specific update",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Update"
                }
              }
            }
          }
        },
        "tags": [
          "updates"
        ]
      }
    },
    "/metrics": {
      "get": {
        "summary": "List Metrics",
        "operationId": "listMetrics",
        "description": "Retrieve company metrics",
        "responses": {
          "200": {
