        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Investor"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "investors"
        ]
      }
    },
    "/investors/{id}": {
      "get": {
        "summary": "Get Investor",
        "operationId": "getInvestor",
        "description": "Retrieve a specific investor",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Investor"
                }
              }
            }
          }
        },
        "tags": [
          "investors"
        ]
