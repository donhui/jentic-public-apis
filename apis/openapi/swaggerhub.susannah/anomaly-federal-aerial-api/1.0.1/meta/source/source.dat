{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "Local Server",
      "url": "https://virtserver.swaggerhub.com/SUSANNAH/anomaly-federal-aerial-api/1.0.1"
    }
  ],
  "info": {
    "version": "1.0.1",
    "title": "Anomaly Federal Aerial Awareness API",
    "description": "Anomaly Federal's API for configuring, managing, and receiving real-time reports about anomalous aerial objects or activity, with on-demand mobile alert network activation.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/SUSANNAH/anomaly-federal-aerial-api/1.0.1/swagger.json"
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Aerial Activity Feed",
      "description": "Query, configure, and manage aerial activity feeds.\n"
    },
    {
      "name": "Mobile Alert Network Activation",
      "description": "On-demand activation of the Mobile Alert Network."
    }
  ],
  "paths": {
    "/activity-feed-configurations": {
      "description": "Manage configurations for real-time reports of aerial activity. You can: - **Create** a new configuration to customize a feed of aerial activity reports. - **Retrieve** details of an existing configuration. - **Update** criteria or webhook configurations for an active configuration.\n",
      "post": {
        "tags": [
          "Aerial Activity Feed"
        ],
        "summary": "Create a new configuration to populate a feed of aerial activity reports",
        "description": "Create a new configuration to define a feed of aerial activity based on specific criteria within an area of interest.  Define an **area of interest** and **configuration criteria** to tailor a feed of data for reports that match granular parameters, such as shape, movement patterns, or media analysis results. \nYou may create as many configurations as needed - each will populate their own activity feed.\n\n**Key Features:**\n- **Area of Interest**  \n  Define the area of interest to monitor by geolocation:\n  - `global`: Subscribe to reports worldwide.\n  - `radius`: Specify a central coordinate (latitude, longitude) and radius in miles or kilometers.\n  - `bounding_box`: Define a rectangular area with two coordinate pairs (e.g., SW and NE corners).\n  - `polygon`: Define a custom area using multiple coordinate pairs connected sequentially.\n\n- **Configuration Criteria**  \n  Tailor configurations to specific reports using available filters:\n  - Craft Shapes\n  - Movement Patterns\n  - Noise Patterns\n  - Witness Count\n  - Duration\n  - Anomaly Score\n  - Included Media\n  - Number of Objects\n\n- **Webhook Configuration**  \n  - If a valid `webhook_url` is provided, Anomaly Federal will push real-time reports to this address with event and request metadata.\n  - Without a webhook, reports are still saved as records accessible through the `GET /activity-feeds` endpoint.\n",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Unique name for the activity feed configuration."
                  },
                  "area_of_interest": {
                    "$ref": "#/components/schemas/AreaOfInterest"
                  },
                  "criteria": {
                    "$ref": "#/components/schemas/ConfigurationCriteria"
                  }
                },
                "required": [
                  "name",
                  "area_of_interest",
                  "criteria"
                ]
              },
              "examples": {
                "example-1": {
                  "summary": "Activity feed configuration request",
                  "value": {
                    "name": "langley-afb-configuration",
                    "area_of_interest": {
                      "type": "bounding_box",
                      "coordinates": [
                        {
                          "latitude": 37.0821,
                          "longitude": -76.3607
                        },
                        {
                          "latitude": 37.2821,
                          "longitude": -76.1607
                        }
                      ]
                    },
                    "criteria": {
                      "shapes": [
                        "triangle",
                        "orb",
                        "sphere",
                        "disc"
                      ],
                      "colors": [
                        "grey",
                        "metallic",
                        "red"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration created successfully",
            "content": {
              "application/json": {
                "example": {
                  "configuration_name": "langley-afb-configuration",
                  "status": "active",
                  "area_of_interest": {
                    "type": "bounding_box",
                    "coordinates": [
                      {
                        "latitude": 37.0821,
                        "longitude": -76.3607
                      },
                      {
                        "latitude": 37.2821,
                        "longitude": -76.1607
                      }
                    ]
                  },
                  "criteria": {
                    "shapes": [
                      "triangle",
                      "orb",
                      "sphere"
                    ],
                    "colors": [
                      "grey",
                      "metallic",
                      "red"
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid input (e.g., malformed webhook URL, missing required fields)",
            "content": {
              "application/json": {
                "example": {
                  "error": "Invalid webhook URL."
                }
              }
            }
          }
        }
      }
    },
    "/activity-feed-configurations/{name}": {
      "get": {
        "tags": [
          "Aerial Activity Feed"
        ],
        "summary": "Retrieve a specific configuration by unique name",
        "description": "Fetch the details of a configuration by its unique name. Use this endpoint to check current configurations, including criteria, webhook details, and the area of interest.\n",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique name to identify the configuration."
          }
        ],
        "responses": {
          "200": {
            "description": "Details of the configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Configuration"
                },
                "example": {
                  "configuration_name": "langley-afb-configuration",
                  "status": "active",
                  "area_of_interest": {
                    "type": "bounding_box",
                    "coordinates": [
                      {
                        "latitude": 37.0821,
                        "longitude": -76.3607
                      },
                      {
                        "latitude": 37.2821,
                        "longitude": -76.1607
                      }
                    ]
                  },
                  "criteria": {
                    "shapes": [
                      "triangle",
                      "orb",
                      "sphere"
                    ],
                    "colors": [
                      "grey",
                      "metallic",
                      "red"
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "Configuration not found",
            "content": {
              "application/json": {
                "example": {
                  "error": "Configuration with ID 'invalid-id' not found."
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Aerial Activity Feed"
        ],
        "summary": "Update a configuration by unique name",
        "description": "Modify an existing configuration's criteria or webhook configuration.  For example:\n- Update the `webhook_url` if your endpoint changes.\n- Adjust the `area_of_interest` to expand or narrow the activity feed scope.\n- Refine `criteria` to match new data filtering preferences.\n",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique name to identify the configuration."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfigurationUpdate"
              },
              "examples": {
                "example-1": {
                  "summary": "Monitor a new shape",
                  "value": {
                    "criteria": {
                      "shapes": [
                        "disk"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration updated successfully",
            "content": {
              "application/json": {
                "example": {
                  "configuration_name": "langley-afb-configuration",
                  "status": "active",
                  "criteria_updated": {
                    "shapes": [
                      "triangle",
                      "orb",
                      "sphere",
                      "disk"
                    ]
                  }
                }
              }
            }
          },
          "404": {
            "description": "Configuration not found"
          }
        }
      }
    },
    "/activity-feeds": {
      "get": {
        "tags": [
          "Aerial Activity Feed"
        ],
        "summary": "Retrieve enriched aerial activity reports organized by type and name",
        "description": "Retrieve all reports triggered by configurations, on-demand requests, or global anomalies.  Reports are categorized into three sources:\n- **Configuration**: Reports are generated based on API-defined criteria and area of interest.\n- **Global**: Patterns of Anomalies algorithmically detected by AF's system based on:\n  - Spikes in mass UAP reports by location and/or time.\n  - Craft characteristics, flight patterns, and other patterns.\n  - Baseline global criteria (minimum corroboration of 2 reports within the last 24 hours).\n\n- **On-Demand**: Reports are triggered by a mobile alert network activation (below), a high-urgency request to mobilize users on the ground to corroborate or rule out anomalous aerial activity. \n  If a matching configuration exists, users receive both the configuration and on-demand reports in their activity feeds.\n",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "configuration",
                "on_demand",
                "global"
              ]
            },
            "description": "Filter reports by type:\n- **configuration**: Reports generated from a configured configuration.\n- **on_demand**: Reports triggered by network pushes.\n- **global**: Anomalies detected globally based on system thresholds and mapping.\n"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of aerial activity reports with a unique configuration",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ActivityFeedEntry"
                  }
                },
                "example": {
                  "reports": [
                    {
                      "report_id": "report-12345",
                      "report_started_at": "2024-11-27T10:00:00Z",
                      "duration_ms": 30000,
                      "location": {
                        "latitude": 37.1621,
                        "longitude": -76.2607
                      },
                      "details": {
                        "shape": "triangle",
                        "movement_pattern": "hovering",
                        "noise_pattern": "silent",
                        "colors": [
                          "grey",
                          "metallic"
                        ],
                        "anomaly_score": 87
                      },
                      "media_files": [
                        {
                          "id": "media-001",
                          "fetch_url": "static.anomalyfederal.io/media/media-001",
                          "type": "video",
                          "analysis": {
                            "object_detection": [
                              {
                                "bounding_box": [
                                  0.2,
                                  0.3,
                                  0.4,
                                  0.5
                                ],
                                "confidence": 0.95
                              }
                            ],
                            "triangulation": {
                              "flight_path": [
                                {
                                  "timestamp": "2024-11-27T10:00:05Z",
                                  "position": {
                                    "latitude": 37.1623,
                                    "longitude": -76.2605,
                                    "altitude_meters": 500
                                  }
                                },
                                {
                                  "timestamp": "2024-11-27T10:00:10Z",
                                  "position": {
                                    "latitude": 37.1625,
                                    "longitude": -76.2603,
                                    "altitude_meters": 520
                                  }
                                }
                              ]
                            }
                          }
                        }
                      ]
                    },
                    {
                      "report_id": "report-67890",
                      "report_started_at": "2024-11-27T12:00:00Z",
                      "duration_ms": 15000,
                      "location": {
                        "latitude": 37.1921,
                        "longitude": -76.2907
                      },
                      "details": {
                        "shape": "orb",
                        "movement_pattern": "straight_and_steady",
                        "noise_pattern": "low_hum",
                        "colors": [
                          "red"
                        ]
                      },
                      "media_files": [
                        {
                          "id": "media-002",
                          "fetch_url": "static.anomalyfederal.io/media/media-002",
                          "type": "photo",
                          "analysis": {
                            "object_detection": [
                              {
                                "bounding_box": [
                                  0.1,
                                  0.1,
                                  0.2,
                                  0.2
                                ],
                                "confidence": 0.87
                              }
                            ],
                            "triangulation": {
                              "flight_path": [
                                {
                                  "timestamp": "2024-11-27T12:00:05Z",
                                  "position": {
                                    "latitude": 37.1923,
                                    "longitude": -76.2905,
                                    "altitude_meters": 400
                                  }
                                },
                                {
                                  "timestamp": "2024-11-27T12:00:10Z",
                                  "position": {
                                    "latitude": 37.1925,
                                    "longitude": -76.2903,
                                    "altitude_meters": 420
                                  }
                                }
                              ]
                            }
                          }
                        }
                      ]
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/mobile-network-activation/estimate": {
      "post": {
        "tags": [
          "Mobile Alert Network Activation"
        ],
        "summary": "Estimate reach for a network activation",
        "description": "Use this API to estimate the number of mobile users in Anomaly Federal's Mobile Alert Network who can be reached by a network activation request.  Network activation targets a specific **Area of Interest (AoI)** to encourage users within that region to look up for report corroboration.\n",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NetworkActivationRequest"
              },
              "examples": {
                "example-1": {
                  "summary": "Mobile network activation request reach estimate",
                  "value": {
                    "area_of_interest": {
                      "type": "bounding_box",
                      "coordinates": [
                        {
                          "latitude": 38.6442,
                          "longitude": -77.2797
                        },
                        {
                          "latitude": 38.8442,
                          "longitude": -77.0797
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Estimated reach for activation request with location metadata",
            "content": {
              "application/json": {
                "example": {
                  "estimated_users": 1251,
                  "location_metadata": {
                    "coverage_sq_km": 1036,
                    "city": "Langley",
                    "state": "VA",
                    "country": "United States",
                    "entities_matched": [
                      {
                        "name": "Langley Air Force Base",
                        "type": "AIR_FORCE_BASE"
                      }
                    ]
                  },
                  "area_of_interest": {
                    "type": "bounding_box",
                    "coordinates": [
                      {
                        "latitude": 37.0821,
                        "longitude": -76.3607
                      },
                      {
                        "latitude": 37.2821,
                        "longitude": -76.1607
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/mobile-network-activation": {
      "post": {
        "tags": [
          "Mobile Alert Network Activation"
        ],
        "summary": "Activate the Mobile Alert Network",
        "description": "Broadcast an **on-demand network activation** to Anomaly Federal's Mobile Alert Network. A network activation targets mobile users in a specific **Area of Interest (AoI)** to encourage them to observe the skies and trigger a funnel of report corroborations.\n\n**Details**:\n- By default, the **AoI** for the activation will also create a new configuration, \n  allowing users to receive continued reports matching the defined parameters\n  after the broadcast ends.\n\n- To disable this behavior, set the `create_configuration` flag to `false`.\n",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "A unique name for the activation request."
                  },
                  "area_of_interest": {
                    "$ref": "#/components/schemas/AreaOfInterest"
                  },
                  "expires_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The expiration time for the activation. If specified,  the activation will continue broadcasting to new users who enter the AoI during the active period.\n"
                  },
                  "text_description": {
                    "type": "string",
                    "description": "Information"
                  },
                  "create_configuration": {
                    "type": "boolean",
                    "description": "Whether to create a new activity-feed-configuration using the activation's AoI.  Defaults to `true`. If set to `false`, users will only receive activity reports during the activation period, not ongoing configuration-based reports.\n"
                  }
                },
                "required": [
                  "name",
                  "area_of_interest"
                ]
              },
              "examples": {
                "example-1": {
                  "summary": "Mobile network activation request",
                  "value": {
                    "name": "langley-activation",
                    "area_of_interest": {
                      "type": "bounding_box",
                      "coordinates": [
                        {
                          "latitude": 37.0821,
                          "longitude": -76.3607
                        },
                        {
                          "latitude": 37.2821,
                          "longitude": -76.1607
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Network activation successful",
            "content": {
              "application/json": {
                "example": {
                  "activation_name": "langley-activation",
                  "status": "active",
                  "broadcast_message": "Reports of aerial activity have been detected in your area. See anything strange in the sky? Submit your report now.",
                  "expires_at": "2024-12-03T12:00:00Z",
                  "users_reached": 1259,
                  "location_metadata": {
                    "coverage_sq_km": 1036,
                    "city": "Langley",
                    "state": "VA",
                    "country": "United States",
                    "entities_matched": [
                      {
                        "name": "Langley Air Force Base",
                        "type": "AIR_FORCE_BASE"
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/mobile-network-activation/{name}": {
      "get": {
        "tags": [
          "Mobile Alert Network Activation"
        ],
        "summary": "Retrieve activation details and reach",
        "description": "Retrieve details of a Mobile Alert Network Activation request,  including the current or final number of users reached.\n\n**Behavior**:\n- For one-time activations, the response includes the final reach count.\n- For activations with an expiration date:\n  - If the activation is still active, the response includes the current reach.\n  - If the activation has expired, the response includes the final total reach.\n",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique identifier for the activation."
          }
        ],
        "responses": {
          "200": {
            "description": "Details of the network activation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "activation_id": {
                      "type": "string",
                      "description": "The unique identifier for the activation request."
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "active",
                        "expired"
                      ],
                      "description": "The status of the activation."
                    },
                    "expires_at": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Expiration date/time of the activation (if applicable)."
                    },
                    "users_reached": {
                      "type": "integer",
                      "description": "Total number of users reached by the activation."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Configuration": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name for the configuration."
          },
          "webhook_url": {
            "type": "string",
            "format": "uri",
            "description": "Webhook endpoint to receive activty feed reports."
          },
          "area_of_interest": {
            "$ref": "#/components/schemas/AreaOfInterest"
          },
          "criteria": {
            "$ref": "#/components/schemas/ConfigurationCriteria"
          }
        }
      },
      "ConfigurationUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "webhook_url": {
            "type": "string"
          },
          "criteria": {
            "$ref": "#/components/schemas/ConfigurationCriteria"
          }
        }
      },
      "ActivityFeedEntry": {
        "type": "object",
        "properties": {
          "entry_id": {
            "type": "string"
          },
          "source_type": {
            "type": "string",
            "enum": [
              "configuration",
              "on_demand",
              "global"
            ]
          },
          "report": {
            "$ref": "#/components/schemas/Report"
          }
        }
      },
      "NetworkActivationRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "A unique name for the activation request."
          },
          "area_of_interest": {
            "$ref": "#/components/schemas/AreaOfInterest"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "description": "The expiration time for the network activation request."
          },
          "text_description": {
            "type": "string",
            "description": "Information or details relating to the specific request."
          }
        }
      },
      "AreaOfInterest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "bounding_box",
              "radius",
              "polygon",
              "global"
            ],
            "description": "Defines the type of area for the configuration:\n- `bounding_box`: A rectangular area.\n- `radius`: A circular area.\n- `polygon`: A custom polygon area.\n- `global`: Includes reports from all areas.\n"
          },
          "coordinates": {
            "type": "array",
            "description": "Coordinates defining the area of interest. Not required for `global`.",
            "items": {
              "type": "object",
              "properties": {
                "latitude": {
                  "type": "number"
                },
                "longitude": {
                  "type": "number"
                }
              }
            },
            "minItems": 2
          },
          "radius": {
            "type": "number",
            "description": "Radius for the `radius` type, measured in the unit specified."
          },
          "unit": {
            "type": "string",
            "enum": [
              "mi",
              "km"
            ],
            "description": "Unit of measurement for the radius."
          }
        }
      },
      "ConfigurationCriteria": {
        "type": "object",
        "properties": {
          "shapes": {
            "type": "array",
            "description": "List of craft shapes to be included",
            "items": {
              "type": "string"
            }
          },
          "movement_patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "noise_patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "anomaly_score_threshold": {
            "type": "number",
            "description": "Minimum Anomaly Score threshold for a report to be included"
          },
          "witness_count": {
            "type": "number",
            "description": "Minimum number of witnesses to have corroborated the report"
          },
          "media_types_included": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "time_of_day": {
            "type": "array",
            "description": "A range to define the localized times of day for a report to be included",
            "example": [
              "00:00",
              "06:00"
            ],
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Report": {
        "type": "object",
        "properties": {
          "report_id": {
            "type": "string"
          },
          "report_started_at": {
            "type": "string",
            "format": "date-time"
          },
          "duration_ms": {
            "type": "number"
          },
          "location": {
            "type": "object",
            "properties": {
              "latitude": {
                "type": "number"
              },
              "longitude": {
                "type": "number"
              }
            }
          },
          "details": {
            "type": "object",
            "properties": {
              "shape": {
                "type": "string"
              },
              "movement_pattern": {
                "type": "string"
              },
              "noise_pattern": {
                "type": "string"
              },
              "anomaly_score": {
                "type": "number"
              }
            }
          },
          "media_files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                },
                "analysis": {
                  "type": "object",
                  "properties": {
                    "object_detection": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "bounding_box": {
                            "type": "array",
                            "items": {
                              "type": "number"
                            }
                          },
                          "confidence": {
                            "type": "number"
                          }
                        }
                      }
                    },
                    "triangulation": {
                      "type": "object",
                      "properties": {
                        "flight_path": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "timestamp": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "position": {
                                "type": "object",
                                "properties": {
                                  "latitude": {
                                    "type": "number"
                                  },
                                  "longitude": {
                                    "type": "number"
                                  },
                                  "altitude_meters": {
                                    "type": "number"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}