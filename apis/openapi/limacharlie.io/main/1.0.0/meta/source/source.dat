            "schema": {
              "type": "string"
            },
            "in": "query"
          },
          {
            "name": "backup_count",
            "description": "maximum number of output in rotation",
            "schema": {
              "type": "string"
            },
            "in": "query"
          },
          {
            "name": "bucket",
            "description": "name of the bucket for output",
            "schema": {
