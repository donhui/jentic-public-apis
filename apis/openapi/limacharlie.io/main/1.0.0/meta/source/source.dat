            "schema": {
              "enum": [
                "1",
                "t",
                "T",
                "true",
                "TRUE",
                "True",
                "0",
                "f",
                "F",
                "false",
                "FALSE",
                "False"
              ]
            },
            "in": "query"
          },
          {
            "name": "is_compression",
            "description": "if data should be sent compressed (true, false)",
            "schema": {
              "enum": [
