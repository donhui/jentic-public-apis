{
  "openapi": "3.0.3",
  "info": {
    "title": "Dellyman Delivery API",
    "description": "Dellyman delivery logistics API for managing orders, tracking shipments, and obtaining delivery quotes.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://dellyman.com/rest-api/"
  },
  "servers": [
    {
      "url": "https://dellyman.com/api/v3.0",
      "description": "Production server"
    },
    {
      "url": "https://dev.dellyman.com/api/v3.0",
      "description": "Test/Development server"
    }
  ],
  "paths": {
    "/Vehicles": {
      "get": {
        "operationId": "getCarriers",
        "summary": "Get available carrier/vehicle types",
        "description": "Retrieve available delivery vehicle types and their capacities.",
        "tags": [
          "Vehicles"
        ],
        "responses": {
          "200": {
            "description": "Successful response with vehicle list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VehicleListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
