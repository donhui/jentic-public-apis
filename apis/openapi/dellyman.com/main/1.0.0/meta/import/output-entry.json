  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed as Bearer token in Authorization header"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": {
            "type": "integer"
          },
          "ResponseMessage": {
            "type": "string"
          }
        }
      },
      "Vehicle": {
        "type": "object",
        "properties": {
          "VehicleID": {
            "type": "integer"
          },
          "Name": {
            "type": "string"
          },
          "Capacity": {
            "type": "string"
          }
        }
      },
      "VehicleListResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": {
            "type": "integer"
          },
          "ResponseMessage": {
            "type": "string"
          },
          "Vehicles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Vehicle"
            }
          }
        }
      },
      "State": {
        "type": "object",
        "properties": {
          "StateID": {
            "type": "integer"
          },
          "Name": {
            "type": "string"
          }
        }
      },
      "StateListResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": {
            "type": "integer"
          },
          "ResponseMessage": {
            "type": "string"
          },
          "States": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/State"
            }
          }
        }
      },
      "City": {
        "type": "object",
        "properties": {
          "CityID": {
            "type": "integer"
          },
          "StateID": {
            "type": "integer"
          },
          "Name": {
            "type": "string"
          }
        }
      },
      "GetCitiesRequest": {
        "type": "object",
        "required": [
          "StateID"
        ],
        "properties": {
          "StateID": {
            "type": "integer",
            "description": "ID of the state to retrieve cities for"
          }
        }
      },
      "CityListResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": {
            "type": "integer"
          },
          "ResponseMessage": {
            "type": "string"
          },
          "Cities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/City"
            }
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "Address": {
            "type": "string"
          },
          "Latitude": {
            "type": "number",
            "format": "double"
          },
          "Longitude": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "GetQuotesRequest": {
        "type": "object",
        "required": [
          "PaymentMode",
          "Vehicle",
          "PickupAddress",
          "DeliveryAddress"
        ],
        "properties": {
          "PaymentMode": {
            "type": "string",
            "description": "Payment mode for the order"
          },
          "Vehicle": {
            "type": "string",
            "description": "Vehicle type for delivery"
          },
          "IsInstantDelivery": {
            "type": "boolean",
            "description": "Whether this is an instant delivery"
          },
          "PickupRequestedTime": {
            "type": "string",
            "description": "Requested pickup time"
          },
          "IsProductOrder": {
            "type": "boolean",
            "description": "Whether this is a product order"
          },
          "ProductAmount": {
            "type": "number",
            "description": "Amount of the product"
          },
          "PickupRequestedDate": {
            "type": "string",
            "description": "Requested pickup date"
          },
          "PickupAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "DeliveryAddress": {
            "$ref": "#/components/schemas/Address"
          }
        }
      },
      "Company": {
        "type": "object",
        "properties": {
          "CompanyID": {
            "type": "integer"
          },
          "CompanyName": {
            "type": "string"
          },
          "TotalPrice": {
            "type": "number"
          },
          "PayableAmount": {
            "type": "number"
          }
        }
      },
      "QuotesResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": {
            "type": "integer"
          },
          "ResponseMessage": {
            "type": "string"
          },
          "Companies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Company"
            }
          },
          "RejectedCompanies": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "Products": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "Distance": {
            "type": "number"
          }
        }
      },
      "Package": {
        "type": "object",
        "properties": {
          "Description": {
            "type": "string"
          },
          "Weight": {
            "type": "number"
          },
          "Quantity": {
            "type": "integer"
          },
          "DeliveryContactName": {
            "type": "string"
          },
          "DeliveryContactNumber": {
            "type": "string"
          },
          "DeliveryAddress": {
            "type": "string"
          },
          "DeliveryLatitude": {
            "type": "number",
            "format": "double"
          },
          "DeliveryLongitude": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": [
          "CompanyID",
          "PaymentMode",
          "Vehicle",
          "Packages"
        ],
        "properties": {
          "CompanyID": {
            "type": "integer",
            "description": "ID of the delivery company"
          },
          "PaymentMode": {
            "type": "string",
            "description": "Payment mode"
          },
          "Vehicle": {
            "type": "string",
            "description": "Vehicle type"
          },
          "PickupContactName": {
            "type": "string"
          },
          "PickupContactNumber": {
            "type": "string"
          },
          "PickupAddress": {
            "type": "string"
          },
          "PickupLatitude": {
            "type": "number",
            "format": "double"
          },
          "PickupLongitude": {
            "type": "number",
            "format": "double"
          },
          "Packages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Package"
            }
          }
        }
      },
      "CreateOrderResponse": {
