{
  "openapi": "3.0.3",
  "info": {
    "title": "Dellyman Delivery API",
    "description": "API for managing deliveries, tracking orders, and obtaining quotes through the Dellyman logistics platform.",
    "version": "3.0",
    "contact": {
      "name": "Dellyman",
      "url": "https://dellyman.com/rest-api/"
    }
  },
  "servers": [
    {
      "url": "https://dellyman.com/api/v3.0",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Locations", "description": "Endpoints for retrieving vehicles, states, and cities" },
    { "name": "Quotes", "description": "Endpoints for obtaining delivery quotes" },
    { "name": "Orders", "description": "Endpoints for creating and retrieving orders" },
    { "name": "Tracking", "description": "Endpoints for tracking orders and packages" },
    { "name": "Interstate", "description": "Endpoints for interstate delivery rates, quotes, and orders" }
  ],
  "paths": {
    "/Vehicles": {
      "get": {
        "operationId": "getVehicles",
        "summary": "Get available carriers",
        "description": "Retrieve a list of available vehicle/carrier types for deliveries.",
        "tags": ["Locations"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VehiclesResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/States": {
      "get": {
        "operationId": "getStates",
        "summary": "List available states",
        "description": "Retrieve a list of states available for delivery operations.",
        "tags": ["Locations"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatesResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/Cities": {
      "post": {
        "operationId": "getCities",
        "summary": "Get cities for a state",
        "description": "Retrieve a list of cities for the specified state.",
        "tags": ["Locations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CitiesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CitiesResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/GetQuotes": {
      "post": {
        "operationId": "getQuotes",
        "summary": "Get delivery quotes",
        "description": "Obtain delivery quotes based on pickup and delivery details.",
        "tags": ["Quotes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetQuotesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotesResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/BookOrder": {
      "post": {
        "operationId": "bookOrder",
        "summary": "Create an order",
        "description": "Book a single delivery order with pickup and package details.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookOrderResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/BookOrders": {
      "post": {
        "operationId": "bookOrders",
        "summary": "Create multiple orders",
        "description": "Book multiple delivery orders in a single request.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookOrdersRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Orders created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookOrdersResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/GetOrder": {
      "post": {
        "operationId": "getOrder",
        "summary": "Get order details",
        "description": "Retrieve detailed information about a specific order.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderIDRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetOrderResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/GetPackageLabel": {
      "post": {
        "operationId": "getPackageLabel",
        "summary": "Get package label in base64",
        "description": "Retrieve the shipping label for an order encoded as a base64 string.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderIDRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PackageLabelResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/TrackOrder": {
      "post": {
        "operationId": "trackOrder",
        "summary": "Track order status",
        "description": "Get the current tracking status for an order.",
        "tags": ["Tracking"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackingIDRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackOrderResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/TrackPackage": {
      "post": {
        "operationId": "trackPackage",
        "summary": "Track a specific package",
        "description": "Get the current tracking status for a specific package within an order.",
        "tags": ["Tracking"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackingIDRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackPackageResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/OrderEventDetails": {
      "post": {
        "operationId": "getOrderEventDetails",
        "summary": "Get order event history",
        "description": "Retrieve the full event history for a tracked order.",
        "tags": ["Tracking"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackingIDRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderEventDetailsResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/GetInterstateRates": {
      "post": {
        "operationId": "getInterstateRates",
        "summary": "List interstate rates",
        "description": "Retrieve available interstate delivery rates.",
        "tags": ["Interstate"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InterstateRatesResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/GetCitiesInState": {
      "post": {
        "operationId": "getCitiesInState",
        "summary": "Get cities for interstate delivery",
        "description": "Retrieve a list of cities in a destination state for interstate deliveries.",
        "tags": ["Interstate"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetCitiesInStateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CitiesResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/GetInterstateQuote": {
      "post": {
        "operationId": "getInterstateQuote",
        "summary": "Get interstate delivery quote",
        "description": "Obtain a quote for an interstate delivery.",
        "tags": ["Interstate"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetInterstateQuoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InterstateQuoteResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/BookInterstateOrder": {
      "post": {
        "operationId": "bookInterstateOrder",
        "summary": "Create an interstate order",
        "description": "Book an interstate delivery order with full pickup, delivery, and package details.",
        "tags": ["Interstate"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BookInterstateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookOrderResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key passed as a Bearer token in the Authorization header."
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Authentication failed or API key is missing/invalid.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" }
        }
      },
      "Vehicle": {
        "type": "object",
        "properties": {
          "VehicleID": { "type": "integer" },
          "VehicleName": { "type": "string" },
          "VehicleDescription": { "type": "string" }
        }
      },
      "VehiclesResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Vehicle" }
          }
        }
      },
      "State": {
        "type": "object",
        "properties": {
          "StateID": { "type": "integer" },
          "StateName": { "type": "string" }
        }
      },
      "StatesResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/State" }
          }
        }
      },
      "CitiesRequest": {
        "type": "object",
        "required": ["StateID"],
        "properties": {
          "StateID": {
            "type": "integer",
            "description": "The ID of the state to retrieve cities for."
          }
        }
      },
      "City": {
        "type": "object",
        "properties": {
          "CityID": { "type": "integer" },
          "CityName": { "type": "string" }
        }
      },
      "CitiesResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/City" }
          }
        }
      },
      "DeliveryAddress": {
        "type": "object",
        "properties": {
          "Address": { "type": "string" },
          "Latitude": { "type": "number", "format": "double" },
          "Longitude": { "type": "number", "format": "double" }
        }
      },
      "GetQuotesRequest": {
        "type": "object",
        "required": [
          "PaymentMode",
          "Vehicle",
          "PickupRequestedTime",
          "PickupRequestedDate",
          "PickupAddress",
          "DeliveryAddress"
        ],
        "properties": {
          "PaymentMode": {
            "type": "string",
            "description": "Payment mode for the delivery."
          },
          "Vehicle": {
            "type": "string",
            "description": "Vehicle type for the delivery."
          },
          "PickupRequestedTime": {
            "type": "string",
            "description": "Requested pickup time."
          },
          "PickupRequestedDate": {
            "type": "string",
            "description": "Requested pickup date."
          },
          "PickupAddress": {
            "type": "string",
            "description": "Address for pickup."
          },
          "DeliveryAddress": {
            "type": "string",
            "description": "Address for delivery."
          }
        }
      },
      "Quote": {
        "type": "object",
        "properties": {
          "CourierID": { "type": "integer" },
          "CourierName": { "type": "string" },
          "ServiceType": { "type": "string" },
          "Total": { "type": "number", "format": "double" },
          "Currency": { "type": "string" },
          "EstimatedDeliveryTime": { "type": "string" }
        }
      },
      "QuotesResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Quote" }
          }
        }
      },
      "Package": {
        "type": "object",
        "properties": {
          "PackageDescription": { "type": "string" },
          "DeliveryContactName": { "type": "string" },
          "DeliveryContactNumber": { "type": "string" },
          "DeliveryGooglePlaceAddress": { "type": "string" },
          "DeliveryRequestedDate": { "type": "string" },
          "DeliveryRequestedTime": { "type": "string" },
          "PackageWeight": { "type": "string" }
        }
      },
      "BookOrderRequest": {
        "type": "object",
        "required": [
          "OrderRef",
          "CompanyID",
          "PaymentMode",
          "Vehicle",
          "PickUpContactName",
          "PickUpContactNumber",
          "PickUpGooglePlaceAddress",
          "PickUpRequestedDate",
          "PickUpRequestedTime",
          "DeliveryRequestedTime",
          "Packages"
        ],
        "properties": {
          "OrderRef": {
            "type": "string",
            "description": "Your unique reference for this order."
          },
          "CompanyID": {
            "type": "string",
            "description": "Company identifier."
          },
          "PaymentMode": {
            "type": "string",
            "description": "Payment mode for the delivery."
          },
          "Vehicle": {
            "type": "string",
            "description": "Vehicle type for the delivery."
          },
          "PickUpContactName": {
            "type": "string",
            "description": "Contact name at pickup location."
          },
          "PickUpContactNumber": {
            "type": "string",
            "description": "Contact phone number at pickup location."
          },
          "PickUpGooglePlaceAddress": {
            "type": "string",
            "description": "Google Place address for pickup."
          },
          "PickUpRequestedDate": {
            "type": "string",
            "description": "Requested date for pickup."
          },
          "PickUpRequestedTime": {
            "type": "string",
            "description": "Requested time for pickup."
          },
          "DeliveryRequestedTime": {
            "type": "string",
            "description": "Requested time for delivery."
          },
          "Packages": {
            "type": "array",
            "description": "List of packages in this order.",
            "items": { "$ref": "#/components/schemas/Package" }
          }
        }
      },
      "BookOrderResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "object",
            "properties": {
              "OrderID": { "type": "string" },
              "TrackingID": { "type": "string" },
              "OrderRef": { "type": "string" },
              "Status": { "type": "string" }
            }
          }
        }
      },
      "BookOrdersRequest": {
        "type": "object",
        "required": ["Orders"],
        "properties": {
          "Orders": {
            "type": "array",
            "description": "Array of orders to create.",
            "items": { "$ref": "#/components/schemas/BookOrderRequest" }
          }
        }
      },
      "BookOrdersResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "OrderID": { "type": "string" },
                "TrackingID": { "type": "string" },
                "OrderRef": { "type": "string" },
                "Status": { "type": "string" }
              }
            }
          }
        }
      },
      "OrderIDRequest": {
        "type": "object",
        "required": ["OrderID"],
        "properties": {
          "OrderID": {
            "type": "string",
            "description": "The unique identifier of the order."
          }
        }
      },
      "GetOrderResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "object",
            "properties": {
              "OrderID": { "type": "string" },
              "OrderRef": { "type": "string" },
              "TrackingID": { "type": "string" },
              "Status": { "type": "string" },
              "Vehicle": { "type": "string" },
              "PaymentMode": { "type": "string" },
              "PickUpAddress": { "type": "string" },
              "PickUpContactName": { "type": "string" },
              "PickUpContactNumber": { "type": "string" },
              "Packages": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Package" }
              }
            }
          }
        }
      },
      "PackageLabelResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "object",
            "properties": {
              "Label": {
                "type": "string",
                "format": "byte",
                "description": "Base64-encoded package label."
              }
            }
          }
        }
      },
      "TrackingIDRequest": {
        "type": "object",
        "required": ["TrackingID"],
        "properties": {
          "TrackingID": {
            "type": "string",
            "description": "The tracking identifier for the order or package."
          }
        }
      },
      "TrackOrderResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "object",
            "properties": {
              "OrderID": { "type": "string" },
              "TrackingID": { "type": "string" },
              "Status": { "type": "string" },
              "RiderName": { "type": "string" },
              "RiderPhone": { "type": "string" },
              "EstimatedDeliveryTime": { "type": "string" }
            }
          }
        }
      },
      "TrackPackageResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "object",
            "properties": {
              "TrackingID": { "type": "string" },
              "PackageStatus": { "type": "string" },
              "DeliveryAddress": { "type": "string" },
              "DeliveryContactName": { "type": "string" },
              "DeliveryContactNumber": { "type": "string" }
            }
          }
        }
      },
      "OrderEvent": {
        "type": "object",
        "properties": {
          "EventID": { "type": "integer" },
          "EventName": { "type": "string" },
          "EventDescription": { "type": "string" },
          "EventDate": { "type": "string", "format": "date-time" }
        }
      },
      "OrderEventDetailsResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrderEvent" }
          }
        }
      },
      "InterstateRate": {
        "type": "object",
        "properties": {
          "RateID": { "type": "integer" },
          "Origin": { "type": "string" },
          "Destination": { "type": "string" },
          "Vehicle": { "type": "string" },
          "Rate": { "type": "number", "format": "double" },
          "Currency": { "type": "string" }
        }
      },
      "InterstateRatesResponse": {
        "type": "object",
        "properties": {
          "ResponseCode": { "type": "string" },
          "ResponseMessage": { "type": "string" },
          "Data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/InterstateRate" }
          }
        }
      },
      "GetCitiesInStateRequest": {
        "type": "object",
        "required": ["DestinationState"],
        "properties": {
          "DestinationState": {
            "type": "string",
            "description": "The destination state to get cities for."
          }
        }
      },
      "GetInterstateQuoteRequest": {
        "type": "object",
        "required": [
          "Vehicle",
          "PackageWeight",
          "PickupState",
          "PickupCity",
          "DeliveryState",
          "DeliveryCity",
          "DeliverTo"
        ],
        "properties": {
          "Vehicle": {
            "type": "string",
            "description": "Vehicle type for the interstate delivery."
          },
          "PackageWeight": {
            "type": "string",
            "description": "Weight of the package."
          },
