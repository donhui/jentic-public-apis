{
  "openapi": "3.0.3",
  "info": {
    "title": "Buckaroo Checkout JSON Gateway API",
    "version": "1.0.0",
    "description": "Buckaroo payment gateway API for processing transactions, data requests, checking statuses, managing refunds, and validating IBANs.",
    "x-jentic-source-url": "https://docs.buckaroo.io/reference"
