              }
            }
          },
          "CustomParameters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CustomParameter"
            }
          },
          "AdditionalParameters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CustomParameter"
            }
