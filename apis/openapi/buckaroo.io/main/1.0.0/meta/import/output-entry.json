      "CreateTransactionRequest": {
        "type": "object",
        "properties": {
          "Currency": {
            "type": "string"
          },
          "AmountDebit": {
            "type": "number"
          },
          "AmountCredit": {
            "type": "number"
          },
          "Invoice": {
            "type": "string"
          },
          "Order": {
            "type": "string"
          },
          "Description": {
            "type": "string"
          },
          "ClientIP": {
            "type": "object",
            "properties": {
              "Type": {
                "type": "integer"
              },
              "Address": {
                "type": "string"
              }
            }
          },
          "ReturnURL": {
            "type": "string",
            "format": "uri"
          },
          "ReturnURLCancel": {
            "type": "string",
            "format": "uri"
          },
          "ReturnURLError": {
            "type": "string",
            "format": "uri"
          },
          "ReturnURLReject": {
            "type": "string",
            "format": "uri"
          },
          "Services": {
            "type": "object",
            "properties": {
              "ServiceList": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ServiceItem"
                }
              }
            }
          },
          "CustomParameters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CustomParameter"
            }
          }
        },
        "required": [
