              }
            }
          },
          "ReturnURL": {
            "type": "string",
            "format": "uri"
          },
          "ReturnURLCancel": {
            "type": "string",
            "format": "uri"
          },
          "ReturnURLError": {
            "type": "string",
            "format": "uri"
          },
          "ReturnURLReject": {
            "type": "string",
            "format": "uri"
          },
          "Invoice": {
            "type": "string"
          },
          "Description": {
            "type": "string"
          },
          "Currency": {
            "type": "string"
          },
          "Amount": {
            "type": "number"
          },
          "AmountCredit": {
            "type": "number"
          },
          "OriginalTransactionKey": {
