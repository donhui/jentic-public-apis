{
  "openapi": "3.0.3",
  "info": {
    "title": "New Dialogue REST API",
    "version": "1.0.0",
    "description": "New Dialogue is an AI driven data insight tool designed to understand your content and converse with you over your operational knowledge.",
    "x-jentic-source-url": "https://ai.newdialogue.com/docs/rest-api.html"
  },
  "servers": [
    {
      "url": "https://ai.newdialogue.com/api/v1"
    }
  ],
  "security": [
    {
      "XAuthorization": []
    }
  ],
  "tags": [
    {
      "name": "Dialogue",
      "description": "Core dialogue and query operations"
    },
    {
      "name": "Integrations",
      "description": "Integration management operations"
    },
    {
      "name": "Messages",
      "description": "Message and conversation history operations"
    },
    {
      "name": "Zapier",
      "description": "Zapier integration endpoints"
    }
  ],
  "paths": {
    "/newdialogue": {
      "get": {
        "operationId": "getFileDialogue",
        "summary": "Get file dialogue",
        "description": "Query the AI dialogue system with a question and get a streamed response.",
        "tags": ["Dialogue"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "The query string to send to the dialogue system",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK - Returns streamed response",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/api": {
      "get": {
        "operationId": "getFileDialogueFromApi",
        "summary": "Get file dialogue from API",
        "description": "Query the AI dialogue system via the API endpoint with optional message regeneration.",
        "tags": ["Dialogue"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "The query string to send to the dialogue system",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "regenId",
            "in": "query",
            "required": false,
            "description": "ID of a message to regenerate",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK - Returns streamed response",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/integrations/{integrationId}/fields/{fieldId}": {
      "get": {
        "operationId": "getIntegrationField",
        "summary": "Get integration field",
        "description": "Retrieve a specific field from a specific integration.",
        "tags": ["Integrations"],
        "parameters": [
          {
            "name": "integrationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "fieldId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewDialogueIntegrationFieldResource"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "post": {
        "operationId": "updateIntegrationField",
        "summary": "Update integration field",
        "description": "Create or update a field in a specific integration.",
        "tags": ["Integrations"],
        "parameters": [
          {
            "name": "integrationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "fieldId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewDialogueIntegrationFieldResource"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewDialogueIntegrationFieldResource"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/integrations": {
      "get": {
        "operationId": "getIntegrations",
        "summary": "Get integrations",
        "description": "Retrieve all available integrations.",
        "tags": ["Integrations"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NewDialogueIntegrationResource"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/integrations/{integrationId}/share": {
      "post": {
        "operationId": "shareContent",
        "summary": "Share content via integration",
        "description": "Share content through a specific integration.",
        "tags": ["Integrations"],
        "parameters": [
          {
            "name": "integrationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ShareContentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/messages/{messageId}": {
      "get": {
        "operationId": "getMessage",
        "summary": "Get a message",
        "description": "Retrieve a specific message by its ID.",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResource"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/messages": {
      "get": {
        "operationId": "getMessages",
        "summary": "Get messages",
        "description": "Retrieve all messages.",
        "tags": ["Messages"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageResource"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/messages/history": {
      "get": {
        "operationId": "getHistory",
        "summary": "Get message history",
        "description": "Retrieve the conversation history.",
        "tags": ["Messages"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageResource"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/messages/saved": {
      "get": {
        "operationId": "getSavedMessages",
        "summary": "Get saved messages",
        "description": "Retrieve all saved messages.",
        "tags": ["Messages"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MessageResource"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/messages/{messageId}/regenerate": {
      "post": {
        "operationId": "regenerateMessage",
        "summary": "Regenerate a message",
        "description": "Regenerate a specific AI response message.",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/messages/{messageId}/save": {
      "post": {
        "operationId": "saveResponse",
        "summary": "Save a response",
        "description": "Save a specific message response for later reference.",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "delete": {
        "operationId": "unsaveResponse",
        "summary": "Unsave a response",
        "description": "Remove a message from saved responses.",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/newdialogue/messages/{messageId}/response": {
      "delete": {
        "operationId": "deleteResponse",
        "summary": "Delete a response",
        "description": "Delete a specific AI response message.",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/zapier/newdialogue/sample": {
      "get": {
        "operationId": "getZapierSample",
        "summary": "Get Zapier sample data",
        "description": "Get sample data for Zapier integration testing.",
        "tags": ["Zapier"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/zapier/webhooks/newdialogue": {
      "post": {
        "operationId": "setNewDialogueWebhook",
        "summary": "Set New Dialogue webhook",
        "description": "Register a webhook URL for New Dialogue events (used by Zapier triggers).",
        "tags": ["Zapier"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "delete": {
        "operationId": "deleteNewDialogueWebhook",
        "summary": "Delete New Dialogue webhook",
        "description": "Remove a registered webhook for New Dialogue events.",
        "tags": ["Zapier"],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "XAuthorization": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Authorization"
      }
    },
    "schemas": {
      "NewDialogueIntegrationFieldResource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "NewDialogueIntegrationResource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NewDialogueIntegrationFieldResource"
            }
          }
        }
      },
      "MessageResource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "content": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "saved": {
            "type": "boolean"
          }
        }
      },
      "ShareContentRequest": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "The content to share"
          },
          "messageId": {
            "type": "integer",
            "format": "int64",
            "description": "The ID of the message to share"
          }
        }
      },
      "WebhookRequest": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "The webhook URL to register"
          }
        }
      }
    }
  }
}