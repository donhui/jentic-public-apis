  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication using API key credentials"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" }
        }
      },
      "CreateCampaignRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "segment_uuid": { "type": "string" }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CampaignDetail": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "stats": { "type": "object", "additionalProperties": true }
        }
      },
      "CampaignScheduleRequest": {
        "type": "object",
        "properties": {
          "schedule_at": { "type": "string", "format": "date-time" },
          "timezone": { "type": "string" }
        }
      },
      "TriggerCampaignRequest": {
        "type": "object",
        "properties": {
          "campaign_uuid": { "type": "string" },
          "customer_id": { "type": "string" },
          "email": { "type": "string" }
        }
      },
      "BulkTriggerCampaignRequest": {
        "type": "object",
        "properties": {
          "campaign_uuid": { "type": "string" },
          "customers": { "type": "array", "items": { "type": "object", "properties": { "customer_id": { "type": "string" }, "email": { "type": "string" } } } }
        }
      },
      "EventRequest": {
        "type": "object",
        "required": ["event"],
        "properties": {
          "event": { "type": "string" },
          "customer_id": { "type": "string" },
          "email": { "type": "string" },
          "properties": { "type": "object", "additionalProperties": true }
        }
      },
      "BulkEventsRequest": {
        "type": "object",
        "properties": {
          "events": { "type": "array", "items": { "$ref": "#/components/schemas/EventRequest" } }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "event": { "type": "string" },
          "customer_id": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "properties": { "type": "object", "additionalProperties": true }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "email": { "type": "string" },
          "customer_id": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CustomerRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "customer_id": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" }
        }
      },
      "CustomerIdentifier": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "customer_id": { "type": "string" }
        }
      },
      "MergeCustomersRequest": {
        "type": "object",
        "properties": {
          "source_customer_id": { "type": "string" },
          "target_customer_id": { "type": "string" }
        }
      },
      "EmailTemplate": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "subject": { "type": "string" },
          "body": { "type": "string" }
        }
      },
      "EmailTemplateRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "subject": { "type": "string" },
          "body": { "type": "string" },
          "from_email": { "type": "string" }
        }
      },
      "Segment": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "user_count": { "type": "integer" }
        }
      },
      "EmailValidationResponse": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "valid": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      },
      "SubscriptionGroup": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Catalog": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "item_count": { "type": "integer" }
        }
      },
      "CatalogRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        }
      }
    }
  }
}