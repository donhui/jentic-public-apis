{
  "openapi": "3.0.3",
  "info": {
    "title": "Blueshift API",
    "version": "1.0.0",
    "description": "Blueshift is a customer data and marketing automation platform. The API enables management of campaigns, events, customers, email/push/SMS templates, catalogs, segments, custom user lists, promotions, shared assets, email validation, and subscription groups.",
    "x-jentic-source-url": "https://developer.blueshift.com/"
  },
  "servers": [
    {
      "url": "https://api.blueshift.com",
      "description": "Blueshift Production API"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    { "name": "Campaigns", "description": "Campaign management and execution" },
    { "name": "Events", "description": "Event tracking and history" },
    { "name": "Customers", "description": "Customer profile management" },
    { "name": "Email Templates", "description": "Email template management" },
    { "name": "Push Templates", "description": "Push notification templates" },
    { "name": "SMS Templates", "description": "SMS template management" },
    { "name": "Catalogs", "description": "Product catalog management" },
    { "name": "Segments", "description": "User segment queries" },
    { "name": "Custom User Lists", "description": "Custom user list management" },
    { "name": "Email Validation", "description": "Email address validation" },
    { "name": "Subscription Groups", "description": "Subscription group management" },
    { "name": "Promotions", "description": "Promotion code management" },
    { "name": "Shared Assets", "description": "Shared asset management" },
    { "name": "Live Content", "description": "Real-time content delivery" }
  ],
  "paths": {
    "/api/v1/campaigns": {
      "post": {
        "operationId": "createCampaign",
        "summary": "Create a campaign",
        "description": "Creates a new campaign.",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCampaignRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Campaign created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/{campaignUuid}/schedule": {
      "patch": {
        "operationId": "updateCampaignSchedule",
        "summary": "Update campaign schedule",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "campaignUuid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CampaignScheduleRequest" } } }
        },
        "responses": {
          "200": { "description": "Schedule updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/{campaignUuid}/launch": {
      "patch": {
        "operationId": "launchCampaign",
        "summary": "Launch a campaign",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "campaignUuid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Campaign launched", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/{campaignUuid}/pause": {
      "patch": {
        "operationId": "pauseCampaign",
        "summary": "Pause a campaign",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "campaignUuid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Campaign paused", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/execute": {
      "post": {
        "operationId": "triggerCampaign",
        "summary": "Trigger a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TriggerCampaignRequest" } } }
        },
        "responses": {
          "200": { "description": "Campaign triggered", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/bulk-execute": {
      "post": {
        "operationId": "bulkTriggerCampaigns",
        "summary": "Bulk trigger campaigns",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BulkTriggerCampaignRequest" } } }
        },
        "responses": {
          "200": { "description": "Campaigns triggered", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns.json": {
      "get": {
        "operationId": "getCampaignsSummary",
        "summary": "Get campaigns performance summary",
        "tags": ["Campaigns"],
        "responses": {
          "200": { "description": "Campaign summary", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Campaign" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v2/campaigns.json": {
      "get": {
        "operationId": "listCampaigns",
        "summary": "List campaigns (v2)",
        "tags": ["Campaigns"],
        "responses": {
          "200": { "description": "List of campaigns", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Campaign" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/{campaignUuid}/detail.json": {
      "get": {
        "operationId": "getCampaignDetailWithStats",
        "summary": "Get campaign detail with stats",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "campaignUuid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Campaign detail with statistics", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CampaignDetail" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/{campaignUuid}/archive": {
      "put": {
        "operationId": "archiveCampaign",
        "summary": "Archive a campaign",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "campaignUuid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Campaign archived", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/campaigns/{campaignUuid}/unarchive": {
      "put": {
        "operationId": "unarchiveCampaign",
        "summary": "Unarchive a campaign",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "campaignUuid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Campaign unarchived", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/event": {
      "post": {
        "operationId": "sendEvent",
        "summary": "Send an event",
        "tags": ["Events"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EventRequest" } } }
        },
        "responses": {
          "200": { "description": "Event sent", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/bulkevents": {
      "post": {
        "operationId": "sendBulkEvents",
        "summary": "Send bulk events",
        "tags": ["Events"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BulkEventsRequest" } } }
        },
        "responses": {
          "200": { "description": "Events sent", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/event/debug": {
      "get": {
        "operationId": "getRecentEvent",
        "summary": "Get most recent event",
        "tags": ["Events"],
        "responses": {
          "200": { "description": "Most recent event", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Event" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/customers": {
      "get": {
        "operationId": "searchCustomers",
        "summary": "Search customers",
        "tags": ["Customers"],
        "parameters": [
          { "name": "email", "in": "query", "schema": { "type": "string" }, "description": "Customer email to search" }
        ],
        "responses": {
          "200": { "description": "Customer search results", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Customer" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createOrUpdateCustomer",
        "summary": "Create or update a customer",
        "tags": ["Customers"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CustomerRequest" } } }
        },
        "responses": {
          "200": { "description": "Customer created or updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Customer" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/customers/{uuid}": {
      "get": {
        "operationId": "getCustomer",
        "summary": "Get a customer by UUID",
        "tags": ["Customers"],
        "parameters": [
          { "name": "uuid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Customer details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Customer" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/customers/bulk": {
      "post": {
        "operationId": "bulkCreateOrUpdateCustomers",
        "summary": "Bulk create or update customers",
        "tags": ["Customers"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CustomerRequest" } } } }
        },
        "responses": {
          "200": { "description": "Customers processed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/customers/forget": {
      "post": {
        "operationId": "forgetCustomer",
        "summary": "Stop tracking a customer",
        "tags": ["Customers"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CustomerIdentifier" } } }
        },
        "responses": {
          "200": { "description": "Customer forgotten", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/customers/delete": {
      "post": {
        "operationId": "deleteCustomer",
        "summary": "Delete a customer",
        "tags": ["Customers"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CustomerIdentifier" } } }
        },
        "responses": {
          "200": { "description": "Customer deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/customers/merge": {
      "post": {
        "operationId": "mergeCustomers",
        "summary": "Merge customers",
        "tags": ["Customers"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MergeCustomersRequest" } } }
        },
        "responses": {
          "200": { "description": "Customers merged", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/email-templates.json": {
      "get": {
        "operationId": "listEmailTemplates",
        "summary": "List email templates",
        "tags": ["Email Templates"],
        "responses": {
          "200": { "description": "Email templates", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/EmailTemplate" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createEmailTemplate",
        "summary": "Create an email template",
        "tags": ["Email Templates"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailTemplateRequest" } } }
        },
        "responses": {
          "200": { "description": "Template created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailTemplate" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/email-templates/{templateUuid}.json": {
      "get": {
        "operationId": "getEmailTemplate",
        "summary": "Get email template details",
        "tags": ["Email Templates"],
        "parameters": [
          { "name": "templateUuid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Template details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailTemplate" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateEmailTemplate",
        "summary": "Update an email template",
        "tags": ["Email Templates"],
        "parameters": [
          { "name": "templateUuid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailTemplateRequest" } } }
        },
        "responses": {
          "200": { "description": "Template updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailTemplate" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/segments/list": {
      "get": {
        "operationId": "listSegments",
        "summary": "Get list of segments",
        "tags": ["Segments"],
        "responses": {
          "200": { "description": "List of segments", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Segment" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/emails/validate": {
      "get": {
        "operationId": "validateEmail",
        "summary": "Validate a single email",
        "tags": ["Email Validation"],
        "parameters": [
          { "name": "email", "in": "query", "required": true, "schema": { "type": "string", "format": "email" } }
        ],
        "responses": {
          "200": { "description": "Validation result", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailValidationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/emails/bulk-validate": {
      "post": {
        "operationId": "bulkValidateEmails",
        "summary": "Validate multiple emails",
        "tags": ["Email Validation"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "emails": { "type": "array", "items": { "type": "string", "format": "email" } } } } } }
        },
        "responses": {
          "200": { "description": "Validation results", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/EmailValidationResponse" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/subscription-groups": {
      "get": {
        "operationId": "listSubscriptionGroups",
        "summary": "List subscription groups",
        "tags": ["Subscription Groups"],
        "responses": {
          "200": { "description": "Subscription groups", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/SubscriptionGroup" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/catalogs": {
      "get": {
        "operationId": "listCatalogs",
        "summary": "Get list of catalogs",
        "tags": ["Catalogs"],
        "responses": {
          "200": { "description": "List of catalogs", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Catalog" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
