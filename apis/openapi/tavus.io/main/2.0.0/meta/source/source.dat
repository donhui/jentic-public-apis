{
  "openapi": "3.0.3",
  "info": {
    "title": "Tavus API",
    "version": "2.0.0",
    "description": "Tavus API enables creation and management of AI video replicas, personas, and real-time conversations powered by digital twins.",
    "x-jentic-source-url": "https://docs.tavus.io/api-reference/overview"
  },
  "servers": [
    {
      "url": "https://tavusapi.com"
    }
  ],
  "paths": {
    "/v2/personas": {
      "get": {
        "operationId": "listPersonas",
        "summary": "List personas",
        "description": "Retrieve a paginated list of personas.",
        "tags": ["Personas"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "The number of personas to return per page. Default is 10.",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The page number to return. Default is 1.",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "persona_type",
            "in": "query",
            "description": "Filter by persona type.",
            "schema": { "type": "string", "enum": ["user", "system"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PersonaListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPersona",
        "summary": "Create a persona",
        "description": "Define an agent's behavior, tone, and knowledge by creating a persona.",
        "tags": ["Personas"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePersonaRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Persona created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreatePersonaResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v2/personas/{persona_id}": {
      "get": {
        "operationId": "getPersona",
        "summary": "Get a persona",
        "description": "Retrieve details of a specific persona by ID.",
        "tags": ["Personas"],
        "parameters": [
          {
            "name": "persona_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the persona.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Persona" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "patchPersona",
        "summary": "Update a persona",
        "description": "Update a persona using JSON Patch (RFC 6902).",
        "tags": ["Personas"],
        "parameters": [
          {
            "name": "persona_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the persona.",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/JsonPatchOperation" }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Persona updated successfully"
          },
          "304": {
            "description": "No changes were made to the persona"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "422": {
            "description": "Invalid JSON patch format",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deletePersona",
        "summary": "Delete a persona",
        "description": "Delete a persona by its unique identifier.",
        "tags": ["Personas"],
        "parameters": [
          {
            "name": "persona_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the persona.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": {
            "description": "Persona deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v2/replicas": {
      "get": {
        "operationId": "listReplicas",
        "summary": "List replicas",
        "description": "Retrieve a paginated list of replicas.",
        "tags": ["Replicas"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "The number of replicas to return per page.",
            "schema": { "type": "integer" }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The page number to return.",
            "schema": { "type": "integer" }
          },
          {
            "name": "verbose",
            "in": "query",
            "description": "Include additional replica details when true.",
            "schema": { "type": "boolean" }
          },
          {
            "name": "replica_type",
            "in": "query",
            "description": "Filter by replica type.",
            "schema": { "type": "string", "enum": ["user", "system"] }
          },
          {
            "name": "replica_ids",
            "in": "query",
            "description": "Comma-separated list of replica identifiers.",
            "schema": { "type": "string" }
          },
          {
            "name": "model_name",
            "in": "query",
            "description": "Filter by Phoenix model version.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReplicaListResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createReplica",
        "summary": "Create a replica",
        "description": "Train a lifelike digital twin from a short 2-minute video.",
        "tags": ["Replicas"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateReplicaRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Replica creation started",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateReplicaResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v2/replicas/{replica_id}": {
      "get": {
        "operationId": "getReplica",
        "summary": "Get a replica",
        "description": "Retrieve details of a specific replica by ID.",
        "tags": ["Replicas"],
        "parameters": [
          {
            "name": "replica_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the replica.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Replica" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteReplica",
        "summary": "Delete a replica",
        "description": "Delete a replica by its unique identifier.",
        "tags": ["Replicas"],
        "parameters": [
          {
            "name": "replica_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the replica.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": {
            "description": "Replica deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "patchReplicaName",
        "summary": "Update replica name",
        "description": "Update the name of a replica.",
        "tags": ["Replicas"],
        "parameters": [
          {
            "name": "replica_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the replica.",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "replica_name": {
                    "type": "string",
                    "description": "The new name for the replica."
                  }
                },
                "required": ["replica_name"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Replica updated successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v2/conversations": {
      "get": {
        "operationId": "listConversations",
        "summary": "List conversations",
        "description": "Retrieve a paginated list of conversations.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "The number of conversations to return per page. Default is 10.",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The page number to return. Default is 1.",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by conversation state.",
            "schema": { "type": "string", "enum": ["active", "ended"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConversationListResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createConversation",
        "summary": "Create a conversation",
        "description": "Create a real-time video call session with an AI replica.",
        "tags": ["Conversations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateConversationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversation created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateConversationResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v2/conversations/{conversation_id}": {
      "get": {
        "operationId": "getConversation",
        "summary": "Get a conversation",
        "description": "Retrieve details of a specific conversation.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "conversation_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the conversation.",
            "schema": { "type": "string" }
          },
          {
            "name": "verbose",
            "in": "query",
            "description": "When true, returns expanded event data including shutdown reasons, transcripts, and perception analysis.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Conversation" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteConversation",
        "summary": "Delete a conversation",
        "description": "Delete a conversation by its unique identifier.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "conversation_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the conversation.",
            "schema": { "type": "string" }
          },
          {
            "name": "hard",
            "in": "query",
            "description": "If set to true, the conversation and associated assets will be permanently deleted.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "204": {
            "description": "Conversation deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v2/conversations/{conversation_id}/end": {
      "post": {
        "operationId": "endConversation",
        "summary": "End a conversation",
        "description": "End an active conversation session.",
        "tags": ["Conversations"],
        "parameters": [
          {
            "name": "conversation_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the conversation.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversation ended successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/v2/videos": {
      "get": {
        "operationId": "listVideos",
        "summary": "List videos",
        "description": "Retrieve a paginated list of generated videos.",
        "tags": ["Videos"],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 }, "description": "Number of videos per page." },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 }, "description": "Page number." }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VideoListResponse" } } }
          },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createVideo",
        "summary": "Generate a video",
        "description": "Generate a new video using a replica and script or audio file.",
        "tags": ["Videos"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateVideoRequest" } } }
        },
        "responses": {
          "200": { "description": "Video generation started", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Video" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/videos/{video_id}": {
      "get": {
        "operationId": "getVideo",
        "summary": "Get a video",
        "description": "Retrieve details of a specific video by ID.",
        "tags": ["Videos"],
        "parameters": [
          { "name": "video_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique identifier of the video." }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Video" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "patch": {
        "operationId": "patchVideo",
        "summary": "Update a video",
        "description": "Rename a video.",
        "tags": ["Videos"],
        "parameters": [
          { "name": "video_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique identifier of the video." }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "video_name": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Video updated successfully" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteVideo",
        "summary": "Delete a video",
        "description": "Delete a video by its unique identifier.",
        "tags": ["Videos"],
        "parameters": [
          { "name": "video_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique identifier of the video." }
        ],
        "responses": {
          "204": { "description": "Video deleted successfully" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/documents": {
      "get": {
        "operationId": "listDocuments",
        "summary": "List documents",
        "description": "Retrieve a list of documents with optional filtering and pagination.",
        "tags": ["Documents"],
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 }, "description": "Number of documents per page." },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 }, "description": "Page number." }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DocumentListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createDocument",
        "summary": "Upload a document",
        "description": "Upload a document to the knowledge base for personas to reference.",
        "tags": ["Documents"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateDocumentRequest" } } }
        },
        "responses": {
          "200": { "description": "Document created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Document" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/documents/{document_id}": {
      "get": {
        "operationId": "getDocument",
        "summary": "Get a document",
        "description": "Retrieve a specific document by ID.",
        "tags": ["Documents"],
        "parameters": [
          { "name": "document_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique identifier of the document." }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Document" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "patch": {
        "operationId": "patchDocument",
        "summary": "Update a document",
        "description": "Update document metadata.",
        "tags": ["Documents"],
        "parameters": [
          { "name": "document_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique identifier of the document." }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" }, "tags": { "type": "array", "items": { "type": "string" } } } } } }
        },
        "responses": {
          "200": { "description": "Document updated successfully" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteDocument",
        "summary": "Delete a document",
        "description": "Remove a document from the knowledge base.",
        "tags": ["Documents"],
        "parameters": [
          { "name": "document_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique identifier of the document." }
        ],
        "responses": {
          "204": { "description": "Document deleted successfully" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/documents/{document_id}/recrawl": {
      "post": {
        "operationId": "recrawlDocument",
        "summary": "Recrawl a document",
        "description": "Trigger a website content refresh for a URL-based document.",
        "tags": ["Documents"],
        "parameters": [
          { "name": "document_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique identifier of the document." }
        ],
        "responses": {
          "200": { "description": "Recrawl initiated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/guardrails": {
      "get": {
        "operationId": "listGuardrails",
        "summary": "List guardrails",
        "description": "Retrieve all guardrail sets.",
        "tags": ["Guardrails"],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GuardrailListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createGuardrail",
        "summary": "Create guardrails",
        "description": "Create behavioral boundaries and guidelines for personas.",
        "tags": ["Guardrails"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateGuardrailRequest" } } }
        },
        "responses": {
          "200": { "description": "Guardrail created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Guardrail" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/guardrails/{guardrail_id}": {
      "get": {
        "operationId": "getGuardrail",
        "summary": "Get guardrails",
        "description": "Retrieve specific guardrails by ID.",
        "tags": ["Guardrails"],
        "parameters": [
          { "name": "guardrail_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique guardrail identifier." }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Guardrail" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "patch": {
        "operationId": "patchGuardrail",
        "summary": "Update guardrails",
        "description": "Modify guardrail fields.",
        "tags": ["Guardrails"],
        "parameters": [
          { "name": "guardrail_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique guardrail identifier." }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": { "description": "Guardrail updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteGuardrail",
        "summary": "Delete guardrails",
        "description": "Remove guardrails by ID.",
        "tags": ["Guardrails"],
        "parameters": [
          { "name": "guardrail_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique guardrail identifier." }
        ],
        "responses": {
          "204": { "description": "Guardrail deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/objectives": {
      "get": {
        "operationId": "listObjectives",
        "summary": "List objectives",
        "description": "Retrieve all objectives.",
        "tags": ["Objectives"],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ObjectiveListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createObjective",
        "summary": "Create an objective",
        "description": "Create goal-oriented instructions for desired conversation outcomes.",
        "tags": ["Objectives"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateObjectiveRequest" } } }
        },
        "responses": {
          "200": { "description": "Objective created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Objective" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/objectives/{objective_id}": {
      "get": {
        "operationId": "getObjective",
        "summary": "Get an objective",
        "description": "Fetch a specific objective.",
        "tags": ["Objectives"],
        "parameters": [
          { "name": "objective_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique objective identifier." }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Objective" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "patch": {
        "operationId": "patchObjective",
        "summary": "Update an objective",
        "description": "Update objective fields.",
        "tags": ["Objectives"],
        "parameters": [
          { "name": "objective_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique objective identifier." }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": { "description": "Objective updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteObjective",
        "summary": "Delete an objective",
        "description": "Remove an objective.",
        "tags": ["Objectives"],
        "parameters": [
          { "name": "objective_id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The unique objective identifier." }
        ],
        "responses": {
          "204": { "description": "Objective deleted" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Persona": {
        "type": "object",
        "properties": {
          "persona_id": { "type": "string", "description": "Unique identifier for the persona." },
          "persona_name": { "type": "string", "description": "Display name for the persona." },
          "system_prompt": { "type": "string", "description": "The system prompt used by the LLM." },
          "default_replica_id": { "type": "string", "description": "Associated replica identifier." },
          "document_ids": { "type": "array", "items": { "type": "string" }, "description": "Documents accessible to the persona." },
          "document_tags": { "type": "array", "items": { "type": "string" }, "description": "Document tags for access control." },
          "layers": { "$ref": "#/components/schemas/PersonaLayers" },
          "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
          "updated_at": { "type": "string", "format": "date-time", "description": "Last modification timestamp." }
        }
      },
      "PersonaLayers": {
        "type": "object",
        "description": "Configuration layers for persona behavior.",
        "properties": {
          "llm": {
            "type": "object",
            "description": "Language model configuration.",
            "properties": {
              "model": { "type": "string" },
              "base_url": { "type": "string" },
              "api_key": { "type": "string" }
            }
          },
          "tts": {
            "type": "object",
            "description": "Text-to-speech configuration.",
            "properties": {
              "engine": { "type": "string" },
              "voice_id": { "type": "string" }
            }
          },
          "stt": {
            "type": "object",
            "description": "Speech-to-text configuration.",
            "properties": {
              "engine": { "type": "string" },
              "hotwords": { "type": "array", "items": { "type": "string" } }
            }
          },
          "perception": {
            "type": "object",
            "description": "Vision and audio perception settings.",
            "properties": {
              "model": { "type": "string" }
            }
          }
        }
      },
      "CreatePersonaRequest": {
        "type": "object",
        "required": ["system_prompt"],
        "properties": {
          "system_prompt": { "type": "string", "description": "The system prompt that will be used by the LLM." },
          "persona_name": { "type": "string", "description": "A descriptive name for the persona." },
          "pipeline_mode": { "type": "string", "enum": ["full", "echo"], "description": "Execution mode, defaults to full." },
          "default_replica_id": { "type": "string", "description": "Associated replica identifier." },
          "document_ids": { "type": "array", "items": { "type": "string" }, "description": "Documents accessible to the persona." },
          "document_tags": { "type": "array", "items": { "type": "string" }, "description": "Document tags for access control." },
          "objectives_id": { "type": "string", "description": "Goal-oriented instruction identifier." },
          "guardrails_id": { "type": "string", "description": "Behavioral boundary identifier." },
          "layers": { "$ref": "#/components/schemas/PersonaLayers" }
        }
      },
      "CreatePersonaResponse": {
        "type": "object",
        "properties": {
          "persona_id": { "type": "string", "description": "Unique identifier for the created persona." },
          "persona_name": { "type": "string", "description": "Name of the persona." },
          "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
        }
      },
      "PersonaListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Persona" } },
          "total_count": { "type": "integer", "description": "Total personas matching applied filters." }
        }
      },
      "Replica": {
        "type": "object",
        "properties": {
          "replica_id": { "type": "string", "description": "Unique identifier for the replica." },
          "replica_name": { "type": "string", "description": "Display name for the replica." },
          "thumbnail_video_url": { "type": "string", "description": "Thumbnail video link." },
          "training_progress": { "type": "string", "description": "Progress indicator." },
          "status": { "type": "string", "enum": ["started", "completed", "error"], "description": "Current status of the replica." },
          "model_name": { "type": "string", "description": "Phoenix model designation." },
          "replica_type": { "type": "string", "description": "User or system replica type." },
          "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
        }
      },
      "CreateReplicaRequest": {
        "type": "object",
        "required": ["train_video_url"],
        "properties": {
          "train_video_url": { "type": "string", "description": "Direct link to publicly accessible video for training." },
          "consent_video_url": { "type": "string", "description": "Separate consent statement video." },
          "replica_name": { "type": "string", "description": "Name for the replica." },
          "model_name": { "type": "string", "default": "phoenix-4", "description": "Phoenix model version." },
          "callback_url": { "type": "string", "description": "Webhook URL for completion notifications." },
          "properties": {
            "type": "object",
            "properties": {
              "background_green_screen": { "type": "boolean", "description": "Enable green screen background." }
            }
          }
        }
      },
      "CreateReplicaResponse": {
        "type": "object",
        "properties": {
          "replica_id": { "type": "string", "description": "Unique identifier for the created replica." },
          "status": { "type": "string", "enum": ["started", "completed", "error"], "description": "Current status." }
        }
      },
      "ReplicaListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Replica" } },
          "total_count": { "type": "integer", "description": "Total replicas matching applied filters." }
        }
      },
      "Conversation": {
        "type": "object",
        "properties": {
          "conversation_id": { "type": "string", "description": "Unique conversation identifier." },
          "conversation_name": { "type": "string", "description": "Name of the conversation." },
          "conversation_url": { "type": "string", "description": "Direct link to join the conversation." },
          "callback_url": { "type": "string", "description": "Webhook endpoint for state updates." },
          "status": { "type": "string", "enum": ["active", "ended"], "description": "Current conversation status." },
          "replica_id": { "type": "string", "description": "Associated replica identifier." },
          "persona_id": { "type": "string", "description": "Associated persona identifier." },
          "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
          "updated_at": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
        }
      },
      "CreateConversationRequest": {
        "type": "object",
        "properties": {
          "persona_id": { "type": "string", "description": "Persona identifier." },
          "replica_id": { "type": "string", "description": "Replica identifier (required unless persona has a default)." },
          "audio_only": { "type": "boolean", "description": "For audio-only conversations." },
          "callback_url": { "type": "string", "description": "Webhook endpoint for status updates." },
          "conversation_name": { "type": "string", "description": "Display name for the conversation." },
          "conversational_context": { "type": "string", "description": "Additional context instructions." },
          "custom_greeting": { "type": "string", "description": "Opening message from replica." },
          "memory_stores": { "type": "array", "items": { "type": "string" }, "description": "Memory store identifiers." },
          "document_ids": { "type": "array", "items": { "type": "string" }, "description": "Document references." },
          "document_retrieval_strategy": { "type": "string", "enum": ["speed", "quality", "balanced"], "description": "Document retrieval strategy." },
          "document_tags": { "type": "array", "items": { "type": "string" }, "description": "Document categorization." },
          "test_mode": { "type": "boolean", "description": "Testing without costs." },
          "require_auth": { "type": "boolean", "description": "Authentication requirement." },
          "max_participants": { "type": "integer", "minimum": 2, "description": "Participant limit." },
          "properties": {
            "type": "object",
            "description": "Advanced settings including call duration, recording, captions, language, greenscreen."
          }
        }
      },
      "CreateConversationResponse": {
        "type": "object",
        "properties": {
          "conversation_id": { "type": "string", "description": "Unique conversation identifier." },
          "conversation_name": { "type": "string", "description": "Conversation title." },
          "conversation_url": { "type": "string", "description": "Direct access link." },
          "status": { "type": "string", "enum": ["active", "ended"], "description": "Conversation status." },
          "callback_url": { "type": "string", "description": "Configured webhook URL." },
          "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
          "meeting_token": { "type": "string", "description": "JWT for authenticated access." }
        }
      },
      "ConversationListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Conversation" } },
          "total_count": { "type": "integer", "description": "Total matching conversations." }
        }
      },
      "JsonPatchOperation": {
        "type": "object",
        "required": ["op", "path"],
        "properties": {
          "op": { "type": "string", "enum": ["add", "remove", "replace", "copy", "move", "test"], "description": "The operation to perform." },
          "path": { "type": "string", "description": "JSON Pointer referencing the target location." },
          "value": { "description": "The value to apply." }
        }
      },
      "Video": {
        "type": "object",
        "properties": {
          "video_id": { "type": "string", "description": "Unique video identifier." },
          "video_name": { "type": "string", "description": "Display name for the video." },
          "status": { "type": "string", "enum": ["queued", "generating", "ready", "error"], "description": "Current video status." },
          "download_url": { "type": "string", "description": "URL to download the generated video." },
          "stream_url": { "type": "string", "description": "URL to stream the generated video." },
          "replica_id": { "type": "string", "description": "Associated replica identifier." },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateVideoRequest": {
        "type": "object",
        "required": ["replica_id"],
        "properties": {
          "replica_id": { "type": "string", "description": "Replica to use for generation." },
          "script": { "type": "string", "description": "Text script for the video." },
          "audio_url": { "type": "string", "description": "URL of audio file to use instead of script." },
          "video_name": { "type": "string", "description": "Name for the video." },
          "callback_url": { "type": "string", "description": "Webhook URL for completion notifications." }
        }
      },
      "VideoListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Video" } },
          "total_count": { "type": "integer" }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "document_id": { "type": "string", "description": "Unique document identifier." },
          "name": { "type": "string", "description": "Document name." },
          "type": { "type": "string", "description": "Document type (file, url)." },
          "tags": { "type": "array", "items": { "type": "string" }, "description": "Document tags." },
          "status": { "type": "string", "description": "Processing status." },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateDocumentRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Document name." },
          "url": { "type": "string", "description": "URL to crawl for document content." },
          "file_url": { "type": "string", "description": "URL to a file to upload." },
          "tags": { "type": "array", "items": { "type": "string" }, "description": "Document tags." }
        }
      },
      "DocumentListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Document" } },
          "total_count": { "type": "integer" }
        }
      },
      "Guardrail": {
        "type": "object",
        "properties": {
          "guardrail_id": { "type": "string", "description": "Unique guardrail identifier." },
          "name": { "type": "string" },
          "rules": { "type": "array", "items": { "type": "string" }, "description": "Behavioral rules." },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateGuardrailRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "rules": { "type": "array", "items": { "type": "string" } }
        }
      },
      "GuardrailListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Guardrail" } },
          "total_count": { "type": "integer" }
        }
      },
      "Objective": {
        "type": "object",
        "properties": {
          "objective_id": { "type": "string", "description": "Unique objective identifier." },
          "name": { "type": "string" },
          "instructions": { "type": "string", "description": "Goal-oriented instructions." },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateObjectiveRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "instructions": { "type": "string" }
        }
      },
      "ObjectiveListResponse": {
        "type": "object",
        "properties": {
          "data": { "type": "array", "items": { "$ref": "#/components/schemas/Objective" } },
          "total_count": { "type": "integer" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "Error message." },
          "message": { "type": "string", "description": "Error description." }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "x-api-key",
        "in": "header",
        "description": "API key for authentication."
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}