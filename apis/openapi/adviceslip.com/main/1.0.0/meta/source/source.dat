{
  "openapi": "3.0.3",
  "info": {
    "title": "Advice Slip API",
    "version": "1.0.0",
    "description": "A free API for generating random advice slips. Provides random advice, advice by ID, and search functionality.",
    "x-jentic-source-url": "https://api.adviceslip.com/"
  },
  "servers": [
    {
      "url": "https://api.adviceslip.com",
      "description": "Advice Slip API server"
    }
  ],
  "tags": [
    {
      "name": "Advice",
      "description": "Advice slip endpoints"
    }
  ],
  "paths": {
    "/advice": {
      "get": {
        "operationId": "getRandomAdvice",
        "summary": "Get a random advice slip",
        "description": "Returns a random advice slip as a slip object. Results are cached for 2 seconds.",
        "tags": ["Advice"],
        "parameters": [
          {
            "name": "callback",
            "in": "query",
            "description": "JSONP callback function name.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A random advice slip.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SlipResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/advice/{slip_id}": {
      "get": {
        "operationId": "getAdviceById",
        "summary": "Get advice slip by ID",
        "description": "Returns a specific advice slip by its ID number.",
        "tags": ["Advice"],
        "parameters": [
          {
            "name": "slip_id",
            "in": "path",
            "required": true,
            "description": "The ID of the advice slip to retrieve.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "callback",
            "in": "query",
            "description": "JSONP callback function name.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The requested advice slip.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SlipResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          }
        }
      }
    },
    "/advice/search/{query}": {
      "get": {
        "operationId": "searchAdvice",
        "summary": "Search for advice slips",
        "description": "Search for advice slips containing the given search term. Returns an array of matching slip objects.",
        "tags": ["Advice"],
        "parameters": [
          {
            "name": "query",
            "in": "path",
            "required": true,
            "description": "The search term to find in advice slips.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "callback",
            "in": "query",
            "description": "JSONP callback function name.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results containing matching advice slips.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Slip": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "The unique identifier of the advice slip."
          },
          "advice": {
            "type": "string",
            "description": "The advice text."
          }
        },
        "required": ["id", "advice"]
      },
      "SlipResponse": {
        "type": "object",
        "properties": {
          "slip": {
            "$ref": "#/components/schemas/Slip"
          }
        },
        "required": ["slip"]
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "total_results": {
            "type": "integer",
            "description": "Total number of matching results."
          },
          "query": {
            "type": "string",
            "description": "The search term used."
          },
          "slips": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Slip"
            },
            "description": "Array of matching advice slips."
          }
        },
        "required": ["total_results", "query", "slips"]
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Message type: notice, warning, or error.",
                "enum": ["notice", "warning", "error"]
              },
              "text": {
                "type": "string",
                "description": "The message text."
              }
            },
            "required": ["type", "text"]
          }
        },
        "required": ["message"]
      }
    }
  },
  "security": []
}