{
  "openapi": "3.0.3",
  "info": {
    "title": "Forem API",
    "version": "1.0.0",
    "description": "Access Forem (Dev.to) articles, comments, users, organizations, tags, podcast episodes, and more. API key authentication via api-key header for authenticated endpoints.",
    "x-jentic-source-url": "https://developers.forem.com/api"
  },
  "servers": [
    {
      "url": "https://dev.to/api"
    }
  ],
  "paths": {
    "/articles": {
      "get": {
        "operationId": "listArticles",
        "summary": "List articles",
        "description": "Return a list of published articles, ordered by descending publish date.",
        "tags": [
          "Articles"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Pagination page number.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (max 1000).",
            "schema": {
              "type": "integer",
              "default": 30
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "Filter by tag.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags",
            "in": "query",
            "description": "Filter by multiple tags (comma-separated).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags_exclude",
            "in": "query",
            "description": "Exclude articles with these tags.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "query",
            "description": "Filter by author username.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Filter by article state.",
            "schema": {
              "type": "string",
              "enum": [
                "fresh",
                "rising",
                "all"
              ]
            }
          },
          {
            "name": "top",
            "in": "query",
            "description": "Return most popular articles in the last N days.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "collection_id",
            "in": "query",
            "description": "Filter by collection/series ID.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ArticleSummary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createArticle",
        "summary": "Create an article",
        "description": "Create a new article. Requires authentication.",
        "tags": [
          "Articles"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateArticleRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Article created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Article"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/articles/{id}": {
      "get": {
        "operationId": "getArticle",
        "summary": "Get an article by ID",
