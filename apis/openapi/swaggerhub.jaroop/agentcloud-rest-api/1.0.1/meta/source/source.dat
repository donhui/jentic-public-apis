    "/contacts/{contactId}": {
      "get": {
        "summary": "Gets information about a contact",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "contactId",
            "in": "path",
            "required": true,
            "description": "The AgentCloud ID of the contact to retrieve",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved the requested opportunity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "403": {
            "description": "The client lacks permission to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "The given ID does not match any known opportunities.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "put": {
        "summary": "Updates a contact",
        "description": "Use this endpoint with caution. When a contact is updated through this\nendpoint, all eligible fields will be overwritten with the data \nincluded in the request. Fields that are null or omitted will be\noverwritten, and it may not be possible to recover the original value.\nIt is recommended that you pull the latest contact data before updating\nif you don't want to accidentally overwrite something.\n\nPhones and emails are an exception to this rule. Any phone numbers or\nemail addresses included in the request will be added to the contact.\nIf the phone numbers or email addresses are already associated with the \ncontact, they will be ignored. Phone numbers and email addresses not \nincluded in the request will be left alone; no phones or emails will \nbe removed from the contact through this endpoint.\n",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "contactId",
            "in": "path",
            "required": true,
            "description": "The AgentCloud ID of the opportunity to update",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Contact"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns the successfully updated contact.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": {
            "description": "A failed response, typically indicating that the request data was\nmalformed or invalid.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "The client lacks permission to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "The given ID does not match any known opportunities.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
