  "components": {
    "responses": {
      "InternalServerError": {
        "description": "Indicates that an unexpected error occurred that the server could not\nhandle. Every bad response will include the request's UUID, which SHOULD\nbe included with trouble reports.\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "RequestId": {
        "type": "string",
        "format": "uuid",
        "example": "33110038-1bba-47c1-97ea-b10eaeadddc3",
        "description": "A unique ID that can be used to identify the request for \nsupport and debugging purposes.\n"
      },
      "LeadCreateRequest": {
        "type": "object",
        "required": [
          "clientRef",
          "contact",
          "campaignName"
        ],
        "properties": {
          "clientRef": {
            "type": "string",
            "minLength": 1,
            "description": "A unique ID provided by you that corresponds to this lead. \nWe will use this to identify the lead when making outbound requests. \nMUST NOT be empty.\n"
          },
          "contact": {
            "$ref": "#/components/schemas/LeadContact"
          },
          "policyDetails": {
            "$ref": "#/components/schemas/LeadDetails"
          },
          "mortgageDetails": {
            "$ref": "#/components/schemas/MortgageDetails"
          },
          "medicareDetails": {
            "$ref": "#/components/schemas/LeadMedicareDetails"
          },
          "clientIp": {
            "type": "string",
            "format": "ip",
            "example": "fe80::1",
            "description": "The lead's remote internet address, formatted as a valid IPv4 or \nIPv6 address. Optional.\n"
          },
          "referringUrl": {
            "type": "string",
            "format": "url",
            "example": "https://www.example.com/sign-up",
            "description": "The url the lead is referred from. Optional."
          },
          "trustedFormCert": {
            "type": "string",
            "format": "url",
            "example": "https://www.example.com/sign-up",
            "description": "An additional URL optionally provided by Healthcare users."
          },
          "tcpaToken": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426655440000",
            "description": "A LeadiD/Jornaya token for this lead. Optional.",
            "minLength": 1
          },
          "companion": {
            "$ref": "#/components/schemas/LeadCompanion"
          },
          "product": {
            "type": "string",
            "enum": [
              "TERM",
              "SITERM",
              "FE"
            ],
            "description": "The kind of insurance product to sell to the lead. This is required \nfor all leads not from HomeBridge. HomeBridge leads are always SI \nTerm.\n"
          },
          "campaignName": {
            "type": "string",
            "example": "My Test Campaign",
            "description": "The name of the campaign with which the lead is associated. MUST be \na case-sensitive match for a campaign configured in AgentCloud. \nAllowed values will be provided by AccuQuote and are unique to\neach partner.\n(Note: For backwards compatibility, this is not required for \npartners who began using this API prior to June 2020.)\n"
          },
          "sessionId": {
            "type": "string",
            "example": "20200415034956.e9a2827aa987",
            "maxLength": 124,
            "description": "A client-set ID that links the lead back to the session on the\nsystem from which it originated.\n"
          }
        }
      },
      "LeadUpdateRequest": {
        "type": "object",
        "required": [
          "clientRef",
          "contact"
        ],
        "properties": {
          "clientRef": {
            "type": "string",
            "minLength": 1,
            "description": "A unique ID provided by the client that corresponds to this lead. \nWe will use this to identify the lead when making outbound requests. \nMUST NOT be empty.\n"
          },
          "contact": {
            "$ref": "#/components/schemas/LeadContact"
          },
          "policyDetails": {
            "$ref": "#/components/schemas/LeadDetails"
          },
          "mortgageDetails": {
            "$ref": "#/components/schemas/MortgageDetails"
          },
          "medicareDetails": {
            "$ref": "#/components/schemas/LeadMedicareDetails"
          },
          "clientIp": {
            "type": "string",
            "format": "ip",
            "example": "fe80::1",
            "description": "The lead's remote internet address, formatted as a valid IPv4 or \nIPv6 address. Optional.\n"
          },
          "referringUrl": {
            "type": "string",
            "format": "url",
            "example": "https://www.example.com/sign-up",
            "description": "The url the lead is referred from. Optional."
          },
          "trustedFormCert": {
            "type": "string",
            "format": "url",
            "example": "https://www.example.com/sign-up",
            "description": "An additional URL optionally provided by Healthcare users."
          },
          "product": {
            "type": "string",
            "enum": [
              "TERM",
              "SITERM",
              "FE"
            ],
            "description": "The kind of insurance product to sell to the lead. This is required \nfor all leads not from HomeBridge. HomeBridge leads are always SI \nTerm.\n"
          },
          "sessionId": {
            "type": "string",
            "example": "20200415034956.e9a2827aa987",
            "maxLength": 124,
            "description": "A client-set ID that links the lead back to the session on the\nsystem from which it originated.\n"
          }
        }
      },
      "LeadContact": {
        "type": "object",
        "required": [
          "firstName",
          "lastName",
          "state",
          "phones"
        ],
        "properties": {
          "firstName": {
            "type": "string",
            "example": "Alan",
            "minLength": 1,
            "maxLength": 124,
            "description": "The first name of the lead contact. MUST NOT be empty. MUST be 124 \ncharacters or less.\n"
          },
          "middleName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "The middle name of the lead contact. Optional. If present, MUST NOT \nbe empty. MUST be 124 characters or less.\n"
          },
          "lastName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "Smith",
            "description": "The last name of the lead contact. MUST NOT be empty. MUST be 124 \ncharacters or less.\n"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "example": "1970-07-14",
            "description": "The birthday of the lead contact. The format is ISO8601. Optional.\n"
          },
          "street": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "521 Pine St.",
            "description": "The first line of the street address of the lead contact. Optional. \nMUST be 124 characters or less.\n"
          },
          "street2": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "Unit 42A",
            "description": "The second line of the street address of the lead contact. Optional. \nMUST be 124 characters or less.\n"
          },
          "city": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "Omaha",
            "description": "The city of the street address of the lead contact. Optional. \nMUST be 124 characters or less.\n"
          },
          "state": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "NE",
            "description": "The state where the lead resides. MUST be a USPS 2-letter state \ncode. MUST be one of the 50 states or DC.\n"
          },
          "zip": {
            "type": "string",
            "minLength": 5,
            "maxLength": 10,
            "example": "68022",
            "description": "The ZIP code where the lead resides. Optional. MUST be between 5 \nand 10 characters, inclusive.\n"
          },
          "phones": {
            "type": "array",
            "minLength": 1,
            "items": {
              "$ref": "#/components/schemas/LeadPhone"
            },
            "description": "A list of telephone numbers with which to reach the lead contact. \nMUST contain at least one phone number. The numbers MUST be valid \nphone numbers. If any of the phone numbers match leads that are \nalready in the AgentCloud database, regardless of the source of the \noriginal lead, the lead SHALL be rejected.\n"
          },
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 3,
            "example": "alan.smith@mail.example.com",
            "description": "An e-mail address at which the lead can be reached. MUST contain\nexactly one `@` symbol with at least one character on either side.\n"
          },
          "gender": {
            "type": "string",
            "description": "The lead's gender. Optional.",
            "enum": [
              "Male",
              "Female"
            ]
          }
        }
      },
      "LeadPhone": {
        "type": "object",
        "description": "A phone number and related metadata.",
        "required": [
          "phoneNumber",
          "phoneType"
        ],
        "properties": {
          "phoneNumber": {
            "type": "string",
            "format": "phone",
            "minLength": 10,
            "maxLength": 10,
            "example": "8605551234",
            "description": "The number MUST be valid under the North American Numbering Plan \n(NANP). The first digit of the area code MUST NOT contain 0 or 1. \nThe first digit of the prefix MUST NOT contain 0 or 1. The area code \nand prefix MUST NOT match the regular expression `[2-9]11`. \nSee [Wikipedia](https://en.wikipedia.org/wiki/North_American_Numbering_Plan#Modern_plan)\nfor a detailed explanation of the NANP.\n"
          },
          "phoneType": {
            "type": "string",
            "format": "phone",
            "enum": [
              "Work",
              "Cell",
              "Home",
              "Other"
            ]
          }
        }
      },
      "LeadDetails": {
        "type": "object",
        "description": "Detailed information about the lead and sought policy.\n",
        "properties": {
          "termLength": {
            "type": "integer",
            "example": 10,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Length of the sought policy, in years. MUST be greater than zero.\n"
          },
          "tobacco": {
            "type": "boolean",
            "example": true,
            "description": "True if the lead has a history of tobacco use."
          },
          "riskClass": {
            "type": "string",
            "enum": [
              "Standard",
              "Preferred",
              "Preferred Plus"
            ]
          },
          "optInDateTime": {
            "type": "string",
            "format": "date-time",
            "example": "2011-12-03T10:15:30-00:00",
            "description": "The date and time the lead gave TCPA consent, with offset. \nThe format is ISO8601.\n"
          },
          "faceAmount": {
            "type": "integer",
            "example": 50000,
            "description": "The face amount of the sought policy, in US dollars. \nMUST be greater than zero.\n"
          },
          "height": {
            "type": "integer",
            "example": 70,
            "description": "Height of the lead in inches. MUST be greater than or \nequal to 12. MUST be less than 96.\n"
          },
          "weight": {
            "type": "integer",
            "example": 180,
            "description": "Weight of the lead in pounds. MUST be greater than or \nequal to 50. MUST be less than 1000.\n"
          },
          "usCitizen": {
            "type": "boolean",
            "example": true,
            "description": "Whether or not the lead is a citizen of the United States.\n"
          },
          "familyStatus": {
            "type": "string",
            "enum": [
              "Single",
              "Couple",
              "Single w/kids",
              "Couple w/kids"
            ]
          },
          "incomeMonthly": {
            "type": "integer",
            "example": 5000,
            "minimum": 5000,
            "exclusiveMinimum": true,
            "description": "Monthly income of the lead, in US Dollars. MUST be greater than \nzero.\n"
          }
        }
      },
      "MortgageDetails": {
        "type": "object",
        "description": "Mortgage information related to this lead, if applicable. REQUIRED for \nHomebridge leads. Optional otherwise.\n",
        "required": [
          "borrowerId",
          "borrowerStatus",
          "mortgageId",
          "mortgageCloseDate",
          "insurancePurpose",
          "faceAmount",
          "termLength",
          "loanOfficerFirstName",
          "loanOfficerLastName",
          "loanOfficerPhone",
          "loanOfficerEmail",
          "processorFirstName",
          "processorLastName",
          "processorEmail"
        ],
        "properties": {
          "borrowerId": {
            "type": "string",
            "example": "123789",
            "description": "The ID of the borrower that the mortgage is made through. \nMUST NOT be empty.\n"
          },
          "borrowerStatus": {
            "type": "string",
            "description": "The latest borrower status for the lead.\n\n`Open`: If the lead should be considered open, but not ready for \nautodialing. For HomeBridge, this is leads with more than 3 days \nleft prior to close.\n\n`AutoDial`: If the lead should be considered open and ready for \nautodialing. For HomeBridge, this is leads with fewer than 3 days \nleft prior to close, or leads that have already closed on their \nmortgage.\n\n`Inactive`: If the lead should be considered closed.\n",
            "enum": [
              "Open",
              "AutoDial",
              "Inactive"
            ]
          },
          "mortgageId": {
            "type": "string",
            "example": "123789",
            "minLength": 1,
            "description": "The ID of the mortgage for the lead. MUST NOT be empty."
          },
          "mortgageCloseDate": {
            "type": "string",
            "format": "date",
            "example": "1996-08-20",
            "description": "The closing date for the mortgage. The format is ISO8601."
          },
          "insurancePurpose": {
            "type": "string",
            "example": "Mortgage Protection",
            "description": "The reason the lead is seeking a policy. \nMUST NOT be empty.\n"
          },
          "faceAmount": {
            "type": "integer",
            "example": 250000,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "The face amount of the mortgage, in US Dollars. \nMUST be greater than zero.\n"
          },
          "termLength": {
            "type": "integer",
            "example": 30,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "The term length of the mortgage, in years. \nMUST be greater than zero.\n"
          },
          "loanOfficerFirstName": {
            "type": "string",
            "example": "Charlie",
            "maxLength": 124,
            "description": "The loan officer's first name. MUST NOT be empty. MUST be 124 \ncharacters or less.\n"
          },
          "loanOfficerLastName": {
            "type": "string",
            "example": "Tuna",
            "maxLength": 124,
            "description": "The loan officer's last name. MUST NOT be empty. MUST be 124 \ncharacters or less.\n"
          },
          "loanOfficerPhone": {
            "type": "string",
            "format": "phone",
            "example": "2035551234",
            "description": "Telephone number for the loan officer. MUST be a valid phone number.\n"
          },
          "loanOfficerEmail": {
            "type": "string",
            "format": "email",
            "example": "charlie.tuna@mail.example.com",
            "description": "E-mail address for the loan officer. MUST be a valid email address.\n"
          },
          "processorFirstName": {
            "type": "string",
            "example": "Dave",
            "description": "The loan processor's first name. MUST NOT be empty. MUST be 124 \ncharacters or less.\n"
          },
          "processorLastName": {
            "type": "string",
            "example": "Stone",
            "description": "The loan processor's last name. MUST NOT be empty. MUST be 124 \ncharacters or less.\n"
          },
          "processorPhone": {
            "type": "string",
            "format": "phone",
            "example": "2035551234",
            "description": "Telephone number for the loan processor. MUST be a valid phone \nnumber.\n"
          },
          "processorEmail": {
            "type": "string",
            "format": "email",
            "example": "dave.stone@mail.example.com",
            "description": "E-mail address for the loan processor. MUST be a valid email\naddress.\n"
          }
        }
      },
      "LeadMedicareDetails": {
        "type": "object",
        "description": "Information about the policy type(s) sought by a medicare lead.",
        "properties": {
          "medicareType": {
            "enum": [
              "Medicare Supplement",
              "Medicare Advantage"
            ]
          },
          "medicareCoverage": {
            "enum": [
              "A",
              "B",
              "AB"
            ]
          }
        }
      },
      "LeadCompanion": {
        "type": "object",
        "description": "A second contact for the lead, generally someone who is related to the \nprimary contact, a spouse or other family member. Optional.\n",
        "required": [
          "borrowerId",
          "firstName",
          "lastName",
          "state",
          "phones"
        ],
        "properties": {
          "borrowerId": {
            "type": "string",
            "example": "123789",
            "minLength": 1,
            "description": "The ID of the borrower that the companion's mortgage is made \nthrough. MUST NOT be empty.\n"
          },
          "firstName": {
            "type": "string",
            "example": "Alan",
            "minLength": 1,
            "maxLength": 124,
            "description": "The first name of the lead contact. MUST NOT be empty. MUST be 124 \ncharacters or less.\n"
          },
          "middleName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "The middle name of the lead contact. Optional. If present, MUST NOT \nbe empty. MUST be 124 characters or less.\n"
          },
          "lastName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "Smith",
            "description": "The last name of the lead contact. MUST NOT be empty. MUST be 124 \ncharacters or less.\n"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "example": "1970-07-14",
            "description": "The birthday of the lead contact. The format is ISO8601. Optional.\n"
          },
          "street": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "521 Pine St.",
            "description": "The first line of the street address of the lead contact. Optional. \nMUST be 124 characters or less.\n"
          },
          "street2": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "Unit 42A",
            "description": "The second line of the street address of the lead contact. Optional. \nMUST be 124 characters or less.\n"
          },
          "city": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "Omaha",
            "description": "The city of the street address of the lead contact. Optional. \nMUST be 124 characters or less.\n"
          },
          "state": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "example": "NE",
            "description": "The state where the lead resides. MUST be a USPS 2-letter state \ncode. MUST be one of the 50 states or DC.\n"
          },
          "zip": {
            "type": "string",
            "minLength": 5,
            "maxLength": 10,
            "example": "68022",
            "description": "The ZIP code where the lead resides. Optional. MUST be between 5 \nand 10 characters, inclusive.\n"
          },
          "phones": {
            "type": "array",
            "minLength": 1,
            "items": {
              "$ref": "#/components/schemas/LeadPhone"
            },
            "description": "A list of telephone numbers with which to reach the lead contact. \nMUST contain at least one phone number. The numbers MUST be valid \nphone numbers. If any of the phone numbers match leads that are \nalready in the AgentCloud database, regardless of the source of the \noriginal lead, the lead SHALL be rejected.\n"
          },
          "email": {
            "type": "string",
            "format": "email",
            "minLength": 3,
            "example": "alan.smith@mail.example.com",
            "description": "An e-mail address at which the lead can be reached. MUST contain\nexactly one `@` symbol with at least one character on either side.\n"
          },
          "gender": {
            "type": "string",
            "description": "The lead's gender. Optional.",
            "enum": [
              "Male",
              "Female"
            ]
          },
          "termLength": {
            "type": "integer",
            "example": 25,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "Term length of the sought policy for the companion. If present, \nMUST be greater than zero.\n"
          },
          "faceAmount": {
            "type": "integer",
            "example": 35000,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "The value of the companion's sought policy, in US dollars. \nIf present, MUST be greater than zero.\n"
          },
          "incomeMonthly": {
            "type": "integer",
            "example": 5000,
            "minimum": 0,
            "exclusiveMinimum": true,
            "description": "The companion's monthly income, in US dollars. MUST be greater than \nzero.\n"
          }
        }
      },
      "Error": {
        "type": "object",
        "description": "A failed response. Contains a message describing the error and a\nunique request ID that can be used to look up the error in the \napplication logs for debugging. Users of the API SHOULD include this\nID when submitting a request for support so that the support team\ncan quickly identify the request in the logs and determine what went \nwrong.\n",
        "required": [
          "message",
          "requestId"
        ],
        "properties": {
          "message": {
            "type": "string",
            "example": "An error occurred while processing your request."
          },
          "requestId": {
            "$ref": "#/components/schemas/RequestId"
          },
          "errors": {
            "type": "array",
            "description": "An array of more granular messages that may help in \ntroubleshooting the problem.\n",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "LeadCreateResponse": {
        "type": "object",
        "required": [
          "leadId",
          "requestId",
          "clientRef"
        ],
        "properties": {
          "leadId": {
            "description": "The ID of the newly created lead in the AgentCloud platform.\n",
            "type": "integer",
            "format": "int64",
            "example": 123456789
          },
          "requestId": {
            "$ref": "#/components/schemas/RequestId"
          },
          "clientRef": {
            "type": "string",
            "description": "A unique value provided by the client to identify this lead.\nTypically corresponds to an ID in the client system.\n"
          }
        }
      },
      "LeadUpdateResponse": {
        "type": "object",
        "required": [
          "leadId",
          "requestId"
        ],
        "properties": {
          "leadId": {
            "description": "The ID of the updated lead in the AgentCloud platform.\n",
            "type": "integer",
            "format": "int64",
            "example": 123456789
          },
          "requestId": {
            "$ref": "#/components/schemas/RequestId"
          }
        }
      },
      "EmailDoNotContactRequest": {
        "type": "object",
        "properties": {
          "leads": {
            "type": "array",
            "description": "An array of lead IDs (which MUST be numbers). All email addresses \nassociated with these leads will be added to the do-not-contact list.\nEither this or the `emails` field (or both) MUST be present.\n",
            "items": {
              "type": "number"
            }
          },
          "emails": {
            "type": "array",
            "description": "An array of email addresses to add to the do-not-contact list.\nEither this field or the `leads` field (or both) MUST be present.\n",
            "items": {
              "type": "string",
              "format": "email"
            }
          }
        }
      },
      "EmailDoNotContactResponse": {
        "type": "object",
        "required": [
          "requestId"
        ],
        "properties": {
          "requestId": {
            "type": "string",
            "format": "uuid",
            "example": "ee6fda2c-16cd-4446-aedf-9800e13b7628",
            "description": "A random UUID that may be used to identify this request."
          }
        }
      },
      "AvailableAgents": {
        "type": "object",
        "required": [
          "available",
          "requestId"
        ],
        "properties": {
          "requestId": {
            "type": "string",
            "format": "uuid",
            "example": "ee6fda2c-16cd-4446-aedf-9800e13b7628",
            "description": "A random UUID that may be used to identify this request."
          },
          "available": {
            "type": "integer",
            "description": "The number of agents available to take calls.",
            "example": 3
          }
        }
      },
      "MatchingOpportunities": {
        "type": "object",
        "required": [
          "matches"
        ],
        "properties": {
          "matches": {
            "type": "array",
            "description": "An array of matching opportunities, if any.",
            "minLength": 0,
            "maxLength": 10,
            "items": {
              "$ref": "#/components/schemas/Opportunity"
            }
          }
        }
      },
      "OpportunityStatus": {
        "type": "object",
        "readOnly": true,
        "description": "Represents possible states of an opportunity.\n* 1 - Reached Not Quoted\n* 2 - Not Interested\n* 3 - No Response\n* 4 - Declined\n* 5 - Postponed\n* 6 - In Force\n* 7 - Lapsed\n* 8 - Replaced\n* 9 - Withdrawn\n* 10 - Converted - Full\n* 12 - App Completed\n* 13 - App Sent To Carrier\n* 14 - Policy In House\n* 15 - Del Reqs Sent to Client\n* 16 - Del Reqs Sent to Carrier\n* 17 - Not Taken\n* 19 - Issued As Approved\n* 20 - Issued Other Than Approved\n* 21 - Verified In Force\n* 22 - Deceased\n* 23 - App In Progress\n* 24 - Ineligible\n* 25 - Reached Quoted\n* 26 - App Processed\n* 27 - App Sent to Client\n* 28 - App Received\n* 29 - Underwriting\n* 30 - Tentative Offer\n* 31 - Resell\n* 34 - Await Policy\n* 35 - Del Reqs Received\n* 36 - Lapse Pending\n* 37 - Reissue Requested\n* 38 - Needs Sales Review\n* 39 - Needs Sales Review Changes\n* 40 - Policy Created in Error\n* 41 - Canceled\n* 42 - Denied\n\nThe statuses Postponed, Declined, Withdrawn, Del Reqs Sent To Carrier, Ineligible, Not Interested, Not Taken, No Response, Deceased, Lapsed, Canceled, and Denied should also include a reason code. See the ReasonCode schema for more details.\n",
        "required": [
          "id",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the status"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "example": "Reached Not Quoted",
            "description": "The name of the status"
          }
        }
      },
      "ProductType": {
        "type": "object",
        "readOnly": true,
        "description": "Represents categories of product that may be sold in AgentCloud.\n* 1 - Final Expense\n* 2 - Simplified Issue Term\n* 3 - HomeBridge SI Term\n* 4 - Term\n* 5 - New Benefits\n* 6 - Children's Whole Life\n* 7 - Fidelity ADB\n* 8 - ReliaShield\n* 9 - Conversion\n* 10 - Medicare\n",
        "required": [
          "id",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the product type"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "example": "Term",
            "description": "The name of the product type"
          }
        }
      },
      "ContactStatus": {
        "type": "object",
        "readOnly": true,
        "description": "Represents possible states of a contact.\n* 1 - Active\n* 2 - Inactive\n",
        "required": [
          "id",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the status"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "example": "Active",
            "description": "The name of the status"
          }
        }
      },
      "Gender": {
        "type": "object",
        "readOnly": true,
        "description": "Gender options available for a contact.\n* 1 - Male\n* 2 - Female\n",
        "required": [
          "id",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the gender"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "example": "Male",
            "description": "The name of the gender"
          }
        }
      },
      "ResidencyStatus": {
        "type": "object",
        "readOnly": true,
        "description": "Contact's US residency/immigration status.\n* 1 - US Citizen\n* 2 - Non-Citizen\n* 3 - Green Card\n* 4 - Visa A - Government Official\n* 5 - Visa B1 - Visitor/Business\n* 6 - Visa B2 - Visitor/Medical Treatment\n* 7 - Visa C - Transit\n* 8 - Visa D - Crewman\n* 9 - Visa E1 - Treaty Trader\n* 10 - Visa E2 - Treaty Investor\n* 11 - Visa E3-5 - Misc Employment Visas\n* 12 - Visa F1-4 - Family Based/Academic Studies\n* 13 - Visa G - Representative to International Organization\n* 14 - Visa H-1B - Temporary Worker: Distinguished Merit/Ability\n* 15 - Visa H-2A/B - Temporary Worker: General Labor\n* 16 - Visa H-3 - Temporary Worker: Trainee\n* 17 - Visa H-4 - Spouse of Child of H1, 2, or 3\n* 18 - Visa I - Information Media Representative\n* 19 - Visa J - USIA Education/Cultural Exchange\n* 20 - Visa K1 - Fiance/Fiancee I: Information Media Red\n* 21 - Visa L - Intra Company Transfer\n* 22 - Visa M - Vocational/Non-Academic Studies\n* 23 - Visa O1-2 - Science/Art\n* 24 - Visa P1-3 - Athletes, Artists, Entertainers\n* 25 - Visa Q1 - INS International Cultural Exchange\n* 26 - Visa R - Non Immigrant Religious\n* 27 - Visa SB-1 - Returning Resident Alien\n* 28 - Visa SD - Immigrant Religious\n* 29 - Visa TN - NAFTA Professionals\n",
        "required": [
          "id",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the gender"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "example": "Male",
            "description": "The name of the gender"
          }
        }
      },
      "Contact": {
        "type": "object",
        "required": [
          "id",
          "created",
          "status",
          "agentId",
          "homeAddress",
          "mailingAddress",
          "orgId",
          "phones",
          "emails"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1234567,
            "description": "AgentCloud ID of the contact",
            "readOnly": true
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "example": "2021-07-20T20:04:46.278815-04:00",
            "description": "When the contact was created in AgentCloud.",
            "readOnly": true
          },
          "status": {
            "$ref": "#/components/schemas/ContactStatus"
          },
          "statusId": {
            "type": "integer",
            "example": 1,
            "description": "ID of the desired contact status. Used when updating a contact.\nSee ContactStatus schema.\n",
            "writeOnly": true
          },
          "agentId": {
            "type": "integer",
            "example": 1234,
            "description": "ID of the agent assigned to this contact",
            "readOnly": true
          },
          "homeAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "mailingAddress": {
            "$ref": "#/components/schemas/Address"
          },
          "orgId": {
            "type": "integer",
            "example": 2,
            "description": "ID of the organization to which this contact belongs",
            "readOnly": true
          },
          "firstName": {
            "type": "string",
            "example": "John",
            "description": "Given name of the contact",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true
          },
          "middleName": {
            "type": "string",
            "example": "Quincy",
            "minLength": 1,
            "maxLength": 124,
            "description": "Middle name of the contact",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "example": "Adams",
            "minLength": 1,
            "maxLength": 124,
            "description": "Surname of the contact",
            "nullable": true
          },
          "birthday": {
            "type": "string",
            "format": "date",
            "example": "2021-07-20",
            "description": "Date of birth of the contact",
            "nullable": true
          },
          "phones": {
            "type": "array",
            "description": "Phone numbers associated with this contact",
            "readOnly": true,
            "items": {
              "$ref": "#/components/schemas/ContactPhone"
            }
          },
          "phoneNumbers": {
            "type": "array",
            "description": "Phone numbers to be added to this contact. New phone numbers\nwill be associated with the contact. Phone numbers\nalready associated with the contact will be ignored. \nNo phone numbers will be removed from the contact, even if\nthey are not included in this array.\n",
            "writeOnly": true,
            "items": {
              "type": "string",
              "format": "phone",
              "example": "(860) 357-2060",
              "description": "Must be a valid phone number in the NANP"
            }
          },
          "emails": {
            "type": "array",
            "description": "Email addresses associated with this contact",
            "readOnly": true,
            "items": {
              "$ref": "#/components/schemas/ContactEmail"
            }
          },
          "emailAddresses": {
            "type": "array",
            "description": "Email addresses to be added to this contact. New emails\nwill be associated with the contact. Email addresses\nalready associated with the contact will be ignored. \nNo emails will be removed from the contact, even if\nthey are not included in this array.\n",
            "writeOnly": true,
            "items": {
              "type": "string",
              "format": "email",
              "example": "test@example.com",
              "description": "Must be a valid email address."
            }
          },
          "notes": {
            "type": "string",
            "description": "Notes added by staff to the contact record",
            "readOnly": true
          },
          "gender": {
            "$ref": "#/components/schemas/Gender"
          },
          "genderName": {
            "type": "string",
            "example": "Male",
            "enum": [
              "Male",
              "Female"
            ],
            "writeOnly": true,
            "nullable": true,
            "description": "Gender of the contact. Used only when updating.\n"
          },
          "residencyStatus": {
            "$ref": "#/components/schemas/ResidencyStatus"
          },
          "nickname": {
            "type": "string",
            "example": "Johnny",
            "nullable": true,
            "description": "Nickname to use when addressing the contact"
          },
          "prefix": {
            "type": "string",
            "example": "Dr.",
            "nullable": true,
            "description": "Prefix to use when addressing the contact."
          }
        }
      },
      "Address": {
        "type": "object",
        "description": "Represents a physical address in the United States",
        "properties": {
          "street": {
            "type": "string",
            "example": "123 Main Street",
            "nullable": true,
            "minLength": 1,
            "maxLength": 124,
            "description": "First line of the street address"
          },
          "street2": {
            "type": "string",
            "example": "Unit 456",
            "nullable": true,
            "minLength": 1,
            "maxLength": 124,
            "description": "Second line of the street address"
          },
          "city": {
            "type": "string",
            "example": "Hartford",
            "nullable": true,
            "minLength": 1,
            "maxLength": 124
          },
          "state": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "nullable": true,
            "example": "CT",
            "description": "Two-letter USPS abbreviation of the state"
          },
          "zip": {
            "type": "string",
            "minLength": 5,
            "maxLength": 10,
            "nullable": true,
            "example": "06101",
            "description": "Postal code of the address"
          }
        }
      },
      "ContactPhone": {
        "type": "object",
        "description": "A phone number and related metadata",
        "required": [
          "id",
          "created",
          "updated",
          "phoneNumber",
          "orgId",
          "doNotContact",
          "tcpaStatus",
          "phoneType",
          "tcpaText"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1234567,
            "readOnly": true,
            "description": "ID of the phone number"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "example": "2021-07-20T20:04:46.278815-04:00",
            "description": "When the phone number was created in AgentCloud.",
            "readOnly": true
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "example": "2021-07-20T20:04:46.278815-04:00",
            "description": "When the phone number was last updated in AgentCloud.",
            "readOnly": true
          },
          "phoneNumber": {
            "type": "string",
            "format": "phone",
            "example": "(860) 357-2060",
            "description": "Must be a valid phone number in the NANP"
          },
          "orgId": {
            "type": "integer",
            "example": 2,
            "description": "Organization with which the phone number is associated",
            "readOnly": true
          },
          "doNotContact": {
            "type": "boolean",
            "example": false,
            "description": "If true, this number should not be called. Defaults to false.\n",
            "readOnly": true
          },
          "tcpaStatus": {
            "$ref": "#/components/schemas/TCPAStatus"
          },
          "tcpaText": {
            "$ref": "#/components/schemas/TCPAText"
          },
          "phoneType": {
            "$ref": "#/components/schemas/PhoneType"
          }
        }
      },
      "TCPAStatus": {
        "type": "object",
        "readOnly": true,
        "description": "Whether TCPA approval has been granted.\n* 1 - Yes\n* 2 - No\n* 3 - N/A (indicates that the contact has not been asked yet)\n",
        "required": [
          "id",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the status"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "example": "yes",
            "description": "The name of the status"
          }
        }
      },
      "TCPAText": {
        "type": "object",
        "readOnly": true,
        "description": "Whether TCPA approval has been granted for text messages.\n* 1 - Yes\n* 2 - No\n* 3 - N/A (indicates that the contact has not been asked yet)\n",
        "required": [
          "id",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the status"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "example": "Yes",
            "description": "The name of the status"
          }
        }
      },
      "PhoneType": {
        "type": "object",
        "readOnly": true,
        "description": "The type of phone number\n* 1 - Cell\n* 2 - Home\n* 3 - Work\n* 4 - Other\n",
        "required": [
          "id",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the phone type"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "example": "Cell",
            "description": "The name of the phone type"
          }
        }
      },
      "ContactEmail": {
        "type": "object",
        "description": "An email address and related metadata",
        "required": [
          "id",
          "created",
          "updated",
          "email",
          "doNotContact",
          "orgId"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1234567,
            "readOnly": true,
            "description": "ID of the email address in AgentCloud"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "example": "2021-07-20T20:04:46.278815-04:00",
            "description": "When the email address was created in AgentCloud.",
            "readOnly": true
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "example": "2021-07-20T20:04:46.278815-04:00",
            "description": "When the email address was last updated in AgentCloud.",
            "readOnly": true
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "test@example.com",
            "description": "Must be a valid email address"
          },
          "orgId": {
            "type": "integer",
            "example": 2,
            "description": "Organization with which the email address is associated",
            "readOnly": true
          },
          "doNotContact": {
            "type": "boolean",
            "example": false,
            "description": "If true, this email should not be sent marketing messages.\nDefaults to false.\n",
            "readOnly": true
          },
          "validationResult": {
            "$ref": "#/components/schemas/ValidationResult"
          }
        }
      },
      "ValidationResult": {
        "type": "object",
        "readOnly": true,
        "description": "Whether an email was successfully verified or not.\n* 1 - valid\n* 2 - invalid\n* 3 - disposable\n* 4 - catchall\n* 5 - unknown\n",
        "required": [
          "id",
          "displayName"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the validation result"
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "example": "valid",
            "description": "The name of the validation result"
          }
        }
      },
      "Opportunity": {
        "type": "object",
        "description": "An opportunity is a potential deal that an agent may sell to a customer. \nOpportunities are created when an agent manages to get a person on the \nphone. Typically, that person has an associated lead, which is converted\ninto an opportunity. An opportunity is the parent for all data \nassociated with the specific policy or policies being sold, and it is \nconsidered the \"respondent\" for all answers collected through the\njourney.\n",
        "required": [
          "id",
          "created",
          "product",
          "status",
          "agentId",
          "orgId"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1234567,
            "description": "ID of the opportunity in AgentCloud",
            "readOnly": true
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "example": "2021-07-20T20:04:46.278815-04:00",
            "description": "When the opportunity was created",
            "readOnly": true
          },
          "orgId": {
            "type": "integer",
            "example": 2,
            "description": "The organization to which the opportunity belongs.",
            "readOnly": true
          },
          "product": {
            "$ref": "#/components/schemas/ProductType"
          },
          "status": {
            "$ref": "#/components/schemas/OpportunityStatus"
          },
          "statusId": {
            "type": "integer",
            "example": 10,
            "description": "The ID of the status that the opportunity should have after being \nupdated. Only nullable when other fields in the request exist. If the status requires a reason code, please provide it with 'reasonCodeId'. See OpportunityStatus schema.\n",
            "writeOnly": true,
            "nullable": true
          },
          "agentId": {
            "type": "integer",
            "example": 1234,
            "description": "Agent to which the opportunity is assigned",
            "readOnly": true
          },
          "adminId": {
            "type": "integer",
            "example": 1234,
            "description": "Administrative assistant assigned to the opportunity.",
            "readOnly": true
          },
          "insuredId": {
            "type": "integer",
            "example": 10000,
            "description": "ID of the contact who is the insured on the policy.",
            "readOnly": true
          },
          "ownerId": {
            "type": "integer",
            "example": 10001,
            "description": "ID of the contact who is the owner of the policy.",
            "readOnly": true
          },
          "payorId": {
            "type": "integer",
            "example": 10002,
            "description": "ID of the contact who is the payor of the policy.",
            "readOnly": true
          },
          "authorizedUserId": {
            "type": "integer",
            "example": 10003,
            "description": "ID of a contact who is authorized to make changes. Typically,\nthis field is only used if the contact does not have any other\nroles on this opportunity. For example, a family member who helps\na relative sign up for a policy but is not formally on the policy\nmay be the authorized user.\n",
            "readOnly": true
          },
          "powerOfAttorneyId": {
            "type": "integer",
            "example": 10004,
            "description": "ID of the contact who has power of attorney.",
            "readOnly": true
          },
          "selectedQuoteId": {
            "type": "integer",
            "example": 12345678,
            "description": "ID of the quote selected by the customer in the journey.",
            "readOnly": true
          },
          "leadId": {
            "type": "integer",
            "example": 12345678,
            "description": "ID of the lead from which this opportunity was converted.",
            "readOnly": true
          },
          "primaryContactId": {
            "type": "integer",
            "example": 12345678,
            "description": "ID of the contact that should be used for most purposes.",
            "readOnly": true
          },
          "parentOpportunityId": {
            "type": "integer",
            "example": 12345678,
            "readOnly": true,
            "description": "ID of the original opportunity from which this one originated,\nif applicable.\n"
          },
          "handoffId": {
            "type": "string",
            "example": "opp123",
            "readOnly": true,
            "description": "When the agent is handed off to a third-party system at the end of\nthe journey to complete the app, the third-party API may, in some \ncases, return an ID that can be used to identify the opportunity in \nthat system. This field stores that ID as a string. Its format and \nusage will vary depending on which third party the agent was handed \noff to, which depends on the product type of the opportunity. \nNot all hand-off recipient systems may return an ID in all cases.\n"
          },
          "reasonCode": {
            "$ref": "#/components/schemas/ReasonCode"
          },
          "reasonCodeId": {
            "type": "integer",
            "example": 40,
            "description": "The reason code that the opportunity should have along with the status. Only nullable when other fields in the request exist. See the ReasonCode schema.",
            "writeOnly": true,
            "nullable": true
          }
        }
      },
      "OpportunityMedicare": {
        "type": "object",
        "description": "Medicare-related data for an opportunity. Includes background \ninformation about the customer's eligibility as well as information \nabout the policy and application, if available.\n",
        "required": [
          "opportunityId",
          "autoPopulated"
        ],
        "properties": {
          "opportunityId": {
            "type": "integer",
            "example": 1234567,
            "description": "ID of the opportunity to which this data belongs.",
            "readOnly": true
          },
          "enrolledPartA": {
            "type": "boolean",
            "example": true,
            "nullable": true,
            "description": "Whether the insured is enrolled in Medicare Part A."
          },
          "enrolledPartB": {
            "type": "boolean",
            "example": true,
            "nullable": true,
            "description": "Whether the insured is enrolled in Medicare Part B."
          },
          "effectiveDatePartA": {
            "type": "string",
            "format": "date",
            "example": "2021-07-20",
            "nullable": true,
            "description": "The date the insured was enrolled in Medicare Part A."
          },
          "effectiveDatePartB": {
            "type": "string",
            "format": "date",
            "example": "2021-07-20",
            "nullable": true,
            "description": "The date the insured was enrolled in Medicare Part B."
          },
          "medicareBeneficiaryId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "1K56J9QX99",
            "nullable": true,
            "description": "The insured's Medicare Beneficiary ID (a.k.a Medicare number)\n"
          },
          "medicaidNumber": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "1234567890123",
            "nullable": true,
            "description": "The insured's Medicaid Number"
          },
          "tricareEnrollment": {
            "type": "string",
            "enum": [
              "Tricare",
              "Employer Group",
              "Both",
              "Not Enrolled"
            ],
            "nullable": true,
            "description": "Whether the insured is enrolled in Tricare"
          },
          "vaEnrollment": {
            "type": "boolean",
            "example": false,
            "nullable": true,
            "description": "Whether the insured is enrolled for VA benefits"
          },
          "fehbpEnrollment": {
            "type": "boolean",
            "example": false,
            "nullable": true,
            "description": "Whether the insured is enrolled in an FEHB plan."
          },
          "medicaidEnrollment": {
            "type": "boolean",
            "example": false,
            "nullable": true,
            "description": "Whether the insured is enrolled in Medicaid"
          },
          "stateFedSubsidy": {
            "type": "boolean",
            "example": false,
            "nullable": true,
            "description": "Whether the insured receives state or federal subsidies."
          },
          "nursingHome": {
            "type": "boolean",
            "example": false,
            "nullable": true,
            "description": "Whether the insured resides in a nursing home."
          },
          "electionEligibility": {
            "type": "string",
            "enum": [
              "AEP",
              "SEP",
              "Not Eligible"
            ],
            "nullable": true,
            "description": "Whether the insured is eligible for Medicare election (AEP or SEP).\n"
          },
          "effectiveDate": {
            "type": "string",
            "format": "date",
            "example": "2021-07-20",
            "nullable": true,
            "description": "The date the insured's policy goes into effect."
          },
          "personId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "The customer code from Sunfire"
          },
          "enrollmentId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "The enrollment code from Sunfire"
          },
          "planId": {
            "type": "integer",
            "example": 1,
            "writeOnly": true,
            "nullable": true,
            "description": "AgentCloud ID of the plan.\n"
          },
          "monthlyPremium": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true,
            "example": 9950,
            "nullable": true,
            "description": "The plan's monthly premium, in cents (USD * 100)."
          },
          "deductible": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true,
            "example": 100000,
            "nullable": true,
            "description": "The plan's deductible, in cents (USD * 100)."
          },
          "maximumOutOfPocket": {
            "type": "integer",
            "minimum": 0,
            "exclusiveMinimum": true,
            "example": 100000,
            "nullable": true,
            "description": "The plan's maximum out of pocket, in cents (USD * 100)."
          },
          "policyNumber": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "The policy number issued by the carrier."
          },
          "autoPopulated": {
            "type": "boolean",
            "example": false,
            "readOnly": true,
            "description": "Whether the data has been populated by the API. Once an update is\nmade via the API, this flag is set to `true`, and the policy\ndata can no longer be updated manually through the UI. It may\nstill be updated through the API.\n"
          },
          "inForceDate": {
            "type": "string",
            "format": "date",
            "example": "2021-07-20",
            "nullable": true,
            "description": "The date the policy went in force."
          },
          "lapseDate": {
            "type": "string",
            "format": "date",
            "example": "2021-07-20",
            "nullable": true,
            "description": "The date the policy lapsed."
          }
        }
      },
      "MedicareCarrier": {
        "type": "object",
        "readOnly": true,
        "description": "Possible carriers of a Medicare policy. Values TBD.\n",
        "required": [
          "id",
          "name",
          "naicCode",
          "orgId",
          "created"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the carrier in AgentCloud's system"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "example": "Pivot Health",
            "description": "The name of the carrier"
          },
          "naicCode": {
            "type": "string",
            "example": "44335",
            "description": "The NAIC code of the carrier"
          },
          "orgId": {
            "type": "integer",
            "example": 2,
            "description": "The ID of the organization to which the carrier belongs \nin AgentCloud.\n"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "example": "2021-07-20T20:04:46.278815-04:00",
            "description": "When the carrier was created in AgentCloud"
          }
        }
      },
      "MedicarePlan": {
        "type": "object",
        "readOnly": true,
        "description": "A Medicare plan that can be sold through AgentCloud",
        "required": [
          "id",
          "orgId",
          "displayName",
          "coverageType",
          "carrier",
          "policyType"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the plan in AgentCloud"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "Silver Plan",
            "description": "The name of the plan"
          },
          "coverageType": {
            "type": "string",
            "enum": [
              "PDP",
              "MAPD",
              "MA",
              "MedSupp"
            ]
          },
          "carrier": {
            "$ref": "#/components/schemas/MedicareCarrier"
          },
          "policyType": {
            "$ref": "#/components/schemas/MedicarePolicyType"
          },
          "contractId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "Contract ID. Does not apply to MedSupp."
          },
          "planId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "The carrier's ID for the plan. Distinct from AgentCloud's `id` \nfield. Does not apply to MedSupp.\n"
          },
          "segmentId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "Segment ID. Does not apply to MedSupp."
          }
        }
      },
      "CreateMedicarePlanRequest": {
        "type": "object",
        "description": "A request to create a Medicare plan.",
        "required": [
          "name",
          "coverageType",
          "carrierId",
          "policyTypeId"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "The name of the plan. Must be unique per carrier.",
            "example": "Silver Plan"
          },
          "coverageType": {
            "type": "string",
            "enum": [
              "PDP",
              "MAPD",
              "MA",
              "MedSupp"
            ],
            "description": "The type of coverage provided by the plan"
          },
          "carrierId": {
            "type": "integer",
            "example": 1234,
            "description": "The AgentCloud ID of the carrier offering the plan"
          },
          "policyTypeId": {
            "type": "integer",
            "example": 1234,
            "description": "The AgentCloud ID of the type of policy"
          },
          "contractId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "The ID of the contract"
          },
          "planId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "ID used to identify the plan by third parties. Distinct from the\nAgentCloud ID used to identify the plan in this API.\n"
          },
          "segmentId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "Segment ID of the plan"
          }
        }
      },
      "CreateMedicareCarrierRequest": {
        "type": "object",
        "description": "A request to create a new Medicare carrier in AgentCloud",
        "required": [
          "name",
          "naicCode"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Aetna",
            "minLength": 1,
            "maxLength": 124,
            "description": "Name of the carrier. Must be unique (case insensitive)."
          },
          "naicCode": {
            "type": "string",
            "example": 44335,
            "description": "NAIC code of the carrier. Must be numeric."
          }
        }
      },
      "MedicarePolicyType": {
        "type": "object",
        "readOnly": true,
        "description": "A type of Medicare policy",
        "required": [
          "id",
          "name",
          "orgId",
          "created"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the policy type in AgentCloud's system"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "The name of the policy type"
          },
          "orgId": {
            "type": "integer",
            "example": 2,
            "description": "The ID of the organization to which the policy type belongs \nin AgentCloud.\n"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "example": "2021-07-20T20:04:46.278815-04:00",
            "description": "When the policy type was created in AgentCloud"
          }
        }
      },
      "CreateMedicarePolicyType": {
        "type": "object",
        "description": "A request to create a new type of Medicare policy.",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "description": "Name of the policy type. Must be unique (case insensitive).\n"
          }
        }
      },
      "DentalVisionProductInputType": {
        "type": "object",
        "description": "A request to upsert a Dental/Vision product.",
        "required": [
          "displayName",
          "carrierId"
        ],
        "properties": {
          "displayName": {
            "type": "string",
            "example": "Vision Plan",
            "description": "Name of the Dental/Vision product. Must be\n  unique (case insensitive).\n"
          },
          "carrierId": {
            "type": "integer",
            "example": 1234,
            "description": "The AgentCloud ID of the carrier offering the Dental/Vision product"
          }
        }
      },
      "DentalVisionProductType": {
        "type": "object",
        "readOnly": true,
        "description": "A Dental/Vision product that can be sold through AgentCloud",
        "required": [
          "id",
          "displayName",
          "carrier"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1,
            "description": "The ID of the product in AgentCloud"
          },
          "displayName": {
            "type": "string",
            "example": "Vision Plan",
            "description": "The name of the product"
          },
          "carrier": {
            "$ref": "#/components/schemas/MedicareCarrier"
          }
        }
      },
      "Doctor": {
        "type": "object",
        "description": "One of the insured's doctors.",
        "required": [
          "id",
          "opportunityId"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1234,
            "description": "The doctor's ID in AgentCloud.",
            "readOnly": true
          },
          "opportunityId": {
            "type": "integer",
            "example": 12345678,
            "description": "The opportunity with which the doctor is associated.",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "The doctor's name"
          },
          "locationId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "The doctor's location ID"
          },
          "npi": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "National Provider Identifier"
          },
          "street": {
            "type": "string",
            "example": "123 Main Street",
            "nullable": true,
            "minLength": 1,
            "maxLength": 124,
            "description": "First line of the street address"
          },
          "street2": {
            "type": "string",
            "example": "Unit 456",
            "nullable": true,
            "minLength": 1,
            "maxLength": 124,
            "description": "Second line of the street address"
          },
          "city": {
            "type": "string",
            "example": "Hartford",
            "nullable": true,
            "minLength": 1,
            "maxLength": 124
          },
          "state": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "nullable": true,
            "example": "CT",
            "description": "Two-letter USPS abbreviation of the state"
          },
          "zipCode": {
            "type": "string",
            "minLength": 5,
            "maxLength": 10,
            "nullable": true,
            "example": "06101",
            "description": "Postal code of the address"
          }
        }
      },
      "Drug": {
        "type": "object",
        "description": "A drug prescribed to the insured.",
        "required": [
          "id",
          "opportunityId"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1234,
            "description": "The drug's ID in AgentCloud.",
            "readOnly": true
          },
          "opportunityId": {
            "type": "integer",
            "example": 12345678,
            "description": "The opportunity with which the drug is associated.",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "The name of the drug"
          },
          "drugId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "The ID of the drug"
          },
          "quantity": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "The quantity of the drug prescribed"
          },
          "frequency": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true,
            "description": "How often the drug should be taken"
          },
          "packageSize": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true
          },
          "packagePriceCategory": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "nullable": true
          }
        }
      },
      "EmergencyContact": {
        "type": "object",
        "required": [
          "id",
          "opportunityId"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1234,
            "description": "The emergency contact's ID in AgentCloud.",
            "readOnly": true
          },
          "opportunityId": {
            "type": "integer",
            "example": 12345678,
            "description": "The opportunity with which the emergency contact is associated.\n",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "John Smith",
            "nullable": true,
            "description": "The emergency contact's name. When submitting new emergency \ncontacts to the POST endpoint, this field is used to deduplicate\nemergency contacts. The deduplication comparison is case \ninsensitive.\n"
          },
          "phone": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": 8605551234,
            "nullable": true,
            "description": "The emergency contact's phone number. Unlike most phone numbers in\nthis API, this field is not subject to any validation other than\nbasic length restrictions.\n"
          },
          "relationshipToInsured": {
            "type": "string",
            "minLength": 1,
            "maxLength": 124,
            "example": "Daughter",
            "nullable": true,
            "description": "How the emergency contact is related to the insured."
          }
        }
      },
      "Schema": {
        "description": "A"
      },
      "ReasonCode": {
        "type": "object",
        "readOnly": true,
        "description": "A reason code is the particular reason why an opportunity is currently in its status. The reason codes should be associated with a particular opportunity status\n* Postponed\n  * 1 - Medical Short Term\n  * 2 - Medical Long Term\n  * 3 - Non-Medical Short Term\n  * 4 - Non-Medical Long Term\n  * 5 - Covid\n* Declined\n  * 6 - Medical\n  * 7 - Habit\n  * 8 - Financial\n* Withdrawn\n  * 9 - Customer Request\n  * 10 - No Response\n  * 11 - Auto Withdrawn\n* Del Reqs Sent to Carrier\n  * 12 - Active\n  * 13 - Paid Issue\n* Ineligible\n  * 14 - Medical\n  * 15 - Habit\n  * 16 - Financial\n  * 17 - Age\n* Not Interested\n  * 18 - Already Purchased\n  * 19 - Too Expensive\n  * 20 - Product Issue\n  * 21 - Did Not Request\n  * 22 - No Payment Method\n  * 23 - App Never Sent\n  * 24 - App Never Returned\n  * 25 - Journey Pivot\n* Not Taken\n  * 26 - Max Attempt Reached\n  * 27 - Resell Rejected\n  * 28 - Rewrite\n  * 29 - Too Expensive\n  * 30 - Chose Other Agent\n  * 31 - Took Too Long\n  * 32 - Resell No Resp AE\n  * 33 - Insufficient Funds\n* No Response\n  * 34 - App Not Returned\n  * 35 - Exam Not Completed\n  * 36 - Max Attempt Reached\n* Deceased\n  * 37 - Death Claim UW\n  * 38 - Death Claim Inforce\n  * 39 - No Claim\n* Lapsed\n  * 40 - Free Look Cancellation\n  * 41 - Cancellation Year 1\n  * 42 - Cancellation After Year 1\n  * 43 - Lapsed Year 1\n  * 44 - Lapsed After Year 1\n* Canceled\n  * 45 - Already had a plan in place\n  * 46 - MBR chose another plan\n  * 47 - MBR did not respond to carrier with needed information\n  * 48 - MBR enrolled in the wrong plan\n  * 49 - No application found on file with Carrier\n  * 50 - Stayed with the previous plan\n  * 51 - Wrong SEP code used\n* Denied\n  * 52 - GI proof not supplied\n  * 53 - Non-payment on policy\n  * 54 - No SEP available\n  * 55 - Not Medicaid eligible\n  * 56 - Not Medicaid eligible (Part A termed)\n  * 57 - Not Medicaid eligible (Part B termed)\n",
        "properties": {
          "id": {
            "type": "integer",
            "example": 40,
            "nullable": false,
            "description": "The unique identifier for the reason code."
          },
          "displayName": {
            "type": "string",
            "example": "Free Look Cancellation",
            "nullable": false,
            "description": "The human-readable explanation of the reason."
          }
        }
      }
    }
  }
}