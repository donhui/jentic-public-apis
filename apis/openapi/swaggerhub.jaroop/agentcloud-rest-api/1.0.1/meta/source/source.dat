    "/opportunities/{opportunityId}/medicare/drugs": {
      "get": {
        "summary": "Gets all drugs listed for a Medicare patient's opportunity",
        "tags": [
          "Opportunities",
          "Medicare"
        ],
        "parameters": [
          {
            "name": "opportunityId",
            "in": "path",
            "required": true,
            "description": "The AgentCloud ID of a Medicare opportunity",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved the drugs for an opportunity. Note that \nthe array may be empty even though the request was successful.\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Drug"
                  }
                }
              }
            }
          },
          "403": {
            "description": "The client lacks permission to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "The given ID does not match any known opportunities.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "summary": "Updates a Medicare opportunity's drugs",
        "description": "This endpoint performs an upsert operation to associate drugs\nwith a Medicare opportunity. The drug's `drugId` field (not to be \nconfused with the `id` field assigned by AgentCloud) is used to dedupe\ndrugs on a per-opportunity basis. In other words, the same drug ID\nmay only be associated with one drug per opportunity. If the\n`drugId` matches an existing drug for this opportunity, then the \ndrug's data is updated to match the request. If the `drugId` does\nnot match any drugs for this opportunity, a new drug is created\nwith the data in the request.\n",
        "tags": [
          "Opportunities",
          "Medicare"
        ],
        "parameters": [
          {
            "name": "opportunityId",
            "in": "path",
            "required": true,
            "description": "The AgentCloud ID of a Medicare opportunity",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "minLength": 1,
                "items": {
                  "$ref": "#/components/schemas/Drug"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns the complete list of ALL drugs associated with this\nopportunity, including drugs that were not part of the original\nrequest.\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Drug"
                  }
                }
              }
            }
          },
          "400": {
            "description": "A failed response, typically indicating that the request data was\nmalformed or invalid.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "The client lacks permission to access this resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "The given ID does not match any known opportunities.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
