      "post": {
        "summary": "Updates a Medicare opportunity's emergency contacts",
        "description": "This endpoint performs an upsert operation to associate emergency \ncontacts with a Medicare opportunity. The emergency contact's full\nname is used to deduplicate contacts for a given opportunity. If \nan emergency contact submitted to this endpoint is a case-insensitive\nmatch for an existing emergency contact on the same opportunity, then\nthe original contact will be updated. Otherwise a new contact will be\ncreated.\n",
        "tags": [
          "Opportunities",
          "Medicare"
        ],
        "parameters": [
          {
            "name": "opportunityId",
            "in": "path",
            "required": true,
            "description": "The AgentCloud ID of a Medicare opportunity",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
