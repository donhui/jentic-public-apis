{
  "swagger": "2.0",
  "info": {
    "description": "Online Accounting API is to be used where the accounting entry is expected to be handed off on-line to the host AND host can provide synchronous response. Typically, this would be for intra-day customer debit and credit transactions. Online API is always for a single batch, containing a single group, which in turn will contain a single accounting entry. An accounting entry will typically have both debit and credit legs. However, if host supports, single-sided entries will also be allowed (wherein an entry has only debit legs or only credit legs).\nNo debit or credit leg consolidation is supported for this API\nResposne to this API will be synchronous. note: IF host cannot provide synchronous response, then batch interface should be used even for intra-day",
    "version": "1.0.2",
    "title": "Accounting - Online Interface",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/igtbdigital/accounting-online_interface/1.0.2/swagger.json"
  },
  "paths": {
    "/v1/common/accounting": {
      "post": {
        "tags": [
          "Accounting"
        ],
        "operationId": "accounting",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "accounting",
            "required": true,
            "schema": {
              "$ref": "#/definitions/accounting"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "standard response",
            "schema": {
              "$ref": "#/definitions/accountingResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "accounting": {
      "type": "object",
      "required": [
        "product",
        "batchId",
        "groupId",
        "entryId",
        "bankEntity",
        "ppTxnCode",
        "entryDate",
        "valueDate",
        "leg"
      ],
      "properties": {
        "product": {
          "type": "string",
          "maxLength": 35,
          "example": "Payment",
          "description": "Payment / CnR / Liquidity etc"
        },
        "batchId": {
          "type": "string",
          "maxLength": 35,
          "example": "CNR20180719001",
          "description": "Batch ID of Accounting transactions (PP Code + YYYYMMDD+Batch ID Number to make it unique ); Note that a batch is expected to have only one group and one entry"
        },
        "batchDate": {
          "type": "string",
          "format": "dd-mm-yyyy",
          "example": "29-08-2017",
          "description": "Batch creation date"
        },
        "groupId": {
          "type": "string",
          "maxLength": 35,
          "example": "G001",
          "description": "Group ID of Accounting transactions; Note that a batch is expected to have only one group and one entry"
        },
        "entryId": {
          "type": "string",
          "maxLength": 35,
          "example": "E001",
          "description": "Unique Entry ID , In One entry Multiple debit & Multiple credits are not possible , Any one debit or credit legs should be single leg ."
        },
        "hostId": {
          "type": "string",
          "maxLength": 35,
          "example": "ISPTH",
          "description": "Host  where account held"
        },
        "bankEntity": {
          "type": "string",
          "maxLength": 15,
          "example": "THAILAND",
          "description": "Bank Entity for the GL Account"
        },
        "ppTxnCode": {
          "type": "string",
          "maxLength": 10,
          "example": "RAIBDIB",
          "description": "Product Processor Transaction Code"
        },
        "entryDate": {
          "type": "string",
          "format": "dd-mm-yyyy",
          "example": "29-04-2017",
          "description": "Transaction Date"
        },
        "valueDate": {
          "type": "string",
          "format": "dd-mm-yyy",
          "example": "29-04-2018",
          "description": "Transaction Value Date"
        },
        "forceDebitFlag": {
          "type": "string",
          "maxLength": 1,
          "example": "Y",
          "description": "Force debit flag  Y- Yes N - No"
        },
        "fxRateType": {
          "type": "string",
          "maxLength": 1,
          "example": "C",
          "description": "S- Spot , C- Contract"
        },
        "fxRate": {
          "type": "number",
          "format": "double",
          "maxLength": 16,
          "example": "1.5677",
          "description": "FX conversion Rate between debit account currency to credit account currency; Will be Spot rate or Contract rate used for the transaction"
        },
        "contractReference": {
          "type": "string",
          "maxLength": 35,
          "example": null,
          "description": "Contract reference number for FX Rate, where applicable. This value is expected to be used by host to utilize the contract"
        },
        "leg": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/legs"
          }
        }
      }
    },
    "legs": {
      "type": "object",
      "required": [
        "legId",
        "legSequenceNumber",
        "branchCode",
        "debitCreditFlag",
        "accountType",
        "accountGuid",
        "accountCurrency",
        "amountInAccountCurrency",
        "shortNarration"
      ],
      "properties": {
        "legId": {
          "type": "string",
          "maxLength": 35,
          "example": "L001",
          "description": "Unique Leg Number"
        },
        "legSequenceNumber": {
          "type": "number",
          "maxLength": 5,
          "example": "001",
          "description": "Sequence Number"
        },
        "branchCode": {
          "type": "string",
          "maxLength": 10,
          "example": "1004",
          "description": "Branch code of the account"
        },
        "debitCreditFlag": {
          "maxLength": 1,
          "type": "string",
          "example": "D",
          "description": "Debit credit flags - D-Debit C- Credit"
        },
        "accountType": {
          "maxLength": 1,
          "type": "string",
          "example": "G",
          "description": "Flag to identify the accountGuid is customer GUID or GL GUID. G- Gl Account GUID , C- Customer Account GUID."
        },
        "accountGuid": {
          "type": "string",
          "maxLength": 36,
          "example": "0ee6e247-8fd5-5c16-92c3-aff884baf117",
          "description": "Account GUID"
        },
        "accountCurrency": {
          "type": "string",
          "maxLength": 3,
          "example": "INR",
          "description": "Account Currency"
        },
        "amountInAccountCurrency": {
          "type": "number",
          "format": "double",
          "maxLength": 20,
          "example": "20000",
          "description": "Amount in account currency"
        },
        "instrumentNumber": {
          "type": "string",
          "maxLength": 35,
          "example": "1223",
          "description": "If Instrument is involved in transaction"
        },
        "instrumentDate": {
          "type": "string",
          "format": "dd-mm-yyyy",
          "example": "12-04-2018",
          "description": "If Instrument is involved in transaction"
        },
        "shortNarration": {
          "type": "string",
          "maxLength": 50,
          "example": null,
          "description": "Narration details"
        },
        "narration": {
          "type": "string",
          "maxLength": 100,
          "example": null,
          "description": "Narration details"
        },
        "extendedNarration": {
          "type": "string",
          "maxLength": 200,
          "example": null,
          "description": "Narration details"
        }
      }
    },
    "accountingResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "object",
          "properties": {
            "product": {
              "type": "string",
              "example": "CNR",
              "description": "Product name like COLLECTION , PAYMENTS , LIQUIDITY "
            },
            "batchId": {
              "type": "string",
              "description": "Batch ID of Accounting transactions as sent in request.",
              "example": "CNR20180719001"
            },
            "groupId": {
              "type": "string",
              "description": "Group ID of Accounting transactions as sent in request",
              "example": "G001"
            },
            "entryId": {
              "type": "string",
              "description": "Entry ID of accounting transaction as sent in request",
              "example": "E001"
            },
            "responseTime": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "description": " Accounting Entry status as provided by Host S-SUCCESS  F-FAILURE",
              "example": "S"
            },
            "errorCode": {
              "type": "string",
              "description": "error code incase of failure as given by Host"
            },
            "errorDescription": {
              "type": "string",
              "description": "error Description in case of failure as given by Host"
            }
          }
        },
        "status": {
          "type": "string",
          "example": "200",
          "description": "200 - Success / 400 - Bad Input Parameter "
        },
        "errorCode": {
          "type": "string",
          "description": "error code incase of business validation / parsing failure as provided by accounting engine"
        },
        "errorMessage": {
          "type": "string",
          "description": "errorMessage incase of business validation / parsing failure as provided by accounting engine"
        }
      }
    }
  },
  "host": "virtserver.swaggerhub.com",
  "schemes": [
    "https"
  ]
}