{
    "openapi": "3.0.0",
    "info": {
        "description": "This is a Account Master API",
        "version": "1.1.0",
        "title": "Account Master API",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/igtbdigital/AccountMasterAPI/1.1.0/swagger.json"
    },
    "tags": [
        {
            "name": "Account Master",
            "description": "It contains Accounts Details"
        }
    ],
    "paths": {
        "/v1/common/accounts/{accountNo}/{bankEntityId}": {
            "get": {
                "tags": [
                    "Account Master"
                ],
                "summary": "To get the Accounts details",
                "operationId": "getAccountsDetails",
                "description": "It returns the account Number and other details about to Account\n",
                "parameters": [
                    {
                        "name": "bankEntityId",
                        "in": "path",
                        "description": "Enter the Enter Entity ID",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "accountNo",
                        "in": "path",
                        "description": "Enter the Account Number",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success response indicating request Account details got successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Account"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "bad input parameter"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Account Master"
                ],
                "summary": "Delete Accounts Details",
                "description": "Delete the Account details for the given Account Nos",
                "parameters": [
                    {
                        "name": "bankEntityId",
                        "in": "path",
                        "description": "Enter the Enter Entity ID",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "accountNo",
                        "in": "path",
                        "description": "Account Nos of the given Account type",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/DeleteAccountNos"
                            }
                        }
                    },
                    "description": "The Account Number and the action needs to be passed"
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "400": {
                        "description": "Error! Unable to Delete the Accounts"
                    }
                }
            }
        },
        "/v1/common/accounts": {
            "get": {
                "tags": [
                    "Account Master"
                ],
                "summary": "Get all Accounts details",
                "operationId": "getAllAccountsDetails",
                "description": "It returns the account No and other details about to Accounts\n",
                "responses": {
                    "200": {
                        "description": "Success response indicating request Accounts details got successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Account"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "bad input parameter"
                    }
                }
            },
            "put": {
                "tags": [
                    "Account Master"
                ],
                "summary": "Update Account Details",
                "description": "Update Account Details",
                "operationId": "updateAccountDetails",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Account"
                            }
                        }
                    },
                    "description": "Update Account Numbers Request body",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Success response indicating request Status updated successfully"
                    },
                    "201": {
                        "description": "Success response indicating request state created successfully"
                    },
                    "422": {
                        "description": "Request failed validation"
                    },
                    "500": {
                        "description": "An Error Response indicating internal server error"
                    }
                }
            },
            "post": {
                "tags": [
                    "Account Master"
                ],
                "summary": "Adds new Account numbers to the system",
                "operationId": "addNewAccountNos",
                "description": "Adds new account Nos to the system",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Account"
                            }
                        }
                    },
                    "description": "Account numbers to add"
                },
                "responses": {
                    "201": {
                        "description": "Account number has inserted successfully"
                    },
                    "400": {
                        "description": "invalid input, object invalid"
                    },
                    "409": {
                        "description": "an existing Account numbers already exists"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/igtbdigital/AccountMasterAPI/1.0.0"
        }
    ],
    "components": {
        "schemas": {
            "Account": {
                "type": "object",
                "required": [
                    "bankEntityId",
                    "accountNo",
                    "accountNoGUID",
                    "accountName",
                    "hostId",
                    "currency",
                    "branch",
                    "cif",
                    "accountType",
                    "residentType",
                    "accountStatus",
                    "overDraftFlag",
                    "stopPayment",
                    "noCredit",
                    "noDebit",
                    "lastUpdateTime",
                    "onBoardFlag",
                    "identifierMT940NMT950"
                ],
                "properties": {
                    "bankEntityId": {
                        "type": "string",
                        "example": "IGTB01"
                    },
                    "accountNo": {
                        "type": "string",
                        "example": 10000000000001
                    },
                    "accountNoGUID": {
                        "type": "string",
                        "example": 10000000000001
                    },
                    "accountName": {
                        "type": "string",
                        "example": "Tata Group"
                    },
                    "accountNameLocalLanguage": {
                        "type": "string",
                        "example": "Tata Group"
                    },
                    "hostId": {
                        "type": "number",
                        "example": "ISPIN"
                    },
                    "currency": {
                        "type": "number",
                        "example": "INR"
                    },
                    "branch": {
                        "type": "number",
                        "example": 1021
                    },
                    "cif": {
                        "type": "string",
                        "example": 1000000000
                    },
                    "iban": {
                        "type": "string",
                        "example": null
                    },
                    "accountType": {
                        "type": "string",
                        "example": "SBA"
                    },
                    "accountSubType": {
                        "type": "string",
                        "example": "FCD"
                    },
                    "residentType": {
                        "type": "string",
                        "description": "R-Resident and N- Non Resident",
                        "enum": [
                            "R",
                            "N"
                        ],
                        "default": "R"
                    },
                    "openDate": {
                        "type": "string",
                        "example": "21-06-2017"
                    },
                    "accountStatus": {
                        "type": "string",
                        "description": "'C'-Closed, 'O'-Open, 'B'-Blocked and 'D' - Dormant",
                        "enum": [
                            "C",
                            "O",
                            "B",
                            "D"
                        ],
                        "default": "O"
                    },
                    "closureDate": {
                        "type": "string",
                        "example": null
                    },
                    "overDraftFlag": {
                        "type": "string",
                        "description": "Y-Yes and N-No",
                        "enum": [
                            "Y",
                            "N"
                        ],
                        "default": "Y"
                    },
                    "overDraftLimit": {
                        "type": "string",
                        "example": "200000000.0000."
                    },
                    "primaryPhone": {
                        "type": "string",
                        "description": "Y-Yes and N-No",
                        "enum": [
                            "Y",
                            "N"
                        ],
                        "default": "Y"
                    },
                    "stopPayment": {
                        "type": "string",
                        "description": "Y-Yes and N-No",
                        "enum": [
                            "Y",
                            "N"
                        ],
                        "default": "Y"
                    },
                    "delinquencyStatus": {
                        "type": "string",
                        "description": "Y-Yes and N-No",
                        "enum": [
                            "Y",
                            "N"
                        ],
                        "default": "Y"
                    },
                    "noCredit": {
                        "type": "string",
                        "description": "Y-Yes and N-No",
                        "enum": [
                            "Y",
                            "N"
                        ],
                        "default": "Y"
                    },
                    "noDebit": {
                        "type": "string",
                        "description": "Y-Yes and N-No",
                        "enum": [
                            "Y",
                            "N"
                        ],
                        "default": "Y"
                    },
                    "lastUpdateTime": {
                        "type": "string",
                        "example": "26-08-2017"
                    },
                    "onBoardFlag": {
                        "type": "string",
                        "description": "Y-Yes and N-No",
                        "enum": [
                            "Y",
                            "N"
                        ],
                        "default": "Y"
                    },
                    "identifierMT101NMT103": {
                        "type": "string",
                        "description": "Y-Yes and N-No",
                        "enum": [
                            "Y",
                            "N"
                        ],
                        "default": "N"
                    },
                    "identifierMT940NMT950": {
                        "type": "string",
                        "description": "Y-Yes and N-No",
                        "enum": [
                            "Y",
                            "N"
                        ],
                        "default": "Y"
                    }
                }
            },
            "DeleteAccountNos": {
                "type": "object",
                "required": [
                    "bankEntityId",
                    "accountNo"
                ],
                "properties": {
                    "bankEntityId": {
                        "type": "string",
                        "example": "IGTB01"
                    },
                    "accountNo": {
                        "type": "string",
                        "example": 10000000000001
                    }
                }
            }
        }
    }
}