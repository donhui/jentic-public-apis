{
  "openapi": "3.0.3",
  "info": {
    "title": "Voiso Contact Center API",
    "description": "Voiso API for contact center operations including voice, messaging, campaigns, and monitoring",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{cluster_id}.voiso.com",
      "variables": {
        "cluster_id": {
          "default": "api",
          "description": "Your Voiso cluster ID"
        }
      }
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      },
      "BearerToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Contact Center Bearer Token"
      },
      "UserBearerToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "User Bearer Token"
      },
      "StaticKey": {
        "type": "http",
        "scheme": "bearer",
        "description": "Static Key authentication"
      }
    }
  },
  "security": [
    {
      "ApiKey": []
    },
    {
      "BearerToken": []
    },
    {
      "UserBearerToken": []
    },
    {
      "StaticKey": []
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "summary": "List users",
        "description": "Retrieve list of users",
        "tags": [
          "User Management"
        ],
        "responses": {
          "200": {
            "description": "List of users"
          }
        }
      }
    },
    "/users/deleted": {
      "get": {
        "summary": "List deleted users",
        "description": "Retrieve list of deleted users",
        "tags": [
          "User Management"
        ],
        "responses": {
          "200": {
            "description": "List of deleted users"
          }
        }
      }
    },
    "/teams": {
      "get": {
        "summary": "List teams",
        "description": "Retrieve list of teams",
        "tags": [
          "User Management"
        ],
        "responses": {
          "200": {
            "description": "List of teams"
          }
        }
      }
    },
    "/click2call/start": {
      "post": {
        "summary": "Initiate outbound call",
        "description": "Start a click-to-call outbound call",
        "tags": [
          "Voice Services"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Call initiated"
          }
        }
      }
    },
    "/click2call/stop": {
      "post": {
        "summary": "Stop outbound call",
        "description": "Stop an active click-to-call",
        "tags": [
          "Voice Services"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Call stopped"
          }
        }
      }
    },
    "/callback/schedule": {
      "post": {
        "summary": "Schedule callback",
        "description": "Schedule a future callback",
        "tags": [
          "Voice Services"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Callback scheduled"
          }
        }
      }
    },
    "/sms/send": {
      "post": {
        "summary": "Send SMS message",
        "description": "Send an SMS message",
        "tags": [
          "Messaging"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS sent successfully"
          }
        }
      }
    },
    "/sms/templates": {
      "get": {
        "summary": "Retrieve SMS templates",
        "description": "Get list of SMS templates",
        "tags": [
          "Messaging"
        ],
        "responses": {
          "200": {
            "description": "List of SMS templates"
          }
        }
      }
    },
    "/whatsapp/send": {
      "post": {
        "summary": "Send WhatsApp message",
        "description": "Send a WhatsApp message",
        "tags": [
          "Messaging"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "WhatsApp message sent"
          }
        }
      }
    },
    "/whatsapp/templates": {
      "get": {
        "summary": "List WhatsApp templates",
        "description": "Get list of WhatsApp templates",
        "tags": [
          "Messaging"
        ],
        "responses": {
          "200": {
            "description": "List of WhatsApp templates"
          }
        }
      }
    },
    "/campaigns": {
      "get": {
        "summary": "List campaigns",
        "description": "Retrieve all campaigns",
        "tags": [
          "Campaigns"
        ],
        "responses": {
          "200": {
            "description": "List of campaigns"
          }
        }
      },
      "post": {
        "summary": "Create campaign",
        "description": "Create a new campaign",
        "tags": [
          "Campaigns"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Campaign created"
          }
        }
      }
    },
    "/campaigns/{id}": {
      "get": {
        "summary": "Get campaign",
        "description": "Retrieve campaign details",
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign details"
          }
        }
      },
      "put": {
        "summary": "Update campaign",
        "description": "Update an existing campaign",
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Campaign updated"
          }
        }
      },
      "delete": {
        "summary": "Delete campaign",
        "description": "Delete a campaign",
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign deleted"
          }
        }
      }
    },
    "/cdr": {
      "get": {
        "summary": "Query interaction data",
        "description": "Query call detail records",
        "tags": [
          "Contact Center Operations"
        ],
        "responses": {
          "200": {
            "description": "CDR data"
          }
        }
      }
    },
    "/balance": {
      "get": {
        "summary": "Request account balance",
        "description": "Get current account balance information",
        "tags": [
          "Contact Center Operations"
        ],
        "responses": {
          "200": {
            "description": "Balance information"
          }
        }
      }
    },
    "/agent/status": {
      "get": {
        "summary": "Retrieve agent status",
        "description": "Get current agent status",
        "tags": [
          "Contact Center Operations"
        ],
        "responses": {
          "200": {
            "description": "Agent status"
          }
        }
      }
    },
    "/agent/wrapup-codes": {
      "get": {
        "summary": "Get wrap-up codes",
        "description": "Retrieve agent wrap-up codes",
        "tags": [
          "Contact Center Operations"
        ],
        "responses": {
          "200": {
            "description": "List of wrap-up codes"
          }
        }
      }
    },
    "/queues": {
      "get": {
        "summary": "List queues",
        "description": "Retrieve inbound routing queues",
        "tags": [
          "Contact Center Operations"
        ],
        "responses": {
          "200": {
            "description": "List of queues"
          }
        }
      }
    },
    "/numbers": {
      "get": {
        "summary": "Query phone numbers",
        "description": "Retrieve phone number information",
        "tags": [
          "Contact Center Operations"
        ],
        "responses": {
          "200": {
            "description": "List of phone numbers"
          }
        }
      }
    },
    "/conversations": {
      "get": {
        "summary": "Access digital channel messages",
        "description": "Retrieve conversations from digital channels",
        "tags": [
          "Contact Center Operations"
        ],
        "responses": {
          "200": {
            "description": "List of conversations"
          }
        }
      }
    },
    "/webhooks/failures": {
      "get": {
        "summary": "Track webhook failures",
        "description": "Get list of failed webhooks",
        "tags": [
          "Monitoring"
        ],
        "responses": {
          "200": {
            "description": "List of webhook failures"
          }
        }
      }
    },
    "/webhooks/retrigger": {
      "post": {
        "summary": "Retrigger failed webhook",
        "description": "Retry a failed webhook",
        "tags": [
          "Monitoring"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook retriggered"
          }
        }
      }
    }
  }
}
