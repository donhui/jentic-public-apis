{
  "openapi": "3.0.3",
  "info": {
    "title": "Cruisen Public API",
    "version": "1.0.0",
    "description": "Public API endpoints for Cruisen system. This API allows travel agents to:\n* Retrieve booking information\n* Access trip details\n* View traveller profile details\n\nAuthentication is required via API key for all endpoints.\n",
    "x-jentic-source-url": "https://cruisen-preview.firebaseapp.com/public-api-docs.html"
  },
  "servers": [
    {
      "url": "https://cruisen-production.web.app",
      "description": "Production server"
    }
  ],
  "paths": {
    "/get-user": {
      "get": {
        "operationId": "publicGetUser",
        "summary": "Get authenticated user information",
        "description": "Retrieves the public information about the currently authenticated user",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "code": {
                      "type": "string",
                      "example": "ok"
                    },
                    "result": {
                      "$ref": "#/components/schemas/PublicUserData"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/get-profile": {
      "get": {
        "operationId": "publicGetProfile",
        "summary": "Get a single profile by ID",
        "description": "Retrieves detailed information about a specific profile.\nAccess is restricted to profile owner or users from the same agency.\n",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Profile ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "code": {
                      "type": "string",
                      "example": "ok"
                    },
                    "result": {
                      "$ref": "#/components/schemas/PublicProfileData"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid argument",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "success": false,
                  "code": "invalid-argument",
                  "message": "Profile id is empty"
                }
              }
            }
          },
          "403": {
            "description": "Permission denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "success": false,
                  "code": "permission-denied",
                  "message": "Profile access denied"
                }
              }
            }
          },
          "404": {
            "description": "Profile not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "success": false,
                  "code": "not-found",
                  "message": "Profile not found"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/get-profiles": {
      "get": {
        "operationId": "publicGetProfiles",
        "summary": "Get profiles based on request type",
        "description": "Retrieves profiles based on the request type:\n- All profiles for a specific trip's users\n- All profiles owned by the authenticated user\n",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "code": {
                      "type": "string",
                      "example": "ok"
                    },
                    "result": {
                      "type": "object",
                      "properties": {
                        "profiles": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/PublicProfileData"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Permission denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/get-booking": {
      "get": {
        "operationId": "publicGetBooking",
        "summary": "Get a single booking by ID",
        "description": "Retrieves detailed information about a specific booking.\nOnly bookings belonging to the authenticated advisor can be accessed.\n",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Booking ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "code": {
                      "type": "string",
                      "example": "ok"
                    },
                    "result": {
                      "$ref": "#/components/schemas/PublicBookingData"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid argument",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "success": false,
                  "code": "invalid-argument",
                  "message": "Booking id is empty"
                }
              }
            }
          },
          "403": {
            "description": "Permission denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "success": false,
                  "code": "permission-denied",
                  "message": "Booking access denied"
                }
              }
            }
          },
          "404": {
            "description": "Booking not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "success": false,
                  "code": "not-found",
                  "message": "Booking not found"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/get-bookings": {
      "get": {
        "operationId": "publicGetBookings",
        "summary": "Get all bookings for the authenticated advisor",
        "description": "Retrieves all bookings associated with the authenticated advisor.\nResults include related trip and cruise sailing information.\n",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "code": {
                      "type": "string",
                      "example": "ok"
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PublicBookingData"
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/get-trip": {
      "get": {
        "operationId": "publicGetTrip",
        "summary": "Get a single trip by ID",
        "description": "Retrieves detailed information about a specific trip.\nAccess is restricted based on user permissions.\n",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Trip ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "code": {
                      "type": "string",
                      "example": "ok"
                    },
                    "result": {
                      "$ref": "#/components/schemas/PublicTripData"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid argument",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Permission denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Trip not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/get-trips": {
      "get": {
        "operationId": "publicGetTrips",
        "summary": "Get all trips for the authenticated user",
        "description": "Retrieves all trips accessible to the authenticated user.\nResults include trip owner information.\n",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "code": {
                      "type": "string",
                      "example": "ok"
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PublicTripData"
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key provided to authorized travel advisors"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "success",
          "code",
          "message"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "code": {
            "type": "string",
            "enum": [
              "error",
              "invalid-argument",
              "permission-denied",
              "not-found"
            ],
            "example": "error"
          },
          "message": {
            "type": "string",
            "example": "Error message"
          },
          "details": {
            "type": "object",
            "description": "Additional error details if available"
          }
        }
      },
      "ShipData": {
        "type": "object",
        "required": [
          "id",
          "name",
          "code",
          "description",
          "shortDescription",
          "lineId",
          "lineName"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "shortDescription": {
            "type": "string"
          },
          "lineId": {
            "type": "number"
          },
          "lineName": {
            "type": "string"
          },
          "imageCaption": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "hdImageUrl": {
            "type": "string",
            "nullable": true
          },
          "smallImageUrl": {
            "type": "string",
            "nullable": true
          },
          "launched": {
            "type": "string"
          },
          "tonnage": {
            "type": "number"
          },
          "length": {
            "type": "number"
          },
          "occupancy": {
            "type": "number"
          },
          "totalCabins": {
            "type": "number"
          },
          "totalCrew": {
            "type": "number"
          },
          "niceUrl": {
            "type": "string"
          },
          "rating": {
            "type": "number"
          },
          "starRating": {
            "type": "number"
          },
          "adultsOnly": {
            "type": "boolean"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CruiseLineData": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "engine": {
            "type": "string"
          },
          "logoUrl": {
            "type": "string"
          },
          "niceUrl": {
            "type": "string",
            "nullable": true
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "PublicUserData": {
        "type": "object",
        "required": [
          "id",
          "firstName",
          "lastName",
          "email"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        }
      },
      "PublicProfileData": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "ownerUserId": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "nationality": {
            "type": "string"
          },
          "gender": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PublicTripCollaboratorData": {
        "type": "object",
        "required": [
          "userId",
          "firstName",
          "lastName"
        ],
        "properties": {
          "userId": {
            "type": "string",
            "description": "Unique identifier of the user"
          },
          "firstName": {
            "type": "string",
            "description": "First name of the collaborator"
          },
          "lastName": {
            "type": "string",
            "description": "Last name of the collaborator"
          },
          "avatar": {
            "type": "string",
            "nullable": true,
            "description": "URL to the collaborator's avatar image"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the collaborator"
          }
        }
      },
      "PublicTripData": {
        "type": "object",
        "required": [
          "id",
          "name",
          "ownerId"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "inviteLink": {
            "type": "string",
            "nullable": true
          },
          "ownerId": {
            "type": "string"
          },
          "owner": {
            "nullable": true,
            "$ref": "#/components/schemas/PublicUserData"
          },
          "months": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "chosenTripSearchResultId": {
            "type": "string",
            "nullable": true
          },
          "bookedCruiseDetails": {
            "type": "object",
            "nullable": true,
            "properties": {
              "lineName": {
                "type": "string"
              },
              "startDate": {
                "type": "string"
              },
              "endDate": {
                "type": "string"
              }
            }
          },
          "collaborators": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PublicTripCollaboratorData"
            }
          },
          "originPortGroups": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "object",
              "required": [
                "id",
                "name"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "destinationRegions": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "object",
              "required": [
                "id",
                "name"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "created": {
            "type": "string",
            "nullable": true
          },
          "updated": {
            "type": "string",
            "nullable": true
          },
          "updatedBy": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PublicCruiseSailingData": {
        "type": "object",
        "required": [
          "id",
          "departureDate",
          "returnDate"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "departureDate": {
            "type": "string",
            "format": "date-time"
          },
          "returnDate": {
            "type": "string",
            "format": "date-time"
          },
          "ship": {
            "$ref": "#/components/schemas/ShipData"
          },
          "line": {
            "$ref": "#/components/schemas/CruiseLineData"
          },
          "status": {
            "type": "string",
            "enum": [
              "scheduled",
              "in-progress",
              "completed",
              "cancelled"
            ]
          },
          "portOfDeparture": {
            "type": "string"
          },
          "portOfReturn": {
            "type": "string"
          },
          "price": {
            "type": "object",
            "properties": {
              "amount": {
                "type": "number"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "availability": {
            "type": "object",
            "properties": {
              "total": {
                "type": "number"
              },
              "available": {
                "type": "number"
              },
              "reserved": {
                "type": "number"
              }
            }
          }
        }
      },
      "PublicBookingData": {
        "type": "object",
        "required": [
          "id",
          "tripId",
          "cruiseSailingId",
          "status",
          "passengerCount"
        ],
        "properties": {
          "id": {
            "type": "number"
          },
          "tripId": {
            "type": "string"
          },
          "cruiseSailingId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "confirmed",
              "cancelled",
              "completed"
            ]
          },
          "bookingDate": {
            "type": "string",
            "format": "date-time"
          },
          "passengerCount": {
            "type": "integer",
            "minimum": 1
          },
          "agentCode": {
            "type": "string"
          },
          "totalPrice": {
            "type": "object",
            "properties": {
              "amount": {
                "type": "number"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "passengers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "firstName": {
                  "type": "string"
                },
                "lastName": {
                  "type": "string"
                },
                "dateOfBirth": {
                  "type": "string",
                  "format": "date"
                }
              }
            }
          },
          "trip": {
            "$ref": "#/components/schemas/PublicTripData"
          },
          "cruiseSailing": {
            "$ref": "#/components/schemas/PublicCruiseSailingData"
          }
        }
      }
    }
  }
}