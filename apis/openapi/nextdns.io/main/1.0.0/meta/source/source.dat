{
  "openapi": "3.0.3",
  "info": {
    "title": "NextDNS API",
    "description": "NextDNS API for managing DNS profiles, analytics, and logs. Currently in beta.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://nextdns.io/api"
  },
  "servers": [
    {
      "url": "https://api.nextdns.io"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {"name": "Profiles", "description": "Manage DNS profiles"},
    {"name": "Analytics", "description": "Profile analytics and statistics"},
    {"name": "Logs", "description": "DNS query logs"}
  ],
  "paths": {
    "/profiles": {
      "get": {
        "operationId": "listProfiles",
        "tags": ["Profiles"],
        "summary": "List all profiles",
        "parameters": [
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"}
        ],
        "responses": {
          "200": {
            "description": "List of profiles",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileListResponse"
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "createProfile",
        "tags": ["Profiles"],
        "summary": "Create a new profile",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileCreateResponse"
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}": {
      "get": {
        "operationId": "getProfile",
        "tags": ["Profiles"],
        "summary": "Get a profile",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"}
        ],
        "responses": {
          "200": {
            "description": "Profile details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateProfile",
        "tags": ["Profiles"],
        "summary": "Update a profile",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfileInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteProfile",
        "tags": ["Profiles"],
        "summary": "Delete a profile",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"}
        ],
        "responses": {
          "200": {"description": "Profile deleted"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/security": {
      "get": {
        "operationId": "getProfileSecurity",
        "tags": ["Profiles"],
        "summary": "Get security settings",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "responses": {
          "200": {
            "description": "Security settings",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SecuritySettings"}}}
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateProfileSecurity",
        "tags": ["Profiles"],
        "summary": "Update security settings",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SecuritySettings"}}}},
        "responses": {
          "200": {"description": "Security settings updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SecuritySettings"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/privacy": {
      "get": {
        "operationId": "getProfilePrivacy",
        "tags": ["Profiles"],
        "summary": "Get privacy settings",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "responses": {
          "200": {"description": "Privacy settings", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PrivacySettings"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateProfilePrivacy",
        "tags": ["Profiles"],
        "summary": "Update privacy settings",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PrivacySettings"}}}},
        "responses": {
          "200": {"description": "Privacy settings updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PrivacySettings"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/denylist": {
      "get": {
        "operationId": "getDenylist",
        "tags": ["Profiles"],
        "summary": "Get denylist entries",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "responses": {
          "200": {"description": "Denylist entries", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DenylistResponse"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "addToDenylist",
        "tags": ["Profiles"],
        "summary": "Add domain to denylist",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DenylistEntry"}}}},
        "responses": {
          "200": {"description": "Domain added"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/allowlist": {
      "get": {
        "operationId": "getAllowlist",
        "tags": ["Profiles"],
        "summary": "Get allowlist entries",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "responses": {
          "200": {"description": "Allowlist entries", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AllowlistResponse"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "addToAllowlist",
        "tags": ["Profiles"],
        "summary": "Add domain to allowlist",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AllowlistEntry"}}}},
        "responses": {
          "200": {"description": "Domain added"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/denylist/{domainId}": {
      "patch": {
        "operationId": "updateDenylistEntry",
        "tags": ["Profiles"],
        "summary": "Update a denylist entry",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"name": "domainId", "in": "path", "required": true, "description": "Domain name serving as the entry ID", "schema": {"type": "string"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DenylistEntry"}}}},
        "responses": {
          "200": {"description": "Denylist entry updated"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "removeDenylistEntry",
        "tags": ["Profiles"],
        "summary": "Remove a domain from the denylist",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"name": "domainId", "in": "path", "required": true, "description": "Domain name serving as the entry ID", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Domain removed from denylist"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/allowlist/{domainId}": {
      "patch": {
        "operationId": "updateAllowlistEntry",
        "tags": ["Profiles"],
        "summary": "Update an allowlist entry",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"name": "domainId", "in": "path", "required": true, "description": "Domain name serving as the entry ID", "schema": {"type": "string"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AllowlistEntry"}}}},
        "responses": {
          "200": {"description": "Allowlist entry updated"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "removeAllowlistEntry",
        "tags": ["Profiles"],
        "summary": "Remove a domain from the allowlist",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"name": "domainId", "in": "path", "required": true, "description": "Domain name serving as the entry ID", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Domain removed from allowlist"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/privacy/blocklists": {
      "get": {
        "operationId": "getPrivacyBlocklists",
        "tags": ["Profiles"],
        "summary": "Get privacy blocklist entries",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "responses": {
          "200": {"description": "Privacy blocklist entries", "content": {"application/json": {"schema": {"type": "object", "properties": {"data": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}}}}}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "put": {
        "operationId": "replacePrivacyBlocklists",
        "tags": ["Profiles"],
        "summary": "Replace all privacy blocklist entries",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}}}}}}},
        "responses": {
          "200": {"description": "Privacy blocklists replaced"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "addPrivacyBlocklist",
        "tags": ["Profiles"],
        "summary": "Add a privacy blocklist entry",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"id": {"type": "string"}}}}}},
        "responses": {
          "200": {"description": "Blocklist entry added"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/privacy/blocklists/{blocklistId}": {
      "patch": {
        "operationId": "updatePrivacyBlocklist",
        "tags": ["Profiles"],
        "summary": "Update a privacy blocklist entry",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"name": "blocklistId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"id": {"type": "string"}}}}}},
        "responses": {
          "200": {"description": "Blocklist entry updated"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "removePrivacyBlocklist",
        "tags": ["Profiles"],
        "summary": "Remove a privacy blocklist entry",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"name": "blocklistId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Blocklist entry removed"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/privacy/natives": {
      "get": {
        "operationId": "getPrivacyNatives",
        "tags": ["Profiles"],
        "summary": "Get native tracking protection entries",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "responses": {
          "200": {"description": "Native tracking entries", "content": {"application/json": {"schema": {"type": "object", "properties": {"data": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}}}}}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "put": {
        "operationId": "replacePrivacyNatives",
        "tags": ["Profiles"],
        "summary": "Replace all native tracking protection entries",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}}}}}}},
        "responses": {
          "200": {"description": "Native entries replaced"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "addPrivacyNative",
        "tags": ["Profiles"],
        "summary": "Add a native tracking protection entry",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"id": {"type": "string"}}}}}},
        "responses": {
          "200": {"description": "Native entry added"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/parentalControl": {
      "get": {
        "operationId": "getParentalControl",
        "tags": ["Profiles"],
        "summary": "Get parental control settings",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "responses": {
          "200": {"description": "Parental control settings", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ParentalControlSettings"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateParentalControl",
        "tags": ["Profiles"],
        "summary": "Update parental control settings",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ParentalControlSettings"}}}},
        "responses": {
          "200": {"description": "Parental control settings updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ParentalControlSettings"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/settings": {
      "get": {
        "operationId": "getProfileSettings",
        "tags": ["Profiles"],
        "summary": "Get profile settings",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "responses": {
          "200": {"description": "Profile settings", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProfileSettings"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateProfileSettings",
        "tags": ["Profiles"],
        "summary": "Update profile settings",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProfileSettings"}}}},
        "responses": {
          "200": {"description": "Settings updated"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/status": {
      "get": {
        "operationId": "getAnalyticsStatus",
        "tags": ["Analytics"],
        "summary": "Get query status analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"}
        ],
        "responses": {
          "200": {"description": "Status analytics", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AnalyticsStatusResponse"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/domains": {
      "get": {
        "operationId": "getAnalyticsDomains",
        "tags": ["Analytics"],
        "summary": "Get domain analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"},
          {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["default", "blocked", "allowed"]}},
          {"name": "root", "in": "query", "schema": {"type": "boolean", "default": false}}
        ],
        "responses": {
          "200": {"description": "Domain analytics", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AnalyticsDomainsResponse"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/protocols": {
      "get": {
        "operationId": "getAnalyticsProtocols",
        "tags": ["Analytics"],
        "summary": "Get protocol analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"}
        ],
        "responses": {
          "200": {"description": "Protocol analytics"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/devices": {
      "get": {
        "operationId": "getAnalyticsDevices",
        "tags": ["Analytics"],
        "summary": "Get device analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"}
        ],
        "responses": {
          "200": {"description": "Device analytics"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/ips": {
      "get": {
        "operationId": "getAnalyticsIps",
        "tags": ["Analytics"],
        "summary": "Get IP address analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"}
        ],
        "responses": {
          "200": {"description": "IP analytics"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
