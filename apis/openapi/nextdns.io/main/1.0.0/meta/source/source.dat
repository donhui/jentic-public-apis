      }
    },
    "/profiles/{profileId}/analytics/reasons": {
      "get": {
        "operationId": "getAnalyticsReasons",
        "tags": ["Analytics"],
        "summary": "Get block reason analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"}
        ],
        "responses": {
          "200": {"description": "Reason analytics"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/queryTypes": {
      "get": {
        "operationId": "getAnalyticsQueryTypes",
        "tags": ["Analytics"],
        "summary": "Get DNS query type analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"}
        ],
        "responses": {
          "200": {"description": "Query type analytics"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/destinations": {
      "get": {
        "operationId": "getAnalyticsDestinations",
        "tags": ["Analytics"],
        "summary": "Get destination analytics (countries or GAFAM)",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"},
          {"name": "type", "in": "query", "required": true, "schema": {"type": "string", "enum": ["countries", "gafam"]}}
        ],
        "responses": {
          "200": {"description": "Destination analytics"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/dnssec": {
      "get": {
        "operationId": "getAnalyticsDnssec",
        "tags": ["Analytics"],
        "summary": "Get DNSSEC validation analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"}
        ],
        "responses": {
          "200": {"description": "DNSSEC analytics"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/encryption": {
      "get": {
        "operationId": "getAnalyticsEncryption",
        "tags": ["Analytics"],
        "summary": "Get encryption analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"}
        ],
        "responses": {
          "200": {"description": "Encryption analytics"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/analytics/ipVersions": {
      "get": {
        "operationId": "getAnalyticsIpVersions",
        "tags": ["Analytics"],
        "summary": "Get IP version analytics",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"$ref": "#/components/parameters/LimitParam"},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"}
        ],
        "responses": {
          "200": {"description": "IP version analytics"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/logs": {
      "get": {
        "operationId": "getLogs",
        "tags": ["Logs"],
        "summary": "Get DNS query logs",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/FromParam"},
          {"$ref": "#/components/parameters/ToParam"},
          {"name": "sort", "in": "query", "schema": {"type": "string", "enum": ["asc", "desc"], "default": "desc"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "minimum": 10, "maximum": 1000, "default": 100}},
          {"$ref": "#/components/parameters/CursorParam"},
          {"$ref": "#/components/parameters/DeviceParam"},
          {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["default", "error", "blocked", "allowed"]}},
          {"name": "search", "in": "query", "schema": {"type": "string"}},
          {"name": "raw", "in": "query", "schema": {"type": "boolean", "default": false}}
        ],
        "responses": {
          "200": {"description": "DNS query logs", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/LogsResponse"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "clearLogs",
        "tags": ["Logs"],
        "summary": "Clear all logs for a profile",
        "parameters": [{"$ref": "#/components/parameters/ProfileIdParam"}],
        "responses": {
          "200": {"description": "Logs cleared"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/logs/download": {
      "get": {
        "operationId": "downloadLogs",
        "tags": ["Logs"],
        "summary": "Download logs as a file",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"name": "redirect", "in": "query", "schema": {"type": "integer", "enum": [0, 1], "default": 1}}
        ],
        "responses": {
          "200": {"description": "Download URL or redirect"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/profiles/{profileId}/logs/stream": {
      "get": {
        "operationId": "streamLogs",
        "tags": ["Logs"],
        "summary": "Stream logs in real-time via SSE",
        "parameters": [
          {"$ref": "#/components/parameters/ProfileIdParam"},
          {"$ref": "#/components/parameters/DeviceParam"},
          {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["default", "error", "blocked", "allowed"]}},
          {"name": "search", "in": "query", "schema": {"type": "string"}},
          {"name": "raw", "in": "query", "schema": {"type": "boolean", "default": false}},
          {"name": "id", "in": "query", "description": "Resume from this event ID", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Server-sent event stream", "content": {"text/event-stream": {"schema": {"type": "string"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "X-Api-Key",
        "in": "header"
      }
    },
    "parameters": {
      "ProfileIdParam": {
        "name": "profileId",
        "in": "path",
        "required": true,
        "schema": {"type": "string"}
      },
      "LimitParam": {
        "name": "limit",
        "in": "query",
        "schema": {"type": "integer", "minimum": 1, "maximum": 500, "default": 10}
      },
      "CursorParam": {
        "name": "cursor",
        "in": "query",
        "schema": {"type": "string"}
      },
      "FromParam": {
        "name": "from",
        "in": "query",
        "description": "Filter from date (ISO 8601, unix timestamp, or relative like -6h)",
        "schema": {"type": "string"}
      },
      "ToParam": {
        "name": "to",
        "in": "query",
        "description": "Filter to date (exclusive)",
        "schema": {"type": "string"}
      },
      "DeviceParam": {
        "name": "device",
        "in": "query",
        "description": "Filter by device ID. Use __UNIDENTIFIED__ for unidentified devices.",
        "schema": {"type": "string"}
      }
    },
    "schemas": {
      "ProfileListResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/Profile"}},
          "meta": {"$ref": "#/components/schemas/PaginationMeta"}
        }
      },
      "ProfileCreateResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {"id": {"type": "string"}}
          }
        }
      },
      "ProfileResponse": {
        "type": "object",
        "properties": {
          "data": {"$ref": "#/components/schemas/Profile"}
        }
      },
      "Profile": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "security": {"$ref": "#/components/schemas/SecuritySettings"},
          "privacy": {"$ref": "#/components/schemas/PrivacySettings"},
          "parentalControl": {"$ref": "#/components/schemas/ParentalControlSettings"},
          "denylist": {"type": "array", "items": {"$ref": "#/components/schemas/DenylistEntry"}},
          "allowlist": {"type": "array", "items": {"$ref": "#/components/schemas/AllowlistEntry"}},
          "settings": {"$ref": "#/components/schemas/ProfileSettings"}
        }
      },
      "ProfileInput": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "security": {"$ref": "#/components/schemas/SecuritySettings"},
          "privacy": {"$ref": "#/components/schemas/PrivacySettings"},
          "parentalControl": {"$ref": "#/components/schemas/ParentalControlSettings"},
          "denylist": {"type": "array", "items": {"$ref": "#/components/schemas/DenylistEntry"}},
          "allowlist": {"type": "array", "items": {"$ref": "#/components/schemas/AllowlistEntry"}},
          "settings": {"$ref": "#/components/schemas/ProfileSettings"}
        }
      },
      "SecuritySettings": {
        "type": "object",
        "properties": {
          "threatIntelligenceFeeds": {"type": "boolean"},
          "aiThreatDetection": {"type": "boolean"},
          "googleSafeBrowsing": {"type": "boolean"},
          "cryptojacking": {"type": "boolean"},
          "dnsRebinding": {"type": "boolean"},
          "idnHomographs": {"type": "boolean"},
          "typosquatting": {"type": "boolean"},
          "dga": {"type": "boolean"},
          "nrd": {"type": "boolean"},
          "ddns": {"type": "boolean"},
          "parking": {"type": "boolean"},
          "csam": {"type": "boolean"},
          "tlds": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}}}}
        }
      },
      "PrivacySettings": {
        "type": "object",
        "properties": {
          "blocklists": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}}}},
          "natives": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}}}},
          "disguisedTrackers": {"type": "boolean"},
          "allowAffiliate": {"type": "boolean"}
        }
      },
      "ParentalControlSettings": {
        "type": "object",
        "properties": {
          "services": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}, "active": {"type": "boolean"}}}},
          "categories": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}, "active": {"type": "boolean"}}}},
          "safeSearch": {"type": "boolean"},
          "youtubeRestrictedMode": {"type": "boolean"},
          "blockBypass": {"type": "boolean"}
        }
      },
      "DenylistEntry": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "description": "Domain name"},
          "active": {"type": "boolean"}
        }
      },
      "AllowlistEntry": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "description": "Domain name"},
          "active": {"type": "boolean"}
        }
      },
      "DenylistResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/DenylistEntry"}}
        }
      },
      "AllowlistResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/AllowlistEntry"}}
        }
      },
      "ProfileSettings": {
        "type": "object",
        "properties": {
          "logs": {
            "type": "object",
            "properties": {
              "enabled": {"type": "boolean"},
              "drop": {"type": "object", "properties": {"ip": {"type": "boolean"}, "domain": {"type": "boolean"}}},
              "retention": {"type": "integer"},
              "location": {"type": "string"}
            }
          },
          "blockPage": {"type": "object", "properties": {"enabled": {"type": "boolean"}}},
          "performance": {"type": "object", "properties": {"ecs": {"type": "boolean"}, "cacheBoost": {"type": "boolean"}, "cnameFlattening": {"type": "boolean"}}},
          "web3": {"type": "boolean"}
        }
      },
      "AnalyticsStatusResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": {"type": "string"},
                "queries": {"type": "integer"}
              }
            }
          },
          "meta": {"$ref": "#/components/schemas/PaginationMeta"}
        }
      },
      "AnalyticsDomainsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "domain": {"type": "string"},
                "root": {"type": "string"},
                "queries": {"type": "integer"}
              }
            }
          },
          "meta": {"$ref": "#/components/schemas/PaginationMeta"}
        }
      },
      "LogsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/LogEntry"}
          },
          "meta": {"$ref": "#/components/schemas/PaginationMeta"}
        }
      },
      "LogEntry": {
        "type": "object",
        "properties": {
          "timestamp": {"type": "string", "format": "date-time"},
          "domain": {"type": "string"},
          "root": {"type": "string"},
          "tracker": {"type": "string"},
          "encrypted": {"type": "boolean"},
          "protocol": {"type": "string"},
          "clientIp": {"type": "string"},
          "client": {"type": "string"},
          "device": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "name": {"type": "string"},
              "model": {"type": "string"}
            }
          },
          "status": {"type": "string", "enum": ["default", "blocked", "allowed", "error"]},
          "reasons": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {"type": "string"},
                "name": {"type": "string"}
              }
            }
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "pagination": {
            "type": "object",
            "properties": {
              "cursor": {"type": "string", "nullable": true}
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {"type": "string"},
                "detail": {"type": "string"},
                "source": {"type": "object"}
              }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/ErrorResponse"}
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key"
      }
    }
  }
}
