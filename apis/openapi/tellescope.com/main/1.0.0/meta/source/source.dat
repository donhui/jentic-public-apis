        "responses": {
          "200": {
            "description": "AI decision generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AIDecisionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/ai-conversation": {
      "post": {
        "operationId": "createAIConversation",
        "summary": "Create an AI conversation",
        "tags": ["AIConversations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAIConversationRequest"
              }
            }
