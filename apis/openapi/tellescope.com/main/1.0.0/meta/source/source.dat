{
  "openapi": "3.0.3",
  "info": {
    "title": "Tellescope Healthcare API",
    "description": "Tellescope is a healthcare platform API providing tools for agent records, AI conversations, allergy codes, and analytics.",
    "version": "1.0.0",
    "contact": {
      "name": "Tellescope",
      "url": "https://docs.tellescope.com/api-documentation"
    }
  },
  "externalDocs": {
    "description": "Tellescope API Documentation",
    "url": "https://docs.tellescope.com/api-documentation"
  },
  "servers": [
    {
      "url": "https://api.tellescope.com/v1",
      "description": "Production"
    }
  ],
  "security": [
    { "apiKeyQuery": [] },
    { "apiKeyHeader": [] }
  ],
  "tags": [
    { "name": "AgentRecords", "description": "Manage agent records and support tickets" },
    { "name": "AIConversations", "description": "AI-powered conversations and decision generation" },
    { "name": "AllergyCodes", "description": "Manage allergy code references" },
    { "name": "Analytics", "description": "Analytics frames, queries, and custom reports" }
  ],
  "paths": {
    "/agent-records/submit-ticket": {
      "post": {
        "operationId": "submitAgentTicket",
        "summary": "Submit a support ticket",
        "tags": ["AgentRecords"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitTicketRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentRecord"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/agent-record": {
      "post": {
        "operationId": "createAgentRecord",
        "summary": "Create an agent record",
        "tags": ["AgentRecords"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAgentRecordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent record created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentRecord"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/agent-records": {
      "post": {
        "operationId": "createAgentRecords",
        "summary": "Create multiple agent records",
        "tags": ["AgentRecords"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["create"],
                "properties": {
                  "create": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/CreateAgentRecordRequest"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent records created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentRecord"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "get": {
        "operationId": "listAgentRecords",
        "summary": "List agent records",
        "tags": ["AgentRecords"],
        "parameters": [
          { "$ref": "#/components/parameters/lastId" },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/sort" },
          { "$ref": "#/components/parameters/search" },
          { "$ref": "#/components/parameters/filter" }
        ],
        "responses": {
          "200": {
            "description": "List of agent records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentRecord"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/agent-record/{id}": {
      "get": {
        "operationId": "getAgentRecord",
        "summary": "Get an agent record by ID",
        "tags": ["AgentRecords"],
        "parameters": [
          { "$ref": "#/components/parameters/resourceId" }
        ],
        "responses": {
          "200": {
            "description": "Agent record details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentRecord"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "operationId": "updateAgentRecord",
        "summary": "Update an agent record",
        "tags": ["AgentRecords"],
        "parameters": [
          { "$ref": "#/components/parameters/resourceId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["updates"],
                "properties": {
                  "updates": {
                    "$ref": "#/components/schemas/AgentRecordUpdates"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent record updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentRecord"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "deleteAgentRecord",
        "summary": "Delete an agent record",
        "tags": ["AgentRecords"],
        "parameters": [
          { "$ref": "#/components/parameters/resourceId" }
        ],
        "responses": {
          "200": {
            "description": "Agent record deleted"
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/ai-conversations/send-message": {
      "post": {
        "operationId": "sendAIMessage",
        "summary": "Send a message to an AI conversation",
        "tags": ["AIConversations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendAIMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AIMessageResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/ai-conversations/generate-ai-decision": {
      "post": {
        "operationId": "generateAIDecision",
