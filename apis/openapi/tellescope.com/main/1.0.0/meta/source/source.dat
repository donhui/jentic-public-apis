              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/ai-conversations": {
      "get": {
        "operationId": "listAIConversations",
        "summary": "List AI conversations",
        "tags": ["AIConversations"],
        "parameters": [
          { "$ref": "#/components/parameters/lastId" },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/sort" },
          { "$ref": "#/components/parameters/search" },
          { "$ref": "#/components/parameters/filter" }
        ],
        "responses": {
          "200": {
            "description": "List of AI conversations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AIConversation"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/ai-conversation/{id}": {
      "get": {
        "operationId": "getAIConversation",
        "summary": "Get an AI conversation by ID",
        "tags": ["AIConversations"],
        "parameters": [
          { "$ref": "#/components/parameters/resourceId" }
        ],
        "responses": {
          "200": {
            "description": "AI conversation details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AIConversation"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "operationId": "updateAIConversation",
        "summary": "Update an AI conversation",
        "tags": ["AIConversations"],
        "parameters": [
          { "$ref": "#/components/parameters/resourceId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["updates"],
                "properties": {
                  "updates": {
                    "$ref": "#/components/schemas/AIConversationUpdates"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI conversation updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AIConversation"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/allergy-code": {
      "post": {
        "operationId": "createAllergyCode",
        "summary": "Create an allergy code",
        "tags": ["AllergyCodes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAllergyCodeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Allergy code created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllergyCode"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/allergy-codes": {
      "post": {
        "operationId": "createAllergyCodes",
        "summary": "Create multiple allergy codes",
        "tags": ["AllergyCodes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["create"],
                "properties": {
                  "create": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/CreateAllergyCodeRequest"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Allergy codes created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AllergyCode"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "get": {
        "operationId": "listAllergyCodes",
        "summary": "List allergy codes",
        "tags": ["AllergyCodes"],
        "parameters": [
          { "$ref": "#/components/parameters/lastId" },
          { "$ref": "#/components/parameters/limit" },
          { "$ref": "#/components/parameters/sort" },
          { "$ref": "#/components/parameters/search" },
          { "$ref": "#/components/parameters/filter" }
        ],
        "responses": {
          "200": {
            "description": "List of allergy codes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AllergyCode"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/allergy-code/{id}": {
      "get": {
        "operationId": "getAllergyCode",
        "summary": "Get an allergy code by ID",
        "tags": ["AllergyCodes"],
        "parameters": [
          { "$ref": "#/components/parameters/resourceId" }
        ],
        "responses": {
          "200": {
            "description": "Allergy code details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllergyCode"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "operationId": "updateAllergyCode",
        "summary": "Update an allergy code",
        "tags": ["AllergyCodes"],
        "parameters": [
          { "$ref": "#/components/parameters/resourceId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["updates"],
                "properties": {
                  "updates": {
                    "$ref": "#/components/schemas/AllergyCodeUpdates"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Allergy code updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllergyCode"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
