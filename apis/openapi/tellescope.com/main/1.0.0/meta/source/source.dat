        ],
        "responses": {
          "200": {
            "description": "Allergy code deleted"
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/analytics-frames/update-indexes": {
      "patch": {
        "operationId": "updateAnalyticsFrameIndexes",
        "summary": "Update sort indexes for analytics frames",
        "tags": ["Analytics"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["updates"],
                "properties": {
                  "updates": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["id", "index"],
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "Analytics frame ID"
                        },
                        "index": {
                          "type": "integer",
                          "description": "New sort index"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Indexes updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AnalyticsFrame"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/result-for-analytics-query": {
      "get": {
        "operationId": "getAnalyticsQueryResult",
        "summary": "Get result for an analytics query",
        "tags": ["Analytics"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "JSON-encoded analytics query structure",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics query result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsQueryResult"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/analytics/custom-report": {
      "get": {
        "operationId": "getCustomReport",
        "summary": "Get a custom analytics report",
        "tags": ["Analytics"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Report key identifier",
            "schema": {
              "type": "string"
            }
          },
          { "$ref": "#/components/parameters/lastId" },
          { "$ref": "#/components/parameters/limit" }
        ],
        "responses": {
          "200": {
            "description": "Custom report data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomReportResult"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/analytics/custom-aggregation": {
      "post": {
        "operationId": "createCustomAggregation",
        "summary": "Run a custom aggregation query",
        "tags": ["Analytics"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomAggregationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Aggregation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomAggregationResult"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/analytics-frame": {
      "post": {
        "operationId": "createAnalyticsFrame",
        "summary": "Create an analytics frame",
        "tags": ["Analytics"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAnalyticsFrameRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analytics frame created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsFrame"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "apiKey",
        "description": "API key passed as a query parameter"
      },
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key passed in Authorization header as 'API_KEY {key}'"
      }
    },
    "parameters": {
      "resourceId": {
        "name": "id",
        "in": "path",
        "required": true,
        "description": "Resource ID",
        "schema": {
          "type": "string"
        }
      },
      "lastId": {
        "name": "lastId",
        "in": "query",
        "required": false,
        "description": "Cursor for pagination; ID of the last item from the previous page",
        "schema": {
          "type": "string"
        }
      },
      "limit": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "Maximum number of results to return (default 100)",
        "schema": {
          "type": "integer",
          "default": 100,
          "minimum": 1,
          "maximum": 100
        }
      },
      "sort": {
        "name": "sort",
        "in": "query",
        "required": false,
        "description": "Sort field and direction (e.g. 'createdAt' or '-createdAt')",
        "schema": {
          "type": "string"
        }
      },
      "search": {
        "name": "search",
        "in": "query",
        "required": false,
        "description": "Free-text search query",
        "schema": {
          "type": "string"
        }
      },
      "filter": {
        "name": "filter",
        "in": "query",
        "required": false,
        "description": "JSON-encoded filter object",
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid or missing parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - missing or invalid API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - insufficient permissions",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "integer",
            "description": "HTTP status code"
          }
        },
        "required": ["message"]
      },
      "AgentRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique record identifier"
          },
          "type": {
            "type": "string",
            "description": "Record type"
          },
          "title": {
            "type": "string",
            "description": "Record title"
          },
          "description": {
            "type": "string",
            "description": "Record description"
          },
          "url": {
            "type": "string",
            "description": "Associated URL"
          },
          "content": {
            "type": "string",
            "description": "Record content"
          },
          "source": {
            "type": "string",
            "description": "Record source"
          },
          "externalId": {
            "type": "string",
            "description": "External system identifier"
          },
          "priority": {
            "type": "string",
            "description": "Priority level"
          },
          "message": {
            "type": "string",
            "description": "Associated message"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        },
        "required": ["id"]
      },
      "SubmitTicketRequest": {
        "type": "object",
        "required": ["priority", "message"],
        "properties": {
          "priority": {
            "type": "string",
            "description": "Ticket priority level",
            "enum": ["low", "medium", "high", "urgent"]
          },
          "message": {
            "type": "string",
            "description": "Ticket message content"
          }
        }
      },
      "CreateAgentRecordRequest": {
        "type": "object",
        "required": ["type", "title"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Record type"
          },
          "title": {
            "type": "string",
            "description": "Record title"
          },
          "description": {
            "type": "string",
            "description": "Record description"
          },
          "url": {
            "type": "string",
            "description": "Associated URL"
          },
          "content": {
            "type": "string",
            "description": "Record content"
          },
          "source": {
            "type": "string",
            "description": "Record source"
          },
          "externalId": {
            "type": "string",
            "description": "External system identifier"
          }
        }
      },
      "AgentRecordUpdates": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "url": { "type": "string" },
          "content": { "type": "string" },
          "source": { "type": "string" },
          "externalId": { "type": "string" }
        }
      },
      "AIConversation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique conversation identifier"
          },
          "type": {
            "type": "string",
            "description": "Conversation type"
          },
          "modelName": {
            "type": "string",
            "description": "AI model name"
          },
          "orchestrationId": {
            "type": "string",
            "description": "Orchestration identifier"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AIMessage"
            },
            "description": "Conversation messages"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        },
        "required": ["id"]
      },
      "AIMessage": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": ["user", "assistant", "system"],
            "description": "Message role"
          },
          "content": {
            "type": "string",
            "description": "Message content"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Message timestamp"
          }
        },
        "required": ["role", "content"]
      },
      "SendAIMessageRequest": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Single message to send"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AIMessage"
            },
            "description": "Array of messages to send"
          },
          "type": {
            "type": "string",
            "description": "Conversation type"
          },
          "maxTokens": {
            "type": "integer",
            "description": "Maximum tokens in the AI response"
          },
          "conversationId": {
            "type": "string",
            "description": "Existing conversation ID to continue"
          },
          "prompt": {
            "type": "string",
            "description": "System prompt for the AI"
          }
        }
      },
      "AIMessageResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "AI response message"
          },
          "conversationId": {
            "type": "string",
            "description": "Conversation ID"
          },
          "tokensUsed": {
            "type": "integer",
            "description": "Number of tokens consumed"
          }
        }
      },
      "GenerateAIDecisionRequest": {
        "type": "object",
        "required": ["enduserId", "automationStepId", "outcomes"],
        "properties": {
          "enduserId": {
            "type": "string",
            "description": "Enduser ID for the decision"
          },
          "automationStepId": {
            "type": "string",
            "description": "Automation step ID"
          },
          "outcomes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Possible decision outcomes"
          },
          "prompt": {
            "type": "string",
            "description": "Custom prompt for the decision"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Data sources for the decision"
          }
        }
      },
      "AIDecisionResponse": {
        "type": "object",
        "properties": {
          "outcome": {
            "type": "string",
            "description": "Selected decision outcome"
          },
          "reasoning": {
            "type": "string",
            "description": "Reasoning for the decision"
          },
          "confidence": {
            "type": "number",
            "format": "float",
            "description": "Confidence score (0-1)"
          }
        }
      },
      "CreateAIConversationRequest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Conversation type"
          },
          "modelName": {
            "type": "string",
            "description": "AI model name"
          },
          "orchestrationId": {
            "type": "string",
            "description": "Orchestration identifier"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AIMessage"
            },
            "description": "Initial messages"
          }
        }
      },
      "AIConversationUpdates": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "modelName": { "type": "string" },
          "orchestrationId": { "type": "string" }
        }
      },
      "AllergyCode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier"
          },
          "code": {
            "type": "string",
            "description": "Allergy code (e.g. SNOMED or RxNorm code)"
          },
          "display": {
            "type": "string",
            "description": "Human-readable display name"
          },
          "system": {
            "type": "string",
            "description": "Code system URI (e.g. http://snomed.info/sct)"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        },
        "required": ["id", "code", "display", "system"]
      },
      "CreateAllergyCodeRequest": {
        "type": "object",
        "required": ["code", "display", "system"],
        "properties": {
          "code": {
            "type": "string",
            "description": "Allergy code"
          },
          "display": {
            "type": "string",
            "description": "Human-readable display name"
          },
          "system": {
            "type": "string",
            "description": "Code system URI"
          }
        }
      },
      "AllergyCodeUpdates": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "display": { "type": "string" },
          "system": { "type": "string" }
        }
      },
      "AnalyticsFrame": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique frame identifier"
          },
          "query": {
            "type": "object",
            "description": "Analytics query definition"
          },
          "title": {
            "type": "string",
            "description": "Frame title"
          },
          "displayType": {
            "type": "string",
            "description": "Visualization display type",
            "enum": ["bar", "line", "pie", "table", "number"]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Categorization tags"
          },
          "index": {
            "type": "integer",
            "description": "Sort index"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        },
        "required": ["id", "title"]
      },
      "CreateAnalyticsFrameRequest": {
        "type": "object",
        "required": ["query", "title", "displayType"],
        "properties": {
          "query": {
            "type": "object",
            "description": "Analytics query definition"
          },
          "title": {
            "type": "string",
            "description": "Frame title"
          },
          "displayType": {
            "type": "string",
            "description": "Visualization display type",
            "enum": ["bar", "line", "pie", "table", "number"]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Categorization tags"
          }
        }
      },
      "AnalyticsQueryResult": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Result data rows"
          },
          "count": {
            "type": "integer",
            "description": "Total matching count"
          }
        }
      },
      "CustomReportResult": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Report data"
          },
          "lastId": {
            "type": "string",
            "description": "Last ID for cursor pagination"
          }
        }
      },
      "CustomAggregationRequest": {
        "type": "object",
        "required": ["modelName", "aggregation"],
        "properties": {
          "modelName": {
            "type": "string",
            "description": "Data model to aggregate over"
          },
          "aggregation": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Aggregation pipeline stages"
          }
        }
      },
      "CustomAggregationResult": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Aggregation results"
          }
        }
      }
    }
  }
}