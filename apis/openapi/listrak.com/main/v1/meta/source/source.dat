              "subscribeDate": {"type": "string", "format": "date-time"},
              "resubscribeDate": {"type": "string", "format": "date-time", "nullable": true},
              "subscribeMethod": {"type": "string"},
              "unsubscribeDate": {"type": "string", "format": "date-time", "nullable": true},
              "unsubscribeMethod": {"type": "string", "nullable": true},
              "externalContactID": {"type": "string"},
