          {"name": "activityType", "in": "query", "schema": {"type": "string"}},
          {"name": "cursor", "in": "query", "schema": {"type": "string"}},
          {"name": "count", "in": "query", "schema": {"type": "string"}},
          {"name": "startDate", "in": "query", "schema": {"type": "string"}},
