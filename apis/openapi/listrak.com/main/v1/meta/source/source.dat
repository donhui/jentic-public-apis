{
  "openapi": "3.0.3",
  "info": {
    "title": "Listrak Email REST API",
    "description": "Listrak Email REST API enables developers to integrate with Listrak's email marketing application. It provides automation for managing lists, contacts, campaigns, conversations, events, messages, segmentation, and transactional messages.",
    "version": "v1",
    "x-jentic-source-url": "https://api.listrak.com/email/swagger/docs/v1"
  },
  "servers": [
    {
      "url": "https://api.listrak.com/email",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "oauth2": ["List", "Message", "Contact", "Event", "Report", "Segmentation"]
    }
  ],
  "tags": [
    {"name": "Campaign", "description": "Campaign management"},
    {"name": "Contact", "description": "Contact management"},
    {"name": "ContactSegmentationField", "description": "Contact profile field management"},
    {"name": "Conversation", "description": "Conversation management"},
    {"name": "ConversationMessage", "description": "Conversation message management"},
    {"name": "ConversationMessageActivity", "description": "Conversation message activity"},
    {"name": "ConversationMessageLink", "description": "Conversation message links"},
    {"name": "ConversationMessageLinkClicker", "description": "Conversation message link clickers"},
    {"name": "ConversationMessageSummary", "description": "Conversation message summaries"},
    {"name": "ConversationSummary", "description": "Conversation summaries"},
    {"name": "Event", "description": "Event management"},
    {"name": "List", "description": "List management"},
    {"name": "Message", "description": "Message management"},
    {"name": "MessageActivity", "description": "Message activity"},
    {"name": "MessageLink", "description": "Message links"},
    {"name": "MessageLinkClicker", "description": "Message link clickers"},
    {"name": "MessageSummary", "description": "Message summaries"},
    {"name": "SegmentationFieldGroup", "description": "Profile field group management"},
    {"name": "SegmentationField", "description": "Profile field management"},
    {"name": "TransactionalMessage", "description": "Transactional message management"}
  ],
  "paths": {
    "/v1/List/{listId}/Campaign": {
      "get": {
        "tags": ["Campaign"],
        "summary": "Get all Campaigns",
        "description": "Returns the campaigns associated with the specified list.",
        "operationId": "Campaign_GetCampaignCollection",
        "parameters": [
          {"$ref": "#/components/parameters/ListId"}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignCollection"
                }
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      },
      "post": {
        "tags": ["Campaign"],
        "summary": "Create a Campaign",
        "description": "Creates a new campaign on the specified list.",
        "operationId": "Campaign_PostCampaignResource",
        "parameters": [
          {"$ref": "#/components/parameters/ListId"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/Campaign"}
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ResourceCreated"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
    "/v1/List/{listId}/Campaign/{campaignId}": {
      "get": {
        "tags": ["Campaign"],
        "summary": "Get a Campaign",
        "description": "Returns the specified campaign on the specified list.",
        "operationId": "Campaign_GetCampaignResource",
        "parameters": [
          {"$ref": "#/components/parameters/ListId"},
          {"$ref": "#/components/parameters/CampaignId"}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/CampaignResource"}
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      },
      "put": {
        "tags": ["Campaign"],
        "summary": "Update a Campaign",
        "description": "Updates an existing campaign.",
        "operationId": "Campaign_PutCampaignResource",
        "parameters": [
          {"$ref": "#/components/parameters/ListId"},
          {"$ref": "#/components/parameters/CampaignId"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/Campaign"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ResourceUpdated"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      },
      "delete": {
        "tags": ["Campaign"],
        "summary": "Delete a Campaign",
        "description": "Deletes the specified campaign.",
        "operationId": "Campaign_DeleteCampaignResource",
        "parameters": [
          {"$ref": "#/components/parameters/ListId"},
          {"$ref": "#/components/parameters/CampaignId"}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ResourceDeleted"}
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
    "/v1/List/{listId}/Contact": {
      "get": {
        "tags": ["Contact"],
        "summary": "Get all Contacts",
        "description": "Returns the collection of contacts associated with the specified list.",
        "operationId": "Contact_GetContactCollection",
        "parameters": [
          {"$ref": "#/components/parameters/ListId"},
          {"name": "subscriptionState", "in": "query", "description": "Allowed values: Subscribed, Unsubscribed. Default: Subscribed.", "schema": {"type": "string"}},
          {"name": "externalContactId", "in": "query", "description": "Filter by external contact ID.", "schema": {"type": "string"}},
          {"name": "segmentationFieldIds", "in": "query", "description": "Comma-separated profile field IDs (max 30).", "schema": {"type": "string"}},
          {"name": "cursor", "in": "query", "description": "Page cursor. Default: Start.", "schema": {"type": "string"}},
          {"name": "count", "in": "query", "description": "Items per page. Default: 1000, max: 5000.", "schema": {"type": "string"}},
          {"name": "startDate", "in": "query", "description": "Inclusive start date filter.", "schema": {"type": "string"}},
          {"name": "endDate", "in": "query", "description": "End date filter.", "schema": {"type": "string"}},
          {"name": "useOriginalSubscribeDate", "in": "query", "description": "Use original subscribe date. Default: true.", "schema": {"type": "boolean"}}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContactCollectionPaged"}
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      },
      "post": {
        "tags": ["Contact"],
        "summary": "Create or update a Contact",
        "description": "Creates or updates a contact on the specified list.",
        "operationId": "Contact_PostContactResource",
        "parameters": [
          {"$ref": "#/components/parameters/ListId"},
          {"name": "eventIds", "in": "query", "description": "Comma-separated event IDs to raise.", "schema": {"type": "string"}},
          {"name": "overrideUnsubscribe", "in": "query", "description": "Force unsubscribed to subscribed. Default: false.", "schema": {"type": "boolean"}},
          {"name": "subscribedByContact", "in": "query", "description": "Subscribe initiated by contact. Default: false.", "schema": {"type": "boolean"}},
          {"name": "sendDoubleOptIn", "in": "query", "description": "Send double opt-in email. Default: false.", "schema": {"type": "boolean"}},
          {"name": "updateType", "in": "query", "description": "Update type: Update, Append, Overwrite. Default: Update.", "schema": {"type": "string"}},
          {"name": "newEmailAddress", "in": "query", "description": "New email address for existing contact.", "schema": {"type": "string"}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/Contact"}
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ResourceCreated"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
    "/v1/List/{listId}/Contact/{contactIdentifier}": {
      "get": {
        "tags": ["Contact"],
        "summary": "Get a Contact",
        "description": "Returns a contact by email address or Listrak email key.",
        "operationId": "Contact_GetContactResourceByIdentifier",
        "parameters": [
          {"$ref": "#/components/parameters/ListId"},
          {"name": "contactIdentifier", "in": "path", "required": true, "description": "Email address or Listrak email key.", "schema": {"type": "string"}},
          {"name": "segmentationFieldIds", "in": "query", "description": "Comma-separated profile field IDs (max 30).", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ContactResource"}
              }
            }
          },
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
    "/v1/List/{listId}/Contact/SegmentationField": {
      "post": {
        "tags": ["ContactSegmentationField"],
        "summary": "Start a list import to update contact profile fields",
        "description": "Beta route. Starts list imports to update specified contact profile fields.",
        "operationId": "ContactSegmentationField_PostContactSegmentationFieldValuesResource",
        "parameters": [
          {"$ref": "#/components/parameters/ListId"}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {"$ref": "#/components/schemas/ContactSegmentationFieldValues"}
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ResourceCreated"}
              }
            }
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"},
          "404": {"$ref": "#/components/responses/NotFound"}
        }
      }
    },
