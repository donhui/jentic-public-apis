            "schema": {
              "type": "string",
              "enum": [
                "put",
                "delete"
              ]
            }
          },
          {
            "name": "import",
            "in": "query",
            "description": "Imports entries into a list. Requires the entry to be a list and the request body to be application/zip",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "moveEntry",
            "in": "query",
            "description": "Moves moveEntry to the list-entry that is posted to. To be used with fromList and removeAll.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromList",
            "in": "query",
            "description": "Removes the given entry from fromList. To be used with fromList and removeAll.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "removeAll",
            "in": "query",
            "description": "Indicates that the moved entry is to be removed from all other lists. To be used with fromList and removeAll.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful"
          },
          "404": {
            "description": "Entry or its metadata not found"
          }
        }
      },
