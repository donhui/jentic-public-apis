          },
          "404": {
            "description": "Context not found"
          }
        }
      },
      "delete": {
        "summary": "Resets the quota to system default",
        "operationId": "quotaDelete",
        "tags": [
          "quota"
        ],
        "parameters": [
          {
            "name": "context-id",
            "in": "path",
            "description": "Context ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful"
          },
          "403": {
            "description": "Insufficient rights for resetting quota"
          },
          "404": {
            "description": "Quotas not active for instance"
          }
        }
      }
    },
    "/{context-id}/lookup": {
      "get": {
        "summary": "Performs a lookup based on the resource URI and returns metadata about the resource.",
        "operationId": "lookup",
        "tags": [
          "context"
        ],
        "parameters": [
          {
            "name": "context-id",
            "in": "path",
            "description": "Context ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uri",
            "in": "query",
            "description": "",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scope",
            "in": "query",
            "description": "",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "local",
                "external"
              ],
              "default": "all"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful"
          },
          "400": {
            "description": "Missing request parameters"
          },
          "404": {
            "description": "No metadata found for resource"
          }
        }
      }
    },
    "/{context-id}/execute": {
      "post": {
        "summary": "Executes pipelines",
        "operationId": "execute",
        "tags": [
          "context"
        ],
        "parameters": [
          {
            "name": "context-id",
            "in": "path",
            "description": "Context ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/execution"
              }
            }
          },
          "required": true,
          "description": "Information about the pipeline to be executed"
        },
        "responses": {
          "201": {
            "description": "Entries created during pipeline execution"
          },
          "400": {
            "description": "Pipeline and source have to be located in the same context"
          },
          "409": {
            "description": "The pipeline has wrong state"
          },
          "415": {
            "description": "Request body is in wrong format"
          },
          "422": {
            "description": "Unable to process the request"
          },
          "500": {
            "description": "Internal error while processing pipeline"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "user": {
        "type": "object",
        "description": "Administrative information about a user",
        "required": [
          "user",
          "id",
          "uri"
        ],
        "properties": {
          "user": {
            "type": "string",
            "description": "Username (alias)"
          },
          "id": {
            "type": "string",
            "description": "Internal ID"
          },
          "uri": {
            "type": "string",
            "description": "URI"
          },
          "homecontext": {
            "type": "string",
            "description": "Home context"
          },
          "language": {
            "type": "string",
            "description": "Preferred language"
          },
          "authTokenExpires": {
            "type": "string",
            "description": "Date and time when authentication token expires (read-only)"
          }
        }
      },
      "quotaRead": {
        "type": "object",
        "description": "Quota information",
        "required": [
          "quota",
          "fillLevel",
          "hasDefaultQuota"
        ],
        "properties": {
          "quota": {
            "type": "integer"
          },
          "fillLevel": {
            "type": "integer"
          },
          "hasDefaultQuota": {
            "type": "boolean"
          }
        }
      },
      "quotaWrite": {
        "type": "object",
        "description": "Quota information",
        "required": [
          "quota"
        ],
        "properties": {
          "quota": {
            "type": "integer"
          }
        }
      },
      "rdf": {
        "type": "object",
        "description": "RDF graph"
      },
      "binary": {
        "type": "object",
        "description": "Binary"
      },
      "json": {
        "type": "object",
        "description": "Binary"
      },
      "execution": {
        "type": "object",
        "description": "Execution information",
        "required": [
          "pipeline",
          "source"
        ],
        "properties": {
          "pipeline": {
            "type": "string",
            "description": "Pipeline entry URI"
          },
          "source": {
            "type": "string",
            "description": "Data source entry URI"
          }
        }
      },
      "name": {
        "type": "object",
        "description": "Name (alias)",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "contextNewEntry": {
        "type": "object",
        "description": "Entry created response",
        "required": [
          "entryId"
        ],
        "properties": {
          "entryId": {
            "type": "string",
            "description": "ID of the newly created entry"
          }
        }
      },
      "harvester": {
        "type": "object",
        "description": "Harvester",
        "required": [
          "timeRegularExpression",
          "target",
          "metadataType",
          "harvesterType"
        ],
        "properties": {
          "timeRegularExpression": {
            "type": "string",
            "description": "Time expression (cron)"
          },
          "target": {
            "type": "string",
            "description": "Harvesting target URL"
          },
          "metadataType": {
            "type": "string",
            "description": "Metadata-format to be harvested"
          },
          "harvesterType": {
            "type": "string",
            "description": "Harvester type"
          },
          "from": {
            "type": "string",
            "description": "Time/date expression to harvest all resources after a specific date"
          },
          "until": {
            "type": "string",
            "description": "Time/date expression to harvest all resources before a specific date"
          },
          "set": {
            "type": "string",
            "description": "Which OAI-set to harvest"
          }
        }
      },
      "entry": {
        "type": "object",
        "description": "Entry information, only to be used for application/json bodies",
        "required": [
          "entryId",
          "info"
        ],
        "properties": {
          "entryId": {
            "type": "string",
            "description": "Entry ID"
          },
          "quota": {
            "type": "string",
            "description": "Quota object if the entry is a context"
          },
          "name": {
            "type": "string",
            "description": "Name (alias) if the entry is a user, group or context"
          },
          "homecontext": {
            "type": "string",
            "description": "Home context if the entry is a user"
          },
          "language": {
            "type": "string",
            "description": "Preferred language if the entry is a user"
          },
          "info": {
            "type": "string",
            "description": "Entry information as RDF/JSON"
          },
          "cached-external-metadata": {
            "type": "string",
            "description": "Cached external metadata as RDF/JSON. Requires parameter \"includeAll\""
          },
          "metadata": {
            "type": "string",
            "description": "Metadata as RDF/JSON. Requires parameter \"includeAll\""
          },
          "relation": {
            "type": "string",
            "description": "Relations as RDF/JSON. Requires parameter \"includeAll\""
          },
          "rights": {
            "type": "string",
            "description": "ACL. Requires parameter \"includeAll\""
          },
          "resource": {
            "type": "string",
            "description": "Resource, only for certain entry types. Requires parameter \"includeAll\""
          }
        }
      }
    }
  },
  "externalDocs": {
    "description": "EntryStore official documentation site.",
    "url": "http://entrystore.org"
  }
}