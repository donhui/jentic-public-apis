{
  "openapi": "3.0.3",
  "info": {
    "title": "APITemplate.io API",
    "description": "APITemplate.io provides a REST API for generating PDFs and images from reusable templates. Supports synchronous and asynchronous generation, webhook callbacks, and template management. Templates can be designed via the web editor and populated with dynamic data via API calls.",
    "version": "1.0.0",
    "contact": {
      "name": "APITemplate.io Support",
      "url": "https://apitemplate.io"
    },
    "x-jentic-source-url": "https://docs.apitemplate.io/reference/api-reference.html"
  },
  "servers": [
    {
      "url": "https://rest.apitemplate.io/v1",
      "description": "APITemplate.io REST API v1 (US)"
    },
    {
      "url": "https://rest-eu.apitemplate.io/v1",
      "description": "APITemplate.io REST API v1 (EU)"
    },
    {
      "url": "https://rest-sg.apitemplate.io/v1",
      "description": "APITemplate.io REST API v1 (Singapore)"
    },
    {
      "url": "https://rest-au.apitemplate.io/v1",
      "description": "APITemplate.io REST API v1 (Australia)"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "PDF",
      "description": "PDF document generation"
    },
    {
      "name": "Image",
      "description": "Image generation (JPEG/PNG)"
    },
    {
      "name": "Templates",
      "description": "Template management"
    },
    {
      "name": "Objects",
      "description": "Generated object management"
    }
  ],
  "paths": {
    "/create": {
      "post": {
        "operationId": "createDocument",
        "summary": "Create a PDF or image from a template",
        "description": "Generates a PDF document or image from a specified template populated with the provided data. Supports synchronous generation (returns download URL) and asynchronous generation via webhook.",
        "tags": ["PDF", "Image"],
        "parameters": [
          {
            "name": "template_id",
            "in": "query",
            "required": true,
            "description": "The ID of the template to use for generation.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "export_type",
            "in": "query",
            "required": false,
            "description": "Output format: 'json' returns a JSON response with download URL, 'file' returns the file directly.",
            "schema": {
              "type": "string",
              "enum": ["json", "file"],
              "default": "json"
            }
          },
          {
            "name": "output_html",
            "in": "query",
            "required": false,
            "description": "Set to 1 to include an HTML version of the output.",
            "schema": {
              "type": "integer",
              "enum": [0, 1],
              "default": 0
            }
          },
          {
            "name": "filename",
            "in": "query",
            "required": false,
            "description": "Custom filename for the generated document. Defaults to a UUID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "webhook",
            "in": "query",
            "required": false,
            "description": "Set to 1 to enable asynchronous generation via webhook.",
            "schema": {
              "type": "integer",
              "enum": [0, 1],
              "default": 0
            }
          },
          {
            "name": "webhook_url",
            "in": "query",
            "required": false,
            "description": "URL-encoded callback URL for async webhook delivery. Required when webhook=1.",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Template data for PDF generation, or overrides array for image generation.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful synchronous generation response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateResponse"
                }
              }
            }
          },
          "202": {
            "description": "Accepted for asynchronous processing (webhook mode).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookAcceptedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters or template data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Template not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/list-templates": {
      "get": {
        "operationId": "listTemplates",
        "summary": "List all templates",
        "description": "Returns a list of all templates available in the account.",
        "tags": ["Templates"],
        "responses": {
          "200": {
            "description": "Successful response with list of templates.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListTemplatesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/list-objects": {
      "get": {
        "operationId": "listObjects",
        "summary": "List generated objects",
        "description": "Returns a paginated list of generated PDFs and images.",
        "tags": ["Objects"],
        "parameters": [
          {
            "name": "template_id",
            "in": "query",
            "required": false,
            "description": "Filter by template ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of objects to return (max 500).",
            "schema": {
              "type": "integer",
              "maximum": 500
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Offset for pagination.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of generated objects.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListObjectsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/delete-object": {
      "get": {
        "operationId": "deleteObject",
        "summary": "Delete a generated object",
        "description": "Deletes a previously generated PDF or image by its transaction reference.",
        "tags": ["Objects"],
        "parameters": [
          {
            "name": "transaction_ref",
            "in": "query",
            "required": true,
            "description": "The transaction reference of the object to delete.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Object deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteObjectResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Object not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "API key passed via the X-API-KEY header. Alternatively, use 'Authorization: Token <API_KEY>' header."
      }
    },
    "schemas": {
      "CreateRequest": {
        "type": "object",
        "description": "Request body for document/image creation. For PDFs, pass template variable key-value pairs. For images, pass an 'overrides' array.",
        "properties": {
          "overrides": {
            "type": "array",
            "description": "Array of override objects for image template elements.",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "The name of the template element to override."
                },
                "text": {
                  "type": "string",
                  "description": "Text content override."
                },
                "src": {
                  "type": "string",
                  "description": "Image source URL override."
                },
                "backgroundColor": {
                  "type": "string",
                  "description": "Background color override."
                },
                "color": {
                  "type": "string",
                  "description": "Text color override."
                }
              }
            }
          }
        },
        "additionalProperties": true
      },
      "CreateResponse": {
        "type": "object",
        "properties": {
          "download_url": {
            "type": "string",
            "description": "URL to download the generated PDF."
          },
          "download_url_png": {
            "type": "string",
            "description": "URL to download the generated image in PNG format (image templates only)."
          },
          "template_id": {
            "type": "string",
            "description": "The template ID used."
          },
          "transaction_ref": {
            "type": "string",
            "description": "Unique transaction reference for the generation."
          },
          "status": {
            "type": "string",
            "description": "Status of the generation."
          }
        }
      },
      "WebhookAcceptedResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status of the async request."
          },
          "is_webhook": {
            "type": "boolean",
            "description": "Whether this is a webhook response."
          },
          "webhook_url": {
            "type": "string",
            "description": "The webhook URL that will receive the callback."
          },
          "transaction_ref": {
            "type": "string",
            "description": "Unique transaction reference."
          }
        }
      },
      "ListTemplatesResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "templates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Template"
            }
          }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "template_id": {
            "type": "string",
            "description": "Unique template identifier."
          },
          "name": {
            "type": "string",
            "description": "Template name."
          },
          "format": {
            "type": "string",
            "description": "Template format (e.g., 'pdf', 'image')."
          }
        }
      },
      "ListObjectsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "num_of_records": {
            "type": "integer",
            "description": "Total number of records."
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "objects": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GeneratedObject"
            }
          }
        }
      },
      "GeneratedObject": {
        "type": "object",
        "properties": {
          "transaction_ref": {
            "type": "string",
            "description": "Unique transaction reference."
          },
          "download_url": {
            "type": "string",
            "description": "URL to download the object."
          },
          "template_id": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DeleteObjectResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "transaction_ref": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Error status."
          },
          "message": {
            "type": "string",
            "description": "Error message describing the issue."
          }
        }
      }
    }
  }
}