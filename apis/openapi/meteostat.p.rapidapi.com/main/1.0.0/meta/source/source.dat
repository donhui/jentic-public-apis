  "components": {
    "securitySchemes": {
      "RapidAPIKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-RapidAPI-Key",
        "description": "API key provided by RapidAPI for authentication."
      }
    },
    "schemas": {
      "Meta": {
        "type": "object",
        "description": "General metadata about the API response.",
        "properties": {
          "source": {
            "type": "string",
            "description": "The data source identifier."
          },
          "generated": {
            "type": "string",
            "description": "Timestamp when the response was generated."
          }
        }
      },
      "StationMeta": {
        "type": "object",
        "description": "Metadata for a weather station.",
        "properties": {
          "id": {
            "type": "string",
            "description": "The Meteostat station ID."
          },
          "name": {
            "type": "object",
            "description": "Station name in different languages.",
            "properties": {
              "en": {
                "type": "string",
                "description": "Station name in English."
              }
            }
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code."
          },
          "region": {
            "type": "string",
            "description": "Region or state code."
          },
          "national": {
            "type": "string",
            "description": "National weather service station ID."
          },
          "wmo": {
            "type": "integer",
            "description": "WMO station identifier."
          },
          "icao": {
            "type": "string",
            "description": "ICAO airport code."
          },
          "iata": {
            "type": "string",
            "description": "IATA airport code."
          },
          "latitude": {
            "type": "number",
            "format": "float",
            "description": "Station latitude."
          },
          "longitude": {
            "type": "number",
            "format": "float",
            "description": "Station longitude."
          },
          "elevation": {
            "type": "integer",
            "description": "Station elevation in meters above sea level."
          },
          "timezone": {
            "type": "string",
            "description": "Time zone of the station."
          }
        }
      },
      "StationMetaResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "$ref": "#/components/schemas/Meta"
          },
          "data": {
            "$ref": "#/components/schemas/StationMeta"
          }
        }
      },
      "NearbyStation": {
        "type": "object",
        "description": "A nearby weather station with distance information.",
        "properties": {
          "id": {
            "type": "string",
            "description": "The Meteostat station ID."
          },
          "name": {
            "type": "object",
            "description": "Station name in different languages.",
            "properties": {
              "en": {
                "type": "string",
                "description": "Station name in English."
              }
            }
          },
          "active": {
            "type": "boolean",
            "description": "Whether the station is currently active."
          },
          "distance": {
            "type": "number",
            "format": "float",
            "description": "Distance from the specified coordinates in meters."
