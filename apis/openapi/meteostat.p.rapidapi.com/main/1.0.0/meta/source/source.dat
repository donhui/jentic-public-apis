{
  "openapi": "3.0.3",
  "info": {
    "title": "Meteostat Weather API",
    "description": "Access historical weather and climate data through the Meteostat JSON API. Retrieve data for weather stations or geographic coordinates.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://dev.meteostat.net/api/"
  },
  "servers": [
    {
      "url": "https://meteostat.p.rapidapi.com",
      "description": "Meteostat RapidAPI production server"
    }
  ],
  "security": [
    {
      "RapidAPIKey": []
    }
  ],
  "paths": {
    "/stations/meta": {
      "get": {
        "operationId": "getStationMeta",
        "summary": "Get station metadata",
        "description": "Returns metadata for a weather station identified by its Meteostat ID, WMO identifier, or ICAO code.",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "The Meteostat station ID.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "wmo",
            "in": "query",
            "description": "The WMO identifier of the station.",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "icao",
            "in": "query",
            "description": "The ICAO code of the station.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with station metadata.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StationMetaResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/stations/nearby": {
      "get": {
        "operationId": "getNearbyStations",
        "summary": "Find nearby weather stations",
        "description": "Returns a list of weather stations near the specified geographic coordinates.",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "description": "The latitude of the location.",
            "required": true,
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "lon",
            "in": "query",
            "description": "The longitude of the location.",
            "required": true,
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of stations to return.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "radius",
            "in": "query",
            "description": "Maximum radius in meters.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with nearby stations.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NearbyStationsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/stations/hourly": {
      "get": {
        "operationId": "getStationHourlyData",
        "summary": "Get hourly station data",
        "description": "Returns hourly weather observations and model data for a specified station and date range.",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "station",
            "in": "query",
            "description": "The Meteostat station ID.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start date in YYYY-MM-DD format.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date in YYYY-MM-DD format.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "tz",
            "in": "query",
            "description": "Time zone according to the tz database.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "UTC"
            }
          },
          {
            "name": "model",
            "in": "query",
            "description": "Enable model-based gap filling.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "true"
            }
          },
          {
            "name": "freq",
            "in": "query",
            "description": "Frequency of the time series.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "units",
            "in": "query",
            "description": "Unit system for the response data.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["metric", "imperial", "scientific"],
              "default": "metric"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with hourly data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HourlyDataResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/stations/daily": {
      "get": {
        "operationId": "getStationDailyData",
        "summary": "Get daily station data",
        "description": "Returns daily weather data for a specified station and date range.",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "station",
            "in": "query",
            "description": "The Meteostat station ID.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start date in YYYY-MM-DD format.",
