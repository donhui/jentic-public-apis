            "required": false,
            "schema": {
              "type": "string",
              "enum": ["metric", "imperial", "scientific"],
              "default": "metric"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with hourly point data.",
            "content": {
              "application/json": {
                "schema": {
