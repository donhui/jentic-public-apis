            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date in YYYY-MM-DD format.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "model",
            "in": "query",
            "description": "Enable model-based gap filling.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "true"
            }
          },
          {
            "name": "freq",
            "in": "query",
            "description": "Frequency of the time series.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "units",
            "in": "query",
            "description": "Unit system for the response data.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["metric", "imperial", "scientific"],
              "default": "metric"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with daily data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DailyDataResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/stations/monthly": {
      "get": {
        "operationId": "getStationMonthlyData",
        "summary": "Get monthly station data",
        "description": "Returns monthly aggregated weather data for a specified station and date range.",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "station",
            "in": "query",
            "description": "The Meteostat station ID.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start date in YYYY-MM-DD format.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date in YYYY-MM-DD format.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "model",
            "in": "query",
            "description": "Enable model-based gap filling.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "true"
            }
          },
          {
            "name": "freq",
            "in": "query",
            "description": "Frequency of the time series.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "units",
            "in": "query",
            "description": "Unit system for the response data.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["metric", "imperial", "scientific"],
              "default": "metric"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with monthly data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MonthlyDataResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/stations/normals": {
      "get": {
        "operationId": "getStationNormals",
        "summary": "Get climate normals for a station",
        "description": "Returns climate normals for a specified station and optional reference period.",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "station",
            "in": "query",
            "description": "The Meteostat station ID.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start year (YYYY) of the reference period.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End year (YYYY) of the reference period.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "units",
            "in": "query",
            "description": "Unit system for the response data.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["metric", "imperial", "scientific"],
              "default": "metric"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with climate normals.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NormalsDataResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/point/hourly": {
      "get": {
        "operationId": "getPointHourlyData",
        "summary": "Get hourly point data",
        "description": "Returns hourly weather data for a geographic location specified by latitude and longitude.",
        "tags": ["Point"],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "description": "The latitude of the location.",
            "required": true,
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "lon",
            "in": "query",
            "description": "The longitude of the location.",
            "required": true,
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "alt",
            "in": "query",
            "description": "The altitude of the location in meters.",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start date in YYYY-MM-DD format.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date in YYYY-MM-DD format.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "tz",
            "in": "query",
            "description": "Time zone according to the tz database.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "UTC"
            }
          },
          {
            "name": "model",
            "in": "query",
            "description": "Enable model-based gap filling.",
            "required": false,
            "schema": {
              "type": "string",
              "default": "true"
            }
          },
          {
            "name": "freq",
            "in": "query",
            "description": "Frequency of the time series.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "units",
            "in": "query",
