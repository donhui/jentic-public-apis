    "/account/user": {
      "get": {
        "tags": [
          "Аккаунт"
        ],
        "summary": "Получение пользователя",
        "description": "Возвращает данные профиля пользователя.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "description": "Authorization: Bearer {token}",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Информация о пользователе",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "example": "Иванов Иван Иванович"
                    },
                    "phone": {
                      "type": "string",
                      "example": "79112345687"
                    },
                    "role": {
                      "type": "string",
                      "enum": [
                        "slave",
                        "master"
                      ],
                      "example": "slave"
                    },
                    "position": {
                      "type": "string",
                      "enum": [
                        "repairer",
                        "cleaner"
                      ],
                      "example": "cleaner"
                    },
                    "picture": {
                      "type": "string",
                      "example": "{url}/pictures/053.png"
                    },
                    "status": {
                      "type": "object",
                      "properties": {
                        "inside": {
                          "type": "boolean",
                          "example": true
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Отказано в доступе",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errors": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "level": {
                            "type": "string",
                            "enum": [
                              "error",
                              "warning",
                              "info"
                            ]
                          },
                          "message": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "errors": [
                      {
                        "level": "error",
                        "message": "Токен доступа невалидный"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "operationId": "get-account-user"
      }
    },
    "/shops/scan": {
      "post": {
        "tags": [
          "Магазин"
        ],
        "summary": "Контроллер принимает QR коды от входной двери",
        "description": "Авторизация по номеру телефона и паролю сотрудника",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "code"
                ],
                "properties": {
                  "code": {
                    "type": "string",
                    "example": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешная авторизация",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "node": {
                      "type": "object"
                    },
                    "status": {
                      "type": "object",
                      "properties": {
                        "inside": {
                          "type": "boolean"
                        },
                        "commitment": {
                          "type": "boolean"
                        }
                      }
                    }
                  },
                  "example": {
                    "type": "product",
                    "node": {},
                    "status": {
                      "inside": true,
                      "commitment": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Ошибка при попытке войти",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errors": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "level": {
                            "type": "string",
                            "enum": [
                              "error",
                              "warning",
                              "info"
                            ]
                          },
                          "message": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "errors": [
                      {
                        "level": "error",
                        "message": "Неверный код"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "operationId": "post-shops-scan"
      }
    },
