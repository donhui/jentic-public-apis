  "paths": {
    "/authorize": {
      "post": {
        "summary": "Авторизация",
        "tags": [
          "Авторизация"
        ],
        "description": "Авторизация по номеру телефона и паролю сотрудника",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phone",
                  "password"
                ],
                "properties": {
                  "phone": {
                    "type": "string",
                    "example": "+79112345687"
                  },
                  "password": {
                    "type": "string",
                    "example": "password1234"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешная авторизация",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access": {
                      "type": "string"
                    },
                    "refresh": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "access": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ0b2tlbl90eXBlIjoiYWNjZXNzIiwiZXhwIjoxNTUxNzA0NjU1LCJqdGkiOiI5ZWI5MDA4MDJmMDg0ZjgxOGY3N2JkZWM1NDQ0NWJjYyIsInVzZXJfaWQiOjN9.XV3fXXLVrjbaQQjxp2DccLfW-rCEzQNoZWkEQXMRlA0",
                    "refresh": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ0b2tlbl90eXBlIjoicmVmcmVzaCIsImV4cCI6MTU1MTc5MDc1NSwianRpIjoiOWNlODdjNzYzYTZmNDA2ZThmYWUzZmU3NmVhZGQ2ZjEiLCJ1c2VyX2lkIjozfQ.Qu-C_MhwEI8ovfYVPeg9gyqmZbV_O4xs8YbyMZorr84"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Ошибка при попытке войти",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errors": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "level": {
                            "type": "string",
                            "enum": [
                              "error",
                              "warning",
                              "info"
                            ]
                          },
                          "message": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "errors": [
                      {
                        "level": "error",
                        "message": "Неверный формат номера телефона"
                      }
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "Отказано в доступе",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errors": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "level": {
                            "type": "string",
                            "enum": [
                              "error",
                              "warning",
                              "info"
                            ]
                          },
                          "message": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "example": {
                    "errors": [
                      {
                        "level": "error",
                        "message": "Неверный номер телефона или пароль"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "operationId": "post-authorize"
      }
    },
