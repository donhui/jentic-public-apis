{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0",
    "title": "Axeta Auth",
    "description": "Описание API для входа сотрудников",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Axeta/AXETA_AUTH_APP/1.0/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/Axeta/AXETA_AUTH_APP/1.0"
    },
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/Axeta/auth-backend/1.0"
    }
  ],
  "paths": {
    "/authorize/": {
      "post": {
        "description": "Авторизация по номеру телефона",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "phone",
                  "password"
                ],
                "properties": {
                  "phone": {
                    "type": "string",
                    "example": 79112345687
                  },
                  "password": {
                    "type": "string",
                    "example": "password1234"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешная авторизация",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Ошибка при попытке войти",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/logout/": {
      "get": {
        "description": "Выход (окончание сессии)",
        "responses": {
          "200": {
            "description": "Выход выполнен",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/user/": {
      "get": {
        "description": "Возвращает данные профиля пользователя.",
        "responses": {
          "200": {
            "description": "Информация пользователя",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "example": "Ivan"
                    },
                    "phone": {
                      "type": "string",
                      "example": "79112345687"
                    },
                    "email": {
                      "type": "string",
                      "example": "mail@mail.com"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Отказано в доступе",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": {
                      "type": "string",
                      "example": "Access token is missing or invalid"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "description": "Обновляет данные профиля пользователя.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Ivan"
                  },
                  "phone": {
                    "type": "string",
                    "example": "79112345687"
                  },
                  "email": {
                    "type": "string",
                    "example": "mail@mail.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Информация пользователя",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "example": "Ivan"
                    },
                    "phone": {
                      "type": "string",
                      "example": "79112345687"
                    },
                    "email": {
                      "type": "string",
                      "example": "mail@mail.com"
                    },
                    "status": {
                      "type": "object",
                      "properties": {
                        "inside": {
                          "type": "boolean",
                          "example": true
                        },
                        "commitment": {
                          "type": "boolean",
                          "example": true
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Отказано в доступе",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": {
                      "type": "string",
                      "example": "Access token is missing or invalid"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/refresh/": {
      "post": {
        "description": "Обновление токена",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string",
                    "example": "ashda13jasldk2kl34hksadj"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешно обновлен токен",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "proporties": {
                    "token": {
                      "type": "string",
                      "example": "bnbamghjgdashda13jasldk2kl34hksadj"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Ошибка при попытке обновить токен",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/scan/": {
      "post": {
        "description": "Вход двери",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "code"
                ],
                "properties": {
                  "code": {
                    "type": "string",
                    "example": "ashda13jasldk2kl34hksadj"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "example": "product"
                    },
                    "node": {
                      "type": "object"
                    },
                    "status": {
                      "type": "object",
                      "properties": {
                        "inside": {
                          "type": "boolean",
                          "example": true
                        },
                        "commitment": {
                          "type": "boolean",
                          "example": true
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Ошибка",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}