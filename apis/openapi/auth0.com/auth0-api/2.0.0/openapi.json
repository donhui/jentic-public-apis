{
  "openapi": "3.0.3",
  "info": {
    "title": "Auth0 Authentication API",
    "description": "The Auth0 Authentication API exposes identity functionality for Auth0 and supported identity protocols including OpenID Connect, OAuth 2.0, and SAML. Use this API for token retrieval, user authentication, passwordless login, MFA challenges, and more.",
    "version": "2.0.0",
    "contact": {
      "name": "Auth0 Support",
      "url": "https://support.auth0.com",
      "email": "support@auth0.com"
    },
    "termsOfService": "https://auth0.com/terms",
    "license": {
      "name": "Auth0 Terms of Service",
      "url": "https://auth0.com/terms"
    }
  },
  "servers": [
    {
      "url": "https://{tenant}.auth0.com",
      "description": "Auth0 tenant domain",
      "variables": {
        "tenant": {
          "default": "YOUR_DOMAIN",
          "description": "Your Auth0 tenant domain"
        }
      }
    }
  ],
  "externalDocs": {
    "description": "Auth0 Authentication API Documentation",
    "url": "https://auth0.com/docs/api/authentication"
  },
  "paths": {
    "/authorize": {
      "get": {
        "operationId": "authorize",
        "summary": "Authorization Endpoint",
        "description": "Used to interact with the resource owner and obtain an authorization grant. This is the standard OAuth 2.0 authorization endpoint.",
        "tags": ["Authorization"],
        "parameters": [
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "description": "Indicates the type of credentials returned (code or token).",
            "schema": {
              "type": "string",
              "enum": ["code", "token", "id_token", "code token", "code id_token", "token id_token", "code token id_token"]
            }
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "description": "Your application's Client ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": false,
            "description": "URL to redirect the user after authorization.",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "description": "Space-separated list of OIDC and custom API scopes.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "description": "An opaque value used to prevent CSRF attacks.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "audience",
            "in": "query",
            "required": false,
            "description": "The unique identifier of the target API.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "connection",
            "in": "query",
            "required": false,
            "description": "The name of the connection configured for your application.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nonce",
            "in": "query",
            "required": false,
            "description": "A string value to associate with the ID token for replay prevention.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prompt",
            "in": "query",
            "required": false,
            "description": "Controls the authentication experience.",
            "schema": {
              "type": "string",
              "enum": ["none", "login", "consent"]
            }
          },
          {
            "name": "organization",
            "in": "query",
            "required": false,
            "description": "Organization ID or name for organization-enabled applications.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "invitation",
            "in": "query",
            "required": false,
            "description": "Ticket ID for organization invitations.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code_challenge",
            "in": "query",
            "required": false,
            "description": "PKCE code challenge.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "code_challenge_method",
            "in": "query",
            "required": false,
            "description": "PKCE code challenge method.",
            "schema": {
              "type": "string",
              "enum": ["S256", "plain"]
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirects to the identity provider or back to the redirect_uri."
          },
          "400": {
            "description": "Bad request - missing or invalid parameters."
          },
          "401": {
            "description": "Unauthorized - invalid client_id."
          }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "operationId": "oauthToken",
        "summary": "Get Token",
        "description": "Exchange an authorization code, refresh token, or client credentials for access and ID tokens.",
        "tags": ["OAuth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "client_id"],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "description": "The type of grant being requested.",
                    "enum": [
                      "authorization_code",
                      "client_credentials",
                      "refresh_token",
                      "urn:ietf:params:oauth:grant-type:device_code",
                      "http://auth0.com/oauth/grant-type/password-realm",
                      "http://auth0.com/oauth/grant-type/passwordless/otp",
                      "http://auth0.com/oauth/grant-type/mfa-otp",
                      "http://auth0.com/oauth/grant-type/mfa-oob",
                      "http://auth0.com/oauth/grant-type/mfa-recovery-code"
                    ]
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Your application's Client ID."
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Your application's Client Secret (for confidential applications)."
                  },
                  "code": {
                    "type": "string",
                    "description": "Authorization code received from /authorize (for authorization_code grant)."
                  },
                  "redirect_uri": {
                    "type": "string",
                    "description": "Must match the redirect_uri used in the /authorize call."
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token (for refresh_token grant)."
                  },
                  "audience": {
                    "type": "string",
                    "description": "The unique identifier of the target API."
                  },
                  "scope": {
                    "type": "string",
                    "description": "Space-separated list of requested scopes."
                  },
                  "code_verifier": {
                    "type": "string",
                    "description": "PKCE code verifier."
                  },
                  "username": {
                    "type": "string",
                    "description": "Username or email (for password grant)."
                  },
                  "password": {
                    "type": "string",
                    "description": "Password (for password grant)."
                  },
                  "realm": {
                    "type": "string",
                    "description": "Realm/connection name (for password-realm grant)."
                  },
                  "otp": {
                    "type": "string",
                    "description": "One-time password (for MFA/passwordless grants)."
                  },
                  "mfa_token": {
                    "type": "string",
                    "description": "MFA token from a previous authentication attempt."
                  },
                  "device_code": {
                    "type": "string",
                    "description": "Device code (for device_code grant)."
                  },
                  "recovery_code": {
                    "type": "string",
                    "description": "MFA recovery code."
                  }
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "client_id"],
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  },
                  "code": {
                    "type": "string"
                  },
                  "redirect_uri": {
                    "type": "string"
                  },
                  "refresh_token": {
                    "type": "string"
                  },
                  "audience": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden - MFA required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MfaRequiredResponse"
                }
              }
            }
          }
        }
      }
    },
    "/oauth/revoke": {
      "post": {
        "operationId": "oauthRevoke",
        "summary": "Revoke Refresh Token",
        "description": "Revoke a refresh token.",
        "tags": ["OAuth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id", "token"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application's Client ID."
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Your application's Client Secret."
                  },
                  "token": {
                    "type": "string",
                    "description": "The refresh token to revoke."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token revoked successfully."
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/dbconnections/signup": {
      "post": {
        "operationId": "dbSignup",
        "summary": "Signup",
        "description": "Create a new user using a database connection.",
        "tags": ["Database Connections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id", "email", "password", "connection"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application's Client ID."
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "User's email address."
                  },
                  "password": {
                    "type": "string",
                    "description": "User's desired password."
                  },
                  "connection": {
                    "type": "string",
                    "description": "Name of the database connection."
                  },
                  "username": {
                    "type": "string",
                    "description": "User's username (if connection requires username)."
                  },
                  "given_name": {
                    "type": "string",
                    "description": "User's given name."
                  },
                  "family_name": {
                    "type": "string",
                    "description": "User's family name."
                  },
                  "name": {
                    "type": "string",
                    "description": "User's full name."
                  },
                  "nickname": {
                    "type": "string",
                    "description": "User's nickname."
                  },
                  "picture": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the user's picture."
                  },
                  "user_metadata": {
                    "type": "object",
                    "description": "Additional user metadata."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": {
                      "type": "string"
                    },
                    "email_verified": {
                      "type": "boolean"
                    },
                    "email": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters or user already exists."
          }
        }
      }
    },
    "/dbconnections/change_password": {
      "post": {
        "operationId": "dbChangePassword",
        "summary": "Change Password",
        "description": "Send a change password email to the user or change the password directly.",
        "tags": ["Database Connections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id", "email", "connection"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application's Client ID."
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "User's email address."
                  },
                  "connection": {
                    "type": "string",
                    "description": "Name of the database connection."
                  },
                  "password": {
                    "type": "string",
                    "description": "New password (if directly changing)."
                  },
                  "organization": {
                    "type": "string",
                    "description": "Organization ID."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password change email sent or password changed successfully.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          }
        }
      }
    },
    "/passwordless/start": {
      "post": {
        "operationId": "passwordlessStart",
        "summary": "Start Passwordless Flow",
        "description": "Start a passwordless authentication flow by sending an email or SMS with a one-time code or magic link.",
        "tags": ["Passwordless"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id", "connection"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application's Client ID."
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Your application's Client Secret."
                  },
                  "connection": {
                    "type": "string",
                    "description": "Connection name (email or sms).",
                    "enum": ["email", "sms"]
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "User's email address (required for email connection)."
                  },
                  "phone_number": {
                    "type": "string",
                    "description": "User's phone number (required for sms connection)."
                  },
                  "send": {
                    "type": "string",
                    "description": "Whether to send a code or a link (for email only).",
                    "enum": ["code", "link"]
                  },
                  "authParams": {
                    "type": "object",
                    "description": "Additional authentication parameters.",
                    "properties": {
                      "scope": {
                        "type": "string"
                      },
                      "state": {
                        "type": "string"
                      },
                      "redirect_uri": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Passwordless authentication started.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "_id": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "phone_number": {
                      "type": "string"
                    },
                    "phone_verified": {
                      "type": "boolean"
                    },
                    "email_verified": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          }
        }
      }
    },
    "/passwordless/verify": {
      "post": {
        "operationId": "passwordlessVerify",
        "summary": "Verify Passwordless Code",
        "description": "Verify the one-time password sent via email or SMS.",
        "tags": ["Passwordless"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id", "connection", "otp"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application's Client ID."
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Your application's Client Secret."
                  },
                  "connection": {
                    "type": "string",
                    "description": "Connection name (email or sms).",
                    "enum": ["email", "sms"]
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "User's email address."
                  },
                  "phone_number": {
                    "type": "string",
                    "description": "User's phone number."
                  },
                  "otp": {
                    "type": "string",
                    "description": "The one-time password to verify."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request or invalid OTP."
          }
        }
      }
    },
    "/userinfo": {
      "get": {
        "operationId": "getUserInfo",
        "summary": "Get User Info",
        "description": "Returns user profile information based on the access token (OpenID Connect compliant).",
        "tags": ["User Info"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or expired token."
          }
        }
      }
    },
    "/mfa/challenge": {
      "post": {
        "operationId": "mfaChallenge",
        "summary": "MFA Challenge",
        "description": "Request a challenge for multi-factor authentication.",
        "tags": ["MFA"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id", "mfa_token"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application's Client ID."
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Your application's Client Secret."
                  },
                  "mfa_token": {
                    "type": "string",
                    "description": "MFA token from a previous authentication attempt."
                  },
                  "challenge_type": {
                    "type": "string",
                    "description": "Type of MFA challenge to request.",
                    "enum": ["oob", "otp"]
                  },
                  "authenticator_id": {
                    "type": "string",
                    "description": "The ID of the authenticator to challenge."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "MFA challenge issued",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "challenge_type": {
                      "type": "string"
                    },
                    "oob_code": {
                      "type": "string",
                      "description": "Out-of-band code (for OOB challenges)."
                    },
                    "binding_method": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          }
        }
      }
    },
    "/mfa/associate": {
      "post": {
        "operationId": "mfaAssociate",
        "summary": "Associate MFA Authenticator",
        "description": "Associate a new authenticator for multi-factor authentication.",
        "tags": ["MFA"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["authenticator_types"],
                "properties": {
                  "authenticator_types": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["otp", "oob"]
                    },
                    "description": "Types of authenticators to associate."
                  },
                  "oob_channel": {
                    "type": "string",
                    "description": "OOB channel type.",
                    "enum": ["sms", "auth0"]
                  },
                  "phone_number": {
                    "type": "string",
                    "description": "Phone number for SMS-based OOB."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticator associated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "authenticator_type": {
                      "type": "string"
                    },
                    "secret": {
                      "type": "string",
                      "description": "TOTP secret (for OTP type)."
                    },
                    "barcode_uri": {
                      "type": "string",
                      "description": "QR code URI for OTP enrollment."
                    },
                    "oob_code": {
                      "type": "string"
                    },
                    "oob_channel": {
                      "type": "string"
                    },
                    "recovery_codes": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/mfa/authenticators": {
      "get": {
        "operationId": "mfaListAuthenticators",
        "summary": "List MFA Authenticators",
        "description": "List the authenticators associated with the user.",
        "tags": ["MFA"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of authenticators",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "authenticator_type": {
                        "type": "string"
                      },
                      "active": {
                        "type": "boolean"
                      },
                      "oob_channel": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "mfaDeleteAuthenticator",
        "summary": "Delete MFA Authenticator",
        "description": "Delete an authenticator associated with the user.",
        "tags": ["MFA"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "authenticator_id",
            "in": "query",
            "required": true,
            "description": "The ID of the authenticator to delete.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Authenticator deleted successfully."
          }
        }
      }
    },
    "/oauth/device/code": {
      "post": {
        "operationId": "deviceAuthorization",
        "summary": "Device Authorization",
        "description": "Start the device authorization flow. Returns a device code, user code, and verification URI.",
        "tags": ["OAuth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["client_id"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application's Client ID."
                  },
                  "scope": {
                    "type": "string",
                    "description": "Space-separated list of requested scopes."
                  },
                  "audience": {
                    "type": "string",
                    "description": "The unique identifier of the target API."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Device code response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "device_code": {
                      "type": "string"
                    },
                    "user_code": {
