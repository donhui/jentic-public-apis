{
  "openapi": "3.0.3",
  "info": {
    "title": "Dittofeed API",
    "version": "1.0.0",
    "description": "Dittofeed is a customer engagement platform. The API allows you to identify users, track events, record page views, screen views, and send batch requests for user engagement automation.",
    "x-jentic-source-url": "https://docs.dittofeed.com/api-reference/endpoints/apps/identify"
  },
  "servers": [
    {
      "url": "https://app.dittofeed.com"
    }
  ],
  "paths": {
    "/api/public/apps/identify": {
      "post": {
        "operationId": "identifyUser",
        "summary": "Identify a user",
        "description": "Associates a user with their traits and actions. Can be used with either a userId (for logged-in users) or anonymousId (for anonymous users).",
        "tags": ["Apps"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/IdentifyUserRequest" },
                  { "$ref": "#/components/schemas/IdentifyAnonymousRequest" }
                ]
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Successfully identified user"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/apps/track": {
      "post": {
        "operationId": "trackEvent",
        "summary": "Track an event",
        "description": "Records user actions and associated properties for event tracking.",
        "tags": ["Apps"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/TrackUserRequest" },
                  { "$ref": "#/components/schemas/TrackAnonymousRequest" }
                ]
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Event tracked successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/apps/page": {
      "post": {
        "operationId": "trackPageView",
        "summary": "Track a page view",
        "description": "Records user page views with optional metadata about the page visited.",
        "tags": ["Apps"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/PageUserRequest" },
                  { "$ref": "#/components/schemas/PageAnonymousRequest" }
                ]
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Page view tracked successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/apps/screen": {
      "post": {
        "operationId": "trackScreenView",
        "summary": "Track a screen view",
        "description": "Records whenever a user sees a screen, the mobile equivalent of page, in your mobile app.",
        "tags": ["Apps"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/ScreenUserRequest" },
                  { "$ref": "#/components/schemas/ScreenAnonymousRequest" }
                ]
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Screen view tracked successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/public/apps/batch": {
      "post": {
        "operationId": "submitBatch",
        "summary": "Submit a batch of requests",
        "description": "Sends a series of identify, group, track, page and screen requests in a single batch, saving on outbound requests.",
        "tags": ["Apps"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Batch processed successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IdentifyUserRequest": {
        "type": "object",
        "required": ["userId", "messageId"],
        "properties": {
          "userId": {
            "type": "string",
            "description": "Unique user identifier from your system"
          },
          "messageId": {
            "type": "string",
            "description": "UUID for idempotency during retries"
          },
          "traits": {
            "type": "object",
            "description": "Custom user attributes"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO 8601 formatted timestamp"
          },
          "context": {
            "type": "object",
            "description": "Metadata about user/event"
          }
        }
      },
      "IdentifyAnonymousRequest": {
        "type": "object",
        "required": ["anonymousId", "messageId"],
        "properties": {
          "anonymousId": {
            "type": "string",
            "description": "Session or pseudo-unique identifier for anonymous users"
          },
          "messageId": {
            "type": "string",
            "description": "UUID for idempotency during retries"
          },
          "traits": {
            "type": "object",
            "description": "Custom user attributes"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO 8601 formatted timestamp"
          },
          "context": {
            "type": "object",
            "description": "Metadata about user/event"
          }
        }
      },
      "TrackUserRequest": {
        "type": "object",
        "required": ["userId", "messageId", "event"],
        "properties": {
          "userId": { "type": "string" },
          "messageId": { "type": "string" },
          "event": { "type": "string", "description": "Action name (e.g., COURSE_CLICKED)" },
          "timestamp": { "type": "string" },
          "properties": { "type": "object", "description": "Custom event metadata" },
          "context": { "type": "object" },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FileAttachment"
            }
          }
        }
      },
      "TrackAnonymousRequest": {
        "type": "object",
        "required": ["anonymousId", "messageId", "event"],
        "properties": {
          "anonymousId": { "type": "string" },
          "messageId": { "type": "string" },
          "event": { "type": "string" },
          "timestamp": { "type": "string" },
          "properties": { "type": "object" },
          "context": { "type": "object" },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FileAttachment"
            }
          }
        }
      },
      "PageUserRequest": {
        "type": "object",
        "required": ["userId", "messageId"],
        "properties": {
          "userId": { "type": "string" },
          "messageId": { "type": "string" },
          "name": { "type": "string", "description": "Page name" },
          "properties": { "type": "object", "description": "Custom page metadata (url, title, etc.)" },
          "timestamp": { "type": "string" },
          "context": { "type": "object" }
        }
      },
      "PageAnonymousRequest": {
        "type": "object",
        "required": ["anonymousId", "messageId"],
        "properties": {
          "anonymousId": { "type": "string" },
          "messageId": { "type": "string" },
          "name": { "type": "string" },
          "properties": { "type": "object" },
          "timestamp": { "type": "string" },
          "context": { "type": "object" }
        }
      },
      "ScreenUserRequest": {
        "type": "object",
        "required": ["userId", "messageId"],
        "properties": {
          "userId": { "type": "string" },
          "messageId": { "type": "string" },
          "name": { "type": "string", "description": "Screen name" },
          "properties": { "type": "object" },
          "timestamp": { "type": "string" },
          "context": { "type": "object" }
        }
      },
      "ScreenAnonymousRequest": {
        "type": "object",
        "required": ["anonymousId", "messageId"],
        "properties": {
          "anonymousId": { "type": "string" },
          "messageId": { "type": "string" },
          "name": { "type": "string" },
          "properties": { "type": "object" },
          "timestamp": { "type": "string" },
          "context": { "type": "object" }
        }
      },
      "BatchRequest": {
        "type": "object",
        "required": ["batch"],
        "properties": {
          "batch": {
            "type": "array",
            "description": "Array of identify, track, page, screen, or group messages",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["identify", "track", "page", "screen", "group"]
                },
                "userId": { "type": "string" },
                "anonymousId": { "type": "string" },
                "messageId": { "type": "string" },
                "event": { "type": "string" },
                "name": { "type": "string" },
                "groupId": { "type": "string" },
                "traits": { "type": "object" },
                "properties": { "type": "object" },
                "timestamp": { "type": "string" },
                "context": { "type": "object" }
              }
            }
          },
          "context": {
            "type": "object",
            "description": "Context applied to the entire batch"
          }
        }
      },
      "FileAttachment": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "name": { "type": "string" },
          "mimeType": { "type": "string" },
          "data": { "type": "string", "description": "Base64-encoded file data" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained from https://app.dittofeed.com/dashboard/settings#write-key"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}