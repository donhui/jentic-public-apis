{"openapi":"3.0.3","info":{"title":"Webmetic Data Hub","description":"Webmetic Data Hub provides a secure API for querying visitor sessions based on specific filters, tailored for customer use.","termsOfService":"https://webmetic.de/agb","contact":{"name":"API Support","email":"mail@webmetic.de"},"version":"2.3","x-jentic-source-url":"https://hub.webmetic.de/openapi.json"},"servers":[{"url":"https://hub.webmetic.de","description":"Webmetic Data Hub API"}],"paths":{"/company-sessions":{"get":{"summary":"Get Visitor Sessions","description":"Retrieves detailed company information and associated visitor session data for a specified domain within a given time range.","operationId":"getVisitorSessions","security":[{"APIKeyHeader":[]}],"tags":["Sessions"],"parameters":[{"name":"domain","in":"query","required":true,"schema":{"type":"string"}},{"name":"from_date","in":"query","required":false,"schema":{"type":"string","default":"-30 days"},"description":"Starting DateTime format or relative dates like '-30 days'"},{"name":"to_date","in":"query","required":false,"schema":{"type":"string","default":"now"},"description":"Ending DateTime format or 'now'"},{"name":"page","in":"query","required":false,"schema":{"type":"integer","default":1}},{"name":"page_size","in":"query","required":false,"schema":{"type":"integer","maximum":10000,"default":10000}}],"responses":{"200":{"description":"Get visitor sessions","content":{"application/json":{"schema":{"type":"object"}}}},"400":{"description":"Bad request"},"401":{"description":"Unauthorized - invalid or missing API key"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/company":{"get":{"summary":"Get Company Info","description":"Retrieves detailed company information for a specified domain within a given time range.","operationId":"getCompanyInfo","security":[{"APIKeyHeader":[]}],"tags":["Company"],"parameters":[{"name":"domain","in":"query","re