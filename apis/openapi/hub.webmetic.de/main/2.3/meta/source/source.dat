e Visits","description":"Retrieves a list of companies that have had intensive visits to the specified domain.","operationId":"getIntensiveVisits","security":[{"APIKeyHeader":[]}],"tags":["Visits"],"parameters":[{"name":"domain","in":"query","required":true,"schema":{"type":"string"}},{"name":"from_date","in":"query","required":false,"schema":{"type":"string","default":"-30 days"}},{"name":"to_date","in":"query","required":false,"schema":{"type":"string","default":"now"}}],"responses":{"200":{"description":"Get intensive visitor sessions","content":{"application/json":{"schema":{"type":"object"}}}},"400":{"description":"Bad request"},"401":{"description":"Unauthorized"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/returning-visits":{"get":{"summary":"Get Returning Visits","description":"Retrieves a list of companies that have visited the specified domain multiple times.","operationId":"getReturningVisits","security":[{"APIKeyHeader":[]}],"tags":["Visits"],"parameters":[{"name":"domain","in":"query","required":true,"schema":{"type":"string"}},{"name":"from_date","in":"query","required":false,"schema":{"type":"string","default":"-30 days"}},{"name":"to_date","in":"query","required":false,"schema":{"type":"string","default":"now"}}],"responses":{"200":{"description":"Get returning visitor sessions","content":{"application/json":{"schema":{"type":"object"}}}},"400":{"description":"Bad request"},"401":{"description":"Unauthorized"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/new-visits":{"get":{"summary":"Get New Visits","description":"Retrieves a list of companies that have visited the specified domain for the first time.","operationId":"getNewVisits","security":[{"APIKeyHeader":[]}],"tags":["Visits"],"parameters":[{"name":"domain","in":"query","required":true,"schema":{"type":"stri