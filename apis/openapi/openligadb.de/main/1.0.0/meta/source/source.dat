{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenLigaDB API",
    "version": "1.0.0",
    "description": "OpenLigaDB provides free access to sports match data, primarily football/soccer information including leagues, matches, standings, and goal scorers.",
    "x-jentic-source-url": "https://api.openligadb.de"
  },
  "servers": [
    {
      "url": "https://api.openligadb.de"
    }
  ],
  "security": [],
  "tags": [
    {
      "name": "Leagues",
      "description": "League and sport information"
    },
    {
      "name": "Matches",
      "description": "Match data retrieval"
    },
    {
      "name": "Standings",
      "description": "League tables and standings"
    },
    {
      "name": "Statistics",
      "description": "Goal scorers and statistics"
    }
  ],
  "paths": {
    "/getavailableleagues": {
      "get": {
        "operationId": "getavailableleagues",
        "summary": "List all available leagues",
        "tags": [
          "Leagues"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/League"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getavailablesports": {
      "get": {
        "operationId": "getavailablesports",
        "summary": "List all available sports",
        "tags": [
          "Leagues"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Sport"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getavailableteams/{leagueShortcut}/{leagueSeason}": {
      "get": {
        "operationId": "getavailableteams",
        "summary": "Get teams in a league and season",
        "tags": [
          "Leagues"
        ],
        "parameters": [
          {
            "name": "leagueShortcut",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "League shortcut (e.g., bl1)"
          },
          {
            "name": "leagueSeason",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Season year (e.g., 2023)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Team"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getavailablegroups/{leagueShortcut}/{leagueSeason}": {
      "get": {
        "operationId": "getavailablegroups",
