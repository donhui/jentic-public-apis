{
  "openapi": "3.0.3",
  "info": {
    "title": "Campaign Monitor API",
    "description": "Campaign Monitor REST API for managing accounts, clients, campaigns, lists, subscribers, segments, templates, transactional email, journeys, and webhooks.",
    "version": "3.3.0",
    "x-jentic-source-url": "https://www.campaignmonitor.com/api/"
  },
  "servers": [
    {
      "url": "https://api.createsend.com/api/v3.3",
      "description": "Campaign Monitor API v3.3"
    }
  ],
  "security": [
    {
      "BasicAuth": []
    },
    {
      "OAuth2": []
    }
  ],
  "tags": [
    { "name": "Account", "description": "Account management" },
    { "name": "Clients", "description": "Client management" },
    { "name": "Campaigns", "description": "Campaign management" },
    { "name": "Lists", "description": "Subscriber list management" },
    { "name": "Subscribers", "description": "Subscriber management" },
    { "name": "Segments", "description": "Segment management" },
    { "name": "Templates", "description": "Template management" },
    { "name": "Transactional", "description": "Transactional email" },
    { "name": "Journeys", "description": "Journey management" }
  ],
  "paths": {
    "/clients.json": {
      "get": {
        "operationId": "listClients",
        "summary": "Get all clients",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Clients list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ClientSummary" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createClient",
        "summary": "Create a client",
        "tags": ["Clients"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateClientRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Client created",
            "content": { "application/json": { "schema": { "type": "string" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/billingdetails.json": {
      "get": {
        "operationId": "getBillingDetails",
        "summary": "Get billing details",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Billing details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BillingDetails" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/countries.json": {
      "get": {
        "operationId": "getCountries",
        "summary": "Get valid countries",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Country list",
            "content": { "application/json": { "schema": { "type": "array", "items": { "type": "string" } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/timezones.json": {
      "get": {
        "operationId": "getTimezones",
        "summary": "Get valid timezones",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Timezone list",
            "content": { "application/json": { "schema": { "type": "array", "items": { "type": "string" } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/systemdate.json": {
      "get": {
        "operationId": "getSystemDate",
        "summary": "Get current system date",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "System date",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "SystemDate": { "type": "string" } } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/admins.json": {
      "get": {
        "operationId": "listAdmins",
        "summary": "Get all administrators",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Admins list",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Admin" } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "addAdmin",
        "summary": "Add an administrator",
        "tags": ["Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "EmailAddress": { "type": "string" },
                  "Name": { "type": "string" }
                },
                "required": ["EmailAddress", "Name"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin added",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "EmailAddress": { "type": "string" } } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateAdmin",
        "summary": "Update an administrator",
        "tags": ["Account"],
        "parameters": [
          { "name": "email", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "EmailAddress": { "type": "string" },
                  "Name": { "type": "string" }
                },
                "required": ["EmailAddress", "Name"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin updated",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "EmailAddress": { "type": "string" } } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteAdmin",
        "summary": "Delete an administrator",
        "tags": ["Account"],
        "parameters": [
          { "name": "email", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Admin deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/primarycontact.json": {
      "get": {
        "operationId": "getPrimaryContact",
        "summary": "Get primary contact",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Primary contact",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "EmailAddress": { "type": "string" } } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "setPrimaryContact",
        "summary": "Set primary contact",
        "tags": ["Account"],
        "parameters": [
          { "name": "email", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Primary contact set",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "EmailAddress": { "type": "string" } } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/clients/{clientid}.json": {
      "get": {
        "operationId": "getClientDetails",
        "summary": "Get client details",
        "tags": ["Clients"],
        "parameters": [
          { "$ref": "#/components/parameters/ClientId" }
        ],
        "responses": {
          "200": {
            "description": "Client details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientDetail" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteClient",
        "summary": "Delete a client",
        "tags": ["Clients"],
        "parameters": [
          { "$ref": "#/components/parameters/ClientId" }
        ],
        "responses": {
          "200": { "description": "Client deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/clients/{clientid}/lists.json": {
      "get": {
        "operationId": "getClientLists",
        "summary": "Get subscriber lists for a client",
        "tags": ["Clients"],
        "parameters": [
          { "$ref": "#/components/parameters/ClientId" }
        ],
        "responses": {
          "200": {
            "description": "Lists",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ListSummary" } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/clients/{clientid}/segments.json": {
      "get": {
        "operationId": "getClientSegments",
        "summary": "Get segments for a client",
        "tags": ["Clients"],
        "parameters": [
          { "$ref": "#/components/parameters/ClientId" }
        ],
        "responses": {
          "200": {
            "description": "Segments",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/SegmentSummary" } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/clients/{clientid}/campaigns.json": {
      "get": {
        "operationId": "getClientSentCampaigns",
        "summary": "Get sent campaigns for a client",
        "tags": ["Clients"],
        "parameters": [
          { "$ref": "#/components/parameters/ClientId" },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "pagesize", "in": "query", "schema": { "type": "integer" } },
          { "name": "orderdirection", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] } },
          { "name": "sentFromDate", "in": "query", "schema": { "type": "string" } },
          { "name": "sentToDate", "in": "query", "schema": { "type": "string" } },
          { "name": "tags", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Campaigns",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResult" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/clients/{clientid}/setbasics.json": {
      "put": {
        "operationId": "setClientBasicDetails",
        "summary": "Set client basic details",
        "tags": ["Clients"],
        "parameters": [
          { "$ref": "#/components/parameters/ClientId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateClientRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/clients/{clientid}/suppress.json": {
      "post": {
        "operationId": "suppressEmails",
        "summary": "Suppress email addresses",
        "tags": ["Clients"],
        "parameters": [
          { "$ref": "#/components/parameters/ClientId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "EmailAddresses": { "type": "array", "items": { "type": "string" } }
                },
                "required": ["EmailAddresses"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Emails suppressed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/clients/{clientid}/unsuppress.json": {
      "put": {
        "operationId": "unsuppressEmail",
        "summary": "Unsuppress an email address",
        "tags": ["Clients"],
        "parameters": [
          { "$ref": "#/components/parameters/ClientId" },
          { "name": "email", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Email unsuppressed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/campaigns/{clientid}.json": {
      "post": {
        "operationId": "createDraftCampaign",
        "summary": "Create a draft campaign",
        "tags": ["Campaigns"],
        "parameters": [
          { "name": "clientid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCampaignRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Campaign created",
            "content": { "application/json": { "schema": { "type": "string" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/campaigns/{campaignid}/send.json": {
      "post": {
        "operationId": "sendCampaign",
        "summary": "Send a draft campaign",
        "tags": ["Campaigns"],
        "parameters": [
          { "$ref": "#/components/parameters/CampaignId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ConfirmationEmail": { "type": "string" },
                  "SendDate": { "type": "string" }
                },
                "required": ["ConfirmationEmail", "SendDate"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Campaign sent" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/campaigns/{campaignid}/sendpreview.json": {
      "post": {
        "operationId": "sendCampaignPreview",
        "summary": "Send campaign preview",
        "tags": ["Campaigns"],
        "parameters": [
          { "$ref": "#/components/parameters/CampaignId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "PreviewRecipients": { "type": "array", "items": { "type": "string" } }
                },
                "required": ["PreviewRecipients"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Preview sent" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/campaigns/{campaignid}/recipients.json": {
      "get": {
        "operationId": "getCampaignRecipients",
        "summary": "Get campaign recipients",
        "tags": ["Campaigns"],
        "parameters": [
          { "$ref": "#/components/parameters/CampaignId" },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "pagesize", "in": "query", "schema": { "type": "integer" } },
          { "name": "orderfield", "in": "query", "schema": { "type": "string" } },
          { "name": "orderdirection", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Recipients",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResult" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/campaigns/{campaignid}/bounces.json": {
      "get": {
        "operationId": "getCampaignBounces",
        "summary": "Get campaign bounces",
        "tags": ["Campaigns"],
        "parameters": [
          { "$ref": "#/components/parameters/CampaignId" },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "pagesize", "in": "query", "schema": { "type": "integer" } },
          { "name": "orderdirection", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Bounces",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResult" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/campaigns/{campaignid}/opens.json": {
      "get": {
        "operationId": "getCampaignOpens",
        "summary": "Get campaign opens",
        "tags": ["Campaigns"],
        "parameters": [
          { "$ref": "#/components/parameters/CampaignId" },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "pagesize", "in": "query", "schema": { "type": "integer" } },
          { "name": "orderdirection", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Opens",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedResult" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/campaigns/{campaignid}/listsandsegments.json": {
      "get": {
        "operationId": "getCampaignListsAndSegments",
        "summary": "Get campaign lists and segments",
        "tags": ["Campaigns"],
        "parameters": [
          { "$ref": "#/components/parameters/CampaignId" }
        ],
        "responses": {
          "200": {
            "description": "Lists and segments",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ListsAndSegments" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lists/{clientid}.json": {
      "post": {
        "operationId": "createList",
        "summary": "Create a list",
        "tags": ["Lists"],
        "parameters": [
          { "name": "clientid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateListRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "List created",
            "content": { "application/json": { "schema": { "type": "string" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lists/{listid}.json": {
      "get": {
        "operationId": "getListDetails",
        "summary": "Get list details",
        "tags": ["Lists"],
        "parameters": [
          { "$ref": "#/components/parameters/ListId" }
        ],
        "responses": {
          "200": {
            "description": "List details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ListDetail" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateList",
        "summary": "Update a list",
        "tags": ["Lists"],
        "parameters": [
          { "$ref": "#/components/parameters/ListId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateListRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "List updated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteList",
        "summary": "Delete a list",
        "tags": ["Lists"],
        "parameters": [
          { "$ref": "#/components/parameters/ListId" }
        ],
        "responses": {
          "200": { "description": "List deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lists/{listid}/stats.json": {
      "get": {
        "operationId": "getListStats",
        "summary": "Get list statistics",
        "tags": ["Lists"],
        "parameters": [
          { "$ref": "#/components/parameters/ListId" }
        ],
        "responses": {
          "200": {
            "description": "List stats",
            "content": { "application/json": { "schema": { "type": "object", "additionalProperties": true } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lists/{listid}/customfields.json": {
      "get": {
        "operationId": "getListCustomFields",
        "summary": "Get list custom fields",
        "tags": ["Lists"],
        "parameters": [
          { "$ref": "#/components/parameters/ListId" }
        ],
        "responses": {
          "200": {
            "description": "Custom fields",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CustomField" } } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createCustomField",
        "summary": "Create a custom field",
        "tags": ["Lists"],
        "parameters": [
          { "$ref": "#/components/parameters/ListId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCustomFieldRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Custom field created",
            "content": { "application/json": { "schema": { "type": "string" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lists/{listid}/customfields/{customfieldkey}.json": {
      "put": {
        "operationId": "updateCustomField",
        "summary": "Update a custom field",
        "tags": ["Lists"],
