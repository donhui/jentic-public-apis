  "components": {
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use API key as username and any value as password, or use site-wide API key"
      },
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://api.createsend.com/oauth",
            "tokenUrl": "https://api.createsend.com/oauth/token",
            "scopes": {}
          }
        }
      }
    },
    "parameters": {
      "ClientId": {
        "name": "clientid",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "CampaignId": {
        "name": "campaignid",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "ListId": {
        "name": "listid",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "ClientSummary": {
        "type": "object",
        "properties": {
          "ClientID": { "type": "string" },
          "Name": { "type": "string" }
        }
      },
      "ClientDetail": {
        "type": "object",
        "properties": {
          "ApiKey": { "type": "string" },
          "BasicDetails": {
            "type": "object",
            "properties": {
              "ClientID": { "type": "string" },
              "CompanyName": { "type": "string" },
              "Country": { "type": "string" },
              "TimeZone": { "type": "string" }
            }
          },
          "BillingDetails": { "type": "object", "additionalProperties": true }
        }
      },
      "CreateClientRequest": {
        "type": "object",
        "properties": {
          "CompanyName": { "type": "string" },
          "Country": { "type": "string" },
          "TimeZone": { "type": "string" }
        },
        "required": ["CompanyName", "Country", "TimeZone"]
      },
      "BillingDetails": {
        "type": "object",
        "properties": {
          "Credits": { "type": "integer" }
        }
      },
      "Admin": {
        "type": "object",
        "properties": {
          "EmailAddress": { "type": "string" },
          "Name": { "type": "string" },
          "Status": { "type": "string" }
        }
      },
      "ListSummary": {
        "type": "object",
        "properties": {
          "ListID": { "type": "string" },
          "Name": { "type": "string" }
        }
      },
      "ListDetail": {
        "type": "object",
        "properties": {
          "ListID": { "type": "string" },
          "Title": { "type": "string" },
          "UnsubscribePage": { "type": "string" },
          "UnsubscribeSetting": { "type": "string" },
          "ConfirmedOptIn": { "type": "boolean" },
          "ConfirmationSuccessPage": { "type": "string" }
        }
      },
      "CreateListRequest": {
        "type": "object",
        "properties": {
          "Title": { "type": "string" },
          "UnsubscribePage": { "type": "string" },
          "UnsubscribeSetting": { "type": "string", "enum": ["AllClientLists", "OnlyThisList"] },
          "ConfirmedOptIn": { "type": "boolean" },
          "ConfirmationSuccessPage": { "type": "string" }
        },
        "required": ["Title"]
      },
      "CustomField": {
        "type": "object",
        "properties": {
          "FieldName": { "type": "string" },
          "Key": { "type": "string" },
          "DataType": { "type": "string" },
          "Options": { "type": "array", "items": { "type": "string" } },
          "VisibleInPreferenceCenter": { "type": "boolean" }
        }
      },
      "CreateCustomFieldRequest": {
        "type": "object",
        "properties": {
          "FieldName": { "type": "string" },
          "DataType": { "type": "string", "enum": ["Text", "Number", "MultiSelectOne", "MultiSelectMany", "Date", "Country", "USState"] },
          "Options": { "type": "array", "items": { "type": "string" } },
          "VisibleInPreferenceCenter": { "type": "boolean" }
        },
        "required": ["FieldName", "DataType"]
      },
      "SegmentSummary": {
        "type": "object",
        "properties": {
          "ListID": { "type": "string" },
          "SegmentID": { "type": "string" },
          "Title": { "type": "string" }
        }
      },
      "SegmentDetail": {
        "type": "object",
        "properties": {
          "SegmentID": { "type": "string" },
          "ListID": { "type": "string" },
          "Title": { "type": "string" },
          "ActiveSubscribers": { "type": "integer" },
          "RuleGroups": { "type": "array", "items": { "type": "object" } }
        }
      },
      "SegmentRequest": {
        "type": "object",
        "properties": {
          "Title": { "type": "string" },
          "RuleGroups": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Rules": { "type": "array", "items": { "$ref": "#/components/schemas/Rule" } }
              }
            }
          }
        },
        "required": ["Title"]
      },
      "Rule": {
        "type": "object",
        "properties": {
          "RuleType": { "type": "string" },
          "Clause": { "type": "string" }
        }
      },
      "Subscriber": {
        "type": "object",
        "properties": {
          "EmailAddress": { "type": "string" },
          "Name": { "type": "string" },
          "MobileNumber": { "type": "string" },
          "Date": { "type": "string" },
          "State": { "type": "string" },
          "CustomFields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Key": { "type": "string" },
                "Value": { "type": "string" }
              }
            }
          },
          "ConsentToTrack": { "type": "string" },
          "ConsentToSendSms": { "type": "string" }
        }
      },
      "SubscriberRequest": {
        "type": "object",
        "properties": {
          "EmailAddress": { "type": "string" },
          "Name": { "type": "string" },
          "MobileNumber": { "type": "string" },
          "CustomFields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Key": { "type": "string" },
                "Value": { "type": "string" }
              }
            }
          },
          "Resubscribe": { "type": "boolean" },
          "RestartSubscriptionBasedAutoresponders": { "type": "boolean" },
          "ConsentToTrack": { "type": "string", "enum": ["Yes", "No", "Unchanged"] },
          "ConsentToSendSms": { "type": "string", "enum": ["Yes", "No", "Unchanged"] }
        },
        "required": ["EmailAddress", "ConsentToTrack"]
      },
      "ImportRequest": {
        "type": "object",
        "properties": {
          "Subscribers": { "type": "array", "items": { "$ref": "#/components/schemas/SubscriberRequest" } },
          "Resubscribe": { "type": "boolean" },
          "QueueSubscriptionBasedAutoResponders": { "type": "boolean" },
          "RestartSubscriptionBasedAutoresponders": { "type": "boolean" }
        },
        "required": ["Subscribers"]
      },
      "ImportResult": {
        "type": "object",
        "properties": {
          "FailureDetails": { "type": "array", "items": { "type": "object" } },
          "TotalUniqueEmailsSubmitted": { "type": "integer" },
          "TotalExistingSubscribers": { "type": "integer" },
          "TotalNewSubscribers": { "type": "integer" },
          "DuplicateEmailsInSubmission": { "type": "array", "items": { "type": "string" } }
        }
      },
      "CreateCampaignRequest": {
        "type": "object",
        "properties": {
          "Name": { "type": "string" },
          "Subject": { "type": "string" },
          "FromName": { "type": "string" },
          "FromEmail": { "type": "string" },
          "ReplyTo": { "type": "string" },
          "HtmlUrl": { "type": "string" },
          "TextUrl": { "type": "string" },
          "ListIDs": { "type": "array", "items": { "type": "string" } },
          "SegmentIDs": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["Name", "Subject", "FromName", "FromEmail", "ReplyTo", "HtmlUrl", "ListIDs"]
      },
      "ListsAndSegments": {
        "type": "object",
        "properties": {
          "Lists": { "type": "array", "items": { "$ref": "#/components/schemas/ListSummary" } },
          "Segments": { "type": "array", "items": { "$ref": "#/components/schemas/SegmentSummary" } }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "TemplateID": { "type": "string" },
          "Name": { "type": "string" },
          "PreviewURL": { "type": "string" },
          "ScreenshotURL": { "type": "string" }
        }
      },
      "CreateTemplateRequest": {
        "type": "object",
        "properties": {
          "Name": { "type": "string" },
          "HtmlPageURL": { "type": "string" },
          "ZipFileURL": { "type": "string" }
        },
        "required": ["Name", "HtmlPageURL"]
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "WebhookID": { "type": "string" },
          "Events": { "type": "array", "items": { "type": "string" } },
          "Url": { "type": "string" },
          "Status": { "type": "string" },
          "PayloadFormat": { "type": "string" }
        }
      },
      "CreateWebhookRequest": {
        "type": "object",
        "properties": {
          "Events": { "type": "array", "items": { "type": "string", "enum": ["Subscribe", "Deactivate", "Update"] } },
          "Url": { "type": "string" },
          "PayloadFormat": { "type": "string", "enum": ["json", "xml"] }
        },
        "required": ["Events", "Url", "PayloadFormat"]
      },
      "SmartEmailSummary": {
        "type": "object",
        "properties": {
          "ID": { "type": "string" },
          "Name": { "type": "string" },
          "CreatedAt": { "type": "string" },
          "Status": { "type": "string" }
        }
      },
      "SmartEmailDetail": {
        "type": "object",
        "properties": {
          "SmartEmailID": { "type": "string" },
          "CreatedAt": { "type": "string" },
          "Status": { "type": "string" },
          "Name": { "type": "string" },
          "Properties": { "type": "object", "additionalProperties": true },
          "AddRecipientsToList": { "type": "string" }
        }
      },
      "SendSmartEmailRequest": {
        "type": "object",
        "properties": {
          "To": { "type": "array", "items": { "type": "string" } },
          "CC": { "type": "array", "items": { "type": "string" }, "nullable": true },
          "BCC": { "type": "array", "items": { "type": "string" }, "nullable": true },
          "Attachments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "Content": { "type": "string" },
                "Name": { "type": "string" },
                "Type": { "type": "string" }
              }
            }
          },
          "Data": { "type": "object", "additionalProperties": true },
          "ConsentToTrack": { "type": "string", "enum": ["Yes", "No", "Unchanged"] }
        },
        "required": ["To", "ConsentToTrack"]
      },
      "SendClassicEmailRequest": {
        "type": "object",
        "properties": {
          "Subject": { "type": "string" },
          "From": { "type": "string" },
          "ReplyTo": { "type": "string" },
          "To": { "type": "array", "items": { "type": "string" } },
          "CC": { "type": "array", "items": { "type": "string" } },
          "BCC": { "type": "array", "items": { "type": "string" }, "nullable": true },
          "Html": { "type": "string" },
          "Text": { "type": "string" },
          "TrackOpens": { "type": "boolean" },
          "TrackClicks": { "type": "boolean" },
          "InlineCSS": { "type": "boolean" },
          "Group": { "type": "string" },
          "ConsentToTrack": { "type": "string", "enum": ["Yes", "No", "Unchanged"] }
        },
        "required": ["Subject", "From", "To", "ConsentToTrack"]
      },
      "TransactionalSendResult": {
        "type": "object",
        "properties": {
          "Status": { "type": "string" },
          "MessageID": { "type": "string" },
          "Recipient": { "type": "string" }
        }
      },
      "TransactionalStats": {
        "type": "object",
        "properties": {
          "Sent": { "type": "integer" },
          "Bounces": { "type": "integer" },
          "Delivered": { "type": "integer" },
          "Opened": { "type": "integer" },
          "Clicked": { "type": "integer" }
        }
      },
      "TransactionalMessage": {
        "type": "object",
        "properties": {
          "MessageID": { "type": "string" },
          "Status": { "type": "string" },
          "SentAt": { "type": "string" },
          "Recipient": { "type": "string" },
          "From": { "type": "string" },
          "Subject": { "type": "string" },
          "TotalOpens": { "type": "integer" },
          "TotalClicks": { "type": "integer" },
          "CanBeResent": { "type": "boolean" },
          "Group": { "type": "string" },
          "SmartEmailID": { "type": "string" }
        }
      },
      "JourneySummary": {
        "type": "object",
        "properties": {
          "ListID": { "type": "string" },
          "JourneyID": { "type": "string" },
          "Name": { "type": "string" },
          "Status": { "type": "string" }
        }
      },
      "JourneyDetail": {
        "type": "object",
        "properties": {
          "JourneyID": { "type": "string" },
          "Name": { "type": "string" },
          "TriggerType": { "type": "string" },
          "Status": { "type": "string" },
          "Emails": { "type": "array", "items": { "type": "object" } }
        }
      },
      "PagedResult": {
        "type": "object",
        "properties": {
          "Results": { "type": "array", "items": { "type": "object" } },
          "ResultsOrderedBy": { "type": "string" },
          "OrderDirection": { "type": "string" },
          "PageNumber": { "type": "integer" },
          "PageSize": { "type": "integer" },
          "RecordsOnThisPage": { "type": "integer" },
          "TotalNumberOfRecords": { "type": "integer" },
          "NumberOfPages": { "type": "integer" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "Code": { "type": "integer" },
          "Message": { "type": "string" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing authentication",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  }
}