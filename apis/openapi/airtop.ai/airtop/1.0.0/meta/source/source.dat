          },
          "waitUntil": {
            "$ref": "#/components/schemas/type_:BrowserWaitNavigationConfigWaitUntil",
            "description": "The condition to wait for the navigation to complete. Defaults to 'load'."
          }
        },
        "title": "BrowserWaitNavigationConfig"
      },
