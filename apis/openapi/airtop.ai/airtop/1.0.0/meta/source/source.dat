        "properties": {
          "data": {
            "$ref": "#/components/schemas/type_:WindowsWithMeta"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/type_:Issue"
            }
          },
          "meta": {
