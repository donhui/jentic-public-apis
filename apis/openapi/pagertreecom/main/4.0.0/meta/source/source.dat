          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "commentOnAlert",
        "summary": "Comment on an alert",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["body"],
                "properties": {
                  "body": {
                    "type": "string",
                    "description": "Comment text."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comment added"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
