          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "urgency": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "integration_type": {
            "type": "object",
            "description": "Integration type details."
          },
          "options": {
            "type": "object",
            "description": "Integration-specific options."
          },
          "account_user_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "router_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "team_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "IntegrationCreateRequest": {
        "type": "object",
        "required": ["name", "urgency", "integration_type_id"],
        "properties": {
          "name": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "urgency": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "integration_type_id": {
            "type": "string",
