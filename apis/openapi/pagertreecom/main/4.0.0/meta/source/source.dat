      }
    },
    "/schedules/{id}/events": {
      "get": {
        "operationId": "listScheduleEvents",
        "summary": "List schedule events",
        "description": "Retrieves events for a schedule with optional time filtering.",
        "tags": ["Schedules"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_datetime",
            "in": "query",
            "description": "Filter events starting after this time.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "end_datetime",
            "in": "query",
            "description": "Filter events ending before this time.",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
