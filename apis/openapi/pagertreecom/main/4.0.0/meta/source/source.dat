  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key from your User Settings page. Use as: Authorization: Bearer <api_key>"
      }
    },
    "schemas": {
      "Alert": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tag_list": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "urgency": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "status": {
            "type": "string",
            "description": "Alert status (e.g., open, acknowledged, resolved, dropped, suppressed)."
          },
          "source_id": {
            "type": "string"
          },
          "source_type": {
            "type": "string"
          },
          "source_log_id": {
            "type": "string"
          },
          "thirdparty_id": {
            "type": "string"
          },
          "acknowledged_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "resolved_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "dedup_keys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "incident": {
                "type": "boolean"
              },
              "incident_severity": {
                "type": "string",
                "enum": ["SEV-1", "SEV-2", "SEV-3", "SEV-4", "SEV-5", "SEV-UNKNOWN"]
              },
              "incident_message": {
                "type": "string"
              }
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AlertCreateRequest": {
        "type": "object",
        "required": ["title", "urgency", "destination_team_ids"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Alert title."
          },
          "description": {
            "type": "string",
            "description": "Alert description."
          },
          "urgency": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "Alert urgency level."
          },
          "meta": {
            "type": "object",
            "properties": {
              "incident": {
                "type": "boolean",
                "description": "Whether this is an incident."
              },
              "incident_severity": {
                "type": "string",
                "enum": ["SEV-1", "SEV-2", "SEV-3", "SEV-4", "SEV-5", "SEV-UNKNOWN"]
              },
              "incident_message": {
                "type": "string"
              }
            }
          },
          "destination_team_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Team IDs to route the alert to (at least one required)."
          },
          "destination_router_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "destination_account_user_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "escalation_policy_id": {
            "type": "string",
            "nullable": true
          },
          "schedule_id": {
            "type": "string",
            "nullable": true
          },
          "member_account_user_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "admin_account_user_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "drop_notifications": {
            "type": "string",
            "description": "Drop notification setting."
          },
          "handoff_notifications": {
            "type": "string",
            "description": "Handoff notification setting."
          },
          "notes": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TeamCreateRequest": {
        "type": "object",
        "required": ["name", "member_account_user_ids", "admin_account_user_ids"],
