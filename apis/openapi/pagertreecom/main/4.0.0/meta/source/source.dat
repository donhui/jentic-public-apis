            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "At least one member required."
          },
          "admin_account_user_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "At least one admin required."
          },
          "drop_notification_account_user_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "handoff_notification_account_user_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ScheduleRequest": {
        "type": "object",
