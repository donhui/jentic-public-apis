          },
          "account_user_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "router_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "team_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "time_zone": {
            "type": "string"
          },
          "preferred_language": {
            "type": "string"
          },
          "last_sign_in_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "notify_push": {
            "type": "boolean"
          },
          "notify_email": {
            "type": "boolean"
          },
          "notify_sms": {
            "type": "boolean"
          },
          "notify_voice": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UserCreateRequest": {
        "type": "object",
        "required": ["name", "email"],
        "properties": {
