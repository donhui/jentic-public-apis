            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "notify_push": {
            "type": "boolean"
          },
          "notify_email": {
            "type": "boolean"
          },
          "notify_sms": {
            "type": "boolean"
          },
          "notify_voice": {
