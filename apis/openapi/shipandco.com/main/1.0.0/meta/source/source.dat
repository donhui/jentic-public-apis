    "/tracking/{carrier}/{trackingNumber}": {
      "get": {
        "operationId": "getTracking",
        "summary": "Get tracking information",
        "description": "Obtain tracking information from the carrier.",
        "tags": ["Tracking"],
        "parameters": [
          {
            "name": "carrier",
            "in": "path",
            "required": true,
            "description": "Carrier name",
            "schema": { "type": "string" }
          },
          {
            "name": "trackingNumber",
            "in": "path",
            "required": true,
            "description": "Tracking number",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Tracking information",
            "content": {
              "application/json": {
