      }
    },
    "/carriers/{id}": {
      "put": {
        "operationId": "updateCarrier",
        "summary": "Update a carrier",
        "description": "Modify carrier settings.",
        "tags": ["Carriers"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
