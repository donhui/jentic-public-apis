      },
      "delete": {
        "operationId": "deleteNegotiatedRates",
        "summary": "Delete negotiated rates",
        "description": "Remove uploaded negotiated rates.",
        "tags": ["NegotiatedRates"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Carrier ID",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Rates deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
