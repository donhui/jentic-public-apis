            "description": "Sub-user ID",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Sub-user deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "x-access-token",
        "description": "API token for authentication"
      }
    },
    "schemas": {
      "Address": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "full_name": { "type": "string" },
          "company": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "country": { "type": "string" },
          "zip": { "type": "string" },
          "state": { "type": "string" },
          "city": { "type": "string" },
          "address1": { "type": "string" },
          "address2": { "type": "string" }
        }
      },
      "CreateAddressRequest": {
        "type": "object",
        "required": ["full_name", "country", "address1"],
        "properties": {
          "full_name": { "type": "string" },
          "company": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "country": { "type": "string" },
          "zip": { "type": "string" },
          "state": { "type": "string" },
          "city": { "type": "string" },
          "address1": { "type": "string" },
          "address2": { "type": "string" }
        }
      },
      "Parcel": {
        "type": "object",
        "properties": {
          "weight": { "type": "number" },
          "width": { "type": "number" },
          "height": { "type": "number" },
          "depth": { "type": "number" }
        }
      },
      "CreateShipmentRequest": {
        "type": "object",
        "required": ["to_address", "from_address", "parcels", "setup"],
        "properties": {
          "setup": {
            "type": "object",
            "properties": {
              "carrier": { "type": "string" },
              "service": { "type": "string" },
              "currency": { "type": "string" }
            }
          },
          "to_address": { "$ref": "#/components/schemas/Address" },
          "from_address": { "$ref": "#/components/schemas/Address" },
          "parcels": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Parcel" }
          },
          "products": {
            "type": "array",
            "items": { "type": "object" }
          },
          "customs": { "type": "object" }
        }
      },
      "Shipment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "state": { "type": "string" },
          "tracking_numbers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "label_url": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "to_address": { "$ref": "#/components/schemas/Address" },
          "from_address": { "$ref": "#/components/schemas/Address" },
          "parcels": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Parcel" }
          }
        }
      },
      "RateRequest": {
        "type": "object",
        "required": ["to_address", "from_address", "parcels"],
        "properties": {
          "setup": { "type": "object" },
          "to_address": { "$ref": "#/components/schemas/Address" },
          "from_address": { "$ref": "#/components/schemas/Address" },
          "parcels": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Parcel" }
          },
          "products": {
            "type": "array",
            "items": { "type": "object" }
          },
          "customs": { "type": "object" }
        }
      },
      "Rate": {
        "type": "object",
        "properties": {
          "carrier": { "type": "string" },
          "service": { "type": "string" },
          "price": { "type": "number" },
          "currency": { "type": "string" },
          "surcharges": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "Carrier": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "settings": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateCarrierRequest": {
        "type": "object",
        "required": ["type", "credentials"],
        "properties": {
          "type": { "type": "string" },
          "credentials": { "type": "object" },
          "settings": { "type": "object" }
        }
      },
      "UpdateCarrierRequest": {
        "type": "object",
        "properties": {
          "settings": { "type": "object" }
        }
      },
      "NegotiatedRatesRequest": {
        "type": "object",
        "required": ["rates"],
        "properties": {
          "rates": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "TrackingInfo": {
        "type": "object",
        "properties": {
          "carrier": { "type": "string" },
          "tracking_number": { "type": "string" },
          "status": { "type": "string" },
          "history": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": { "type": "string" },
                "date": { "type": "string", "format": "date-time" },
                "location": { "type": "string" }
              }
            }
          }
        }
      },
      "Warehouse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "CreateWarehouseRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "address": { "$ref": "#/components/schemas/Address" }
        }
      },
      "File": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["signature", "logo"] },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "UploadFileRequest": {
        "type": "object",
        "required": ["file", "type"],
        "properties": {
          "file": { "type": "string", "description": "Base64 encoded file content" },
          "type": { "type": "string", "enum": ["signature", "logo"] }
        }
      },
      "SubUser": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "api_token": { "type": "string" },
          "contact": { "type": "object" }
        }
      },
      "CreateSubUserRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string" },
          "api_token": { "type": "string" },
          "contact": { "type": "object" }
        }
      },
      "SuccessMessage": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}