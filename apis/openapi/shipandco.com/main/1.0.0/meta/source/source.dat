          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteCarrier",
        "summary": "Delete a carrier",
        "description": "Remove a carrier account.",
        "tags": ["Carriers"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Carrier ID",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Carrier deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessMessage" }
