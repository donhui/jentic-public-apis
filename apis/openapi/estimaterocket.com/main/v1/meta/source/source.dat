    "/api/v1/projects": {
      "get": {
        "summary": "Retrieve Projects",
        "tags": [
          "Projects"
        ],
        "description": "Retrieve all projects for the signed-in account. You can also search for projects by specifying a project name parameter.",
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "projects": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Project"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "filter[name]",
            "in": "query",
            "description": "Project Name (optional)",
            "schema": {
              "type": "string"
            }
          }
        ]
      },
      "post": {
        "summary": "Create a project",
        "tags": [
          "Projects"
        ],
        "description": "Create a new project",
        "parameters": [],
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "project": {
                      "$ref": "#/components/schemas/Project"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "project": {
                    "type": "object",
                    "properties": {
                      "billing_address1": {
                        "type": "string"
                      },
                      "billing_city": {
                        "type": "string"
                      },
                      "billing_state": {
                        "type": "string"
                      },
                      "billing_zip": {
                        "type": "string"
                      },
                      "billing_same_as_location": {
                        "type": "boolean"
                      },
                      "owner_id": {
                        "type": "string"
                      },
                      "type": {
                        "type": "string"
                      },
                      "client_id": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "billing_address1",
                      "billing_city",
                      "billing_state",
                      "billing_zip",
                      "owner_id",
                      "type",
                      "client_id"
                    ]
                  }
                }
              },
              "examples": {
                "Create Project Request": {
                  "summary": "Valid project create request",
                  "value": {
                    "project": {
                      "billing_address1": "632 Forrest Prairie",
                      "billing_city": "Lake Scott",
                      "billing_state": "AK",
                      "billing_zip": "22771-8374",
                      "billing_same_as_location": true,
                      "owner_id": "<owner_id>",
                      "type": "Pending",
                      "client_id": "<client_id>"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
