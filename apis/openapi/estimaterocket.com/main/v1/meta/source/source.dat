            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "payment": {
                    "$ref": "#/components/schemas/Payment"
                  },
                  "required": [
                    "invoice_id",
                    "date",
                    "amount"
                  ]
                }
              },
              "examples": {
                "create payment request": {
                  "summary": "Valid payment create request",
                  "value": {
                    "payment": {
                      "invoice_id": "<invoice_id>",
                      "date": "2024-03-25",
                      "amount": 100.0,
                      "reference": "Payment for services",
                      "notes": "Additional notes about the payment"
                    }
                  }
                }
              }
            }
          }
        }
