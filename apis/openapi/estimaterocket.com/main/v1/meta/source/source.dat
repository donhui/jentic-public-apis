{
  "openapi": "3.0.3",
  "info": {
    "title": "API V1",
    "version": "v1",
    "x-jentic-source-url": "https://estimate-rocket-api.herokuapp.com/api/openapi.yaml"
  },
  "paths": {
    "/api/v1/assignments": {
      "get": {
        "summary": "Retrieve Assignments",
        "tags": [
          "Assignments"
        ],
        "description": "Retrieve all assignments for the signed-in account. You can also search for assignments for a specific project by specifying a project id parameter.",
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "assignments": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Assignment"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "filter[project_id]",
            "in": "query",
            "description": "Project ID (optional)",
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/api/v1/assignments/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Assignment ID",
          "required": true,
          "schema": {
            "type": "string"
          }
        }
      ],
      "get": {
        "summary": "Retrieve an assignment by ID",
        "tags": [
          "Assignments"
        ],
        "description": "Retrieve an assignment by its ID",
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "assignment": {
                      "$ref": "#/components/schemas/Assignment"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/clients": {
      "get": {
        "summary": "List all clients",
        "tags": [
          "Clients"
        ],
        "description": "Retrieve a list of clients",
        "parameters": [
          {
            "name": "filter[email]",
            "in": "query",
            "description": "Client Email (optional)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "clients": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Client"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create client",
        "tags": [
          "Clients"
        ],
        "description": "Create new client",
        "parameters": [],
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "client": {
                      "$ref": "#/components/schemas/Client"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "client": {
                    "$ref": "#/components/schemas/Client"
                  },
                  "required": [
                    "address1",
                    "city",
                    "first_name",
                    "last_name",
                    "state",
                    "zip"
                  ]
                }
              },
              "examples": {
                "create client request": {
                  "summary": "valid client create request",
                  "value": {
                    "client": {
                      "address1": "576 Ela Fields",
                      "address2": null,
                      "city": "New Sade",
                      "company_name": "Dooley, Weber and Wisozk",
                      "email": null,
                      "first_name": "Janina",
                      "internal_notes": "Example Client created by Estimate Rocket API.",
                      "last_name": "Walker",
                      "middle_name": null,
                      "no_email": true,
                      "no_phone": true,
                      "phone": null,
                      "source": null,
                      "state": "CT",
                      "tags": [
                        "#foundation-repair",
                        "#concrete"
                      ],
                      "tax_rate": 0,
                      "zip": "13225-7007",
                      "owner_id": "<owner_id>"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/clients/{id}": {
      "parameters": [
        {
