    "/login": {
      "post": {
        "summary": "Log in",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "parameters": [],
        "responses": {
          "302": {
            "description": "redirects on successful login"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              },
              "examples": {
                "0": {
                  "summary": "Log in",
                  "value": {
                    "email": "",
                    "password": ""
                  }
                }
              }
            }
          }
        }
      }
    },
    "api/v1/webhook_subscriptions": {
      "post": {
        "summary": "Subscribe to a webhook",
        "tags": [
          "Webhook Subscriptions"
        ],
        "description": "Creates a webhook subscription for specified events",
        "parameters": [],
        "responses": {
          "200": {
            "description": "successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "webhook_subscription": {
                      "$ref": "#/components/schemas/WebhookSubscription"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "webhook_subscription": {
                    "type": "object",
                    "properties": {
                      "event_type": {
                        "type": "string"
                      },
                      "callback_url": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "event_type",
                      "callback_url"
                    ]
                  }
                }
              },
              "examples": {
                "Create Webhook Subscription Request": {
                  "summary": "Valid request to create a webhook subscription",
                  "value": {
                    "webhook_subscription": {
                      "event_type": "proposal_status_updated",
                      "callback_url": "https://new.url.com/hooks/catch/123"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Unsubscribe from a webhook",
        "tags": [
          "Webhook Subscriptions"
        ],
        "description": "Unsubscribes from a webhook for the specified event_type and callback_url",
        "parameters": [
          {
            "name": "event_type",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "proposal_status_updated"
            }
          },
          {
            "name": "callback_url",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "https://new.url.com/hooks/catch/123/"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "successful"
          },
          "404": {
            "description": "not found"
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://estimate-rocket-api.herokuapp.com/"
    }
  ],
  "security": [
    {
      "oauth": [
        "read",
        "write"
      ]
    }
  ],
  "components": {
    "securitySchemes": {
      "oauth": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://estimate-rocket-api.herokuapp.com/oauth/authorize",
            "tokenUrl": "https://estimate-rocket-api.herokuapp.com/oauth/token",
            "scopes": {
              "read": "Grants read-only access",
              "write": "Grants write access"
            }
          }
        }
      }
    },
    "schemas": {
      "Assignment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "project": {
            "$ref": "#/components/schemas/Project"
          },
          "project_state_name": {
            "type": "string",
            "nullable": true
          },
          "project_state_type": {
            "type": "string",
            "nullable": true
          },
          "assignee_id": {
            "type": "string"
          },
          "assigner_id": {
            "type": "string"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "start_time": {
            "type": "string",
            "format": "time",
            "nullable": true
          },
          "active": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date_time"
          },
          "updated_at": {
            "type": "string",
            "format": "date_time"
          },
          "note_id": {
            "type": "string",
            "nullable": true
          },
          "project_action_id": {
            "type": "string"
          },
          "deleted_at": {
            "type": "string",
            "format": "date_time",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "completed_at": {
            "type": "string",
            "format": "date_time",
            "nullable": true
          },
          "scheduled": {
            "type": "boolean"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "end_time": {
            "type": "string",
            "format": "time",
            "nullable": true
          },
          "address1": {
            "type": "string",
            "nullable": true
          },
          "address2": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "state": {
            "type": "string",
            "nullable": true
          },
          "zip": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string",
            "nullable": true
          },
          "latitude": {
            "type": "number",
            "format": "float",
            "nullable": true
          },
          "longitude": {
            "type": "number",
            "format": "float",
            "nullable": true
          },
          "confirmed": {
            "type": "boolean",
            "nullable": true
          },
          "todo_record": {
            "type": "boolean",
            "nullable": true
          }
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "address1": {
            "type": "string"
          },
          "address2": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "first_name": {
            "type": "string"
          },
          "internal_notes": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "owner_id": {
            "type": "string"
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "source": {
            "type": "string",
            "nullable": true
          },
          "state": {
            "type": "string"
          },
          "tax_rate": {
            "type": "number"
          },
          "zip": {
            "type": "string"
          }
        }
