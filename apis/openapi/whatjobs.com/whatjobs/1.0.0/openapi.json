{
  "openapi": "3.0.3",
  "info": {
    "title": "WhatJobs Feed API",
    "description": "WhatJobs FeedAPI is a lightweight REST API that allows publishers to search and retrieve job listings. It responds to HTTP requests with JSON or XML and supports bulk data communication for job data synchronization.",
    "version": "1.0.0",
    "contact": {
      "name": "WhatJobs Publisher Support",
      "url": "https://www.whatjobs.com/contact/publisher"
    },
    "x-jentic-source-url": "https://www.whatjobs.com/affiliates"
  },
  "servers": [
    {
      "url": "https://api.whatjobs.com/api",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Jobs",
      "description": "Job search and retrieval operations"
    }
  ],
  "paths": {
    "/jobs/search": {
      "get": {
        "operationId": "searchJobs",
        "summary": "Search for jobs",
        "description": "Search for job listings matching the specified criteria. Returns results in JSON or XML format.",
        "tags": ["Jobs"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search keywords or job title.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Location to search for jobs (city, state, or country).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "description": "Search radius in miles from the specified location.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results per page.",
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order for results.",
            "schema": {
              "type": "string",
              "enum": ["relevance", "date"]
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format.",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          },
          {
            "name": "country",
            "in": "query",
            "description": "Country code to filter results (e.g. US, GB, AU).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobSearchResponse"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/JobSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid or missing API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}": {
      "get": {
        "operationId": "getJobDetails",
        "summary": "Get job details",
        "description": "Retrieve detailed information about a specific job listing.",
        "tags": ["Jobs"],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "description": "Unique job identifier.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Response format.",
            "schema": {
              "type": "string",
              "enum": ["json", "xml"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful job details response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Job not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key obtained through the WhatJobs publisher program. Contact publisher support for access."
      }
    },
    "schemas": {
      "JobSearchResponse": {
        "type": "object",
        "properties": {
          "totalResults": {
            "type": "integer",
            "description": "Total number of matching jobs."
          },
          "page": {
            "type": "integer",
            "description": "Current page number."
          },
          "pageSize": {
            "type": "integer",
            "description": "Number of results per page."
          },
          "jobs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique job identifier."
          },
          "title": {
            "type": "string",
            "description": "Job title."
          },
          "company": {
            "type": "string",
            "description": "Employer name."
          },
          "description": {
            "type": "string",
            "description": "Job description."
          },
          "location": {
            "type": "string",
            "description": "Job location."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the full job listing."
          },
          "salary": {
            "type": "string",
            "nullable": true,
            "description": "Salary information if available."
          },
          "jobType": {
            "type": "string",
            "nullable": true,
            "description": "Employment type (full-time, part-time, contract, etc.)."
          },
          "datePosted": {
            "type": "string",
            "format": "date-time",
            "description": "Date the job was posted."
          },
          "source": {
            "type": "string",
            "description": "Source of the job listing."
          },
          "country": {
            "type": "string",
            "description": "Country code."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message."
          },
          "code": {
            "type": "integer",
            "description": "Error code."
          }
        }
      }
    }
  }
}
