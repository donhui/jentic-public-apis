{
  "openapi": "3.0.3",
  "info": {
    "title": "NatureServe Explorer REST API",
    "version": "1.0.0",
    "description": "The NatureServe Explorer API provides access to conservation status data for species and ecosystems across North America, including taxonomy, rankings, and geographic distribution information.",
    "x-jentic-source-url": "https://explorer.natureserve.org/api-docs/"
  },
  "servers": [
    {
      "url": "https://explorer.natureserve.org"
    }
  ],
  "paths": {
    "/api/data/taxon/{ouSeqUid}": {
      "get": {
        "operationId": "getTaxon",
        "summary": "Get taxon by Element Global UID",
        "description": "Retrieve detailed taxon information by Element Global UID, including classification, conservation status, and subnational data.",
        "tags": ["Taxon"],
        "parameters": [
          {
            "name": "ouSeqUid",
            "in": "path",
            "required": true,
            "description": "The taxon's Element Global UID.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with taxon details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Taxon" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Taxon not found"
          }
        }
      }
    },
    "/api/data/speciesSearch": {
      "post": {
        "operationId": "searchSpecies",
        "summary": "Search species",
        "description": "Search for species using various criteria including text, status, location, and taxonomy filters.",
        "tags": ["Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SpeciesSearchCriteria" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/data/ecosystemSearch": {
      "post": {
        "operationId": "searchEcosystems",
        "summary": "Search ecosystems",
        "description": "Search for ecosystem records with hierarchy filters.",
        "tags": ["Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EcosystemSearchCriteria" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/data/combinedSearch": {
      "post": {
        "operationId": "combinedSearch",
        "summary": "Combined search",
        "description": "Search species and ecosystems simultaneously.",
        "tags": ["Search"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CombinedSearchCriteria" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful search response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/data/taxonSearch": {
      "get": {
        "operationId": "getTaxonByAlternateKey",
        "summary": "Get taxon by alternate key",
        "description": "Retrieve taxon information using an alternate key.",
        "tags": ["Taxon"],
        "parameters": [
          {
            "name": "scientificName",
            "in": "query",
            "description": "Scientific name to search for.",
            "schema": { "type": "string" }
          },
          {
            "name": "nsxUrl",
            "in": "query",
            "description": "NatureServe Explorer URL identifier.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with taxon details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Taxon" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": { "description": "Taxon not found" }
        }
      }
    },
    "/api/data/ecosystemHierarchy": {
      "get": {
        "operationId": "getEcosystemHierarchy",
        "summary": "Get ecosystem hierarchy",
        "description": "Retrieve the ecosystem classification hierarchy.",
        "tags": ["Reference Data"],
        "responses": {
          "200": {
            "description": "Successful response with hierarchy data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Ecosystem hierarchy tree structure."
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/data/export": {
      "post": {
        "operationId": "exportSearchResults",
        "summary": "Export search results",
        "description": "Export search results in a specified format.",
        "tags": ["Export"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CombinedSearchCriteria" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Export job initiated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "jobId": { "type": "string", "description": "Identifier for the export job." }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/data/job/{jobId}": {
      "get": {
        "operationId": "getJobStatus",
        "summary": "Get job status",
        "description": "Check the status of an asynchronous export job.",
        "tags": ["Export"],
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "description": "The job identifier.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "jobId": { "type": "string" },
                    "status": { "type": "string" },
                    "downloadUrl": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": { "description": "Job not found" }
        }
      }
    },
    "/api/data/nations": {
      "get": {
        "operationId": "getNations",
        "summary": "Get nations",
        "description": "Retrieve list of nations for use in search criteria.",
        "tags": ["Reference Data"],
        "responses": {
          "200": {
            "description": "List of nations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DomainValue" }
                }
              }
            }
          }
        }
      }
    },
    "/api/data/subnations": {
      "get": {
        "operationId": "getSubnations",
        "summary": "Get subnations",
        "description": "Retrieve list of subnations (states/provinces) for use in search criteria.",
        "tags": ["Reference Data"],
        "parameters": [
          {
            "name": "nationCode",
            "in": "query",
            "description": "Filter subnations by nation code.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of subnations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DomainValue" }
                }
              }
            }
          }
        }
      }
    },
    "/api/data/informalTaxonomy": {
      "get": {
        "operationId": "getInformalTaxonomy",
        "summary": "Get informal taxonomy",
        "description": "Retrieve informal taxonomy categories.",
        "tags": ["Reference Data"],
        "responses": {
          "200": {
            "description": "Informal taxonomy list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DomainValue" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Taxon": {
        "type": "object",
        "properties": {
          "uniqueId": { "type": "string", "description": "Element Global UID." },
          "elcode": { "type": "string", "description": "Element code." },
          "scientificName": { "type": "string", "description": "Scientific name of the taxon." },
          "primaryCommonName": { "type": "string", "description": "Primary common name." },
          "roundedGRank": { "type": "string", "description": "Rounded global rank." },
          "nations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/NationInfo" },
            "description": "Nation-level conservation data."
          },
          "classification": {
            "type": "object",
            "properties": {
              "kingdom": { "type": "string" },
              "phylum": { "type": "string" },
              "taxclass": { "type": "string" },
              "taxorder": { "type": "string" },
              "family": { "type": "string" },
              "genus": { "type": "string" }
            }
          },
          "speciesGlobal": {
            "type": "object",
            "properties": {
              "rank": { "type": "string" },
              "rankReviewDate": { "type": "string" },
              "roundedRank": { "type": "string" }
            }
          }
        }
      },
      "NationInfo": {
        "type": "object",
        "properties": {
          "nationCode": { "type": "string" },
          "nationName": { "type": "string" },
          "nationalRank": { "type": "string" },
          "subnations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "subnationCode": { "type": "string" },
                "subnationName": { "type": "string" },
                "subnationalRank": { "type": "string" }
              }
            }
          }
        }
      },
      "SpeciesSearchCriteria": {
        "type": "object",
        "properties": {
          "criteriaType": { "type": "string", "enum": ["species"] },
          "textCriteria": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "paramType": { "type": "string", "enum": ["quickSearch", "scientificName", "commonName"] },
                "searchToken": { "type": "string" }
              }
            }
          },
          "statusCriteria": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "paramType": { "type": "string", "enum": ["globalRank", "nationalRank", "subnationalRank", "usesa", "cosewic", "sara"] },
                "statusValues": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "locationCriteria": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "paramType": { "type": "string", "enum": ["nation", "subnation"] },
                "nation": { "type": "string" },
                "subnation": { "type": "string" }
              }
            }
          },
          "pagingOptions": { "$ref": "#/components/schemas/PagingOptions" }
        }
      },
      "EcosystemSearchCriteria": {
        "type": "object",
        "properties": {
          "criteriaType": { "type": "string", "enum": ["ecosystem"] },
          "textCriteria": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "paramType": { "type": "string", "enum": ["quickSearch"] },
                "searchToken": { "type": "string" }
              }
            }
          },
          "locationCriteria": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "paramType": { "type": "string" },
                "nation": { "type": "string" },
                "subnation": { "type": "string" }
              }
            }
          },
          "pagingOptions": { "$ref": "#/components/schemas/PagingOptions" }
        }
      },
      "CombinedSearchCriteria": {
        "type": "object",
        "properties": {
          "criteriaType": { "type": "string", "enum": ["combined"] },
          "textCriteria": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "paramType": { "type": "string" },
                "searchToken": { "type": "string" }
              }
            }
          },
          "statusCriteria": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "paramType": { "type": "string" },
                "statusValues": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "locationCriteria": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "paramType": { "type": "string" },
                "nation": { "type": "string" },
                "subnation": { "type": "string" }
              }
            }
          },
          "pagingOptions": { "$ref": "#/components/schemas/PagingOptions" }
        }
      },
      "PagingOptions": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "description": "Page number (0-based)." },
          "numberOfItemsPerPage": { "type": "integer", "description": "Items per page." }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SearchResult" }
          },
          "totalResults": { "type": "integer" },
          "resultPages": { "type": "integer" }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "uniqueId": { "type": "string" },
          "elcode": { "type": "string" },
          "scientificName": { "type": "string" },
          "primaryCommonName": { "type": "string" },
          "roundedGRank": { "type": "string" },
          "recordType": { "type": "string" }
        }
      },
      "DomainValue": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "Error message." },
          "status": { "type": "integer", "description": "HTTP status code." }
        }
      }
    }
  }
}