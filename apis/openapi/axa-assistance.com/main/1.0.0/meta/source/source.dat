                                          "maxLength": 50,
                                          "example": "4234BMW"
                                        },
                                        "brand": {
                                          "description": "Brand name",
                                          "type": "string",
                                          "maxLength": 50,
                                          "example": "Volkswagen"
                                        },
                                        "model": {
                                          "description": "Model",
                                          "type": "string",
                                          "maxLength": 50,
                                          "example": "Passat SW"
                                        },
