    "/sales/v2/individual/travel/orders/{order_id}/communication_requests": {
      "post": {
        "summary": "Sends a request for a communication with the customer.",
        "description": "Cf. summary",
        "x-business-category": "TRAVEL",
        "parameters": [
          {
            "name": "order_id",
