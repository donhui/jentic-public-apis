    "/sales/v2/individual/travel/policies": {
      "get": {
        "summary": "Retrieve travel customer policy summaries.",
        "description": "Cf. summary",
        "x-business-category": "TRAVEL",
        "parameters": [
          {
            "name": "accept-language",
            "in": "header",
            "required": false,
            "description": "Accepted language, IANA language codification. If language not managed, \"en\" will be used by default.",
            "schema": {
              "type": "string",
              "example": "en",
              "maxLength": 5
            }
          },
          {
            "name": "x-axa-context",
            "in": "header",
            "required": false,
            "description": "The token is formatted as a JWT and provided by the partner.",
            "schema": {
              "type": "string",
              "format": "JSON Web Token RFC 7519",
              "maxLength": 4000
            }
          },
          {
            "name": "x-tenant-id",
            "description": "The unique identifier of the tenant, the value should be provided\nby AXA.\n",
            "in": "header",
            "schema": {
              "type": "string",
              "example": "42bbd332fa8f48e7bb382165f257a579",
              "maxLength": 32
            }
          },
          {
            "name": "customer_email",
            "description": "The customer email.",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "john.doe@mail.com",
              "maxLength": 320
            }
          },
          {
            "name": "holder_last_name",
            "description": "The policy holder last name.",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "Doe",
              "maxLength": 50
            }
          },
          {
            "name": "holder_birthdate",
            "description": "The policy holder date of birth. Mandatory if policy holder last\nname provided - ISO 8601 format (YYYY-MM-DD).\n",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "1988-05-05",
              "maxLength": 10
            }
          },
          {
            "name": "beneficiary_last_name",
            "description": "The beneficiary last name.",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "Doe",
              "maxLength": 50
            }
          },
          {
            "name": "beneficiary_id",
            "description": "Identifier of the beneficiary. Provided on the certificate of the policy on some countries to identify the beneficiaries.",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 50,
              "example": "6ed78a37-3b31-469a-a6a5-76134a0dfe79"
            }
          },
          {
            "name": "agent_scope",
            "description": "The scope selected by the agent when the police was created.",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 100
            }
          },
          {
            "name": "policy_number",
            "description": "Final policy number.",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 150
            }
          },
          {
            "name": "motor_insured_item_vehicle_registration_number",
            "description": "Car's license plate",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "4234BMW",
              "maxLength": 50
            }
          },
          {
            "name": "expire_in",
            "description": "The number of days from today in witch the travel annual policies\nare going to expire.\n",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of travel policy summaries.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "maxItems": 100,
                  "items": {
                    "type": "object",
                    "allOf": [
                      {
                        "type": "object",
                        "properties": {
                          "policy_id": {
                            "description": "Unique final policy identifier.",
                            "type": "string",
                            "readOnly": true,
                            "maxLength": 150,
                            "example": "5ff96b27-cdc1-4090-b2f4-febfb1b1d08f"
                          },
                          "policy_number": {
                            "description": "Final policy number (only exist if policy is not draft).",
                            "type": "string",
                            "maxLength": 50,
                            "example": "DRULY031000000823"
                          },
                          "draft_policy_number": {
                            "description": "Draft policy number.",
                            "type": "string",
                            "maxLength": 50,
                            "example": "NBYULY03115985008"
                          },
                          "status": {
                            "description": "Policy's status details.",
                            "type": "string",
                            "enum": [
                              "DRAFT",
                              "ACTIVE",
                              "CANCELLED"
                            ],
                            "example": "ACTIVE"
                          },
                          "policy_holder": {
                            "description": "Policy holder summary.",
                            "allOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "title": {
                                    "description": "Civility (Mr, Ms, Miss, Doctor, Professor).",
                                    "type": "string",
                                    "enum": [
                                      "DR",
                                      "MISS",
                                      "MR",
                                      "MS",
                                      "PR"
                                    ],
                                    "example": "MR"
                                  },
                                  "last_name": {
                                    "description": "The last name of the policy holder.",
                                    "type": "string",
                                    "maxLength": 100,
                                    "example": "Doe"
                                  },
                                  "first_name": {
                                    "description": "The first name of the policy holder.",
                                    "type": "string",
                                    "maxLength": 100,
                                    "example": "John"
                                  },
                                  "external_holder_id": {
                                    "description": "Partner identifier of the customer.",
                                    "type": "string",
                                    "maxLength": 150,
                                    "example": "239015d1-feed-49ab-9a62-40b729faeec8"
                                  }
                                }
                              }
                            ]
                          },
                          "beneficiaries": {
                            "description": "Entity benefeciary of the policy.",
                            "type": "array",
                            "maxItems": 100,
                            "items": {
                              "type": "object",
                              "properties": {
                                "last_name": {
                                  "description": "The last name of the policy holder.",
                                  "type": "string",
                                  "maxLength": 100,
                                  "example": "Doe"
                                },
                                "first_name": {
                                  "description": "The first name of the policy holder.",
                                  "type": "string",
                                  "maxLength": 100,
                                  "example": "John"
                                },
                                "birth_date": {
                                  "description": "Birth date - ISO 8601 format (YYYY-MM-DD).",
                                  "type": "string",
                                  "format": "date",
                                  "example": "1990-04-25"
                                },
                                "id": {
                                  "description": "Beneficiary identifier.",
                                  "type": "string",
                                  "maxLength": 50,
                                  "example": "SHINT000000016-C"
                                }
                              }
                            }
                          },
                          "motor_coverages": {
                            "description": "Motor coverage information insured.\n",
                            "type": "object",
                            "allOf": [
                              {
                                "type": "object",
                                "description": "Insured motor assets.\n",
                                "properties": {
                                  "insured_items": {
                                    "description": "Beneficiaries list for motor products\n",
                                    "type": "object",
                                    "allOf": [
                                      {
                                        "type": "object",
                                        "properties": {
                                          "vehicles": {
                                            "description": "Vehicle specific information",
                                            "type": "array",
                                            "maxItems": 100,
                                            "items": {
                                              "description": "Vehicle specific information",
                                              "type": "object",
                                              "properties": {
                                                "registration_number": {
                                                  "description": "Car's license plate",
                                                  "type": "string",
                                                  "maxLength": 50,
                                                  "example": "4234BMW"
                                                },
                                                "brand": {
                                                  "description": "Brand name",
                                                  "type": "string",
                                                  "maxLength": 50,
                                                  "example": "Volkswagen"
                                                },
                                                "model": {
                                                  "description": "Model",
                                                  "type": "string",
                                                  "maxLength": 50,
                                                  "example": "Passat SW"
                                                },
                                                "colour": {
                                                  "description": "Vehicle's colour",
                                                  "type": "string",
                                                  "maxLength": 50,
                                                  "example": "Spatial grey"
                                                }
                                              }
                                            }
                                          }
                                        }
                                      }
                                    ]
                                  }
                                }
                              }
                            ]
                          },
                          "purchase_date": {
                            "description": "The date of the subscription (purchase) of the policy  - ISO 8601\nformat (YYYY-MM-DD).\n",
                            "type": "string",
                            "format": "date",
                            "example": "2018-06-20"
                          },
                          "catalog": {
                            "description": "The product catalog.",
                            "allOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "code": {
                                    "description": "The code of the product catalog relied to the policy",
                                    "type": "string",
                                    "maxLength": 50,
                                    "example": "Opodo FR"
                                  },
                                  "version": {
                                    "description": "Catalog version.",
                                    "type": "string",
                                    "maxLength": 10,
                                    "example": "v12"
                                  }
                                },
                                "required": [
                                  "code",
                                  "version"
                                ]
                              }
                            ]
                          },
                          "product_name": {
                            "description": "Product name",
                            "type": "string",
                            "maxLength": 100,
                            "example": "Advanced"
                          },
                          "contracting_actor_name": {
                            "description": "The legal entity relied to the customer.",
                            "type": "string",
                            "maxLength": 100,
                            "example": "EXPEDIA UK"
                          }
                        }
                      },
                      {
                        "type": "object",
                        "properties": {
                          "start_date": {
                            "description": "Trip start date - ISO 8601 format (YYYY-MM-DD).",
                            "type": "string",
                            "format": "date",
                            "example": "2018-08-20"
                          },
                          "end_date": {
                            "description": "Trip end date - ISO 8601 format (YYYY-MM-DD).",
                            "type": "string",
                            "format": "date",
                            "example": "2018-08-20"
                          }
                        }
                      },
                      {
                        "properties": {
                          "policy_type": {
                            "description": "Type of policy.",
                            "type": "string",
                            "enum": [
                              "SINGLE",
                              "ANNUAL"
                            ],
                            "example": "SINGLE"
                          }
                        }
                      }
                    ]
                  }
                },
                "example": [
                  {
                    "policy_id": "5ff96b27-cdc1-4090-b2f4-febfb1b1d08f",
                    "status": "ACTIVE",
                    "policy_holder": {
                      "title": "MR",
                      "last_name": "Doe",
                      "first_name": "John"
                    }
                  }
                ]
              }
            }
          },
          "400": {
            "description": "Bad Request.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "400",
                  "error": "Bad Request",
                  "error_description": "The input information received were not compliant with the endpoint specification."
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.\nThe identity of the caller has not been definitely confirmed (invalid issuer, expired token, ...)\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "401",
                  "error": "Unauthorized",
                  "error_description": "Header \"authorization\" is not a valid JSON Web Token."
                }
              }
            }
          },
          "403": {
            "description": "Forbidden.\nThe identity of the caller is confirmed, however the required access grants are not met (missing scope, unknown client_id, ...)\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "403",
                  "error": "Forbidden",
                  "error_description": "The right to access this endpoint has not been granted in the JSON Web Token."
                }
              }
            }
          },
          "default": {
            "description": "Default response format.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "500",
                  "error": "Internal Server Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "sandbox_auth0_cc": [
              "urn:axa.partners.sales.individual.travel.policies.read_only"
            ]
          }
        ]
      },
      "post": {
        "summary": "Creates policy subscription.",
        "description": "Cf. summary",
        "x-business-category": "TRAVEL",
        "parameters": [
          {
            "name": "accept-language",
            "in": "header",
            "required": false,
            "description": "Accepted language, IANA language codification. If language not managed, \"en\" will be used by default.",
            "schema": {
              "type": "string",
              "example": "en",
              "maxLength": 5
            }
          },
          {
            "name": "x-axa-context",
            "in": "header",
            "required": false,
            "description": "The token is formatted as a JWT and provided by the partner.",
            "schema": {
              "type": "string",
              "format": "JSON Web Token RFC 7519",
              "maxLength": 4000
            }
          },
          {
            "name": "x-tenant-id",
            "description": "The unique identifier of the tenant, the value should be provided\nby AXA.\n",
            "in": "header",
            "schema": {
              "type": "string",
              "example": "42bbd332fa8f48e7bb382165f257a579",
              "maxLength": 32
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "external_policy_number": {
                    "description": "External policy identifier that can be provided by the partner.",
                    "type": "string",
                    "example": "58eb265b-8175-4e46-9ece-18fb22d8ebb7",
                    "maxLength": 50
                  },
                  "subscription_country": {
                    "description": "Country where the customer subscribes the policy, ISO-3166-1\nalpha-2 format (2 letter codes).\n",
                    "type": "string",
                    "example": "FR",
                    "minLength": 2,
                    "maxLength": 2
                  },
                  "quote_code": {
                    "description": "Quote code, partner can use a default value if provided by AXA or\ngot it with quoting API.\n",
                    "type": "string",
                    "maxLength": 2000,
                    "example": "d41d8cd98f00b204e9800998ecf8427e"
                  },
                  "policy_start_date": {
                    "description": "The effective policy start date - ISO 8601 format (YYYY-MM-DD).",
                    "type": "string",
                    "format": "date",
                    "example": "2019-01-30"
                  },
                  "domain_url": {
                    "description": "The url from the request is originated.",
                    "type": "string",
                    "example": "https://axa.com/deeplink/route",
                    "maxLength": 2000
                  },
                  "sales_information": {
                    "description": "Sales information.",
                    "allOf": [
                      {
                        "description": "Sales information.",
                        "type": "object",
                        "properties": {
                          "point_of_sale": {
                            "description": "Point of sale of the policy.",
                            "type": "string",
                            "maxLength": 50,
                            "example": "THOMAS COOK"
                          },
                          "seller": {
                            "description": "Seller who sold the policy",
                            "type": "string",
                            "maxLength": 50,
                            "example": "S22NBY98"
                          }
                        }
                      }
                    ]
                  },
                  "price": {
                    "description": "Policy's price details.",
                    "allOf": [
                      {
                        "type": "object",
                        "description": "Policy price.",
                        "properties": {
                          "formula": {
                            "description": "Formula selected by the customer.",
                            "type": "string",
                            "maxLength": 50,
                            "example": "12-MONTHS"
                          },
                          "currency": {
                            "description": "Currency, ISO 4217 format (3 letter code).",
                            "type": "string",
                            "minLength": 3,
                            "maxLength": 3,
                            "example": "EUR"
                          },
                          "price_after_discount_inc_tax": {
                            "description": "Price amount discounted including taxes, numeric with 2 decimals.",
                            "type": "number",
                            "example": 150.25
                          }
                        },
                        "required": [
                          "currency",
                          "price_after_discount_inc_tax"
                        ]
                      }
                    ]
                  },
                  "addons": {
                    "description": "List of add-ons code, add-ons added by the customer.",
                    "type": "array",
                    "maxItems": 50,
                    "items": {
                      "type": "string",
                      "maxLength": 1000
                    }
                  },
                  "policy_holder": {
                    "description": "Policy holder.",
                    "allOf": [
                      {
                        "description": "Policy holder",
                        "allOf": [
                          {
                            "type": "object",
                            "properties": {
                              "title": {
                                "description": "Civility (Mr, Ms, Miss, Doctor, Professor).",
                                "type": "string",
                                "enum": [
                                  "MR",
                                  "MS",
                                  "MISS",
                                  "DR",
                                  "PR"
                                ],
                                "minLength": 2,
                                "maxLength": 4,
                                "example": "MR"
                              },
                              "first_name": {
                                "description": "First name.",
                                "type": "string",
                                "maxLength": 100,
                                "example": "John"
                              },
                              "middle_name": {
                                "description": "Middle name.",
                                "type": "string",
                                "example": "Junior",
                                "maxLength": 100
                              },
                              "last_name": {
                                "description": "Last name.",
                                "type": "string",
                                "maxLength": 100,
                                "example": "Doe"
                              },
                              "birth_date": {
                                "description": "Birth date - ISO 8601 format (YYYY-MM-DD).",
                                "type": "string",
                                "format": "date",
                                "example": "1990-04-25"
                              },
                              "email": {
                                "description": "Email address.",
                                "allOf": [
                                  {
                                    "type": "string",
                                    "format": "email",
                                    "example": "jonathan.doe@mail.com"
                                  }
                                ],
                                "example": "john.doe@mail.com"
                              },
                              "registrations": {
                                "description": "List of person registrations.",
                                "type": "array",
                                "maxItems": 2,
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "registration_type": {
                                      "description": "Type of person registration.\nID_CARD : Identity card reference\nPASSPORT : Passport reference\nDRIVER_LICENSE : Driver license reference\nTAX_REGISTRATION : Tax registration reference\nRESIDENCE_PERMIT: Residente permit reference\n",
                                      "type": "string",
                                      "enum": [
                                        "ID_CARD",
                                        "PASSPORT",
                                        "DRIVER_LICENSE",
                                        "TAX_REGISTRATION",
                                        "RESIDENCE_PERMIT"
                                      ],
                                      "maxLength": 28
                                    },
                                    "value": {
                                      "description": "Value of the registration.",
                                      "maxLength": 20,
                                      "type": "string"
                                    }
                                  },
                                  "required": [
                                    "value"
                                  ]
                                }
                              }
                            },
                            "required": [
                              "title",
                              "first_name",
                              "last_name",
                              "birth_date"
                            ]
                          },
                          {
                            "properties": {
                              "spoken_language": {
                                "description": "Spoken language, IANA language codification.",
                                "type": "string",
                                "example": "en-US",
                                "maxLength": 5,
                                "minLength": 2
                              },
                              "phone": {
                                "description": "Phone number.",
                                "allOf": [
                                  {
                                    "type": "object",
                                    "properties": {
                                      "international_prefix": {
                                        "description": "Prefix to be added to be called from abroad.",
                                        "type": "string",
                                        "maxLength": 5,
                                        "example": "+33"
                                      },
                                      "number": {
                                        "description": "Phone number. Can be local or international.",
                                        "type": "string",
                                        "maxLength": 20,
                                        "example": "12345678"
                                      }
                                    },
                                    "required": [
                                      "number"
                                    ]
                                  }
                                ]
                              },
                              "address": {
                                "description": "Postal address",
                                "allOf": [
                                  {
                                    "type": "object",
                                    "properties": {
                                      "street_address": {
                                        "description": "Street address.",
                                        "type": "string",
                                        "example": "150 Avenue de Paris",
                                        "maxLength": 255
                                      },
                                      "postal_code": {
                                        "description": "Postal code or zip code.",
                                        "type": "string",
                                        "example": "75001",
                                        "maxLength": 10
                                      },
                                      "city": {
                                        "description": "City.",
                                        "type": "string",
                                        "example": "Paris",
                                        "maxLength": 100
                                      },
                                      "country": {
                                        "description": "Country ISO-3166-1 alpha-2 format (2 letter codes).",
                                        "type": "string",
                                        "example": "FR",
                                        "minLength": 2,
                                        "maxLength": 2
                                      }
                                    },
                                    "required": [
                                      "street_address",
                                      "postal_code",
                                      "city",
                                      "country"
                                    ]
                                  }
                                ]
                              },
                              "is_policy_beneficiary": {
                                "description": "Indicates if the policy holder is also a policy beneficiary.",
                                "type": "boolean"
                              },
                              "external_holder_id": {
                                "description": "Partner identifier of the customer.",
                                "type": "string",
                                "example": "ab8b7d8b-cdc4-46fd-bc4d-4abb3743a6d8",
                                "maxLength": 150
                              }
                            }
                          }
                        ],
                        "required": [
                          "spoken_language",
                          "email",
                          "is_policy_beneficiary"
                        ]
                      }
                    ]
                  },
                  "beneficiaries": {
                    "description": "Beneficiaries list (other than the policy holder if he is also a\nbeneficiary).\n",
                    "type": "array",
                    "maxItems": 1000,
                    "items": {
                      "type": "object",
                      "properties": {
                        "title": {
                          "description": "Civility (Mr, Ms, Miss, Doctor, Professor).",
                          "type": "string",
                          "enum": [
                            "MR",
                            "MS",
                            "MISS",
                            "DR",
                            "PR"
                          ],
                          "minLength": 2,
                          "maxLength": 4,
                          "example": "MR"
                        },
                        "first_name": {
                          "description": "First name.",
                          "type": "string",
                          "maxLength": 100,
                          "example": "John"
                        },
                        "middle_name": {
                          "description": "Middle name.",
                          "type": "string",
                          "example": "Junior",
                          "maxLength": 100
                        },
                        "last_name": {
                          "description": "Last name.",
                          "type": "string",
                          "maxLength": 100,
                          "example": "Doe"
                        },
                        "birth_date": {
                          "description": "Birth date - ISO 8601 format (YYYY-MM-DD).",
                          "type": "string",
                          "format": "date",
                          "example": "1990-04-25"
                        },
                        "email": {
                          "description": "Email address.",
                          "allOf": [
                            {
                              "type": "string",
                              "format": "email",
                              "example": "jonathan.doe@mail.com"
                            }
                          ],
                          "example": "john.doe@mail.com"
                        },
                        "registrations": {
                          "description": "List of person registrations.",
                          "type": "array",
                          "maxItems": 2,
                          "items": {
                            "type": "object",
                            "properties": {
                              "registration_type": {
                                "description": "Type of person registration.\nID_CARD : Identity card reference\nPASSPORT : Passport reference\nDRIVER_LICENSE : Driver license reference\nTAX_REGISTRATION : Tax registration reference\nRESIDENCE_PERMIT: Residente permit reference\n",
                                "type": "string",
                                "enum": [
                                  "ID_CARD",
                                  "PASSPORT",
                                  "DRIVER_LICENSE",
                                  "TAX_REGISTRATION",
                                  "RESIDENCE_PERMIT"
                                ],
                                "maxLength": 28
                              },
                              "value": {
                                "description": "Value of the registration.",
                                "maxLength": 20,
                                "type": "string"
                              }
                            },
                            "required": [
                              "value"
                            ]
                          }
                        }
                      },
                      "required": [
                        "title",
                        "first_name",
                        "last_name",
                        "birth_date"
                      ]
                    }
                  },
                  "motor_coverages": {
                    "description": "Motor coverage information insured.\n",
                    "type": "object",
                    "allOf": [
                      {
                        "type": "object",
                        "description": "Insured motor assets.\n",
                        "properties": {
                          "insured_items": {
                            "description": "Beneficiaries list for motor products\n",
                            "type": "object",
                            "allOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "vehicles": {
                                    "description": "Vehicle specific information",
                                    "type": "array",
                                    "maxItems": 100,
                                    "items": {
                                      "description": "Vehicle specific information",
                                      "type": "object",
                                      "properties": {
                                        "registration_number": {
                                          "description": "Car's license plate",
                                          "type": "string",
                                          "maxLength": 50,
                                          "example": "4234BMW"
                                        },
                                        "brand": {
                                          "description": "Brand name",
                                          "type": "string",
                                          "maxLength": 50,
                                          "example": "Volkswagen"
                                        },
                                        "model": {
                                          "description": "Model",
                                          "type": "string",
                                          "maxLength": 50,
                                          "example": "Passat SW"
                                        },
                                        "colour": {
                                          "description": "Vehicle's colour",
                                          "type": "string",
                                          "maxLength": 50,
                                          "example": "Spatial grey"
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            ]
                          }
                        }
                      }
                    ]
                  },
                  "consents": {
                    "description": "List of consents displayed to the customer.",
                    "type": "array",
                    "maxItems": 1000,
                    "items": {
                      "type": "object",
                      "description": "Customer consent.",
                      "properties": {
                        "code": {
                          "description": "Code of the consent.",
                          "type": "string",
                          "maxLength": 50
                        },
                        "is_confirmed": {
                          "description": "Indicates if the consent has been confirmed by the customer or not.",
                          "type": "boolean"
                        }
                      },
                      "required": [
                        "code",
                        "is_confirmed"
                      ]
                    }
                  },
                  "payment": {
                    "description": "Payment information provided by the API caller.\nThis information is mandatory in the case where AXA managed the payment.\n",
                    "allOf": [
                      {
                        "type": "object",
                        "description": "Payment information, at least one of the properties psp_transaction_id or transfer_information should be provided.",
                        "properties": {
                          "type": {
                            "description": "Payment mode selected.",
                            "type": "string",
                            "enum": [
                              "CREDIT_CARD",
                              "DEBIT_CARD",
                              "ELECTRONIC_TRANSFERT",
                              "VIRTUAL_CREDIT_CARD",
                              "DIRECT_PAYMENT"
                            ],
                            "example": "CREDIT_CARD"
                          },
                          "psp_transaction_id": {
                            "description": "Payment reference on the payment provider system.",
                            "type": "string",
                            "maxLength": 150,
                            "example": "3af6781b-3f47-4d3f-ae94-0e5167c22dc3"
                          },
                          "transfer_information": {
                            "description": "Information about the payer.",
                            "allOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "account_holder": {
                                    "type": "object",
                                    "properties": {
                                      "first_name": {
                                        "type": "string",
                                        "maxLength": 100,
                                        "description": "First name of the account's owner.",
                                        "example": "John"
                                      },
                                      "last_name": {
                                        "type": "string",
                                        "maxLength": 100,
                                        "example": "Doe",
                                        "description": "Last name of the account's owner."
                                      },
                                      "billing_address": {
                                        "type": "object",
                                        "properties": {
                                          "street_address": {
                                            "description": "Street address.",
                                            "type": "string",
                                            "example": "150 Avenue de Paris",
                                            "maxLength": 255
                                          },
                                          "postal_code": {
                                            "description": "Postal code or zip code.",
                                            "type": "string",
                                            "example": "75001",
                                            "maxLength": 10
                                          },
                                          "city": {
                                            "description": "City.",
                                            "type": "string",
                                            "example": "Paris",
                                            "maxLength": 100
                                          },
                                          "country": {
                                            "description": "Country.",
                                            "type": "string",
                                            "example": "FR",
                                            "maxLength": 100
                                          },
                                          "province": {
                                            "description": "Province.",
                                            "type": "string",
                                            "maxLength": 100
                                          }
                                        }
                                      }
                                    }
                                  },
                                  "account_name": {
                                    "type": "string",
                                    "maxLength": 100,
                                    "description": "Name's of this bank account",
                                    "example": "Personal Account"
                                  },
                                  "country_code": {
                                    "type": "string",
                                    "minLength": 2,
                                    "maxLength": 2,
                                    "description": "Bank's country code, ISO-3166-1 alpha-2 format (2 letters code).",
                                    "example": "FR"
                                  },
                                  "wire_code": {
                                    "type": "array",
                                    "maxItems": 50,
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "wire_code_type": {
                                          "type": "string",
                                          "enum": [
                                            "IBAN"
                                          ],
                                          "description": "Wire's type (only IBAN is accepted)"
                                        },
                                        "value": {
                                          "type": "string",
                                          "maxLength": 50,
                                          "description": "The value of the IBAN",
                                          "example": "FR7630006000011234567890189"
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            ]
                          }
                        }
                      }
                    ]
                  },
                  "additional_information": {
                    "description": "Additional information filled by the partner if needed.\n",
                    "type": "array",
                    "maxItems": 100,
                    "items": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "description": "Information code.\n- EXISTING_INSURANCE_REFERENCE: References to existing or complementary insurance\n- REGISTRATION_PLATE_NUMBER: vehicle license plate reference\n",
                          "type": "string",
                          "enum": [
                            "EXISTING_INSURANCE_REFERENCE",
                            "REGISTRATION_PLATE_NUMBER"
                          ],
                          "maxLength": 28
                        },
                        "value": {
                          "description": "Information value.",
                          "type": "string",
                          "maxLength": 100
                        }
                      },
                      "required": [
                        "code",
                        "value"
                      ]
                    },
                    "example": [
                      {
                        "code": "EXISTING_INSURANCE_REFERENCE",
                        "value": "A1455CDH"
                      }
                    ]
                  },
                  "has_to_send_email_immediately": {
                    "description": "Indicates if the draft email should be sent immediately.",
                    "type": "boolean"
                  },
                  "utm_parameters": {
                    "description": "UTM parameters for tracking traffic sources and marketing campaigns\n",
                    "type": "object",
                    "allOf": [
                      {
                        "description": "UTM parameters for tracking marketing campaigns and traffic sources",
                        "type": "object",
                        "properties": {
                          "source": {
                            "description": "Identifies which site sent the traffic (e.g., search engine, newsletter, or other referral source).",
                            "maxLength": 50,
                            "type": "string",
                            "example": "google"
                          },
                          "medium": {
                            "description": "Identifies the marketing medium used to reach the user (e.g., email, CPC, banner).",
                            "type": "string",
                            "maxLength": 50,
                            "example": "cpc"
                          },
                          "campaign": {
                            "description": "Identifies the specific campaign name or promotion associated with the traffic.",
                            "maxLength": 50,
                            "type": "string",
                            "example": "spring_sale_2025"
                          },
                          "term": {
                            "description": "Identifies keywords associated with the campaign.",
                            "type": "string",
                            "maxLength": 50,
                            "example": "insurance+online"
                          },
                          "content": {
                            "description": "Differentiates between links or ads pointing to the same URL, used for A/B testing.",
                            "maxLength": 50,
                            "type": "string",
                            "example": "banner_top"
                          }
                        }
                      }
                    ]
                  }
                },
                "required": [
                  "quote_code",
                  "policy_holder",
                  "price"
                ]
              }
            }
          },
          "description": "Content of policy subscription.",
          "required": true
        },
        "responses": {
          "201": {
            "description": "Policy created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "policy_id": {
                      "description": "Unique final policy identifier.",
                      "type": "string",
                      "maxLength": 150,
                      "example": "ea45ec62-0d21-4f44-a577-b8624da2bf5b"
                    },
                    "draft_policy_number": {
                      "description": "Draft policy number, provided in case if the policy is not confirmed.",
                      "type": "string",
                      "maxLength": 50
                    },
                    "quote_code": {
                      "description": "Quote code, partner can use a default value if provided by AXA or\ngot it with quoting API.\n",
                      "type": "string",
                      "maxLength": 2000,
                      "example": "d41d8cd98f00b204e9800998ecf8427e"
                    },
                    "policy_number": {
                      "description": "Final policy number.",
                      "type": "string",
                      "maxLength": 50
                    },
                    "external_policy_number": {
                      "description": "External policy identifier that can be provided by the partner.",
                      "type": "string",
                      "maxLength": 50
                    },
                    "status": {
                      "description": "Policy's status details.",
                      "allOf": [
                        {
                          "type": "object",
                          "description": "Policy status.",
                          "readOnly": true,
                          "properties": {
                            "value": {
                              "description": "Status value",
                              "type": "string",
                              "enum": [
                                "CONFIRMED",
                                "DRAFT",
                                "CANCELLED"
                              ],
                              "maxLength": 9,
                              "minLength": 5
                            },
                            "reason": {
                              "description": "Status reason.",
                              "type": "string",
                              "maxLength": 50
                            }
                          },
                          "required": [
                            "value"
                          ]
                        }
                      ]
                    },
                    "subscription_country": {
                      "description": "Country where the customer subscribes the policy, ISO-3166-1\nalpha-2 format (2 letter codes).\n",
                      "type": "string",
                      "example": "FR",
                      "minLength": 2,
                      "maxLength": 2
                    },
                    "sales_information": {
                      "description": "Sales information.",
                      "allOf": [
                        {
                          "description": "Sales information.",
                          "type": "object",
                          "properties": {
                            "point_of_sale": {
                              "description": "Point of sale of the policy.",
                              "type": "string",
                              "maxLength": 50,
                              "example": "THOMAS COOK"
                            },
                            "seller": {
                              "description": "Seller who sold the policy",
                              "type": "string",
                              "maxLength": 50,
                              "example": "S22NBY98"
                            }
                          }
                        }
                      ]
                    },
                    "price": {
                      "description": "Policy's price details.",
                      "allOf": [
                        {
                          "type": "object",
                          "description": "Policy price.",
                          "properties": {
                            "formula": {
                              "description": "Formula selected by the customer.",
                              "type": "string",
                              "maxLength": 50,
                              "example": "12-MONTHS"
                            },
                            "currency": {
                              "description": "Currency, ISO 4217 format (3 letter code).",
                              "type": "string",
                              "minLength": 3,
                              "maxLength": 3,
                              "example": "EUR"
                            },
                            "price_after_discount_inc_tax": {
                              "description": "Price amount discounted including taxes, numeric with 2 decimals.",
                              "type": "number",
                              "example": 150.25
                            }
                          },
                          "required": [
                            "currency",
                            "price_after_discount_inc_tax"
                          ]
                        }
                      ]
                    },
                    "addons": {
                      "description": "List of add-ons code, add-ons added by the customer.",
                      "type": "array",
                      "maxItems": 100,
                      "items": {
                        "type": "string",
                        "maxLength": 1000
                      }
                    },
                    "policy_holder": {
                      "description": "Policy holder.",
                      "allOf": [
                        {
                          "description": "Policy holder",
                          "allOf": [
                            {
                              "type": "object",
                              "properties": {
                                "title": {
                                  "description": "Civility (Mr, Ms, Miss, Doctor, Professor).",
                                  "type": "string",
                                  "enum": [
                                    "MR",
                                    "MS",
                                    "MISS",
                                    "DR",
                                    "PR"
                                  ],
                                  "minLength": 2,
                                  "maxLength": 4,
                                  "example": "MR"
                                },
                                "first_name": {
                                  "description": "First name.",
                                  "type": "string",
                                  "maxLength": 100,
                                  "example": "John"
                                },
                                "middle_name": {
                                  "description": "Middle name.",
                                  "type": "string",
                                  "example": "Junior",
                                  "maxLength": 100
                                },
                                "last_name": {
                                  "description": "Last name.",
                                  "type": "string",
                                  "maxLength": 100,
                                  "example": "Doe"
                                },
                                "birth_date": {
                                  "description": "Birth date - ISO 8601 format (YYYY-MM-DD).",
                                  "type": "string",
                                  "format": "date",
                                  "example": "1990-04-25"
                                },
                                "email": {
                                  "description": "Email address.",
                                  "allOf": [
                                    {
                                      "type": "string",
                                      "format": "email",
                                      "example": "jonathan.doe@mail.com"
                                    }
                                  ],
                                  "example": "john.doe@mail.com"
                                },
                                "registrations": {
                                  "description": "List of person registrations.",
                                  "type": "array",
                                  "maxItems": 2,
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "registration_type": {
                                        "description": "Type of person registration.\nID_CARD : Identity card reference\nPASSPORT : Passport reference\nDRIVER_LICENSE : Driver license reference\nTAX_REGISTRATION : Tax registration reference\nRESIDENCE_PERMIT: Residente permit reference\n",
                                        "type": "string",
                                        "enum": [
                                          "ID_CARD",
                                          "PASSPORT",
                                          "DRIVER_LICENSE",
                                          "TAX_REGISTRATION",
                                          "RESIDENCE_PERMIT"
                                        ],
                                        "maxLength": 28
                                      },
                                      "value": {
                                        "description": "Value of the registration.",
                                        "maxLength": 20,
                                        "type": "string"
                                      }
                                    },
                                    "required": [
                                      "value"
                                    ]
                                  }
                                }
                              },
                              "required": [
                                "title",
                                "first_name",
                                "last_name",
                                "birth_date"
                              ]
                            },
                            {
                              "properties": {
                                "spoken_language": {
                                  "description": "Spoken language, IANA language codification.",
                                  "type": "string",
                                  "example": "en-US",
                                  "maxLength": 5,
                                  "minLength": 2
                                },
                                "phone": {
                                  "description": "Phone number.",
                                  "allOf": [
                                    {
                                      "type": "object",
                                      "properties": {
                                        "international_prefix": {
                                          "description": "Prefix to be added to be called from abroad.",
                                          "type": "string",
                                          "maxLength": 5,
                                          "example": "+33"
                                        },
                                        "number": {
                                          "description": "Phone number. Can be local or international.",
                                          "type": "string",
                                          "maxLength": 20,
                                          "example": "12345678"
                                        }
                                      },
                                      "required": [
                                        "number"
                                      ]
                                    }
                                  ]
                                },
                                "address": {
                                  "description": "Postal address",
                                  "allOf": [
                                    {
                                      "type": "object",
                                      "properties": {
                                        "street_address": {
                                          "description": "Street address.",
                                          "type": "string",
                                          "example": "150 Avenue de Paris",
                                          "maxLength": 255
                                        },
                                        "postal_code": {
                                          "description": "Postal code or zip code.",
                                          "type": "string",
                                          "example": "75001",
                                          "maxLength": 10
                                        },
                                        "city": {
                                          "description": "City.",
                                          "type": "string",
                                          "example": "Paris",
                                          "maxLength": 100
                                        },
                                        "country": {
                                          "description": "Country ISO-3166-1 alpha-2 format (2 letter codes).",
                                          "type": "string",
                                          "example": "FR",
                                          "minLength": 2,
                                          "maxLength": 2
                                        }
                                      },
                                      "required": [
                                        "street_address",
                                        "postal_code",
                                        "city",
                                        "country"
                                      ]
                                    }
                                  ]
                                },
                                "is_policy_beneficiary": {
                                  "description": "Indicates if the policy holder is also a policy beneficiary.",
                                  "type": "boolean"
                                },
                                "external_holder_id": {
                                  "description": "Partner identifier of the customer.",
                                  "type": "string",
                                  "example": "ab8b7d8b-cdc4-46fd-bc4d-4abb3743a6d8",
                                  "maxLength": 150
                                }
                              }
                            }
                          ],
                          "required": [
                            "spoken_language",
                            "email",
                            "is_policy_beneficiary"
                          ]
                        }
                      ]
                    },
                    "beneficiaries": {
                      "description": "Beneficiaries list (other than the policy holder if he is also a\nbeneficiary).\n",
                      "type": "array",
                      "maxItems": 1000,
                      "items": {
                        "description": "Policy beneficiary.",
                        "allOf": [
                          {
                            "properties": {
                              "id": {
                                "description": "Beneficiary identifier.",
                                "maxLength": 150,
                                "type": "string"
                              }
                            }
                          },
                          {
                            "type": "object",
                            "properties": {
                              "title": {
                                "description": "Civility (Mr, Ms, Miss, Doctor, Professor).",
                                "type": "string",
                                "enum": [
                                  "MR",
                                  "MS",
                                  "MISS",
                                  "DR",
                                  "PR"
                                ],
                                "minLength": 2,
                                "maxLength": 4,
                                "example": "MR"
                              },
                              "first_name": {
                                "description": "First name.",
                                "type": "string",
                                "maxLength": 100,
                                "example": "John"
                              },
                              "middle_name": {
                                "description": "Middle name.",
                                "type": "string",
                                "example": "Junior",
                                "maxLength": 100
                              },
                              "last_name": {
                                "description": "Last name.",
                                "type": "string",
                                "maxLength": 100,
                                "example": "Doe"
                              },
                              "birth_date": {
                                "description": "Birth date - ISO 8601 format (YYYY-MM-DD).",
                                "type": "string",
                                "format": "date",
                                "example": "1990-04-25"
                              },
                              "email": {
                                "description": "Email address.",
                                "allOf": [
                                  {
                                    "type": "string",
                                    "format": "email",
                                    "example": "jonathan.doe@mail.com"
                                  }
                                ],
                                "example": "john.doe@mail.com"
                              },
                              "registrations": {
                                "description": "List of person registrations.",
                                "type": "array",
                                "maxItems": 2,
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "registration_type": {
                                      "description": "Type of person registration.\nID_CARD : Identity card reference\nPASSPORT : Passport reference\nDRIVER_LICENSE : Driver license reference\nTAX_REGISTRATION : Tax registration reference\nRESIDENCE_PERMIT: Residente permit reference\n",
                                      "type": "string",
                                      "enum": [
                                        "ID_CARD",
                                        "PASSPORT",
                                        "DRIVER_LICENSE",
                                        "TAX_REGISTRATION",
                                        "RESIDENCE_PERMIT"
                                      ],
                                      "maxLength": 28
                                    },
                                    "value": {
                                      "description": "Value of the registration.",
                                      "maxLength": 20,
                                      "type": "string"
                                    }
                                  },
                                  "required": [
                                    "value"
                                  ]
                                }
                              }
                            },
                            "required": [
                              "title",
                              "first_name",
                              "last_name",
                              "birth_date"
                            ]
                          }
                        ]
                      }
                    },
                    "motor_coverages": {
                      "description": "Motor coverage information insured.\n",
                      "type": "object",
                      "allOf": [
                        {
                          "type": "object",
                          "description": "Insured motor assets.\n",
                          "properties": {
                            "insured_items": {
                              "description": "Beneficiaries list for motor products\n",
                              "type": "object",
                              "allOf": [
                                {
                                  "type": "object",
                                  "properties": {
                                    "vehicles": {
                                      "description": "Vehicle specific information",
                                      "type": "array",
                                      "maxItems": 100,
                                      "items": {
                                        "description": "Vehicle specific information",
                                        "type": "object",
                                        "properties": {
                                          "registration_number": {
                                            "description": "Car's license plate",
                                            "type": "string",
                                            "maxLength": 50,
                                            "example": "4234BMW"
                                          },
                                          "brand": {
                                            "description": "Brand name",
                                            "type": "string",
                                            "maxLength": 50,
                                            "example": "Volkswagen"
                                          },
                                          "model": {
                                            "description": "Model",
                                            "type": "string",
                                            "maxLength": 50,
                                            "example": "Passat SW"
                                          },
                                          "colour": {
                                            "description": "Vehicle's colour",
                                            "type": "string",
                                            "maxLength": 50,
                                            "example": "Spatial grey"
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              ]
                            }
                          }
                        }
                      ]
                    },
                    "consents": {
                      "description": "List of consents displayed to the customer.",
                      "type": "array",
                      "maxItems": 1000,
                      "items": {
                        "type": "object",
                        "description": "Customer consent.",
                        "properties": {
                          "code": {
                            "description": "Code of the consent.",
                            "type": "string",
                            "maxLength": 50
                          },
                          "is_confirmed": {
                            "description": "Indicates if the consent has been confirmed by the customer or not.",
                            "type": "boolean"
                          }
                        },
                        "required": [
                          "code",
                          "is_confirmed"
                        ]
                      }
                    },
                    "payment_technical_information": {
                      "description": "Technical information, provided to the API caller to allow it to\ncomplete the payment.\n",
                      "allOf": [
                        {
                          "type": "object",
                          "description": "Technical information for payment system access.\nThis information is provided to the API caller to allow it to complete the payment.\n",
                          "readOnly": true,
                          "properties": {
                            "zuora_access": {
                              "description": "Access information specific to Zuora.",
                              "allOf": [
                                {
                                  "type": "object",
                                  "properties": {
                                    "payment_gateway": {
                                      "description": "Payment gateway code.",
                                      "type": "string",
                                      "maxLength": 50
                                    },
                                    "key": {
                                      "description": "Public key generated for the subscription.",
                                      "type": "string",
                                      "maxLength": 2000
                                    },
                                    "signature": {
                                      "description": "Digital signature generated for the subscription.",
                                      "type": "string",
                                      "maxLength": 2000
                                    },
                                    "token": {
                                      "description": "Token generated for the subscription.",
                                      "type": "string",
                                      "maxLength": 2000
                                    },
                                    "tenant_id": {
                                      "description": "ID of the Zuora tenant.",
                                      "type": "string",
                                      "maxLength": 50
                                    },
                                    "page_id": {
                                      "description": "The page id.",
                                      "type": "string",
                                      "maxLength": 50
                                    }
                                  },
                                  "required": [
                                    "payment_gateway",
                                    "key",
                                    "signature",
                                    "token",
                                    "tenant_id",
                                    "page_id"
                                  ]
                                }
                              ]
                            }
                          },
                          "required": [
                            "zuora_access"
                          ]
                        }
                      ]
                    },
                    "payment": {
                      "description": "Payment information provided by the API caller.\nThis information is mandatory in the case where AXA managed the payment.\n",
                      "allOf": [
                        {
                          "type": "object",
                          "description": "Payment information, at least one of the properties psp_transaction_id or transfer_information should be provided.",
                          "properties": {
                            "type": {
                              "description": "Payment mode selected.",
                              "type": "string",
                              "enum": [
                                "CREDIT_CARD",
                                "DEBIT_CARD",
                                "ELECTRONIC_TRANSFERT",
                                "VIRTUAL_CREDIT_CARD",
                                "DIRECT_PAYMENT"
                              ],
                              "example": "CREDIT_CARD"
                            },
                            "psp_transaction_id": {
                              "description": "Payment reference on the payment provider system.",
                              "type": "string",
                              "maxLength": 150,
                              "example": "3af6781b-3f47-4d3f-ae94-0e5167c22dc3"
                            },
                            "transfer_information": {
                              "description": "Information about the payer.",
                              "allOf": [
                                {
                                  "type": "object",
                                  "properties": {
                                    "account_holder": {
                                      "type": "object",
                                      "properties": {
                                        "first_name": {
                                          "type": "string",
                                          "maxLength": 100,
                                          "description": "First name of the account's owner.",
                                          "example": "John"
                                        },
                                        "last_name": {
                                          "type": "string",
                                          "maxLength": 100,
                                          "example": "Doe",
                                          "description": "Last name of the account's owner."
                                        },
                                        "billing_address": {
                                          "type": "object",
                                          "properties": {
                                            "street_address": {
                                              "description": "Street address.",
                                              "type": "string",
                                              "example": "150 Avenue de Paris",
                                              "maxLength": 255
                                            },
                                            "postal_code": {
                                              "description": "Postal code or zip code.",
                                              "type": "string",
                                              "example": "75001",
                                              "maxLength": 10
                                            },
                                            "city": {
                                              "description": "City.",
                                              "type": "string",
                                              "example": "Paris",
                                              "maxLength": 100
                                            },
                                            "country": {
                                              "description": "Country.",
                                              "type": "string",
                                              "example": "FR",
                                              "maxLength": 100
                                            },
                                            "province": {
                                              "description": "Province.",
                                              "type": "string",
                                              "maxLength": 100
                                            }
                                          }
                                        }
                                      }
                                    },
                                    "account_name": {
                                      "type": "string",
                                      "maxLength": 100,
                                      "description": "Name's of this bank account",
                                      "example": "Personal Account"
                                    },
                                    "country_code": {
                                      "type": "string",
                                      "minLength": 2,
                                      "maxLength": 2,
                                      "description": "Bank's country code, ISO-3166-1 alpha-2 format (2 letters code).",
                                      "example": "FR"
                                    },
                                    "wire_code": {
                                      "type": "array",
                                      "maxItems": 50,
                                      "items": {
                                        "type": "object",
                                        "properties": {
                                          "wire_code_type": {
                                            "type": "string",
                                            "enum": [
                                              "IBAN"
                                            ],
                                            "description": "Wire's type (only IBAN is accepted)"
                                          },
                                          "value": {
                                            "type": "string",
                                            "maxLength": 50,
                                            "description": "The value of the IBAN",
                                            "example": "FR7630006000011234567890189"
                                          }
                                        }
                                      }
                                    }
                                  }
                                }
                              ]
                            }
                          }
                        }
                      ]
                    },
                    "attachments": {
                      "description": "Set of attachments provided with the policy.",
                      "type": "array",
                      "maxItems": 1000,
                      "items": {
                        "type": "object",
                        "description": "Attachment information.",
                        "properties": {
                          "name": {
                            "description": "Attached document name.",
                            "type": "string",
                            "example": "Proof of purchase",
                            "maxLength": 50
                          },
                          "content_url": {
                            "description": "URL to download the document.",
                            "type": "string",
                            "example": "https://axa.com/deeplink/route",
                            "maxLength": 2000
                          },
                          "type": {
                            "description": "Indicates the type of the document, it can be:\n- TERMS_AND_CONDITIONS;\n- CONTRACT;\n- ...\n",
                            "type": "string",
                            "example": "CONTRACT",
                            "maxLength": 50
                          },
                          "created_at": {
                            "description": "Date and time of document creation - ISO 8601 format (YYYY-MM-DD).",
                            "type": "string",
                            "format": "date",
                            "readOnly": true
                          },
                          "sent_by": {
                            "description": "The attachment sent via confirmation email or precontractual email.",
                            "type": "array",
                            "maxItems": 2,
                            "items": {
                              "type": "string",
                              "enum": [
                                "CONFIRMATION_EMAIL",
                                "PRECONTRACTUAL_EMAIL"
                              ]
                            },
                            "readOnly": true
                          },
                          "technical_reference": {
                            "description": "The technical reference used to download the attachment.",
                            "example": "3c13937d-9f60-4fff-bf03-06d9aee56abe",
                            "type": "string",
                            "maxLength": 50,
                            "readOnly": true
                          }
                        },
                        "required": [
                          "name",
                          "content_url"
                        ]
                      }
                    },
                    "additional_information": {
                      "description": "Additional information filled by the partner if needed.\n",
                      "type": "array",
                      "maxItems": 100,
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {
                            "description": "Information code.\n- EXISTING_INSURANCE_REFERENCE: References to existing or complementary insurance\n- REGISTRATION_PLATE_NUMBER: vehicle license plate reference\n",
                            "type": "string",
                            "enum": [
                              "EXISTING_INSURANCE_REFERENCE",
                              "REGISTRATION_PLATE_NUMBER"
                            ],
                            "maxLength": 28
                          },
                          "value": {
                            "description": "Information value.",
                            "type": "string",
                            "maxLength": 100
                          }
                        },
                        "required": [
                          "code",
                          "value"
                        ]
                      },
                      "example": [
                        {
                          "code": "EXISTING_INSURANCE_REFERENCE",
                          "value": "A1455CDH"
                        }
                      ]
                    }
                  },
                  "required": [
                    "quote_code",
                    "policy_holder",
                    "price"
                  ]
                },
                "example": {
                  "policy_id": "ea45ec62-0d21-4f44-a577-b8624da2bf5b",
                  "quote_code": "d41d8cd98f00b204e9800998ecf8427e",
                  "price": {
                    "currency": "EUR",
                    "price_after_discount_inc_tax": 150.25
                  },
                  "policy_holder": {
                    "title": "MR",
                    "first_name": "John",
                    "last_name": "Doe",
                    "birth_date": "1990-04-25",
                    "email": "john.doe@mail.com",
                    "spoken_language": "en-US",
                    "is_policy_beneficiary": true
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "400",
                  "error": "Bad Request",
                  "error_description": "The input information received were not compliant with the endpoint specification."
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.\nThe identity of the caller has not been definitely confirmed (invalid issuer, expired token, ...)\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "401",
                  "error": "Unauthorized",
                  "error_description": "Header \"authorization\" is not a valid JSON Web Token."
                }
              }
            }
          },
          "403": {
            "description": "Forbidden.\nThe identity of the caller is confirmed, however the required access grants are not met (missing scope, unknown client_id, ...)\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "403",
                  "error": "Forbidden",
                  "error_description": "The right to access this endpoint has not been granted in the JSON Web Token."
                }
              }
            }
          },
          "default": {
            "description": "Default response format.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "500",
                  "error": "Internal Server Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "sandbox_auth0_cc": [
              "urn:axa.partners.sales.individual.travel.policies.write"
            ]
          }
        ]
      }
    },
    "/sales/v2/individual/travel/policies/{policy_id}": {
      "get": {
        "summary": "Gets policy details.",
        "description": "Cf. summary",
        "x-business-category": "TRAVEL",
        "parameters": [
          {
            "name": "accept-language",
            "in": "header",
            "required": false,
            "description": "Accepted language, IANA language codification. If language not managed, \"en\" will be used by default.",
            "schema": {
              "type": "string",
              "example": "en",
              "maxLength": 5
            }
          },
          {
            "name": "x-axa-context",
            "in": "header",
            "required": false,
            "description": "The token is formatted as a JWT and provided by the partner.",
            "schema": {
              "type": "string",
              "format": "JSON Web Token RFC 7519",
              "maxLength": 4000
            }
          },
          {
            "name": "x-tenant-id",
            "description": "The unique identifier of the tenant, the value should be provided\nby AXA.\n",
            "in": "header",
            "schema": {
              "type": "string",
              "example": "42bbd332fa8f48e7bb382165f257a579",
              "maxLength": 32
            }
          },
          {
            "name": "policy_id",
            "description": "Unique policy identifier.",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "ea45ec62-0d21-4f44-a577-b8624da2bf5b",
              "maxLength": 150
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Policy details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "policy_number": {
                      "description": "Final policy number.",
                      "type": "string",
                      "maxLength": 50,
                      "readOnly": true
                    },
                    "external_policy_number": {
                      "description": "External policy identifier that can be provided by the partner.",
                      "type": "string",
                      "maxLength": 50
                    },
                    "status": {
                      "description": "Policy's status details.",
                      "allOf": [
                        {
                          "type": "object",
                          "description": "Policy status.",
                          "readOnly": true,
                          "properties": {
                            "value": {
                              "description": "Status value",
                              "type": "string",
                              "enum": [
                                "CONFIRMED",
                                "DRAFT",
                                "CANCELLED"
                              ],
                              "maxLength": 9,
                              "minLength": 5
                            },
                            "reason": {
                              "description": "Status reason.",
                              "type": "string",
                              "maxLength": 50
                            }
                          },
                          "required": [
                            "value"
                          ]
                        }
                      ],
                      "readOnly": true
                    },
                    "subscription_country": {
                      "description": "Country where the customer subscribes the policy, ISO-3166-1\nalpha-2 format (2 letter codes).\n",
                      "type": "string",
                      "example": "FR",
                      "minLength": 2,
                      "maxLength": 2
                    },
                    "transactions": {
                      "description": "All the policy transactions.",
                      "type": "array",
                      "maxItems": 100,
                      "items": {
                        "type": "object",
                        "properties": {
                          "transaction_id": {
                            "description": "Transaction identifier.",
                            "type": "string",
                            "maxLength": 50,
                            "example": "ABC123456"
                          },
                          "type": {
                            "description": "The transaction type.\nPAYMENT = Payment\nREFUND = Reimbursement\n",
                            "type": "string",
                            "example": "PAYMENT",
                            "enum": [
                              "PAYMENT",
                              "REFUND"
                            ]
                          },
                          "status": {
                            "description": "Status of the transaction.\nPROCESSING = The transaction is being processed.\nERROR = The transaction failed.\nPROCESSED = The transaction is validated.\nCANCELLED = The transaction is cancelled.\n",
                            "type": "string",
                            "example": "PROCESSED",
                            "enum": [
                              "PROCESSING",
                              "PROCESSED",
                              "CANCELLED",
                              "ERROR"
                            ]
                          },
                          "amount": {
                            "description": "Total amount of the transaction.",
                            "allOf": [
                              {
                                "type": "object",
                                "additionalProperties": false,
                                "properties": {
                                  "value": {
                                    "description": "Amount, numeric, with 2 or 3 decimals.",
                                    "type": "number",
                                    "example": 199.99
                                  },
                                  "currency": {
                                    "description": "Currency of the amount.\nISO 4217 format (3 letter code).\n",
                                    "type": "string",
                                    "minLength": 3,
                                    "maxLength": 3,
                                    "example": "EUR"
                                  }
                                },
                                "required": [
                                  "value",
                                  "currency"
                                ]
                              }
                            ]
                          },
                          "processed_at": {
                            "description": "The transaction processed date.",
                            "type": "string",
                            "format": "date",
                            "example": "2018-11-20"
                          }
                        }
                      }
                    },
                    "policy_id": {
                      "description": "Unique final policy identifier.",
                      "type": "string",
                      "maxLength": 50,
                      "example": "ea45ec62-0d21-4f44-a577-b8624da2bf5b"
                    },
                    "draft_policy_number": {
                      "description": "Draft policy number, provided in case if the policy is not confirmed.",
                      "type": "string",
                      "maxLength": 50,
                      "readOnly": true
                    },
                    "cancellation_date": {
                      "description": "Cancellation date of the policy - ISO 8601 format (YYYY-MM-DD).",
                      "type": "string",
                      "format": "date",
                      "example": "2019-01-30"
                    },
                    "purchase_date": {
                      "description": "The date of the subscription (purchase) of the policy  - ISO 8601\nformat (YYYY-MM-DD).\n",
                      "type": "string",
                      "format": "date",
                      "example": "2019-01-23"
                    },
                    "coverage_period": {
                      "description": "The coverage period - ISO 8601 format (YYYY-MM-DD).\nThe coverage start date is the date when it becomes possible for the customer to submit a claim.\nThe coverage end date is the date after which the coverage ends.\n",
                      "allOf": [
                        {
                          "type": "object",
                          "properties": {
                            "start_date": {
                              "description": "Start date - ISO 8601 format (YYYY-MM-DD).",
                              "type": "string",
                              "format": "date"
                            },
                            "end_date": {
                              "description": "End date - ISO 8601 format (YYYY-MM-DD).",
                              "type": "string",
                              "format": "date"
                            }
                          }
                        }
                      ],
                      "example": {
                        "start_date": "2019-01-25",
                        "end_date": "2020-01-24"
                      }
                    },
                    "effective_period": {
                      "description": "The effective period  - ISO 8601 format (YYYY-MM-DD)\nThe start date indicates when the contract is starting = activation date.\nThe end date indicates when the contract is ending. If the policy is cancelled, then the field is updated\n",
                      "allOf": [
                        {
                          "type": "object",
                          "properties": {
                            "start_date": {
                              "description": "Start date - ISO 8601 format (YYYY-MM-DD).",
                              "type": "string",
                              "format": "date"
                            },
                            "end_date": {
                              "description": "End date - ISO 8601 format (YYYY-MM-DD).",
                              "type": "string",
                              "format": "date"
                            }
                          }
                        }
                      ],
                      "example": {
                        "start_date": "2019-01-25",
                        "end_date": "2020-01-24"
                      }
                    },
                    "contracting_actor_name": {
                      "description": "The legal entity relied to the customer.",
                      "type": "string",
                      "maxLength": 100,
                      "example": "EXPEDIA UK"
                    },
                    "editable_version": {
                      "description": "Version of the catalog to use in case of policy edit.\n- SOLD_AS: use the version of the catalog the policy was sold under.\n- LATEST: use the latest version of the catalog.\n",
                      "type": "string",
                      "enum": [
                        "SOLD_AS",
                        "LATEST"
                      ]
                    },
                    "legal_withdrawal_period": {
                      "description": "The legal withdrawal period\nISO 8601 format (P5Y8M4D).\n",
                      "maxLength": 10,
                      "type": "string",
                      "example": "P14D"
                    },
                    "catalog": {
                      "description": "The product catalog.",
                      "allOf": [
                        {
                          "type": "object",
                          "properties": {
                            "code": {
                              "description": "The code of the product catalog relied to the policy",
                              "type": "string",
                              "maxLength": 50,
                              "example": "Opodo FR"
                            },
                            "version": {
                              "description": "Catalog version.",
                              "type": "string",
                              "maxLength": 10,
                              "example": "v12"
                            },
                            "country": {
                              "description": "Origin country, ISO-3166-1 alpha-2 format (2 letter codes).",
                              "type": "string",
                              "example": "FR",
                              "minLength": 2,
                              "maxLength": 2
                            },
                            "currency": {
                              "description": "Currency, ISO 4217 format (3 letter code).",
                              "type": "string",
                              "minLength": 3,
                              "maxLength": 3,
                              "example": "EUR"
                            }
                          },
                          "required": [
                            "code",
                            "version"
                          ]
                        }
                      ]
                    },
                    "guarantees": {
                      "description": "Set of guarantees included in the product.",
                      "type": "array",
                      "maxItems": 1000,
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {
                            "description": "Guarantee code.",
                            "type": "string",
                            "example": "accidental_damage",
                            "maxLength": 50
                          },
                          "label": {
                            "description": "Guarantee label.",
                            "type": "string",
                            "maxLength": 255,
                            "example": "Medical repatriation."
                          },
                          "is_sub_guarantee": {
                            "description": "True if it's a sub guarantee, false if not.",
                            "type": "boolean",
                            "example": true
                          }
                        }
                      }
                    },
                    "product": {
                      "description": "Product subscribed on the policy.",
                      "allOf": [
                        {
                          "type": "object",
                          "description": "Product information.",
                          "properties": {
                            "code": {
                              "description": "Product code",
                              "maxLength": 20,
                              "type": "string",
                              "example": "PRTNCATALOG"
                            },
                            "name": {
                              "description": "Product name",
                              "type": "string",
                              "maxLength": 50,
                              "example": "Short Stay Travel - Formula 1"
                            },
                            "headline": {
                              "description": "Product marketing title.",
                              "type": "string",
                              "maxLength": 1000,
                              "example": "Short Stay Travel - Simple"
                            },
                            "description": {
                              "description": "Product marketing description.",
                              "type": "string",
                              "maxLength": 1000,
                              "example": "The coverage includes this but not that."
                            },
                            "price_after_discount_inc_tax": {
                              "description": "Price amount discounted including taxes, numeric with 2 decimals.",
                              "type": "number",
                              "example": 150.25
                            },
                            "price_before_discount_excl_tax": {
                              "description": "Price not discounted excluding taxes, numeric with 2 decimals.",
                              "type": "number",
                              "example": 200.25
                            },
                            "total_discount": {
                              "description": "Total amount of discount, numeric with 2 decimals.",
                              "type": "number",
                              "example": 10
                            },
                            "premium_after_discount_excl_tax": {
                              "description": "Premium discounted excluding taxes, numeric with 2 decimals.",
                              "type": "number",
                              "example": 180
                            },
                            "total_taxes": {
                              "description": "Total amount of taxes, numeric with 2 decimals.",
                              "type": "number",
                              "example": 5
                            },
                            "sub_category": {
                              "description": "Product sub category.",
                              "type": "string",
                              "example": "VoyageSimple",
                              "maxLength": 50
                            },
                            "promo_code": {
                              "description": "Promotion code provided on the product on which it has been applied.",
                              "type": "string",
                              "example": "ETE2018",
                              "maxLength": 50
                            },
                            "guarantee_class_prices": {
                              "description": "The list of class of guarantees and their impact on the product\nprice.\n",
                              "type": "array",
                              "maxItems": 100,
                              "items": {
                                "type": "object",
                                "description": "The amount that each class of guarantee impacts the price of the product.",
                                "properties": {
                                  "code": {
                                    "description": "Guarantee class code.",
                                    "maxLength": 50,
                                    "type": "string",
                                    "example": "GUARANTEE_CLASS_02"
                                  },
                                  "label": {
                                    "description": "Guarantee class label.",
                                    "type": "string",
                                    "maxLength": 255,
                                    "example": "Accident"
                                  },
                                  "premium_after_discount_excl_tax": {
                                    "description": "Premium discounted excluding taxes, numeric with 2 decimals.",
                                    "type": "number",
                                    "example": 180
                                  },
                                  "total_taxes": {
                                    "description": "Total amount of taxes, numeric with 2 decimals.",
                                    "type": "number",
                                    "example": 5
                                  }
                                }
                              }
                            },
                            "coverage_repartition": {
                              "description": "The list of coverage repartition and their impact on the product\nprice.\n",
                              "type": "array",
                              "maxItems": 100,
                              "items": {
                                "type": "object",
                                "description": "The amount that each coverage repartition of guarantee impacts the price of the product.",
                                "properties": {
                                  "category": {
                                    "description": "Description of the category of the coverage repartition.",
                                    "maxLength": 150,
                                    "type": "string",
                                    "example": "missed_connection_cruise_and_tour_departures"
                                  },
                                  "gross_premium": {
                                    "description": "Premium discounted excluding taxes, numeric with 2 decimals.",
                                    "type": "number",
                                    "example": 180
                                  },
                                  "tax_amount": {
                                    "description": "Total amount of taxes, numeric with 2 decimals.",
                                    "type": "number",
                                    "example": 5
                                  },
                                  "tax_type": {
                                    "description": "Description of the tax type affected on this coverage.",
                                    "maxLength": 150,
                                    "type": "string",
                                    "example": "INSURANCE"
                                  },
                                  "label": {
                                    "description": "Marketing Coverage Repartition label.",
                                    "type": "string",
                                    "maxLength": 255,
                                    "example": "Missed Connection (Cruise and tour Departures)"
                                  },
                                  "name": {
                                    "description": "Name of the coverage repartition that helps identify it to underwritters.",
                                    "type": "string",
                                    "maxLength": 255,
                                    "example": "CR-180628"
                                  }
                                }
                              }
                            },
                            "payment_modes": {
                              "description": "The list of payment modes available for that product.\n",
                              "type": "array",
                              "maxItems": 100,
                              "items": {
                                "type": "object",
                                "description": "The information regarding a payment Method.",
                                "properties": {
                                  "type": {
                                    "description": "The code of the payment modes allowed.\nThe possible values are:\n- APPLE_PAY: refers to payments with Apple Pay.\n\n- BIZUM: refers to payments with Bizum (only Spain).\n\n- CREDIT_CARD: refers to payments with Credit and Debit Cards.\n\n- ELECTRONIC_TRANSFERT: refers to bank transfers across Europe.\n\n- GOOGLE_PAY: refers to payments with Google Pay.\n\n- IDEAL: refers to payments with Ideal (mainly Netherlands).\n\n- PAYPAL: refers to payments with Paypal.\n",
                                    "maxLength": 50,
                                    "type": "string",
                                    "example": "PAYPAL",
                                    "enum": [
                                      "APPLE_PAY",
                                      "BIZUM",
                                      "CREDIT_CARD",
                                      "ELECTRONIC_TRANSFERT",
                                      "GOOGLE_PAY",
                                      "IDEAL",
                                      "PAYPAL"
                                    ]
                                  },
                                  "is_an_express_checkout": {
                                    "description": "Flag used to identify if this payment method should be called on screen load.",
                                    "type": "boolean"
                                  },
                                  "Provider": {
                                    "type": "object",
                                    "description": "Details about Payment Service Provider used with.",
                                    "allOf": [
                                      {
                                        "description": "Details about Payment Service Provider used with.",
                                        "type": "object",
                                        "properties": {
                                          "id": {
                                            "description": "Beneficiary identifier.",
                                            "maxLength": 50,
                                            "type": "string",
                                            "example": "52664e48-a35f-4f68-b3f3-1e45d0f7dbb9"
                                          },
                                          "label": {
                                            "description": "Name of Provider",
                                            "type": "string",
                                            "maxLength": 50,
                                            "example": "WorldPay"
                                          }
                                        }
                                      }
                                    ]
                                  }
                                }
                              }
                            }
                          }
                        }
                      ]
                    },
