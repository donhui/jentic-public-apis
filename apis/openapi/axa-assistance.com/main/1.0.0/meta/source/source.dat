                    "motor_coverages": {
                      "description": "Motor coverage information insured.\n",
                      "type": "object",
                      "allOf": [
                        {
                          "type": "object",
                          "description": "Insured motor assets.\n",
                          "properties": {
                            "insured_items": {
                              "description": "Beneficiaries list for motor products\n",
                              "type": "object",
                              "allOf": [
                                {
                                  "type": "object",
                                  "properties": {
                                    "vehicles": {
                                      "description": "Vehicle specific information",
                                      "type": "array",
                                      "maxItems": 100,
                                      "items": {
                                        "description": "Vehicle specific information",
                                        "type": "object",
                                        "properties": {
                                          "registration_number": {
                                            "description": "Car's license plate",
                                            "type": "string",
                                            "maxLength": 50,
                                            "example": "4234BMW"
