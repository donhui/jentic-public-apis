                                  "example": "1990-04-25"
                                },
                                "age": {
                                  "description": "Age of the person. Only required if needed for the quote and no birth_date is provided.",
                                  "type": "integer",
                                  "example": 33
                                },
                                "additional_information": {
                                  "description": "Additional information filled by the partner if needed\n(example : Passport number, Hotel room number...).\n",
                                  "type": "array",
                                  "maxItems": 1000,
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "code": {
                                        "description": "Information code.",
                                        "type": "string",
                                        "maxLength": 50
                                      },
                                      "value": {
                                        "description": "Information value.",
                                        "type": "string",
                                        "maxLength": 255
                                      }
                                    },
                                    "required": [
