                                  "type": "array",
                                  "maxItems": 2,
                                  "items": {
                                    "type": "string",
                                    "enum": [
                                      "EMAIL",
                                      "SMS"
                                    ]
                                  },
                                  "example": [
                                    "EMAIL",
