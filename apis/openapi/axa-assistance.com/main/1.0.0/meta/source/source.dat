                                        "example": "John"
                                      },
                                      "last_name": {
                                        "type": "string",
                                        "maxLength": 100,
                                        "example": "Doe",
                                        "description": "Last name of the account's owner."
                                      },
                                      "billing_address": {
                                        "type": "object",
                                        "properties": {
                                          "street_address": {
                                            "description": "Street address.",
                                            "type": "string",
                                            "example": "150 Avenue de Paris",
                                            "maxLength": 255
                                          },
                                          "postal_code": {
                                            "description": "Postal code or zip code.",
                                            "type": "string",
                                            "example": "75001",
                                            "maxLength": 10
                                          },
                                          "city": {
                                            "description": "City.",
                                            "type": "string",
                                            "example": "Paris",
                                            "maxLength": 100
                                          },
                                          "country": {
                                            "description": "Country.",
                                            "type": "string",
                                            "example": "FR",
                                            "maxLength": 100
                                          },
                                          "province": {
                                            "description": "Province.",
                                            "type": "string",
                                            "maxLength": 100
                                          }
                                        }
                                      }
                                    }
                                  },
                                  "account_name": {
                                    "type": "string",
                                    "maxLength": 100,
                                    "description": "Name's of this bank account",
                                    "example": "Personal Account"
                                  },
                                  "country_code": {
                                    "type": "string",
                                    "minLength": 2,
                                    "maxLength": 2,
                                    "description": "Bank's country code, ISO-3166-1 alpha-2 format (2 letters code).",
                                    "example": "FR"
                                  },
                                  "wire_code": {
                                    "type": "array",
                                    "maxItems": 50,
                                    "items": {
                                      "type": "object",
