                              "address": {
                                "description": "Postal address",
                                "allOf": [
                                  {
                                    "type": "object",
                                    "properties": {
                                      "street_address": {
                                        "description": "Street address.",
                                        "type": "string",
                                        "example": "150 Avenue de Paris",
                                        "maxLength": 255
                                      },
                                      "postal_code": {
                                        "description": "Postal code or zip code.",
                                        "type": "string",
                                        "example": "75001",
                                        "maxLength": 10
                                      },
                                      "city": {
                                        "description": "City.",
                                        "type": "string",
                                        "example": "Paris",
