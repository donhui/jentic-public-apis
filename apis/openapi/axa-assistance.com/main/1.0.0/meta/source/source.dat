    "/sales/v2/individual/travel/policies/{policy_id}/payment_updates": {
      "post": {
        "summary": "Post new payment information related to the policy.",
        "description": "Cf. summary",
        "x-business-category": "TRAVEL",
        "parameters": [
          {
            "name": "accept-language",
            "in": "header",
            "required": false,
            "description": "Accepted language, IANA language codification. If language not managed, \"en\" will be used by default.",
            "schema": {
              "type": "string",
              "example": "en",
              "maxLength": 5
            }
          },
          {
            "name": "policy_id",
            "description": "Unique policy identifier.",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "ea45ec62-0d21-4f44-a577-b8624da2bf5b",
              "maxLength": 150
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "payment": {
                    "description": "Payment information provided by the API caller.",
                    "allOf": [
                      {
                        "type": "object",
                        "description": "Payment information, at least one of the properties psp_transaction_id or transfer_information should be provided.",
                        "properties": {
                          "type": {
                            "description": "Payment mode selected.",
                            "type": "string",
                            "enum": [
                              "CREDIT_CARD",
                              "DEBIT_CARD",
                              "ELECTRONIC_TRANSFERT",
                              "VIRTUAL_CREDIT_CARD",
                              "DIRECT_PAYMENT"
                            ],
                            "example": "CREDIT_CARD"
                          },
                          "psp_transaction_id": {
                            "description": "Payment reference on the payment provider system.",
                            "type": "string",
                            "maxLength": 150,
                            "example": "3af6781b-3f47-4d3f-ae94-0e5167c22dc3"
                          },
                          "transfer_information": {
                            "description": "Information about the payer.",
                            "allOf": [
                              {
                                "type": "object",
                                "properties": {
                                  "account_holder": {
                                    "type": "object",
                                    "properties": {
                                      "first_name": {
                                        "type": "string",
                                        "maxLength": 100,
                                        "description": "First name of the account's owner.",
                                        "example": "John"
                                      },
                                      "last_name": {
                                        "type": "string",
                                        "maxLength": 100,
                                        "example": "Doe",
                                        "description": "Last name of the account's owner."
                                      },
                                      "billing_address": {
                                        "type": "object",
                                        "properties": {
                                          "street_address": {
                                            "description": "Street address.",
                                            "type": "string",
                                            "example": "150 Avenue de Paris",
                                            "maxLength": 255
                                          },
                                          "postal_code": {
                                            "description": "Postal code or zip code.",
                                            "type": "string",
                                            "example": "75001",
                                            "maxLength": 10
                                          },
                                          "city": {
                                            "description": "City.",
                                            "type": "string",
                                            "example": "Paris",
                                            "maxLength": 100
                                          },
                                          "country": {
                                            "description": "Country.",
                                            "type": "string",
                                            "example": "FR",
                                            "maxLength": 100
                                          },
                                          "province": {
                                            "description": "Province.",
                                            "type": "string",
                                            "maxLength": 100
                                          }
                                        }
                                      }
                                    }
                                  },
                                  "account_name": {
                                    "type": "string",
                                    "maxLength": 100,
                                    "description": "Name's of this bank account",
                                    "example": "Personal Account"
                                  },
                                  "country_code": {
                                    "type": "string",
                                    "minLength": 2,
                                    "maxLength": 2,
                                    "description": "Bank's country code, ISO-3166-1 alpha-2 format (2 letters code).",
                                    "example": "FR"
                                  },
                                  "wire_code": {
                                    "type": "array",
                                    "maxItems": 50,
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "wire_code_type": {
                                          "type": "string",
                                          "enum": [
                                            "IBAN"
                                          ],
                                          "description": "Wire's type (only IBAN is accepted)"
                                        },
                                        "value": {
                                          "type": "string",
                                          "maxLength": 50,
                                          "description": "The value of the IBAN",
                                          "example": "FR7630006000011234567890189"
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            ]
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          },
          "description": "Content of payment information.",
          "required": true
        },
        "responses": {
          "200": {
            "description": "Policy confirmation response.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "allOf": [
                    {
                      "properties": {
                        "payment_technical_information": {
                          "description": "Technical information, provided to the API caller to allow it to\ncomplete the payment.\n",
                          "allOf": [
                            {
                              "type": "object",
                              "description": "Technical information for payment system access.\nThis information is provided to the API caller to allow it to complete the payment.\n",
                              "properties": {
                                "zuora_access": {
                                  "description": "Access information specific to Zuora.",
                                  "allOf": [
                                    {
                                      "type": "object",
                                      "properties": {
                                        "payment_gateway": {
                                          "description": "Payment gateway code.",
                                          "type": "string",
                                          "maxLength": 50
                                        },
                                        "key": {
                                          "description": "Public key generated for the subscription.",
                                          "type": "string",
                                          "maxLength": 2000
                                        },
                                        "signature": {
                                          "description": "Digital signature generated for the subscription.",
                                          "type": "string",
                                          "maxLength": 2000
                                        },
                                        "token": {
                                          "description": "Token generated for the subscription.",
                                          "type": "string",
                                          "maxLength": 2000
                                        },
                                        "tenant_id": {
                                          "description": "ID of the Zuora tenant.",
                                          "type": "string",
                                          "maxLength": 50
                                        },
                                        "page_id": {
                                          "description": "The page id.",
                                          "type": "string",
                                          "maxLength": 50
                                        }
                                      },
                                      "required": [
                                        "payment_gateway",
                                        "key",
                                        "signature",
                                        "token",
                                        "tenant_id",
                                        "page_id"
                                      ]
                                    }
                                  ]
                                }
                              },
                              "required": [
                                "zuora_access"
                              ]
                            }
                          ]
                        }
                      }
                    }
                  ]
                },
                "example": {}
              }
            }
          },
          "400": {
            "description": "Bad Request.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "400",
                  "error": "Bad Request",
                  "error_description": "The input information received were not compliant with the endpoint specification."
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized.\nThe identity of the caller has not been definitely confirmed (invalid issuer, expired token, ...)\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "401",
                  "error": "Unauthorized",
                  "error_description": "Header \"authorization\" is not a valid JSON Web Token."
                }
              }
            }
          },
          "403": {
            "description": "Forbidden.\nThe identity of the caller is confirmed, however the required access grants are not met (missing scope, unknown client_id, ...)\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "403",
                  "error": "Forbidden",
                  "error_description": "The right to access this endpoint has not been granted in the JSON Web Token."
                }
              }
            }
          },
          "404": {
            "description": "Not found.\nThe server did not find a current representation for the searched resource.\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "404",
                  "error": "Not Found",
                  "error_description": "The searched resource was not found."
                }
              }
            }
          },
          "default": {
            "description": "Default response format.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "error": {
                      "type": "string",
                      "maxLength": 50
                    },
                    "error_description": {
                      "type": "string",
                      "maxLength": 4000
                    },
                    "status_code": {
                      "type": "string",
                      "maxLength": 3
                    }
                  }
                },
                "example": {
                  "status_code": "500",
                  "error": "Internal Server Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "sandbox_auth0_cc": [
              "urn:axa.partners.sales.individual.travel.policies.write"
            ]
          }
        ]
      }
    },
    "/sales/v2/individual/travel/policies/{policy_id}/rectify_failed_payment": {
      "post": {
        "summary": "Rectify the failed payments.",
        "description": "Cf. summary",
        "x-business-category": "TRAVEL",
        "parameters": [
          {
            "name": "accept-language",
            "in": "header",
            "required": false,
            "description": "Accepted language, IANA language codification. If language not managed, \"en\" will be used by default.",
            "schema": {
              "type": "string",
              "example": "en",
              "maxLength": 5
            }
          },
          {
            "name": "policy_id",
            "description": "Unique policy identifier.",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "ea45ec62-0d21-4f44-a577-b8624da2bf5b",
              "maxLength": 150
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "field_accountId": {
                    "description": "The account identifier.",
                    "type": "string",
                    "maxLength": 150,
                    "example": "2c92c0f8724a0bc001724c4ba8dd2aa4"
                  },
                  "psp_transaction_id": {
                    "description": "Payment reference on the payment provider system.",
                    "type": "string",
                    "maxLength": 150,
                    "example": "2c92c0f8724a0bc001724c4ba8dd2aa4"
                  },
                  "is_update_without_payment": {
                    "description": "Flag used to change payment method without charge the customer.",
                    "type": "boolean",
                    "example": true
                  }
                },
                "required": [
                  "field_accountId",
                  "psp_transaction_id"
                ]
              }
            }
          },
          "description": "Rectification payment request.",
          "required": true
        },
        "responses": {
