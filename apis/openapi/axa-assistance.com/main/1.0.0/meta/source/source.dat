                            {
                              "type": "object",
                              "properties": {
                                "title": {
                                  "description": "Civility (Mr, Ms, Miss, Doctor, Professor).",
                                  "type": "string",
                                  "enum": [
                                    "MR",
                                    "MS",
                                    "MISS",
                                    "DR",
                                    "PR"
