      "patch": {
        "summary": "Update the order.",
        "description": "Cf. summary",
        "x-business-category": "TRAVEL",
        "parameters": [
          {
            "name": "order_id",
            "description": "Unique order identifier.",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "example": "91ff04ed-0352-4e5e-bb83-5c88e7f3cd3a",
              "maxLength": 150
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "quote_code": {
                    "description": "Quote code, partner can use a default value if provided by AXA or got it with quoting API.",
                    "type": "string",
                    "example": "eJxVj8FuwjAMht8l5wq1ULapt5J2FRJbUGh6rUIbokgs6UwibUJ99yUrReCT",
                    "maxLength": 2000
                  },
                  "addons": {
                    "description": "List of additional option codes that the customer can subscribe in addition to the product.\nNote: There is here only the list of add-ons codes. The contents of each add-on is described in the response of the End Point for Travel quote request.\n",
                    "type": "array",
                    "maxItems": 10,
                    "items": {
                      "type": "string",
                      "maxLength": 1000,
                      "example": "eJxVj8FuwjAMht8l5wq1ULapt5J2FRJbUGh6rUIbokgs6UwibUJ99yUrReCT"
                    }
                  }
                },
                "required": [
                  "quote_code"
                ]
              }
            }
          },
          "description": "Order update request.",
