                                "description": "Middle name.",
                                "type": "string",
                                "example": "Junior",
                                "maxLength": 100
                              },
                              "last_name": {
                                "description": "Last name.",
                                "type": "string",
                                "maxLength": 100,
                                "example": "Doe"
                              },
                              "birth_date": {
                                "description": "Birth date - ISO 8601 format (YYYY-MM-DD).",
                                "type": "string",
                                "format": "date",
                                "example": "1990-04-25"
                              },
                              "email": {
                                "description": "Email address.",
                                "allOf": [
                                  {
                                    "type": "string",
                                    "format": "email",
                                    "example": "jonathan.doe@mail.com"
