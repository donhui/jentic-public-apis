                                  ]
                                },
                                "registrations": {
                                  "description": "List of customer registrations.",
                                  "type": "array",
                                  "maxItems": 2,
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "registration_type": {
                                        "description": "Type of person registration.",
                                        "type": "string",
                                        "enum": [
                                          "ID_CARD",
