                      "maxLength": 1000
                    }
                  },
                  "quote_code": {
                    "description": "New quote code provided by quoting API. Only for draft policies.",
                    "type": "string",
                    "maxLength": 2000,
                    "example": "d41d8cd98f00b204e9800998ecf8427e"
                  },
                  "payment": {
                    "description": "Payment",
                    "type": "object",
                    "properties": {
                      "bad_debt": {
                        "type": "object",
                        "description": "If amount property is set to `null`, then policy is out of bad debt. Otherwise, please specify the bad debt value and currency",
                        "properties": {
                          "amount": {
                            "type": "object",
                            "description": "Bad debt amount.\n\nIf amount property is set to `null`, then policy is out of bad debt.\nOtherwise, please specify the bad debt value and currency\n",
                            "additionalProperties": false,
                            "properties": {
                              "value": {
                                "description": "Amount, numeric, with 2 or 3 decimals. Only negative values, `0` (zero) is not accepted\n",
                                "type": "number",
                                "maximum": 0,
                                "exclusiveMaximum": true,
                                "example": -12.75
                              },
                              "currency": {
                                "description": "Currency of the amount.\nISO 4217 format (3 letter code).\n",
                                "type": "string",
                                "minLength": 3,
                                "maxLength": 3,
                                "example": "EUR"
                              }
                            },
                            "required": [
                              "value",
                              "currency"
                            ],
                            "nullable": true,
                            "example": null
                          },
                          "effective_date": {
                            "description": "Date when the bad debt update needs to be reflected, is today or in the past - ISO 8601 format (YYYY-MM-DD).",
                            "type": "string",
                            "format": "date",
                            "example": "2025-08-20"
                          }
                        },
                        "required": [
                          "amount",
                          "effective_date"
                        ]
                      }
                    }
                  }
                }
              }
            }
