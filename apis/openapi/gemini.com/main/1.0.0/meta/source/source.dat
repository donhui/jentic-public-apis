{
  "openapi": "3.0.3",
  "info": {
    "title": "Gemini REST API",
    "version": "1.0.0",
    "description": "Gemini is a cryptocurrency exchange offering REST APIs for market data, order management, fund management, and account administration. Public market data endpoints require no authentication while private endpoints use HMAC-SHA384 signatures.",
    "x-jentic-source-url": "https://docs.gemini.com/rest-api/"
  },
  "servers": [
    {
      "url": "https://api.gemini.com",
      "description": "Production"
    },
    {
      "url": "https://api.sandbox.gemini.com",
      "description": "Sandbox"
    }
  ],
  "paths": {
    "/v1/symbols": {
      "get": {
        "operationId": "listSymbols",
        "summary": "List all available symbols",
        "description": "Retrieves all available symbols for trading.",
        "tags": ["Market Data"],
        "security": [],
        "responses": {
          "200": {
            "description": "List of trading symbols",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/symbols/details/{symbol}": {
      "get": {
        "operationId": "getSymbolDetails",
        "summary": "Get symbol details",
        "description": "Retrieves extra detail on a supported symbol including minimum order size, tick size, and quote increment.",
        "tags": ["Market Data"],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "Trading symbol (e.g., btcusd)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Symbol details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SymbolDetails"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/networks/{network}/assets": {
      "get": {
        "operationId": "getNetworkAssets",
        "summary": "Get assets for a network",
        "description": "Retrieves the enabled assets available on a specified blockchain network.",
        "tags": ["Market Data"],
        "security": [],
        "parameters": [
          {
            "name": "network",
            "in": "path",
            "required": true,
            "description": "Blockchain network name (e.g., ethereum)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of assets on the network",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/network/{token}": {
      "get": {
        "operationId": "getTokenNetworks",
        "summary": "Get networks for a token",
        "description": "Returns networks with deposit and withdrawal access for a given token. Requires Fund Manager role.",
        "tags": ["Market Data"],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "description": "Token identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Networks available for the token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "network": {
                        "type": "string"
                      },
                      "deposit": {
                        "type": "boolean"
                      },
                      "withdraw": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/pubticker/{symbol}": {
      "get": {
        "operationId": "getTicker",
        "summary": "Get ticker (v1)",
        "description": "Retrieves information about recent trading activity for the symbol.",
        "tags": ["Market Data"],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "Trading symbol",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticker data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TickerV1"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/ticker/{symbol}": {
      "get": {
        "operationId": "getTickerV2",
        "summary": "Get ticker (v2)",
        "description": "Retrieves ticker data with OHLC and 24-hour volume information.",
        "tags": ["Market Data"],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "Trading symbol",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticker v2 data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TickerV2"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/feepromos": {
      "get": {
        "operationId": "listFeePromos",
        "summary": "List fee promotions",
        "description": "Retrieves symbols that currently have fee promotions.",
        "tags": ["Market Data"],
        "security": [],
        "responses": {
          "200": {
            "description": "Fee promotions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "symbols": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/book/{symbol}": {
      "get": {
        "operationId": "getOrderBook",
        "summary": "Get current order book",
        "description": "Return the current order book as two arrays (bids / asks).",
        "tags": ["Market Data"],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "Trading symbol",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit_bids",
            "in": "query",
            "description": "Limit the number of bid price levels returned",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit_asks",
            "in": "query",
            "description": "Limit the number of ask price levels returned",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order book data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderBook"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/trades/{symbol}": {
      "get": {
        "operationId": "listTrades",
        "summary": "List trades",
        "description": "Return the trades that have executed since the specified timestamp. Limited to 7 calendar days.",
        "tags": ["Market Data"],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "Trading symbol",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "description": "Only return trades after this timestamp (seconds or milliseconds)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "since_tid",
            "in": "query",
            "description": "Only return trades after this trade ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit_trades",
            "in": "query",
            "description": "Maximum number of trades to return (default 50)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "include_breaks",
            "in": "query",
            "description": "Whether to include trade breaks",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trade history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Trade"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/pricefeed": {
      "get": {
        "operationId": "listPrices",
        "summary": "Get price feed",
        "description": "Current price feed for all trading pairs with 24-hour changes.",
        "tags": ["Market Data"],
        "security": [],
        "responses": {
          "200": {
            "description": "Price feed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PriceFeedEntry"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/fundingamount/{symbol}": {
      "get": {
        "operationId": "getFundingAmount",
        "summary": "Get funding amount",
        "description": "Funding amount for perpetual swap contracts.",
        "tags": ["Derivatives"],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "Perpetual swap symbol",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Funding amount data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "symbol": {
                      "type": "string"
                    },
                    "fundingAmount": {
                      "type": "string"
                    },
                    "fundingRate": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/candles/{symbol}/{time_frame}": {
      "get": {
        "operationId": "listCandles",
        "summary": "Get candle data",
        "description": "Time-intervaled OHLCV candle data for a symbol.",
        "tags": ["Market Data"],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "Trading symbol",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "time_frame",
            "in": "path",
            "required": true,
            "description": "Candle time frame",
            "schema": {
              "type": "string",
              "enum": ["1m", "5m", "15m", "30m", "1hr", "6hr", "1day"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Candle data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Candle"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v2/fxrate/{symbol}/{timestamp}": {
      "get": {
        "operationId": "getFxRate",
        "summary": "Get historical FX rate",
        "description": "Historical FX rates. Requires Auditor role.",
        "tags": ["Market Data"],
        "parameters": [
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "description": "Currency pair symbol",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "path",
            "required": true,
            "description": "Unix timestamp for the rate",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "FX rate data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fxPair": {
                      "type": "string"
                    },
                    "rate": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/order/new": {
      "post": {
        "operationId": "createOrder",
        "summary": "Create new order",
        "description": "Place a new trading order.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/order/cancel": {
      "post": {
        "operationId": "cancelOrder",
        "summary": "Cancel an order",
        "description": "Cancel an existing open order by order ID.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["order_id"],
                "properties": {
                  "order_id": {
                    "type": "integer",
                    "description": "The order ID to cancel"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/order/cancel/all": {
      "post": {
        "operationId": "cancelAllOrders",
        "summary": "Cancel all active orders",
        "description": "Remove all open orders for the account.",
        "tags": ["Orders"],
        "responses": {
          "200": {
            "description": "All orders cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "string"
                    },
                    "details": {
                      "type": "object",
                      "properties": {
                        "cancelledOrders": {
                          "type": "array",
                          "items": {
                            "type": "integer"
                          }
                        },
                        "cancelRejects": {
                          "type": "array",
                          "items": {
                            "type": "integer"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/order/status": {
      "post": {
        "operationId": "getOrderStatus",
        "summary": "Get order status",
        "description": "Retrieve the current status of a specific order.",
        "tags": ["Orders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["order_id"],
                "properties": {
                  "order_id": {
                    "type": "integer",
                    "description": "The order ID to check"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/orders": {
      "post": {
        "operationId": "listActiveOrders",
        "summary": "List active orders",
        "description": "Retrieve all currently open orders.",
        "tags": ["Orders"],
        "responses": {
          "200": {
            "description": "Active orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Order"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/orders/history": {
      "post": {
        "operationId": "listPastOrders",
        "summary": "List past orders",
        "description": "Retrieve historical order data.",
        "tags": ["Orders"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "symbol": {
                    "type": "string",
                    "description": "Filter by symbol"
                  },
                  "limit_orders": {
                    "type": "integer",
                    "description": "Maximum number of orders to return"
                  },
                  "timestamp": {
                    "type": "integer",
                    "description": "Only return orders after this timestamp"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Past orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Order"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/mytrades": {
      "post": {
        "operationId": "listMyTrades",
        "summary": "List past trades",
        "description": "Get historical trade execution records.",
        "tags": ["Orders"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "symbol": {
                    "type": "string",
                    "description": "Trading symbol"
                  },
                  "limit_trades": {
                    "type": "integer",
                    "description": "Maximum number of trades to return"
                  },
                  "timestamp": {
                    "type": "integer",
                    "description": "Only return trades after this timestamp"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Past trades",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Trade"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/balances": {
      "post": {
        "operationId": "getAvailableBalances",
        "summary": "Get available balances",
        "description": "Retrieve account holdings with available and total amounts.",
        "tags": ["Fund Management"],
        "responses": {
          "200": {
            "description": "Account balances",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Balance"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/notionalbalances/{currency}": {
      "post": {
        "operationId": "getNotionalBalances",
        "summary": "Get notional balances",
        "description": "Retrieve account balances converted to the specified fiat currency.",
        "tags": ["Fund Management"],
        "parameters": [
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "description": "Fiat currency for valuation (e.g., USD)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Notional balances",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NotionalBalance"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/addresses/{currency}": {
      "post": {
        "operationId": "listDepositAddresses",
        "summary": "List deposit addresses",
        "description": "List deposit addresses for a specific cryptocurrency.",
        "tags": ["Fund Management"],
        "parameters": [
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deposit addresses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DepositAddress"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/deposit/{currency}/newAddress": {
      "post": {
        "operationId": "createDepositAddress",
        "summary": "Create new deposit address",
        "description": "Generate a new deposit address for the specified cryptocurrency.",
        "tags": ["Fund Management"],
        "parameters": [
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "network": {
                    "type": "string",
                    "description": "Specific blockchain network"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New deposit address",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DepositAddress"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/withdraw/{currency}": {
      "post": {
        "operationId": "withdrawCrypto",
        "summary": "Withdraw crypto funds",
        "description": "Execute a cryptocurrency withdrawal to a specified address.",
        "tags": ["Fund Management"],
        "parameters": [
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency to withdraw",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WithdrawRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Withdrawal initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WithdrawResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/withdraw/{currency}/estimate/fee": {
      "post": {
        "operationId": "estimateWithdrawalFee",
        "summary": "Estimate withdrawal fee",
        "description": "Get gas fee estimation for a withdrawal.",
        "tags": ["Fund Management"],
        "parameters": [
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "description": "Cryptocurrency code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["address", "amount"],
                "properties": {
                  "address": {
                    "type": "string",
                    "description": "Destination address"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Withdrawal quantity"
                  },
                  "network": {
                    "type": "string",
                    "description": "Blockchain network"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fee estimation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "estimatedFee": {
                      "type": "string"
                    },
                    "currency": {
                      "type": "string"
                    },
                    "network": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/transfers": {
      "post": {
        "operationId": "listTransfers",
        "summary": "List past transfers",
        "description": "Retrieve transaction history of deposits and withdrawals.",
        "tags": ["Fund Management"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "timestamp": {
                    "type": "integer",
                    "description": "Only return transfers after this timestamp"
                  },
                  "limit_transfers": {
                    "type": "integer",
                    "description": "Maximum number of transfers to return"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Transfer"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/account/transfer/{currency}": {
      "post": {
        "operationId": "transferBetweenAccounts",
        "summary": "Transfer between accounts",
        "description": "Move funds between accounts internally.",
        "tags": ["Fund Management"],
        "parameters": [
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "description": "Currency to transfer",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["targetAccountId", "amount"],
                "properties": {
                  "targetAccountId": {
                    "type": "string",
                    "description": "Recipient account ID"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Amount to transfer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "transferId": {
                      "type": "string"
                    },
                    "timestamp": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SymbolDetails": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "baseCurrency": {
            "type": "string"
          },
          "quoteCurrency": {
            "type": "string"
          },
          "tickSize": {
            "type": "number"
          },
          "quoteIncrement": {
            "type": "number"
          },
          "minOrderSize": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "TickerV1": {
        "type": "object",
        "properties": {
          "bid": {
            "type": "string"
          },
          "ask": {
            "type": "string"
          },
          "last": {
            "type": "string"
          },
          "volume": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "TickerV2": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "open": {
            "type": "string"
          },
          "high": {
            "type": "string"
          },
          "low": {
            "type": "string"
          },
          "close": {
            "type": "string"
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "bid": {
            "type": "string"
          },
          "ask": {
            "type": "string"
          }
        }
      },
      "OrderBook": {
        "type": "object",
        "properties": {
          "bids": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderBookEntry"
            }
          },
          "asks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderBookEntry"
            }
          }
        }
      },
      "OrderBookEntry": {
        "type": "object",
        "properties": {
          "price": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          }
        }
      },
      "Trade": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "integer"
          },
          "timestampms": {
            "type": "integer"
          },
          "tid": {
            "type": "integer"
          },
          "price": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "exchange": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["buy", "sell"]
          }
        }
      },
      "PriceFeedEntry": {
        "type": "object",
        "properties": {
          "pair": {
            "type": "string"
          },
          "price": {
            "type": "string"
          },
          "percentChange24h": {
            "type": "string"
          }
        }
      },
      "Candle": {
        "type": "array",
        "items": {
          "type": "number"
        },
        "description": "Array of [time, open, high, low, close, volume]"
      },
      "NewOrderRequest": {
        "type": "object",
        "required": ["symbol", "amount", "price", "side", "type"],
        "properties": {
          "symbol": {
            "type": "string",
            "description": "Trading symbol"
          },
          "amount": {
            "type": "string",
            "description": "Quoted decimal amount to purchase"
          },
          "price": {
            "type": "string",
            "description": "Quoted decimal amount to spend per unit"
          },
          "side": {
            "type": "string",
            "enum": ["buy", "sell"],
            "description": "Order side"
          },
          "type": {
            "type": "string",
            "enum": ["exchange limit", "exchange stop limit"],
            "description": "Order type"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["maker-or-cancel", "immediate-or-cancel", "fill-or-kill", "auction-only", "indication-of-interest"]
            },
            "description": "Order execution options"
          },
          "stop_price": {
            "type": "string",
            "description": "Price to trigger a stop-limit order"
          },
          "client_order_id": {
            "type": "string",
            "description": "Client-specified order ID"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "order_id": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "exchange": {
            "type": "string"
          },
          "avg_execution_price": {
            "type": "string"
          },
          "side": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "timestampms": {
            "type": "integer"
          },
          "is_live": {
            "type": "boolean"
          },
          "is_cancelled": {
            "type": "boolean"
          },
          "is_hidden": {
            "type": "boolean"
          },
          "was_forced": {
            "type": "boolean"
          },
          "executed_amount": {
            "type": "string"
          },
          "remaining_amount": {
            "type": "string"
          },
          "original_amount": {
            "type": "string"
          },
          "price": {
            "type": "string"
          }
        }
      },
      "Balance": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "available": {
            "type": "string"
          }
        }
      },
      "NotionalBalance": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "notionalValue": {
            "type": "string"
          }
        }
      },
      "DepositAddress": {
        "type": "object",
        "properties": {
          "currency": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer"
          }
        }
      },
      "WithdrawRequest": {
        "type": "object",
        "required": ["address", "amount"],
        "properties": {
          "address": {
            "type": "string",
            "description": "Destination blockchain address"
          },
          "amount": {
            "type": "string",
            "description": "Quantity to withdraw"
          },
          "network": {
            "type": "string",
            "description": "Blockchain network"
          }
        }
      },
      "WithdrawResponse": {
        "type": "object",
        "properties": {
          "destination": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "txHash": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer"
          }
        }
      },
      "Transfer": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["Deposit", "Withdrawal"]
          },
          "status": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer"
          },
          "txHash": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "geminiAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-GEMINI-APIKEY",
        "description": "HMAC-SHA384 authentication. Requires X-GEMINI-APIKEY, X-GEMINI-SIGNATURE, and X-GEMINI-PAYLOAD headers."
      }
    }
  },
  "security": [
    {
      "geminiAuth": []
    }
  ]
