          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "birthDate": {
            "type": "string",
            "format": "date"
          },
          "optInStatus": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          },
          "userProfileImageUrl": {
            "type": "string",
            "format": "uri"
          },
          "extendedAttribute": {
            "type": "object"
          }
        }
      },
