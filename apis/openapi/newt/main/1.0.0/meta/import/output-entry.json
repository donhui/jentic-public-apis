{
  "openapi": "3.0.3",
  "info": {
    "title": "Newt API",
    "description": "Newt is a content management platform that provides flexible and extensible APIs including CDN API, Content API, Assets API, and Form API for content delivery, retrieval, asset management, and form submissions.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developers.newt.so/"
  },
  "servers": [
    {
      "url": "https://{spaceUid}.cdn.newt.so/v1",
      "description": "Newt CDN API (cached content delivery)",
      "variables": {
        "spaceUid": {
          "description": "Your Newt space UID",
          "default": "your-space-uid"
        }
      }
    },
    {
      "url": "https://{spaceUid}.api.newt.so/v1",
      "description": "Newt API (latest content without CDN)",
      "variables": {
        "spaceUid": {
          "description": "Your Newt space UID",
          "default": "your-space-uid"
        }
      }
    },
    {
      "url": "https://{spaceUid}.assets.newt.so/v1",
      "description": "Newt Assets API (file retrieval)",
      "variables": {
        "spaceUid": {
          "description": "Your Newt space UID",
          "default": "your-space-uid"
        }
      }
    },
    {
      "url": "https://{spaceUid}.form.newt.so/v1",
      "description": "Newt Form API (form submissions)",
      "variables": {
        "spaceUid": {
          "description": "Your Newt space UID",
          "default": "your-space-uid"
        }
      }
    }
  ],
  "paths": {
    "/{appUid}/{modelUid}": {
      "get": {
        "operationId": "getContents",
        "summary": "Get contents matching query filters",
        "description": "Returns contents matching the provided query filters. Works with both CDN API and Content API servers.",
        "tags": [
          "Contents"
        ],
        "parameters": [
          {
            "name": "appUid",
            "in": "path",
            "required": true,
            "description": "App identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "modelUid",
            "in": "path",
            "required": true,
            "description": "Model identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "select",
            "in": "query",
            "description": "Comma-separated list of properties to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order. Prefix with - for descending (e.g., -_sys.createdAt)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results (1-1000, default 100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000,
              "default": 100
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of results to skip (default 0)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "depth",
            "in": "query",
            "description": "Reference field resolution depth (0-2, default 1)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2,
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with content list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "App or model not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/{appUid}/{modelUid}/{contentId}": {
      "get": {
        "operationId": "getContent",
        "summary": "Get a single content item by ID",
        "description": "Returns the content matching the provided ID.",
        "tags": [
          "Contents"
        ],
        "parameters": [
          {
            "name": "appUid",
            "in": "path",
            "required": true,
            "description": "App identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "modelUid",
            "in": "path",
            "required": true,
            "description": "Model identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "contentId",
            "in": "path",
            "required": true,
            "description": "Content identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "select",
            "in": "query",
            "description": "Comma-separated list of properties to return",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "depth",
            "in": "query",
            "description": "Reference field resolution depth (0-2, default 1)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 2,
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with content item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContentItem"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Content not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/space/apps/{appUid}": {
      "get": {
        "operationId": "getApp",
        "summary": "Get app information",
        "description": "Returns app information matching the appUid.",
        "tags": [
          "Apps"
        ],
        "parameters": [
          {
            "name": "appUid",
            "in": "path",
            "required": true,
            "description": "App identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with app information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInfo"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "App not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/{assetUid}/{assetName}": {
      "get": {
        "operationId": "getAsset",
        "summary": "Get an asset file",
        "description": "Retrieves an asset file. Supports image transformation, video conversion, and document format conversion via query parameters. No authentication required when using the Assets API server.",
        "tags": [
          "Assets"
        ],
        "security": [],
        "parameters": [
          {
            "name": "assetUid",
            "in": "path",
            "required": true,
            "description": "Asset unique identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "assetName",
            "in": "path",
            "required": true,
            "description": "Asset file name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "download",
            "in": "query",
            "description": "Specify filename for download",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "width",
            "in": "query",
            "description": "Resize width (images and videos)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "height",
            "in": "query",
            "description": "Resize height (images and videos)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "fit",
            "in": "query",
            "description": "Resize mode for images",
            "schema": {
              "type": "string",
              "enum": [
                "cover",
                "contain",
                "fill",
                "inside",
                "outside"
              ],
              "default": "cover"
            }
          },
          {
            "name": "quality",
            "in": "query",
            "description": "Quality adjustment for images (1-100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Output format conversion (auto, png, webp, avif, tiff, jpeg for images; webm, mp4 for videos; pdf for office docs)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Asset file binary content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Quota exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Asset not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/{formUid}": {
      "post": {
        "operationId": "submitForm",
        "summary": "Submit form data",
        "description": "Submits form data from end users. No authentication required when using the Form API server.",
        "tags": [
          "Forms"
        ],
        "security": [],
        "parameters": [
          {
            "name": "formUid",
            "in": "path",
            "required": true,
            "description": "Form identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FormSubmission"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/FormSubmission"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/FormSubmission"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FormSuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid fields, email, reCAPTCHA, or spam detected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Quota exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Form not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "413": {
            "description": "Payload too large",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Use CDN API token for CDN endpoints or API token for Content API endpoints."
      }
    },
    "schemas": {
      "ContentListResponse": {
        "type": "object",
        "properties": {
          "skip": {
            "type": "integer",
            "description": "Number of items skipped"
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of items returned"
          },
          "total": {
            "type": "integer",
            "description": "Total number of matching items"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentItem"
            }
          }
        }
      },
      "ContentItem": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "Content unique identifier"
          },
          "_sys": {
            "$ref": "#/components/schemas/SystemMetadata"
          }
        },
        "additionalProperties": true
      },
      "SystemMetadata": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          },
          "raw": {
            "type": "object",
            "properties": {
              "createdAt": {
                "type": "string",
                "format": "date-time"
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time"
              },
              "firstPublishedAt": {
                "type": "string",
                "format": "date-time"
              },
              "publishedAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "AppInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "App name"
          },
          "uid": {
            "type": "string",
            "description": "App unique identifier"
          },
          "icon": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "cover": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        }
      },
      "FormSubmission": {
        "type": "object",
        "additionalProperties": true,
        "description": "Form field data as key-value pairs. Fields depend on the form configuration.",
        "example": {
          "name": "Donna Thomason",
          "email": "donna.thomason@example.com"
        }
      },
      "FormSuccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "example": 200
          },
          "success": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Contents",
      "description": "Content retrieval operations (CDN and API)"
    },
    {
      "name": "Apps",
      "description": "App information retrieval"
    },
    {
      "name": "Assets",
      "description": "Asset file retrieval and transformation"
    },
    {
      "name": "Forms",
      "description": "Form submission operations"
    }
  ]
}