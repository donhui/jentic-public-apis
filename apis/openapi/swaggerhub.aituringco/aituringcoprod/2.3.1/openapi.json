{
  "swagger": "2.0",
  "info": {
    "version": "2.3.1",
    "title": "AITradeAPI",
    "contact": {
      "email": "nelson@aituring.co",
      "name": "Nelson Fajardo B",
      "url": "https://www.aituring.co"
    },
    "license": {
      "name": "No Licence"
    },
    "description": "AITuring API for web services usage",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/AITuringCo/AITuringCoProd/2.3.1/swagger.json"
  },
  "tags": [
    {
      "name": "Authentication",
      "description": "Secured Admin-only calls"
    },
    {
      "name": "Developers",
      "description": "Operations available to regular developers"
    }
  ],
  "paths": {
    "/obtain_token/": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Endpoint that returns a JSON web token. This is necesary to use the other endpoints.",
        "operationId": "obtain_token",
        "description": "Endpoint that returns a JSON web token. the token is valid for 24 hours . This is necesary to use the other endpoints.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "ObtainTokenRequest",
            "description": "JSON With username and password. This information is provided by the service provider (AITuring)",
            "schema": {
              "$ref": "#/definitions/ObtainTokenRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Valid Credentials"
          },
          "400": {
            "description": "Invalid credentials"
          },
          "401": {
            "description": "Unauthorized credentials"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/refresh_token/": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Endpoint that returns a JSON web token, you can refresh an old one. This is necesary to use the other endpoints.",
        "operationId": "refresh_token",
        "description": "Endpoint that returns a JSON web token, you can refresh an old one. This is necesary to use the other endpoints.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "inventoryItem",
            "description": "Inventory item to add",
            "schema": {
              "$ref": "#/definitions/RefreshTokenRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token refresh"
          },
          "400": {
            "description": "Error refreshing token"
          },
          "401": {
            "description": "Unauthorized credentials"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/create/place_task/": {
      "post": {
        "tags": [
          "Operation"
        ],
        "summary": "Endpoint that create Place Task within a time range",
        "operationId": "place_task",
        "description": "Endpoint that create Place Task within a time range",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "description": "JWT Token that authorize the user to use the endpoint. The token is valid for 24 hours (Please refer to obtain token endpoint)",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "PlaceTaskCreateRequest",
            "description": "PlaceTaskCreateRequest object",
            "schema": {
              "$ref": "#/definitions/PlaceTaskCreateRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Place Task Created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized credentials"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/api_post_image_client": {
      "post": {
        "tags": [
          "Upload Images"
        ],
        "summary": "Endpoint that receive PostImageRequestObject ",
        "operationId": "api_post_image_client",
        "description": "Endpoint that receive a PostImageRequestObject that have ionformation of a image url, a poc and location of the image",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "PostImageRequestObject",
            "description": "PostImageRequestObject object",
            "schema": {
              "$ref": "#/definitions/PostImageRequestObject"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful response"
          },
          "201": {
            "description": "Image Uploaded Succesfully"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized credentials"
          },
          "404": {
            "description": "Data not found"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/image/upload_base64": {
      "post": {
        "tags": [
          "Upload Images"
        ],
        "summary": "Endpoint for receiving images",
        "operationId": "upload_images",
        "description": "Endpoint that upload an image for recognition",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "description": "JWT Token that authorize the user to use the endpoint. The token is valid for 24 hours (Please refer to obtain token endpoint)",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "UploadImageRequest",
            "description": "UploadImageRequest object",
            "schema": {
              "$ref": "#/definitions/UploadImageRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Place Task Created"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized credentials"
          },
          "402": {
            "description": "Expired Credentials"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/search/by_task/photo_task/": {
      "post": {
        "tags": [
          "Developers"
        ],
        "summary": "Endpoint that returns a list of objects of type PhotoTaskResponse. There are two new parameters date_to, date from. If these are not set, the end point return thge results of the last 24 hours. These are optionals, but if the date_to parameter is set, it must set date_from parameter.",
        "operationId": "photo_task",
        "description": "Endpoint that returns a list of objects of type PhotoTaskResponse",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "description": "JWT Token that authorize the user to use the endpoint. The token is valid for 24 hours (Please refer to obtain token endpoint)",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "PhotoTaskRequest",
            "description": "succesful",
            "schema": {
              "$ref": "#/definitions/PhotoTaskRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful response",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/PhotoTaskResponse"
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized credentials"
          },
          "404": {
            "description": "Data not found"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    }
  },
  "definitions": {
    "ObtainTokenRequest": {
      "type": "object",
      "required": [
        "username",
        "password"
      ],
      "properties": {
        "username": {
          "type": "string",
          "example": "test@aituring.co"
        },
        "password": {
          "type": "string",
          "example": "20568755"
        }
      }
    },
    "RefreshTokenRequest": {
      "type": "object",
      "required": [
        "token"
      ],
      "properties": {
        "token": {
          "type": "string",
          "example": "eyJ0eXAiOiJsKV1QiLCJhbGciOsiJIUzI1NiJ9.eyJlbWFpbCI6InRlc3RAYWl0dXJpbmcuY28iLCJ1c2VyX2lkIjoyLCJleHAiOjE1NjI2MDczMTUsInVzZXJuYW1lIjoidGsVzdEBhaXR1cmluZy5jbysIsIm9syaWdfaWF0IcjoxNTYyNjA1NTE1fQ.7Qb1pOnyUQo8b0vesaKjgq1fHLBD4MrZELW1HJNr6XKM"
        }
      }
    },
    "PhotoTaskRequest": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "integer",
          "example": 123
        },
        "place_id": {
          "type": "string",
          "example": 20568755
        },
        "date_to": {
          "type": "string",
          "format": "YYY-MM-DD",
          "example": "2019-08-01"
        },
        "date_from": {
          "type": "string",
          "format": "YYY-MM-DD",
          "example": "2019-08-01"
        }
      }
    },
    "PhotoTaskResponse": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "integer",
          "example": 123
        },
        "place_id": {
          "type": "string",
          "example": 20568755
        },
        "processed": {
          "type": "boolean",
          "example": true
        },
        "valid": {
          "type": "boolean",
          "example": false
        }
      }
    },
    "UploadImageRequest": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "example": "poster/cooler"
        },
        "picture": {
          "type": "string"
        },
        "image_analysis_id": {
          "type": "string",
          "example": "12345"
        },
        "transaction_status": {
          "type": "string",
          "example": "In Progress/Complete/Failed"
        }
      }
    },
    "PostImageRequestObject": {
      "type": "object",
      "properties": {
        "image_url": {
          "type": "string",
          "example": "https://bav-app-loyalty.s3.amazonaws.com/styles/digitalpoc_1280_720/s3/activity/40/2019-08/49991_5d5cd23813cad.jpg?itok=BkwCXZxB"
        },
        "place_id": {
          "type": "string",
          "example": "1"
        },
        "task_id": {
          "type": "string",
          "example": "1"
        },
        "date": {
          "type": "string",
          "example": "2019-09-01 07:08:00"
        },
        "lat": {
          "type": "number",
          "example": "4"
        },
        "lon": {
          "type": "number",
          "example": "72"
        }
      }
    },
    "PlaceTaskCreateRequest": {
      "type": "object",
      "required": [
        "place_id",
        "task_id"
      ],
      "properties": {
        "place_id": {
          "type": "string",
          "example": 20568755
        },
        "task_id": {
          "type": "string",
          "example": "123"
        }
      }
    }
  },
  "host": "trade.aituring.co",
  "basePath": "/api/v2",
  "schemes": [
    "https"
  ]
}