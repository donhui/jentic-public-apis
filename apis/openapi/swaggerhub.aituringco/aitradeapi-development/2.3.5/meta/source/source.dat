        "/image/results": {
            "post": {
                "tags": [
                    "Image Results"
                ],
                "summary": "Endpoint that query results of image recognition",
                "operationId": "image_results_get",
                "description": "Endpoint that create Place Task within a time range",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "description": "JWT Token that authorize the user to use the endpoint. The token is valid for 24 hours (Please refer to obtain token endpoint)",
