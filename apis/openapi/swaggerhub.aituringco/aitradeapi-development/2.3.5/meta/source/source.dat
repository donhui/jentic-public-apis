    "tags": [
        {
            "name": "Authentication",
            "description": "Secured Admin-only calls"
        },
        {
            "name": "Developers",
            "description": "Operations available to regular developers"
        }
    ],
    "paths": {
        "/obtain_token": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Endpoint that returns a JSON web token. This is necesary to use the other endpoints.",
                "operationId": "obtain_token",
                "description": "Endpoint that returns a JSON web token. This is necesary to use the other endpoints.",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ObtainTokenRequest"
                            }
                        }
                    },
                    "description": "JSON With username and password. This information is provided by the service provider (AITuring)"
                },
                "responses": {
                    "200": {
                        "description": "Valid Credentials"
                    },
                    "400": {
                        "description": "Invalid credentials"
                    },
                    "401": {
                        "description": "Unauthorized credentials"
                    },
                    "500": {
                        "description": "Server Error"
                    }
                }
            }
        },
        "/refresh_token": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Endpoint that returns a JSON web token, you can refresh an old one. This is necesary to use the other endpoints.",
                "operationId": "refresh_token",
                "description": "Endpoint that returns a JSON web token, you can refresh an old one. This is necesary to use the other endpoints.",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RefreshTokenRequest"
                            }
                        }
                    },
                    "description": "Inventory item to add"
                },
                "responses": {
                    "200": {
                        "description": "Token refresh"
                    },
                    "400": {
                        "description": "Error refreshing token"
                    },
                    "401": {
                        "description": "Unauthorized credentials"
                    },
                    "500": {
                        "description": "Server Error"
                    }
                }
            }
        },
        "/task": {
            "post": {
                "tags": [
                    "Query Execution Information"
                ],
                "summary": "Endpoint that returns tasks objects",
                "operationId": "task_post",
                "description": "Endpoint that returns tasks objects",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "description": "JWT Token that authorize the user to use the endpoint. The token is valid for 24 hours (Please refer to obtain token endpoint)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/TaskGetRequest"
                            }
                        }
                    },
                    "description": "TaskGetRequest object"
                },
                "responses": {
                    "200": {
                        "description": "Succesful request"
                    },
                    "400": {
                        "description": "Bad request"
                    },
                    "401": {
                        "description": "Unauthorized credentials"
                    },
                    "500": {
                        "description": "Server Error"
                    }
                }
            }
        },
        "/placeTasks": {
            "post": {
                "tags": [
                    "Query Execution Information"
                ],
                "summary": "Endpoint that respond a list of PlaceTasks",
                "operationId": "place_task_post",
                "description": "Endpoint that respond a list of PlaceTasks",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "description": "JWT Token that authorize the user to use the endpoint. The token is valid for 24 hours (Please refer to obtain token endpoint)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/PlaceTaskGetRequest"
                            }
                        }
                    },
                    "description": "PlaceTaskGetRequest object"
                },
                "responses": {
                    "201": {
                        "description": "Succesful request"
                    },
                    "400": {
                        "description": "Bad request"
                    },
                    "401": {
                        "description": "Unauthorized credentials"
                    },
                    "500": {
                        "description": "Server Error"
                    }
                }
            }
        },
        "/routes": {
            "post": {
                "tags": [
                    "Query Execution Information"
                ],
                "summary": "Endpoint that query a list of routes",
                "operationId": "route_post",
                "description": "Endpoint that query a list of routes",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "description": "JWT Token that authorize the user to use the endpoint. The token is valid for 24 hours (Please refer to obtain token endpoint)",
