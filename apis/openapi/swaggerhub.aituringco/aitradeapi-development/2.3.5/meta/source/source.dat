                },
                "responses": {
                    "200": {
                        "description": "Succesful request"
                    },
                    "400": {
                        "description": "Bad request"
                    },
                    "401": {
                        "description": "Unauthorized credentials"
                    },
                    "500": {
                        "description": "Server Error"
                    }
                }
            }
        },
        "/customers": {
            "post": {
                "tags": [
                    "Query Execution Information"
                ],
                "summary": "Endpoint that query a Customer Object",
                "operationId": "customer_post",
                "description": "Endpoint that query a Customer Object",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "description": "JWT Token that authorize the user to use the endpoint. The token is valid for 24 hours (Please refer to obtain token endpoint)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CustomerGetRequest"
                            }
                        }
                    },
                    "description": "RoutesRequest object"
                },
                "responses": {
                    "200": {
                        "description": "Succesful query"
                    },
                    "400": {
                        "description": "Bad request"
                    },
                    "401": {
                        "description": "Unauthorized credentials"
                    },
                    "500": {
                        "description": "Server Error"
                    }
                }
            }
        },
        "/image/customer/post": {
            "post": {
                "tags": [
                    "Upload Images"
                ],
                "summary": "Endpoint that receive PostImageRequestObject ",
                "operationId": "api_post_image_client",
                "description": "Endpoint that receive a PostImageRequestObject that have information of a image url, a poc and location of the image",
                "parameters": [
                    {
                        "in": "header",
                        "name": "Authorization",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/PostImageRequestObject"
                            }
                        }
                    },
                    "description": "PostImageRequestObject object"
                },
                "responses": {
                    "200": {
                        "description": "successful response"
                    },
                    "201": {
                        "description": "Image Uploaded Succesfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ImageResultResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request"
                    },
                    "401": {
                        "description": "Unauthorized credentials"
                    },
                    "404": {
                        "description": "Data not found"
                    },
                    "500": {
                        "description": "Server Error"
                    }
                }
            }
        },
