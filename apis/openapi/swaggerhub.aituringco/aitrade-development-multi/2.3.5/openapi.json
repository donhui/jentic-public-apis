  "tags": [
    {
      "name": "Authentication",
      "description": "Secured Admin-only calls"
    },
    {
      "name": "Developers",
      "description": "Operations available to regular developers"
    }
  ],
  "paths": {
    "/obtain_token": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Endpoint that returns a JSON web token. This is necesary to use the other endpoints.",
        "operationId": "obtain_token",
        "description": "Endpoint that returns a JSON web token. This is necesary to use the other endpoints.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "ObtainTokenRequest",
            "description": "JSON With username and password. This information is provided by the service provider (AITuring)",
            "schema": {
              "$ref": "#/definitions/ObtainTokenRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Valid Credentials"
          },
          "400": {
            "description": "Invalid credentials"
          },
          "401": {
            "description": "Unauthorized credentials"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/image/post/base64": {
      "post": {
        "tags": [
          "Upload Images"
        ],
        "summary": "Endpoint that receive PostImageSimple64RequestObject ",
        "operationId": "api_post_image_base64",
        "description": "Endpoint that receive a PostImageSimple64RequestObject that have information of a image url, a poc and location of the image",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "PostImageRequestObject",
            "description": "PostImageSimple64RequestObject object",
            "schema": {
              "$ref": "#/definitions/PostImageSimple64RequestObject"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Image Uploaded Succesfully",
            "schema": {
              "$ref": "#/definitions/ImageSimpleResultResponse"
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized credentials"
          },
          "404": {
            "description": "Data not found"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/image/results": {
      "post": {
        "tags": [
          "Image Results"
        ],
        "summary": "Endpoint that query results of image recognition",
        "operationId": "image_results_get",
        "description": "Endpoint that create Place Task within a time range",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "description": "JWT Token that authorize the user to use the endpoint. The token is valid for 24 hours (Please refer to obtain token endpoint)",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "ImageResultsRequest",
            "description": "ImageResultsRequest object",
            "schema": {
              "$ref": "#/definitions/ImageResultsRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Succesful query",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ImageResultResponse"
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized credentials"
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    }
  },
