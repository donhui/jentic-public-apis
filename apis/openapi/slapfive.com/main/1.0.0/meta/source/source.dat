    "/api/sendPrompt": {
      "post": {
        "operationId": "sendprompt",
        "summary": "Send a Prompt",
        "tags": [
          "Prompts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "customerId"
                ],
                "properties": {
                  "customerId": {
                    "type": "string"
                  },
                  "promptId": {
                    "type": "string"
                  },
                  "promptGroupId": {
                    "type": "string"
                  },
                  "customGreeting": {
                    "type": "string"
                  },
                  "customSubject": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prompt sent"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/sent-prompts/": {
      "get": {
        "operationId": "listsentprompts",
        "summary": "Get all Sent Prompts and Responses",
        "tags": [
          "Prompts"
        ],
        "parameters": [
          {
            "name": "hoursBack",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1000
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of sent prompts and responses"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/client": {
      "get": {
        "operationId": "getclientsettings",
        "summary": "Get Client Settings",
        "description": "Retrieve Activity Types & Scores, Dynamic Fields, and other Client Settings.",
        "tags": [
          "Settings"
        ],
        "responses": {
          "200": {
            "description": "Client settings"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/ai/assistant/": {
      "post": {
        "operationId": "promptaiassistant",
        "summary": "Prompt the SlapFive AI Assistant",
        "tags": [
          "AI"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "message"
                ],
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "Your AI Assistant prompt"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AI response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string"
                    },
                    "usage": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/activity-types/": {
      "post": {
        "operationId": "createorupdateactivitytypes",
        "summary": "Create or Update Activity Types",
        "tags": [
          "Settings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ActivityTypeInput"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Activity types created/updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ActivityType"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/dynamic-fields/{fieldId}/picklist-values/": {
      "post": {
        "operationId": "createorupdatepicklistvalues",
        "summary": "Create or Update Dynamic Field Picklist Values",
        "tags": [
          "Settings"
        ],
        "parameters": [
          {
            "name": "fieldId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Dynamic field ID from Get Client Settings endpoint"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "order": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Picklist values created/updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
