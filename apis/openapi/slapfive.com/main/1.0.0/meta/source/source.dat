{
  "openapi": "3.0.3",
  "info": {
    "title": "SlapFive API",
    "version": "1.0.0",
    "description": "SlapFive API for customer advocacy platform. Manage boards, stories, members, companies, activities, requests, campaigns, content shares, content views, prompts, and AI assistant.",
    "x-jentic-source-url": "https://www.slapfive.com/api/"
  },
  "servers": [
    {
      "url": "https://{company}.slapfive.com/api",
      "description": "SlapFive API Server",
      "variables": {
        "company": {
          "default": "your_company",
          "description": "Your company subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/api/boards/": {
      "get": {
        "operationId": "listboards",
        "summary": "Get all Boards",
        "description": "Returns all Boards in an array with Board Name and Board ID.",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "name": "hoursBack",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Get boards created or changed in last XX hours"
          },
          {
            "name": "since",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Get boards updated since this date (YYYY-MM-DD)"
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of field names to return"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1000
            },
            "description": "Number of records to return"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Number of records to skip"
          }
        ],
        "responses": {
          "200": {
            "description": "List of boards",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Board"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createorupdateboard",
        "summary": "Create or update Board",
        "description": "If a Board record exists for the id provided, it updates that record, otherwise creates a new record.",
        "tags": [
          "Boards"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BoardInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Board created/updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "board": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/boards/{boardId}": {
      "get": {
        "operationId": "getboard",
        "summary": "Get specific Board and its Stories",
        "description": "Returns the Board along with all Stories on that Board.",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "name": "boardId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The Board ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Board with stories",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Board"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteboard",
        "summary": "Delete Board",
        "description": "Delete a Board record by id.",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "name": "boardId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Board deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/stories/": {
