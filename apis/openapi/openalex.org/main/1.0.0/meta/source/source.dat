{
  "openapi": "3.0.3",
  "info": {
    "title": "OpenAlex API",
    "description": "OpenAlex is a free and open catalog of the global research system, providing a fast, modern REST API to access scholarly data including works, authors, sources, institutions, topics, and more.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.openalex.org/"
  },
  "servers": [
    {
      "url": "https://api.openalex.org",
      "description": "OpenAlex Production API"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/works": {
      "get": {
        "operationId": "listWorks",
        "summary": "List works",
        "description": "Retrieve a paginated list of scholarly works with optional filtering, searching, sorting, and grouping.",
        "tags": ["Works"],
        "parameters": [
          { "$ref": "#/components/parameters/filterParam" },
          { "$ref": "#/components/parameters/searchParam" },
          { "$ref": "#/components/parameters/sortParam" },
          { "$ref": "#/components/parameters/perPageParam" },
          { "$ref": "#/components/parameters/pageParam" },
          { "$ref": "#/components/parameters/cursorParam" },
          { "$ref": "#/components/parameters/sampleParam" },
          { "$ref": "#/components/parameters/selectParam" },
          { "$ref": "#/components/parameters/groupByParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          }
        }
      }
    },
    "/works/{id}": {
      "get": {
        "operationId": "getWork",
        "summary": "Get a single work",
        "description": "Retrieve a single scholarly work by its OpenAlex ID, DOI, PMID, or other external identifier.",
        "tags": ["Works"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The OpenAlex ID, DOI (e.g., doi:10.1234/...), PMID (e.g., pmid:12345), or full URL identifier of the work.",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/selectParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Work" }
              }
            }
          },
          "404": {
            "description": "Work not found"
          }
        }
      }
    },
    "/authors": {
      "get": {
        "operationId": "listAuthors",
        "summary": "List authors",
        "description": "Retrieve a paginated list of authors with optional filtering, searching, sorting, and grouping.",
        "tags": ["Authors"],
        "parameters": [
          { "$ref": "#/components/parameters/filterParam" },
          { "$ref": "#/components/parameters/searchParam" },
          { "$ref": "#/components/parameters/sortParam" },
          { "$ref": "#/components/parameters/perPageParam" },
          { "$ref": "#/components/parameters/pageParam" },
          { "$ref": "#/components/parameters/cursorParam" },
          { "$ref": "#/components/parameters/sampleParam" },
          { "$ref": "#/components/parameters/selectParam" },
          { "$ref": "#/components/parameters/groupByParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          }
        }
      }
    },
    "/authors/{id}": {
      "get": {
        "operationId": "getAuthor",
        "summary": "Get a single author",
        "description": "Retrieve a single author by their OpenAlex ID, ORCID, or other external identifier.",
        "tags": ["Authors"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The OpenAlex ID, ORCID, or other identifier of the author.",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/selectParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Author" }
              }
            }
          },
          "404": { "description": "Author not found" }
        }
      }
    },
    "/sources": {
      "get": {
        "operationId": "listSources",
        "summary": "List sources",
        "description": "Retrieve a paginated list of sources (journals, repositories, etc.) with optional filtering, searching, sorting, and grouping.",
        "tags": ["Sources"],
        "parameters": [
          { "$ref": "#/components/parameters/filterParam" },
          { "$ref": "#/components/parameters/searchParam" },
          { "$ref": "#/components/parameters/sortParam" },
          { "$ref": "#/components/parameters/perPageParam" },
          { "$ref": "#/components/parameters/pageParam" },
          { "$ref": "#/components/parameters/cursorParam" },
          { "$ref": "#/components/parameters/sampleParam" },
          { "$ref": "#/components/parameters/selectParam" },
          { "$ref": "#/components/parameters/groupByParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          }
        }
      }
    },
    "/sources/{id}": {
      "get": {
        "operationId": "getSource",
        "summary": "Get a single source",
        "description": "Retrieve a single source by its OpenAlex ID or other external identifier.",
        "tags": ["Sources"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The OpenAlex ID or other identifier of the source.",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/selectParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Source" }
              }
            }
          },
          "404": { "description": "Source not found" }
        }
      }
    },
    "/institutions": {
      "get": {
        "operationId": "listInstitutions",
        "summary": "List institutions",
        "description": "Retrieve a paginated list of institutions with optional filtering, searching, sorting, and grouping.",
        "tags": ["Institutions"],
        "parameters": [
          { "$ref": "#/components/parameters/filterParam" },
          { "$ref": "#/components/parameters/searchParam" },
          { "$ref": "#/components/parameters/sortParam" },
          { "$ref": "#/components/parameters/perPageParam" },
          { "$ref": "#/components/parameters/pageParam" },
          { "$ref": "#/components/parameters/cursorParam" },
          { "$ref": "#/components/parameters/sampleParam" },
          { "$ref": "#/components/parameters/selectParam" },
          { "$ref": "#/components/parameters/groupByParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          }
        }
      }
    },
    "/institutions/{id}": {
      "get": {
        "operationId": "getInstitution",
        "summary": "Get a single institution",
        "description": "Retrieve a single institution by its OpenAlex ID, ROR, or other external identifier.",
        "tags": ["Institutions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The OpenAlex ID, ROR, or other identifier of the institution.",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/selectParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Institution" }
              }
            }
          },
          "404": { "description": "Institution not found" }
        }
      }
    },
    "/topics": {
      "get": {
        "operationId": "listTopics",
        "summary": "List topics",
        "description": "Retrieve a paginated list of topics with optional filtering, searching, sorting, and grouping.",
        "tags": ["Topics"],
        "parameters": [
          { "$ref": "#/components/parameters/filterParam" },
          { "$ref": "#/components/parameters/searchParam" },
          { "$ref": "#/components/parameters/sortParam" },
          { "$ref": "#/components/parameters/perPageParam" },
          { "$ref": "#/components/parameters/pageParam" },
          { "$ref": "#/components/parameters/cursorParam" },
          { "$ref": "#/components/parameters/sampleParam" },
          { "$ref": "#/components/parameters/selectParam" },
          { "$ref": "#/components/parameters/groupByParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          }
        }
      }
    },
    "/topics/{id}": {
      "get": {
        "operationId": "getTopic",
        "summary": "Get a single topic",
        "description": "Retrieve a single topic by its OpenAlex ID.",
        "tags": ["Topics"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The OpenAlex ID of the topic.",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/selectParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Topic" }
              }
            }
          },
          "404": { "description": "Topic not found" }
        }
      }
    },
    "/publishers": {
      "get": {
        "operationId": "listPublishers",
        "summary": "List publishers",
        "description": "Retrieve a paginated list of publishers with optional filtering, searching, sorting, and grouping.",
        "tags": ["Publishers"],
        "parameters": [
          { "$ref": "#/components/parameters/filterParam" },
          { "$ref": "#/components/parameters/searchParam" },
          { "$ref": "#/components/parameters/sortParam" },
          { "$ref": "#/components/parameters/perPageParam" },
          { "$ref": "#/components/parameters/pageParam" },
          { "$ref": "#/components/parameters/cursorParam" },
          { "$ref": "#/components/parameters/sampleParam" },
          { "$ref": "#/components/parameters/selectParam" },
          { "$ref": "#/components/parameters/groupByParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          }
        }
      }
    },
    "/publishers/{id}": {
      "get": {
        "operationId": "getPublisher",
        "summary": "Get a single publisher",
        "description": "Retrieve a single publisher by its OpenAlex ID.",
        "tags": ["Publishers"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The OpenAlex ID of the publisher.",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/selectParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Publisher" }
              }
            }
          },
          "404": { "description": "Publisher not found" }
        }
      }
    },
    "/funders": {
      "get": {
        "operationId": "listFunders",
        "summary": "List funders",
        "description": "Retrieve a paginated list of funders with optional filtering, searching, sorting, and grouping.",
        "tags": ["Funders"],
        "parameters": [
          { "$ref": "#/components/parameters/filterParam" },
          { "$ref": "#/components/parameters/searchParam" },
          { "$ref": "#/components/parameters/sortParam" },
          { "$ref": "#/components/parameters/perPageParam" },
          { "$ref": "#/components/parameters/pageParam" },
          { "$ref": "#/components/parameters/cursorParam" },
          { "$ref": "#/components/parameters/sampleParam" },
          { "$ref": "#/components/parameters/selectParam" },
          { "$ref": "#/components/parameters/groupByParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          }
        }
      }
    },
    "/funders/{id}": {
      "get": {
        "operationId": "getFunder",
        "summary": "Get a single funder",
        "description": "Retrieve a single funder by its OpenAlex ID.",
        "tags": ["Funders"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The OpenAlex ID of the funder.",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/selectParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Funder" }
              }
            }
          },
          "404": { "description": "Funder not found" }
        }
      }
    },
    "/keywords": {
      "get": {
        "operationId": "listKeywords",
        "summary": "List keywords",
        "description": "Retrieve a paginated list of keywords with optional filtering, searching, sorting, and grouping.",
        "tags": ["Keywords"],
        "parameters": [
          { "$ref": "#/components/parameters/filterParam" },
          { "$ref": "#/components/parameters/searchParam" },
          { "$ref": "#/components/parameters/sortParam" },
          { "$ref": "#/components/parameters/perPageParam" },
          { "$ref": "#/components/parameters/pageParam" },
          { "$ref": "#/components/parameters/cursorParam" },
          { "$ref": "#/components/parameters/sampleParam" },
          { "$ref": "#/components/parameters/selectParam" },
          { "$ref": "#/components/parameters/groupByParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ListResponse" }
              }
            }
          }
        }
      }
    },
    "/keywords/{id}": {
      "get": {
        "operationId": "getKeyword",
        "summary": "Get a single keyword",
        "description": "Retrieve a single keyword by its OpenAlex ID.",
        "tags": ["Keywords"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The OpenAlex ID of the keyword.",
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/selectParam" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Keyword" }
              }
            }
          },
          "404": { "description": "Keyword not found" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key passed as a query parameter. Free API keys are available from OpenAlex."
      }
    },
    "parameters": {
      "filterParam": {
        "name": "filter",
        "in": "query",
        "description": "Filter results using field:value pairs (e.g., publication_year:2024, type:journal-article).",
        "schema": { "type": "string" }
      },
      "searchParam": {
        "name": "search",
        "in": "query",
        "description": "Full-text search across relevant fields.",
        "schema": { "type": "string" }
      },
      "sortParam": {
        "name": "sort",
        "in": "query",
        "description": "Sort results by field name. Prefix with '-' for descending order.",
        "schema": { "type": "string" }
      },
      "perPageParam": {
        "name": "per_page",
        "in": "query",
        "description": "Number of results per page (1-100, default 25).",
        "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 25 }
      },
      "pageParam": {
        "name": "page",
        "in": "query",
        "description": "Page number for pagination.",
        "schema": { "type": "integer", "minimum": 1 }
      },
      "cursorParam": {
        "name": "cursor",
        "in": "query",
        "description": "Cursor token for deep pagination. Use '*' to start cursor-based pagination.",
        "schema": { "type": "string" }
      },
      "sampleParam": {
        "name": "sample",
        "in": "query",
        "description": "Return a random sample of the specified size.",
        "schema": { "type": "integer" }
      },
      "selectParam": {
        "name": "select",
        "in": "query",
        "description": "Comma-separated list of fields to include in the response.",
        "schema": { "type": "string" }
      },
      "groupByParam": {
        "name": "group_by",
        "in": "query",
        "description": "Group and aggregate results by the specified field.",
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "Meta": {
        "type": "object",
        "properties": {
          "count": { "type": "integer", "description": "Total number of results matching the query." },
          "db_response_time_ms": { "type": "integer", "description": "Database response time in milliseconds." },
          "page": { "type": "integer", "description": "Current page number." },
          "per_page": { "type": "integer", "description": "Number of results per page." },
          "next_cursor": { "type": "string", "description": "Cursor for the next page of results." }
        }
      },
      "ListResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/Meta" },
          "results": {
            "type": "array",
            "items": { "type": "object" },
            "description": "Array of entity objects."
          },
          "group_by": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GroupByResult" },
            "description": "Aggregation results when group_by parameter is used."
          }
        }
      },
      "GroupByResult": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "key_display_name": { "type": "string" },
          "count": { "type": "integer" }
        }
      },
      "Work": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "The OpenAlex ID for the work." },
          "doi": { "type": "string", "description": "The DOI of the work." },
          "title": { "type": "string", "description": "The title of the work." },
          "display_name": { "type": "string" },
          "publication_year": { "type": "integer" },
          "publication_date": { "type": "string", "format": "date" },
          "type": { "type": "string", "description": "The type of work (e.g., journal-article, book-chapter)." },
          "cited_by_count": { "type": "integer" },
          "is_retracted": { "type": "boolean" },
          "is_paratext": { "type": "boolean" },
          "language": { "type": "string" },
          "authorships": { "type": "array", "items": { "type": "object" } },
          "primary_location": { "type": "object" },
          "open_access": { "type": "object" },
          "biblio": { "type": "object" },
          "concepts": { "type": "array", "items": { "type": "object" } },
          "topics": { "type": "array", "items": { "type": "object" } },
          "keywords": { "type": "array", "items": { "type": "object" } },
          "referenced_works": { "type": "array", "items": { "type": "string" } },
          "related_works": { "type": "array", "items": { "type": "string" } },
          "updated_date": { "type": "string", "format": "date-time" },
          "created_date": { "type": "string", "format": "date" }
        }
      },
      "Author": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "orcid": { "type": "string" },
          "display_name": { "type": "string" },
          "display_name_alternatives": { "type": "array", "items": { "type": "string" } },
          "works_count": { "type": "integer" },
          "cited_by_count": { "type": "integer" },
          "last_known_institutions": { "type": "array", "items": { "type": "object" } },
          "topics": { "type": "array", "items": { "type": "object" } },
          "updated_date": { "type": "string", "format": "date-time" },
          "created_date": { "type": "string", "format": "date" }
        }
      },
      "Source": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "issn_l": { "type": "string" },
          "issn": { "type": "array", "items": { "type": "string" } },
          "display_name": { "type": "string" },
          "host_organization": { "type": "string" },
          "type": { "type": "string" },
          "works_count": { "type": "integer" },
          "cited_by_count": { "type": "integer" },
          "is_oa": { "type": "boolean" },
          "is_in_doaj": { "type": "boolean" },
          "updated_date": { "type": "string", "format": "date-time" },
          "created_date": { "type": "string", "format": "date" }
        }
      },
      "Institution": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "ror": { "type": "string" },
          "display_name": { "type": "string" },
          "country_code": { "type": "string" },
          "type": { "type": "string" },
          "works_count": { "type": "integer" },
          "cited_by_count": { "type": "integer" },
          "updated_date": { "type": "string", "format": "date-time" },
          "created_date": { "type": "string", "format": "date" }
        }
      },
      "Topic": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "description": { "type": "string" },
          "works_count": { "type": "integer" },
          "cited_by_count": { "type": "integer" },
          "domain": { "type": "object" },
          "field": { "type": "object" },
          "subfield": { "type": "object" },
          "updated_date": { "type": "string", "format": "date-time" }
        }
      },
      "Publisher": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "works_count": { "type": "integer" },
          "cited_by_count": { "type": "integer" },
          "sources_count": { "type": "integer" },
          "country_codes": { "type": "array", "items": { "type": "string" } },
          "updated_date": { "type": "string", "format": "date-time" },
          "created_date": { "type": "string", "format": "date" }
        }
      },
      "Funder": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "works_count": { "type": "integer" },
          "cited_by_count": { "type": "integer" },
          "grants_count": { "type": "integer" },
          "country_code": { "type": "string" },
          "updated_date": { "type": "string", "format": "date-time" },
          "created_date": { "type": "string", "format": "date" }
        }
      },
      "Keyword": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "works_count": { "type": "integer" },
          "cited_by_count": { "type": "integer" },
          "updated_date": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}