{
  "openapi": "3.0.3",
  "info": {
    "title": "GoPay REST API",
    "version": "1.0.0",
    "description": "GoPay REST API for payment processing including standard payments, recurring payments, preauthorized payments, refunds, and account management.",
    "x-jentic-source-url": "https://speca.io/gopaycz/gopay-rest-api-en"
  },
  "servers": [
    {
      "url": "https://gate.gopay.cz/api",
      "description": "Production"
    },
    {
      "url": "https://gw.sandbox.gopay.com/api",
      "description": "Sandbox"
    }
  ],
  "tags": [
    {
      "name": "authentication",
      "description": "OAuth2 token operations"
    },
    {
      "name": "payments",
      "description": "Payment operations"
    },
    {
      "name": "recurring",
      "description": "Recurring payment operations"
    },
    {
      "name": "preauthorization",
      "description": "Preauthorized payment operations"
    },
    {
      "name": "payment-methods",
      "description": "Payment methods and instruments"
    },
    {
      "name": "account",
      "description": "Merchant account operations"
    }
  ],
  "paths": {
    "/oauth2/token": {
      "post": {
        "operationId": "getAccessToken",
        "tags": ["authentication"],
        "summary": "Get Access Token",
        "description": "Obtains an OAuth2 access token using client credentials.",
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["scope", "grant_type"],
                "properties": {
                  "scope": {
                    "type": "string",
                    "description": "Token scope (e.g., 'payment-create', 'payment-all')"
                  },
                  "grant_type": {
                    "type": "string",
                    "description": "OAuth2 grant type",
                    "enum": ["client_credentials"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token obtained successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment": {
      "post": {
        "operationId": "createPayment",
        "tags": ["payments"],
        "summary": "Create Standard Payment",
        "description": "Creates a new standard payment. Returns a gateway URL for customer redirection.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}": {
      "get": {
        "operationId": "getPaymentStatus",
        "tags": ["payments"],
        "summary": "Get Payment Status",
        "description": "Retrieves the current status and details of a payment.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Payment ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/refund": {
      "post": {
        "operationId": "refundPayment",
        "tags": ["payments"],
        "summary": "Refund Payment",
        "description": "Refunds a payment. Supports full or partial refunds.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Payment ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["amount"],
                "properties": {
                  "amount": {
                    "type": "integer",
                    "description": "Refund amount in cents"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/create-recurrence": {
      "post": {
        "operationId": "createRecurringPayment",
        "tags": ["recurring"],
        "summary": "Create Recurring On-Demand Payment",
        "description": "Creates a new recurring payment based on an existing parent payment.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Parent payment ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecurrenceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recurring payment created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecurrenceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/void-recurrence": {
      "post": {
        "operationId": "cancelRecurringPayment",
        "tags": ["recurring"],
        "summary": "Cancel Recurring Payment",
        "description": "Cancels a recurring payment.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Parent payment ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recurring payment cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/capture": {
      "post": {
        "operationId": "capturePreauthorizedPayment",
        "tags": ["preauthorization"],
        "summary": "Capture Preauthorized Payment",
        "description": "Captures a previously preauthorized payment. Supports full and partial capture.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Preauthorized payment ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaptureRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment captured successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/payments/payment/{id}/void-authorization": {
      "post": {
        "operationId": "voidPreauthorization",
        "tags": ["preauthorization"],
        "summary": "Cancel Preauthorization",
        "description": "Cancels a preauthorized payment.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Preauthorized payment ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Preauthorization cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/eshops/eshop/{goid}/payment-instruments/{currency}": {
      "get": {
        "operationId": "getAllowedPaymentMethods",
        "tags": ["payment-methods"],
        "summary": "Get Allowed Payment Methods",
        "description": "Retrieves allowed payment instruments for a specific eshop and currency.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "goid",
            "in": "path",
            "required": true,
            "description": "GoPay shop ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "currency",
            "in": "path",
            "required": true,
            "description": "ISO 4217 currency code",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment methods retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentInstruments"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/account-statement": {
      "post": {
        "operationId": "getAccountStatement",
        "tags": ["account"],
        "summary": "Get Account Statement",
        "description": "Generates and downloads an account statement for a specified period.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountStatementRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account statement file",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic HTTP authentication using Base64-encoded ClientID:ClientSecret. Used only for obtaining access tokens."
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained from the /oauth2/token endpoint."
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token_type": {
            "type": "string",
            "example": "bearer"
          },
          "access_token": {
            "type": "string",
            "description": "Access token"
          },
          "refresh_token": {
            "type": "string",
            "description": "Refresh token"
          },
          "expires_in": {
            "type": "integer",
            "description": "Token validity in seconds"
          }
        }
      },
      "CreatePaymentRequest": {
        "type": "object",
        "required": ["payer", "target", "amount", "currency", "order_number", "callback"],
        "properties": {
          "payer": {
            "$ref": "#/components/schemas/Payer"
          },
          "target": {
            "$ref": "#/components/schemas/Target"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            },
            "description": "Order items"
          },
          "amount": {
            "type": "integer",
            "description": "Total amount in cents"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "order_number": {
            "type": "string",
            "description": "Merchant order number"
          },
          "order_description": {
            "type": "string",
            "description": "Order description"
          },
          "lang": {
            "type": "string",
            "description": "Language code (e.g., CS, EN, SK)"
          },
          "callback": {
            "$ref": "#/components/schemas/Callback"
          },
          "additional_params": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdditionalParam"
            }
          },
          "preauthorization": {
            "type": "boolean",
            "description": "Whether to preauthorize only"
          },
          "recurrence": {
            "$ref": "#/components/schemas/Recurrence"
          }
        }
      },
      "Payer": {
        "type": "object",
        "properties": {
          "default_payment_instrument": {
            "type": "string",
            "description": "Default payment instrument code"
          },
          "allowed_payment_instruments": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Allowed payment instrument codes"
          },
          "default_swift": {
            "type": "string",
            "description": "Default bank SWIFT code"
          },
          "allowed_swifts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Allowed bank SWIFT codes"
          },
          "contact": {
            "$ref": "#/components/schemas/Contact"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone_number": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "street": {
            "type": "string"
          },
          "postal_code": {
            "type": "string"
          },
          "country_code": {
            "type": "string"
          }
        }
      },
      "Target": {
        "type": "object",
        "required": ["type", "goid"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["ACCOUNT"],
            "description": "Target type"
          },
          "goid": {
            "type": "integer",
            "format": "int64",
            "description": "GoPay shop ID"
          }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["ITEM", "DELIVERY", "DISCOUNT"],
            "description": "Item type"
          },
          "name": {
            "type": "string",
            "description": "Item name"
          },
          "amount": {
            "type": "integer",
            "description": "Item amount in cents"
          },
          "count": {
            "type": "integer",
            "description": "Item count"
          },
          "vat_rate": {
            "type": "integer",
            "description": "VAT rate in percent"
          }
        }
      },
      "Callback": {
        "type": "object",
        "required": ["return_url", "notification_url"],
        "properties": {
          "return_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to redirect after payment"
          },
          "notification_url": {
            "type": "string",
            "format": "uri",
            "description": "URL for server-to-server notifications"
          }
        }
      },
      "AdditionalParam": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "Recurrence": {
        "type": "object",
        "properties": {
          "recurrence_cycle": {
            "type": "string",
            "enum": ["DAY", "WEEK", "MONTH", "ON_DEMAND"],
            "description": "Recurrence cycle"
          },
          "recurrence_period": {
            "type": "integer",
            "description": "Number of cycles"
          },
          "recurrence_date_to": {
            "type": "string",
            "format": "date",
            "description": "Recurrence end date"
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Payment ID"
          },
          "order_number": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": ["CREATED", "PAYMENT_METHOD_CHOSEN", "PAID", "AUTHORIZED", "CANCELED", "TIMEOUTED", "REFUNDED", "PARTIALLY_REFUNDED"],
            "description": "Payment state"
          },
          "amount": {
            "type": "integer",
            "description": "Amount in cents"
          },
          "currency": {
            "type": "string"
          },
          "gw_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to redirect the customer to the payment gateway"
          }
        }
      },
      "PaymentDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "order_number": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": ["CREATED", "PAYMENT_METHOD_CHOSEN", "PAID", "AUTHORIZED", "CANCELED", "TIMEOUTED", "REFUNDED", "PARTIALLY_REFUNDED"]
          },
          "amount": {
            "type": "integer"
          },
          "currency": {
            "type": "string"
          },
          "payer": {
            "$ref": "#/components/schemas/Payer"
          },
          "target": {
            "$ref": "#/components/schemas/Target"
          },
          "preauthorization": {
            "type": "object",
            "properties": {
              "requested": {
                "type": "boolean"
              },
              "state": {
                "type": "string"
              }
            }
          },
          "recurrence": {
            "type": "object",
            "properties": {
              "recurrence_cycle": {
                "type": "string"
              },
              "recurrence_period": {
                "type": "integer"
              },
              "recurrence_date_to": {
                "type": "string",
                "format": "date"
              },
              "recurrence_state": {
                "type": "string"
              }
            }
          }
        }
      },
      "RecurrenceRequest": {
        "type": "object",
        "required": ["amount", "currency", "order_number"],
        "properties": {
          "amount": {
            "type": "integer",
            "description": "Amount in cents"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "order_number": {
            "type": "string",
            "description": "Merchant order number"
          },
          "order_description": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            }
          },
          "additional_params": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdditionalParam"
            }
          }
        }
      },
      "RecurrenceResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "New payment ID"
          },
          "parent_id": {
            "type": "integer",
            "format": "int64",
            "description": "Parent payment ID"
          },
          "state": {
            "type": "string"
          },
          "amount": {
            "type": "integer"
          }
        }
      },
      "CaptureRequest": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "integer",
            "description": "Capture amount in cents (for partial capture)"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            },
            "description": "Items for partial capture"
          }
        }
      },
      "OperationResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Payment ID"
          },
          "result": {
            "type": "string",
            "enum": ["ACCEPTED", "FINISHED", "FAILED"],
            "description": "Operation result"
          }
        }
      },
      "PaymentInstruments": {
        "type": "object",
        "properties": {
          "groups": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            },
            "description": "Payment instrument groups"
          },
          "enabledPaymentInstruments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "paymentInstrument": {
                  "type": "string"
                },
                "label": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "image": {
                  "type": "object",
                  "properties": {
                    "normal": {
                      "type": "string",
                      "format": "uri"
                    },
                    "large": {
                      "type": "string",
                      "format": "uri"
                    }
                  }
                },
                "group": {
                  "type": "string"
                },
                "enabledSwifts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "swift": {
                        "type": "string"
                      },
                      "label": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "image": {
                        "type": "object",
                        "properties": {
                          "normal": {
                            "type": "string",
                            "format": "uri"
                          },
                          "large": {
                            "type": "string",
                            "format": "uri"
                          }
                        }
                      },
                      "isOnline": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            },
            "description": "List of enabled payment instruments"
          }
        }
      },
      "AccountStatementRequest": {
        "type": "object",
        "required": ["date_from", "date_to", "goid", "currency", "format"],
        "properties": {
          "date_from": {
            "type": "string",
            "format": "date",
            "description": "Start date"
          },
          "date_to": {
            "type": "string",
            "format": "date",
            "description": "End date"
          },
          "goid": {
            "type": "integer",
            "format": "int64",
            "description": "GoPay shop ID"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "format": {
            "type": "string",
            "enum": ["CSV_A", "CSV_B", "CSV_C", "CSV_D", "XLS_A", "XLS_B", "XLS_C", "ABO"],
            "description": "Statement format"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "scope": {
            "type": "string",
            "description": "Error scope"
          },
          "field": {
            "type": "string",
            "description": "Field with error"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}