{
    "openapi": "3.0.0",
    "info": {
        "version": "1.0.0",
        "title": "MOCK API FOR DRIVER APP",
        "description": "This Mock Api for user app",
        "contact": {
            "email": "hung.vu@mobytelab.com"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/Mobytelab/BitCar_Driver/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "Login",
            "description": "Mocking Api for Login process"
        },
        {
            "name": "Register",
            "description": "Mocking Api for Register process"
        }
    ],
    "paths": {
        "/checkExistedAccount": {
            "get": {
                "tags": [
                    "Login"
                ],
                "description": "Check whether account with information of phone number is existed",
                "parameters": [
                    {
                        "in": "query",
                        "name": "phone",
                        "description": "phone number",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Account is existed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "isExisted": {
                                            "type": "boolean",
                                            "example": true
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad input parameter."
                    }
                }
            }
        },
        "/getRegisterLink": {
            "get": {
                "tags": [
                    "Register"
                ],
                "description": "Get register url by country code",
                "parameters": [
                    {
                        "in": "query",
                        "name": "countryCode",
                        "description": "country code (https://countrycode.org/malaysia)",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Account is existed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "url": {
                                            "type": "string",
                                            "example": "https://driver.gobitcar.com/"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad input parameter."
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/Mobytelab/BitCar_Driver/1.0.0"
        }
    ]
}