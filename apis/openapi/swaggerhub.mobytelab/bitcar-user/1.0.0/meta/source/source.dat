{
    "openapi": "3.0.0",
    "info": {
        "description": "This is a MOCK API for User App",
        "version": "1.0.0",
        "title": "MOCK API for User App",
        "contact": {
            "email": "hung.vu@mobytelab.com"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/Mobytelab/BitCar_User/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "Login",
            "description": "Mocking Api for Login process"
        },
        {
            "name": "Register",
            "description": "Mocking Api for Register process"
        }
    ],
    "paths": {
        "/checkExistedAccount": {
            "get": {
                "tags": [
                    "Login"
                ],
                "description": "Check whether account with information of phone number or email address is existed",
                "parameters": [
                    {
                        "in": "query",
                        "name": "phone",
                        "description": "phone number (with country code)",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "email",
                        "description": "email address",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Account is existed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "isExisted": {
                                            "type": "boolean",
                                            "example": true
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad input parameter."
                    }
                }
            }
        },
        "/createAccount": {
            "post": {
                "tags": [
                    "Register"
                ],
                "description": "Add an user account",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/PostItem"
                            }
                        }
                    },
                    "description": "Inventory item to add"
                },
                "responses": {
                    "201": {
                        "description": "item created"
                    },
                    "400": {
                        "description": "invalid input, object invalid"
                    },
                    "409": {
                        "description": "an existing item already exists"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/Mobytelab/BitCar_User/1.0.0"
        }
    ],
    "components": {
        "schemas": {
            "PostItem": {
                "type": "object",
                "required": [
                    "firstName",
                    "lastName",
                    "phone",
                    "email",
                    "idPasspportNumber"
                ],
                "properties": {
                    "firstName": {
                        "type": "string",
                        "example": "Binh"
                    },
                    "lastName": {
                        "type": "string",
                        "example": "Nguyen"
                    },
                    "phone": {
                        "type": "string",
                        "example": "+8490977997"
                    },
                    "email": {
                        "type": "string",
                        "example": "binhnguyen@mobytelab.com"
                    },
                    "idPasspportNumber": {
                        "type": "string",
                        "example": 204104963
                    },
                    "inviteCode": {
                        "type": "string",
                        "example": "bit39er"
                    }
                }
            }
        }
    }
}