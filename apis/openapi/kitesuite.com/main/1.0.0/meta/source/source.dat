    "/api/v1/form/coupon": {
      "post": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Add Coupon",
        "tags": [
          "Form"
        ],
        "description": "Adds a new coupon to a payment element.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "element": {
                    "type": "string",
                    "description": "ID of the payment element to which the coupon is added.",
                    "example": "620122b11771f1acc2141750"
                  },
                  "name": {
                    "type": "string",
                    "description": "Name of the coupon.",
                    "example": "Summer Sale"
                  },
                  "code": {
                    "type": "string",
                    "description": "Coupon code.",
                    "example": "SUMMER20"
                  },
                  "couponLimit": {
                    "type": "integer",
                    "description": "Maximum number of times the coupon can be used.",
                    "example": 100
                  },
                  "limitDate": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Date and time limit for the coupon.",
                    "example": "2024-12-31T23:59:59Z"
                  },
                  "limitValue": {
                    "type": "number",
                    "description": "Minimum value required to apply the coupon.",
                    "example": 50
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "percentage",
                      "fixed"
                    ],
                    "description": "Type of discount.",
                    "example": "percentage"
                  },
                  "discountRate": {
                    "type": "number",
                    "description": "Discount rate (percentage).",
                    "example": 20
                  },
                  "discountAmt": {
                    "type": "number",
                    "description": "Discount amount (fixed).",
                    "example": 10
                  },
                  "applyTo": {
                    "type": "string",
                    "enum": [
                      "all",
                      "specific"
                    ],
                    "description": "Specifies if the coupon applies to all products or specific products.",
                    "example": "all"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Coupon added successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 201
                    },
                    "data": {
                      "type": "object",
                      "description": "Created coupon object."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Payment element or coupon code already exists.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Payment element already exists or coupon code already exists."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - User does not have necessary permissions."
          },
          "404": {
            "description": "Form not found."
          },
          "500": {
            "description": "Internal Server Error."
          }
        },
        "operationId": "postFormCoupon"
      }
    },
