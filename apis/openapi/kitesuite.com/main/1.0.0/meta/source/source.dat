    "/api/v1/form/condition": {
      "post": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Create Form Condition",
        "tags": [
          "Form"
        ],
        "description": "Creates a new form condition based on the provided data.",
        "parameters": [
          {
            "in": "header",
            "name": "tenant",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tenant identifier."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FormConditionValidation"
              },
              "examples": {
                "valid_payload": {
                  "summary": "Valid payload",
                  "value": {
                    "form": "620122b11771f1acc2141742",
                    "type": "show-hide",
                    "ifElement": "620122b11771f1acc2141743",
                    "condition": "eq",
                    "target": "val",
                    "value": "someValue",
                    "doCondition": "show",
                    "actionElements": [
                      "620122b11771f1acc2141745",
                      "620122b11771f1acc2141746"
                    ]
                  }
                },
                "payload_with_anotherElement": {
                  "summary": "Payload with anotherElement",
                  "value": {
                    "form": "620122b11771f1acc2141742",
                    "type": "show-hide",
                    "ifElement": "620122b11771f1acc2141743",
                    "condition": "eq",
                    "target": "ae",
                    "anotherElement": "620122b11771f1acc2141744",
                    "doCondition": "show",
                    "actionElements": [
                      "620122b11771f1acc2141745",
                      "620122b11771f1acc2141746"
                    ]
                  }
                },
                "payload_with_taskField": {
                  "summary": "Payload with taskField",
                  "value": {
                    "form": "620122b11771f1acc2141742",
                    "type": "task-def",
                    "ifElement": "620122b11771f1acc2141743",
                    "condition": "eq",
                    "targetValue": "ae",
                    "taskField": "620122b11771f1acc2141747",
                    "defaultElementValue": "620122b11771f1acc2141748"
                  }
                },
                "payload_with_defaultValue": {
                  "summary": "Payload with defaultValue",
                  "value": {
                    "form": "620122b11771f1acc2141742",
                    "type": "task-def",
                    "ifElement": "620122b11771f1acc2141743",
                    "condition": "eq",
                    "targetValue": "val",
                    "defaultValue": "defaultTaskValue"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Form condition created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 201
                    },
                    "data": {
                      "type": "object",
                      "description": "Created form condition object."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Form is required"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - User does not have necessary permissions or plan does not allow advance forms."
          },
          "404": {
            "description": "Form not found."
          },
          "500": {
            "description": "Internal Server Error."
          }
        },
        "operationId": "postFormCondition"
      }
    },
    "/api/v1/form/condition/{id}": {
      "patch": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Update Form Condition",
        "tags": [
          "Form"
        ],
        "description": "Updates an existing form condition based on the provided data.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the form condition to update.",
            "example": "620122b11771f1acc2141749"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ifElement": {
                    "type": "string",
                    "description": "ID of the element on which the condition is based.",
                    "example": "620122b11771f1acc2141743"
                  },
                  "condition": {
                    "type": "string",
                    "enum": [
                      "emp",
                      "fill",
                      "bf",
                      "af",
                      "neq-date",
                      "eq-date",
                      "lt",
                      "gt",
                      "eq",
                      "neq",
                      "con",
                      "ncon",
                      "sw",
                      "nsw"
                    ],
                    "description": "Condition to be evaluated.",
                    "example": "eq"
                  },
                  "target": {
                    "type": "string",
                    "enum": [
                      "val",
                      "ae"
                    ],
                    "description": "Target element or field.",
                    "example": "val"
                  },
                  "value": {
                    "type": "string",
                    "description": "Value to compare against (required if target is 'val').",
                    "example": "someValue"
                  },
                  "anotherElement": {
                    "type": "string",
                    "description": "ID of another element for comparison (required if target is 'ae').",
                    "example": "620122b11771f1acc2141744"
                  },
                  "doCondition": {
                    "type": "string",
                    "enum": [
                      "hide",
                      "show",
                      "hide_mul",
                      "show_mul",
                      "req",
                      "nreq",
                      "req_mul",
                      "nreq_mul",
                      "disable",
                      "enable",
                      "disable_sub"
                    ],
                    "description": "Action to perform if the condition is met (required for 'show-hide' and 'req-unreq' types).",
                    "example": "show"
                  },
                  "actionElements": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of element IDs to be affected by the action (required for 'show-hide' and 'req-unreq' types).",
                    "example": [
                      "620122b11771f1acc2141745",
                      "620122b11771f1acc2141746"
                    ]
                  },
                  "taskField": {
                    "type": "string",
                    "description": "ID of the task field related to the condition (required if targetValue is 'ae').",
                    "example": "620122b11771f1acc2141747"
                  },
                  "targetValue": {
                    "type": "string",
                    "enum": [
                      "val",
                      "ae"
                    ],
                    "description": "Target value for task field comparison.",
                    "example": "val"
                  },
                  "defaultElementValue": {
                    "type": "string",
                    "description": "Default element value (required if targetValue is 'ae').",
                    "example": "620122b11771f1acc2141748"
                  },
                  "defaultValue": {
                    "type": "string",
                    "description": "Default value (required if targetValue is 'val').",
                    "example": "defaultValue"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Form condition updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "type": "object",
                      "description": "Updated form condition object."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Invalid input data."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - User does not have necessary permissions or plan does not allow advance forms."
          },
          "404": {
            "description": "Form condition or related elements not found."
          },
          "500": {
            "description": "Internal Server Error."
          }
        },
        "operationId": "patchFormConditionId"
      },
      "delete": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Delete Form Condition",
        "tags": [
          "Form"
        ],
        "description": "Soft deletes a form condition by setting isTrashed to true.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the form condition to delete.",
            "example": "620122b11771f1acc2141749"
          }
        ],
        "responses": {
          "200": {
            "description": "Form condition deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "Form condition deleted successfully."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - User does not have necessary permissions."
          },
          "404": {
            "description": "Form condition not found."
          },
          "500": {
            "description": "Internal Server Error."
          }
        },
        "operationId": "deleteFormConditionId"
      }
    },
