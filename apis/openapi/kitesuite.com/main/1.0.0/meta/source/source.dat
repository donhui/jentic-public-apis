    "/api/v1/automation": {
      "get": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          }
        ],
        "summary": "Get all automation conditions",
        "tags": [
          "Automation"
        ],
        "responses": {
          "200": {
            "description": "Return all automation conditions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AutomationCondition"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Access Token is expired or invalid."
          }
        },
        "operationId": "getAutomation"
      },
      "post": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          }
        ],
        "summary": "Create automation condition",
        "tags": [
          "Automation"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "workspace": "60d21b4667d0d8992e610c85",
                  "createdBy": "60d21b4967d0d8992e610c86",
                  "eventType": "item",
                  "trigger": {
                    "projectID": "60d21b4a67d0d8992e610c87",
                    "key": "assignee-changed",
                    "from": "on-value-change",
                    "fromAssignee": "60d21b4b67d0d8992e610c88",
                    "toAssignee": "60d21b4c67d0d8992e610c89"
                  },
                  "events": [
                    {
                      "key": "status",
                      "itemField": "eq",
                      "value": "6638a2642544d313d88218de"
                    }
                  ],
                  "actions": [
                    {
                      "projectID": "60d21b5767d0d8992e610c94",
                      "key": "start-sprint",
                      "status": "60d21b5b67d0d8992e610c98",
                      "sprint": "60d21b5c67d0d8992e610c99"
                    }
                  ],
                  "description": "description",
                  "isActive": true,
                  "isTrashed": false
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Return automation condition with id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AutomationCondition"
                }
              }
            }
          },
          "401": {
            "description": "Access Token is expired or invalid."
          }
        },
        "operationId": "postAutomation"
      }
    },
