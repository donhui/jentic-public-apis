            "type": "string",
            "enum": [
              "percentage",
              "fixed"
            ],
            "description": "Type of discount.",
            "example": "percentage"
          },
          "discountRate": {
            "type": "number",
            "description": "Discount rate (percentage).",
            "example": 20
          },
          "discountAmt": {
            "type": "number",
            "description": "Discount amount (fixed).",
            "example": 0
          },
          "applyTo": {
            "type": "string",
            "enum": [
              "all",
              "specific"
            ],
            "description": "Specifies if the coupon applies to all products or specific products.",
            "example": "all"
          },
          "isEnable": {
            "type": "boolean",
            "description": "Indicates if the coupon is enabled.",
            "example": true
          },
          "totalUssage": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "array of user id that used the coupon.",
            "example": [
              "620122b11771f1acc2141755"
            ]
          }
        }
      },
      "FormConditionValidation": {
        "type": "object",
        "properties": {
          "form": {
            "type": "string",
            "description": "ID of the form.",
            "example": "620122b11771f1acc2141742"
          },
          "type": {
            "type": "string",
            "enum": [
              "show-hide",
              "req-unreq",
              "task-def"
            ],
            "description": "Type of the condition.",
            "example": "show-hide"
          },
          "ifElement": {
            "type": "string",
            "description": "ID of the element on which the condition is based.",
            "example": "620122b11771f1acc2141743"
          },
          "condition": {
            "type": "string",
            "enum": [
              "emp",
              "fill",
              "bf",
              "af",
              "neq-date",
              "eq-date",
              "lt",
              "gt",
              "eq",
              "neq",
              "con",
              "ncon",
              "sw",
              "nsw"
            ],
            "description": "Condition to be evaluated.",
            "example": "eq"
          },
          "target": {
            "type": "string",
            "enum": [
              "val",
              "ae"
            ],
            "description": "Target element or field.",
            "example": "val"
          },
          "anotherElement": {
            "type": "string",
            "description": "ID of another element for comparison (required if target is 'ae').",
            "example": "620122b11771f1acc2141744"
          },
          "value": {
            "type": "string",
            "description": "Value to compare against (required if target is 'val').",
            "example": "someValue"
          },
          "doCondition": {
            "type": "string",
            "enum": [
              "hide",
              "show",
              "hide_mul",
              "show_mul",
              "req",
              "nreq",
              "req_mul",
              "nreq_mul",
              "disable",
              "enable",
              "disable_sub"
            ],
            "description": "Action to perform if the condition is met (required for 'show-hide' and 'req-unreq' types).",
            "example": "show"
          },
          "actionElements": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of element IDs to be affected by the action (required for 'show-hide' and 'req-unreq' types).",
            "example": [
              "620122b11771f1acc2141745",
              "620122b11771f1acc2141746"
            ]
          },
          "taskField": {
            "type": "string",
            "description": "ID of the task field related to the condition (required if targetValue is 'ae').",
            "example": "620122b11771f1acc2141747"
          },
          "targetValue": {
            "type": "string",
            "enum": [
              "val",
              "ae"
            ],
            "description": "Target value for task field comparison.",
            "example": "val"
          },
          "defaultElementValue": {
            "type": "string",
            "description": "Default element value (required if targetValue is 'ae').",
            "example": "620122b11771f1acc2141748"
          },
          "defaultValue": {
            "type": "string",
            "description": "Default value (required if targetValue is 'val').",
            "example": "defaultValue"
          }
        }
      },
