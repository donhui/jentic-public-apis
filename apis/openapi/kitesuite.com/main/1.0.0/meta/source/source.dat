          "Form"
        ],
        "description": "Update the thank you page configuration for a form",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Form Thank You Page ID",
            "example": "620122b11771f1acc2141742"
          }
        ],
        "requestBody": {
          "description": "Form thank you page properties to update",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "button": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "type": "string",
                        "example": "Return to Homepage"
                      },
                      "url": {
                        "type": "string",
                        "example": "https://example.com"
                      },
                      "textColor": {
                        "type": "string",
                        "example": "#ffffff"
                      },
                      "bgColor": {
                        "type": "string",
                        "example": "#2196f3"
                      }
                    }
                  },
                  "logo": {
                    "type": "string",
                    "description": "URL or ID of the logo image",
                    "example": "https://example.com/logo.png"
                  },
                  "logoZoom": {
                    "type": "number",
                    "description": "Zoom level for the logo",
                    "example": 1.5
                  },
                  "text": {
                    "type": "string",
                    "description": "Thank you message text",
                    "example": "Thank you for your submission!"
                  },
                  "buttonAlignment": {
                    "type": "string",
                    "description": "Alignment of the button",
                    "example": "center",
                    "enum": [
                      "left",
                      "center",
                      "right"
                    ]
                  },
                  "nextSubmission": {
                    "type": "boolean",
                    "description": "Whether to allow next submission",
                    "example": true
                  },
                  "layoutDirection": {
                    "type": "string",
                    "description": "Direction of the layout",
                    "example": "vertical",
                    "enum": [
                      "vertical",
                      "horizontal"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully updated form thank you page",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "$ref": "#/components/schemas/FormThankYou"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - You don't have permission or plan doesn't include advanced forms"
          },
          "404": {
            "description": "Form thank you page not found or form not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "operationId": "patchForm-tyId"
      }
    },
