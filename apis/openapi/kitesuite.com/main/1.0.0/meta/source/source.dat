    "/api/v1/white-board/object": {
      "post": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Add Objects to Whiteboard",
        "tags": [
          "Whiteboard"
        ],
        "description": "Adds objects to a whiteboard.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "board": {
                    "type": "string",
                    "description": "ID of the whiteboard.",
                    "example": "620122b11771f1acc2141753"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "rect",
                      "circle",
                      "triangle",
                      "text-box",
                      "image",
                      "link",
                      "node-line",
                      "item"
                    ],
                    "description": "Type of object.",
                    "example": "rect"
                  },
                  "name": {
                    "type": "string",
                    "description": "Name of the object.",
                    "example": "Rectangle 1"
                  },
                  "top": {
                    "type": "number",
                    "description": "Top position of the object.",
                    "example": 100
                  },
                  "left": {
                    "type": "number",
                    "description": "Left position of the object.",
                    "example": 200
                  },
                  "width": {
                    "type": "number",
                    "description": "Width of the object.",
                    "example": 150
                  },
                  "height": {
                    "type": "number",
                    "description": "Height of the object.",
                    "example": 100
                  },
                  "fill": {
                    "type": "string",
                    "description": "Fill color of the object.",
                    "example": "red"
                  },
                  "angle": {
                    "type": "number",
                    "description": "Angle of rotation for the object.",
                    "example": 45
                  },
                  "path": {
                    "type": "string",
                    "description": "Path data for custom shapes.",
                    "example": "M10 10 L100 10 L100 100 Z"
                  },
                  "startNode": {
                    "type": "string",
                    "description": "ID of the start node for node lines.",
                    "example": "node1"
                  },
                  "endNode": {
                    "type": "string",
                    "description": "ID of the end node for node lines.",
                    "example": "node2"
                  },
                  "textValue": {
                    "type": "string",
                    "description": "Text value for text boxes and links.",
                    "example": "Hello World"
                  },
                  "scaleX": {
                    "type": "number",
                    "description": "Horizontal scaling factor.",
                    "example": 1
                  },
                  "scaleY": {
                    "type": "number",
                    "description": "Vertical scaling factor.",
                    "example": 1
                  },
                  "style": {
                    "type": "object",
                    "description": "Style properties for the object.",
                    "example": {
                      "stroke": "black",
                      "strokeWidth": 2
                    }
                  },
                  "textStyle": {
                    "type": "object",
                    "description": "Text style properties for text boxes.",
                    "example": {
                      "fontSize": 16,
                      "fontFamily": "Arial"
                    }
                  },
                  "imagePath": {
                    "type": "string",
                    "description": "Path to the image for image objects.",
                    "example": "/images/image.png"
                  },
                  "item": {
                    "type": "string",
                    "description": "ID of the item for item objects.",
                    "example": "620122b11771f1acc2141754"
                  },
                  "id": {
                    "type": "string",
                    "description": "Unique ID for the object.",
                    "example": "object123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Object added to whiteboard successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 201
                    },
                    "data": {
                      "type": "object",
                      "description": "Added whiteboard object."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input data."
          },
          "401": {
            "description": "Unauthorized - User does not have necessary permissions."
          },
          "404": {
            "description": "Whiteboard or task not found."
          },
          "500": {
            "description": "Internal Server Error - Unable to create objects."
          }
        },
        "operationId": "postWhite-boardObject"
      }
    },
