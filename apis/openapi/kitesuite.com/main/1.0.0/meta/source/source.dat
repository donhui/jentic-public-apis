                    "example": "620122b11771f1acc2141742"
                  },
                  "themeName": {
                    "type": "string",
                    "description": "Name of the theme",
                    "example": "Modern Blue"
                  },
                  "previewImage": {
                    "type": "object",
                    "properties": {
