    "/api/v1/campaign/analytics": {
      "get": {
        "summary": "Get campaign analytics",
        "description": "Retrieves analytics data for a specific campaign within a given date range.",
        "tags": [
          "Campaign"
        ],
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "campaign",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Campaign ID.",
            "example": "64d2f79e6a09f1b9c8d2cbbe"
          },
          {
            "in": "query",
            "name": "start",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date (YYYY-MM-DD). Defaults to 4 weeks prior.",
            "example": "2024-10-01"
          },
          {
            "in": "query",
            "name": "end",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date (YYYY-MM-DD). Defaults to the current date.",
            "example": "2024-10-31"
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign analytics retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "anylytics": {
                          "type": "object",
                          "properties": {
                            "sequenceStarted": {
                              "type": "integer",
                              "example": 50
                            },
                            "openRate": {
                              "type": "string",
                              "example": "75.00%"
                            },
                            "clickRate": {
                              "type": "string",
                              "example": "30.00%"
                            },
                            "opportunities": {
                              "type": "integer",
                              "example": 10
                            },
                            "conversions": {
                              "type": "integer",
                              "example": 5
                            },
                            "unsubscribeRate": {
                              "type": "string",
                              "example": "5.00%"
                            },
                            "uniqueOpenCount": {
                              "type": "integer",
                              "example": 40
                            },
                            "uniqueLinkClick": {
                              "type": "integer",
                              "example": 15
                            },
                            "startDate": {
                              "type": "string",
                              "format": "date-time",
                              "example": "2024-10-01T00:00:00.000Z"
                            },
                            "endDate": {
                              "type": "string",
                              "format": "date-time",
                              "example": "2024-10-31T23:59:59.999Z"
                            },
                            "sequences": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "example": {
                                  "name": "Sequence A",
                                  "status": "active"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
