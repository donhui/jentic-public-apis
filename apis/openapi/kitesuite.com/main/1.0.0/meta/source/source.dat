    "/api/v1/workspace/search/{query}": {
      "get": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Search All Data in Workspace",
        "tags": [
          "Workspace"
        ],
        "description": "Searches for data across tasks, epics, forms, whiteboards, and documents within a workspace.",
        "parameters": [
          {
            "in": "path",
            "name": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query string.",
            "example": "example query"
          },
          {
            "in": "query",
            "name": "selectedType",
            "schema": {
              "type": "string",
              "enum": [
                "task",
                "project",
                "epic"
              ]
            },
            "description": "Type of data to filter by (task, project, epic)."
          },
          {
            "in": "query",
            "name": "projects",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Array of project IDs to filter by."
          },
          {
            "in": "query",
            "name": "assignees",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Array of assignee IDs to filter by."
          },
          {
            "in": "query",
            "name": "reporters",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Array of reporter IDs to filter by."
          },
          {
            "in": "query",
            "name": "status",
            "schema": {
              "type": "string",
              "enum": [
                "done",
                "open"
              ]
            },
            "description": "Status to filter by (done, open)."
          },
          {
            "in": "query",
            "name": "priorities",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "none",
                  "high",
                  "medium",
                  "low"
                ]
              }
            },
            "description": "Array of priorities to filter by."
          }
        ],
        "responses": {
          "200": {
            "description": "Search results retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "items": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "description": "Task search results."
                          }
                        },
                        "epics": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "description": "Epic search results."
                          }
                        },
                        "forms": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "description": "Form search results."
                          }
                        },
                        "whiteBoards": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "description": "Whiteboard search results."
                          }
                        },
                        "docs": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "description": "Document search results."
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - User does not have necessary permissions."
          },
          "500": {
            "description": "Internal Server Error."
          }
        },
        "operationId": "getWorkspaceSearchQuery"
      }
    },
    "/api/v1/workspace/key-exists": {
      "post": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Check Workspace Key Existence",
        "tags": [
          "Workspace"
        ],
        "description": "Checks if a workspace key already exists.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "key": {
                    "type": "string",
                    "description": "Workspace key to check.",
                    "example": "examplekey"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workspace key check successful.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "isExist": {
                          "type": "boolean",
                          "description": "Indicates whether the key exists.",
                          "example": false
                        },
                        "message": {
                          "type": "string",
                          "description": "Message indicating key availability or existence.",
                          "example": "Workspace key available."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Workspace key already exists.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "isExist": {
                          "type": "boolean",
                          "description": "Indicates whether the key exists.",
                          "example": true
                        },
                        "message": {
                          "type": "string",
                          "description": "Message indicating key availability or existence.",
                          "example": "Workspace key already exists."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error."
          }
        },
        "operationId": "postWorkspaceKey-exists"
      }
    },
    "/api/v1/workspace/avatar/{id}": {
      "patch": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Update Workspace Avatar",
