                    "description": "Coupon code to redeem.",
                    "example": "SUMMER20"
                  },
                  "element": {
                    "type": "string",
                    "description": "ID of the form element.",
                    "example": "620122b11771f1acc2141750"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Coupon redeemed successfully.",
