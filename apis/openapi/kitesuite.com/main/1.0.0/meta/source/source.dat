    "/api/v1/communication/unsubscribe/{id}": {
      "get": {
        "summary": "Unsubscribe from communication emails.",
        "description": "Allows users to unsubscribe from future communication emails using a unique unsubscribe link.",
        "tags": [
          "Communication"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The ID of the communication to unsubscribe from.",
            "schema": {
              "type": "string",
              "example": "64a3fbd2f7c3a823b1e77a4f"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns an HTML page indicating the unsubscribe status.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string",
                  "example": "<html><body><h1>You've Unsubscribed Successfully</h1></body></html>"
                }
              }
            }
          },
          "404": {
            "description": "Unsubscribe link expired or invalid.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string",
                  "example": "<html><body><h1>Oops! Link Expired</h1></body></html>"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Error processing unsubscribe request"
                    }
                  }
                }
              }
            }
          }
        },
        "operationId": "getCommunicationUnsubscribeId"
      }
    },
    "/api/v1/communication/multiple-delete": {
      "post": {
        "summary": "Delete multiple communications.",
        "description": "Deletes multiple communications from the workspace. Supports deleting entire threads if specified.",
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "tags": [
          "Communication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "communicationIds": {
                    "type": "array",
                    "description": "List of communication IDs to be deleted.",
                    "items": {
                      "type": "string",
                      "example": "64a3fbd2f7c3a823b1e77a4f"
                    }
                  },
                  "isDeleteThread": {
                    "type": "boolean",
                    "description": "Flag to indicate if the entire thread should be deleted.",
                    "example": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully deleted the communications.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "COMMON.MAIL_DELETED_SUCCESS"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "One or more communications not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "COMMON.COMMUNICATION_NOT_FOUND"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Error processing delete request"
                    }
                  }
                }
              }
            }
          }
        },
        "operationId": "postCommunicationMultiple-delete"
      }
    },
    "/api/v1/communication/email/thread/{id}": {
      "get": {
        "summary": "Get communications of a specific thread.",
        "description": "Retrieves all communications related to a specific thread ID within the given workspace.",
        "tags": [
          "Communication"
        ],
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved communications of the thread.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": {
                            "type": "string",
                            "example": "64e5a4b9d9a3b0123cb8d6f2"
                          },
                          "workspace": {
                            "type": "string",
                            "example": "64c9d2f9e7a4a123ab56c7f1"
                          },
                          "createdBy": {
                            "type": "string",
                            "example": "64b4e8d4f8e3b9123cd91a5d"
                          },
                          "status": {
                            "type": "string",
                            "example": "sent"
                          },
                          "sentAt": {
                            "type": "string",
                            "format": "date-time",
                            "example": "2025-03-15T12:30:00.000Z"
                          },
                          "communicationID": {
                            "type": "object",
                            "properties": {
                              "subject": {
                                "type": "string",
                                "example": "Meeting Invitation"
                              },
                              "responseData": {
                                "type": "string",
                                "example": "Response data here"
                              }
                            }
                          },
                          "itemID": {
                            "type": "object",
                            "properties": {
                              "projectID": {
                                "type": "string",
                                "example": "64d5e7b8d1a2a223b9a3c7e4"
                              }
                            }
                          },
                          "accountID": {
                            "type": "object",
                            "properties": {
                              "account": {
                                "type": "string",
                                "example": "ABC Corp"
                              },
                              "type": {
                                "type": "string",
                                "example": "Client"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "No communications found for the specified thread.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "COMMON.COMMUNICATION_NOT_FOUND"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Error retrieving communications"
                    }
                  }
                }
              }
            }
          }
        },
        "operationId": "getCommunicationEmailThreadId"
      }
    },
