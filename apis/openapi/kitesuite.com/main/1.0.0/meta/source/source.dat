          }
        ],
        "summary": "Update Form payment",
        "tags": [
          "Form"
        ],
        "description": "Updates an existing form payment element based on the provided data.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the form payment element to update.",
            "example": "620122b11771f1acc2141750"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Title of the form element.",
                    "example": "Updated Title"
                  },
                  "subTitle": {
                    "type": "string",
                    "description": "Subtitle of the form element.",
                    "example": "Updated Subtitle"
                  },
                  "placeholder": {
                    "type": "string",
                    "description": "Placeholder text for the form element.",
                    "example": "Updated Placeholder"
                  },
                  "defaultValue": {
                    "type": "string",
                    "description": "Default value for the form element.",
                    "example": "Updated Default Value"
                  },
                  "validationType": {
                    "type": "string",
                    "description": "Validation type for the form element.",
                    "example": "email"
                  },
                  "CharLimit": {
                    "type": "integer",
                    "description": "Character limit for the form element.",
                    "example": 100
                  },
                  "mcqLimit": {
                    "type": "integer",
                    "description": "MCQ limit for the form element.",
                    "example": 5
                  },
                  "currencyType": {
                    "type": "string",
                    "description": "Currency type for the form element.",
                    "example": "USD"
                  },
                  "addressLabels": {
                    "type": "object",
                    "description": "Address labels for the form element.",
                    "example": {
                      "street": "Street",
                      "city": "City"
                    }
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Options for the form element.",
                    "example": [
                      "Option 1",
                      "Option 2"
                    ]
                  },
                  "temsConditionText": {
                    "type": "string",
                    "description": "Terms and conditions text.",
                    "example": "Terms and conditions"
                  },
                  "temsConditionLink": {
                    "type": "string",
                    "description": "Terms and conditions link.",
                    "example": "https://example.com/terms"
                  },
                  "isRequired": {
                    "type": "boolean",
                    "description": "Indicates if the form element is required.",
                    "example": true
                  },
                  "isShrinked": {
                    "type": "boolean",
                    "description": "Indicates if the form element is shrinked.",
                    "example": false
                  },
                  "isHidden": {
                    "type": "boolean",
                    "description": "Indicates if the form element is hidden.",
                    "example": false
                  },
                  "iconAvatar": {
                    "type": "string",
                    "description": "Icon avatar for the form element.",
                    "example": "icon.png"
                  },
                  "iconAvatarZoom": {
                    "type": "integer",
                    "description": "Icon avatar zoom level.",
                    "example": 100
                  },
                  "verticleAlignment": {
                    "type": "string",
                    "description": "Vertical alignment of the form element.",
                    "example": "top"
                  },
                  "horizontallyAlignment": {
                    "type": "string",
                    "description": "Horizontal alignment of the form element.",
                    "example": "left"
                  },
                  "imageAlignment": {
                    "type": "string",
                    "description": "Image alignment of the form element.",
                    "example": "center"
                  },
                  "isReadOnly": {
                    "type": "boolean",
                    "description": "Indicates if the form element is read-only.",
                    "example": false
                  },
                  "HeadingSize": {
                    "type": "string",
                    "description": "Heading size for the form element.",
                    "example": "h1"
                  },
                  "labelAlignment": {
                    "type": "string",
                    "description": "Label alignment for the form element.",
                    "example": "left"
                  },
                  "socialLinks": {
                    "type": "object",
                    "description": "Social links for the form element.",
                    "example": {
                      "id": "620122b11771f1acc2141751",
                      "link": "https://example.com",
                      "enable": true
                    }
                  },
                  "fileTypeSupport": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Supported file types for the form element.",
                    "example": [
                      "pdf",
                      "doc"
                    ]
                  },
                  "uploadType": {
