                      "name": "Product 1",
                      "price": 10,
                      "isAdd": false,
                      "isRemoved": false
                    }
                  },
                  "paymentCurrency": {
                    "type": "string",
                    "description": "Payment currency for the form element.",
                    "example": "USD"
                  },
                  "paymentType": {
                    "type": "string",
                    "description": "Payment type for the form element.",
                    "example": "stripe"
                  },
                  "paymentMode": {
                    "type": "string",
                    "description": "Payment mode for the form element.",
                    "example": "live"
                  },
                  "productView": {
                    "type": "string",
                    "description": "Product view type for the form element.",
                    "example": "grid"
                  },
                  "shipping": {
                    "type": "object",
                    "description": "Shipping information",
