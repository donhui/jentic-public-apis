          "Form"
        ],
        "description": "Retrieve form design templates based on layout",
        "parameters": [
          {
            "in": "query",
            "name": "layout",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Layout type to filter templates",
            "example": "classic"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved form design templates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": {
                            "type": "string",
                            "description": "The template ID"
                          },
                          "themeName": {
                            "type": "string",
                            "description": "Name of the theme"
                          },
                          "layout": {
                            "type": "string",
                            "description": "Layout type of the form"
                          },
                          "previewImage": {
                            "type": "object",
                            "properties": {
                              "key": {
                                "type": "string",
                                "description": "Storage key for the preview image"
                              },
                              "folder": {
                                "type": "string",
                                "description": "Storage folder for the preview image"
                              }
                            }
                          },
                          "isLive": {
                            "type": "boolean",
                            "description": "Whether the template is available for use"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - You don't have permission"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "operationId": "getForm-theme"
      }
    },
    "/api/v1/form-design/{id}": {
      "patch": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Update Form Design",
        "tags": [
          "Form"
        ],
        "description": "Update an existing form design with new styling and elements",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Form Design ID to update",
            "example": "620122b11771f1acc2141742"
          }
        ],
        "requestBody": {
          "description": "Form design properties to update",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "previousNav": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "type": "string",
                        "example": "Previous"
                      },
                      "textColor": {
                        "type": "string",
                        "example": "#ffffff"
                      },
                      "bgColor": {
                        "type": "string",
                        "example": "#2196f3"
                      }
                    }
                  },
                  "nextNav": {
                    "type": "object",
                    "properties": {
                      "text": {
                        "type": "string",
                        "example": "Next"
                      },
                      "textColor": {
                        "type": "string",
                        "example": "#ffffff"
                      },
                      "bgColor": {
                        "type": "string",
                        "example": "#2196f3"
                      }
                    }
                  },
                  "color": {
                    "type": "object",
                    "properties": {
                      "bgColor": {
                        "type": "string",
                        "example": "#f5f5f5"
                      },
                      "formColor": {
                        "type": "string",
                        "example": "#ffffff"
                      },
                      "fontColor": {
                        "type": "string",
                        "example": "#333333"
                      },
                      "inputBgColor": {
                        "type": "string",
                        "example": "#ffffff"
                      },
                      "inputColor": {
                        "type": "string",
                        "example": "#333333"
                      }
                    }
                  },
                  "pageImage": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": "string",
                        "example": "page-bg-123456"
                      },
                      "folder": {
                        "type": "string",
                        "example": "form-images"
                      }
                    }
                  },
                  "formImage": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": "string",
                        "example": "form-image-123456"
                      },
                      "folder": {
                        "type": "string",
                        "example": "form-images"
                      }
                    }
                  },
                  "formStyle": {
                    "type": "object",
                    "properties": {
                      "formWidth": {
                        "type": "number",
                        "example": 800
                      },
                      "font": {
                        "type": "string",
                        "example": "Roboto"
                      },
                      "fontSize": {
                        "type": "number",
                        "example": 16
                      },
                      "spacing": {
                        "type": "number",
                        "example": 20
                      }
                    }
                  },
                  "submitButtom": {
                    "type": "object",
                    "properties": {
                      "color": {
                        "type": "string",
                        "example": "#2196f3"
                      },
                      "hoverColor": {
                        "type": "string",
                        "example": "#1976d2"
                      },
                      "textColor": {
                        "type": "string",
                        "example": "#ffffff"
                      },
                      "bgImageUrl": {
                        "type": "string",
                        "example": "https://example.com/button-bg.png"
                      }
                    }
                  },
                  "elementDesign": {
                    "type": "object",
                    "properties": {
                      "submit_button": {
                        "type": "object",
                        "example": {
                          "color": "#2196f3",
                          "textColor": "#ffffff"
                        }
                      },
                      "heading": {
                        "type": "object",
                        "example": {
                          "fontSize": 24,
                          "color": "#333333"
                        }
                      }
                    }
                  },
                  "formDesignTemplate": {
                    "type": "string",
                    "description": "ID of the form design template to apply",
                    "example": "620122b11771f1acc2141742"
                  },
                  "header": {
                    "type": "object",
                    "description": "Header styling properties"
                  },
                  "button": {
                    "type": "object",
                    "description": "Button styling properties"
                  },
                  "dropdown": {
                    "type": "object",
                    "description": "Dropdown styling properties"
                  },
                  "checkBox": {
                    "type": "object",
                    "description": "Checkbox styling properties"
                  },
                  "textElement": {
                    "type": "object",
                    "description": "Text element styling properties"
                  },
                  "custom": {
                    "type": "object",
                    "description": "Custom styling properties"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully updated form design",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "$ref": "#/components/schemas/FormDesign"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - You don't have permission or plan doesn't include advanced forms"
          },
          "404": {
            "description": "Form design not found, form not found, or form design template not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "operationId": "patchForm-designId"
      }
    },
