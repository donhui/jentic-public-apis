    "/api/v1/form/integration/mailchimp": {
      "post": {
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "summary": "Create Form Mailchimp Integration",
        "tags": [
          "Form"
        ],
        "description": "Creates a Mailchimp integration for a form.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "form": {
                    "type": "string",
                    "description": "ID of the form.",
                    "example": "620122b11771f1acc2141750"
                  },
                  "listId": {
                    "type": "string",
                    "description": "ID of the Mailchimp list.",
                    "example": "123456"
                  },
                  "tagType": {
                    "type": "string",
                    "enum": [
                      "static",
                      "dynamic",
                      "none"
                    ],
                    "description": "Type of Mailchimp tags.",
                    "example": "static"
                  },
                  "staticTags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Array of static Mailchimp tags.",
                    "example": [
                      "tag1",
                      "tag2"
                    ]
                  },
                  "dynamicTag": {
                    "type": "string",
                    "description": "ID of the form field for dynamic Mailchimp tag.",
                    "example": "620122b11771f1acc2141751"
                  },
                  "sendContact": {
                    "type": "string",
                    "enum": [
                      "all",
                      "consent"
                    ],
                    "description": "How to send contact to Mailchimp.",
                    "example": "all"
                  },
                  "consentMessage": {
                    "type": "string",
                    "description": "Consent message for Mailchimp.",
                    "example": "Subscribe to our newsletter"
                  },
                  "isUpdateExistingContact": {
                    "type": "boolean",
                    "description": "Flag to update existing contact in Mailchimp.",
                    "example": true
                  },
                  "isAddExistingContact": {
                    "type": "boolean",
                    "description": "Flag to add existing contact in Mailchimp.",
                    "example": true
                  },
                  "isSendOptIn": {
                    "type": "boolean",
                    "description": "Flag to send opt-in email to contact.",
                    "example": true
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "objectField": {
                          "type": "string",
                          "description": "Mailchimp field ID.",
                          "example": "123"
                        },
                        "formField": {
                          "type": "string",
                          "description": "ID of the form field.",
                          "example": "620122b11771f1acc2141752"
                        }
                      }
                    },
                    "description": "Array of Mailchimp fields and corresponding form fields.",
                    "example": [
                      {
                        "objectField": "123",
                        "formField": "620122b11771f1acc2141752"
                      },
                      {
                        "objectField": "456",
                        "formField": "620122b11771f1acc2141753"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mailchimp integration created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer",
                      "example": 200
                    },
                    "data": {
                      "type": "object",
                      "description": "Created form integration object."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid Mailchimp tags or fields.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Invalid Mailchimp tags or fields."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - User does not have necessary permissions."
          },
          "404": {
            "description": "Form, integration, or Mailchimp list not found."
          },
          "500": {
            "description": "Internal Server Error."
          }
        },
        "operationId": "postFormIntegrationMailchimp"
      }
    },
