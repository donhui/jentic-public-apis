      "patch": {
        "summary": "Update a campaign by its ID",
        "description": "Updates the details of a campaign by its ID. Supports updating campaign status, name, start and end dates, and options.",
        "tags": [
          "Campaign"
        ],
        "security": [
          {
            "JwtToken": []
          },
          {
            "ApiToken": []
          },
          {
            "WorkspaceAuthKey": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The ID of the campaign to update.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Campaign data to be updated.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "The name of the campaign."
                  },
                  "status": {
                    "type": "string",
                    "description": "The status of the campaign (e.g., \"resume\", \"pause\")."
                  },
                  "options": {
                    "type": "object",
                    "description": "Additional campaign options.",
                    "properties": {
                      "accounts": {
                        "type": "array",
                        "description": "List of email account IDs.",
                        "items": {
                          "type": "string"
                        }
                      },
                      "trackEmail": {
                        "type": "boolean",
                        "description": "Whether to track email opens."
                      },
                      "emailAsText": {
                        "type": "boolean",
                        "description": "Whether to send email as plain text."
                      }
                    }
                  },
                  "start": {
                    "type": "string",
                    "format": "date-time",
