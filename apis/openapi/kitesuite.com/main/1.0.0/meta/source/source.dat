    "/api/v1/communication/email/{id}": {
      "get": {
        "summary": "Track email open status through a tracking pixel.",
        "description": "Tracks when an email is opened by recording the IP address and timestamp.",
        "tags": [
          "Communication"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The ID of the communication to track.",
            "schema": {
              "type": "string",
              "example": "64a3fbd2f7c3a823b1e77a4f"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tracking pixel returned successfully.",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Communication not found or tracking pixel not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Tracking pixel not found"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Error loading tracking pixel"
                    }
                  }
                }
              }
            }
          }
        },
        "operationId": "getCommunicationEmailId"
      }
    },
    "/api/v1/communication/link/{id}": {
      "get": {
        "summary": "Track email link clicks and redirect to the target link.",
        "description": "Tracks when a link in the email is clicked by recording the IP address and increments the click count.",
        "tags": [
          "Communication"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The ID of the link to track.",
            "schema": {
              "type": "string",
              "example": "64a3fbd2f7c3a823b1e77a4f"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirects to the original link if tracking is successful.",
            "headers": {
              "Location": {
                "description": "The original link URL.",
                "schema": {
                  "type": "string",
                  "example": "https://example.com"
                }
              }
            }
          },
          "404": {
            "description": "Link expired or invalid.",
            "content": {
              "application/json": {
                "schema": {
