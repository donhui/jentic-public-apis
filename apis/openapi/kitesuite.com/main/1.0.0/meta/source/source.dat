                  },
                  "isShowSearch": {
                    "type": "boolean",
                    "description": "show search box",
                    "example": true
                  },
                  "isShowFilter": {
                    "type": "boolean",
                    "description": "show filter box",
                    "example": true
                  },
                  "invoice": {
                    "type": "object",
                    "description": "invoice settings.",
                    "example": {
                      "invoiceEnabled": true,
                      "name": "Invoice Name",
                      "email": "invoice@example.com",
                      "phone": "1234567890",
                      "address": "Invoice Address",
                      "invoiceNotes": "Invoice Notes",
                      "logo": "invoice_logo.png",
                      "buyer": {
