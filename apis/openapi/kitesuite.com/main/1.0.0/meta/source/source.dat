          {
            "in": "path",
            "name": "id",
            "description": "Project ID",
            "required": true,
            "schema": {
              "type": "string",
              "example": "61fba63dbfa413035ca7a3dc"
            }
          },
          {
            "in": "query",
            "name": "type",
            "description": "Report type",
            "required": true,
            "schema": {
              "type": "string",
              "example": "burn-down"
            }
          },
          {
            "in": "query",
            "name": "fieldName",
            "description": "For Report type time-since-task",
            "schema": {
              "type": "string",
              "example": "updated"
            }
          },
          {
            "in": "query",
            "name": "maxData",
            "description": "For Report type recently-created",
            "schema": {
              "type": "string",
              "example": 5
            }
          },
          {
            "in": "query",
            "name": "source",
