                              "description": "Sales Hack based on Budget-Savvy Buyer Score.",
                              "nullable": true
                            },
                            "qualityFirstBuyerHack": {
                              "type": "string",
                              "description": "Sales Hack based on Quality First Buyer Score.",
                              "nullable": true
                            },
                            "impulseShopperHack": {
