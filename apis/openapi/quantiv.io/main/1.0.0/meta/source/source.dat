                          "type": "integer",
                          "nullable": true,
                          "description": "Score for Impulse Shopper category.",
                          "example": 1
                        },
                        "popularPicksScore": {
                          "type": "integer",
                          "nullable": true,
                          "description": "Score for Popular Picks category.",
                          "example": 5
                        }
                      }
                    },
                    "accuracyCode": {
                      "type": "string",
                      "example": "P",
                      "description": "Represents Accuracy Code.",
                      "enum": [
                        "P",
                        "H",
                        "G",
                        "N"
                      ]
                    },
                    "primaryOwner": {
                      "type": "string",
                      "nullable": true,
                      "example": "John M Doe",
                      "description": "Full name of the primary owner."
                    },
                    "secondaryOwner": {
                      "type": "string",
                      "nullable": true,
                      "example": "Jane Doe",
                      "description": "Full name of the secondary owner."
                    },
                    "ownerOccupied": {
                      "type": "boolean",
                      "nullable": true,
                      "example": true,
                      "description": "Indicates whether the property is occupied by the owner."
                    },
                    "homeBuiltYear": {
                      "type": "string",
                      "nullable": true,
                      "example": "1990",
                      "description": "The year the primary structure was built."
                    },
                    "yearsInHome": {
                      "type": "string",
                      "nullable": true,
                      "example": "16",
                      "description": "The number of years the primary owner has owned the property."
                    },
                    "county": {
                      "type": "string",
                      "nullable": true,
                      "example": "Douglas",
                      "description": "County name."
                    },
                    "subdivision": {
                      "type": "string",
                      "nullable": true,
                      "example": "Castle Oaks",
                      "description": "Subdivision name."
                    },
                    "school": {
                      "type": "string",
                      "nullable": true,
                      "example": "Somerville",
                      "description": "School district name."
                    },
                    "propertyType": {
                      "type": "string",
                      "nullable": true,
                      "example": "Residential",
                      "description": "General property type description."
                    },
                    "areaBuildingSize": {
                      "type": "string",
                      "nullable": true,
                      "example": "3023",
                      "description": "Total square feet of all structures on the property."
                    },
                    "scructurePresent": {
                      "type": "boolean",
                      "nullable": true,
                      "example": true,
                      "description": "Indicates whether the structure is present at the provided address."
                    },
                    "leadIntegrityScore": {
                      "type": "integer",
                      "nullable": true,
                      "example": 7,
                      "description": "Indicates lead\u2019s quality. Evaluates such parameters, as zoning classification, owner occupied, structure present, surname match. The parameter is returned if `leadIntegrityScoreOn` parameter = true in query."
                    },
                    "leadIntegrityDefects": {
                      "type": "array",
                      "nullable": true,
                      "items": {
                        "type": "string"
                      },
                      "example": [
                        "surname"
                      ],
                      "description": "Indicates lead\u2019s quality. Evaluates such parameters, as zoning classification, owner occupied, structure present, surname match. The parameter is returned if `leadIntegrityScoreOn` parameter = true in query."
                    },
                    "salesHacks": {
                      "type": "object",
                      "nullable": true,
                      "properties": {
                        "surePayHack": {
                          "type": "string",
                          "description": "Represents Sales Hack based on SurePay\u2122 Score.",
                          "nullable": true
                        },
                        "elevateHack": {
                          "type": "string",
                          "description": "Represents Sales Hack based on Elevate Score.",
                          "nullable": true
                        },
                        "buyerInsightHacks": {
                          "type": "object",
                          "properties": {
                            "savvyShopperHack": {
