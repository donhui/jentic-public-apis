                          "type": "integer",
                          "nullable": true,
                          "description": "Score for Savvy Shopper category.",
                          "example": 2
                        },
                        "brandLoyalistScore": {
                          "type": "integer",
                          "nullable": true,
                          "description": "Score for Brand Loyalist category.",
                          "example": 3
                        },
