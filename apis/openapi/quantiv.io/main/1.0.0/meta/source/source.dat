    "/api/v1/roof-estimate-widget/{referenceId}": {
      "put": {
        "tags": [
          "EngagePro\u2122 - Lead Widget"
        ],
        "description": "Updates the EngagePro\u2122 - Lead Widget configuration.",
        "summary": "Update EngagePro\u2122 - Lead Widget",
        "parameters": [
          {
            "in": "path",
            "name": "referenceId",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the Widget, which is equal to your Client's identifier and was set in the POST request, to update."
          },
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "example": "application/json"
            },
            "description": "Set to `application/json` to support file and form data submission."
          },
          {
            "in": "header",
            "name": "token",
            "schema": {
              "type": "string",
              "example": "{API Key}"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "elementType": {
                    "type": "string",
                    "example": "banner",
                    "description": "Element type, which appears on the Client\u2019s company website if the Widget Script is installed. Default - `button`.",
                    "enum": [
                      "button",
                      "banner",
                      "custom"
                    ]
                  },
                  "elementSize": {
                    "type": "string",
                    "example": "medium",
                    "description": "Element size. Default - `medium`.",
                    "enum": [
                      "small",
                      "medium",
                      "large"
                    ]
                  },
                  "elementLocation": {
                    "type": "string",
                    "example": "side_right",
                    "description": "Element placement on page. Depends on `elementType` value. `button` - \"bottom_right\" | \"bottom_left\" | \u201cside_right\u201d | \u201cside_left\u201d, `banner` - \"top\" | \"bottom\". Default - `side_right`"
                  },
                  "buttonText": {
                    "type": "string",
                    "example": "Get Your Instant Estimate",
                    "description": "CTA text shown on the element."
                  },
                  "buttonTextColor": {
                    "type": "string",
                    "example": "#FFFFFF",
                    "description": "CTA text color. Format - HEX color code. Default - `#FFFFFF`."
                  },
                  "buttonBackgroundColor": {
                    "type": "string",
                    "example": "#696CFF",
                    "description": "Background color for button or banner text (if `banner` type is applied). Format - HEX color code. Default - `#696CFF`."
                  },
                  "bannerText": {
                    "type": "string",
                    "example": "Check your roof estimate in 60 seconds",
                    "description": "Banner text (beside CTA text)."
                  },
                  "bannerBackgroundColor": {
                    "type": "string",
                    "example": "#F5F5F9",
                    "description": "Banner background color. Format - HEX color code."
                  },
                  "primaryColor": {
                    "type": "string",
                    "example": "#696CFF",
                    "description": "Color of the primary buttons, QR-codes and titles. HEX color code must be used."
                  },
                  "secondaryColor": {
                    "type": "string",
                    "example": "#aaaaaa",
                    "description": "Color of secondary buttons. HEX color code must be used."
                  },
                  "backgroundColor": {
                    "type": "string",
                    "example": "#F5F5F9",
                    "description": "Background color under the hosted widget. HEX color code must be used."
                  },
                  "cardBackgroundColor": {
                    "type": "string",
                    "example": "#ffffff",
                    "description": "Background color of the widget card. HEX color code must be used."
                  },
                  "textColor": {
                    "type": "string",
                    "example": "#22303EE6",
                    "description": "Main text color. HEX color code must be used."
                  },
                  "linkColor": {
                    "type": "string",
                    "example": "#696CFF",
                    "description": "Hyperlink color. HEX color code must be used."
                  },
                  "footerCompanyName": {
                    "type": "string",
                    "example": "Company Name",
                    "description": "Footer company name."
