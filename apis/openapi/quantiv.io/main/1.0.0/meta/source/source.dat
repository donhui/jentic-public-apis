    "/api/v1/roof-estimate": {
      "get": {
        "tags": [
          "Lead Value - Roof"
        ],
        "summary": "Get Lead Value - Roof",
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "application/json"
          },
          {
            "name": "token",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "{API Key}"
          },
          {
            "name": "streetNumber",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead's street number."
          },
          {
            "name": "streetAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead's street address."
          },
          {
            "name": "city",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead\u2019s city name."
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead's state name (two-letter abbreviation, e.g., NY)."
          },
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead\u2019s zip code (5 digit code)."
          },
          {
            "name": "roofMaterial",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "asphalt shingle",
                "slate",
                "tile",
                "metal",
                "other"
              ]
            },
            "example": "asphalt shingle",
            "description": "Type of roofing material used in the estimation. Default value is `asphalt shingle`."
          },
          {
            "name": "installedPrice",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "minimum": 0.01,
              "format": "float"
            },
            "example": 400,
            "description": "Client's all-in installation price (USD) per square, including materials, labor and gross profit, for asphalt shingle roofing material used in the estimation. Default value is `400`."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2024-08-20T14:30:00Z",
                      "description": "The timestamp when the response was returned. It is provided in ISO 8601 format."
                    },
                    "roofArea": {
                      "type": "number",
                      "nullable": true,
                      "description": "Total roof area in square feet, adjusted for pitch.",
                      "example": 1250.75
                    },
                    "squaresWithPitch": {
                      "type": "number",
                      "nullable": true,
                      "description": "Roof size in \"squares\" (1 square = 100 sq ft), adjusted for pitch.",
                      "example": 12.51
                    },
                    "averageRoofPitch": {
                      "type": "number",
                      "nullable": true,
                      "description": "Average roof pitch in degrees.",
                      "example": 6.5
                    },
                    "roofComplexityLevel": {
                      "type": "string",
                      "nullable": true,
                      "enum": [
                        "simple",
                        "average",
                        "complex"
                      ],
                      "description": "Complexity level of the roof, determined based on the number of individual roof facets detected in the structure.",
                      "example": "average"
                    },
                    "roofMaterial": {
                      "type": "string",
                      "nullable": true,
                      "description": "Roofing material used in the estimation and included in an API request. If parameter is not included in an API request, then default value is used.",
                      "example": "asphalt shingle"
                    },
                    "installedPrice": {
                      "type": "number",
                      "nullable": true,
                      "description": "Client's all-in installation price (USD) per square for asphalt shingle roofing material used in the estimation and included in an API request. If parameter is not included in an API request, then default value is used.",
                      "example": 400
                    },
                    "roofCostEstimate": {
                      "type": "number",
                      "nullable": true,
                      "description": "Final estimated total cost of the roofing project (USD).",
                      "example": 5318.19
                    },
                    "structurePresentConfidenceScore": {
                      "type": "number",
                      "nullable": true,
                      "enum": [
                        50,
                        100
                      ],
                      "description": "Confidence score that the structure matches the input address.",
                      "example": 100
                    },
                    "dataAccurcyAlerts": {
                      "type": "object",
                      "properties": {
                        "roofPitchAlert": {
                          "type": "string",
                          "nullable": true,
                          "description": "Roof pitch alert indicating if the `averageRoofPitch` is unusually low or high.",
                          "enum": [
                            "LOW_PITCH",
                            "HIGH_PITCH",
                            "NO_ALERTS"
                          ],
                          "example": "LOW_PITCH"
                        },
                        "roofAreaAlert": {
                          "type": "string",
                          "nullable": true,
                          "description": "Roof area alert indicating if the `roofArea` is unusually small or large.",
                          "enum": [
                            "LOW_AREA",
                            "HIGH_AREA",
                            "NO_ALERTS"
                          ],
                          "example": "LOW_AREA"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Bad Request"
                    },
                    "statusCode": {
                      "type": "integer",
                      "example": 400
                    },
                    "message": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "example": [
                        "state must be a string",
                        "state should not be empty",
                        "installedPrice value must be a decimal greater than 0 with at most 2 decimal places"
                      ]
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Unauthorized"
                    },
                    "statusCode": {
                      "type": "integer",
                      "example": 401
                    },
                    "message": {
                      "type": "string",
                      "example": "Invalid API Key"
                    }
                  }
                }
