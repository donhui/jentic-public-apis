    "/api/v1/utility-bill": {
      "get": {
        "tags": [
          "Utility Bill"
        ],
        "summary": "Get Utility Bill Information",
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "application/json"
          },
          {
            "name": "token",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "{API Key}"
          },
          {
            "name": "streetNumber",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead's street number."
          },
          {
            "name": "streetAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead's street address."
          },
          {
            "name": "city",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead\u2019s city name."
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead's state name (two-letter abbreviation, e.g., NY)."
          },
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead\u2019s zip code (5 digit code)."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Utility Bill data retrieval or No Data case.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "description": "The timestamp when the response was returned. It is provided in ISO 8601 format.",
                      "example": "2024-08-20T14:30:00Z"
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "success",
                        "error"
                      ],
                      "description": "Indicates whether the request was successful or an error occurred.",
                      "example": "success"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable message describing the result of the request.",
                      "example": "Data successfully retrieved."
                    },
                    "address": {
                      "type": "string",
                      "description": "Full address used in the request.",
                      "example": "123 Main St, Austin, TX"
                    },
                    "data": {
                      "type": "object",
                      "description": "Contains utility data.",
                      "properties": {
                        "units": {
                          "type": "object",
                          "description": "Units of measurement used in the response data.",
                          "properties": {
                            "consumption": {
                              "type": "string",
                              "description": "Unit of measurement for energy consumption.",
                              "example": "kWh"
                            },
                            "cost": {
                              "type": "string",
                              "description": "Unit of measurement for energy cost.",
                              "example": "USD"
                            },
                            "emissions": {
                              "type": "string",
                              "description": "Unit of measurement for emissions.",
                              "example": "kgCO2e"
                            },
                            "emissionRate": {
                              "type": "string",
                              "description": "Unit of measurement for emission rate.",
                              "example": "kgCO2e/kWh"
                            },
                            "utilityRate": {
                              "type": "string",
                              "description": "Unit of measurement for utility rate.",
                              "example": "USD/kWh"
                            }
                          }
                        },
                        "electricity": {
                          "type": "object",
                          "nullable": true,
                          "description": "Electricity consumption, cost and emission statistics.",
                          "properties": {
                            "monthlyAverageConsumption": {
                              "type": "number",
                              "description": "Average monthly electricity consumption over the last 12 months.",
                              "example": 435.2
                            },
                            "monthlyAverageCost": {
                              "type": "number",
                              "description": "Average monthly electricity cost over the last 12 months.",
                              "example": 98.5
                            },
                            "annualConsumption": {
                              "type": "number",
                              "description": "Total electricity consumption over the last 12 months.",
                              "example": 5222.4
                            },
                            "annualCost": {
                              "type": "number",
                              "description": "Total electricity cost over the last 12 months.",
                              "example": 1182
                            },
                            "quarterAverageConsumption": {
                              "type": "object",
                              "description": "Average electricity consumption per quarter.",
                              "properties": {
                                "q1": {
                                  "type": "number",
                                  "description": "Average electricity consumption for Q1 (Jan-Mar).",
                                  "example": 410.2
                                },
                                "q2": {
                                  "type": "number",
                                  "description": "Average electricity consumption for Q2 (Apr-Jun).",
                                  "example": 455
                                },
                                "q3": {
                                  "type": "number",
                                  "description": "Average electricity consumption for Q3 (Jul-Sep).",
                                  "example": 472.6
                                },
                                "q4": {
                                  "type": "number",
                                  "description": "Average electricity consumption for Q4 (Oct-Dec).",
                                  "example": 402.9
                                }
                              }
                            },
                            "quarterAverageCost": {
                              "type": "object",
                              "description": "Average electricity cost per quarter.",
                              "properties": {
                                "q1": {
                                  "type": "number",
                                  "description": "Average electricity cost for Q1 (Jan-Mar).",
                                  "example": 90.4
                                },
                                "q2": {
                                  "type": "number",
                                  "description": "Average electricity cost for Q2 (Apr-Jun).",
                                  "example": 102.1
                                },
                                "q3": {
                                  "type": "number",
                                  "description": "Average electricity cost for Q3 (Jul-Sep).",
                                  "example": 110.5
                                },
                                "q4": {
                                  "type": "number",
                                  "description": "Average electricity cost for Q4 (Oct-Dec).",
                                  "example": 91
                                }
                              }
                            },
                            "peakMonth": {
                              "type": "object",
                              "description": "Month with highest electricity consumption.",
                              "properties": {
                                "name": {
                                  "type": "string",
                                  "description": "Peak month name.",
                                  "example": "August"
                                },
                                "consumption": {
                                  "type": "number",
                                  "description": "Electricity consumption in the peak month.",
                                  "example": 520
                                },
                                "cost": {
                                  "type": "number",
                                  "description": "Electricity cost in the peak month.",
                                  "example": 120.5
                                }
                              }
                            },
                            "monthlyAverageUtilityRate": {
                              "type": "number",
                              "description": "Monthly average electricity utility rate over the last 12 month.",
                              "example": 0.215
                            },
                            "emissions": {
                              "type": "object",
                              "description": "Emissions data from electricity usage.",
                              "properties": {
                                "annualEmissions": {
                                  "type": "number",
                                  "description": "Total electricity emissions over the last 12 months.",
                                  "example": 1200
                                },
                                "monthlyAverageEmissions": {
                                  "type": "number",
                                  "description": "Monthly average electricity emissions over the last 12 months.",
                                  "example": 100
                                },
                                "monthlyAverageEmissionRate": {
                                  "type": "number",
                                  "description": "Monthly average electricity emissions per kWh of electricity consumption over the last 12 months.",
                                  "example": 0.18
                                },
                                "peakMonth": {
                                  "type": "object",
                                  "description": "Month with highest electricity emissions.",
                                  "properties": {
                                    "name": {
                                      "type": "string",
                                      "description": "Peak month name.",
                                      "example": "July"
                                    },
                                    "emissions": {
                                      "type": "number",
                                      "description": "Electricity emissions in peak month.",
                                      "example": 0.21
                                    }
                                  }
                                }
                              }
                            }
                          }
                        },
                        "fossilFuel": {
                          "type": "object",
                          "nullable": true,
                          "description": "Fossil fuel usage statistics.",
                          "properties": {
                            "type": {
                              "type": "string",
                              "description": "Type of fossil fuel.",
                              "example": "Natural Gas"
                            },
                            "annualConsumption": {
                              "type": "number",
                              "description": "Total fossil fuel consumption over the last 12 months.",
                              "example": 2840
                            },
                            "annualCost": {
                              "type": "number",
                              "description": "Total fossil fuel cost over the last 12 months.",
                              "example": 380
                            },
                            "monthlyAverageUtilityRate": {
                              "type": "number",
                              "description": "Monthly average fossil fuel utility rate over the last 12 months.",
                              "example": 0.134
                            }
                          }
                        },
                        "ratios": {
                          "type": "object",
                          "nullable": true,
                          "properties": {
                            "electricToFossilRatio": {
                              "type": "number",
                              "description": "Ratio of electricity to fossil fuel consumption over the last 12 months.",
                              "example": 1.84
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
