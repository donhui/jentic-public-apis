                          "type": "integer",
                          "nullable": true,
                          "description": "Score for Trendsetter category.",
                          "example": 3
                        },
                        "budgetsavvyBuyerScore": {
                          "type": "integer",
                          "nullable": true,
                          "description": "Score for Budget-Savvy Buyer category.",
                          "example": 4
                        },
                        "qualityFirstBuyerScore": {
                          "type": "integer",
                          "nullable": true,
                          "description": "Score for Quality First Buyer category.",
                          "example": 0
