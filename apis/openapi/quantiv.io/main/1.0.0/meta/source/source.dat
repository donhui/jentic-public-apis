    "/api/v1/roof-estimate-widget/{referenceId}/upload-logos": {
      "patch": {
        "tags": [
          "EngagePro\u2122 - Lead Widget"
        ],
        "description": "Uploads header and footer logos for the EngagePro\u2122 - Lead Widget configuration.",
        "summary": "Partially Update EngagePro\u2122 - Lead Widget",
        "parameters": [
          {
            "in": "path",
            "name": "referenceId",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the Widget, which is equal to your Client's identifier) and was set in the POST request, to upload logos."
          },
          {
            "in": "header",
            "name": "Content-Type",
            "schema": {
              "type": "string",
              "example": "multipart/form-data"
            },
            "description": "Must be set to `multipart/form-data` for file upload."
          },
          {
            "in": "header",
            "name": "token",
            "schema": {
              "type": "string",
              "example": "{API Key}"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "headerLogo": {
                    "type": "string",
                    "format": "binary",
                    "description": "Logo displayed at the top of the widget. \nPNG or JPG format recommended (horizontal layout preferred, e.g., 300\u00d7150 px).\nMax file size - 1 MB.\n"
                  },
                  "footerLogo": {
                    "type": "string",
                    "format": "binary",
                    "description": "Small logo at the bottom of the widget (favicon preferred, e.g., 24\u00d724 px).\nPNG or JPG format recommended.\nMax file size - 1 MB.\n"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logos successfully uploaded and widget configuration returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "referenceId": {
                      "type": "string",
                      "example": "1051dcbf-560b-40f9-abaa-8d872976d1fd",
                      "description": "Unique identifier of the Client in your system."
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "active",
                        "inactive"
                      ],
                      "example": "active",
                      "description": "Widget status."
                    },
                    "widgetLink": {
                      "type": "string",
                      "format": "url",
                      "example": "https://companyurl1?roof-estimate=open",
                      "description": "Redirect link to open widget on Client's website."
                    },
                    "quantivPageLink": {
                      "type": "string",
                      "format": "url",
                      "example": "https://dev.app.your-estimate.com/widget/roof-estimate/1051dcbf-560b-40f9-abaa-8d872976d1fd",
                      "description": "Redirect link to Quantiv-hosted widget page."
                    },
                    "domains": {
                      "type": "string",
                      "example": "https://quantiv-io-150dfe78743658-2f6743b6afd11.webflow.io",
                      "description": "Authorized domains where widget script can run."
                    },
                    "elementType": {
                      "type": "string",
                      "enum": [
                        "button",
                        "banner",
                        "custom"
                      ],
                      "example": "banner",
                      "description": "UI element type displayed on website."
                    },
                    "elementLocation": {
                      "type": "string",
                      "example": "bottom",
                      "description": "Element placement on page."
                    },
                    "elementSize": {
                      "type": "string",
                      "enum": [
                        "small",
                        "medium",
                        "large"
                      ],
                      "example": "medium",
                      "description": "Element size."
                    },
                    "buttonText": {
                      "type": "string",
                      "example": "button text",
                      "description": "Call-to-action text on element."
                    },
                    "buttonTextColor": {
                      "type": "string",
                      "pattern": "^#[0-9A-Fa-f]{6}$",
                      "example": "#ffffff",
                      "description": "CTA text color in HEX format."
                    },
                    "buttonBackgroundColor": {
                      "type": "string",
                      "pattern": "^#[0-9A-Fa-f]{6}$",
