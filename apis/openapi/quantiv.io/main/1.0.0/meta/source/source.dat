    "/api/v1/gosolar-index": {
      "get": {
        "tags": [
          "GoSolar Index"
        ],
        "summary": "Get GoSolar Index",
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "application/json"
          },
          {
            "name": "token",
            "in": "header",
            "schema": {
              "type": "string"
            },
            "example": "{API Key}"
          },
          {
            "name": "streetNumber",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead's street number."
          },
          {
            "name": "streetAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead's street address."
          },
          {
            "name": "city",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead\u2019s city name."
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead's state name (two-letter abbreviation, e.g., NY)."
          },
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Lead\u2019s zip code (5 digit code)."
          },
          {
            "name": "lastName",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Lead\u2019s last name. Used for Lead Integrity Score calculation."
          },
          {
            "name": "leadIntegrityScoreOn",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Used for activating Lead Integrity information being returned in response."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "example": "2024-08-20T14:30:00Z",
                      "description": "The timestamp when the response was returned. It is provided in ISO 8601 format."
                    },
                    "goSolarIndex": {
                      "type": "integer",
                      "nullable": true,
                      "example": 1,
                      "description": "Represents GoSolar Index Score."
                    },
                    "prospectFitLevel": {
                      "type": "string",
                      "nullable": true,
                      "example": "Ideal",
                      "enum": [
                        "Ideal",
                        "Moderate",
                        "Weak"
                      ],
                      "description": "Represents Prospect Fit Level."
                    },
                    "prospectAttitudeMessage": {
                      "type": "string",
                      "nullable": true,
                      "example": "Lead with emphasis on renewable energy benefits, community.",
                      "description": "Represents Prospect Attitude Message."
                    },
                    "accuracyCode": {
                      "type": "string",
                      "example": "P",
                      "description": "Represents Accuracy Code.",
                      "enum": [
                        "P",
                        "H",
                        "G",
                        "N"
                      ]
                    },
                    "primaryOwner": {
                      "type": "string",
                      "nullable": true,
                      "example": "John M Doe",
                      "description": "Full name of the primary owner."
                    },
                    "secondaryOwner": {
                      "type": "string",
                      "nullable": true,
                      "example": "Jane Doe",
                      "description": "Full name of the secondary owner."
                    },
                    "ownerOccupied": {
                      "type": "boolean",
                      "nullable": true,
                      "example": true,
                      "description": "Indicates whether the property is occupied by the owner."
                    },
                    "homeBuiltYear": {
                      "type": "string",
                      "nullable": true,
                      "example": "1990",
                      "description": "The year the primary structure was built."
                    },
                    "yearsInHome": {
                      "type": "string",
                      "nullable": true,
                      "example": "16",
                      "description": "The number of years the primary owner has owned the property."
                    },
                    "county": {
                      "type": "string",
                      "nullable": true,
                      "example": "Douglas",
                      "description": "County name."
                    },
                    "subdivision": {
                      "type": "string",
                      "nullable": true,
                      "example": "Castle Oaks",
                      "description": "Subdivision name."
                    },
                    "school": {
                      "type": "string",
                      "nullable": true,
                      "example": "Somerville",
                      "description": "School district name."
                    },
                    "propertyType": {
                      "type": "string",
                      "nullable": true,
                      "example": "Residential",
                      "description": "General property type description."
                    },
                    "areaBuildingSize": {
                      "type": "string",
                      "nullable": true,
                      "example": "3023",
                      "description": "Total square feet of all structures on the property."
                    },
                    "scructurePresent": {
                      "type": "boolean",
                      "nullable": true,
                      "example": true,
                      "description": "Indicates whether the structure is present at the provided address."
                    },
                    "leadIntegrityScore": {
                      "type": "integer",
                      "nullable": true,
                      "example": 7,
                      "description": "Indicates lead\u2019s quality. Evaluates such parameters, as zoning classification, owner occupied, structure present, surname match. The parameter is returned if `leadIntegrityScoreOn` parameter = true in query."
                    },
                    "leadIntegrityDefects": {
                      "type": "array",
                      "nullable": true,
                      "items": {
                        "type": "string"
                      },
                      "example": [
                        "surname"
                      ],
                      "description": "Indicates lead\u2019s quality. Evaluates such parameters, as zoning classification, owner occupied, structure present, surname match. The parameter is returned if `leadIntegrityScoreOn` parameter = true in query."
                    }
                  }
                }
              }
            }
          },
