                    "type": "boolean",
                    "description": "Removes Footer Logo if `false` is sent.",
                    "example": false
                  },
                  "headerLogo": {
                    "type": "file",
                    "description": "Logo displayed at the top. PNG or JPG (recommended). Horizontal layout preferred (e.g. 300\u00d7150 px). Max file size - 1 MB."
                  },
