    "/api/v1/webhooks": {
      "post": {
        "tags": [
          "Widget Webhooks"
        ],
        "summary": "Create New Webhook",
        "description": "Creates a webhook to listen for events related to widgets.",
        "parameters": [
          {
            "in": "header",
            "name": "Accept",
            "schema": {
              "type": "string",
              "example": "application/json"
            }
          },
          {
            "in": "header",
            "name": "token",
            "schema": {
              "type": "string",
              "example": "{API key}"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "url",
                  "events"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Webhook Name",
                    "description": "Webhook name."
                  },
                  "url": {
                    "type": "string",
                    "example": "https://webhook.site/6979dd8e-c00b-427a-8c42-245ad782f4bc",
                    "description": "Webhook callback URL that will receive posted webhook events."
                  },
                  "events": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "lead.created",
                      "lead.updated",
                      "widget.created",
                      "widget.updated"
                    ],
                    "description": "Event types that will be sent to the registered webhook endpoint."
                  },
                  "timeoutSeconds": {
                    "type": "number",
                    "example": 30,
                    "description": "Time (in seconds) the system waits for a `200` status code response from the registered endpoint before marking the attempt as failed. Default - `30`."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook is successfully created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Unique identifier of the webhook.",
                      "example": "7352983b-2f3e-4e6f-b472-061945204d79"
                    },
                    "name": {
                      "type": "string",
                      "description": "Webhook name.",
                      "example": "Webhook 1"
                    },
                    "url": {
                      "type": "string",
                      "description": "Webhook callback URL.",
                      "example": "https://webhook.site/6979dd8e-c00b-427a-8c42-245ad782f4bc"
                    },
                    "events": {
                      "type": "array",
                      "description": "Represents which types of events will be posted to the registered webhook endpoint.",
                      "items": {
                        "type": "string"
                      },
                      "example": [
                        "lead.created",
                        "lead.updated",
                        "widget.created",
                        "widget.updated"
                      ]
                    },
                    "active": {
                      "type": "boolean",
                      "description": "Represents whether webhook is active and accepts posted events.",
                      "example": true
                    },
                    "secret": {
                      "type": "string",
                      "description": "Webhook secret parameter, which is used for the implementation of webhook security. The value is shown only in the POST method response.",
                      "example": "dc2503b83d28fe85b57c55ad83daca63..."
                    },
                    "failureCount": {
                      "type": "integer",
                      "description": "Number of failed webhook delivery attempts.",
                      "example": 0
                    },
                    "successCount": {
                      "type": "integer",
                      "description": "Number of successful webhook deliveries.",
                      "example": 12
                    },
                    "lastFailureAt": {
                      "type": "string",
                      "format": "date-time",
                      "nullable": true,
                      "description": "Timestamp of the last failed attempt. It is provided in ISO 8601 format.",
                      "example": null
                    },
                    "lastSuccessAt": {
                      "type": "string",
                      "format": "date-time",
                      "nullable": true,
                      "description": "Timestamp of the last successful attempt. It is provided in ISO 8601 format.",
                      "example": "2025-07-09T16:00:53.244Z"
                    },
                    "timeoutSeconds": {
                      "type": "integer",
                      "description": "Time (in seconds) the system waits for a `200` status code response from the registered endpoint before marking the attempt as failed.",
                      "example": 10
                    },
                    "createdAt": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of webhook creation. It is provided in ISO 8601 format.",
                      "example": "2025-07-09T14:04:03.771Z"
                    },
                    "updatedAt": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of last update to the webhook. It is provided in ISO 8601 format.",
