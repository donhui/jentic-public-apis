      "example": {
        "transport": {
          "host": "smtp-relay.gmail.com",
          "port": 465,
          "secure": true,
          "auth": {}
        },
        "from": "no-reply@bettrdata.io",
        "templates": {
          "failed": {
            "subject": "= `Failed Validation Notification: ${file.fileName}`",
            "body": "p The following file has been received but has failed validation:\np\np \nstrong Sender\n|: #{clientNode.name}\np \nstrong Filename\n|: #{file.fileName}\np \nstrong Byte Size\n|: #{file.byteSize}\np\nstrong Date\n|: #{file.createDate}\np \nstrong System Id\n|: #{file._id}\n\n<br>\n<br>\np Validation failed due to the following errors:\n\neach error,index in convertValidation.errors\n    ul\n        li #{error}"
          },
          "receipt": {
            "subject": "= `File Receipt Notification: ${file.fileName}`",
            "body": "p The following file has been received:\np\np \nstrong Sender\n|: #{clientNode.name}\np \nstrong Filename\n|: #{file.fileName}\np \nstrong Byte Size\n|: #{file.byteSize}\np\nif file.route\n  strong Site\n  |: #{file.route.host}#{file.route.directory}\np\nstrong Date\n|: #{file.createDate}\np \nstrong System Id\n|: #{file._id}"
          },
          "route": {
            "path": "/app/back/src/config/email/route"
          }
