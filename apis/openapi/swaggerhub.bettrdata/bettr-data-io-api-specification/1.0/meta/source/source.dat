    "/route/{id}/upload": {
      "description": "Upload a file",
      "post": {
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/file"
              },
              "examples": {
                "File Example": {
                  "value": "file=@\"/path/to/file\""
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/datafile"
                }
              }
            },
            "description": "Success"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      },
      "parameters": [
        {
          "name": "id",
          "description": "Route Id",
          "schema": {
            "type": "string"
          },
          "in": "path",
          "required": true
        }
      ]
    },
