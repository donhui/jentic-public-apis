{
  "openapi": "3.0.3",
  "info": {
    "title": "Open Trivia Database API",
    "version": "1.0.0",
    "description": "Free, user-contributed trivia question database. Provides trivia questions with configurable amount, category, difficulty, and type, along with session token management and category statistics.",
    "x-jentic-source-url": "https://opentdb.com/api_config.php"
  },
  "servers": [
    {
      "url": "https://opentdb.com"
    }
  ],
  "paths": {
    "/api.php": {
      "get": {
        "operationId": "getTriviaQuestions",
        "summary": "Get trivia questions",
        "description": "Retrieves trivia questions from the database with optional filters for amount, category, difficulty, type, and encoding.",
        "tags": ["Questions"],
        "parameters": [
          {
            "name": "amount",
            "in": "query",
            "required": true,
            "description": "Number of questions to retrieve (1-50).",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50 }
          },
          {
            "name": "category",
            "in": "query",
            "description": "Category ID to filter questions.",
            "schema": { "type": "integer" }
          },
          {
            "name": "difficulty",
            "in": "query",
            "description": "Difficulty level.",
            "schema": { "type": "string", "enum": ["easy", "medium", "hard"] }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Question type.",
            "schema": { "type": "string", "enum": ["multiple", "boolean"] }
          },
          {
            "name": "encode",
            "in": "query",
            "description": "Encoding format for the response.",
            "schema": { "type": "string", "enum": ["urlLegacy", "url3986", "base64"] }
          },
          {
            "name": "token",
            "in": "query",
            "description": "Session token to prevent duplicate questions.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TriviaResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api_token.php": {
      "get": {
        "operationId": "manageSessionToken",
        "summary": "Manage session token",
        "description": "Request a new session token (command=request) or reset an existing one (command=reset).",
        "tags": ["Tokens"],
        "parameters": [
          {
            "name": "command",
            "in": "query",
            "required": true,
            "description": "Token command: 'request' for new token, 'reset' to reset existing.",
            "schema": { "type": "string", "enum": ["request", "reset"] }
          },
          {
            "name": "token",
            "in": "query",
            "description": "Session token to reset (required when command=reset).",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api_category.php": {
      "get": {
        "operationId": "getCategories",
        "summary": "Get categories",
        "description": "Returns all available trivia categories and their IDs.",
        "tags": ["Categories"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CategoryListResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api_count.php": {
      "get": {
        "operationId": "getCategoryQuestionCount",
        "summary": "Get category question count",
        "description": "Returns the number of questions in a specific category.",
        "tags": ["Categories"],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "required": true,
            "description": "The category ID.",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CategoryCountResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api_count_global.php": {
      "get": {
        "operationId": "getGlobalQuestionCount",
        "summary": "Get global question count",
        "description": "Returns the total number of questions across all categories and statuses.",
        "tags": ["Categories"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GlobalCountResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TriviaResponse": {
        "type": "object",
        "properties": {
          "response_code": { "type": "integer", "description": "0=Success, 1=No Results, 2=Invalid Parameter, 3=Token Not Found, 4=Token Empty" },
          "results": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TriviaQuestion" }
          }
        }
      },
      "TriviaQuestion": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["multiple", "boolean"] },
          "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
          "category": { "type": "string" },
          "question": { "type": "string" },
          "correct_answer": { "type": "string" },
          "incorrect_answers": { "type": "array", "items": { "type": "string" } }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "response_code": { "type": "integer" },
          "response_message": { "type": "string" },
          "token": { "type": "string" }
        }
      },
      "CategoryListResponse": {
        "type": "object",
        "properties": {
          "trivia_categories": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TriviaCategory" }
          }
        }
      },
      "TriviaCategory": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      },
      "CategoryCountResponse": {
        "type": "object",
        "properties": {
          "category_id": { "type": "integer" },
          "category_question_count": {
            "type": "object",
            "properties": {
              "total_question_count": { "type": "integer" },
              "total_easy_question_count": { "type": "integer" },
              "total_medium_question_count": { "type": "integer" },
              "total_hard_question_count": { "type": "integer" }
            }
          }
        }
      },
      "GlobalCountResponse": {
        "type": "object",
        "properties": {
          "overall": {
            "type": "object",
            "properties": {
              "total_num_of_questions": { "type": "integer" },
              "total_num_of_pending_questions": { "type": "integer" },
              "total_num_of_verified_questions": { "type": "integer" },
              "total_num_of_rejected_questions": { "type": "integer" }
            }
          },
          "categories": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "total_num_of_questions": { "type": "integer" },
                "total_num_of_pending_questions": { "type": "integer" },
                "total_num_of_verified_questions": { "type": "integer" },
                "total_num_of_rejected_questions": { "type": "integer" }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "response_code": {
            "type": "integer",
            "description": "Error code: 1=No Results, 2=Invalid Parameter, 3=Token Not Found, 4=Token Empty, 5=Rate Limit"
          },
          "results": {
            "type": "array",
            "items": {}
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}