    "/reports": {
      "post": {
        "operationId": "querytransactions",
        "summary": "Query transactions by date range",
        "tags": [
          "Reports"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
