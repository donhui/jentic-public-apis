                  "name": {
                    "type": "string",
                    "description": "Report name filter"
                  },
                  "start_date": {
                    "type": "string",
                    "format": "date",
                    "description": "Start date"
                  },
                  "end_date": {
                    "type": "string",
                    "format": "date",
                    "description": "End date"
                  },
                  "start_row": {
                    "type": "integer"
                  },
                  "end_row": {
                    "type": "integer"
                  }
                },
                "required": [
                  "start_date",
                  "end_date"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction report",
