{
  "openapi": "3.0.0",
  "info": {
    "title": "Basketball Shot Matching",
    "version": "0.1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/KNX_Sports_and_Media/Basketball_Shot_Matching/0.1/swagger.json"
  },
  "paths": {
    "/api/noah-shot": {
      "post": {
        "tags": [
          "Shot"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/Shot"
                    },
                    {
                      "$ref": "#/components/schemas/ShotWithCoef"
                    }
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shot response",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": {
                        "oneOf": [
                          {
                            "$ref": "#/components/schemas/NoSessionResponse"
                          },
                          {
                            "$ref": "#/components/schemas/NoMatchResponse"
                          },
                          {
                            "$ref": "#/components/schemas/MatchResponse"
                          }
                        ]
                      }
                    },
                    {
                      "$ref": "#/components/schemas/InvalidRequestResponse"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Auth failure"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Shot": {
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/Shot"
          },
          {
            "properties": {
              "origin_timestamp": {
                "type": "integer",
                "description": "Timestamp in ms",
                "example": 1620369623563
              },
              "basket_id": {
                "type": "integer",
                "example": 1
              },
              "origin_x": {
                "type": "number",
                "example": 1.3
              },
              "origin_y": {
                "type": "number",
                "example": 2.2
              },
              "origin_z": {
                "type": "number",
                "example": 2.5
              },
              "successful": {
                "type": "boolean",
                "example": true
              },
              "grade": {
                "oneOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "array"
                  }
                ],
                "example": [
                  1
                ]
              },
              "arc": {
                "type": "number",
                "example": 45.69
              }
            }
          }
        ]
      },
      "ShotWithCoef": {
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/ShotWithCoef"
          },
          {
            "properties": {
              "origin_timestamp": {
                "type": "integer",
                "description": "Timestamp in ms",
                "example": 1620369623563
              },
              "basket_id": {
                "type": "integer",
                "example": 1
              },
              "origin_x": {
                "type": "number",
                "example": 1.3
              },
              "origin_y": {
                "type": "number",
                "example": 2.2
              },
              "origin_z": {
                "type": "number",
                "example": 2.5
              },
              "successful": {
                "type": "boolean",
                "example": true
              },
              "grade": {
                "oneOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "array"
                  }
                ],
                "example": [
                  1
                ]
              },
              "arc": {
                "type": "number",
                "example": 45.69
              },
              "x_coef": {
                "type": "array",
                "example": [
                  0,
                  -0.147399,
                  59.3595
                ]
              },
              "y_coef": {
                "type": "array",
                "example": [
                  0,
                  -0.147399,
                  59.3595
                ]
              },
              "z_coef": {
                "type": "array",
                "example": [
                  0,
                  -0.147399,
                  59.3595
                ]
              }
            }
          }
        ]
      },
      "NoSessionResponse": {
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/NoSessionResponse"
          },
          {
            "properties": {
              "status": {
                "type": "string",
                "example": "NO_SESSION"
              },
              "origin_timestamp": {
                "type": "integer",
                "nullable": true,
                "example": 1620369623563
              },
              "player_id": {
                "type": "integer",
                "nullable": true,
                "example": null
              },
              "matching_distance": {
                "type": "number",
                "nullable": true,
                "example": null,
                "description": "Distance to supplied coordinates in meters"
              }
            }
          }
        ]
      },
      "NoMatchResponse": {
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/NoMatchResponse"
          },
          {
            "properties": {
              "status": {
                "type": "string",
                "example": "NO_MATCH"
              },
              "origin_timestamp": {
                "type": "integer",
                "nullable": true,
                "example": 1620369623563
              },
              "player_id": {
                "type": "integer",
                "nullable": true,
                "example": null
              },
              "matching_distance": {
                "type": "number",
                "nullable": true,
                "example": null,
                "description": "Distance to supplied coordinates in meters"
              }
            }
          }
        ]
      },
      "MatchResponse": {
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/MatchResponse"
          },
          {
            "properties": {
              "status": {
                "type": "string",
                "example": "SUCCESS"
              },
              "origin_timestamp": {
                "type": "integer",
                "nullable": true,
                "example": 1620369623563
              },
              "player_id": {
                "type": "integer",
                "nullable": true,
                "example": 123
              },
              "matching_distance": {
                "type": "number",
                "nullable": true,
                "example": 1.2,
                "description": "Distance to supplied coordinates in meters"
              }
            }
          }
        ]
      },
      "InvalidRequestResponse": {
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/InvalidRequestResponse"
          },
          {
            "properties": {
              "status": {
                "type": "string",
                "example": "INVALID_REQUEST"
              },
              "error": {
                "type": "string",
                "example": "Error string"
              }
            }
          }
        ]
      }
    }
  }
}