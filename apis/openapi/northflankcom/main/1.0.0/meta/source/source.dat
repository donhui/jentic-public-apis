          "200": { "description": "List of jobs" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createProjectJob",
        "summary": "Create a job in a project",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/JobCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "Job created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/jobs/{jobId}": {
      "get": {
        "operationId": "getProjectJob",
        "summary": "Get job details",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/JobId" }
        ],
        "responses": {
          "200": { "description": "Job details" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteProjectJob",
        "summary": "Delete a job",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/JobId" }
        ],
        "responses": {
          "200": { "description": "Job deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/jobs/{jobId}/runs": {
      "post": {
        "operationId": "triggerJobRun",
        "summary": "Execute a job run",
        "tags": ["Jobs"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/JobId" }
        ],
        "responses": {
          "201": { "description": "Job run triggered" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/secrets": {
      "get": {
        "operationId": "listProjectSecrets",
        "summary": "List project secrets",
        "tags": ["Secrets"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" }
        ],
        "responses": {
          "200": { "description": "List of project secrets" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createProjectSecret",
        "summary": "Create a project secret",
        "tags": ["Secrets"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SecretCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "Secret created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/volumes": {
      "get": {
        "operationId": "listProjectVolumes",
        "summary": "List project volumes",
        "tags": ["Volumes"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" }
        ],
        "responses": {
          "200": { "description": "List of volumes" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createProjectVolume",
        "summary": "Create a volume",
        "tags": ["Volumes"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "201": { "description": "Volume created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/domains": {
      "get": {
        "operationId": "listDomains",
        "summary": "List custom domains",
        "tags": ["Domains"],
        "responses": {
          "200": { "description": "List of domains" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createDomain",
        "summary": "Register a custom domain",
        "tags": ["Domains"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DomainCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "Domain created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/domains/{domain}/subdomains": {
      "get": {
        "operationId": "listSubdomains",
        "summary": "List subdomains for a domain",
        "tags": ["Domains"],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Domain name"
          }
        ],
        "responses": {
          "200": { "description": "List of subdomains" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createSubdomain",
        "summary": "Create a subdomain",
        "tags": ["Domains"],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Domain name"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "201": { "description": "Subdomain created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/backup-destinations": {
      "get": {
        "operationId": "listBackupDestinations",
        "summary": "List backup destinations",
        "tags": ["Backups"],
        "responses": {
          "200": { "description": "List of backup destinations" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createBackupDestination",
        "summary": "Create a backup destination",
        "tags": ["Backups"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "201": { "description": "Backup destination created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/teams/{teamId}/projects": {
      "get": {
        "operationId": "listTeamProjects",
        "summary": "List projects in a team",
        "tags": ["Projects"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamId" }
        ],
        "responses": {
          "200": { "description": "List of projects" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createTeamProject",
        "summary": "Create a project in a team",
        "tags": ["Projects"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProjectCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "Project created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/teams/{teamId}/secrets": {
      "get": {
        "operationId": "listTeamSecrets",
        "summary": "List global team secrets",
        "tags": ["Secrets"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamId" }
        ],
        "responses": {
          "200": { "description": "List of team secrets" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createTeamSecret",
        "summary": "Create a global team secret",
        "tags": ["Secrets"],
        "parameters": [
          { "$ref": "#/components/parameters/TeamId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SecretCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "Team secret created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/cloud-providers/clusters": {
      "get": {
        "operationId": "listClusters",
        "summary": "List Kubernetes clusters",
        "tags": ["Infrastructure"],
        "responses": {
          "200": { "description": "List of clusters" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createCluster",
        "summary": "Create a Kubernetes cluster",
        "tags": ["Infrastructure"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "201": { "description": "Cluster created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/cloud-providers/integrations": {
      "get": {
        "operationId": "listCloudIntegrations",
        "summary": "List cloud provider integrations",
        "tags": ["Infrastructure"],
        "responses": {
          "200": { "description": "List of integrations" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createCloudIntegration",
        "summary": "Create a cloud provider integration",
        "tags": ["Infrastructure"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "201": { "description": "Integration created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/billing/invoices": {
      "get": {
        "operationId": "listInvoices",
        "summary": "List billing invoices",
        "tags": ["Billing"],
        "responses": {
          "200": { "description": "List of invoices" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token authentication. Obtain tokens from the Northflank dashboard."
      }
    },
    "parameters": {
      "ProjectId": {
        "name": "projectId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Project identifier"
      },
      "ServiceId": {
        "name": "serviceId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Service identifier"
      },
      "JobId": {
        "name": "jobId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Job identifier"
      },
      "AddonId": {
        "name": "addonId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Addon identifier"
      },
      "TeamId": {
        "name": "teamId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Team identifier"
      }
    },
    "schemas": {
      "AddonCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Addon name" },
          "type": { "type": "string", "description": "Addon type (e.g. mongodb, postgresql, redis)" }
        },
        "required": ["name", "type"]
      },
      "ServiceCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Service name" },
          "type": { "type": "string", "description": "Service type (build, combined, deployment)" }
        },
        "required": ["name"]
      },
      "JobCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Job name" },
          "type": { "type": "string", "description": "Job type (manual, scheduled)" }
        },
        "required": ["name"]
      },
      "SecretCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Secret name" },
          "data": { "type": "object", "description": "Key-value pairs for the secret" }
        },
        "required": ["name"]
      },
      "DomainCreate": {
        "type": "object",
        "properties": {
          "domain": { "type": "string", "description": "Domain name to register" }
        },
        "required": ["domain"]
      },
      "ProjectCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Project name" },
          "description": { "type": "string" }
        },
        "required": ["name"]
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters"
      },
