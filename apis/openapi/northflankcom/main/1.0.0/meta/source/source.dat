{
  "openapi": "3.0.3",
  "info": {
    "title": "Northflank API",
    "description": "Northflank platform API for managing projects, services, jobs, addons, domains, secrets, and cloud infrastructure programmatically.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://northflank.com/docs/v1/api"
  },
  "servers": [
    {
      "url": "https://api.northflank.com",
      "description": "Northflank API server"
    }
  ],
  "paths": {
    "/v1/": {
      "get": {
        "operationId": "healthCheck",
        "summary": "API health check",
        "tags": ["General"],
        "responses": {
          "200": { "description": "API is healthy" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/addon-types": {
      "get": {
        "operationId": "listAddonTypes",
        "summary": "List available addon types",
        "description": "Returns the list of available addon types (databases, caches, etc.).",
        "tags": ["Addons"],
        "responses": {
          "200": { "description": "List of addon types" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/addons": {
      "get": {
        "operationId": "listProjectAddons",
        "summary": "List addons in a project",
        "tags": ["Addons"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" }
        ],
        "responses": {
          "200": { "description": "List of addons in the project" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createProjectAddon",
        "summary": "Create an addon in a project",
        "tags": ["Addons"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddonCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "Addon created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/addons/{addonId}": {
      "get": {
        "operationId": "getProjectAddon",
        "summary": "Get addon details",
        "tags": ["Addons"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/AddonId" }
        ],
        "responses": {
          "200": { "description": "Addon details" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "operationId": "updateProjectAddon",
        "summary": "Update an addon",
        "tags": ["Addons"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/AddonId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "Addon updated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteProjectAddon",
        "summary": "Delete an addon",
        "tags": ["Addons"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/AddonId" }
        ],
        "responses": {
          "200": { "description": "Addon deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/addons/{addonId}/backups": {
      "get": {
        "operationId": "listAddonBackups",
        "summary": "List addon backups",
        "tags": ["Addons"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/AddonId" }
        ],
        "responses": {
          "200": { "description": "List of backups" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createAddonBackup",
        "summary": "Create an addon backup",
        "tags": ["Addons"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/AddonId" }
        ],
        "responses": {
          "201": { "description": "Backup created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/services": {
      "get": {
        "operationId": "listProjectServices",
        "summary": "List services in a project",
        "tags": ["Services"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" }
        ],
        "responses": {
          "200": { "description": "List of services" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createProjectService",
        "summary": "Create a service in a project",
        "tags": ["Services"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ServiceCreate" }
            }
          }
        },
        "responses": {
          "201": { "description": "Service created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/services/{serviceId}": {
      "get": {
        "operationId": "getProjectService",
        "summary": "Get service details",
        "tags": ["Services"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/ServiceId" }
        ],
        "responses": {
          "200": { "description": "Service details" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "operationId": "updateProjectService",
        "summary": "Update a service",
        "tags": ["Services"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/ServiceId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": { "description": "Service updated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
