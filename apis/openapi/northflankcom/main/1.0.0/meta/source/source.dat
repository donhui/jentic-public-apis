        "responses": {
          "200": { "description": "Service deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/services/{serviceId}/builds": {
      "post": {
        "operationId": "triggerServiceBuild",
        "summary": "Trigger a service build",
        "tags": ["Services"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/ServiceId" }
        ],
        "responses": {
          "201": { "description": "Build triggered" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/services/{serviceId}/logs": {
      "get": {
        "operationId": "getServiceLogs",
        "summary": "Retrieve service logs",
        "tags": ["Services"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectId" },
          { "$ref": "#/components/parameters/ServiceId" }
        ],
        "responses": {
          "200": { "description": "Service log entries" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/projects/{projectId}/jobs": {
      "get": {
        "operationId": "listProjectJobs",
