            "description": "Number of records to skip (optional)",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "take",
            "in": "query",
            "description": "umber of records to take (optional, max 1000)",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
