{
  "openapi": "3.0.3",
  "info": {
    "title": "RTA Fleet Management API",
    "description": "REST API for interacting with RTA Fleet Management software, including vehicle search, details, updates, authentication, and data extraction.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developers.rtafleet.com/"
  },
  "servers": [
    {
      "url": "https://api.momentum-prd.rtafleet.com",
      "description": "Production - Asset Management and Authentication"
    },
    {
      "url": "https://api.rtafleet.com",
      "description": "Production - Data Extract API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Obtain API tokens"
    },
    {
      "name": "Vehicles",
      "description": "Search and manage vehicles"
    },
    {
      "name": "Data Extract",
      "description": "Extract data from RTA"
    }
  ],
  "paths": {
    "/information-management/{tenantId}/integrations/get-api-token": {
      "get": {
        "operationId": "getApiToken",
        "summary": "Get an API token using client credentials",
        "tags": ["Authentication"],
        "security": [],
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "description": "Your RTA tenant identifier (Serial Number)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "clientId",
            "in": "query",
            "required": true,
            "description": "Your application's Client ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "clientSecret",
            "in": "query",
            "required": true,
            "description": "Your application's Client Secret",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "API token returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/asset-management/{tenantId}/vehicles/search-vehicles-enhanced": {
      "post": {
        "operationId": "searchVehiclesEnhanced",
        "summary": "Search vehicles with filters, sorts, and pagination",
        "tags": ["Vehicles"],
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "description": "Your RTA tenant identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VehicleSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/asset-management/{tenantId}/vehicles/{id}": {
      "get": {
        "operationId": "getVehicle",
        "summary": "Get vehicle details by ID",
        "tags": ["Vehicles"],
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "description": "Your RTA tenant identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Vehicle unique identifier (UUID)",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Vehicle details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VehicleResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - missing required permission",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Vehicle not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateVehicle",
        "summary": "Update a vehicle by ID",
        "tags": ["Vehicles"],
        "parameters": [
          {
            "name": "tenantId",
            "in": "path",
            "required": true,
            "description": "Your RTA tenant identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Vehicle unique identifier (UUID)",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateVehicleRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Vehicle updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VehicleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - missing required permission",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v0/extract/{tablename}": {
      "get": {
        "operationId": "extractData",
        "summary": "Extract raw database records from RTA",
        "description": "Extract data from RTA using the Data Extract API (hosted on api.rtafleet.com). Supports etag-based change tracking for incremental synchronization. Requires 'api:extractTable' permission.",
        "tags": ["Data Extract"],
        "parameters": [
          {
            "name": "tablename",
            "in": "path",
            "required": true,
            "description": "Database table name to extract from",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of records to return",
            "schema": {
              "type": "integer",
              "default": 1000
            }
          },
          {
            "name": "etag",
            "in": "query",
            "description": "Retrieve rows modified since this etag value",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Extracted data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataExtractResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - missing required permission",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Bearer token obtained from the Get API Token endpoint"
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT access token"
          }
        }
      },
      "SearchRequest": {
        "type": "object",
        "properties": {
          "queryOptions": {
            "$ref": "#/components/schemas/QueryOptions"
          }
        }
      },
      "QueryOptions": {
        "type": "object",
        "properties": {
          "pagination": {
            "type": "object",
            "properties": {
              "offset": {
                "type": "integer",
                "description": "Number of records to skip (zero-based)"
              },
              "limit": {
                "type": "integer",
                "description": "Maximum number of records to return"
              }
            }
          },
          "filters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Filter"
            }
          },
          "sorts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sort"
            }
          }
        }
      },
      "Filter": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Field name to filter on"
          },
          "operator": {
            "type": "string",
            "enum": ["eq", "neq", "gt", "gte", "lt", "lte", "contains", "beginsWith", "endsWith"],
            "description": "Comparison operator"
          },
          "values": {
            "type": "array",
            "items": {},
            "description": "Array of values to compare against"
          }
        }
      },
      "Sort": {
        "type": "object",
        "properties": {
          "sortBy": {
            "type": "string",
            "description": "Field name to sort on"
          },
          "sortOrder": {
            "type": "string",
            "enum": ["ASC", "DESC"],
            "description": "Sort direction"
          }
        }
      },
      "Vehicle": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "vehicleNumber": {
            "type": "string"
          },
          "serialNumber": {
            "type": "string"
          },
          "make": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          }
        }
      },
      "VehicleSearchResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Vehicle"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "VehicleResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "vehicleNumber": {
            "type": "string"
          },
          "serialNumber": {
            "type": "string"
          },
          "make": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          }
        }
      },
      "UpdateVehicleRequest": {
        "type": "object",
        "properties": {
          "make": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "year": {
            "type": "integer"
          }
        }
      },
      "DataExtractResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          },
          "totalRecords": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "sorts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sort"
            }
          },
          "searchMeta": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "requiredPermission": {
            "type": "string"
          }
        }
      }
    }
  }
}