              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/cancel_request": {
      "post": {
        "operationId": "cancelFillRequest",
        "summary": "Cancel a fill request",
        "description": "Cancel an existing fill request.",
        "tags": ["Fill Requests"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "request_id": {
                    "type": "string",
                    "description": "Fill request identifier to cancel"
                  }
                },
                "required": ["request_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fill request cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
