    "/webhook_events/{webhook_type}": {
      "get": {
        "operationId": "getWebhookEvents",
        "summary": "Get webhook events",
        "description": "Retrieve webhook events by type with optional query filters. Supports filtering by id, timestamp, next, and status using operators like $lt, $gt, $lte, $gte, $eq.",
        "tags": ["Webhook Events"],
        "parameters": [
          {
            "name": "webhook_type",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["notify_rx"]
            },
            "description": "Type of webhook events to retrieve"
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter by timestamp using operators (e.g. $gt:1625177120)"
          },
          {
            "name": "next",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Pagination token from previous response next_page_token"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter by delivery status"
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook events returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookEventsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key authentication. Format: 'ApiKey {YOUR_API_KEY}'"
      }
    },
    "schemas": {
      "CreatePatientRequest": {
        "type": "object",
        "required": ["first_name", "last_name", "dob", "gender"],
        "properties": {
          "first_name": { "type": "string", "description": "Legal patient first name" },
          "last_name": { "type": "string", "description": "Legal patient last name" },
          "guardian": { "type": "string", "description": "Pet owner first name", "nullable": true },
          "dob": { "type": "string", "description": "Date of birth in YYYYMMDD format" },
          "gender": { "type": "string", "enum": ["male", "female"], "description": "Assigned gender at birth" },
          "ssn": { "type": "string", "description": "Social Security Number (e.g. 123456789)" },
          "communications_opt_in": { "type": "boolean", "description": "Communications opt in" },
          "id_image": { "type": "string", "description": "URL for image of user ID" },
          "ssn_serial": { "type": "string", "description": "Last 4 digits of SSN" },
          "mbi": { "type": "string", "description": "Medicare Beneficiary ID" },
          "zip": { "type": "string", "description": "Patient zip code" },
          "company": { "type": "string", "description": "Company name" },
          "street1": { "type": "string", "description": "Street address line 1" },
          "street2": { "type": "string", "description": "Street address line 2" },
          "city": { "type": "string", "description": "City" },
          "state": { "type": "string", "description": "Two-letter state abbreviation" },
          "country": { "type": "string", "description": "Country code" },
          "phone": { "type": "string", "description": "Phone number" },
          "email": { "type": "string", "description": "Email address" },
          "language_preference": { "type": "string", "description": "Preferred language (English or Spanish)" },
          "species": { "type": "string", "description": "Patient species. Default is HUMAN." },
          "viewed_notice_of_privacy_practices": { "type": "boolean", "description": "Received Notice of Privacy Practices" },
          "viewed_notice_of_privacy_practices_date": { "type": "string", "description": "Date in YYYYMMDD format" }
        }
      },
      "CreatePatientResponse": {
        "type": "object",
        "properties": {
          "patient_token": { "type": "string", "description": "Token to reference the patient record" }
        }
      },
      "UpdatePatientRequest": {
        "type": "object",
        "properties": {
          "ssn": { "type": "string" },
          "communications_opt_in": { "type": "boolean" },
          "id_image": { "type": "string" },
          "ssn_serial": { "type": "string" },
          "mbi": { "type": "string" },
          "zip": { "type": "string" },
          "company": { "type": "string" },
          "street1": { "type": "string" },
          "street2": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "phone": { "type": "string" },
          "email": { "type": "string" },
          "language_preference": { "type": "string" },
          "viewed_notice_of_privacy_practices": { "type": "boolean" },
          "viewed_notice_of_privacy_practices_date": { "type": "string" }
        }
      },
      "UpdatePatientResponse": {
        "type": "object",
        "properties": {
          "patient_token": { "type": "string" },
          "timestamp": { "type": "integer" },
          "status": { "type": "string" },
          "details": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          }
        }
      },
      "FindPatientResponse": {
        "type": "object",
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "guardian": { "type": "string" },
          "gender": { "type": "string" },
          "dob": { "type": "string" },
          "communications_opt_in": { "type": "boolean" },
          "patient_token": { "type": "string" },
          "species": { "type": "string" }
        }
      },
      "PatientDetail": {
        "type": "object",
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "guardian": { "type": "string" },
          "gender": { "type": "string" },
          "dob": { "type": "string" },
          "mbi": { "type": "string" },
          "address": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "street1": { "type": "string" },
              "street2": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "zip": { "type": "string" },
              "company": { "type": "string", "nullable": true },
              "country": { "type": "string" },
              "phone": { "type": "string" },
              "email": { "type": "string" },
              "communications_opt_in": { "type": "boolean" }
            }
          },
          "patient_token": { "type": "string" }
        }
      },
      "PatientPrescriptionsResponse": {
        "type": "object",
        "properties": {
          "patient_token": { "type": "string" },
          "prescriptions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Prescription"
            }
          }
        }
      },
      "Prescription": {
        "type": "object",
        "properties": {
          "prescription_token": { "type": "string" },
          "fillable": { "type": "boolean" },
          "is_refill": { "type": "integer" },
          "medication_name": { "type": "string" },
          "rx_number": { "type": "string" },
          "medication_id": { "type": "string" },
          "origin": { "type": "string" },
          "prescribed_brand_name": { "type": "string" },
          "prescribed_drug_strength": { "type": "string" },
          "prescribed_generic_name": { "type": "string" },
          "prescribed_written_name": { "type": "string" },
          "prescribed_quantity": { "type": "integer" },
          "prescribed_quantity_unit": { "type": "string" },
          "prescribed_ndc": { "type": "string" },
          "original_prescribed_ndc": { "type": "string", "nullable": true },
          "medication_sig": { "type": "string" },
          "prescriber": { "type": "string" },
          "prescriber_npi": { "type": "string" },
          "prescriber_order_number": { "type": "string" },
          "date_written": { "type": "string" },
          "date_filled_utc": { "type": "string" },
          "last_filled_date": { "type": "string" },
          "expiration_date_utc": { "type": "string" },
          "days_supply": { "type": "string" },
          "number_of_refills_allowed": { "type": "integer" },
          "refills_remaining": { "type": "integer" },
          "quantity_remaining": { "type": "integer" },
          "current_rx_status_text": { "type": "string" }
        }
      },
      "PrescriptionDetailResponse": {
        "type": "object",
        "properties": {
          "prescription": {
            "$ref": "#/components/schemas/PrescriptionDetail"
          }
        }
      },
      "PrescriptionDetail": {
        "type": "object",
        "properties": {
          "date_written": { "type": "string" },
          "expiration_date": { "type": "string" },
          "days_supply": { "type": "string" },
          "is_refill": { "type": "integer" },
          "last_filled_date": { "type": "string", "nullable": true },
          "medication_sig": { "type": "string" },
          "number_of_refills_allowed": { "type": "integer" },
          "origin": { "type": "string" },
          "prescribed_brand_name": { "type": "string" },
          "prescribed_drug_strength": { "type": "string" },
          "prescribed_generic_name": { "type": "string" },
          "prescribed_ndc": { "type": "string" },
          "prescribed_quantity": { "type": "integer" },
          "prescribed_written_name": { "type": "string" },
          "prescriber": { "type": "string" },
          "prescriber_address": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "company": { "type": "string", "nullable": true },
              "street1": { "type": "string" },
              "street2": { "type": "string", "nullable": true },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "zip": { "type": "string" },
              "country": { "type": "string" },
              "phone": { "type": "string" },
              "email": { "type": "string" }
            }
          },
          "prescriber_npi": { "type": "string" },
          "prescriber_order_number": { "type": "string" },
          "quantity_remaining": { "type": "integer" },
          "refills_remaining": { "type": "integer" },
          "rx_number": { "type": "string" }
        }
      },
      "TransferRequestBody": {
        "type": "object",
        "required": ["patient_token"],
        "properties": {
          "patient_token": { "type": "string", "description": "Token referencing the patient" },
          "metadata": { "type": "string", "description": "Customer-side identifier" }
        }
      },
      "TransferRequestResponse": {
        "type": "object",
        "properties": {
          "request_id": { "type": "string" },
          "timestamp": { "type": "integer" },
          "status": { "type": "string" }
        }
      },
      "DirectTransferRequest": {
        "type": "object",
        "required": ["patient_token"],
        "properties": {
          "patient_token": { "type": "string", "description": "Token referencing the patient" },
          "metadata": { "type": "string", "description": "Customer-side identifier" }
        }
      },
      "DirectTransferResponse": {
        "type": "object",
        "properties": {
          "request_id": { "type": "string" },
          "timestamp": { "type": "integer" },
          "status": { "type": "string" }
        }
      },
      "FillRequestBody": {
        "type": "object",
        "required": ["patient_token", "prescription_token", "metadata"],
        "properties": {
          "patient_token": { "type": "string", "description": "Token referencing the patient" },
          "prescription_token": { "type": "string", "description": "Token referencing the prescription" },
          "metadata": { "type": "string", "description": "Customer-side identifier" }
        }
      },
      "FillRequestResponse": {
        "type": "object",
        "properties": {
          "request_id": { "type": "string" },
          "timestamp": { "type": "integer" },
          "status": { "type": "string" },
          "details": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          }
        }
      },
      "CreateInsuranceRequest": {
        "type": "object",
        "required": ["patient_token"],
        "properties": {
          "patient_token": { "type": "string", "description": "Token referencing the patient" }
        }
      },
      "CopayRequestBody": {
        "type": "object",
        "required": ["patient_token", "prescription_token", "metadata"],
        "properties": {
          "patient_token": { "type": "string", "description": "Token referencing the patient" },
          "prescription_token": { "type": "string", "description": "Token referencing the prescription" },
          "metadata": { "type": "string", "description": "Customer-side identifier" }
        }
      },
      "CopayRequestResponse": {
        "type": "object",
        "properties": {
          "request_id": { "type": "string" },
          "timestamp": { "type": "integer" },
          "status": { "type": "string" },
          "details": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          }
        }
      },
      "CoverageRequestBody": {
        "type": "object",
        "required": ["patient_token", "metadata"],
        "properties": {
          "patient_token": { "type": "string", "description": "Token referencing the patient" },
          "metadata": { "type": "string", "description": "Customer-side identifier" }
        }
      },
      "CoverageRequestResponse": {
        "type": "object",
        "properties": {
          "request_id": { "type": "string" },
          "timestamp": { "type": "integer" },
          "status": { "type": "string" },
          "details": {
            "type": "object",
            "properties": {
              "coverage_request_token": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      },
      "WebhookEventsResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WebhookEvent"
            }
          },
          "next_page_token": { "type": "string", "description": "Token for retrieving next page of results" }
        }
      },
      "WebhookEvent": {
        "type": "object",
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "integer" },
              "callback_type": { "type": "string" },
              "details": { "type": "object" }
            }
          },
          "delivery_data": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "status_code": { "type": "integer" }
            }
          }
        }
      },
      "ValidationErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "integer", "example": 400 },
          "error": { "type": "string", "example": "Bad Request" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "integer" },
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "UnauthorizedResponse": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "integer", "example": 401 },
          "error": { "type": "string", "example": "Unauthorized" },
          "message": { "type": "string", "example": "Please Send a Valid Api-Key" }
        }
      }
    }
  }
}