              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fill_request/{request_id}/webhook_events": {
      "get": {
        "operationId": "getFillRequestWebhookEvents",
        "summary": "Get fill request webhook events",
        "description": "Retrieve webhook events associated with a fill request.",
        "tags": ["Fill Requests"],
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
