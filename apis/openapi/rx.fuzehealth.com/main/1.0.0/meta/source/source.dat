        },
        "responses": {
          "200": {
            "description": "Fill request created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FillRequestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fill_request/{request_id}": {
      "get": {
        "operationId": "getFillRequest",
        "summary": "Get a fill request",
        "description": "Retrieve details of a specific fill request.",
