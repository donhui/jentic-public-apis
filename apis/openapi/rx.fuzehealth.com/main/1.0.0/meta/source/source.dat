            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fill_request/{fill_request_id}/stripe_payment": {
      "put": {
        "operationId": "updateFillRequestPaymentIntent",
        "summary": "Update fill request payment intent",
        "description": "Update the Stripe payment intent for a fill request.",
        "tags": ["Fill Requests"],
        "parameters": [
          {
            "name": "fill_request_id",
            "in": "path",
