    },
    "/update_request": {
      "post": {
        "operationId": "updateFillRequest",
        "summary": "Update a fill request",
        "description": "Update an existing fill request.",
        "tags": ["Fill Requests"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fill request updated",
