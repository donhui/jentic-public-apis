{
  "openapi": "3.0.3",
  "info": {
    "title": "FuzeRx Pharmacy & Telehealth API",
    "description": "The FuzeRx API provides access to pharmacy and telehealth infrastructure including patient management, prescription handling, fill requests, transfers, insurance, copay requests, coverage requests, and prior authorizations.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://rx.fuzehealth.com/api-docs/introduction"
  },
  "servers": [
    {
      "url": "https://rxapi.fuzehealth.com/v1",
      "description": "Production"
    },
    {
      "url": "https://rxapi.sandbox.fuzehealth.com/v1",
      "description": "Sandbox"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    { "name": "Patients", "description": "Patient record management" },
    { "name": "Prescriptions", "description": "Prescription retrieval and management" },
    { "name": "Fill Requests", "description": "Medication fill request operations" },
    { "name": "Transfers", "description": "Prescription transfer requests" },
    { "name": "Direct Transfers", "description": "Direct prescription transfers between pharmacies" },
    { "name": "Insurance", "description": "Insurance management" },
    { "name": "Copay Requests", "description": "Copay request operations" },
    { "name": "Coverage Requests", "description": "Coverage/eligibility request operations" },
    { "name": "Prior Authorization", "description": "Prior authorization operations" },
    { "name": "Patient Safety", "description": "Drug, allergy, and condition search" },
    { "name": "Webhook Events", "description": "Webhook event retrieval" }
  ],
  "paths": {
    "/patient": {
      "put": {
        "operationId": "createPatient",
        "summary": "Create a patient",
        "description": "Generates a patient record in the FuzeRx ecosystem. Returns a patient_token for subsequent API requests.",
        "tags": ["Patients"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePatientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patient created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePatientResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - validation errors",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "findPatient",
        "summary": "Find a patient",
        "description": "Search for patient information by demographic fields without a patient_token.",
        "tags": ["Patients"],
        "parameters": [
          {
            "name": "first_name",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Legal patient first name"
          },
          {
            "name": "last_name",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Legal patient last name"
          },
          {
            "name": "dob",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Date of birth in YYYYMMDD format"
          },
          {
            "name": "gender",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["male", "female"] },
            "description": "Assigned gender at birth"
          },
          {
            "name": "zip",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Patient zip code"
          }
        ],
        "responses": {
          "200": {
            "description": "Patient found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FindPatientResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/patient/{patient_token}": {
      "get": {
        "operationId": "getPatient",
        "summary": "Get a patient",
        "description": "Retrieve patient information using the patient_token.",
        "tags": ["Patients"],
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Token referencing the patient record"
          }
        ],
        "responses": {
          "200": {
            "description": "Patient details returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientDetail"
                }
              }
            }
          },
          "400": {
            "description": "Patient does not belong to this customer",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "updatePatient",
        "summary": "Update a patient",
        "description": "Updates a patient record. Only non-required fields can be updated (first_name, last_name, dob, gender cannot be changed).",
        "tags": ["Patients"],
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Token referencing the patient record"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePatientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Patient updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdatePatientResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - restricted field or validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/patient/{patient_token}/prescriptions": {
      "get": {
        "operationId": "getPatientPrescriptions",
        "summary": "Get patient prescriptions",
        "description": "Retrieve the list of a patient's prescriptions including prescription token, medication details, and fill status.",
        "tags": ["Prescriptions"],
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Token referencing the patient record"
          }
        ],
        "responses": {
          "200": {
            "description": "List of patient prescriptions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatientPrescriptionsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/patient/{patient_token}/patient_survey": {
      "get": {
        "operationId": "getPatientSurvey",
        "summary": "Get a patient survey",
        "description": "Retrieve the patient safety survey information for a patient.",
        "tags": ["Patient Safety"],
        "parameters": [
          {
            "name": "patient_token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Token referencing the patient record"
          }
        ],
        "responses": {
          "200": {
            "description": "Patient survey returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/prescription/{prescription_token}": {
      "get": {
        "operationId": "getPrescription",
        "summary": "Get a prescription",
        "description": "Retrieve detailed prescription information using the prescription token.",
        "tags": ["Prescriptions"],
        "parameters": [
          {
            "name": "prescription_token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Token referencing the prescription"
          }
        ],
        "responses": {
          "200": {
            "description": "Prescription details returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PrescriptionDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/prescription/{prescription_token}/fill/{fill_number}/claims": {
      "get": {
        "operationId": "getInsuranceClaimDetails",
        "summary": "Get insurance claim details",
        "description": "Retrieve insurance claim details for a specific prescription fill.",
        "tags": ["Insurance"],
        "parameters": [
          {
            "name": "prescription_token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Token referencing the prescription"
          },
          {
            "name": "fill_number",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Fill number for the prescription"
          }
        ],
        "responses": {
          "200": {
            "description": "Claim details returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transfer_request": {
      "post": {
        "operationId": "createTransferRequest",
        "summary": "Create a transfer request",
        "description": "Create a prescription transfer request to transfer a patient's prescription from another pharmacy to FuzeRx.",
        "tags": ["Transfers"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferRequestBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer request created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransferRequestResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listTransferRequests",
        "summary": "List transfer requests",
        "description": "Retrieve a list of transfer requests with optional pagination.",
        "tags": ["Transfers"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Page number for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "List of transfer requests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transfer_request/{transfer_token}": {
      "get": {
        "operationId": "getTransferRequest",
        "summary": "Get a transfer request",
        "description": "Retrieve details of a specific transfer request by its token.",
        "tags": ["Transfers"],
        "parameters": [
          {
            "name": "transfer_token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Token referencing the transfer request"
          }
        ],
        "responses": {
          "200": {
            "description": "Transfer request details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/direct_transfer": {
      "post": {
        "operationId": "createDirectTransfer",
        "summary": "Create a direct transfer",
        "description": "Programmatic transfer of a prescription from your pharmacy to FuzeRx pharmacy.",
        "tags": ["Direct Transfers"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DirectTransferRequest"
