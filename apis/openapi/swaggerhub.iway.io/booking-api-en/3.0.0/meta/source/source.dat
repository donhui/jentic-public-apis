                                  "lat": {
                                    "description": "LAT coordinate",
                                    "type": "string",
                                    "example": 55.012599945068
                                  },
                                  "lon": {
                                    "description": "LON coordinate",
                                    "type": "string",
                                    "example": 82.650703430176
                                  }
                                }
                              }
                            }
                          },
                          "description": {
                            "description": "Description (title)",
                            "type": "string",
                            "example": "Airport Tolmachevo"
                          },
                          "place_id": {
                            "description": "Google place ID",
                            "type": "string",
                            "example": "ChIJJQMqy2UJ4EIRLlTJkaXKslM"
                          },
                          "structured_formatting": {
                            "title": "Structural formatting",
                            "type": "object",
                            "properties": {
                              "main_text": {
                                "description": "Object's name",
                                "type": "string",
                                "example": "Airport Tolmachevo"
                              },
                              "secondary_text": {
                                "description": "Additional information",
                                "type": "string",
                                "example": ""
                              }
                            }
                          },
                          "country": {
                            "description": "Country",
                            "type": "string",
                            "example": ""
                          },
                          "types": {
                            "description": "Location types",
                            "type": "array",
                            "items": {
                              "example": "airport, establishment"
                            }
                          },
                          "iata": {
                            "description": "IATA code",
                            "type": "string",
                            "example": "OVB"
                          },
                          "icao": {
                            "description": "ICAO code",
                            "type": "string",
                            "example": "UNNT"
                          }
                        }
                      }
                    },
                    "error": {
                      "type": "string",
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request."
          },
          "404": {
            "description": "Page Not Found."
          },
          "5XX": {
            "description": "Internal Server Error."
          }
        }
      }
    },
    "/v3/orders/documents/send/{transaction}": {
