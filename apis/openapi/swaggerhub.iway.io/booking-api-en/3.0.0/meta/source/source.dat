    "/v3/orders/recommended-time": {
      "get": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "tags": [
          "order"
        ],
        "summary": "Recommended car delivery time",
        "operationId": "getRecommendedTime",
        "parameters": [
          {
            "in": "query",
            "name": "lang",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/lang"
            }
          },
          {
            "in": "query",
            "name": "user_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/user_id"
            }
          },
          {
            "in": "query",
            "name": "price_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/price_id"
            }
          },
          {
            "in": "query",
            "name": "departure_time",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/departure_time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "recommended_time": {
                          "description": "Recommended car delivery time",
                          "type": "string",
                          "example": "2021-09-12T09:50:00+07:00"
                        },
                        "min_allowed_time_order": {
                          "description": "The shortest possible pick-up time",
                          "type": "string",
                          "example": "2021-11-12T15:30:06+07:00"
                        },
                        "recommended_check_in_time": {
                          "description": "Recommended time for registration",
                          "type": "integer",
                          "example": 7200
                        },
                        "start_time_zone_code": {
                          "description": "Time shift from UTC in departure point",
                          "type": "string",
                          "example": "+07:00"
                        },
                        "finish_time_zone_zode": {
                          "description": "Time shift from UTC in arrival point",
                          "type": "string",
                          "example": "+07:00"
                        },
                        "travel_time": {
                          "description": "Trip time",
                          "type": "integer",
                          "example": 7200
                        }
                      }
                    },
                    "error": {
                      "type": "string",
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request."
          },
          "404": {
            "description": "Page Not Found."
          },
          "5XX": {
            "description": "Internal Server Error."
          }
        }
      }
    },
    "/v3/orders/check-time": {
      "post": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "tags": [
          "order"
        ],
        "summary": "Checking the possibility of placing an order for a specified time",
        "operationId": "getCheckTime",
        "parameters": [
          {
            "in": "query",
            "name": "lang",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/lang"
            }
          },
          {
            "in": "query",
            "name": "user_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/user_id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "price_id": {
                    "$ref": "#/components/schemas/price_id"
                  },
                  "pickup_time": {
                    "$ref": "#/components/schemas/pickup_time"
                  },
                  "departure_time": {
                    "$ref": "#/components/schemas/departure_time"
                  },
                  "start_place_id (required in case of ordering Rent with driver)": {
                    "$ref": "#/components/schemas/start_place_id"
                  }
                },
                "required": [
                  "price_id",
                  "pickup_time"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "allow booking": {
                          "description": "Flag showing whether booking is possible",
                          "type": "boolean",
                          "example": true
                        },
                        "notice": {
                          "description": "Notice",
                          "type": "string",
                          "example": ""
                        },
                        "similar_orders": {
                          "description": "Similar partner's trips within a time period",
                          "type": "object",
                          "example": null
                        },
                        "possible_connecting_time": {
                          "description": "The departure time of either aircraft or train does not meet the conditions",
                          "type": "boolean",
                          "example": true
                        },
                        "possible_pickup_time": {
                          "description": "Car delivery time does not meet the conditions",
                          "type": "boolean",
                          "example": true
                        },
                        "min_allowed_time_order": {
                          "description": "The minimum possible car delivery time in the time zone of the departure point (the nearest time of car delivery)",
                          "type": "string",
                          "example": "2021-11-12T15:41:03+07:00"
                        },
                        "min_connecting_time": {
                          "description": "The minimum possible departure time of either aircraft or train (in case of a constant car delivery time)",
                          "type": "string",
                          "example": "22021-12-25T14:00:00+07:00"
                        }
                      }
                    },
                    "error": {
                      "type": "object",
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request."
          },
          "404": {
            "description": "Page Not Found."
          },
          "5XX": {
            "description": "Internal Server Error."
          }
        }
      }
    },
