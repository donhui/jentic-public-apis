                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "enum": [
                                  1,
                                  2,
                                  3
                                ]
                              },
                              "title": {
                                "type": "integer"
                              },
                              "value": {
                                "type": "integer"
                              }
                            }
                          },
                          "id_custom_price": {
                            "type": "integer",
                            "example": null
                          },
                          "minimum_duration": {
                            "type": "integer",
                            "example": 0
                          },
                          "start_place": {
                            "$ref": "#/components/schemas/place_object"
                          },
                          "finish_place": {
                            "$ref": "#/components/schemas/place_object"
                          },
                          "flexible_tariff": {
                            "$ref": "#/components/schemas/flexible_tariff"
                          },
                          "flexible_tariff_agreement": {
                            "$ref": "#/components/schemas/flexible_tariff_agreement"
                          },
                          "additional_services": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "title": "ID Pricing additional service",
                                "type": "number",
                                "example": 25
                              },
                              "additional_service_id": {
                                "title": "Service ID extra",
                                "type": "number",
                                "example": 1
                              },
                              "price": {
                                "title": "Price in Price-Currency",
                                "type": "number",
                                "example": "RUB"
                              },
                              "name": {
                                "title": "Name of additional service",
                                "type": "string",
                                "example": "Plate"
                              },
                              "uid": {
                                "title": "Unique identifier in 1C pricing",
                                "type": "string",
                                "example": "hgds-jrm9-56vgk-gr3h"
                              },
                              "default_include": {
                                "title": "Is the service included in the price by default?",
                                "type": "boolean",
                                "example": false
                              },
                              "slug": {
                                "title": "Language tag extra service",
                                "type": "string",
                                "example": "trans.table"
                              },
                              "type": {
                                "title": "Type of additional service",
                                "type": "string",
                                "example": "table"
                              },
                              "category": {
                                "title": "Additional service category",
                                "type": "string",
                                "example": "flexible_tariff"
                              }
