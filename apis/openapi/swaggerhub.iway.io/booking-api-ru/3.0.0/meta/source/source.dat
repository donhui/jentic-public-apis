                          "description": "\u041f\u0440\u0438\u043c\u0435\u0447\u0430\u043d\u0438\u0435",
                          "type": "string",
                          "example": ""
                        },
                        "similar_orders": {
                          "description": "\u041f\u043e\u0445\u043e\u0436\u0438\u0435 \u043f\u043e\u0435\u0437\u0434\u043a\u0438 \u0443 \u043f\u0430\u0440\u0442\u043d\u0435\u0440\u0430 \u0432 \u043f\u0440\u043e\u043c\u0435\u0436\u0443\u0442\u043a\u0435 \u0432\u0440\u0435\u043c\u0435\u043d\u0438",
                          "type": "object",
                          "example": null
                        },
                        "possible_connecting_time": {
                          "description": "\u0412\u0440\u0435\u043c\u044f \u0432\u044b\u043b\u0435\u0442\u0430 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u0430 \u0438\u043b\u0438 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u043f\u043e\u0435\u0437\u0434\u0430 \u043d\u0435 \u0443\u0434\u043e\u0432\u043b\u0435\u0442\u0432\u043e\u0440\u044f\u0435\u0442 \u0443\u0441\u043b\u043e\u0432\u0438\u044f\u043c",
                          "type": "boolean",
                          "example": true
