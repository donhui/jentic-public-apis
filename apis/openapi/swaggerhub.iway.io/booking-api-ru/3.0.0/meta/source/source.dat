        "example": 1
      },
      "location_object": {
        "title": "\u0422\u043e\u0447\u043a\u0430 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u0430",
        "type": "object",
        "properties": {
          "place_id": {
            "description": "\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0442\u043e\u0447\u043a\u0438 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u0430 \u0438\u0437 \u043f\u043e\u0438\u0441\u043a\u043e\u0432\u043e\u0439 \u0441\u0438\u0441\u0442\u0435\u043c\u044b Google Maps",
            "type": "string",
            "example": "ChIJybDUc_xKtUYRTM9XV8zWRD0"
          },
          "flight_number": {
            "description": "\u041d\u043e\u043c\u0435\u0440 \u0430\u0432\u0438\u0430\u0440\u0435\u0439\u0441\u0430, \u0435\u0441\u043b\u0438 \u043c\u0435\u0441\u0442\u043e \u043d\u0430\u0447\u0430\u043b\u0430 \u043f\u043e\u0435\u0437\u0434\u043a\u0438 \u0430\u044d\u0440\u043e\u043f\u043e\u0440\u0442",
            "type": "string",
            "example": "TS-12"
          },
          "terminal_number": {
            "description": "\u041d\u043e\u043c\u0435\u0440 \u0442\u0435\u0440\u043c\u0438\u043d\u0430\u043b\u0430 \u0430\u044d\u0440\u043e\u043f\u043e\u0440\u0442\u0430, \u0435\u0441\u043b\u0438 \u043c\u0435\u0441\u0442\u043e \u043d\u0430\u0447\u0430\u043b\u0430 \u0438\u043b\u0438 \u043e\u043a\u043e\u043d\u0447\u0430\u043d\u0438\u044f \u043f\u043e\u0435\u0437\u0434\u043a\u0438 \u0430\u044d\u0440\u043e\u043f\u043e\u0440\u0442",
            "type": "string",
            "example": "TS-41"
          },
          "train_number": {
            "description": "\u041d\u043e\u043c\u0435\u0440 \u043f\u043e\u0435\u0437\u0434\u0430, \u0435\u0441\u043b\u0438 \u043c\u0435\u0441\u0442\u043e \u043d\u0430\u0447\u0430\u043b\u0430 \u043f\u043e\u0435\u0437\u0434\u043a\u0438 \u0436/\u0434 \u0432\u043e\u043a\u0437\u0430\u043b",
            "type": "string",
            "example": "TS-1352"
          },
          "train_carriage_number": {
            "description": "\u041d\u043e\u043c\u0435\u0440 \u0432\u0430\u0433\u043e\u043d\u0430 \u043f\u043e\u0435\u0437\u0434\u0430, \u0435\u0441\u043b\u0438 \u043c\u0435\u0441\u0442\u043e \u043d\u0430\u0447\u0430\u043b\u0430 \u043f\u043e\u0435\u0437\u0434\u043a\u0438 \u0436/\u0434 \u0432\u043e\u043a\u0437\u0430\u043b",
            "type": "string",
            "example": "TS-4"
          },
          "address": {
            "description": "\u0410\u0434\u0440\u0435\u0441 \u043c\u0435\u0441\u0442\u0430",
            "type": "string",
            "example": "\u041d\u043e\u0432\u043e\u0441\u0438\u0431\u0438\u0440\u0441\u043a"
          },
          "location": {
            "description": "\u041a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0442\u044b \u043c\u0435\u0441\u0442\u0430",
            "type": "string",
            "example": "55.00835259999999,82.9357327"
          },
          "time": {
            "description": "\u0412\u0440\u0435\u043c\u044f \u043f\u0440\u0438\u043b\u0435\u0442\u0430/\u0432\u044b\u043b\u0435\u0442\u0430 \u0441\u0430\u043c\u043e\u043b\u0435\u0442\u0430, \u043f\u0440\u0438\u0431\u044b\u0442\u0438\u044f/\u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u043f\u043e\u0435\u0437\u0434\u0430 \u0438\u043b\u0438 \u043f\u043e\u0434\u0430\u0447\u0438 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044f. \u0417\u0430\u0432\u0438\u0441\u0438\u0442 \u043e\u0442 \u0442\u0438\u043f\u0430 \u043c\u0435\u0441\u0442\u0430 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f/\u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f",
            "type": "string",
            "format": "date-time",
            "example": "2020-05-30 00:00"
          }
        }
      },
      "place_object": {
        "title": "\u0422\u043e\u0447\u043a\u0430 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u0430",
        "type": "object",
        "properties": {
          "place_id": {
            "title": "ID \u043c\u0435\u0441\u0442\u0430",
            "type": "integer",
            "example": 9
          },
          "title": {
            "title": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043c\u0435\u0441\u0442\u0430",
            "type": "string",
            "example": "\u041d\u043e\u0432\u043e\u0441\u0438\u0431\u0438\u0440\u0441\u043a"
          },
          "type": {
            "title": "\u0422\u0438\u043f \u043c\u0435\u0441\u0442\u0430",
            "type": "integer",
            "description": "`1` - \u0412 \u0447\u0435\u0440\u0442\u0435 \u0433\u043e\u0440\u043e\u0434\u0430\n`2` - \u0410\u044d\u0440\u043e\u043f\u043e\u0440\u0442\n`3` - \u0416/\u0434 \u0432\u043e\u043a\u0437\u0430\u043b\n`4` - \u0412\u0431\u043b\u0438\u0437\u0438 \u0433\u043e\u0440\u043e\u0434\u0430\n`5` - \u041d\u0430\u0441\u0435\u043b\u0435\u043d\u043d\u044b\u0439 \u043f\u0443\u043d\u043a\u0442\n`6` - \u041f\u0440\u043e\u0447\u0435\u0435\n`7` - \u0412 \u043f\u0440\u0435\u0434\u0435\u043b\u0430\u0445 \u041c\u041a\u0410\u0414\n`8` - \u0412 \u043f\u0440\u0435\u0434\u0435\u043b\u0430\u0445 \u041a\u0410\u0414\n`9` - \u0426\u0435\u043d\u0442\u0440 \u0433\u043e\u0440\u043e\u0434\u0430\n`10` - \u041e\u0442\u0435\u043b\u044c\n",
            "example": 1
          },
          "type_title": {
            "title": "\u041d\u0430\u0432\u0430\u043d\u0438\u0435 \u0442\u0438\u043f\u0430 \u043c\u0435\u0441\u0442\u0430",
            "type": "string",
            "example": "\u0432 \u0447\u0435\u0440\u0442\u0435 \u0433\u043e\u0440\u043e\u0434\u0430"
          },
          "terminal": {
            "title": "\u0422\u0435\u0440\u043c\u0438\u043d\u0430\u043b\u044b",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "declension_titles": {
            "title": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u0432 \u0440\u0430\u0437\u043d\u044b\u0445 \u0441\u043a\u043b\u043e\u043d\u0435\u043d\u0438\u044f\u0445",
