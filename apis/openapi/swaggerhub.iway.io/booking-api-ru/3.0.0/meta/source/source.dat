        "type": "string",
        "example": "l73q8272rg.png"
      },
      "capacity": {
        "title": "\u0412\u043c\u0435\u0441\u0442\u0438\u043c\u043e\u0441\u0442\u044c \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044f",
        "type": "integer",
