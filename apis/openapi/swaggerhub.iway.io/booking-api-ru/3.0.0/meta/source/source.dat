          },
          "send_params": {
            "title": "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u0443\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u0438\u0439",
            "type": "object",
            "properties": {
              "send_client_voucher": {
                "description": "\u041e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0442\u044c \u0432\u0430\u0443\u0447\u0435\u0440 \u043f\u0430\u0441\u0441\u0430\u0436\u0438\u0440\u0443",
