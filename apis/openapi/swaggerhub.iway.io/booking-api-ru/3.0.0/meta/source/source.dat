  "paths": {
    "/v3/auth/login": {
      "post": {
        "security": [],
        "tags": [
          "user"
        ],
        "summary": "\u0410\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u044f \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f \u0432 \u0441\u0438\u0441\u0442\u0435\u043c\u0435 \u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f i'way transfer",
        "operationId": "authUser",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": {
                    "$ref": "#/components/schemas/user_id"
                  },
                  "password": {
                    "$ref": "#/components/schemas/password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "title": "\u0422\u043e\u043a\u0435\u043d \u0430\u0443\u0442\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438",
                          "type": "string",
                          "example": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpYXQiOjE1MjYwMTYwMTcsImV4cCI6MTUyNjYyMDgxNywidXNlciI6eyJpZCI6IjY2NiJ9fQ.-CY39UWl9jT-CkeYDkNp7dbbr4ubECc4JEjzyGnLqKw"
                        }
                      }
                    },
                    "error": {
                      "type": "object",
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request."
          },
          "404": {
            "description": "Page Not Found."
          },
          "5XX": {
            "description": "Internal Server Error."
          }
        }
      }
    },
    "/v3/transport-nodes": {
      "get": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "tags": [
          "transport node"
        ],
        "summary": "\u041f\u043e\u0438\u0441\u043a \u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u043d\u044b\u0445 \u0443\u0437\u043b\u043e\u0432",
        "operationId": "getTransportNode",
        "parameters": [
          {
            "in": "query",
            "name": "lang",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/lang"
            }
          },
          {
            "in": "query",
            "name": "user_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/user_id"
            }
          },
          {
            "in": "query",
            "name": "term",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/term"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "array",
                      "items": {
                        "title": "\u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u043d\u044b\u0439 \u0443\u0437\u0435\u043b",
                        "type": "object",
                        "properties": {
                          "formatted_address": {
                            "description": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435",
                            "type": "string",
                            "example": "\u0410\u044d\u0440\u043e\u043f\u043e\u0440\u0442 \u0422\u043e\u043b\u043c\u0430\u0447\u0435\u0432\u043e"
                          },
                          "geometry": {
                            "title": "\u0414\u0430\u043d\u043d\u044b\u0435 geo",
                            "type": "object",
                            "properties": {
                              "location": {
                                "title": "\u041b\u043e\u043a\u0430\u0446\u0438\u044f",
                                "type": "object",
                                "properties": {
                                  "lat": {
                                    "description": "\u041a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0442\u0430 LAT",
                                    "type": "string",
                                    "example": 55.012599945068
                                  },
                                  "lon": {
                                    "description": "\u041a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0442\u0430 LON",
                                    "type": "string",
                                    "example": 82.650703430176
                                  }
                                }
                              }
                            }
                          },
                          "description": {
                            "description": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 (\u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435)",
                            "type": "string",
                            "example": "\u0410\u044d\u0440\u043e\u043f\u043e\u0440\u0442 \u0422\u043e\u043b\u043c\u0430\u0447\u0435\u0432\u043e"
                          },
                          "place_id": {
                            "description": "Google ID \u043c\u0435\u0441\u0442\u0430",
                            "type": "string",
                            "example": "ChIJJQMqy2UJ4EIRLlTJkaXKslM"
                          },
                          "structured_formatting": {
                            "title": "\u0421\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u043d\u043e\u0435 \u0444\u043e\u0440\u043c\u0430\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435",
                            "type": "object",
                            "properties": {
                              "main_text": {
                                "description": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043e\u0431\u044a\u0435\u043a\u0442\u0430",
                                "type": "string",
                                "example": "\u0410\u044d\u0440\u043e\u043f\u043e\u0440\u0442 \u0422\u043e\u043b\u043c\u0430\u0447\u0435\u0432\u043e"
                              },
                              "secondary_text": {
                                "description": "\u0414\u043e\u043f. \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f",
                                "type": "string",
                                "example": ""
                              }
                            }
                          },
                          "country": {
                            "description": "\u0421\u0442\u0440\u0430\u043d\u0430",
                            "type": "string",
                            "example": ""
                          },
                          "types": {
                            "description": "\u0422\u0438\u043f\u044b \u043c\u0435\u0441\u0442\u0430",
                            "type": "array",
                            "items": {
                              "example": "airport, establishment"
                            }
                          },
                          "iata": {
                            "description": "\u041a\u043e\u0434 IATA",
                            "type": "string",
                            "example": "OVB"
                          },
                          "icao": {
                            "description": "\u041a\u043e\u0434 ICAO",
                            "type": "string",
                            "example": "UNNT"
                          }
                        }
                      }
                    },
                    "error": {
                      "type": "string",
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request."
          },
          "404": {
            "description": "Page Not Found."
          },
          "5XX": {
            "description": "Internal Server Error."
          }
        }
      }
    },
    "/v3/prices": {
      "get": {
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "tags": [
          "price"
        ],
        "summary": "\u041f\u043e\u043b\u0443\u0447\u0435\u043d\u0438\u0435 \u0441\u043f\u0438\u0441\u043a\u0430 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0439 \u043f\u043e \u0443\u0441\u043b\u0443\u0433\u0435 \"\u0422\u0440\u0430\u043d\u0441\u0444\u0435\u0440\"",
        "operationId": "getTransferPriceList",
        "parameters": [
          {
            "in": "query",
            "name": "user_id",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/user_id"
            }
          },
          {
            "in": "query",
            "name": "lang",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/lang"
            }
          },
          {
            "in": "query",
            "name": "currency",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/currency"
            }
          },
          {
            "in": "query",
            "name": "start_place_point",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/place_point"
            }
          },
          {
            "in": "query",
            "name": "finish_place_point",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/place_point"
            }
          },
          {
            "in": "query",
            "name": "relation_car_class_ids",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/relation_car_class_ids"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "array",
                      "items": {
                        "title": "\u0426\u0435\u043d\u043e\u0432\u043e\u0435 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0435",
                        "type": "object",
                        "properties": {
                          "price_uid": {
                            "$ref": "#/components/schemas/price_uuid"
                          },
                          "price_id": {
                            "$ref": "#/components/schemas/price_id"
                          },
                          "price": {
                            "$ref": "#/components/schemas/price"
                          },
                          "price_rub": {
                            "$ref": "#/components/schemas/price"
                          },
                          "reverse_price": {
                            "$ref": "#/components/schemas/reverse_price_object"
                          },
                          "currency": {
                            "$ref": "#/components/schemas/currency"
                          },
                          "service_id": {
                            "$ref": "#/components/schemas/service_id"
                          },
                          "car_class": {
                            "$ref": "#/components/schemas/car_class_object"
                          },
                          "allowable_subaddress": {
                            "title": "\u0420\u0430\u0437\u0440\u0435\u0448\u0435\u043d\u043d\u043e\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u0430\u0434\u0440\u0435\u0441\u043e\u0432",
                            "type": "integer",
                            "example": 3
                          },
                          "price_subaddress": {
                            "title": "\u0426\u0435\u043d\u0430 \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u043f\u043e\u0435\u0437\u0434\u043e\u043a",
                            "type": "number",
                            "example": 270
                          },
                          "cancellation_time": {
                            "title": "\u041c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f \u0434\u043b\u044f \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e\u0439 \u043e\u0442\u043c\u0435\u043d\u044b \u043f\u043e\u0435\u0437\u0434\u043a\u0438",
                            "type": "integer",
                            "example": 2
                          },
                          "type": {
                            "$ref": "#/components/schemas/type"
                          },
                          "payed_road": {
                            "title": "\u041f\u043b\u0430\u0442\u043d\u0430\u044f \u0434\u043e\u0440\u043e\u0433\u0430",
                            "type": "boolean",
                            "example": false
                          },
                          "blackout_date": {
                            "title": "\u041c\u0430\u0441\u0441\u0438\u0432 \u0434\u0430\u0442, \u0437\u0430\u043a\u0440\u044b\u0442\u044b\u0445 \u0434\u043b\u044f \u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f",
                            "type": "array",
                            "items": {
                              "type": "string",
                              "format": "date"
                            }
                          },
                          "allowable_time": {
                            "title": "\u041c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u043e \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f \u0434\u043b\u044f \u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u043f\u043e\u0435\u0437\u0434\u043a\u0438",
                            "type": "integer",
                            "example": 2
                          },
                          "id_custom_price": {
                            "title": "ID \u0431\u0430\u0437\u043e\u0432\u043e\u0439 \u0446\u0435\u043d\u044b",
                            "type": "integer",
                            "example": null
                          },
                          "minimum_duration": {
                            "title": "\u041c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f \u0430\u0440\u0435\u043d\u0434\u044b",
