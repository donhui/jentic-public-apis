          "default_include": {
            "title": "\u0412\u043a\u043b\u044e\u0447\u0435\u043d\u0430 \u043b\u0438 \u0443\u0441\u043b\u0443\u0433\u0430 \u0432 \u043f\u0440\u0430\u0439\u0441 \u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e",
            "type": "boolean",
            "example": false
