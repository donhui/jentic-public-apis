  "components": {
    "schemas": {
      "user_id": {
        "title": "\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f",
        "type": "integer",
        "example": 1863
      },
      "pickup_time": {
        "title": "\u0414\u0430\u0442\u0430 \u0438 \u0432\u0440\u0435\u043c\u044f \u043f\u043e\u0434\u0430\u0447\u0438 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044f",
        "type": "string",
        "example": "2021-08-21 12:00"
      },
      "start_place_id": {
        "title": "\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0442\u043e\u0447\u043a\u0438 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f (\u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u0435\u043d \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u0440\u0438 \u0437\u0430\u043a\u0430\u0437\u0435 \u0430\u0440\u0435\u043d\u0434\u044b)",
        "type": "integer",
        "example": 135
      },
      "password": {
        "title": "\u041f\u0430\u0440\u043e\u043b\u044c \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044f",
        "type": "string",
        "format": "password",
        "example": "1830Voldemort"
      },
      "transaction": {
        "title": "\u0423\u043d\u0438\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u0438\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0437\u0430\u043a\u0430\u0437\u0430. \u041e\u0431\u0449\u0438\u0439 \u0434\u043b\u044f \u0437\u0430\u043a\u0430\u0437\u0430 \u0438\u0437 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u0438\u0445 \u043f\u043e\u0435\u0437\u0434\u043e\u043a (\u043f\u043b\u0430\u0442\u0435\u0436\u043d\u0430\u044f \u0442\u0440\u0430\u043d\u0437\u0430\u043a\u0446\u0438\u044f)",
        "type": "integer",
        "example": 14565973
      },
      "pos": {
        "title": "\u0422\u043e\u0447\u043a\u0430 \u043f\u0440\u043e\u0434\u0430\u0436\u0438",
        "type": "string",
        "example": "\u0422\u0435\u0440\u043c\u0438\u043d\u0430\u043b \u043a\u0430\u0441\u0441\u044b S7 \u211614373"
      },
      "lang": {
        "title": "\u041b\u043e\u043a\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f \u043e\u0436\u0438\u0434\u0430\u0435\u043c\u043e\u0433\u043e \u043e\u0442\u0432\u0435\u0442\u0430",
        "description": "\u041b\u043e\u043a\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f \u043e\u0436\u0438\u0434\u0430\u0435\u043c\u043e\u0433\u043e \u043e\u0442\u0432\u0435\u0442\u0430\n`ru` - \u0420\u0443\u0441\u0441\u043a\u0438\u0439\n`en` - \u0410\u043d\u0433\u043b\u0438\u0439\u0441\u043a\u0438\u0439\n",
        "type": "string",
        "enum": [
          "ru",
          "en"
        ],
        "example": "ru",
        "default": "ru"
      },
      "currency": {
        "title": "\u0412\u0430\u043b\u044e\u0442\u0430 \u0446\u0435\u043d\u043e\u0432\u043e\u0433\u043e \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f",
        "description": "\u0412\u0430\u043b\u044e\u0442\u0430 \u0446\u0435\u043d\u043e\u0432\u043e\u0433\u043e \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f\n`RUB` - \u0420\u043e\u0441\u0441\u0438\u0439\u0441\u043a\u0438\u0439 \u0420\u0443\u0431\u043b\u044c\n`EUR` - \u0415\u0432\u0440\u043e\n`USD` - \u0410\u043c\u0435\u0440\u0438\u043a\u0430\u043d\u0441\u043a\u0438\u0439 \u0414\u043e\u043b\u043b\u0430\u0440\n`CNY` - \u042e\u0430\u043d\u044c \u0420\u0435\u043d\u043c\u0438\u043d\u0431\u0438\n`CZK` - \u0427\u0435\u0448\u0441\u043a\u0430\u044f \u041a\u0440\u043e\u043d\u0430\n`GBP` - \u0424\u0443\u043d\u0442 \u0421\u0442\u0435\u0440\u043b\u0438\u043d\u0433\u043e\u0432\n`INR` - \u0418\u043d\u0434\u0438\u0439\u0441\u043a\u0430\u044f \u0420\u0443\u043f\u0438\u044f\n`KZT` - \u0422\u0435\u043d\u0433\u0435\n`SGD` - \u0421\u0438\u043d\u0433\u0430\u043f\u0443\u0440\u0441\u043a\u0438\u0439 \u0414\u043e\u043b\u043b\u0430\u0440\n`TRY` - \u0422\u0443\u0440\u0435\u0446\u043a\u0430\u044f \u041b\u0438\u0440\u0430\n`UAH` - \u0413\u0440\u0438\u0432\u043d\u0430\n`ZAR` - \u0420\u044d\u043d\u0434\n`BYN` - \u0411\u0435\u043b\u043e\u0440\u0443\u0441\u0441\u043a\u0438\u0439 \u0440\u0443\u0431\u043b\u044c\n",
        "type": "string",
        "enum": [
          "RUB",
          "EUR",
          "USD",
          "CNY",
          "CZK",
          "GBP",
          "INR",
          "KZT",
          "SGD",
          "TRY",
          "UAH",
          "ZAR",
          "BYN"
        ],
        "example": "RUB",
        "default": "RUB"
      },
      "place_point": {
        "title": "\u041a\u043e\u043e\u0440\u0434\u0438\u043d\u0430\u0442\u044b \u0442\u043e\u0447\u043a\u0438 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u0430",
        "type": "string",
        "example": "55.00835259999999,82.9357327"
      },
      "relation_car_class_ids": {
        "title": "\u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043d\u044b\u0435 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f",
        "type": "array",
        "items": {
          "type": "integer",
          "enum": [
            34,
            35
          ]
        }
      },
      "duration": {
        "title": "\u041f\u0440\u043e\u0434\u043e\u043b\u0436\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u0430\u0440\u0435\u043d\u0434\u044b \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044f (\u0432 \u0441\u0435\u043a\u0443\u043d\u0434\u0430\u0445)",
        "type": "integer",
        "example": 3600
      },
      "additional_change_itinerary": {
        "title": "\u0414\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0437\u0430\u0435\u0437\u0434\u044b/\u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0435 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u043e\u0432",
        "description": "\u0414\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0437\u0430\u0435\u0437\u0434\u044b/\u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0435 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u043e\u0432\n`1` - \u041d\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0441\u043e\u0433\u043b\u0430\u0441\u043e\u0432\u0430\u043d\u0438\u044f\n`2` - \u0422\u0440\u0435\u0431\u0443\u0435\u0442 \u0441\u043e\u0433\u043b\u0430\u0441\u043e\u0432\u0430\u043d\u0438\u044f\n`3` - \u0417\u0430\u043f\u0440\u0435\u0449\u0435\u043d\u043e\n",
        "type": "integer",
        "enum": [
          1,
          2,
          3
        ],
        "example": 1
      },
      "additional_wait": {
        "title": "\u0414\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u043e\u0436\u0438\u0434\u0430\u043d\u0438\u0435",
        "description": "\u0414\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0435 \u043e\u0436\u0438\u0434\u0430\u043d\u0438\u0435\n`1` - \u041d\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0441\u043e\u0433\u043b\u0430\u0441\u043e\u0432\u0430\u043d\u0438\u044f\n`2` - \u0422\u0440\u0435\u0431\u0443\u0435\u0442 \u0441\u043e\u0433\u043b\u0430\u0441\u043e\u0432\u0430\u043d\u0438\u044f\n`3` - \u0417\u0430\u043f\u0440\u0435\u0449\u0435\u043d\u043e\n",
        "type": "integer",
        "enum": [
          1,
          2,
          3
        ],
        "example": 1
      },
      "fare_on_toll_road": {
        "title": "\u041f\u0440\u043e\u0435\u0437\u0434 \u043f\u043e \u043f\u043b\u0430\u0442\u043d\u043e\u0439 \u0434\u043e\u0440\u043e\u0433\u0435",
        "description": "\u041f\u0440\u043e\u0435\u0437\u0434 \u043f\u043e \u043f\u043b\u0430\u0442\u043d\u043e\u0439 \u0434\u043e\u0440\u043e\u0433\u0435\n`1` - \u041d\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0441\u043e\u0433\u043b\u0430\u0441\u043e\u0432\u0430\u043d\u0438\u044f\n`2` - \u0422\u0440\u0435\u0431\u0443\u0435\u0442 \u0441\u043e\u0433\u043b\u0430\u0441\u043e\u0432\u0430\u043d\u0438\u044f\n`3` - \u0417\u0430\u043f\u0440\u0435\u0449\u0435\u043d\u043e\n",
        "type": "integer",
        "enum": [
          1,
          2,
          3
        ],
        "example": 1
      },
      "flexible_tariff": {
        "title": "\u0424\u043b\u0430\u0433 \u0443\u0441\u043b\u0443\u0433\u0438 - \u0413\u0438\u0431\u043a\u0430\u044f \u0442\u0430\u0440\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u044f",
        "type": "boolean",
        "example": true
      },
      "flexible_tariff_agreement": {
        "title": "\u0424\u043b\u0430\u0433 \u043d\u0430\u043b\u0438\u0447\u0438\u044f \u0434\u043e\u0433\u043e\u0432\u043e\u0440\u0430 \u043f\u043e \u0443\u0441\u043b\u0443\u0433\u0435 - \u0413\u0438\u0431\u043a\u0430\u044f \u0442\u0430\u0440\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u044f",
        "type": "boolean",
        "example": true
      },
      "price_id": {
        "title": "\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f",
        "type": "integer",
        "example": 2921215
      },
      "trip_id": {
        "title": "\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u043f\u043e\u0435\u0437\u0434\u043a\u0438",
        "type": "integer",
        "example": null
      },
      "departure_time": {
        "title": "\u0412\u0440\u0435\u043c\u044f \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u043f\u043e\u0435\u0437\u0434\u0430 \u0438\u043b\u0438 \u0441\u0430\u043c\u043e\u043b\u0451\u0442\u0430",
        "type": "string",
        "example": "2021-08-21 12:00"
      },
      "passengers_number": {
        "title": "\u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u043f\u0430\u0441\u0441\u0430\u0436\u0438\u0440\u043e\u0432",
        "type": "integer",
        "example": 3
      },
      "text_tablet": {
        "title": "\u0422\u0435\u043a\u0441\u0442 \u0442\u0430\u0431\u043b\u0438\u0447\u043a\u0438",
        "type": "string",
        "example": "i'way \u0436\u0434\u0451\u0442 \u0442\u0435\u0431\u044f!"
      },
      "comment": {
        "title": "\u041a\u043e\u043c\u043c\u0435\u043d\u0442\u0430\u0440\u0438\u0439 \u043a \u0437\u0430\u043a\u0430\u0437\u0443",
        "type": "string",
        "example": "\u0412\u0441\u0442\u0440\u0435\u0442\u0438\u0442\u044c \u043d\u0430 \u0447\u0438\u0441\u0442\u043e\u043c \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u0435 \u0438 \u0432 \u043d\u0430\u0440\u044f\u0434\u043d\u043e\u043c \u043a\u043e\u0441\u0442\u044e\u043c\u0435"
      },
      "payable_status": {
        "title": "\u0421\u0442\u0430\u0442\u0443\u0441 \u043e\u043f\u043b\u0430\u0442\u044b \u0437\u0430\u043a\u0430\u0437\u0430",
        "description": "\u0421\u0442\u0430\u0442\u0443\u0441 \u043e\u043f\u043b\u0430\u0442\u044b \u0437\u0430\u043a\u0430\u0437\u0430\n`0` - \u041d\u0435 \u043e\u043f\u043b\u0430\u0447\u0435\u043d\u043e\n`1` - \u041e\u043f\u043b\u0430\u0447\u0435\u043d\u043e\n`5` - \u041e\u0442\u043c\u0435\u043d\u0435\u043d\u043e\n",
        "type": "integer",
        "enum": [
          0,
          1,
          5
        ],
        "example": 1
      },
      "service_id": {
        "title": "\u0422\u0438\u043f \u043f\u043e\u0435\u0437\u0434\u043a\u0438",
        "description": "\u0422\u0438\u043f \u043f\u043e\u0435\u0437\u0434\u043a\u0438\n`1` - \u0422\u0440\u0430\u043d\u0441\u0444\u0435\u0440\n`2` - \u0410\u0440\u0435\u043d\u0434\u0430 \u0441 \u0432\u043e\u0434\u0438\u0442\u0435\u043b\u0435\u043c\n",
        "type": "integer",
        "enum": [
          1,
          2
        ],
        "example": 1
      },
      "status": {
        "title": "\u0421\u0442\u0430\u0442\u0443\u0441 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438 \u043f\u043e\u0435\u0437\u0434\u043a\u0438",
        "description": "`0` - \u041e\u0436\u0438\u0434\u0430\u043d\u0438\u0435 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438\n`1` - \u041e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430\n`2` - \u041f\u0440\u0438\u043d\u044f\u0442\u0430\n`3` - \u0412\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0430\n`4` - \u041e\u0442\u043c\u0435\u043d\u0435\u043d\u0430 \u0431\u0435\u0437 \u0448\u0442\u0440\u0430\u0444\u0430\n`5` - \u041e\u0442\u043c\u0435\u043d\u0435\u043d\u0430 \u0441\u043e \u0448\u0442\u0440\u0430\u0444\u043e\u043c\n`6` - \u041d\u0435 \u043e\u043f\u043b\u0430\u0447\u0435\u043d\u0430\n`7` - \u0418\u0437\u043c\u0435\u043d\u0435\u043d\u0430\n",
        "type": "integer",
        "enum": [
          0,
          1,
          2,
          3,
          4,
          5,
          6,
          7
        ],
        "example": 0
      },
      "order_id": {
        "title": "\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0437\u0430\u043a\u0430\u0437\u0430 / \u043f\u043e\u0435\u0437\u0434\u043a\u0438",
        "type": "integer",
        "example": 4000172
      },
      "booker_number": {
        "title": "\u0412\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u0439 \u043d\u043e\u043c\u0435\u0440 \u0437\u0430\u043a\u0430\u0437\u0430 \u0432 \u0441\u0438\u0441\u0442\u0435\u043c\u0435 \u0443\u0447\u0435\u0442\u0430 i'way (1C)",
        "type": "string",
        "example": "C-0000062"
      },
      "price": {
        "title": "\u0421\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c \u043f\u043e\u0435\u0437\u0434\u043a\u0438",
        "type": "number",
