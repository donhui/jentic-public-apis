                          }
                        }
                      }
                    },
                    "error": {
                      "type": "object",
                      "example": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request."
          },
          "401": {
            "description": "Auth Error."
          },
          "404": {
            "description": "Page Not Found."
          },
