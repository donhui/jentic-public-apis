              "email": {
                "description": "\u0410\u0434\u0440\u0435\u0441 \u044d\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u043e\u0439 \u043f\u043e\u0447\u0442\u044b \u043c\u0435\u043d\u0435\u0434\u0436\u0435\u0440\u0430",
                "type": "string",
                "example": "iwaytest@gmail.com"
