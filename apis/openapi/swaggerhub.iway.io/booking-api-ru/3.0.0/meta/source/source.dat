      "price_uuid": {
        "title": "UUID \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f",
        "type": "string",
        "example": "704fecdc-d516-4cc5-bf61-5a74a37c7ba4"
      },
      "term": {
        "title": "\u0421\u0442\u0440\u043e\u043a\u0430 \u0434\u043b\u044f \u043f\u043e\u0438\u0441\u043a\u0430 \u043f\u043e\u0434\u0441\u043a\u0430\u0437\u043e\u043a \u043c\u0435\u0441\u0442",
        "type": "string",
        "example": "\u0410\u044d\u0440\u043e\u043f\u043e\u0440\u0442 \u0422\u043e\u043b\u043c\u0430\u0447\u0435\u0432\u043e"
      },
      "car_class_id": {
