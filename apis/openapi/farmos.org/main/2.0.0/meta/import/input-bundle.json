          "404": {
            "description": "Not found"
          }
        }
      },
      "patch": {
        "operationId": "updateLog",
        "summary": "Update a log entry",
        "description": "Update an existing log entry.",
        "tags": [
          "Logs"
        ],
        "parameters": [
          {
            "name": "bundle",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.api+json": {
              "schema": {
                "$ref": "#/components/schemas/JsonApiUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Log entry updated",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/JsonApiSingleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteLog",
        "summary": "Delete a log entry",
        "description": "Delete a log entry by UUID.",
        "tags": [
          "Logs"
        ],
        "parameters": [
          {
            "name": "bundle",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Log entry deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
