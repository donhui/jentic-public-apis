{
  "openapi": "3.0.3",
  "info": {
    "title": "farmOS API",
    "description": "REST API for farmOS, a web-based farm management platform. Built on Drupal's JSON:API module, it provides access to farm assets, logs, plans, and other resources using the JSON:API specification. All resources use UUIDs.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://farmos.org/development/api/"
  },
  "servers": [
    {
      "url": "https://{host}",
      "description": "farmOS instance",
      "variables": {
        "host": {
          "default": "your-farm.farmos.net",
          "description": "Your farmOS server hostname"
        }
      }
    }
  ],
  "paths": {
    "/api": {
      "get": {
        "operationId": "getApiRoot",
        "summary": "Get API root information",
        "description": "Returns meta information about the authenticated user and the farmOS server, including available resource types.",
        "tags": [
          "Meta"
        ],
        "responses": {
          "200": {
            "description": "API root metadata",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiRoot"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/schema": {
      "get": {
        "operationId": "getApiSchema",
        "summary": "Get API schema",
        "description": "Returns a JSON Schema describing all available API resources, their fields, and relationships.",
        "tags": [
          "Meta"
        ],
        "responses": {
          "200": {
            "description": "JSON Schema of available resources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/log/{bundle}": {
      "get": {
        "operationId": "listLogs",
        "summary": "List log entries",
        "description": "Retrieve a list of log entries of the specified bundle type (e.g., activity, observation, harvest, seeding, input, maintenance).",
        "tags": [
          "Logs"
        ],
        "parameters": [
          {
            "name": "bundle",
            "in": "path",
            "required": true,
            "description": "Log bundle type",
            "schema": {
              "type": "string",
              "enum": [
                "activity",
                "observation",
                "harvest",
                "seeding",
                "input",
                "maintenance",
                "medical",
                "transplanting"
              ]
            }
          },
          {
            "$ref": "#/components/parameters/FilterParam"
          },
          {
            "$ref": "#/components/parameters/SortParam"
          },
          {
            "$ref": "#/components/parameters/PageLimit"
          },
          {
            "$ref": "#/components/parameters/PageOffset"
          },
          {
            "$ref": "#/components/parameters/Include"
          }
        ],
        "responses": {
          "200": {
            "description": "List of log entries",
            "content": {
              "application/vnd.api+json": {
                "schema": {
                  "$ref": "#/components/schemas/JsonApiListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createLog",
        "summary": "Create a log entry",
        "description": "Create a new log entry of the specified bundle type.",
        "tags": [
          "Logs"
        ],
        "parameters": [
          {
            "name": "bundle",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "activity",
                "observation",
                "harvest",
                "seeding",
                "input",
                "maintenance",
                "medical",
                "transplanting"
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.api+json": {
              "schema": {
                "$ref": "#/components/schemas/JsonApiCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Log entry created",
