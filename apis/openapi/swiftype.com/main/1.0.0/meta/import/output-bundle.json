{
  "openapi": "3.0.3",
  "info": {
    "title": "Swiftype Site Search API",
    "version": "1.0.0",
    "description": "Swiftype Site Search API provides search and autocomplete functionality for websites and applications.",
    "x-jentic-source-url": "https://swiftype.com/documentation/overview"
  },
  "servers": [
    {
      "url": "https://search-api.swiftype.com/api/v1"
    }
  ],
  "paths": {
    "/public/engines/search.json": {
      "post": {
        "operationId": "publicsearch",
        "summary": "Search an engine using the public API",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PublicSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid engine key"
          }
        }
      },
      "get": {
        "operationId": "publicsearchget",
        "summary": "Search an engine using the public API (GET)",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "engine_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Engine Key credential"
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Query string"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Page number for pagination"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid engine key"
          }
        }
      }
    },
    "/public/engines/suggest.json": {
      "post": {
        "operationId": "publicautocomplete",
        "summary": "Autocomplete suggestions for an engine",
        "tags": [
          "Autocomplete"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AutocompleteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Autocomplete suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AutocompleteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid engine key"
          }
        }
      },
      "get": {
        "operationId": "publicautocompleteget",
        "summary": "Autocomplete suggestions for an engine (GET)",
        "tags": [
          "Autocomplete"
        ],
        "parameters": [
          {
            "name": "engine_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Engine Key credential"
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Prefix query string"
          },
          {
            "name": "document_types",
            "in": "query",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Specific document types to search"
          }
        ],
        "responses": {
          "200": {
            "description": "Autocomplete suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AutocompleteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid engine key"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PublicSearchRequest": {
        "type": "object",
        "required": [
          "engine_key",
          "q"
        ],
        "properties": {
          "engine_key": {
            "type": "string",
            "description": "Engine Key credential"
          },
          "q": {
            "type": "string",
            "description": "Query string"
          },
          "document_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Document type filters"
          },
          "page": {
            "type": "integer",
            "description": "Page number for pagination"
          },
          "per_page": {
            "type": "integer",
            "description": "Results per page"
          },
          "filters": {
            "type": "object",
            "description": "Filter results by document type fields"
          },
          "fetch_fields": {
            "type": "object",
            "description": "Specify which fields to return"
          },
          "highlight_fields": {
            "type": "object",
            "description": "Configure field highlighting"
          },
          "search_fields": {
            "type": "object",
            "description": "Limit search to specific fields"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "records": {
            "type": "object",
            "description": "Object containing document type results with matching documents"
          },
          "info": {
            "type": "object",
            "description": "Metadata including query, pagination, total results, facets",
            "properties": {
              "query": {
                "type": "string"
              },
              "page": {
                "type": "integer"
              },
              "per_page": {
                "type": "integer"
              },
              "total_result_count": {
                "type": "integer"
              }
            }
          },
          "errors": {
            "type": "object",
            "description": "Error information"
          }
        }
      },
      "AutocompleteRequest": {
        "type": "object",
        "required": [
          "engine_key",
          "q"
        ],
        "properties": {
          "engine_key": {
            "type": "string",
            "description": "Engine Key credential"
          },
          "q": {
            "type": "string",
            "description": "Prefix query string"
          },
          "document_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Specific document types to search"
          }
        }
      },
      "AutocompleteResponse": {
        "type": "object",
        "properties": {
          "records": {
            "type": "object",
            "description": "Object containing autocomplete suggestions by document type"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "engineKey": {
        "type": "apiKey",
        "in": "query",
        "name": "engine_key",
        "description": "Public engine key for read-only access"
      }
    }
  },
  "security": [
    {
      "engineKey": []
    }
  ],
  "tags": [
    {
      "name": "Autocomplete",
      "description": "Operations related to Autocomplete"
    },
    {
      "name": "Search",
      "description": "Operations related to Search"
    }
  ]
}