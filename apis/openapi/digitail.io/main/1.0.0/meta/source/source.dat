    "schemas": {
      "Pet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "nickname": {
            "type": "string"
          },
          "species_id": {
            "type": "integer"
          },
          "breed_id": {
            "type": "integer"
          },
          "gender": {
            "type": "string"
          },
          "microchip": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "birthday": {
            "type": "string",
            "format": "date"
          },
          "profile_picture": {
            "type": "string"
          },
          "age": {
            "type": "string"
          },
          "is_archived": {
            "type": "boolean"
          },
          "patients": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "PetInput": {
        "type": "object",
        "properties": {
          "nickname": {
            "type": "string"
          },
          "species_id": {
            "type": "integer"
          },
          "breed_id": {
