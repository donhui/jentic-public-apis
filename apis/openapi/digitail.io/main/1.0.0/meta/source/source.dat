{
  "openapi": "3.0.3",
  "info": {
    "title": "Digitail Veterinary API",
    "description": "Digitail API for veterinary practice management including pets, appointments, records, invoices, prescriptions, and more.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://documentation.digitail.io/list-all-pets"
  },
  "servers": [
    {
      "url": "https://developer.digitail.io/api/v1",
      "description": "Sandbox server"
    },
    {
      "url": "https://vet.digitail.io/api/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/me": {
      "get": {
        "operationId": "getme",
        "summary": "Get Current User",
        "description": "Retrieve logged-in user (Vet) information.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Current user details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid authorization token"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pets": {
      "get": {
        "operationId": "listpets",
        "summary": "List All Pets",
        "description": "Returns a paginated list of pets. Requires ACCESS_PATIENTS permission.",
        "tags": [
          "Pets"
        ],
        "parameters": [
          {
            "name": "filter[clinic_id]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Clinic ID where entity was created"
          },
          {
            "name": "filter[vet_id]",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Vet ID"
          },
          {
            "name": "filter[owner_id]",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Related PetParent ID"
          },
          {
            "name": "filter[id]",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Pet ID"
          },
          {
            "name": "filter[nickname]",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pet nickname"
          },
          {
            "name": "filter[updated_from]",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "ISO8601 format"
          },
          {
            "name": "filter[updated_to]",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "ISO8601 format"
          },
          {
            "name": "filter[birthday_between]",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Format: YYYY-MM-DD,YYYY-MM-DD"
          },
          {
            "name": "include",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated: species, breed, crossBreed, owners, clinics, vetPetRequests.clinic, patients"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Order by field(s)"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 15
            },
            "description": "Items per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of pets",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PetListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or disallowed filters"
          },
          "401": {
            "description": "Missing or invalid authorization token"
          },
          "403": {
            "description": "Unauthorized operation"
          },
          "429": {
            "description": "Rate limit exceeded (200 requests/minute max)"
          }
        }
      },
      "post": {
        "operationId": "createpet",
        "summary": "Create Pet",
        "description": "Create a new pet record.",
        "tags": [
          "Pets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PetInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pet created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Pet"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pets/{id}": {
      "get": {
        "operationId": "getpet",
