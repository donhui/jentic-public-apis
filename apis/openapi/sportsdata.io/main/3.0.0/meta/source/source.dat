{
  "openapi": "3.0.3",
  "info": {
    "title": "SportsData.io NFL API",
    "version": "3.0.0",
    "description": "SportsData.io NFL Scores API providing access to NFL teams, players, standings, and other related data.",
    "x-jentic-source-url": "https://sportsdata.io/developers/api-documentation/"
  },
  "servers": [
    {
      "url": "https://api.sportsdata.io/v3/nfl/scores"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    },
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Standings",
      "description": "League standings"
    },
    {
      "name": "Teams",
      "description": "Team profiles"
    },
    {
      "name": "Players",
      "description": "Player profiles"
    }
  ],
  "paths": {
    "/json/Standings/{season}": {
      "get": {
        "operationId": "getstandings",
        "summary": "Get regular season standings for all teams",
        "tags": [
          "Standings"
        ],
        "parameters": [
          {
            "name": "season",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Season year (e.g., 2024REG, 2024POST)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Standing"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/json/Teams": {
      "get": {
        "operationId": "getactiveteams",
        "summary": "Get all active team profiles",
        "tags": [
          "Teams"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Team"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/json/AllTeams": {
      "get": {
        "operationId": "getallteams",
        "summary": "Get all teams regardless of active status",
        "tags": [
          "Teams"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Team"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/json/Teams/{season}": {
      "get": {
        "operationId": "getteamsbyseason",
        "summary": "Get team profiles active in a specified season",
        "tags": [
          "Teams"
        ],
        "parameters": [
          {
            "name": "season",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Season year"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Team"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/json/TeamsBasic": {
      "get": {
        "operationId": "getbasicteams",
        "summary": "Get basic team information for all teams",
        "tags": [
          "Teams"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TeamBasic"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/json/PlayersBasic/{team}": {
      "get": {
        "operationId": "getplayersbyteam",
        "summary": "Get all player profiles for a team",
        "tags": [
          "Players"
        ],
        "parameters": [
          {
            "name": "team",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Team abbreviation (e.g., WAS, DAL)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PlayerBasic"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/json/PlayersByAvailable": {
      "get": {
        "operationId": "getallavailableplayers",
        "summary": "Get all available players with biographical info",
        "tags": [
          "Players"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PlayerBasic"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/json/PlayersByFreeAgents": {
      "get": {
        "operationId": "getfreeagentplayers",
        "summary": "Get all free agent players",
        "tags": [
          "Players"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PlayerBasic"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/json/PlayersByRookieDraftYear/{season}": {
      "get": {
        "operationId": "getplayersbyrookiedraftyear",
        "summary": "Get rookie players from a specified draft year",
        "tags": [
          "Players"
        ],
        "parameters": [
          {
            "name": "season",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Draft year"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PlayerBasic"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key passed as query parameter"
      },
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "Ocp-Apim-Subscription-Key",
        "description": "API key passed as HTTP header"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Standing": {
        "type": "object",
        "properties": {
          "Season": {
            "type": "integer"
          },
          "SeasonType": {
            "type": "integer"
          },
          "TeamID": {
            "type": "integer"
          },
          "Key": {
            "type": "string"
          },
          "City": {
            "type": "string"
          },
          "Name": {
            "type": "string"
          },
          "Conference": {
            "type": "string"
          },
          "Division": {
            "type": "string"
          },
          "Wins": {
            "type": "integer"
          },
          "Losses": {
            "type": "integer"
          },
          "Ties": {
            "type": "integer"
          },
          "Percentage": {
            "type": "number"
          },
          "PointsFor": {
            "type": "integer"
          },
          "PointsAgainst": {
            "type": "integer"
          },
          "NetPoints": {
            "type": "integer"
          },
          "ConferenceWins": {
            "type": "integer"
          },
          "ConferenceLosses": {
            "type": "integer"
          },
          "DivisionWins": {
            "type": "integer"
          },
          "DivisionLosses": {
            "type": "integer"
          }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "TeamID": {
            "type": "integer"
          },
          "Key": {
            "type": "string"
          },
          "City": {
            "type": "string"
          },
          "Name": {
            "type": "string"
          },
          "Conference": {
            "type": "string"
          },
          "Division": {
            "type": "string"
          },
          "FullName": {
            "type": "string"
          },
          "StadiumID": {
            "type": "integer"
          },
          "HeadCoach": {
            "type": "string"
          },
          "PrimaryColor": {
            "type": "string"
          },
          "SecondaryColor": {
            "type": "string"
          },
          "WikipediaLogoUrl": {
            "type": "string"
          },
          "WikipediaWordMarkUrl": {
            "type": "string"
          },
          "OffensiveScheme": {
            "type": "string"
          },
          "DefensiveScheme": {
            "type": "string"
          }
        }
      },
      "TeamBasic": {
        "type": "object",
        "properties": {
          "TeamID": {
            "type": "integer"
          },
          "Key": {
            "type": "string"
          },
          "City": {
            "type": "string"
          },
          "Name": {
            "type": "string"
          },
          "Conference": {
            "type": "string"
          },
          "Division": {
            "type": "string"
          },
          "StadiumID": {
            "type": "integer"
          },
          "HeadCoach": {
            "type": "string"
          },
          "PrimaryColor": {
            "type": "string"
          },
          "SecondaryColor": {
            "type": "string"
          }
        }
      },
      "PlayerBasic": {
        "type": "object",
        "properties": {
          "PlayerID": {
            "type": "integer"
          },
          "Team": {
            "type": "string"
          },
          "Number": {
            "type": "integer"
          },
          "FirstName": {
            "type": "string"
          },
          "LastName": {
            "type": "string"
          },
          "Position": {
            "type": "string"
          },
          "Status": {
            "type": "string"
          },
          "Height": {
            "type": "string"
          },
          "Weight": {
            "type": "integer"
          },
          "BirthDate": {
            "type": "string",
            "format": "date"
          },
          "College": {
            "type": "string"
          },
          "Experience": {
            "type": "integer"
          },
          "PhotoUrl": {
            "type": "string"
          }
        }
      }
    }
  }
}