{
  "openapi": "3.0.3",
  "info": {
    "title": "IPS Online API",
    "description": "IPS Online (Identity Protection Services) by identity.ps provides AI-powered anonymization APIs for protecting personal identity in images and videos. The API offers face anonymization (blurring/pixelation), license plate anonymization, and full-body person anonymization to help organizations comply with privacy regulations such as GDPR.",
    "version": "1.0.0",
    "contact": {
      "name": "IPS Online Support",
      "url": "https://identity.ps"
    },
    "x-jentic-source-url": "https://docs.identity.ps/docs"
  },
  "servers": [
    {
      "url": "https://api.identity.ps/v1",
      "description": "IPS Online Production API"
    }
  ],
  "tags": [
    {
      "name": "Face Anonymization",
      "description": "Detect and anonymize faces in images and videos"
    },
    {
      "name": "License Plate Anonymization",
      "description": "Detect and anonymize license plates in images and videos"
    },
    {
      "name": "Person Anonymization",
      "description": "Detect and anonymize full persons in images and videos"
    },
    {
      "name": "Jobs",
      "description": "Manage asynchronous anonymization jobs"
    }
  ],
  "paths": {
    "/anonymize/face": {
      "post": {
        "operationId": "anonymizeFaces",
        "summary": "Anonymize faces in an image",
        "description": "Detects all faces in the provided image and applies anonymization (blur, pixelation, or black box) to each detected face.",
        "tags": ["Face Anonymization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageAnonymizationRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileAnonymizationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Faces anonymized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnonymizationResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "413": { "$ref": "#/components/responses/PayloadTooLarge" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    },
    "/anonymize/license-plate": {
      "post": {
        "operationId": "anonymizeLicensePlates",
        "summary": "Anonymize license plates in an image",
        "description": "Detects all license plates in the provided image and applies anonymization to each detected plate.",
        "tags": ["License Plate Anonymization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageAnonymizationRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileAnonymizationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "License plates anonymized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnonymizationResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "413": { "$ref": "#/components/responses/PayloadTooLarge" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    },
    "/anonymize/person": {
      "post": {
        "operationId": "anonymizePersons",
        "summary": "Anonymize full persons in an image",
        "description": "Detects all persons in the provided image and applies full-body anonymization including face, body, and silhouette.",
        "tags": ["Person Anonymization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageAnonymizationRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileAnonymizationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Persons anonymized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnonymizationResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "413": { "$ref": "#/components/responses/PayloadTooLarge" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    },
    "/anonymize/all": {
      "post": {
        "operationId": "anonymizeAll",
        "summary": "Anonymize all detectable PII in an image",
        "description": "Detects and anonymizes all personally identifiable information including faces, license plates, and persons in a single request.",
        "tags": ["Face Anonymization", "License Plate Anonymization", "Person Anonymization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageAnonymizationRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileAnonymizationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "All PII anonymized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnonymizationResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "413": { "$ref": "#/components/responses/PayloadTooLarge" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    },
    "/detect/face": {
      "post": {
        "operationId": "detectFaces",
        "summary": "Detect faces without anonymization",
        "description": "Detects all faces in the provided image and returns bounding box coordinates without modifying the image.",
        "tags": ["Face Anonymization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DetectionRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileDetectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Faces detected successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    },
    "/detect/license-plate": {
      "post": {
        "operationId": "detectLicensePlates",
        "summary": "Detect license plates without anonymization",
        "description": "Detects all license plates in the provided image and returns bounding box coordinates without modifying the image.",
        "tags": ["License Plate Anonymization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DetectionRequest"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageFileDetectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "License plates detected successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    },
    "/jobs": {
      "get": {
        "operationId": "listJobs",
        "summary": "List anonymization jobs",
        "description": "Returns a list of all anonymization jobs with their current status.",
        "tags": ["Jobs"],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by job status",
            "schema": {
              "type": "string",
              "enum": ["pending", "processing", "completed", "failed"]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of jobs to return",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Offset for pagination",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Jobs listed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobListResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    },
    "/jobs/{job_id}": {
      "get": {
        "operationId": "getJob",
        "summary": "Get job status",
        "description": "Retrieves the status and result of a specific anonymization job.",
        "tags": ["Jobs"],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The job identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Job details returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "ApiKeyAuth": [] }]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key obtained from the IPS Online dashboard at https://identity.ps"
      }
    },
    "schemas": {
      "ImageAnonymizationRequest": {
        "type": "object",
        "required": ["image_url"],
        "properties": {
          "image_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the image to anonymize"
          },
          "method": {
            "type": "string",
            "enum": ["blur", "pixelate", "blackbox", "mosaic"],
            "default": "blur",
            "description": "Anonymization method to apply"
          },
          "intensity": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 1,
            "default": 0.8,
            "description": "Anonymization intensity (0-1)"
          },
          "output_format": {
            "type": "string",
            "enum": ["jpeg", "png", "webp"],
            "default": "jpeg",
            "description": "Output image format"
          },
          "min_confidence": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 1,
            "default": 0.5,
            "description": "Minimum detection confidence threshold"
          }
        }
      },
      "ImageFileAnonymizationRequest": {
        "type": "object",
        "required": ["image"],
        "properties": {
          "image": {
            "type": "string",
            "format": "binary",
            "description": "Image file to anonymize (JPEG, PNG, WebP)"
          },
          "method": {
            "type": "string",
            "enum": ["blur", "pixelate", "blackbox", "mosaic"],
            "default": "blur"
          },
          "intensity": {
            "type": "number",
            "format": "float",
            "default": 0.8
          },
          "output_format": {
            "type": "string",
            "enum": ["jpeg", "png", "webp"],
            "default": "jpeg"
          },
          "min_confidence": {
            "type": "number",
            "format": "float",
            "default": 0.5
          }
        }
      },
      "DetectionRequest": {
        "type": "object",
        "required": ["image_url"],
        "properties": {
          "image_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the image to analyze"
          },
          "min_confidence": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 1,
            "default": 0.5,
            "description": "Minimum detection confidence"
          }
        }
      },
      "ImageFileDetectionRequest": {
        "type": "object",
        "required": ["image"],
        "properties": {
          "image": {
            "type": "string",
            "format": "binary",
            "description": "Image file to analyze"
          },
          "min_confidence": {
            "type": "number",
            "format": "float",
            "default": 0.5
          }
        }
      },
      "AnonymizationResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "anonymized_image_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the anonymized image"
          },
          "anonymized_image_base64": {
            "type": "string",
            "description": "Base64-encoded anonymized image (if requested)"
          },
          "detections": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Detection" }
          },
          "detection_count": {
            "type": "integer",
            "description": "Number of detections found and anonymized"
          },
          "processing_time_ms": {
            "type": "integer",
            "description": "Processing time in milliseconds"
          }
        }
      },
      "DetectionResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "detections": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Detection" }
          },
          "detection_count": { "type": "integer" },
          "processing_time_ms": { "type": "integer" }
        }
      },
      "Detection": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["face", "license_plate", "person"],
            "description": "Type of detection"
          },
          "confidence": {
            "type": "number",
            "format": "float",
            "description": "Detection confidence (0-1)"
          },
          "bounding_box": {
            "type": "object",
            "properties": {
              "x": { "type": "integer" },
              "y": { "type": "integer" },
              "width": { "type": "integer" },
              "height": { "type": "integer" }
            }
          }
        }
      },
      "JobListResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "jobs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Job" }
          },
          "total": { "type": "integer" },
          "limit": { "type": "integer" },
          "offset": { "type": "integer" }
        }
      },
      "JobResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "job": { "$ref": "#/components/schemas/Job" }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "job_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "processing", "completed", "failed"]
          },
          "type": {
            "type": "string",
            "enum": ["face", "license_plate", "person", "all"]
          },
          "created_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" },
          "result_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the anonymized result (available when completed)"
          },
          "detection_count": { "type": "integer" },
          "error_message": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters or unsupported image format",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "PayloadTooLarge": {
        "description": "Image file too large (exceeds maximum size)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "RateLimited": {
        "description": "Too many requests - rate limit exceeded",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}
