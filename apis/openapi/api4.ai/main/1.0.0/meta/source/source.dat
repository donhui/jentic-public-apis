{
  "openapi": "3.0.3",
  "info": {
    "title": "OCR API",
    "description": "api4ai Optical Character Recognition (OCR) API for detecting and extracting text from images. Supports individual word detection and full text extraction with bounding box coordinates.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api4.ai/apis/ocr"
  },
  "servers": [
    {
      "url": "https://demo.api4ai.cloud",
      "description": "Demo API server"
    }
  ],
  "paths": {
    "/ocr/v1/results": {
      "post": {
        "operationId": "performOcr",
        "summary": "Perform OCR on an image",
        "description": "Submits an image for optical character recognition. Supports file upload or URL input. Returns detected text with bounding box coordinates.",
        "tags": ["OCR"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image file to process (JPG, PNG). Max size: 16 MB."
                  },
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the image to process (alternative to file upload)."
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["simple-words", "text"],
                    "description": "Recognition mode: 'simple-words' for individual word detection, 'text' for full text extraction."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OCR results with detected text and bounding boxes.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OcrResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid image or parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing credentials.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/ocr/v1/warmup": {
      "get": {
        "operationId": "warmupOcr",
        "summary": "Warm up the OCR service",
        "description": "Initializes the OCR service for faster subsequent requests. Can be used as a health check.",
        "tags": ["OCR"],
        "responses": {
          "200": {
            "description": "Service is ready.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request."
          },
          "401": {
            "description": "Unauthorized."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OcrResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "entities": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "kind": {
                        "type": "string"
                      },
                      "objects": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "text": {
                              "type": "string",
                              "description": "Detected text content."
                            },
                            "box": {
                              "type": "array",
                              "items": {
                                "type": "number"
                              },
                              "description": "Bounding box coordinates [x, y, width, height]."
                            },
                            "confidence": {
                              "type": "number",
                              "description": "Confidence score of the detection."
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "appId": {
        "type": "apiKey",
        "in": "header",
        "name": "A4A-CLIENT-APP-ID",
        "description": "Application ID for authentication."
      }
    }
  },
  "security": [
    {
      "appId": []
    }
  ],
  "tags": [
    {
      "name": "OCR",
      "description": "Optical Character Recognition operations"
    }
  ]
}