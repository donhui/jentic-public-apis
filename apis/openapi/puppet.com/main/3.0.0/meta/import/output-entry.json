{
  "openapi": "3.0.3",
  "info": {
    "title": "Puppet HTTP API",
    "version": "3.0.0",
    "description": "Puppet Server HTTP API for managing catalogs, nodes, facts, reports, file content, file metadata, environments, and file bucket operations.",
    "x-jentic-source-url": "https://www.puppet.com/"
  },
  "servers": [
    {
      "url": "https://{puppetserver}:8140",
      "variables": {
        "puppetserver": {
          "default": "puppet",
          "description": "Puppet Server hostname"
        }
      }
    }
  ],
  "paths": {
    "/puppet/v3/catalog/{nodename}": {
      "post": {
        "operationId": "compileCatalog",
        "summary": "Compile and retrieve a catalog for a node",
        "tags": [
          "Catalog"
        ],
        "parameters": [
          {
            "name": "nodename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Node certificate name"
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Puppet environment"
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "facts_format": {
                    "type": "string",
                    "enum": [
                      "application/json"
                    ]
                  },
                  "facts": {
                    "type": "string",
                    "description": "Serialized JSON facts"
                  },
                  "transaction_uuid": {
                    "type": "string"
                  },
                  "static_catalog": {
                    "type": "boolean"
                  },
                  "checksum_type": {
                    "type": "string"
                  },
                  "configured_environment": {
                    "type": "string"
                  },
                  "job_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compiled catalog",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Catalog"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "getCatalog",
        "summary": "Retrieve a cached catalog for a node",
        "tags": [
          "Catalog"
        ],
        "parameters": [
          {
            "name": "nodename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Compiled catalog",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Catalog"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/puppet/v3/node/{certname}": {
      "get": {
        "operationId": "getNode",
        "summary": "Retrieve node information",
        "tags": [
          "Node"
        ],
        "parameters": [
          {
            "name": "certname",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Node certificate name"
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "transaction_uuid",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "configured_environment",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Node information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Node"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/puppet/v3/facts/{nodename}": {
      "put": {
        "operationId": "putFacts",
        "summary": "Store facts for a node",
        "tags": [
          "Facts"
        ],
        "parameters": [
          {
            "name": "nodename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Facts"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Facts stored",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/puppet/v3/report/{nodename}": {
      "put": {
        "operationId": "putReport",
        "summary": "Submit a report for a node",
        "tags": [
          "Report"
        ],
        "parameters": [
          {
            "name": "nodename",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Report"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Report accepted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/puppet/v3/file_bucket_file/{md5}": {
      "get": {
        "operationId": "getFileBucketFile",
        "summary": "Retrieve a file from the file bucket by MD5 hash",
        "tags": [
          "File Bucket"
        ],
        "parameters": [
          {
            "name": "md5",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "head": {
        "operationId": "headFileBucketFile",
        "summary": "Check if a file exists in the file bucket",
        "tags": [
          "File Bucket"
        ],
        "parameters": [
          {
            "name": "md5",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File exists"
          },
          "404": {
            "description": "File not found"
          }
        }
      },
      "put": {
        "operationId": "putFileBucketFile",
        "summary": "Upload a file to the file bucket",
        "tags": [
          "File Bucket"
        ],
        "parameters": [
          {
            "name": "md5",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File stored",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/puppet/v3/file_content/{mount}/{path}": {
      "get": {
        "operationId": "getFileContent",
        "summary": "Retrieve file content from the Puppet file server",
        "tags": [
          "File Server"
        ],
        "parameters": [
          {
            "name": "mount",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Mount point (custom, modules/<MODULE>, plugins, pluginfacts, tasks/<MODULE>)"
          },
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File path within the mount"
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "File not found"
          }
        }
      }
    },
    "/puppet/v3/file_metadata/{mount}/{path}": {
      "get": {
        "operationId": "getFileMetadata",
        "summary": "Retrieve metadata for a single file",
        "tags": [
          "File Server"
        ],
        "parameters": [
          {
            "name": "mount",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "links",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "manage",
                "follow"
              ],
              "default": "manage"
            }
          },
          {
            "name": "checksum_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "md5",
                "md5lite",
                "sha256",
                "sha256lite",
                "mtime",
                "ctime",
                "none"
              ]
            }
          },
          {
            "name": "source_permissions",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "ignore",
                "use",
                "use_when_creating"
              ],
              "default": "ignore"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileMetadata"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/puppet/v3/file_metadatas/{mount}/{path}": {
      "get": {
        "operationId": "searchFileMetadata",
        "summary": "Search for file metadata recursively",
        "tags": [
          "File Server"
        ],
        "parameters": [
          {
            "name": "mount",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "environment",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "recurse",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "yes",
                "no"
              ],
              "default": "no"
            }
          },
          {
            "name": "ignore",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Regex pattern to exclude files"
          },
          {
            "name": "links",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "manage",
                "follow"
              ],
              "default": "manage"
            }
          },
          {
            "name": "checksum_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "md5",
                "md5lite",
                "sha256",
                "sha256lite",
                "mtime",
                "ctime",
                "none"
              ]
            }
          },
          {
            "name": "source_permissions",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "ignore",
                "use",
                "use_when_creating"
              ],
              "default": "ignore"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of file metadata",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FileMetadata"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/puppet/v3/environments": {
      "get": {
        "operationId": "getEnvironments",
        "summary": "List all Puppet environments",
        "tags": [
          "Environments"
        ],
        "responses": {
          "200": {
            "description": "Environment listing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Environments"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "issue_kind": {
            "type": "string"
          }
        }
      },
      "Catalog": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "environment": {
            "type": "string"
          },
          "resources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Resource"
            }
          },
          "edges": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "target": {
                  "type": "string"
                },
                "relationship": {
                  "type": "string"
                }
              }
            }
          },
          "classes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Resource": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "exported": {
            "type": "boolean"
          },
          "parameters": {
            "type": "object"
          }
        }
      },
      "Node": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "environment": {
            "type": "string"
          },
          "parameters": {
            "type": "object"
          }
        }
      },
      "Facts": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "values": {
            "type": "object"
          },
          "timestamp": {
            "type": "string"
          },
          "expiration": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "values"
        ]
      },
      "Report": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string"
          },
          "time": {
            "type": "string"
          },
          "configuration_version": {
            "type": "string"
          },
          "transaction_uuid": {
            "type": "string"
          },
          "report_format": {
            "type": "integer"
          },
          "puppet_version": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "environment": {
            "type": "string"
          },
          "logs": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "metrics": {
            "type": "object"
          },
          "resource_statuses": {
            "type": "object"
          }
        }
      },
      "FileMetadata": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "relative_path": {
            "type": "string"
          },
          "links": {
            "type": "string"
          },
          "owner": {
            "type": "integer"
          },
          "group": {
            "type": "integer"
          },
          "mode": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": [
              "file",
              "directory",
              "link"
            ]
          },
          "checksum": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "destination": {
            "type": "string"
          }
        }
      },
      "Environments": {
        "type": "object",
        "properties": {
          "search_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "environments": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "settings": {
                  "type": "object",
                  "properties": {
                    "modulepath": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "manifest": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "environment_timeout": {
                      "type": "integer"
                    },
                    "config_version": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "sslCert": {
        "type": "mutualTLS",
        "description": "Client SSL certificate authentication"
      }
    }
  },
  "security": [
    {
      "sslCert": []
    }
  ]
}