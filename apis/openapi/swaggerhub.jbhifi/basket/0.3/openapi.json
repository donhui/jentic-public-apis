  "paths": {
    "/Basket/Api/CalculatePrices": {
      "post": {
        "tags": [
          "Calculate prices for items in basket"
        ],
        "summary": "Get all fulfilment options for a SKU / basket of SKUs",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/BasketRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful calculated",
            "schema": {
              "$ref": "#/definitions/BasketResponse"
            }
          },
          "400": {
            "description": "Data error",
            "schema": {
              "$ref": "#/definitions/GeneralError"
            }
          },
          "401": {
            "description": "Unauthorised",
            "schema": {
              "$ref": "#/definitions/AuthError"
            }
          },
          "404": {
            "description": "Requested code does not exist",
            "schema": {
              "$ref": "#/definitions/GeneralError"
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/Basket/Api/CalculatedPrices/{CalculatedBasketId}": {
      "get": {
        "tags": [
          "Retrieve previously calculated basket prices by Id"
        ],
        "summary": "Retrieve previously calculated basket prices by Id",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "CalculatedBasketId",
            "in": "path",
            "description": "Calculated Basket Id",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful retrieve",
            "schema": {
              "$ref": "#/definitions/BasketResponse"
            }
          },
          "400": {
            "description": "Data error",
            "schema": {
              "$ref": "#/definitions/GeneralError"
            }
          },
          "401": {
            "description": "Unauthorised",
            "schema": {
              "$ref": "#/definitions/AuthError"
            }
          },
          "404": {
            "description": "Requested code does not exist",
            "schema": {
              "$ref": "#/definitions/GeneralError"
            }
          }
        }
      }
    }
