  "info": {
    "version": "0.3",
    "title": "Basket API",
    "description": "Receive a basket of goods, coupon codes and fulfillment options and retrieves fulfilment options, applies basket level promotions and any supplied coupon codes then returns the basket and fulfilment option details",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/JBHIFI/Basket/0.3/swagger.json"
