          "Actor",
          "Organisation",
          "Location",
          "When",
          "Application",
          "Action",
          "Description"
        ],
        "properties": {
          "Id": {
            "type": "string",
            "example": "1"
          },
          "Actor": {
            "type": "string",
            "example": "232"
          },
          "Organisation": {
            "type": "integer",
            "example": 1
          },
          "Location": {
            "type": "string",
            "example": "002 Camberwell"
          },
          "IP": {
            "type": "string",
            "example": "192.168.1.104"
          },
          "When": {
            "type": "string",
            "format": "date-time",
            "example": "2019-06-03T22:54:26Z"
          },
          "Application": {
            "type": "string",
            "example": "MobilePhoneSales"
          },
          "ApplicationID": {
            "type": "string",
            "example": "134"
          },
          "Version": {
            "type": "string",
            "example": "2019.01.01.43334"
          },
          "Action": {
            "type": "string",
            "example": "delete"
          },
          "ActionID": {
            "type": "string",
            "example": "1234"
          },
          "Description": {
            "type": "string",
            "example": "delete item number 1234"
          },
          "Custom": {
            "type": "string",
            "example": "Some random stuff in here"
          },
          "GroupID": {
            "type": "string",
            "example": "42"
          },
          "Data": {
            "type": "string"
          }
        }
      }
    }
