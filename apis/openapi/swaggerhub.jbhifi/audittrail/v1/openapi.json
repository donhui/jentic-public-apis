          },
          "403": {
            "description": "Forbidden"
          },
          "429": {
            "description": "Too many requests"
          }
        },
        "tags": [
          "Write"
        ],
        "description": "Creates a new audit entry",
        "operationId": "post-audit-api-create",
        "requestBody": {
          "content": {
