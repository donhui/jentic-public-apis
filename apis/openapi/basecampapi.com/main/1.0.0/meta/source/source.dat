{
  "openapi": "3.0.3",
  "info": {
    "title": "Basecamp API",
    "version": "1.0.0",
    "description": "The Basecamp 4 API provides programmatic access to Basecamp project management features including projects, to-do lists, to-dos, messages, comments, people, campfires, and more. All URLs use flat routes with resource IDs.",
    "x-jentic-source-url": "https://github.com/basecamp/bc3-api"
  },
  "servers": [
    {
      "url": "https://3.basecampapi.com/{accountId}",
      "variables": {
        "accountId": {
          "default": "999999999",
          "description": "Your Basecamp account ID"
        }
      }
    }
  ],
  "paths": {
    "/projects.json": {
      "get": {
        "operationId": "listProjects",
        "summary": "Get all projects",
        "description": "Returns a paginated list of active projects visible to the current user, sorted by most recently created first.",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["archived", "trashed"] },
            "description": "Filter by status"
          }
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Project" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createProject",
        "summary": "Create a project",
        "tags": ["Projects"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Project created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/projects/{projectId}.json": {
      "get": {
        "operationId": "getProject",
        "summary": "Get a project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Project details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateProject",
        "summary": "Update a project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Project updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "trashProject",
        "summary": "Trash a project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "Project trashed" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/people.json": {
      "get": {
        "operationId": "listPeople",
        "summary": "Get all people",
        "description": "Returns all people visible to the current user.",
        "tags": ["People"],
        "responses": {
          "200": {
            "description": "List of people",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Person" } } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/projects/{projectId}/people.json": {
      "get": {
        "operationId": "listProjectPeople",
        "summary": "Get people on a project",
        "tags": ["People"],
        "parameters": [
          { "name": "projectId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List of people on the project", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Person" } } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/people/{personId}.json": {
      "get": {
        "operationId": "getPerson",
        "summary": "Get a person",
        "tags": ["People"],
        "parameters": [
          { "name": "personId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Person details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Person" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/my/profile.json": {
      "get": {
        "operationId": "getMyProfile",
        "summary": "Get my personal info",
        "tags": ["People"],
        "responses": {
          "200": { "description": "Current user profile", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Person" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/todosets/{todosetId}/todolists.json": {
      "get": {
        "operationId": "listTodolists",
        "summary": "Get to-do lists",
        "description": "Returns a paginated list of active to-do lists in the to-do set.",
        "tags": ["To-do Lists"],
        "parameters": [
          { "name": "todosetId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "required": false, "schema": { "type": "string", "enum": ["archived", "trashed"] } }
        ],
        "responses": {
          "200": { "description": "List of to-do lists", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Todolist" } } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createTodolist",
        "summary": "Create a to-do list",
        "tags": ["To-do Lists"],
        "parameters": [
          { "name": "todosetId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "To-do list created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Todolist" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/todolists/{todolistId}.json": {
      "get": {
        "operationId": "getTodolist",
        "summary": "Get a to-do list",
        "tags": ["To-do Lists"],
        "parameters": [
          { "name": "todolistId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "To-do list details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Todolist" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateTodolist",
        "summary": "Update a to-do list",
        "tags": ["To-do Lists"],
        "parameters": [
          { "name": "todolistId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "To-do list updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Todolist" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/todolists/{todolistId}/todos.json": {
      "get": {
        "operationId": "listTodos",
        "summary": "Get to-dos",
        "description": "Returns a paginated list of active to-dos in the to-do list.",
        "tags": ["To-dos"],
        "parameters": [
          { "name": "todolistId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "required": false, "schema": { "type": "string", "enum": ["archived", "trashed"] } },
          { "name": "completed", "in": "query", "required": false, "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": { "description": "List of to-dos", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Todo" } } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createTodo",
        "summary": "Create a to-do",
        "tags": ["To-dos"],
        "parameters": [
          { "name": "todolistId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string" },
                  "description": { "type": "string" },
                  "assignee_ids": { "type": "array", "items": { "type": "integer" } },
                  "completion_subscriber_ids": { "type": "array", "items": { "type": "integer" } },
                  "notify": { "type": "boolean" },
                  "due_on": { "type": "string", "format": "date" },
                  "starts_on": { "type": "string", "format": "date" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "To-do created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Todo" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/todos/{todoId}.json": {
      "get": {
        "operationId": "getTodo",
        "summary": "Get a to-do",
        "tags": ["To-dos"],
        "parameters": [
          { "name": "todoId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "To-do details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Todo" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateTodo",
        "summary": "Update a to-do",
        "tags": ["To-dos"],
        "parameters": [
          { "name": "todoId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string" },
                  "description": { "type": "string" },
                  "assignee_ids": { "type": "array", "items": { "type": "integer" } },
                  "due_on": { "type": "string", "format": "date" },
                  "starts_on": { "type": "string", "format": "date" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "To-do updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Todo" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/todos/{todoId}/completion.json": {
      "post": {
        "operationId": "completeTodo",
        "summary": "Complete a to-do",
        "tags": ["To-dos"],
        "parameters": [
          { "name": "todoId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "To-do completed" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "uncompleteTodo",
        "summary": "Uncomplete a to-do",
        "tags": ["To-dos"],
        "parameters": [
          { "name": "todoId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "204": { "description": "To-do uncompleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/message_boards/{messageBoardId}/messages.json": {
      "get": {
        "operationId": "listMessages",
        "summary": "Get messages",
        "description": "Returns a paginated list of active messages in the message board.",
        "tags": ["Messages"],
        "parameters": [
          { "name": "messageBoardId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "sort", "in": "query", "required": false, "schema": { "type": "string", "enum": ["created_at", "updated_at"] } },
          { "name": "direction", "in": "query", "required": false, "schema": { "type": "string", "enum": ["asc", "desc"] } }
        ],
        "responses": {
          "200": { "description": "List of messages", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Message" } } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createMessage",
        "summary": "Create a message",
        "tags": ["Messages"],
        "parameters": [
          { "name": "messageBoardId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subject"],
                "properties": {
                  "subject": { "type": "string" },
                  "content": { "type": "string" },
                  "status": { "type": "string" },
                  "category_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Message created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Message" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/messages/{messageId}.json": {
      "get": {
        "operationId": "getMessage",
        "summary": "Get a message",
        "tags": ["Messages"],
        "parameters": [
          { "name": "messageId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Message details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Message" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateMessage",
        "summary": "Update a message",
        "tags": ["Messages"],
        "parameters": [
          { "name": "messageId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subject": { "type": "string" },
                  "content": { "type": "string" },
                  "category_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Message updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Message" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recordings/{recordingId}/comments.json": {
      "get": {
        "operationId": "listComments",
        "summary": "Get comments",
        "description": "Returns a paginated list of active comments for the recording.",
        "tags": ["Comments"],
        "parameters": [
          { "name": "recordingId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List of comments", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Comment" } } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createComment",
        "summary": "Create a comment",
        "tags": ["Comments"],
        "parameters": [
          { "name": "recordingId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Comment created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Comment" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/chats.json": {
      "get": {
        "operationId": "listCampfires",
        "summary": "Get all Campfires",
        "description": "Returns a paginated list of all active Campfires visible to the current user.",
        "tags": ["Campfires"],
        "responses": {
          "200": { "description": "List of campfires", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Campfire" } } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/chats/{chatId}.json": {
      "get": {
        "operationId": "getCampfire",
        "summary": "Get a Campfire",
        "tags": ["Campfires"],
        "parameters": [
          { "name": "chatId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Campfire details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campfire" } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/chats/{chatId}/lines.json": {
      "get": {
        "operationId": "listCampfireLines",
        "summary": "Get Campfire lines",
        "tags": ["Campfires"],
        "parameters": [
          { "name": "chatId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List of chat lines", "content": { "application/json": { "schema": { "type": "array", "items": { "type": "object" } } } } },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createCampfireLine",
        "summary": "Create a Campfire line",
        "tags": ["Campfires"],
        "parameters": [
          { "name": "chatId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Line created" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "purpose": { "type": "string" },
          "clients_enabled": { "type": "boolean" },
          "timesheet_enabled": { "type": "boolean" },
          "url": { "type": "string" },
          "app_url": { "type": "string" },
          "bookmark_url": { "type": "string" },
          "dock": { "type": "array", "items": { "$ref": "#/components/schemas/Dock" } }
        }
      },
      "Dock": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "name": { "type": "string" },
          "enabled": { "type": "boolean" },
          "position": { "type": "integer", "nullable": true },
          "url": { "type": "string" },
          "app_url": { "type": "string" }
        }
      },
      "Person": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "attachable_sgid": { "type": "string" },
          "name": { "type": "string" },
          "email_address": { "type": "string" },
          "personable_type": { "type": "string" },
          "title": { "type": "string" },
          "bio": { "type": "string", "nullable": true },
          "location": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "admin": { "type": "boolean" },
          "owner": { "type": "boolean" },
          "client": { "type": "boolean" },
          "employee": { "type": "boolean" },
          "time_zone": { "type": "string" },
          "avatar_url": { "type": "string" },
          "company": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          }
        }
      },
      "Todolist": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": { "type": "string" },
          "visible_to_clients": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
