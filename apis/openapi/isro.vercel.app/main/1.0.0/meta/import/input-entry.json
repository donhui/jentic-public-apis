{
  "openapi": "3.0.3",
  "info": {
    "title": "ISRO API",
    "version": "1.0.0",
    "description": "Open source REST API providing data about ISRO's launched spacecrafts, rockets/launchers, customer satellites, and research centres.",
    "x-jentic-source-url": "https://isro.vercel.app"
  },
  "servers": [
    {
      "url": "https://isro.vercel.app"
    }
  ],
  "paths": {
    "/api/spacecrafts": {
      "get": {
        "operationId": "listSpacecrafts",
        "summary": "List all ISRO spacecrafts",
        "description": "Returns a list of all spacecrafts launched by ISRO.",
        "tags": [
          "Spacecrafts"
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of spacecrafts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpacecraftsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/launchers": {
      "get": {
        "operationId": "listLaunchers",
        "summary": "List all ISRO launchers",
        "description": "Returns a list of all rockets/launchers used by ISRO.",
        "tags": [
          "Launchers"
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of launchers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LaunchersResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/customer_satellites": {
      "get": {
        "operationId": "listCustomerSatellites",
        "summary": "List all customer satellites",
        "description": "Returns a list of customer satellites launched by ISRO.",
        "tags": [
          "Customer Satellites"
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of customer satellites",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CustomerSatellitesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/api/centres": {
      "get": {
        "operationId": "listCentres",
        "summary": "List all ISRO centres",
        "description": "Returns a list of all ISRO research and development centres.",
        "tags": [
          "Centres"
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of centres",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CentresResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Spacecraft": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the spacecraft"
          },
          "name": {
            "type": "string",
            "description": "Name of the spacecraft"
          }
        }
      },
      "SpacecraftsResponse": {
        "type": "object",
        "properties": {
          "spacecrafts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Spacecraft"
            }
          }
        }
      },
      "Launcher": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the launcher"
          },
          "name": {
            "type": "string",
            "description": "Name of the launcher/rocket"
          }
        }
      },
      "LaunchersResponse": {
        "type": "object",
        "properties": {
          "launchers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Launcher"
            }
          }
        }
      },
      "CustomerSatellite": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the customer satellite"
          },
          "name": {
            "type": "string",
            "description": "Name of the customer satellite"
          },
          "country": {
            "type": "string",
            "description": "Country of origin"
          }
        }
      },
      "CustomerSatellitesResponse": {
        "type": "object",
        "properties": {
          "customer_satellites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CustomerSatellite"
            }
          }
        }
      },
      "Centre": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the centre"
          },
          "name": {
            "type": "string",
            "description": "Name of the ISRO centre"
          },
          "Place": {
            "type": "string",
            "description": "Location of the centre"
          },
          "State": {
            "type": "string",
            "description": "State where the centre is located"
          }
        }
      },
      "CentresResponse": {
        "type": "object",
        "properties": {
          "centres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Centre"
            }
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}