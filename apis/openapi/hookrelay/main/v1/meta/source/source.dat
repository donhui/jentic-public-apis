{
  "openapi": "3.0.3",
  "info": {
    "title": "HookRelay API",
    "description": "HookRelay API for managing webhook accounts, hooks, and deliveries.",
    "version": "v1",
    "x-jentic-source-url": "https://hookrelay.dev/docs"
  },
  "servers": [
    {
      "url": "https://app.hookrelay.dev/api/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {"name": "accounts"},
    {"name": "hooks"},
    {"name": "deliveries"},
    {"name": "user"}
  ],
  "paths": {
    "/accounts": {
      "get": {
        "operationId": "listAccounts",
        "summary": "List all accounts",
        "tags": ["accounts"],
        "parameters": [
          {
            "name": "ending_before",
            "in": "query",
            "required": false,
            "schema": {"type": "string"}
          },
          {
            "name": "starting_after",
            "in": "query",
            "required": false,
            "schema": {"type": "string"}
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {"type": "integer"}
          }
        ],
        "responses": {
          "200": {
            "description": "List of accounts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountListResponse"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/accounts/{account_id}": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get an account",
        "tags": ["accounts"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Account details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"},
          "404": {"description": "Account not found"}
        }
      }
    },
    "/accounts/{account_id}/hooks": {
      "get": {
        "operationId": "listHooks",
        "summary": "List all hooks",
        "tags": ["hooks"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "ending_before",
            "in": "query",
            "required": false,
            "schema": {"type": "string"}
          },
          {
            "name": "starting_after",
            "in": "query",
            "required": false,
            "schema": {"type": "string"}
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {"type": "integer"}
          }
        ],
        "responses": {
          "200": {
            "description": "List of hooks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HookListResponse"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"}
        }
      },
      "post": {
        "operationId": "createHook",
        "summary": "Create a hook",
        "tags": ["hooks"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HookCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created hook",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Hook"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/accounts/{account_id}/hooks/{hook_id}": {
      "get": {
        "operationId": "getHook",
        "summary": "Get a hook",
        "tags": ["hooks"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "hook_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Hook details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Hook"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"},
          "404": {"description": "Hook not found"}
        }
      },
      "put": {
        "operationId": "updateHook",
        "summary": "Update a hook",
        "tags": ["hooks"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "hook_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HookUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated hook",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Hook"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Hook not found"}
        }
      },
      "delete": {
        "operationId": "deleteHook",
        "summary": "Delete a hook",
        "tags": ["hooks"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "hook_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Hook deleted"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Hook not found"}
        }
      }
    },
    "/accounts/{account_id}/hooks/{hook_id}/deliveries": {
      "get": {
        "operationId": "listDeliveries",
        "summary": "List deliveries",
        "tags": ["deliveries"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "hook_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "ending_before",
            "in": "query",
            "required": false,
            "schema": {"type": "string"}
          },
          {
            "name": "starting_after",
            "in": "query",
            "required": false,
            "schema": {"type": "string"}
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {"type": "integer"}
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {"type": "string"}
          },
          {
            "name": "started_at",
            "in": "query",
            "required": false,
            "schema": {"type": "string", "format": "date-time"}
          },
          {
            "name": "stream",
            "in": "query",
            "required": false,
            "schema": {"type": "boolean"}
          }
        ],
        "responses": {
          "200": {
            "description": "List of deliveries",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeliveryListResponse"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/accounts/{account_id}/hooks/{hook_id}/deliveries/{delivery_id}": {
      "get": {
        "operationId": "getDelivery",
        "summary": "Get a delivery",
        "tags": ["deliveries"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "hook_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "delivery_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Delivery details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"},
          "404": {"description": "Delivery not found"}
        }
      }
    },
    "/accounts/{account_id}/hooks/{hook_id}/deliveries/{delivery_id}/retry": {
      "post": {
        "operationId": "retryDelivery",
        "summary": "Retry a delivery",
        "tags": ["deliveries"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "hook_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "delivery_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Delivery queued for retry",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RetryDeliveryResponse"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"},
          "404": {"description": "Delivery not found"}
        }
      }
    },
    "/me": {
      "get": {
        "operationId": "getUser",
        "summary": "Show current user",
        "tags": ["user"],
        "responses": {
          "200": {
            "description": "Current user info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "links": {
            "type": "object",
            "properties": {
              "self": {"type": "string", "format": "uri"},
              "hooks": {"type": "string", "format": "uri"}
            }
          }
        }
      },
      "AccountListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Account"}
          },
          "has_more": {"type": "boolean"}
        }
      },
      "Hook": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "account_id": {"type": "string"},
          "links": {
            "type": "object",
            "properties": {
              "self": {"type": "string", "format": "uri"},
              "deliveries": {"type": "string", "format": "uri"}
            }
          }
        }
      },
      "HookCreateRequest": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "url": {"type": "string", "format": "uri"}
        }
      },
      "HookUpdateRequest": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "url": {"type": "string", "format": "uri"}
        }
      },
      "HookListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Hook"}
          },
          "has_more": {"type": "boolean"}
        }
      },
      "Delivery": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "hook_id": {"type": "string"},
          "status": {"type": "string"},
          "attempts": {"type": "integer"},
          "request": {"type": "object"},
          "response": {"type": "object"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "DeliveryListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Delivery"}
          },
          "has_more": {"type": "boolean"}
        }
      },
      "RetryDeliveryResponse": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "status": {"type": "string", "example": "queued"}
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "email": {"type": "string", "format": "email"},
          "name": {"type": "string"},
          "accounts": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Account"}
          }
        }
      }
    }
  }
}