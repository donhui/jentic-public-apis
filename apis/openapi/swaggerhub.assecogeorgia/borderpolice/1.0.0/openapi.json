{
  "swagger": "2.0",
  "info": {
    "description": "GIA and Border Police data exchange api",
    "version": "1.0.0",
    "title": "Border Police Api",
    "contact": {
      "email": "nika.nikabadze@asseco.ge"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/AssecoGeorgia/BorderPolice/1.0.0/swagger.json"
  },
  "paths": {
    "/api/policies": {
      "get": {
        "summary": "checks if there is active policy on vehicle via GIA system",
        "operationId": "getVehiclePolicy",
        "description": "check if there is active policy on vehicle",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "requestId",
            "description": "pass an required parameter, by which we can afterwards identify transaction on submitters side",
            "required": true,
            "type": "string",
            "format": "uuid"
          },
          {
            "in": "query",
            "name": "securityKey",
            "description": "unique key by which we will validate border police user through their respective service  side",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "vinChassisNumber",
            "description": "pass an optional vin code or chassis number to service to check whether vehicle has active policy",
            "required": false,
            "type": "string"
          },
          {
            "in": "query",
            "name": "vehicleRegistratioNumber",
            "description": "pass vehicle vehicle registration number to service to check whether vehicle has active policy",
            "required": false,
            "type": "string"
          },
          {
            "in": "query",
            "name": "categoryId",
            "description": "pass vehicle categoryId",
            "required": false,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Policy existense for specified vehicle",
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2,
                3
              ],
              "example": [
                "Found",
                "NotFound",
                "Doubt"
              ]
            }
          }
        }
      }
    }
  },
  "definitions": {
    "VehiclePolicyInfo": {
      "type": "object",
      "required": [
        "vin",
        "chassisNumber"
      ],
      "properties": {
        "vin": {
          "type": "string",
          "example": "4T1BK46K87U548149"
        },
        "chassisNumber": {
          "type": "string"
        },
        "owner": {
          "type": "string",
          "example": "NAME LASTNAME"
        },
        "ownerDocumentNumber": {
          "type": "string",
          "example": "TEST1234"
        },
        "ownerCitizenship": {
          "type": "string",
          "example": "TURKEY"
        },
        "policyNumber": {
          "type": "string",
          "example": "TPL-1234"
        },
        "policyStartDate": {
          "type": "string",
          "example": "2018-01-05T15:05:10"
        },
        "policyExpirationDate": {
          "type": "string",
          "example": "2018-06-05T00:00:00"
        },
        "borderEntryDate": {
          "type": "string",
          "example": "2018-01-01T20:42:00"
        },
        "category": {
          "type": "string",
          "example": "SEDAN"
        },
        "categoryId": {
          "type": "integer",
          "example": 2
        },
        "vehicleManufacturer": {
          "type": "string",
          "example": "Mercedes-Benz"
        },
        "vehicleManufacturerId": {
          "type": "integer",
          "example": 5
        },
        "vehicleModel": {
          "type": "string",
          "example": "ML320"
        },
        "vehicleModelId": {
          "type": "integer",
          "example": 6
        }
      }
    }
  },
  "basePath": "/AssecoGeorgia/BorderPolice/1.0.0",
  "schemes": [
    "https"
  ],
  "host": "virtserver.swaggerhub.com"
}