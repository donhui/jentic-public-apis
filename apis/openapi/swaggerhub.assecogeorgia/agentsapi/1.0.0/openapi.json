        "/api/vehicles/manufacturers": {
            "get": {
                "summary": "returns manufacturers",
                "operationId": "getManufacturer",
                "description": "returns all manufacturers",
                "parameters": [
                    {
                        "in": "query",
                        "name": "sessionKey",
                        "description": "unique key by which we will validate third party user through their respective service  side",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
