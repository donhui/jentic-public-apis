{
    "openapi": "3.0.0",
    "info": {
        "description": "Api for Thirdparty systems",
        "version": "1.0.0",
        "title": "Billing API",
        "contact": {
            "email": "nika.nikabadze@asseco.ge"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/AssecoGeorgia/AgentsApi/1.0.0/swagger.json"
    },
    "paths": {
        "/api/policies": {
            "get": {
                "summary": "returns policies",
                "operationId": "getPolicies",
                "description": "by default returns policies registered today",
                "parameters": [
                    {
                        "in": "query",
                        "name": "sessionKey",
                        "description": "unique key by which we will validate third party user through their respective service  side",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "policies",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Policy"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "The server cannot or will not process the request due to an apparent client error"
                    }
                }
            },
            "post": {
                "summary": "registers policy to GIA system",
                "operationId": "registerPolicy",
                "description": "Adds an item to the system",
                "parameters": [
                    {
                        "in": "query",
                        "name": "sessionKey",
                        "description": "unique key by which we will validate third party user through their respective service  side",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Policy"
                            }
                        }
                    },
                    "description": "Policy registration"
                },
                "responses": {
                    "201": {
                        "description": "policy created"
                    },
                    "400": {
                        "description": "invalid input, object invalid",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/categories": {
            "get": {
                "summary": "returns vehicle categories",
                "operationId": "getVehicleCategories",
                "description": "returns all registered vehicle categories",
                "parameters": [
