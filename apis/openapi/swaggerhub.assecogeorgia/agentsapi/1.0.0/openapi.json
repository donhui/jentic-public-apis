                    }
                }
            }
        },
        "/api/vehicles/manufacturers/{id}/models": {
            "get": {
                "summary": "returns car models",
                "operationId": "getCarModels",
                "description": "returns all car models specific to automaker",
                "parameters": [
                    {
                        "in": "query",
                        "name": "sessionKey",
                        "description": "unique key by which we will validate third party user through their respective service  side",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "path",
                        "name": "id",
                        "description": "pass an required automaker id, by which api returns all models associated to automaker",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "car models",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/CarModel"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "The server cannot or will not process the request due to an apparent client error"
                    }
                }
            }
        },
        "/api/vehicles": {
            "get": {
                "summary": "checks if there is any vehicles in system which matched vin code or chassis number",
                "operationId": "getVehicleBorderCross",
                "description": "check if there is any vehicles which crossed border matched to vin code or chassis number",
                "parameters": [
                    {
                        "in": "query",
                        "name": "securityKey",
                        "description": "unique key by which we will validate third party user through their respective service  side",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "vinChassisNumber",
                        "description": "pass an optional vin code or chassis number to service to check whether vehicle has crossed border",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "vehicleRegistratioNumber",
                        "description": "pass vehicle vehicle registration number to service to check whether vehicle has crossed border",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "there is one or more matches",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/VehicleInfo"
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "nothing found"
                    }
                }
            }
        }
    },
    "servers": [
