{
  "openapi": "3.0.0",
  "info": {
    "title": "Web App Regione API",
    "description": "API server della web-app per il Consiglio Regionale Veneto",
    "version": "1.0.0-oas3",
    "contact": {
      "email": "you@your-company.com"
    },
    "license": {
      "name": "Apache 2.0",
