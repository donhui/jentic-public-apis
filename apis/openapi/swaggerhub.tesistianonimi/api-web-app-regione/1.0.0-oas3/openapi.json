    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/tesistiAnonimi/API-web-app-regione/1.0.0-oas3/swagger.json"
  },
  "tags": [
    {
      "name": "utenti",
      "description": "Operazioni disponinbili a tutti gli utenti"
    }
  ],
  "paths": {
    "/categoria": {
      "get": {
        "tags": [
          "utenti"
        ],
        "summary": "categorie presenti nel database",
        "operationId": "getCategorie",
        "description": "Permette di ottenere l'elenco di tutte le categorie presenti nel database",
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    {
                      "$ref": "#/components/schemas/APIResponse"
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "utenti"
        ],
        "summary": "aggiunta di una nuova categoria al database",
        "operationId": "addCategoria",
        "description": "Permette di aggiungere una nuova categoria al database",
        "responses": {
          "200": {
            "description": "categoria aggiunta",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "400": {
            "description": "sintassi non corretta",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "409": {
            "description": "categoria gia' esistente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "description": "Nome della nuova categoria",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Categoria"
              }
            }
          }
        }
      }
    },
    "/categoria/{nomeCategoria}": {
      "get": {
        "tags": [
          "utenti"
        ],
        "summary": "elenco csv nella categoria selezionata",
        "operationId": "getCSVinCategory",
        "description": "Permette di ottenere l'elenco dei file csv appartenenti alla categoria selezionata",
        "parameters": [
          {
            "name": "nomeCategoria",
            "in": "path",
            "required": true,
            "description": "nome della categoria dei file csv da visualizzare",
            "schema": {
              "$ref": "#/components/schemas/Categoria"
            }
          },
          {
            "name": "skip",
            "in": "query",
            "required": false,
            "description": "pagina precedente o successiva",
            "schema": {
              "$ref": "#/components/schemas/Paginazione"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "quanti elementi per pagina",
            "schema": {
              "$ref": "#/components/schemas/Paginazione"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    {
                      "$ref": "#/components/schemas/APIResponse"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "risorsa non trovata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "utenti"
        ],
        "summary": "caricamento file csv nel database",
        "operationId": "loadCSV",
        "description": "Permette il caricamento del file csv nel database nella categoria selezionata",
        "parameters": [
          {
            "name": "nomeCategoria",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/Categoria"
            }
          },
          {
            "name": "nomeFile",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/Categoria"
            }
          }
        ],
        "requestBody": {
          "description": "File CSV da caricare",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CSV"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "400": {
            "description": "Un documento con lo stesso nome in questa categoria gia' presente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "417": {
            "description": "Esecuzione non riuscita",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "404": {
            "description": "Categoria non trovata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "utenti"
        ],
        "summary": "modifica nome categoria",
        "operationId": "modifyCategory",
        "description": "Permette di modificare il nome della categoria",
        "parameters": [
          {
            "name": "nomeCategoria",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/Categoria"
            }
          }
        ],
        "requestBody": {
          "description": "Nuovo nome per la categoria",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Categoria"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "400": {
            "description": "Una categoria con lo stesso nome esiste gia'",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "utenti"
        ],
        "summary": "eliminazione categoria",
        "operationId": "deleteCSV",
        "description": "Elimina in modo permanente una categoria dal database. I documenti appartenenti a tale categoria vengono automaticamente spostati nella categoria \"Nessuna Categoria\".",
        "parameters": [
          {
            "name": "nomeCategoria",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/Categoria"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "404": {
            "description": "Risorsa non trovata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        }
      }
    },
    "/categoria/{nomeCategoria}/{nomeCSV}": {
      "get": {
        "tags": [
          "utenti"
        ],
        "summary": "restituisce una parte delle righe del csv",
        "operationId": "getCSV",
        "description": "Restituisce un numero limitato di righe del csv, in base ai parametri skip e limit",
        "parameters": [
          {
            "name": "nomeCategoria",
            "in": "path",
            "required": true,
            "description": "nome della categoria dei file csv da visualizzare",
            "schema": {
              "$ref": "#/components/schemas/Categoria"
            }
          },
          {
            "name": "nomeCSV",
            "in": "path",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "nome del file csv"
          },
          {
            "name": "skip",
            "in": "query",
            "required": false,
            "description": "pagina precedente o successiva",
            "schema": {
              "$ref": "#/components/schemas/Paginazione"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "quanti elementi per pagina",
            "schema": {
              "$ref": "#/components/schemas/Paginazione"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "indiceInizio": {
                              "type": "number"
                            },
                            "indiceFine": {
                              "type": "number"
                            },
                            "csv": {
                              "$ref": "#/components/schemas/CSV"
                            }
                          }
                        }
                      }
                    },
                    {
                      "$ref": "#/components/schemas/APIResponse"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Risorsa non trovata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "utenti"
        ],
        "summary": "modifica del file csv",
        "operationId": "modificaCSV",
        "description": "Modifica del file csv. Un booleano indica se \u00e9 da modificare la categoria di appartenenza del file CSV oppure se  sono da modificare le righe.",
        "parameters": [
          {
            "name": "nomeCategoria",
            "in": "path",
            "required": true,
            "description": "nome della categoria dei file csv da visualizzare",
            "schema": {
              "$ref": "#/components/schemas/Categoria"
            }
          },
          {
            "name": "nomeCSV",
            "in": "path",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "nome del file csv"
          }
        ],
        "requestBody": {
          "description": "Modifiche da apportare al file CSV",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "modificaCategoria": {
                    "type": "boolean"
                  },
                  "data": {
                    "oneOf": [
                      {
                        "$ref": "#/components/schemas/Categoria"
                      },
                      {
                        "$ref": "#/components/schemas/ModificheCSV"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "404": {
            "description": "Risorsa non trovata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "utenti"
        ],
        "summary": "eliminazione del file csv",
        "operationId": "deleteCSV",
        "description": "Effettua la cancellazione del file csv in maniera permanente NB! non sar\u00e1 possibile recuperare il file in alcun modo",
        "parameters": [
          {
            "name": "nomeCategoria",
            "in": "path",
            "required": true,
            "description": "nome della categoria dei file csv da visualizzare",
            "schema": {
              "$ref": "#/components/schemas/Categoria"
            }
          },
          {
            "name": "nomeCSV",
            "in": "path",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "nome del file csv"
          }
        ],
        "responses": {
          "200": {
            "description": "Ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "417": {
            "description": "Esecuzione non riuscita",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        }
      }
    },
    "/grafico/{nomeCategoria}/{nomeCSV}": {
      "get": {
        "tags": [
          "utenti"
        ],
        "summary": "informazioni per grafici",
        "operationId": "graphInfo",
        "description": "Produce i dati per la visualizzazione del grafico",
        "parameters": [
          {
            "name": "nomeCategoria",
            "in": "path",
            "schema": {
              "$ref": "#/components/schemas/Categoria"
            },
            "required": true,
            "description": "nome della categoria in cui \u00e9 presente il file"
          },
          {
            "name": "nomeCSV",
            "in": "path",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "nome del file csv"
          },
          {
            "name": "colonna",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "la colonna di cui visualizzare il grafico"
          }
        ],
        "responses": {
          "200": {
            "description": "Ok",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/InfoGrafico"
                        }
                      }
                    },
                    {
                      "$ref": "#/components/schemas/APIResponse"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Risorsa non trovata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          },
          "500": {
            "description": "Errore interno",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/APIResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://api.site.com/v1",
      "description": "Production server"
    },
    {
      "url": "https://api.site-dev.com/v1",
      "description": "Development server"
    }
  ],
  "components": {
    "schemas": {
      "APIResponse": {
        "type": "object",
        "properties": {
          "codice": {
            "type": "number"
          },
          "messaggioErrore": {
            "type": "string"
          }
        }
      },
      "Categoria": {
        "type": "string",
        "example": "Energia"
      },
      "Paginazione": {
        "type": "number",
        "example": 1000
      },
      "InfoGrafico": {
        "type": "object",
        "properties": {
          "titolo": {
            "type": "string",
            "example": "nome colonna 1"
          },
          "etichette": {
            "type": "array",
            "example": [
              "label 1",
              "label 2"
            ],
            "items": {
              "type": "string"
            }
          },
          "conteggi": {
            "type": "array",
            "example": [
              46,
              58
            ],
            "items": {
              "type": "number"
            }
          }
        }
      },
      "CSV": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "value": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "boolean"
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "ModificheCSV": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": {
                  "type": "string"
                },
                "value": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "boolean"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}