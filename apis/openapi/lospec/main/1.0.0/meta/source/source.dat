{
  "openapi": "3.0.3",
  "info": {
    "title": "Lospec Palettes API",
    "description": "API for retrieving color palettes from Lospec, a website for pixel art and retro-style content. Palettes are available in JSON and CSV formats.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://lospec.com/palettes/api"
  },
  "servers": [
    {
      "url": "https://lospec.com"
    }
  ],
  "paths": {
    "/palette-list/{paletteSlug}.json": {
      "get": {
        "operationId": "getPaletteJson",
        "summary": "Get a palette in JSON format",
        "tags": ["Palettes"],
        "parameters": [
          {
            "name": "paletteSlug",
            "in": "path",
            "required": true,
            "description": "URL-friendly slug of the palette (e.g., 'greyt-bit')",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Palette data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Palette" }
              }
            }
          },
          "404": {
            "description": "Palette not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/palette-list/{paletteSlug}.csv": {
      "get": {
        "operationId": "getPaletteCsv",
        "summary": "Get a palette in CSV format",
        "tags": ["Palettes"],
        "parameters": [
          {
            "name": "paletteSlug",
            "in": "path",
            "required": true,
            "description": "URL-friendly slug of the palette (e.g., 'greyt-bit')",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Palette data as CSV (Name,Author,HexColor1,HexColor2,...)",
            "content": {
              "text/csv": {
                "schema": { "type": "string" }
              }
            }
          },
          "404": {
            "description": "Palette not found",
            "content": {
              "text/plain": {
                "schema": { "type": "string", "example": "file not found" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Palette": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Full palette name" },
          "author": { "type": "string", "description": "Author's Lospec username" },
          "colors": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Array of hex color values (without # prefix)"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "file not found" }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}