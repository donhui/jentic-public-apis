{
  "openapi": "3.0.3",
  "info": {
    "title": "PropEco Flood Risk API",
    "description": "API for assessing flood risk at a given location. Returns detailed flood risk data across England, Scotland, and Wales, including river, coastal, and surface water flood risk, flood defences, elevation data, and recorded flood events.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.propeco.io/api-reference/flood-risk/"
  },
  "servers": [
    {
      "url": "https://api.propeco.io",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Flood Risk",
      "description": "Flood risk assessment operations"
    }
  ],
  "paths": {
    "/flood-risk": {
      "get": {
        "operationId": "getFloodRisk",
        "summary": "Get flood risk assessment",
        "description": "Returns a comprehensive flood risk assessment for a given location. Location can be specified by UPRN, latitude/longitude, or British National Grid x/y coordinates.",
        "tags": ["Flood Risk"],
        "parameters": [
          {
            "name": "uprn",
            "in": "query",
            "required": false,
            "description": "Unique Property Reference Number of the property",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "latitude",
            "in": "query",
            "required": false,
            "description": "Latitude in ETRS89 / EPSG:4258 coordinate system",
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "required": false,
            "description": "Longitude in ETRS89 / EPSG:4258 coordinate system",
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "x_coord",
            "in": "query",
            "required": false,
            "description": "X coordinate in BNG / EPSG:27700 coordinate system",
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "y_coord",
            "in": "query",
            "required": false,
            "description": "Y coordinate in BNG / EPSG:27700 coordinate system",
            "schema": {
              "type": "number",
              "format": "float"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful flood risk assessment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FloodRiskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid location parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key passed via x-api-key header"
      }
    },
    "schemas": {
      "FloodRiskResponse": {
        "type": "object",
        "properties": {
          "england": {
            "$ref": "#/components/schemas/EnglandFloodRisk"
          },
          "scotland": {
            "$ref": "#/components/schemas/ScotlandFloodRisk"
          },
          "wales": {
            "$ref": "#/components/schemas/WalesFloodRisk"
          },
          "flood_defences": {
            "$ref": "#/components/schemas/FloodDefences"
          },
          "elevation": {
            "$ref": "#/components/schemas/Elevation"
          },
          "nearest_coastal_point": {
            "$ref": "#/components/schemas/NearestCoastalPoint"
          },
          "recorded_flood_events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecordedFloodEvent"
            },
            "description": "Historical flooding records for the area"
          }
        }
      },
      "EnglandFloodRisk": {
        "type": "object",
        "properties": {
          "rivers_and_seas": {
            "type": "object",
            "properties": {
              "risk_level": {
                "type": "string",
                "description": "Flood risk level from rivers and seas"
              }
            }
          },
          "surface_water": {
            "type": "object",
            "properties": {
              "risk_level": {
                "type": "string",
                "description": "Surface water flood risk level"
              }
            }
          },
          "climate_change": {
            "type": "object",
            "description": "Climate change scenario projections"
          }
        }
      },
      "ScotlandFloodRisk": {
        "type": "object",
        "properties": {
          "coastal": {
            "type": "object",
            "properties": {
              "risk_level": {
                "type": "string",
                "description": "Coastal flood risk level"
              }
            }
          },
          "river": {
            "type": "object",
            "properties": {
              "risk_level": {
                "type": "string",
                "description": "River flood risk level"
              }
            }
          },
          "surface_water": {
            "type": "object",
            "properties": {
              "risk_level": {
                "type": "string",
                "description": "Surface water flood risk level"
              }
            }
          },
          "climate_projections": {
            "type": "object",
            "description": "Climate change projections for Scotland"
          }
        }
      },
      "WalesFloodRisk": {
        "type": "object",
        "properties": {
          "coastal": {
            "type": "object",
            "properties": {
              "risk_level": {
                "type": "string",
                "description": "Coastal flood risk level"
              }
            }
          },
          "river": {
            "type": "object",
            "properties": {
              "risk_level": {
                "type": "string",
                "description": "River flood risk level"
              }
            }
          },
          "surface_water": {
            "type": "object",
            "properties": {
              "risk_level": {
                "type": "string",
                "description": "Surface water flood risk level"
              }
            }
          }
        }
      },
      "FloodDefences": {
        "type": "object",
        "properties": {
          "protected": {
            "type": "boolean",
            "description": "Whether the location is protected by flood defences"
          },
          "nearest_defence": {
            "type": "object",
            "properties": {
              "distance_meters": {
                "type": "number",
                "description": "Distance to the nearest flood defence in meters"
              },
              "type": {
                "type": "string",
                "description": "Type of flood defence"
              }
            }
          }
        }
      },
      "Elevation": {
        "type": "object",
        "properties": {
          "height_above_sea_level": {
            "type": "number",
            "description": "Height above sea level in meters"
          },
          "contour_data": {
            "type": "object",
            "description": "Surrounding contour elevation data"
          }
        }
      },
      "NearestCoastalPoint": {
        "type": "object",
        "properties": {
          "distance_meters": {
            "type": "number",
            "description": "Distance to the nearest coastal point in meters"
          },
          "latitude": {
            "type": "number",
            "format": "float",
            "description": "Latitude of the nearest coastal point"
          },
          "longitude": {
            "type": "number",
            "format": "float",
            "description": "Longitude of the nearest coastal point"
          }
        }
      },
      "RecordedFloodEvent": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "description": "Date of the recorded flood event"
          },
          "type": {
            "type": "string",
            "description": "Type of flood event"
          },
          "description": {
            "type": "string",
            "description": "Description of the flood event"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  }
}