{
  "openapi": "3.0.3",
  "info": {
    "title": "Lytx DriveCam API",
    "version": "0.0.0",
    "description": "Lytx fleet management and video telematics API. Provides access to devices, vehicles, GPS tracking, driver assignments, safety events, video, HOS, trips, DVIR, ECM, geofences, distances, groups, and users.",
    "x-jentic-source-url": "https://developer.lytx.com/docs/api-reference/"
  },
  "servers": [
    {
      "url": "https://api.lytx.com/v0",
      "description": "Lytx API v0"
    }
  ],
  "paths": {
    "/auth/user": {
      "post": {
        "operationId": "authenticateUser",
        "summary": "Authenticate user and obtain bearer token",
        "description": "Authenticates a user with username and password and returns a bearer token valid for 1 hour. Not compatible with SSO or MFA-enabled accounts.",
        "tags": [
          "Authentication"
        ],
        "servers": [
          {
            "url": "https://login.lytx.com/api",
            "description": "Lytx authentication server"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful, returns bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid credentials format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid username or password",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
