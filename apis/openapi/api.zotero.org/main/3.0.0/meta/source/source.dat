{
  "openapi": "3.0.3",
  "info": {
    "title": "Zotero Web API",
    "version": "3.0.0",
    "description": "The Zotero Web API allows read and write access to Zotero libraries. Supports items, collections, searches, and tags for both user and group libraries.",
    "x-jentic-source-url": "https://www.zotero.org/support/dev/web_api/v3/start"
  },
  "servers": [
    {
      "url": "https://api.zotero.org"
    }
  ],
  "paths": {
    "/users/{userId}/items": {
      "get": {
        "operationId": "listUserItems",
        "summary": "List items in a user library",
        "tags": ["Items"],
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          },
          {
            "$ref": "#/components/parameters/Format"
          },
          {
            "$ref": "#/components/parameters/Include"
          },
          {
            "$ref": "#/components/parameters/SearchQuery"
          },
          {
            "$ref": "#/components/parameters/QueryMode"
          },
          {
            "$ref": "#/components/parameters/Tag"
          },
          {
            "$ref": "#/components/parameters/ItemType"
          },
          {
            "$ref": "#/components/parameters/Since"
          },
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/Start"
          },
          {
            "$ref": "#/components/parameters/Sort"
          },
          {
            "$ref": "#/components/parameters/Direction"
          },
          {
            "$ref": "#/components/parameters/IncludeTrashed"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Item"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createUserItems",
        "summary": "Create items in a user library",
        "tags": ["Items"],
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ItemWriteRequest"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Items created (may include partial failures)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WriteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
