        "operationId": "listUserGroups",
        "summary": "List groups the user has access to",
        "tags": ["Groups"],
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Group"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/groups/{groupId}/items": {
      "get": {
        "operationId": "listGroupItems",
        "summary": "List items in a group library",
        "tags": ["Items"],
        "parameters": [
          {
            "$ref": "#/components/parameters/GroupId"
          },
          {
            "$ref": "#/components/parameters/Format"
          },
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/Start"
          },
          {
            "$ref": "#/components/parameters/Sort"
          },
          {
            "$ref": "#/components/parameters/Direction"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Item"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createGroupItems",
        "summary": "Create items in a group library",
        "tags": ["Items"],
        "parameters": [
          {
            "$ref": "#/components/parameters/GroupId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ItemWriteRequest"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Items created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WriteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/groups/{groupId}/collections": {
      "get": {
        "operationId": "listGroupCollections",
        "summary": "List all collections in a group library",
        "tags": ["Collections"],
        "parameters": [
          {
            "$ref": "#/components/parameters/GroupId"
          },
          {
            "$ref": "#/components/parameters/Format"
          },
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/Start"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Collection"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createGroupCollections",
        "summary": "Create collections in a group library",
        "tags": ["Collections"],
        "parameters": [
          {
            "$ref": "#/components/parameters/GroupId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CollectionWriteRequest"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collections created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WriteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/keys/{key}": {
      "get": {
        "operationId": "getKeyInfo",
        "summary": "Get API key privileges",
        "description": "Returns the privileges and associated user ID for an API key.",
        "tags": ["Keys"],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "key": {
                      "type": "string"
                    },
                    "userID": {
                      "type": "integer"
                    },
                    "username": {
                      "type": "string"
                    },
                    "access": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteKey",
        "summary": "Delete an API key",
        "tags": ["Keys"],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Key deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "UserId": {
        "name": "userId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      },
      "GroupId": {
        "name": "groupId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      },
      "ItemKey": {
        "name": "itemKey",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "CollectionKey": {
        "name": "collectionKey",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "Format": {
        "name": "format",
        "in": "query",
        "description": "Response format: json, atom, bib, keys, versions",
        "schema": {
          "type": "string",
          "enum": ["json", "atom", "bib", "keys", "versions"]
        }
      },
      "Include": {
        "name": "include",
        "in": "query",
        "description": "Additional data to include: data, bib, citation",
        "schema": {
          "type": "string"
        }
      },
      "SearchQuery": {
        "name": "q",
        "in": "query",
        "description": "Quick search string",
        "schema": {
          "type": "string"
        }
      },
      "QueryMode": {
        "name": "qmode",
        "in": "query",
        "description": "Search mode: titleCreatorYear, everything",
        "schema": {
          "type": "string"
        }
      },
      "Tag": {
        "name": "tag",
        "in": "query",
        "description": "Tag filter. Use - prefix to exclude.",
        "schema": {
          "type": "string"
        }
      },
      "ItemType": {
        "name": "itemType",
        "in": "query",
        "description": "Item type filter. Use - prefix to exclude.",
        "schema": {
          "type": "string"
        }
      },
      "Since": {
        "name": "since",
        "in": "query",
        "description": "Return only objects modified after the specified library version",
        "schema": {
          "type": "integer"
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "description": "Maximum number of results (1-100, default 25)",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 25
        }
      },
      "Start": {
        "name": "start",
        "in": "query",
        "description": "Index of first result (default 0)",
        "schema": {
          "type": "integer",
          "default": 0
        }
      },
      "Sort": {
        "name": "sort",
        "in": "query",
        "description": "Sort field: dateAdded, dateModified, title, creator, itemType, date, publisher, publicationTitle, journalAbbreviation, language, accessDate, libraryCatalog, callNumber, rights, addedBy, numItems",
        "schema": {
          "type": "string"
        }
      },
      "Direction": {
        "name": "direction",
        "in": "query",
        "description": "Sort direction: asc or desc",
        "schema": {
          "type": "string",
          "enum": ["asc", "desc"]
        }
      },
      "IncludeTrashed": {
        "name": "includeTrashed",
        "in": "query",
        "description": "Include trashed items in results",
        "schema": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "schemas": {
      "Item": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          },
          "library": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "id": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "links": {
            "type": "object"
          },
          "meta": {
            "type": "object",
            "properties": {
              "createdByUser": {
                "type": "object"
              },
              "creatorSummary": {
                "type": "string"
              },
              "parsedDate": {
                "type": "string"
              },
              "numChildren": {
                "type": "integer"
              }
            }
          },
          "data": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              },
              "version": {
                "type": "integer"
              },
              "itemType": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "creators": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Creator"
                }
              },
              "tags": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ItemTag"
                }
              },
              "collections": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "relations": {
                "type": "object"
              },
              "dateAdded": {
                "type": "string",
                "format": "date-time"
              },
              "dateModified": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "ItemWriteRequest": {
        "type": "object",
        "required": ["itemType"],
        "properties": {
          "itemType": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "creators": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Creator"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemTag"
            }
          },
          "collections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relations": {
            "type": "object"
          }
        }
      },
      "Creator": {
        "type": "object",
        "properties": {
          "creatorType": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "description": "Single-field name (use instead of firstName/lastName for institutional authors)"
          }
        }
      },
      "ItemTag": {
        "type": "object",
        "properties": {
          "tag": {
            "type": "string"
          },
          "type": {
            "type": "integer"
          }
        }
      },
      "Collection": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          },
          "library": {
            "type": "object"
          },
          "links": {
            "type": "object"
          },
          "meta": {
            "type": "object",
            "properties": {
              "numCollections": {
                "type": "integer"
              },
              "numItems": {
                "type": "integer"
              }
            }
          },
          "data": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              },
              "version": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "parentCollection": {
                "type": "string",
                "nullable": true
              },
              "relations": {
                "type": "object"
              }
            }
          }
        }
      },
      "CollectionWriteRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "parentCollection": {
            "type": "string",
            "description": "Key of parent collection, or false for top-level"
          }
        }
      },
      "Search": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "version": {
            "type": "integer"
          },
          "library": {
            "type": "object"
          },
          "data": {
            "type": "object",
            "properties": {
              "key": {
                "type": "string"
              },
              "version": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "conditions": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/SearchCondition"
                }
              }
            }
          }
        }
      },
      "SearchWriteRequest": {
        "type": "object",
        "required": ["name", "conditions"],
        "properties": {
          "name": {
            "type": "string"
          },
          "conditions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchCondition"
            }
          }
        }
      },
      "SearchCondition": {
        "type": "object",
        "properties": {
          "condition": {
            "type": "string"
          },
          "operator": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "tag": {
            "type": "string"
          },
          "meta": {
            "type": "object",
            "properties": {
              "type": {
                "type": "integer"
              },
              "numItems": {
                "type": "integer"
              }
            }
          }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "version": {
            "type": "integer"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "version": {
                "type": "integer"
              },
              "name": {
                "type": "string"
              },
              "owner": {
                "type": "integer"
              },
              "type": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      },
      "WriteResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "object",
            "additionalProperties": {
              "type": "object"
            }
          },
          "unchanged": {
            "type": "object",
            "additionalProperties": {
              "type": "object"
            }
          },
          "failed": {
            "type": "object",
            "additionalProperties": {
              "type": "object"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "Zotero-API-Key",
        "in": "header",
        "description": "API key for authentication. Can also be sent as Bearer token in Authorization header."
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}