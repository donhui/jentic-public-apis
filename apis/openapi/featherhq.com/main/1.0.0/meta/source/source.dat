                              }
                            }
                          ]
                        },
                        {
                          "nullable": true
                        }
                      ],
                      "description": "Execution metadata"
                    },
                    "variables": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "string"
                      },
                      "description": "Variables for the execution"
                    },
                    "disposition": {
                      "type": "string",
                      "nullable": true,
                      "enum": [
                        "COULD_NOT_CONNECT",
                        "NO_ANSWER",
                        "LEFT_VOICEMAIL",
                        "VOICEMAIL_DETECTED",
                        "SILENCE_TIMEOUT",
                        "BAD_NUMBER",
                        "NOT_INTERESTED",
                        "WARM_TRANSFER",
                        "CALENDLY",
                        "DNC",
                        "ENDED",
                        "FRAUD",
                        "LINE_BUSY",
                        "TEXT_CONSENT",
                        "CALL_AGAIN"
                      ],
                      "description": "Final execution disposition"
                    },
