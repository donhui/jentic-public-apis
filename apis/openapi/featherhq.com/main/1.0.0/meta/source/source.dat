        ]
      },
      "TestingLabRunScenariosRequest": {
        "type": "object",
        "properties": {
          "agent_id": {
            "type": "number"
          },
          "assistant_id": {
            "type": "string"
          },
          "scenarios": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "frequency": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "outbound_phone_number": {
            "type": "string"
          }
        },
        "required": [
          "agent_id",
          "scenarios",
          "frequency",
          "name",
          "outbound_phone_number"
        ]
      },
      "CreateCekuraMetricResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "project": {
            "type": "number",
            "nullable": true
          },
          "agent": {
            "type": "number",
            "nullable": true
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "basic",
              "custom_prompt",
              "custom_code",
              "llm_judge"
            ]
          },
          "eval_type": {
            "type": "string",
            "enum": [
              "binary_workflow_adherence",
              "binary_qualitative",
              "continuous_qualitative",
              "numeric",
              "enum"
            ]
          },
          "enum_values": {
            "nullable": true
          },
          "audio_enabled": {
            "type": "boolean"
          },
          "prompt": {
            "type": "string"
          },
          "evaluation_trigger": {
            "type": "string",
            "enum": [
              "always",
              "automatic",
              "custom"
            ]
          },
          "evaluation_trigger_prompt": {
            "type": "string"
          },
          "priority_assignment_prompt": {
            "type": "string"
          },
          "configuration": {
            "nullable": true
          },
          "overall_score": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          },
          "total_score": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          },
          "knowledge_base_files": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "nullable": true
                }
              }
            ]
          },
          "observability_enabled": {
            "type": "boolean"
          },
          "simulation_enabled": {
            "type": "boolean"
          },
          "alert_enabled": {
            "type": "boolean"
          },
          "alert_type": {
            "type": "string",
            "enum": [
              "disabled",
              "normal",
              "significant_change"
            ]
          },
          "significant_change_alert_status": {
            "type": "string",
            "enum": [
              "enabled",
              "disabled"
            ]
          },
          "significant_change_alert_direction": {
            "type": "string",
            "enum": [
              "",
              "increase",
              "decrease"
            ]
          },
          "function_name": {
            "type": "string",
            "nullable": true
          },
          "custom_code": {
            "type": "string"
          },
          "vocera_defined_metric_code": {
            "type": "string"
          },
          "agents": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "assistant_id": {
            "type": "string"
          },
          "display_order": {
            "type": "integer"
          },
          "reviews": {
            "type": "array",
            "items": {
              "nullable": true
            }
          },
          "window_size": {
            "type": "number"
          },
          "std_multiplier": {
            "type": "number"
          },
          "ewma_alpha": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "TestingLabMetricsResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/CreateCekuraMetricResponse"
        }
      },
      "CreateCekuraMetricRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the metric"
          },
          "description": {
            "type": "string",
            "description": "Description of what this metric evaluates"
          },
          "audio_enabled": {
            "type": "boolean",
            "description": "Whether this metric evaluates audio content"
          },
          "prompt": {
            "type": "string",
            "description": "The evaluation prompt used for this metric"
          },
          "agent": {
            "type": "number",
            "nullable": true,
            "description": "ID of the agent for agent-level metrics. Either agent or project must be provided."
          },
          "project": {
            "type": "number",
            "nullable": true,
            "description": "ID of the project for project-level metrics. Either agent or project must be provided."
          },
          "agents": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "description": "List of agent IDs to enable this project-level metric for. Only applicable when project is set."
          },
          "assistant_id": {
            "type": "string",
            "description": "External identifier for the assistant"
          },
          "type": {
            "type": "string",
            "enum": [
              "basic",
              "custom_prompt",
              "custom_code",
              "llm_judge"
            ],
            "description": "Type of metric"
          },
          "eval_type": {
            "type": "string",
            "enum": [
              "binary_workflow_adherence",
              "binary_qualitative",
              "continuous_qualitative",
              "numeric",
              "enum"
            ],
            "description": "Type of evaluation"
          },
          "enum_values": {
            "nullable": true,
            "description": "Possible values for enum-type metrics"
          },
          "evaluation_trigger": {
            "type": "string",
            "enum": [
              "always",
              "automatic",
              "custom"
            ],
            "description": "Evaluation trigger"
          },
          "evaluation_trigger_prompt": {
            "type": "string",
            "description": "Evaluation trigger prompt"
          }
        },
        "required": [
          "name"
        ]
      },
