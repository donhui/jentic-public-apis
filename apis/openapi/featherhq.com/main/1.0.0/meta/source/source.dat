            "type": "number"
          },
          "agent": {
            "type": "number"
          },
          "status": {
            "type": "string"
          },
          "success_rate": {
            "type": "number"
          },
          "run_as_text": {
            "type": "boolean"
          },
          "runs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "number"
                },
                "scenario": {
                  "type": "number"
                },
                "number": {
                  "type": "string"
                }
              },
              "required": [
