                              "NO_ANSWER",
                              "LEFT_VOICEMAIL",
                              "VOICEMAIL_DETECTED",
                              "SILENCE_TIMEOUT",
                              "BAD_NUMBER",
                              "NOT_INTERESTED",
                              "WARM_TRANSFER",
                              "CALENDLY",
                              "DNC",
