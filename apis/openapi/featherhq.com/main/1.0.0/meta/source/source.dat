    "/api/v1/email-domains": {
      "post": {
        "tags": [
          "Email Domains"
        ],
        "summary": "Create an email domain",
        "description": "Register a new subdomain with Resend and return the DNS records the customer must add to their DNS provider.",
        "security": [
          {
            "ApiKey": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subdomain": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 63,
                    "pattern": "^[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?$"
                  },
                  "domain": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[a-zA-Z0-9][a-zA-Z0-9-.]+\\.[a-zA-Z]{2,}$"
                  }
                },
                "required": [
                  "subdomain",
                  "domain"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Email domain created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "emailDomain": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "format": "uuid"
                        },
                        "organizationId": {
                          "type": "string"
                        },
                        "subdomain": {
                          "type": "string"
                        },
                        "domain": {
                          "type": "string"
                        },
                        "fullDomain": {
                          "type": "string"
                        },
                        "emailProvider": {
                          "type": "string",
                          "enum": [
                            "RESEND"
                          ]
                        },
                        "providerDomainId": {
                          "type": "string",
                          "nullable": true
                        },
                        "mxRecord": {
                          "type": "string",
                          "nullable": true
                        },
                        "mxPriority": {
                          "type": "integer",
                          "nullable": true
                        },
                        "spfHostname": {
                          "type": "string",
                          "nullable": true
                        },
                        "spfValue": {
                          "type": "string",
                          "nullable": true
                        },
                        "dkimSelector": {
                          "type": "string",
                          "nullable": true
                        },
                        "dkimHostname": {
                          "type": "string",
                          "nullable": true
                        },
                        "dkimValue": {
                          "type": "string",
                          "nullable": true
                        },
                        "cnameValue": {
                          "type": "string",
                          "nullable": true
                        },
                        "cnamePriority": {
                          "type": "integer",
                          "nullable": true
                        },
                        "mxVerified": {
                          "type": "boolean"
                        },
                        "spfVerified": {
                          "type": "boolean"
                        },
                        "dkimVerified": {
                          "type": "boolean"
                        },
                        "cnameVerified": {
                          "type": "boolean"
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "PENDING",
                            "VERIFYING",
                            "VERIFIED",
                            "FAILED",
                            "SUSPENDED"
                          ]
                        },
                        "verifiedAt": {
                          "type": "string",
                          "nullable": true
                        },
                        "lastCheckedAt": {
                          "type": "string",
                          "nullable": true
                        },
                        "createdAt": {
                          "type": "string"
                        },
                        "updatedAt": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "id",
                        "organizationId",
                        "subdomain",
                        "domain",
                        "fullDomain",
                        "emailProvider",
                        "providerDomainId",
                        "mxRecord",
                        "mxPriority",
                        "spfHostname",
                        "spfValue",
                        "dkimSelector",
                        "dkimHostname",
                        "dkimValue",
                        "cnameValue",
                        "cnamePriority",
                        "mxVerified",
                        "spfVerified",
                        "dkimVerified",
                        "cnameVerified",
                        "status",
                        "verifiedAt",
                        "lastCheckedAt",
                        "createdAt",
                        "updatedAt"
                      ]
                    }
                  },
                  "required": [
                    "emailDomain"
                  ]
                }
              }
            }
