                      "description": "TCPA schedule - applies to borrower local timezone",
                      "example": {
                        "monday": {
                          "enabled": true,
                          "timeRanges": [
                            {
                              "startHour": 8,
                              "startMinute": 0,
                              "endHour": 21,
                              "endMinute": 0
                            }
                          ]
                        },
                        "tuesday": {
                          "enabled": true,
