                            "format": "uuid",
                            "description": "Agent ID"
                          },
                          "agentCall": {
                            "type": "object",
                            "nullable": true,
                            "properties": {
                              "id": {
                                "type": "string",
                                "format": "uuid"
                              },
                              "status": {
                                "type": "string"
                              },
                              "callStartedAt": {
                                "type": "string",
                                "nullable": true
                              },
                              "callEndedAt": {
                                "type": "string",
                                "nullable": true
                              },
                              "callDuration": {
                                "type": "integer"
                              },
                              "callEndedReason": {
                                "type": "string",
                                "nullable": true,
                                "enum": [
                                  "COULD_NOT_CONNECT",
                                  "NO_ANSWER",
                                  "LEFT_VOICEMAIL",
                                  "VOICEMAIL_DETECTED",
                                  "SILENCE_TIMEOUT",
                                  "BAD_NUMBER",
                                  "NOT_INTERESTED",
                                  "WARM_TRANSFER",
                                  "CALENDLY",
                                  "DNC",
                                  "ENDED",
                                  "FRAUD",
                                  "LINE_BUSY",
                                  "TEXT_CONSENT",
                                  "CALL_AGAIN"
                                ]
                              },
                              "recordingUrl": {
                                "type": "string",
                                "nullable": true
                              },
                              "summary": {
