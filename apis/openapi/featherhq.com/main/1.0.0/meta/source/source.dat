                                "COULD_NOT_CONNECT",
                                "NO_ANSWER",
                                "LEFT_VOICEMAIL",
                                "VOICEMAIL_DETECTED",
                                "SILENCE_TIMEOUT",
                                "BAD_NUMBER",
                                "NOT_INTERESTED",
                                "WARM_TRANSFER",
                                "CALENDLY",
                                "DNC",
                                "ENDED",
                                "FRAUD",
                                "LINE_BUSY",
                                "TEXT_CONSENT",
                                "CALL_AGAIN"
                              ]
                            },
                            "description": "Workflow finish conditions"
                          },
                          "startedAt": {
                            "type": "string",
                            "nullable": true,
                            "description": "Step start timestamp"
                          },
                          "completedAt": {
                            "type": "string",
                            "nullable": true,
                            "description": "Step completion timestamp"
                          },
                          "leaveVoicemail": {
                            "type": "boolean",
                            "description": "Whether to leave voicemail"
                          },
                          "disposition": {
                            "type": "string",
                            "nullable": true,
                            "enum": [
