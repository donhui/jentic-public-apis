{
  "openapi": "3.0.3",
  "info": {
    "title": "Twist API",
    "version": "3.0",
    "description": "REST API for the Twist team communication platform. Manage workspaces, channels, threads, comments, conversations, and messages.",
    "x-jentic-source-url": "https://developer.twist.com/v3/"
  },
  "servers": [
    {
      "url": "https://api.twist.com/api/v3"
    }
  ],
  "paths": {
    "/users/login": {
      "post": {
        "operationId": "loginUser",
        "tags": ["Users"],
        "summary": "Authenticate a user and obtain a token",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "set_session_cookie": { "type": "boolean" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/users/logout": {
      "post": {
        "operationId": "logoutUser",
        "tags": ["Users"],
        "summary": "End user session",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logged out successfully" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/get_session_user": {
      "get": {
        "operationId": "getSessionUser",
        "tags": ["Users"],
        "summary": "Get the currently authenticated user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/update": {
      "post": {
        "operationId": "updateUser",
        "tags": ["Users"],
        "summary": "Update user settings",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "default_workspace": { "type": "integer" },
                  "profession": { "type": "string" },
                  "contact_info": { "type": "string" },
                  "timezone": { "type": "string" },
                  "away_mode": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/update_password": {
      "post": {
        "operationId": "updatePassword",
        "tags": ["Users"],
        "summary": "Change user password",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "new_password": { "type": "string" }
                },
                "required": ["new_password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/update_avatar": {
      "post": {
        "operationId": "updateAvatar",
        "tags": ["Users"],
        "summary": "Upload a new profile picture",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": { "type": "string", "format": "binary" }
                },
                "required": ["image"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Avatar updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/invalidate_token": {
      "post": {
        "operationId": "invalidateToken",
        "tags": ["Users"],
        "summary": "Revoke current token and generate a new one",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Token invalidated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/validate_token": {
      "post": {
        "operationId": "validateToken",
        "tags": ["Users"],
        "summary": "Verify if a token is valid",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": { "type": "string" }
                },
                "required": ["token"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token is valid" },
          "400": { "description": "Bad request" },
          "401": { "description": "Token is invalid" }
        }
      }
    },
    "/users/reset_password": {
      "post": {
        "operationId": "resetPassword",
        "tags": ["Users"],
        "summary": "Send a password reset email",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Reset email sent" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/delete": {
      "post": {
        "operationId": "deleteUser",
        "tags": ["Users"],
        "summary": "Permanently delete user account",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": { "type": "string" }
                },
                "required": ["password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/workspaces/getone": {
      "get": {
        "operationId": "getWorkspace",
        "tags": ["Workspaces"],
        "summary": "Retrieve a specific workspace by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Workspace details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workspace" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/workspaces/get": {
      "get": {
        "operationId": "listWorkspaces",
        "tags": ["Workspaces"],
        "summary": "List all user workspaces",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of workspaces",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Workspace" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/workspaces/get_default": {
      "get": {
        "operationId": "getDefaultWorkspace",
        "tags": ["Workspaces"],
        "summary": "Fetch the user's default workspace",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Default workspace",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workspace" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/workspaces/add": {
      "post": {
        "operationId": "createWorkspace",
        "tags": ["Workspaces"],
        "summary": "Create a new workspace",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" }
                },
                "required": ["name"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workspace created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workspace" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/workspaces/remove": {
      "post": {
        "operationId": "removeWorkspace",
        "tags": ["Workspaces"],
        "summary": "Delete a workspace and all its data",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Workspace removed" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/channels/getone": {
      "get": {
        "operationId": "getChannel",
        "tags": ["Channels"],
        "summary": "Retrieve a single channel by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Channel details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Channel" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/channels/get": {
      "get": {
        "operationId": "listChannels",
        "tags": ["Channels"],
        "summary": "List all channels in a workspace",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "workspace_id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of channels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Channel" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/channels/add": {
      "post": {
        "operationId": "createChannel",
        "tags": ["Channels"],
        "summary": "Create a new channel",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "workspace_id": { "type": "integer" },
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "color": { "type": "integer" },
                  "public": { "type": "boolean" },
                  "user_ids": { "type": "string", "description": "JSON array of user IDs" }
                },
                "required": ["workspace_id", "name"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Channel created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Channel" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/channels/update": {
      "post": {
        "operationId": "updateChannel",
        "tags": ["Channels"],
        "summary": "Modify an existing channel",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "color": { "type": "integer" },
                  "public": { "type": "boolean" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Channel updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Channel" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/channels/archive": {
      "post": {
        "operationId": "archiveChannel",
        "tags": ["Channels"],
        "summary": "Archive a channel",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Channel archived" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/channels/remove": {
      "post": {
        "operationId": "removeChannel",
        "tags": ["Channels"],
        "summary": "Delete a channel (must be archived first)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Channel removed" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/threads/getone": {
      "get": {
        "operationId": "getThread",
        "tags": ["Threads"],
        "summary": "Retrieve a single thread by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Thread details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Thread" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/threads/get": {
      "get": {
        "operationId": "listThreads",
        "tags": ["Threads"],
        "summary": "List all threads in a channel",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "channel_id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of threads",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Thread" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/threads/add": {
      "post": {
        "operationId": "createThread",
        "tags": ["Threads"],
        "summary": "Create a new thread",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "channel_id": { "type": "integer" },
                  "title": { "type": "string" },
                  "content": { "type": "string" },
                  "attachments": { "type": "string" },
                  "recipients": { "type": "string" }
                },
                "required": ["channel_id", "title", "content"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Thread created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Thread" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/threads/update": {
      "post": {
        "operationId": "updateThread",
        "tags": ["Threads"],
        "summary": "Modify an existing thread",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "title": { "type": "string" },
                  "content": { "type": "string" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Thread updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Thread" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/threads/remove": {
      "post": {
        "operationId": "removeThread",
        "tags": ["Threads"],
        "summary": "Delete a thread",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Thread removed" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/threads/mark_read": {
      "post": {
        "operationId": "markThreadRead",
        "tags": ["Threads"],
        "summary": "Mark a thread as read",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Thread marked as read" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/comments/getone": {
      "get": {
        "operationId": "getComment",
        "tags": ["Comments"],
        "summary": "Retrieve a single comment by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Comment details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Comment" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/comments/get": {
      "get": {
        "operationId": "listComments",
        "tags": ["Comments"],
        "summary": "List all comments for a thread",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "thread_id", "in": "query", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of comments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Comment" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/comments/add": {
      "post": {
        "operationId": "addComment",
        "tags": ["Comments"],
        "summary": "Add a comment to a thread",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "thread_id": { "type": "integer" },
                  "content": { "type": "string" },
                  "attachments": { "type": "string" },
                  "recipients": { "type": "string" }
                },
                "required": ["thread_id", "content"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comment added",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Comment" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/comments/update": {
      "post": {
        "operationId": "updateComment",
        "tags": ["Comments"],
        "summary": "Modify an existing comment",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" },
                  "content": { "type": "string" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Comment updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Comment" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/comments/remove": {
      "post": {
        "operationId": "removeComment",
        "tags": ["Comments"],
        "summary": "Delete a comment",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "integer" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Comment removed" },
