  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2 Bearer token"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "default_workspace": { "type": "integer" },
          "profession": { "type": "string" },
          "contact_info": { "type": "string" },
          "timezone": { "type": "string" },
          "avatar_id": { "type": "string" },
          "token": { "type": "string" }
        }
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "creator": { "type": "integer" },
          "created_ts": { "type": "integer" }
        }
      },
      "Channel": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "workspace_id": { "type": "integer" },
          "creator": { "type": "integer" },
          "color": { "type": "integer" },
          "public": { "type": "boolean" },
          "archived": { "type": "boolean" },
          "created_ts": { "type": "integer" }
        }
      },
      "Thread": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "content": { "type": "string" },
          "channel_id": { "type": "integer" },
          "workspace_id": { "type": "integer" },
          "creator": { "type": "integer" },
          "created_ts": { "type": "integer" },
          "last_updated_ts": { "type": "integer" },
          "comment_count": { "type": "integer" },
          "is_starred": { "type": "boolean" },
          "is_pinned": { "type": "boolean" }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "content": { "type": "string" },
          "thread_id": { "type": "integer" },
          "creator": { "type": "integer" },
          "created_ts": { "type": "integer" },
          "attachments": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "Conversation": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "workspace_id": { "type": "integer" },
          "creator": { "type": "integer" },
          "created_ts": { "type": "integer" },
          "last_message_ts": { "type": "integer" },
          "participant_ids": {
            "type": "array",
            "items": { "type": "integer" }
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "content": { "type": "string" },
          "conversation_id": { "type": "integer" },
          "creator": { "type": "integer" },
          "created_ts": { "type": "integer" },
          "attachments": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}