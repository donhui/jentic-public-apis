{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.2",
    "title": "Bal\u00edkoBOXy - Parcel API",
    "description": "API syst\u00e9mu Bal\u00edkoBOXy Slovensk\u00e9 po\u0161ty pro p\u0159ed\u00e1v\u00e1n\u00ed informac\u00ed o z\u00e1silk\u00e1ch\n\nChangelog:\n- v1.0.1 (20.9.2022): Dopln\u011bny URL pro testovac\u00ed prost\u0159ed\u00ed Datasys a\n  produk\u010dn\u00ed prost\u0159ed\u00ed Slovensk\u00e9 po\u0161ty\n- v1.0.2 (19.10.2022): Opraven p\u0159\u00edklad pro POST /tenant/{tenantId}/parcel\n",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/datasys/balikoboxy-parcel-management/1.0.2/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/datasys/balikoboxy-parcel-management/1.0.2"
    },
    {
      "description": "Testovac\u00ed prost\u0159ed\u00ed Datasys",
      "url": "https://tdsSPboxSrv2012.sp.local:8443/adbserver/services/balikoboxy-parcel-management/1"
    },
    {
      "description": "Produk\u010dn\u00ed prost\u0159ed\u00ed Slovensk\u00e9 po\u0161ty",
      "url": "https://aptaps1.slposta.sk:8443/adbserver/services/balikoboxy-parcel-management/1"
    }
  ],
  "tags": [
    {
      "name": "parcel",
      "description": "Spr\u00e1va z\u00e1silek"
    }
  ],
  "paths": {
    "/tenant/{tenantId}/parcel": {
      "post": {
        "operationId": "postParcels",
        "tags": [
          "parcel"
        ],
        "summary": "Vytvo\u0159\u00ed nebo aktualizuje informace o z\u00e1silk\u00e1ch",
        "description": "Operace umo\u017e\u0148uje d\u00e1vkov\u00e9 p\u0159ed\u00e1n\u00ed informac\u00ed o v\u00edce z\u00e1silk\u00e1ch najednou.",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Parcel"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Vr\u00e1cen seznam v\u00fdsledk\u016f zpracov\u00e1n\u00ed jednotliv\u00fdch z\u00e1silek",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostParcelResponse"
                }
              }
            }
          },
          "400": {
            "description": "Chybn\u00fd po\u017eadavek",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Neplatn\u00e9 p\u0159ihla\u0161ovac\u00ed \u00fadaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostate\u010dn\u00e9 opr\u00e1vn\u011bn\u00ed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba slu\u017eby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/tenant/{tenantId}/parcel/{barcode}": {
      "put": {
        "operationId": "putParcel",
        "tags": [
          "parcel"
        ],
        "summary": "Vytvo\u0159\u00ed nebo aktualizuje informace o z\u00e1silce",
        "description": "Po ulo\u017een\u00ed z\u00e1silky do Bal\u00edkoBOXu je ji\u017e mo\u017en\u00e9 m\u011bnit pouze k\u00f3d pro vyzvednut\u00ed.",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "$ref": "#/components/parameters/barcode"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Parcel"
              }
            }
          },
          "description": "Atribut _barcode_ se mus\u00ed shodovat s parametrem _barcode_ v URL po\u017eadavku."
        },
        "responses": {
          "200": {
            "description": "Aktualizov\u00e1na existuj\u00edc\u00ed z\u00e1silka"
          },
          "201": {
            "description": "Vytvo\u0159ena nov\u00e1 z\u00e1silka"
          },
          "400": {
            "description": "Chybn\u00fd po\u017eadavek",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Neplatn\u00e9 p\u0159ihla\u0161ovac\u00ed \u00fadaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostate\u010dn\u00e9 opr\u00e1vn\u011bn\u00ed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba slu\u017eby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "tenantId": {
        "name": "tenantId",
        "description": "ID tenanta\n\nV p\u0159\u00edpad\u011b DPD je ID tenanta \"dpd\"\n",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "dpd"
      },
      "barcode": {
        "name": "barcode",
        "description": "\u010c\u00e1rov\u00fd k\u00f3d z\u00e1silky",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Parcel": {
        "type": "object",
        "required": [
          "barcode",
          "rackPostCodes"
        ],
        "properties": {
          "barcode": {
            "description": "\u010c\u00e1rov\u00fd k\u00f3d z\u00e1silky\n\nV p\u0159\u00edpad\u011b z\u00e1silek DPD 14m\u00edstn\u00fd \u010d\u00edseln\u00fd k\u00f3d\n",
            "type": "string",
            "maxLength": 50,
            "example": "01234567890123"
          },
          "senderName": {
            "description": "Jm\u00e9no odes\u00edlatele",
            "type": "string",
            "example": "Jan Nov\u00e1k"
          },
          "recipientName": {
            "description": "Jm\u00e9no adres\u00e1ta",
            "type": "string",
            "maxLength": 100,
            "example": "Jan Nov\u00e1k"
          },
          "price": {
            "description": "Cena dob\u00edrky v eurech. Pokud je z\u00e1silka bez dob\u00edrky, atribut je bu\u010f neuveden nebo nulov\u00fd.",
            "type": "number",
            "minimum": 0,
            "example": "12.34"
          },
          "rackPostCodes": {
            "description": "Seznam PS\u010c Bal\u00edkoBOX\u016f, do kter\u00fdch m\u016f\u017ee b\u00fdt z\u00e1silka ulo\u017eena. PS\u010c m\u00e1 5 nebo 6 \u010d\u00edslic.",
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^\\d{5,6}$",
              "example": "012345"
            },
            "minItems": 1
          },
          "pickUpCode": {
            "description": "K\u00f3d pro vyzvednut\u00ed z\u00e1silky.\n\nK\u00f3d m\u016f\u017ee b\u00fdt nastaven i dodate\u010dn\u011b, typicky a\u017e po vlo\u017een\u00ed z\u00e1silky do boxu. Dokud nem\u00e1 z\u00e1silka k\u00f3d pro vyzvednut\u00ed nastaven, nem\u016f\u017ee si ji adres\u00e1t z boxu vyzvednout.\n",
            "type": "string",
            "maxLength": 8,
            "example": "D1047954"
          }
        }
      },
      "PostParcelResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "barcode",
            "status"
          ],
          "properties": {
            "barcode": {
              "description": "\u010c\u00e1rov\u00fd k\u00f3d z\u00e1silky",
              "type": "string",
              "maxLength": 50,
              "example": "01234567890123"
            },
            "status": {
              "description": "Stavov\u00fd k\u00f3d\n- 200: Aktualizov\u00e1na existuj\u00edc\u00ed z\u00e1silka\n- 201: Vytvo\u0159ena nov\u00e1 z\u00e1silka\n- 400: Neplatn\u00e1 data z\u00e1silky\n- 500: Chyba slu\u017eby\n",
              "type": "integer",
              "example": 400
            },
            "error": {
              "description": "Kr\u00e1t\u00fd \u010diteln\u00fd n\u00e1zev druhu chyby ur\u010den\u00fd pro techniky. N\u00e1zev by se nem\u011bl m\u011bnit pro jednotliv\u00e9 p\u0159\u00edpady.",
              "type": "string",
              "example": "Non-existing delivery box"
            },
            "message": {
              "description": "\u010citeln\u00fd popis d\u016fvodu konkr\u00e9tn\u00ed chyby ur\u010den\u00fd pro techniky.",
              "type": "string",
              "example": "Delivery box with postcode 47002 not found."
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "title",
          "message"
        ],
        "properties": {
          "error": {
            "description": "Kr\u00e1t\u00fd \u010diteln\u00fd n\u00e1zev druhu chyby ur\u010den\u00fd pro techniky. N\u00e1zev by se nem\u011bl m\u011bnit pro jednotliv\u00e9 p\u0159\u00edpady.",
            "type": "string",
            "example": "Non-existing delivery box"
          },
          "message": {
            "description": "\u010citeln\u00fd popis d\u016fvodu konkr\u00e9tn\u00ed chyby ur\u010den\u00fd pro techniky.",
            "type": "string",
            "example": "Delivery box with postcode 47002 not found."
          }
        }
      }
    }
  }
}