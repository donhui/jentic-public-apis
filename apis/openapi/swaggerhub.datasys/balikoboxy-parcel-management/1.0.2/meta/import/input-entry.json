  "paths": {
    "/tenant/{tenantId}/parcel": {
      "post": {
        "operationId": "postParcels",
        "tags": [
          "parcel"
        ],
        "summary": "Vytvoří nebo aktualizuje informace o zásilkách",
        "description": "Operace umožňuje dávkové předání informací o více zásilkách najednou.",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Parcel"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Vrácen seznam výsledků zpracování jednotlivých zásilek",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostParcelResponse"
                }
              }
            }
          },
          "400": {
            "description": "Chybný požadavek",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Neplatné přihlašovací údaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostatečné oprávnění",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba služby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/tenant/{tenantId}/parcel/{barcode}": {
      "put": {
        "operationId": "putParcel",
        "tags": [
          "parcel"
        ],
        "summary": "Vytvoří nebo aktualizuje informace o zásilce",
        "description": "Po uložení zásilky do BalíkoBOXu je již možné měnit pouze kód pro vyzvednutí.",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "$ref": "#/components/parameters/barcode"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Parcel"
              }
            }
          },
          "description": "Atribut _barcode_ se musí shodovat s parametrem _barcode_ v URL požadavku."
        },
        "responses": {
          "200": {
            "description": "Aktualizována existující zásilka"
          },
          "201": {
            "description": "Vytvořena nová zásilka"
          },
          "400": {
            "description": "Chybný požadavek",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Neplatné přihlašovací údaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostatečné oprávnění",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba služby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "tenantId": {
        "name": "tenantId",
        "description": "ID tenanta\n\nV případě DPD je ID tenanta \"dpd\"\n",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "dpd"
      },
      "barcode": {
        "name": "barcode",
        "description": "Čárový kód zásilky",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Parcel": {
        "type": "object",
        "required": [
          "barcode",
          "rackPostCodes"
        ],
        "properties": {
          "barcode": {
            "description": "Čárový kód zásilky\n\nV případě zásilek DPD 14místný číselný kód\n",
            "type": "string",
            "maxLength": 50,
            "example": "01234567890123"
          },
          "senderName": {
            "description": "Jméno odesílatele",
            "type": "string",
            "example": "Jan Novák"
          },
          "recipientName": {
            "description": "Jméno adresáta",
            "type": "string",
            "maxLength": 100,
            "example": "Jan Novák"
          },
          "price": {
            "description": "Cena dobírky v eurech. Pokud je zásilka bez dobírky, atribut je buď neuveden nebo nulový.",
            "type": "number",
            "minimum": 0,
            "example": "12.34"
          },
          "rackPostCodes": {
            "description": "Seznam PSČ BalíkoBOXů, do kterých může být zásilka uložena. PSČ má 5 nebo 6 číslic.",
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^\\d{5,6}$",
              "example": "012345"
            },
            "minItems": 1
          },
          "pickUpCode": {
            "description": "Kód pro vyzvednutí zásilky.\n\nKód může být nastaven i dodatečně, typicky až po vložení zásilky do boxu. Dokud nemá zásilka kód pro vyzvednutí nastaven, nemůže si ji adresát z boxu vyzvednout.\n",
            "type": "string",
            "maxLength": 8,
            "example": "D1047954"
          }
        }
      },
      "PostParcelResponse": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "barcode",
            "status"
          ],
          "properties": {
            "barcode": {
              "description": "Čárový kód zásilky",
              "type": "string",
              "maxLength": 50,
              "example": "01234567890123"
            },
            "status": {
              "description": "Stavový kód\n- 200: Aktualizována existující zásilka\n- 201: Vytvořena nová zásilka\n- 400: Neplatná data zásilky\n- 500: Chyba služby\n",
              "type": "integer",
              "example": 400
            },
            "error": {
              "description": "Krátý čitelný název druhu chyby určený pro techniky. Název by se neměl měnit pro jednotlivé případy.",
              "type": "string",
              "example": "Non-existing delivery box"
            },
            "message": {
              "description": "Čitelný popis důvodu konkrétní chyby určený pro techniky.",
              "type": "string",
              "example": "Delivery box with postcode 47002 not found."
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "title",
          "message"
        ],
        "properties": {
          "error": {
            "description": "Krátý čitelný název druhu chyby určený pro techniky. Název by se neměl měnit pro jednotlivé případy.",
            "type": "string",
            "example": "Non-existing delivery box"
          },
          "message": {
            "description": "Čitelný popis důvodu konkrétní chyby určený pro techniky.",
            "type": "string",
            "example": "Delivery box with postcode 47002 not found."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "parcel",
      "description": "Správa zásilek"
    }
  ]
}