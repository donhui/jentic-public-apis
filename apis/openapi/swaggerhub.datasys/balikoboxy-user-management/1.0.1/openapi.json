    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "user",
      "description": "Spr\u00e1va u\u017eivatelsk\u00fdch \u00fa\u010dt\u016f"
    }
  ],
  "paths": {
    "/tenant/{tenantId}/user": {
      "get": {
        "operationId": "getUser",
        "tags": [
          "user"
        ],
        "summary": "Vr\u00e1t\u00ed seznam u\u017eivatelsk\u00fdch \u00fa\u010dt\u016f",
        "description": "Vr\u00e1cen\u00e9 informace o \u00fa\u010dtech neobsahuj\u00ed hesla (atribut _password_)",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          }
        ],
        "responses": {
          "200": {
            "description": "Vr\u00e1cen seznam \u00fa\u010dt\u016f",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Neplatn\u00e9 p\u0159ihla\u0161ovac\u00ed \u00fadaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostate\u010dn\u00e9 opr\u00e1vn\u011bn\u00ed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba slu\u017eby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/tenant/{tenantId}/user/{userName}": {
      "put": {
        "operationId": "putUser",
        "tags": [
          "user"
        ],
        "summary": "Vytvo\u0159\u00ed nebo aktualizuje \u00fa\u010det u\u017eivatele",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "$ref": "#/components/parameters/userName"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          },
          "description": "Atribut _userName_ se mus\u00ed se shodovat s parametrem _userName_ v URL po\u017eadavku.\n"
        },
        "responses": {
          "200": {
            "description": "Aktualizov\u00e1n existuj\u00edc\u00ed \u00fa\u010det"
          },
          "201": {
            "description": "Vytvo\u0159en nov\u00fd \u00fa\u010det"
          },
          "400": {
            "description": "Chybn\u00fd po\u017eadavek",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Neplatn\u00e9 p\u0159ihla\u0161ovac\u00ed \u00fadaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostate\u010dn\u00e9 opr\u00e1vn\u011bn\u00ed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba slu\u017eby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "tags": [
          "user"
        ],
        "summary": "Sma\u017ee \u00fa\u010det u\u017eivatele",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "$ref": "#/components/parameters/userName"
          }
        ],
        "responses": {
          "200": {
            "description": "\u00da\u010det byl smaz\u00e1n"
          },
          "401": {
            "description": "Neplatn\u00e9 p\u0159ihla\u0161ovac\u00ed \u00fadaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostate\u010dn\u00e9 opr\u00e1vn\u011bn\u00ed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "\u00da\u010det neexistuje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba slu\u017eby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "parameters": {
      "tenantId": {
        "name": "tenantId",
        "description": "ID tenanta\n\nV p\u0159\u00edpad\u011b DPD je ID tenanta \"dpd\"\n",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "dpd"
      },
      "userName": {
        "name": "userName",
        "description": "P\u0159ihla\u0161ovac\u00ed jm\u00e9no u\u017eivatele\n\nV p\u0159\u00edpad\u011b kur\u00fdr\u016f DPD 9m\u00edstn\u00e9 osobn\u00ed \u010d\u00edslo\n",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "required": [
          "userName",
          "password"
        ],
        "properties": {
          "userName": {
            "description": "P\u0159ihla\u0161ovac\u00ed jm\u00e9no u\u017eivatele\n\nV p\u0159\u00edpad\u011b kur\u00fdr\u016f DPD 9m\u00edstn\u00e9 osobn\u00ed \u010d\u00edslo\n",
            "type": "string",
            "minLength": 1,
            "example": 123456789
          },
          "displayName": {
            "description": "Jm\u00e9no u\u017eivatele",
            "type": "string",
            "minLength": 1,
            "example": "Jan Nov\u00e1k"
          },
          "password": {
            "description": "Heslo pro p\u0159ihl\u00e1\u0161en\u00ed\n\nV p\u0159\u00edpad\u011b kur\u00fdr\u016f DPD 5m\u00edstn\u00fd \u010d\u00edseln\u00fd PIN\n",
            "type": "string",
            "format": "password",
            "example": 12345
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "title",
          "message"
        ],
        "properties": {
          "error": {
            "description": "Kr\u00e1t\u00fd \u010diteln\u00fd n\u00e1zev druhu chyby ur\u010den\u00fd pro techniky. N\u00e1zev by se nem\u011bl m\u011bnit pro jednotliv\u00e9 p\u0159\u00edpady.",
            "type": "string",
            "example": "Non-existing user"
          },
          "message": {
            "description": "\u010citeln\u00fd popis d\u016fvodu konkr\u00e9tn\u00ed chyby ur\u010den\u00fd pro techniky.",
            "type": "string",
            "example": "User '123456789' not found."
          }
        }
      }
    }
  }
}