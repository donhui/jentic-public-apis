{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.1",
    "title": "BalíkoBOXy - User Management API",
    "description": "API systému BalíkoBOXy Slovenské pošty pro správu uživatelských účtů operátorů boxů.\n\nChangelog:\n- v1.0.1 (20.9.2022): Doplněny URL pro testovací prostředí Datasys a\n  produkční prostředí Slovenské pošty\n",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/datasys/balikoboxy-user-management/1.0.1/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/datasys/balikoboxy-user-management/1.0.1"
    },
    {
      "description": "Testovací prostředí Datasys",
      "url": "https://tdsSPboxSrv2012.sp.local:8443/adbserver/services/balikoboxy-user-management/1"
    },
    {
      "description": "Produkční prostředí Slovenské pošty",
      "url": "https://aptaps1.slposta.sk:8443/adbserver/services/balikoboxy-user-management/1"
    }
  ],
  "paths": {
    "/tenant/{tenantId}/user": {
      "get": {
        "operationId": "getUser",
        "tags": [
          "user"
        ],
        "summary": "Vrátí seznam uživatelských účtů",
        "description": "Vrácené informace o účtech neobsahují hesla (atribut _password_)",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          }
        ],
        "responses": {
          "200": {
            "description": "Vrácen seznam účtů",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Neplatné přihlašovací údaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostatečné oprávnění",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba služby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/tenant/{tenantId}/user/{userName}": {
      "put": {
        "operationId": "putUser",
        "tags": [
          "user"
        ],
        "summary": "Vytvoří nebo aktualizuje účet uživatele",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "$ref": "#/components/parameters/userName"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          },
          "description": "Atribut _userName_ se musí se shodovat s parametrem _userName_ v URL požadavku.\n"
        },
        "responses": {
          "200": {
            "description": "Aktualizován existující účet"
          },
          "201": {
            "description": "Vytvořen nový účet"
          },
          "400": {
            "description": "Chybný požadavek",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Neplatné přihlašovací údaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostatečné oprávnění",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba služby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "tags": [
          "user"
        ],
        "summary": "Smaže účet uživatele",
        "parameters": [
          {
            "$ref": "#/components/parameters/tenantId"
          },
          {
            "$ref": "#/components/parameters/userName"
          }
        ],
        "responses": {
          "200": {
            "description": "Účet byl smazán"
          },
          "401": {
            "description": "Neplatné přihlašovací údaje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Nedostatečné oprávnění",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Účet neexistuje",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Chyba služby",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "parameters": {
      "tenantId": {
        "name": "tenantId",
        "description": "ID tenanta\n\nV případě DPD je ID tenanta \"dpd\"\n",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "dpd"
      },
      "userName": {
        "name": "userName",
        "description": "Přihlašovací jméno uživatele\n\nV případě kurýrů DPD 9místné osobní číslo\n",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "required": [
          "userName",
          "password"
        ],
        "properties": {
          "userName": {
            "description": "Přihlašovací jméno uživatele\n\nV případě kurýrů DPD 9místné osobní číslo\n",
            "type": "string",
            "minLength": 1,
            "example": 123456789
          },
          "displayName": {
            "description": "Jméno uživatele",
            "type": "string",
            "minLength": 1,
            "example": "Jan Novák"
          },
          "password": {
            "description": "Heslo pro přihlášení\n\nV případě kurýrů DPD 5místný číselný PIN\n",
            "type": "string",
            "format": "password",
            "example": 12345
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "title",
          "message"
        ],
        "properties": {
          "error": {
            "description": "Krátý čitelný název druhu chyby určený pro techniky. Název by se neměl měnit pro jednotlivé případy.",
            "type": "string",
            "example": "Non-existing user"
          },
          "message": {
            "description": "Čitelný popis důvodu konkrétní chyby určený pro techniky.",
            "type": "string",
            "example": "User '123456789' not found."
          }
        }
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "user",
      "description": "Správa uživatelských účtů"
    }
  ]
}