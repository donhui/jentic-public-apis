    "/admin/identities/{id}/credentials/{type}": {
      "delete": {
        "description": "Delete an [identity](https://www.ory.sh/docs/kratos/concepts/identity-user-model) credential by its type.\nYou cannot delete passkeys or code auth credentials through this API.",
        "operationId": "deleteIdentityCredentials",
        "parameters": [
