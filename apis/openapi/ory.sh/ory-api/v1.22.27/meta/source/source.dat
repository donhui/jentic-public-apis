          },
          "id": {
            "description": "Session ID",
            "format": "uuid",
            "type": "string"
          },
          "identity": {
            "$ref": "#/components/schemas/identity"
          },
          "issued_at": {
            "description": "The Session Issuance Timestamp\n\nWhen this session was issued at. Usually equal or close to `authenticated_at`.",
            "format": "date-time",
