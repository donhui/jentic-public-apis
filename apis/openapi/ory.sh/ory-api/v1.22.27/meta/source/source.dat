            "type": "object"
          }
        },
        "required": [
          "email",
          "method"
        ],
        "type": "object"
      },
      "updateWorkspaceBody": {
        "properties": {
          "access_policy": {
            "description": "The access policy of the workspace.\nIf the workspace is not linked to an organization, this field is ignored and\nthe access policy is set to \"INVITED_MEMBERS\", which allows all invited members\nto access the workspace.\nCHECK_ORGANIZATION_AND_WORKSPACE_MEMBERSHIP WorkspaceAccessPolicyOrganizationMembershipRequired  Only invited members that are part of the organization defined for the workspace can access it\nCHECK_ACCESS_PERMISSION WorkspaceAccessPolicyMembershipRequired  All invited members can access the workspace, regardless of their organization membership  This is useful for migration scenarios where workspaces previously did not have an organization assigned  If a user is just a member of a project within the workspace, they'll still have access to the project, but not to the workspace itself (the default for existing workspaces)",
            "enum": [
              "CHECK_ORGANIZATION_AND_WORKSPACE_MEMBERSHIP",
              "CHECK_ACCESS_PERMISSION"
            ],
            "type": "string",
            "x-go-enum-desc": "CHECK_ORGANIZATION_AND_WORKSPACE_MEMBERSHIP WorkspaceAccessPolicyOrganizationMembershipRequired  Only invited members that are part of the organization defined for the workspace can access it\nCHECK_ACCESS_PERMISSION WorkspaceAccessPolicyMembershipRequired  All invited members can access the workspace, regardless of their organization membership  This is useful for migration scenarios where workspaces previously did not have an organization assigned  If a user is just a member of a project within the workspace, they'll still have access to the project, but not to the workspace itself (the default for existing workspaces)"
          },
          "name": {
            "description": "The name of the workspace.",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
