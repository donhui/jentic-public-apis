        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Record name"
          },
          "type": {
            "type": "string",
            "description": "Record type (A, AAAA, CNAME, MX, etc.)"
          },
          "content": {
            "type": "string",
            "description": "Record content/value"
          },
          "ttl": {
            "type": "integer",
            "description": "Time to live in seconds"
          },
          "prio": {
            "type": "integer",
            "description": "Priority (for MX, SRV records)"
          }
        },
        "required": [
          "name",
          "type",
          "content"
        ]
      },
      "UserInput": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "description": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "perm_templ": {
            "type": "integer",
            "description": "Permission template ID"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "GroupInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "PermissionTemplateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          }
        },
        "required": [
          "name"
        ]
      },
      "ZoneTemplateInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "properties": {
