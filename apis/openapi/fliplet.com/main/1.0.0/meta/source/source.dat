{
  "openapi": "3.0.3",
  "info": {
    "title": "Fliplet API",
    "version": "1.0.0",
    "description": "Fliplet REST API provides access to data sources, media files, notifications, and app management for the Fliplet app development platform.",
    "x-jentic-source-url": "https://developers.fliplet.com/REST-API-Documentation.html"
  },
  "servers": [
    {
      "url": "https://api.fliplet.com"
    }
  ],
  "security": [
    {
      "apiToken": []
    }
  ],
  "tags": [
    {
      "name": "Data Sources",
      "description": "Manage data sources and entries"
    },
    {
      "name": "Media",
      "description": "Manage folders and files"
    },
    {
      "name": "Notifications",
      "description": "Manage app notifications"
    },
    {
      "name": "Apps",
      "description": "Manage Fliplet apps"
    }
  ],
  "paths": {
    "/v1/data-sources": {
      "get": {
        "operationId": "listDataSources",
        "summary": "List data sources",
        "description": "Retrieve data sources filtered by app or organization.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "appId",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Filter by app ID"
          },
          {
            "name": "organizationId",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Filter by organization ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of data sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dataSources": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/DataSource" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "post": {
        "operationId": "createDataSource",
        "summary": "Create a data source",
        "description": "Create a new data source.",
        "tags": ["Data Sources"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "description": "Data source name" },
                  "organizationId": { "type": "integer", "description": "Organization ID" },
                  "appId": { "type": "integer", "description": "App ID" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data source created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataSource" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/data-sources/{dataSourceId}": {
      "get": {
        "operationId": "getDataSource",
        "summary": "Get a data source",
        "description": "Retrieve a specific data source by ID or name.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Data source ID or name"
          }
        ],
        "responses": {
          "200": {
            "description": "Data source details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataSource" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "put": {
        "operationId": "updateDataSource",
        "summary": "Update a data source",
        "description": "Update data source attributes like name and columns.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Data source ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "description": "Data source name" },
                  "columns": { "type": "array", "items": { "type": "string" }, "description": "Column names" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data source updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataSource" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "operationId": "deleteDataSource",
        "summary": "Delete a data source",
        "description": "Remove a data source and all its entries.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Data source ID"
          }
        ],
        "responses": {
          "200": { "description": "Data source deleted" },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/data-sources/{dataSourceId}/data/{entryId}": {
      "get": {
        "operationId": "getDataEntry",
        "summary": "Get a data entry",
        "description": "Retrieve a single entry by ID from a data source.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Data source ID"
          },
          {
            "name": "entryId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Entry ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Data entry",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataEntry" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "put": {
        "operationId": "updateDataEntry",
        "summary": "Update a data entry",
        "description": "Update an existing entry in a data source.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Data source ID"
          },
          {
            "name": "entryId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Entry ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "description": "Entry data as key-value pairs"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataEntry" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "operationId": "deleteDataEntry",
        "summary": "Delete a data entry",
        "description": "Remove a specific entry from a data source.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Data source ID"
          },
          {
            "name": "entryId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Entry ID"
          }
        ],
        "responses": {
          "200": { "description": "Entry deleted" },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/data-sources/{dataSourceId}/data": {
      "put": {
        "operationId": "insertDataEntry",
        "summary": "Insert a data entry",
        "description": "Insert a new entry into a data source.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Data source ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true,
                "description": "Entry data as key-value pairs"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataEntry" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "post": {
        "operationId": "bulkImportEntries",
        "summary": "Bulk import entries",
        "description": "Import entries in bulk. Replaces all existing entries unless append=true is specified.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Data source ID"
          },
          {
            "name": "append",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "When true, appends entries instead of replacing"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "entries": {
                    "type": "array",
                    "items": { "type": "object", "additionalProperties": true },
                    "description": "Array of entries to import"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entries imported",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/DataEntry" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/data-sources/{dataSourceId}/data/query": {
      "post": {
        "operationId": "queryDataEntries",
        "summary": "Query data entries",
        "description": "Execute a query with filters, aggregation, joins, sorting, and pagination.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Data source ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/DataEntry" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/data-sources/{dataSourceId}/commit": {
      "post": {
        "operationId": "commitDataChanges",
        "summary": "Commit multiple data changes",
        "description": "Apply multiple insert, update, and delete changes in a single request.",
        "tags": ["Data Sources"],
        "parameters": [
          {
            "name": "dataSourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Data source ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "insert": {
                    "type": "array",
                    "items": { "type": "object", "additionalProperties": true },
                    "description": "Entries to insert"
                  },
                  "update": {
                    "type": "array",
                    "items": { "type": "object", "additionalProperties": true },
                    "description": "Entries to update"
                  },
                  "delete": {
                    "type": "array",
                    "items": { "type": "integer" },
                    "description": "Entry IDs to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Changes committed" },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/media": {
      "get": {
        "operationId": "listMedia",
        "summary": "List media folders and files",
        "description": "Retrieve folders and files filtered by app, organization, or folder.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "appId",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Filter by app ID"
          },
          {
            "name": "organizationId",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Filter by organization ID"
          },
          {
            "name": "folderId",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Filter by folder ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of media items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "files": { "type": "array", "items": { "$ref": "#/components/schemas/MediaFile" } },
                    "folders": { "type": "array", "items": { "$ref": "#/components/schemas/MediaFolder" } }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/media/folders": {
      "post": {
        "operationId": "createMediaFolder",
        "summary": "Create a media folder",
        "description": "Create a new folder in the media library.",
        "tags": ["Media"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "description": "Folder name" },
                  "parentId": { "type": "integer", "description": "Parent folder ID" },
                  "organizationId": { "type": "integer", "description": "Organization ID" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Folder created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MediaFolder" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/media/files": {
      "post": {
        "operationId": "uploadMediaFile",
        "summary": "Upload a media file",
        "description": "Upload a file to the media library using multipart form data.",
        "tags": ["Media"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary", "description": "File to upload" },
                  "folderId": { "type": "integer", "description": "Target folder ID" },
                  "appId": { "type": "integer", "description": "App ID context" },
                  "organizationId": { "type": "integer", "description": "Organization ID context" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File uploaded",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MediaFile" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/media/files/{fileId}/contents": {
      "get": {
        "operationId": "getMediaFileContents",
        "summary": "Get file contents",
        "description": "Stream the contents of a media file. Supports size parameter for image resizing.",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "fileId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "File ID"
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["small", "medium", "large", "xlarge", "xxlarge", "xxxlarge"]
            },
            "description": "Image size variant"
          }
        ],
        "responses": {
          "200": {
            "description": "File contents",
            "content": { "application/octet-stream": { "schema": { "type": "string", "format": "binary" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/media/folders/{folderId}": {
      "delete": {
        "operationId": "deleteMediaFolder",
        "summary": "Delete a media folder",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "folderId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Folder ID"
          }
        ],
        "responses": {
          "200": { "description": "Folder deleted" },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/media/files/{fileId}": {
      "delete": {
        "operationId": "deleteMediaFile",
        "summary": "Delete a media file",
        "tags": ["Media"],
        "parameters": [
          {
            "name": "fileId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "File ID"
          }
        ],
        "responses": {
          "200": { "description": "File deleted" },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/apps": {
      "get": {
        "operationId": "listApps",
        "summary": "List apps",
        "description": "Retrieve a list of all accessible Fliplet apps.",
        "tags": ["Apps"],
        "responses": {
          "200": {
            "description": "List of apps",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "apps": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/App" }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/v1/apps/{appId}/publish": {
      "post": {
        "operationId": "publishApp",
        "summary": "Publish an app update",
        "description": "Publish an update for a Fliplet app with release type and changelog.",
        "tags": ["Apps"],
        "parameters": [
          {
            "name": "appId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "App ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["silent", "visible", "forced"],
                    "description": "Release type"
                  },
                  "changelog": {
                    "type": "string",
                    "description": "Release notes"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "App published",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/App" } } }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
