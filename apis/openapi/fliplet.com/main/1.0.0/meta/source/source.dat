  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Auth-token",
        "description": "API token created via Fliplet Studio"
      }
    },
    "schemas": {
      "DataSource": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Data source ID" },
          "name": { "type": "string", "description": "Data source name" },
          "appId": { "type": "integer", "description": "Associated app ID" },
          "organizationId": { "type": "integer", "description": "Associated organization ID" },
          "columns": { "type": "array", "items": { "type": "string" }, "description": "Column names" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "DataEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Entry ID" },
          "data": { "type": "object", "additionalProperties": true, "description": "Entry data" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "QueryRequest": {
        "type": "object",
        "properties": {
          "where": { "type": "object", "description": "Filter conditions" },
          "attributes": { "type": "array", "items": { "type": "string" }, "description": "Columns to select" },
          "order": { "type": "string", "description": "Sort field" },
          "limit": { "type": "integer", "description": "Maximum results" },
          "offset": { "type": "integer", "description": "Offset for pagination" },
          "includePagination": { "type": "boolean", "description": "Include pagination metadata" },
          "join": { "type": "object", "description": "Join configuration for cross-datasource queries" },
          "aggregate": { "type": "array", "items": { "type": "object" }, "description": "Aggregation pipeline" }
        }
      },
      "MediaFile": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "File ID" },
          "name": { "type": "string", "description": "File name" },
          "url": { "type": "string", "description": "File URL" },
          "size": { "type": "integer", "description": "File size in bytes" },
          "contentType": { "type": "string", "description": "MIME type" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "MediaFolder": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Folder ID" },
          "name": { "type": "string", "description": "Folder name" },
          "parentId": { "type": "integer", "description": "Parent folder ID" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "App": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "App ID" },
          "name": { "type": "string", "description": "App name" },
          "icon": { "type": "string", "description": "App icon URL" },
          "version": { "type": "integer", "description": "App version number" },
          "organizationId": { "type": "integer", "description": "Organization ID" },
          "settings": { "type": "object", "description": "App settings" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Notification ID" },
          "data": { "type": "object", "description": "Notification content" },
          "status": { "type": "string", "enum": ["draft", "published"], "description": "Notification status" },
          "scope": { "type": "array", "items": { "type": "object" }, "description": "Targeting scope" },
          "orderAt": { "type": "string", "format": "date-time", "description": "Order timestamp" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "NotificationCreateRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": { "type": "object", "description": "Notification content as JSON" },
          "scope": { "type": "array", "items": { "type": "object" }, "description": "Targeting scope" },
          "status": { "type": "string", "enum": ["draft", "published"], "description": "Notification status" },
          "orderAt": { "type": "string", "format": "date-time", "description": "Order timestamp" },
          "pushNotification": { "type": "object", "description": "Push notification payload" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "description": "Error message" }
        }
      }
    }
  }
}