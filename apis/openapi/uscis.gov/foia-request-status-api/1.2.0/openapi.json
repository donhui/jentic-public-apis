{
  "openapi": "3.0.3",
  "info": {
    "title": "USCIS FOIA Request and Status API",
    "version": "1.2.0",
    "description": "API for creating and tracking FOIA (Freedom of Information Act) requests with USCIS.",
    "x-jentic-source-url": "https://developer.uscis.gov/api/foia-request-and-status"
  },
  "servers": [
    {
      "url": "https://api-int.uscis.gov/first-case-sbox"
    }
  ],
  "paths": {
    "/case": {
      "post": {
        "operationId": "createFoiaCase",
        "summary": "Create FOIA case",
        "description": "Receives a FOIA request and returns a case control number to track the case",
        "tags": [
          "Cases"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FoiaCaseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Case created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FoiaCaseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/case-status": {
      "get": {
        "operationId": "getCaseStatus",
        "summary": "Check FOIA case status",
        "description": "Returns a single FOIA Public Case Metric by control number",
        "tags": [
          "Cases"
        ],
        "parameters": [
          {
            "name": "caseControlNumber",
            "in": "query",
            "description": "Case control number",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "requestNumber",
            "in": "query",
            "description": "Request number",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Case status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CaseStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FoiaCaseRequest": {
        "type": "object",
        "properties": {
          "subjectType": {
            "type": "string"
          },
          "alienNumbers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "receiptNumbers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recordsRequested": {
            "type": "string"
          },
          "consentMethod": {
            "type": "string"
          },
          "digitalDeliveryMethod": {
            "type": "string"
          }
        }
      },
      "FoiaCaseResponse": {
        "type": "object",
        "properties": {
          "requestNumber": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CaseStatusResponse": {
        "type": "object",
        "properties": {
          "caseControlNumber": {
            "type": "string"
          },
          "requestNumber": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "estimatedCompletionDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://api-int.uscis.gov/oauth/token",
            "scopes": {
              "write": "Create FOIA cases",
              "read": "Read FOIA case status"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "OAuth2": [
        "write",
        "read"
      ]
    }
  ]
}