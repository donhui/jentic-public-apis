          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "address": {
                    "type": "string",
                    "example": "9898 Market Street # 1"
                  },
                  "address_2": {
                    "type": "string",
                    "example": "Address 2 here"
                  },
                  "city": {
                    "type": "string",
                    "example": "city"
                  },
                  "state": {
                    "type": "string",
                    "example": "AZ"
                  },
                  "zipcode": {
                    "type": "string",
                    "example": ""
                  },
                  "county": {
                    "type": "string",
                    "example": "COUNTY 2"
                  },
                  "type": {
                    "type": "string",
                    "example": "mailing"
                  }
                }
              }
            }
          }
        }
      }
    },
