{
  "openapi": "3.0.3",
  "info": {
    "title": "NextAgency API",
    "version": "2.0.0",
    "description": "NextAgency is an insurance agency management platform. This API provides RESTful endpoints for managing businesses, contacts, tasks, notes, sub-agents, carriers, leads, commissions, policies, and more.",
    "x-jentic-source-url": "http://dev.nextagency.com",
    "contact": {
      "name": "NextAgency",
      "url": "https://www.nextagency.com"
    }
  },
  "servers": [
    {
      "url": "https://yahoo.nextbroker.io",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "oauth2": [
        "read",
        "write"
      ]
    }
  ],
  "paths": {
    "/oauth/authorize": {
      "get": {
        "operationId": "Oauth_Code",
        "summary": "Oauth Code",
        "description": "",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "operationId": "Access_Token",
        "summary": "Access Token",
        "description": "<p>Exchange your auth_code for an access_token or refresh your token by using this endpoint.</p>\n",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "client_id": {
                    "type": "string",
                    "example": "client_id"
                  },
                  "client_secret": {
                    "type": "string",
                    "example": "client_secret"
                  },
                  "redirect_uri": {
                    "type": "string",
                    "example": "redirect_uri"
                  },
                  "code": {
                    "type": "string",
                    "example": "code"
                  },
                  "grant_type": {
                    "type": "string",
                    "example": "authorization_code or refresh_token"
                  },
                  "refresh_token": {
                    "type": "string",
                    "example": "refresh_token"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/businesses": {
      "get": {
        "operationId": "Cases",
        "summary": "Cases",
        "description": "<p>Use this endpoint to fetch all cases of an agencyy.</p>\n",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "Create_Case",
        "summary": "Create Case",
        "description": "<p>Create a new case in your agency through this endpoint.</p>\n",
        "tags": [
          "Cases"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "My New Case"
                  },
                  "first_name": {
                    "type": "string",
                    "example": ""
                  },
                  "last_name": {
                    "type": "string",
                    "example": ""
                  },
                  "sales_status": {
                    "type": "string",
                    "example": "Client"
                  },
                  "stage": {
                    "type": "string",
                    "example": "In Discussion"
                  },
                  "ssn": {
                    "type": "string",
                    "example": "123123"
                  },
                  "phone_number": {
                    "type": "string",
                    "example": "1231231234"
                  },
                  "naics_code": {
                    "type": "string",
                    "example": "123"
                  },
                  "sic_code": {
                    "type": "string",
                    "example": "12345"
                  },
                  "website": {
                    "type": "string",
                    "example": "website"
                  },
                  "url": {
                    "type": "string",
                    "example": "URL"
                  },
                  "tax_id": {
                    "type": "string",
                    "example": "111127727272"
                  },
                  "type": {
                    "type": "string",
                    "example": ""
                  },
                  "market_segment": {
                    "type": "string",
                    "example": "small_group"
                  },
                  "email": {
                    "type": "string",
                    "example": "example@gmail.com"
                  },
                  "birthdate": {
                    "type": "string",
                    "example": "01-01-2000"
                  },
                  "gender": {
                    "type": "string",
                    "example": "female"
                  },
                  "age": {
                    "type": "integer",
                    "example": 25
                  },
                  "physical_address": {
                    "type": "object"
                  },
                  "mailing_address": {
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
