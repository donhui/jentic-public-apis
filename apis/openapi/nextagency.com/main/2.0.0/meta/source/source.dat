    "/api/v2/businesses/ba3d6ecd-6787-43f7-859d-0dc4dfda3181/tasks": {
      "get": {
        "operationId": "Tasks",
        "summary": "Tasks",
        "description": "<p>Use this endpoint to fetch tasks of a case.</p>\n",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "Create_Tasks",
        "summary": "Create Tasks",
        "description": "<p>Create a new task of a case through this endpoint,<br />To assign this to users, use the <code>assigned_to</code> parameter and pass an array of unique user IDs.</p>\n",
        "tags": [
          "Tasks"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "example": "Attend meeting!"
                  },
                  "stage": {
                    "type": "string",
                    "example": "To Do"
                  },
                  "type": {
                    "type": "string",
                    "example": "Other"
                  },
                  "priority": {
                    "type": "integer",
                    "example": 1
                  },
                  "due": {
                    "type": "string",
                    "example": "04-11-2020 05:00 AM UTC"
                  },
                  "body": {
                    "type": "string",
                    "example": "<p>You have a meeting at 5:00 PM.</p>"
                  },
                  "assigned_to": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
