{
  "openapi": "3.0.3",
  "info": {
    "title": "Rentry",
    "version": "1.0.0",
    "description": "Rentry.co is a markdown-powered paste/publishing service with preview, custom URLs and editing. The API allows creating, editing, fetching and deleting entries.",
    "x-jentic-source-url": "https://github.com/radude/rentry"
  },
  "servers": [
    {
      "url": "https://rentry.co",
      "description": "Rentry.co production"
    }
  ],
  "tags": [
    {
      "name": "Entries",
      "description": "Create, edit, fetch and delete entries"
    }
  ],
  "paths": {
    "/new": {
      "post": {
        "operationId": "createEntry",
        "tags": [
          "Entries"
        ],
        "summary": "Create a new entry",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "csrfmiddlewaretoken",
                  "text"
                ],
                "properties": {
                  "csrfmiddlewaretoken": {
                    "type": "string",
                    "description": "CSRF token"
                  },
                  "text": {
                    "type": "string",
                    "description": "Markdown text content"
                  },
                  "metadata": {
                    "type": "string",
                    "description": "Entry metadata"
                  },
                  "url": {
                    "type": "string",
                    "description": "Custom URL slug"
                  },
                  "edit_code": {
                    "type": "string",
                    "description": "Edit code for the entry"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/edit/{url}": {
      "post": {
        "operationId": "editEntry",
        "tags": [
          "Entries"
        ],
        "summary": "Edit an existing entry",
        "parameters": [
          {
            "name": "url",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Entry URL slug"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "csrfmiddlewaretoken",
                  "edit_code"
                ],
                "properties": {
                  "csrfmiddlewaretoken": {
                    "type": "string"
                  },
                  "edit_code": {
                    "type": "string"
                  },
                  "text": {
                    "type": "string"
                  },
                  "metadata": {
                    "type": "string"
                  },
                  "update_mode": {
                    "type": "string"
                  },
                  "new_url": {
                    "type": "string"
                  },
                  "new_edit_code": {
                    "type": "string"
                  },
                  "new_modify_code": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/raw/{url}": {
      "post": {
        "operationId": "getRawEntry",
        "tags": [
          "Entries"
        ],
        "summary": "Get raw markdown text of an entry",
        "parameters": [
          {
            "name": "url",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "csrfmiddlewaretoken"
                ],
                "properties": {
                  "csrfmiddlewaretoken": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Raw text",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "content": {
                      "type": "object",
                      "properties": {
                        "text": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/fetch/{url}": {
      "post": {
        "operationId": "fetchEntry",
        "tags": [
          "Entries"
        ],
        "summary": "Fetch entry details including metadata",
        "parameters": [
          {
            "name": "url",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "csrfmiddlewaretoken",
                  "edit_code"
                ],
                "properties": {
                  "csrfmiddlewaretoken": {
                    "type": "string"
                  },
                  "edit_code": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FetchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/delete/{url}": {
      "post": {
        "operationId": "deleteEntry",
        "tags": [
          "Entries"
        ],
        "summary": "Delete an entry",
        "parameters": [
          {
            "name": "url",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "csrfmiddlewaretoken",
                  "edit_code"
                ],
                "properties": {
                  "csrfmiddlewaretoken": {
                    "type": "string"
                  },
                  "edit_code": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "csrfToken": {
        "type": "apiKey",
        "in": "cookie",
        "name": "csrftoken",
        "description": "CSRF token from cookie"
      }
    },
    "schemas": {
      "EntryResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "content": {
            "type": "object"
          }
        }
      },
      "FetchResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "content": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "url_case": {
                "type": "string"
              },
              "views": {
                "type": "integer"
              },
              "pub_date": {
                "type": "string",
                "format": "date-time"
              },
              "edit_date": {
                "type": "string",
                "format": "date-time"
              },
              "modify_code_set": {
                "type": "boolean"
              },
              "text": {
                "type": "string"
              },
              "metadata": {
                "type": "object"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        }
      }
    }
  }
}