{
  "openapi": "3.0.3",
  "info": {
    "title": "Jasper AI API",
    "version": "1.0",
    "description": "Jasper is the leader in generative AI for marketing teams, helping create quality content for blog posts, social media posts, web pages, and more. The Jasper API provides endpoints for commands, tasks, knowledge, voices, styles, documents, users, image operations, and templates.",
    "x-jentic-source-url": "https://developers.jasper.ai/reference"
  },
  "servers": [
    {
      "url": "https://api.jasper.ai",
      "description": "Jasper AI Production API"
    }
  ],
  "tags": [
    {
      "name": "Commands",
      "description": "Run AI commands to generate content"
    },
    {
      "name": "Tasks",
      "description": "Agent task management and execution"
    },
    {
      "name": "Knowledge",
      "description": "Knowledge base management"
    },
    {
      "name": "Voices",
      "description": "Voice/tone management"
    },
    {
      "name": "Styles",
      "description": "Style guide management"
    },
    {
      "name": "Documents",
      "description": "Document management"
    },
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Images",
      "description": "Image operations and manipulation"
    },
    {
      "name": "ImageTemplates",
      "description": "Image template management"
    },
    {
      "name": "Audiences",
      "description": "Audience management"
    },
    {
      "name": "Usage",
      "description": "API usage tracking"
    },
    {
      "name": "Templates",
      "description": "Content template management"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/v1/command": {
      "post": {
        "operationId": "runCommand",
        "summary": "Run command",
        "description": "Run a command to generate an AI Output",
        "tags": ["Commands"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CommandRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Command executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommandResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks": {
      "get": {
        "operationId": "listTasks",
        "summary": "Retrieve all agent tasks",
        "description": "Retrieve all agent tasks available in your workspace",
        "tags": ["Tasks"],
        "parameters": [
          {
            "name": "size",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Number of results per page"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Page number"
          },
          {
            "name": "scope",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Scope filter"
          },
          {
            "name": "includeContextItems",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "Include context items in response"
          },
          {
            "name": "includeCategories",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "Include categories in response"
          },
          {
            "name": "searchTerm",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Search term to filter tasks"
          }
        ],
        "responses": {
          "200": {
            "description": "List of tasks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TasksListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{id}": {
      "get": {
        "operationId": "getTask",
        "summary": "Retrieve a specific agent task",
        "description": "Retrieve a specific agent task by its unique identifier",
        "tags": ["Tasks"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Task details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{id}/run": {
      "post": {
        "operationId": "runTask",
        "summary": "Execute an agent task",
        "description": "Execute an agent task by ID",
        "tags": ["Tasks"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskRunRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task execution result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskRunResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tasks/{id}/run/stream": {
      "post": {
        "operationId": "runTaskStream",
        "summary": "Execute task with streaming",
        "description": "Execute an agent task with Server-Sent Events streaming",
        "tags": ["Tasks"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskRunRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSE stream with step updates and content chunks",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/knowledge": {
      "post": {
        "operationId": "createKnowledge",
        "summary": "Create a knowledge item",
        "description": "Create a new knowledge item in the knowledge base",
        "tags": ["Knowledge"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/KnowledgeCreateRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Knowledge item created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeItem"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listKnowledge",
        "summary": "List knowledge items",
        "description": "Returns a list of knowledge items",
        "tags": ["Knowledge"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Search query"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "size",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of knowledge items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/knowledge/{knowledgeId}": {
      "get": {
        "operationId": "getKnowledge",
        "summary": "Retrieve knowledge item",
        "description": "Retrieve a knowledge item by ID",
        "tags": ["Knowledge"],
        "parameters": [
          {
            "name": "knowledgeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Knowledge item details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeItem"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateKnowledge",
        "summary": "Update knowledge item",
        "description": "Update an existing knowledge item",
        "tags": ["Knowledge"],
        "parameters": [
          {
            "name": "knowledgeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KnowledgeUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Knowledge item updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeItem"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteKnowledge",
        "summary": "Delete knowledge item",
        "description": "Delete a knowledge item by ID",
        "tags": ["Knowledge"],
        "parameters": [
          {
            "name": "knowledgeId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": {
            "description": "Knowledge item deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/knowledge/search": {
      "post": {
        "operationId": "searchKnowledge",
        "summary": "Search knowledge base",
        "description": "Search the knowledge base using natural language",
        "tags": ["Knowledge"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Natural language search query"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tones": {
      "post": {
        "operationId": "createVoice",
        "summary": "Create a voice",
        "description": "Create a new voice/tone",
        "tags": ["Voices"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VoiceRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Voice created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Voice"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listVoices",
        "summary": "Retrieve all voices",
        "description": "Retrieve all voices/tones in the workspace",
        "tags": ["Voices"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "size",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of voices",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VoicesListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/tones/{toneId}": {
      "get": {
        "operationId": "getVoice",
        "summary": "Retrieve voice by ID",
        "tags": ["Voices"],
        "parameters": [
          {
            "name": "toneId",
            "in": "path",
            "required": true,
