    },
    "/v1/styles/{styleId}": {
      "get": {
        "operationId": "getStyle",
        "summary": "Retrieve style guide by ID",
        "tags": ["Styles"],
        "parameters": [
          {
            "name": "styleId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Style guide details",
            "content": {
              "application/json": {
