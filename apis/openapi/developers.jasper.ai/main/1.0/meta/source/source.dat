  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Jasper API key passed in the X-API-Key header"
      }
    },
    "schemas": {
      "CommandRequest": {
        "type": "object",
        "required": ["inputs"],
        "properties": {
          "inputs": {
            "type": "object",
            "required": ["command"],
            "properties": {
              "command": {
                "type": "string",
                "description": "The command/prompt to generate content"
              },
              "context": {
                "type": "string",
                "description": "Additional context for the command"
              },
              "knowledgeIds": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Knowledge item IDs to use as context"
              },
              "styleId": {
                "type": "string",
                "description": "Style guide ID"
              },
              "toneId": {
                "type": "string",
                "description": "Tone/voice ID"
              },
              "audienceId": {
                "type": "string",
                "description": "Audience ID"
              }
            }
          },
          "options": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "CommandResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
