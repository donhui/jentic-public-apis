          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteVoice",
        "summary": "Delete voice by ID",
        "tags": ["Voices"],
        "parameters": [
          {
            "name": "toneId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": {
            "description": "Voice deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/styles": {
      "get": {
        "operationId": "listStyles",
        "summary": "List style guides",
        "description": "Returns a list of style guides",
        "tags": ["Styles"],
        "responses": {
          "200": {
            "description": "List of style guides",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StylesListResponse"
                }
              }
