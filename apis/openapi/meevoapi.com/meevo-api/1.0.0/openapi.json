{
  "openapi": "3.0.3",
  "info": {
    "title": "Meevo API",
    "version": "1.0.0",
    "description": "Meevo Zapier integration API for managing appointments, clients, and event subscriptions in the Meevo salon and spa management platform.",
    "x-jentic-source-url": "https://zaps.meevoapi.com/Introduction.htm"
  },
  "servers": [
    {
      "url": "https://zapier.meevo.com"
    }
  ],
  "paths": {
    "/api/event-data/authenticate": {
      "post": {
        "operationId": "authenticate",
        "summary": "Authenticate and obtain JWT token",
        "description": "Obtains a JWT Bearer Token for API access. Token is valid for 3 days.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/event-data/check": {
      "get": {
        "operationId": "checkToken",
        "summary": "Check token validity",
        "description": "Verify the validity of a user's authentication token.",
        "tags": ["Authentication"],
        "responses": {
          "200": { "description": "Token is valid", "content": { "application/json": { "schema": { "type": "object", "properties": { "valid": { "type": "boolean" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/marketplace/events/subscribe": {
      "post": {
        "operationId": "subscribeToEvent",
        "summary": "Subscribe to a trigger event",
        "description": "Subscribes user to a Meevo trigger event such as appointment or client changes.",
        "tags": ["Subscriptions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscribeRequest"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Subscription created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Subscription" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/marketplace/events/unsubscribe/{id}": {
      "delete": {
        "operationId": "unsubscribeFromEvent",
        "summary": "Unsubscribe from a trigger event",
        "description": "Removes user from a trigger subscription.",
        "tags": ["Subscriptions"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "description": "Subscription ID", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Unsubscribed successfully" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/marketplace/events/sample-data/AppointmentCreated": {
      "post": {
        "operationId": "getAppointmentCreatedSample",
        "summary": "Get appointment created sample data",
        "description": "Returns sample data model for new appointments.",
        "tags": ["Sample Data"],
        "responses": {
          "200": { "description": "Sample data returned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AppointmentEvent" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/marketplace/events/sample-data/AppointmentUpdated": {
      "get": {
        "operationId": "getAppointmentUpdatedSample",
        "summary": "Get appointment updated sample data",
        "tags": ["Sample Data"],
        "responses": {
          "200": { "description": "Sample data returned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AppointmentEvent" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/marketplace/events/sample-data/AppointmentDeleted": {
      "get": {
        "operationId": "getAppointmentDeletedSample",
        "summary": "Get appointment deleted sample data",
        "tags": ["Sample Data"],
        "responses": {
          "200": { "description": "Sample data returned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AppointmentEvent" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/marketplace/events/sample-data/ClientCreated": {
      "get": {
        "operationId": "getClientCreatedSample",
        "summary": "Get client created sample data",
        "tags": ["Sample Data"],
        "responses": {
          "200": { "description": "Sample data returned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientEvent" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/marketplace/events/sample-data/ClientUpdated": {
      "get": {
        "operationId": "getClientUpdatedSample",
        "summary": "Get client updated sample data",
        "tags": ["Sample Data"],
        "responses": {
          "200": { "description": "Sample data returned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientEvent" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/marketplace/events/sample-data/ClientMerge": {
      "get": {
        "operationId": "getClientMergeSample",
        "summary": "Get client merge sample data",
        "tags": ["Sample Data"],
        "responses": {
          "200": { "description": "Sample data returned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientEvent" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/marketplace/events/sample-data/ClientDeleted": {
      "delete": {
        "operationId": "getClientDeletedSample",
        "summary": "Get client deleted sample data",
        "tags": ["Sample Data"],
        "responses": {
          "200": { "description": "Sample data returned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClientEvent" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        },
        "security": [{ "bearerAuth": [] }]
      }
    }
  },
  "components": {
    "schemas": {
      "AuthRequest": {
        "type": "object",
        "required": ["clientId", "clientSecret"],
        "properties": {
          "clientId": { "type": "string", "description": "Client ID for authentication" },
          "clientSecret": { "type": "string", "description": "Client secret for authentication" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "description": "JWT Bearer token, valid for 3 days" }
        }
      },
      "SubscribeRequest": {
        "type": "object",
        "required": ["HookUrl", "EventType"],
        "properties": {
          "HookUrl": { "type": "string", "description": "Webhook URL to receive events" },
          "EventType": { "type": "string", "description": "Type of event to subscribe to", "enum": ["AppointmentCreated", "AppointmentUpdated", "AppointmentDeleted", "ClientCreated", "ClientUpdated", "ClientDeleted", "ClientMerge"] }
        }
      },
      "Subscription": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Subscription ID" },
          "hookUrl": { "type": "string", "description": "Webhook URL" },
          "eventType": { "type": "string", "description": "Event type subscribed to" }
        }
      },
      "AppointmentEvent": {
        "type": "object",
        "properties": {
          "appointmentId": { "type": "string" },
          "clientId": { "type": "string" },
          "scheduledAt": { "type": "string", "format": "date-time" },
          "status": { "type": "string" }
        }
      },
      "ClientEvent": {
        "type": "object",
        "properties": {
          "clientId": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["error"] },
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ]
}
