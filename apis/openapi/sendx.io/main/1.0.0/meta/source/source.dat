{
  "openapi": "3.0.3",
  "info": {
    "title": "SendX REST API",
    "description": "SendX REST API for managing contacts, campaigns, tags, lists, senders, and webhooks for email marketing and marketing automation.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.sendx.io"
  },
  "servers": [
    {
      "url": "https://api.sendx.io/api/v1/rest",
      "description": "SendX REST API v1"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/contact": {
      "get": {
        "operationId": "listcontacts",
        "summary": "Get all contacts",
        "description": "Retrieves a paginated list of all contacts.",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "description": "Number of records to skip for pagination",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of records per response",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30,
              "default": 10
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Filter by first name, last name, or email (case-insensitive partial match, 2-255 chars)",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 255
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Contact"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid input parameters"
          },
          "401": {
            "description": "Unauthorized - Missing or invalid API key"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/campaign": {
      "get": {
        "operationId": "listcampaigns",
        "summary": "Get all campaigns",
        "description": "Retrieves a paginated list of all campaigns.",
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "description": "Number of campaigns to skip",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum campaigns per request",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          },
          {
            "name": "campaignType",
            "in": "query",
            "description": "Filter by campaign type",
            "schema": {
              "type": "string",
              "enum": [
                "all",
                "draft",
                "scheduled",
                "sent"
              ],
              "default": "all"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of campaigns",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Campaign"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "500": {
            "description": "Internal server error"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/tag": {
      "get": {
        "operationId": "listtags",
        "summary": "Get all tags",
        "description": "Retrieves all tags in your team.",
        "tags": [
          "Tags"
        ],
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "description": "Number of tags to skip",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum tags returned",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of tags",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Tag"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "500": {
            "description": "Internal server error"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/list": {
      "get": {
        "operationId": "listlists",
        "summary": "Get all contact lists",
        "description": "Retrieves all contact lists in your team.",
        "tags": [
          "Lists"
        ],
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "description": "Number of records to skip",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum records per response",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Filter by list name (2-100 chars)",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of lists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ContactList"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "500": {
            "description": "Internal server error"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sender": {
      "get": {
        "operationId": "listsenders",
        "summary": "Get all verified sender addresses",
        "description": "Retrieves all verified sender addresses.",
        "tags": [
          "Senders"
        ],
        "responses": {
          "200": {
            "description": "Array of senders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Sender"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "500": {
            "description": "Internal server error"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/webhook": {
      "get": {
        "operationId": "listwebhooks",
        "summary": "Get all webhooks",
        "description": "Retrieves all configured webhooks.",
        "tags": [
          "Webhooks"
        ],
        "responses": {
          "200": {
            "description": "Array of webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Webhook"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          },
          "500": {
            "description": "Internal server error"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Team-ApiKey",
        "description": "Team API key for authentication"
      }
    },
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Contact identifier with contact_ prefix"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "customFields": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Custom field values keyed by field ID"
          },
          "lists": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List IDs the contact belongs to"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tag IDs assigned to the contact"
          },
          "unsubscribed": {
            "type": "boolean"
          },
          "bounced": {
            "type": "boolean"
          },
          "spam": {
            "type": "boolean"
          },
          "blocked": {
            "type": "boolean"
          },
          "dropped": {
            "type": "boolean"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          },
          "trackData": {
            "type": "string"
          },
          "contactSource": {
            "type": "integer"
          },
          "pageSource": {
            "type": "string"
          },
          "lastTrackedIp": {
            "type": "string"
          },
          "LTV": {
            "type": "integer",
            "description": "Lifetime value"
          }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Campaign identifier with campaign_ prefix"
          },
          "name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "preheader": {
            "type": "string"
          },
          "sender": {
            "type": "string",
            "description": "Sender ID reference"
          },
          "status": {
            "type": "integer",
            "description": "Campaign state (0-7)"
          },
          "scheduleType": {
            "type": "string"
          },
          "scheduleCondition": {
            "type": "string"
          },
          "includedLists": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Target audience list IDs"
          },
          "includedTags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Target audience tag IDs"
          },
          "excludedLists": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "excludedTags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "smartSend": {
            "type": "boolean"
          },
          "sendInContactsTimezone": {
            "type": "boolean"
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Tag identifier with tag_ prefix"
          },
          "name": {
            "type": "string"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ContactList": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "List identifier with list_ prefix"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "integer",
            "description": "0 = single opt-in, 1 = double opt-in"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Sender": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Sender identifier with sender_ prefix"
          },
          "name": {
            "type": "string",
            "description": "Display name"
          },
          "email": {
            "type": "string"
          },
          "isWhitelisted": {
            "type": "boolean",
            "description": "Verification status"
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Webhook identifier with webhook_ prefix"
          },
          "url": {
            "type": "string",
            "description": "Webhook endpoint URL"
          },
          "enabled": {
            "type": "boolean"
          },
          "unsubscribed": {
            "type": "boolean",
            "description": "Trigger on contact unsubscribe"
          },
          "dropped": {
            "type": "boolean",
            "description": "Trigger on dropped email"
          },
          "bounced": {
            "type": "boolean",
            "description": "Trigger on bounce"
          },
          "markedSpam": {
            "type": "boolean",
            "description": "Trigger on spam report"
          },
          "clicked": {
            "type": "boolean",
            "description": "Trigger on link click"
          },
          "opened": {
            "type": "boolean",
            "description": "Trigger on email open"
          },
          "contactCreated": {
            "type": "boolean",
            "description": "Trigger on new contact creation"
          },
          "created": {
            "type": "number",
            "description": "Timestamp of webhook creation"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Campaigns",
      "description": "Operations related to Campaigns"
    },
    {
      "name": "Contacts",
      "description": "Operations related to Contacts"
    },
    {
      "name": "Lists",
      "description": "Operations related to Lists"
    },
    {
      "name": "Senders",
      "description": "Operations related to Senders"
    },
    {
      "name": "Tags",
      "description": "Operations related to Tags"
    },
    {
      "name": "Webhooks",
      "description": "Operations related to Webhooks"
    }
  ]
}