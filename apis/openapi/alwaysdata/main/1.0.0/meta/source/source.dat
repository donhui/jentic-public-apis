  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic auth with API key and account name. Format: 'APIKEY account=accountname' as username, empty password."
      }
    },
    "parameters": {
      "ResourceId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Resource ID"
      }
    },
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "customer": { "type": "integer" }
        }
      },
      "Domain": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "account": { "type": "integer" }
        }
      },
      "DomainCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Domain name" }
        },
        "required": ["name"]
      },
      "DnsRecord": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "domain": { "type": "integer" },
          "type": { "type": "string" },
          "name": { "type": "string" },
          "value": { "type": "string" },
          "ttl": { "type": "integer" },
          "priority": { "type": "integer" }
        }
      },
      "DnsRecordCreate": {
        "type": "object",
        "properties": {
          "domain": { "type": "integer" },
          "type": { "type": "string", "description": "A, AAAA, CNAME, MX, TXT, etc." },
          "name": { "type": "string" },
          "value": { "type": "string" },
          "ttl": { "type": "integer" },
          "priority": { "type": "integer" }
        },
        "required": ["domain", "type", "name", "value"]
      },
      "Site": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "account": { "type": "integer" },
          "type": { "type": "string" }
        }
      },
      "SiteCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "path": { "type": "string" }
        },
        "required": ["name"]
      },
      "Database": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "type": { "type": "string", "description": "mysql, postgresql, etc." },
          "account": { "type": "integer" }
        }
      },
      "DatabaseCreate": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" }
