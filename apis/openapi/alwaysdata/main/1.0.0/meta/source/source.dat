{
  "openapi": "3.0.3",
  "info": {
    "title": "Alwaysdata API",
    "description": "Alwaysdata hosting management REST API for managing accounts, domains, databases, mailboxes, websites, SSL certificates, and more.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.alwaysdata.com/v1/"
  },
  "servers": [
    {
      "url": "https://api.alwaysdata.com/v1",
      "description": "Alwaysdata API server"
    }
  ],
  "paths": {
    "/account/": {
      "get": {
        "operationId": "listAccounts",
        "summary": "List hosting accounts",
        "tags": ["Accounts"],
        "responses": {
          "200": {
            "description": "List of accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Account" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/account/{id}/": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account details",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": {
            "description": "Account details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Account" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateAccount",
        "summary": "Update account",
        "tags": ["Accounts"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Account" }
            }
          }
        },
        "responses": {
          "200": { "description": "Account updated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
