{
  "openapi": "3.0.3",
  "info": {
    "title": "SkyBiometry Face Detection and Recognition API",
    "description": "SkyBiometry provides a cloud-based face detection and recognition API. Detect faces in images, recognize trained users, manage face tags, and train face templates for identification. Supports both JSON and XML response formats.",
    "version": "1.0.0",
    "contact": {
      "name": "SkyBiometry",
      "url": "https://skybiometry.com"
    },
    "x-jentic-source-url": "https://skybiometry.com/documentation/"
  },
  "servers": [
    {
      "url": "https://api.skybiometry.com/fc",
      "description": "SkyBiometry Production API"
    }
  ],
  "security": [
    {
      "ApiKeySecret": []
    }
  ],
  "tags": [
    {
      "name": "Account",
      "description": "Account management, authentication testing, and usage limits"
    },
    {
      "name": "Faces",
      "description": "Face detection, recognition, training, and grouping"
    },
    {
      "name": "Tags",
      "description": "Face tag management - save, retrieve, add, and remove tags"
    }
  ],
  "paths": {
    "/account/authenticate.json": {
      "get": {
        "tags": ["Account"],
        "summary": "Test authentication",
        "description": "Test the connection and verify that the API key and secret are valid.",
        "operationId": "accountAuthenticate",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          }
        ],
        "responses": {
          "200": {
            "description": "Authentication status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/account/limits.json": {
      "get": {
        "tags": ["Account"],
        "summary": "Check usage limits",
        "description": "Returns the current quota usage and API limits for the account.",
        "operationId": "accountLimits",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          }
        ],
        "responses": {
          "200": {
            "description": "Account limits and usage",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LimitsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/account/namespaces.json": {
      "get": {
        "tags": ["Account"],
        "summary": "List namespaces",
        "description": "Returns all data namespaces associated with the API key.",
        "operationId": "accountNamespaces",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          }
        ],
        "responses": {
          "200": {
            "description": "List of namespaces",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NamespacesResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/account/users.json": {
      "get": {
        "tags": ["Account"],
        "summary": "List users in namespaces",
        "description": "Returns users registered in the specified namespaces.",
        "operationId": "accountUsers",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          },
          {
            "name": "namespaces",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of namespace names",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsersResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/faces/detect.json": {
      "get": {
        "tags": ["Faces"],
        "summary": "Detect faces in images",
        "description": "Detects faces in one or more images and returns face positions, attributes (yaw, roll, pitch), eye positions, and confidence scores.",
        "operationId": "facesDetect",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          },
          {
            "name": "urls",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of image URLs to process",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "description": "Comma-separated attributes to detect (e.g., 'all', 'age', 'gender', 'glasses', 'smiling')",
            "schema": {
              "type": "string",
              "default": "all"
            }
          },
          {
            "name": "detector",
            "in": "query",
            "description": "Face detector to use",
            "schema": {
              "type": "string",
              "enum": ["default", "aggressive"],
              "default": "default"
            }
          },
          {
            "$ref": "#/components/parameters/Callback"
          },
          {
            "$ref": "#/components/parameters/CallbackUrl"
          }
        ],
        "responses": {
          "200": {
            "description": "Face detection results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "post": {
        "tags": ["Faces"],
        "summary": "Detect faces in images (POST)",
        "description": "Detects faces in images. Supports image upload via multipart form data in addition to URLs.",
        "operationId": "facesDetectPost",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "urls": {
                    "type": "string",
                    "description": "Comma-separated list of image URLs"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image file upload"
                  },
                  "attributes": {
                    "type": "string",
                    "default": "all"
                  },
                  "detector": {
                    "type": "string",
                    "enum": ["default", "aggressive"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Face detection results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/faces/recognize.json": {
      "get": {
        "tags": ["Faces"],
        "summary": "Recognize faces in images",
        "description": "Detect and attempt to recognize trained users in photos. Returns matched user IDs with confidence scores.",
        "operationId": "facesRecognize",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          },
          {
            "name": "urls",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of image URLs",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uids",
            "in": "query",
            "required": true,
            "description": "Comma-separated user IDs to attempt recognition against (format: user@namespace)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "namespace",
            "in": "query",
            "description": "Default namespace for user IDs without explicit namespace",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "description": "Comma-separated attributes to detect",
            "schema": {
              "type": "string",
              "default": "all"
            }
          },
          {
            "name": "threshold",
            "in": "query",
            "description": "Minimum confidence threshold for recognition (0-100)",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of matches to return per face",
            "schema": {
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/Callback"
          },
          {
            "$ref": "#/components/parameters/CallbackUrl"
          }
        ],
        "responses": {
          "200": {
            "description": "Recognition results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecognitionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/faces/train.json": {
      "get": {
        "tags": ["Faces"],
        "summary": "Train face templates",
        "description": "Train face recognition templates for specified users based on previously saved tags.",
        "operationId": "facesTrain",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          },
          {
            "name": "uids",
            "in": "query",
            "required": true,
            "description": "Comma-separated user IDs to train (format: user@namespace)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "namespace",
            "in": "query",
            "description": "Default namespace",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Callback"
          },
          {
            "$ref": "#/components/parameters/CallbackUrl"
          }
        ],
        "responses": {
          "200": {
            "description": "Training initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrainingResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/faces/status.json": {
      "get": {
        "tags": ["Faces"],
        "summary": "Get training status",
        "description": "Check the training status for specified users.",
        "operationId": "facesStatus",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          },
          {
            "name": "uids",
            "in": "query",
            "required": true,
            "description": "Comma-separated user IDs to check (format: user@namespace)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "namespace",
            "in": "query",
            "description": "Default namespace",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Training status results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrainingResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/faces/group.json": {
      "get": {
        "tags": ["Faces"],
        "summary": "Group faces in images",
        "description": "Detect, group, and optionally recognize faces in photos. Groups similar faces together.",
        "operationId": "facesGroup",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          },
          {
            "name": "urls",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of image URLs",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uids",
            "in": "query",
            "description": "Comma-separated user IDs for optional recognition",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "namespace",
            "in": "query",
            "description": "Default namespace",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attributes",
            "in": "query",
            "description": "Comma-separated attributes to detect",
            "schema": {
              "type": "string",
              "default": "all"
            }
          },
          {
            "$ref": "#/components/parameters/Callback"
          },
          {
            "$ref": "#/components/parameters/CallbackUrl"
          }
        ],
        "responses": {
          "200": {
            "description": "Grouping results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GroupResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/tags/get.json": {
      "get": {
        "tags": ["Tags"],
        "summary": "Get saved tags",
        "description": "Retrieve previously saved face tags filtered by user IDs, photo IDs, or URLs.",
        "operationId": "tagsGet",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          },
          {
            "name": "uids",
            "in": "query",
            "description": "Comma-separated user IDs to filter by",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pids",
            "in": "query",
            "description": "Comma-separated photo IDs to filter by",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "urls",
            "in": "query",
            "description": "Comma-separated image URLs to filter by",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of tags to return",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order for results",
            "schema": {
              "type": "string",
              "enum": ["recent", "random"]
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Filter tags by attributes",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "namespace",
            "in": "query",
            "description": "Namespace to search within",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of tags",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TagsGetResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/tags/save.json": {
      "post": {
        "tags": ["Tags"],
        "summary": "Save face tags",
        "description": "Save detected face tags to permanent storage, associating them with a user ID.",
        "operationId": "tagsSave",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["uid", "tids"],
                "properties": {
                  "uid": {
                    "type": "string",
                    "description": "User ID to associate with the tags (format: user@namespace)"
                  },
                  "tids": {
                    "type": "string",
                    "description": "Comma-separated tag IDs to save"
                  },
                  "label": {
                    "type": "string",
                    "description": "Optional label for the tags"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tags saved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/tags/add.json": {
      "post": {
        "tags": ["Tags"],
        "summary": "Add manual face tags",
        "description": "Manually add face tags to an image with specified coordinates.",
        "operationId": "tagsAdd",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["uid", "url", "x", "y", "width", "height"],
                "properties": {
                  "uid": {
                    "type": "string",
                    "description": "User ID (format: user@namespace)"
                  },
                  "url": {
                    "type": "string",
                    "description": "Image URL"
                  },
                  "x": {
                    "type": "number",
                    "description": "X position of the face center (percentage of image width)"
                  },
                  "y": {
                    "type": "number",
                    "description": "Y position of the face center (percentage of image height)"
                  },
                  "width": {
                    "type": "number",
                    "description": "Width of the face area (percentage of image width)"
                  },
                  "height": {
                    "type": "number",
                    "description": "Height of the face area (percentage of image height)"
                  },
                  "label": {
                    "type": "string",
                    "description": "Optional label"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tag added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/tags/remove.json": {
      "post": {
        "tags": ["Tags"],
        "summary": "Remove face tags",
        "description": "Remove previously saved face tags.",
        "operationId": "tagsRemove",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKey"
          },
          {
            "$ref": "#/components/parameters/ApiSecret"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["tids"],
                "properties": {
                  "tids": {
                    "type": "string",
                    "description": "Comma-separated tag IDs to remove"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tags removed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeySecret": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key provided by SkyBiometry. Must be used together with api_secret query parameter for server-side requests."
      }
    },
    "parameters": {
      "ApiKey": {
        "name": "api_key",
        "in": "query",
        "required": true,
        "description": "Application API key",
        "schema": {
          "type": "string"
        }
      },
      "ApiSecret": {
        "name": "api_secret",
        "in": "query",
        "required": true,
        "description": "Application API secret",
        "schema": {
          "type": "string"
        }
      },
      "Callback": {
        "name": "callback",
        "in": "query",
        "description": "JSONP callback function name",
        "schema": {
          "type": "string"
        }
      },
      "CallbackUrl": {
        "name": "callback_url",
        "in": "query",
        "description": "URL to POST asynchronous results to",
        "schema": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "schemas": {
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "failure"]
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "LimitsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          },
          "limits": {
            "type": "object",
            "properties": {
              "used": {
                "type": "integer",
                "description": "Number of API calls used"
              },
              "remaining": {
                "type": "integer",
                "description": "Number of API calls remaining"
              },
              "limit": {
                "type": "integer",
                "description": "Total API call limit"
              },
              "reset_time": {
                "type": "string",
                "format": "date-time",
                "description": "When the usage counter resets"
              }
            }
          }
        }
      },
      "NamespacesResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "namespaces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "UsersResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "users": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Map of namespace to list of user IDs"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "DetectionResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "photos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Photo"
            }
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "RecognitionResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "photos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Photo"
            }
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "TrainingResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "updated": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "uid": {
                  "type": "string"
                },
                "training_set_size": {
                  "type": "integer"
                },
                "last_trained": {
                  "type": "string",
                  "format": "date-time"
                },
                "training_in_progress": {
                  "type": "boolean"
                }
              }
            }
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "GroupResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tids": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "uids": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UidMatch"
                  }
                }
              }
            }
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "TagsGetResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "photos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Photo"
            }
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "Photo": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "pid": {
            "type": "string",
            "description": "Photo ID"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "tid": {
            "type": "string",
            "description": "Tag ID"
          },
          "recognizable": {
            "type": "boolean"
          },
          "confirmed": {
            "type": "boolean"
          },
          "manual": {
            "type": "boolean"
          },
          "width": {
            "type": "number",
            "description": "Width of face area as percentage of image"
          },
          "height": {
            "type": "number",
            "description": "Height of face area as percentage of image"
          },
          "center": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              }
            }
          },
          "eye_left": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              }
            }
          },
          "eye_right": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              }
            }
          },
          "yaw": {
            "type": "number",
            "description": "Face yaw angle"
          },
          "roll": {
            "type": "number",
            "description": "Face roll angle"
          },
          "pitch": {
            "type": "number",
            "description": "Face pitch angle"
          },
          "attributes": {
            "type": "object",
            "properties": {
              "face": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string"
                  },
                  "confidence": {
                    "type": "integer"
                  }
                }
              },
              "gender": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string"
                  },
                  "confidence": {
                    "type": "integer"
                  }
                }
              },
              "age_est": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "integer"
                  },
                  "confidence": {
                    "type": "integer"
                  }
                }
              },
              "glasses": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string"
                  },
                  "confidence": {
                    "type": "integer"
                  }
                }
              },
              "smiling": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "boolean"
                  },
                  "confidence": {
                    "type": "integer"
                  }
                }
              }
            }
          },
          "uids": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UidMatch"
            }
          }
        }
      },
      "UidMatch": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "description": "Recognition confidence (0-100)"
          }
        }
      },
      "Usage": {
        "type": "object",
        "properties": {
          "used": {
            "type": "integer"
          },
          "remaining": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "reset_time_text": {
            "type": "string"
          },
          "reset_time": {
            "type": "integer"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "failure"
          },
          "error_code": {
            "type": "integer"
          },
          "error_message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid or missing parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid API key or secret",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  }
}
