    "/api/request-monitor/api-usage": {
      "get": {
        "summary": "Get API Usage for All Requests",
        "description": "Retrieve the API usage details for all requests.",
        "operationId": "getApiUsageAll",
        "tags": [
          "Monitoring"
        ],
        "parameters": [
