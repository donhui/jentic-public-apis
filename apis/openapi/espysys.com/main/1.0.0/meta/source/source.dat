{
  "openapi": "3.0.3",
  "info": {
    "title": "IRBIS API",
    "version": "1.0.0",
    "description": "ESPY/IRBIS is a comprehensive tool for validating phone numbers, verifying customer identities, and leveraging API endpoints for data enrichment and fraud prevention.",
    "x-jentic-source-url": "https://api-docs.espysys.com/"
  },
  "servers": [
    {
      "url": "https://irbis.espysys.com",
      "description": "IRBIS API Production"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "key"
      }
    },
    "schemas": {
      "LookupRequest": {
        "type": "object",
        "required": [
          "key",
          "value",
          "lookupId"
        ],
        "properties": {
          "key": {
            "type": "string",
            "description": "Your unique API key"
          },
          "value": {
            "type": "string",
            "description": "The value to search for (phone number, email, name, etc.)"
          },
          "lookupId": {
            "type": "integer",
            "description": "The lookup type ID from the LookupId-List endpoint"
          }
        }
      },
      "DeepwebLookupRequest": {
        "type": "object",
        "required": [
          "key",
          "value",
          "lookupType",
          "lookupId"
        ],
        "properties": {
          "key": {
            "type": "string",
            "description": "Your unique API key"
          },
          "value": {
            "type": "string",
            "description": "The value to search for"
          },
          "lookupType": {
            "type": "string",
            "description": "Type of deepweb lookup",
            "enum": [
              "email",
              "phone",
              "facebookid",
              "telegramid",
              "password",
              "linkedinid",
              "vkid",
              "instagramid",
              "twitterid",
              "fullname"
            ]
          },
          "lookupId": {
            "type": "integer",
            "description": "The lookup type ID"
          }
        }
      },
      "LookupResponse": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "format": "uuid"
          },
          "id": {
            "type": "integer",
            "description": "Response ID for retrieving results"
          },
          "status": {
            "type": "string",
            "description": "Status of the request"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "CreditStatus": {
        "type": "object",
        "properties": {
          "balance": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string"
          },
          "credits": {
            "type": "integer"
          },
          "expiratioDate": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "DeleteRequest": {
        "type": "object",
        "required": [
          "key"
        ],
        "properties": {
          "key": {
            "type": "string",
            "description": "Your unique API key"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Lookups",
      "description": "Data lookup and enrichment endpoints"
    },
    {
      "name": "Monitoring",
      "description": "API usage monitoring endpoints"
    },
    {
      "name": "Management",
      "description": "Record management endpoints"
    }
  ],
  "paths": {
    "/api/developer/deepweb": {
      "post": {
        "summary": "BreachScan Lookup",
        "description": "Perform a BreachScan based on criteria such as email, phone, social IDs, password, or fullname.",
        "operationId": "breachScanLookup",
        "tags": [
          "Lookups"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/{'$ref': '#/components/schemas/DeepwebLookupRequest'}"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lookup initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LookupResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        }
      }
    },
    "/api/developer/combined_phone": {
      "post": {
        "summary": "Phone Lookup",
        "description": "Phone Lookup or Phone WebScan. Gather information by phone number in real-time from mobile applications and exposed data sources.",
        "operationId": "phoneLookup",
        "tags": [
          "Lookups"
        ],
        "requestBody": {
          "required": true,
