  },
  "servers": [
    {
      "url": "/services/swagger/gestionetessera"
    }
  ],
  "paths": {
    "/saldopunti": {
      "get": {
        "tags": [
          "gestionetessera"
        ],
        "summary": "Richiede il saldo punti di una tessera fedeltà.",
        "description": "Richiede il saldo punti di una tessera fedeltà.",
        "operationId": "getSaldoPunti",
        "parameters": [
          {
            "name": "tessera",
            "in": "query",
            "description": "numero della tessera",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Basic {base64_encode($username . ':' . $password)}",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "SourceApplication",
            "in": "header",
            "description": "Applicazione chiamante",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "TransmissionId",
            "in": "header",
            "description": "Identificativo trasmissione",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SaldoPuntiResponse"
                }
              }
            }
          },
          "401": {
            "description": "Client non autorizzato all'operazione"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SaldoPuntiResponse": {
        "type": "object",
        "required": [
          "codice"
        ],
        "properties": {
          "codice": {
            "type": "string",
            "description": "esito della chiamata"
          },
          "descrizione": {
            "type": "string",
            "description": "messaggio di errore in caso di esito negativo"
          },
          "tessera": {
            "$ref": "#/components/schemas/Tessera"
          }
        },
        "description": "Risposta per il saldo punti"
      },
      "Tessera": {
        "type": "object",
        "properties": {
          "puntiA": {
            "type": "string",
            "description": "saldo dei punti A"
          },
          "puntiB": {
            "type": "string",
            "description": "saldo dei punti B"
          },
          "labelpuntiA": {
            "type": "string",
            "description": "etichetta punti A"
          },
          "labelpuntiB": {
            "type": "string",
            "description": "etichetta punti B"
          },
          "pdv": {
            "type": "string",
            "description": "codice pdv"
          },
          "mostrasaldo": {
            "type": "string",
            "description": "mostra saldo"
          },
          "tipocarta": {
            "type": "string",
            "description": "tipo carta"
          },
          "tipocartadesc": {
            "type": "string",
            "description": "dscrizione tipo carta"
          },
          "ultimomovimento": {
            "type": "string",
            "description": "ultimo movimento"
          }
        },
        "description": "Informazioni sulla tessera"
      }
    }
  },
  "tags": [
    {
      "name": "gestionetessera",
      "description": "Operazioni gestione tessera"
    }
  ]
