{
  "openapi": "3.0.3",
  "info": {
    "title": "Groove REST API",
    "description": "Groove REST API for managing customer support tickets, messages, customers, agents, groups, mailboxes, folders, and webhooks. Note: This REST API is no longer in active development; Groove recommends using their GraphQL API for newer features.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.groovehq.com/docs"
  },
  "servers": [
    {
      "url": "https://api.groovehq.com/v1",
      "description": "Groove REST API v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "apiKeyParam": []
    }
  ],
  "paths": {
    "/tickets": {
      "get": {
        "operationId": "listtickets",
        "summary": "List all tickets",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "assignee",
            "in": "query",
            "description": "Filter by agent email or 'unassigned'",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "customer",
            "in": "query",
            "description": "Filter by customer email or ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page (max 50)",
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 50
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Filter by ticket state",
            "schema": {
              "type": "string",
              "enum": [
                "unread",
                "opened",
                "pending",
                "closed",
                "spam"
              ]
            }
          },
          {
            "name": "folder",
            "in": "query",
            "description": "Filter by folder ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of tickets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tickets": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Ticket"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createticket",
        "summary": "Create a new ticket",
        "tags": [
          "Tickets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTicketRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Ticket created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ticket": {
                      "$ref": "#/components/schemas/Ticket"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tickets/{ticket_number}": {
      "get": {
        "operationId": "getticket",
        "summary": "Find one ticket",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "ticket_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticket details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ticket": {
                      "$ref": "#/components/schemas/Ticket"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/{ticket_number}/state": {
      "get": {
        "operationId": "getticketstate",
        "summary": "Find ticket state",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "ticket_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ticket state",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "state": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "put": {
        "operationId": "updateticketstate",
        "summary": "Update ticket state",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "ticket_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "state"
                ],
                "properties": {
                  "state": {
                    "type": "string",
                    "enum": [
                      "unread",
                      "opened",
                      "pending",
                      "closed",
                      "spam"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "State updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/{ticket_number}/assignee": {
      "get": {
        "operationId": "getticketassignee",
        "summary": "Find ticket assignee",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "ticket_number",
            "in": "path",
