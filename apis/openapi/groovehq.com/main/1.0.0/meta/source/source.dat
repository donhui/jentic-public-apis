          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "put": {
        "operationId": "replaceticketlabels",
        "summary": "Replace all labels on a ticket",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "ticket_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
