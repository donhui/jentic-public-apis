          "Tickets"
        ],
        "parameters": [
          {
            "name": "ticket_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "assignee"
                ],
                "properties": {
                  "assignee": {
                    "type": "string",
                    "description": "Agent email"
                  },
                  "skip_notifications": {
                    "type": "boolean",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Assignee updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/{ticket_number}/assigned_group": {
      "put": {
        "operationId": "updateticketassignedgroup",
        "summary": "Update ticket assigned group",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "ticket_number",
            "in": "path",
            "required": true,
            "schema": {
