    "/customers/{customer_email}": {
      "get": {
        "operationId": "getCustomer",
        "summary": "Get a single customer",
        "description": "Retrieves a single customer by email.",
        "tags": ["Customers"],
        "parameters": [
          {
            "name": "customer_email",
