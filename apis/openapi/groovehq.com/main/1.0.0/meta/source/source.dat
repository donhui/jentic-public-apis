  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Access token obtained from the Groove admin panel. Can also be passed as access_token query parameter."
      }
    },
    "schemas": {
      "Ticket": {
        "type": "object",
        "properties": {
          "number": {
            "type": "integer"
          },
          "subject": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": ["unread", "opened", "pending", "closed", "spam"]
          },
          "starred": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "href": {
            "type": "string"
          },
          "links": {
            "type": "object",
            "properties": {
              "assignee": {
                "type": "string"
              },
              "customer": {
                "type": "string"
              },
              "messages": {
                "type": "string"
              }
            }
          }
        }
      },
      "CreateTicketRequest": {
        "type": "object",
        "required": ["body", "from", "to"],
        "properties": {
          "body": {
            "type": "string",
            "description": "Initial comment content"
          },
          "from": {
            "type": "string",
            "description": "Agent email or customer email"
          },
          "to": {
            "type": "string",
            "description": "Customer email or mailbox address"
          },
          "mailbox": {
            "type": "string",
            "description": "Mailbox email or ID"
          },
          "assigned_group": {
            "type": "string",
            "description": "Group name"
          },
          "assignee": {
            "type": "string",
            "description": "Agent email"
          },
          "sent_at": {
            "type": "string",
            "format": "date-time",
            "description": "RFC-822 timestamp"
          },
          "note": {
            "type": "boolean",
            "default": false,
            "description": "Create as private note"
          },
          "send_copy_to_customer": {
            "type": "boolean",
            "default": false
          },
          "state": {
            "type": "string",
            "enum": ["unread", "opened", "pending", "closed", "spam"],
            "default": "unread"
          },
          "subject": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "starred": {
            "type": "boolean",
            "default": false
          },
          "skip_notifications": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "plain_text_body": {
            "type": "string"
          },
          "note": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "href": {
            "type": "string"
          },
          "links": {
            "type": "object",
            "properties": {
              "attachments": {
                "type": "string"
              },
              "author": {
                "type": "string"
              },
              "recipient": {
                "type": "string"
              },
              "ticket": {
                "type": "string"
              }
            }
          }
        }
      },
      "CreateMessageRequest": {
        "type": "object",
        "required": ["body"],
        "properties": {
          "body": {
            "type": "string",
            "description": "Message content"
          },
          "author": {
            "type": "string",
            "description": "Email of agent or customer"
          },
          "sent_at": {
            "type": "string",
            "format": "date-time",
            "description": "RFC-822 format for backdating"
          },
          "note": {
            "type": "boolean",
            "default": false
          },
          "send_copy_to_customer": {
            "type": "boolean",
            "default": false
          },
          "skip_unread_ticket": {
            "type": "boolean",
            "default": false
          },
          "skip_notifications": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "about": {
            "type": "string"
          },
          "twitter_username": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "linkedin_username": {
            "type": "string"
          },
          "custom": {
            "type": "object",
            "additionalProperties": true
          },
          "href": {
            "type": "string"
          }
        }
      },
      "UpdateCustomerRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "about": {
            "type": "string"
          },
          "twitter_username": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "linkedin_username": {
            "type": "string"
          },
          "custom": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "Agent": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "links": {
            "type": "object",
            "properties": {
              "tickets": {
                "type": "string"
              }
            }
          }
        }
      },
      "Mailbox": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "links": {
            "type": "object",
            "properties": {
              "folders": {
                "type": "string"
              }
            }
          }
        }
      },
      "Folder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "agent_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CreateGroupRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "agents": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of agent emails or IDs"
          }
        }
      },
      "Attachment": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        }
      },
      "CreateWebhookRequest": {
        "type": "object",
        "required": ["event", "url"],
        "properties": {
          "event": {
            "type": "string",
            "enum": [
              "ticket_started",
              "ticket_opened",
              "ticket_closed",
              "ticket_assigned",
              "ticket_priority_changed",
              "ticket_deleted",
              "ticket_tagged",
              "ticket_moved",
              "customer_replied",
              "customer_added",
              "agent_invited",
              "agent_archived",
              "note_added",
              "agent_replied"
            ],
            "description": "Event type to subscribe to"
          },
          "url": {
            "type": "string",
            "description": "URL to receive webhook payloads"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Tickets",
      "description": "Manage support tickets"
    },
    {
      "name": "Messages",
      "description": "Manage ticket messages and notes"
    },
    {
      "name": "Customers",
      "description": "Manage customer profiles"
    },
    {
      "name": "Agents",
      "description": "View agent information"
    },
    {
      "name": "Mailboxes",
      "description": "View mailbox configuration"
    },
    {
      "name": "Folders",
      "description": "View folder organization"
    },
    {
      "name": "Groups",
      "description": "Manage agent groups"
    },
    {
      "name": "Attachments",
      "description": "Manage message attachments"
    },
    {
      "name": "Webhooks",
      "description": "Manage webhook subscriptions"
    }
  ]
}