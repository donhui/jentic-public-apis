            "description": "Labels replaced"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/tickets/{ticket_id}/change_mailbox/{mailbox_id}": {
