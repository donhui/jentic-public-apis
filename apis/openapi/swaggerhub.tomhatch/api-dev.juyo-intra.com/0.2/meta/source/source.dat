    "/embed/{hostToken}/hotel/{hotelToken}/dashboards": {
      "get": {
        "tags": [
          "public"
        ],
        "description": "Get the available dashboards for a hotel",
        "parameters": [
          {
            "in": "path",
            "name": "hostToken",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The host token for which you want to check the available dashboards"
          },
          {
            "in": "path",
            "name": "hotelToken",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The hotel token for which you want to check the available dashboards"
          }
        ],
        "responses": {
          "200": {
            "description": "On success, will return a list of available dashboards",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dashboards": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "examples": {}
              }
            }
          }
        },
        "servers": [
          {
            "url": "https://api-dev.juyo-intra.com"
          }
        ]
      },
      "servers": [
        {
          "url": "https://api-dev.juyo-intra.com"
        }
      ]
    },
    "/embed/{hostToken}/cluster/{clusterToken}/dashboards": {
      "get": {
        "tags": [
          "public"
        ],
        "description": "Get the available dashboards for a cluster",
        "parameters": [
          {
            "in": "path",
            "name": "hostToken",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The host token for which you want to check the available dashboards"
          },
          {
            "in": "path",
            "name": "clusterToken",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The cluster token for which you want to check the available dashboards"
          }
        ],
        "responses": {
          "200": {
            "description": "On success, will return a list of available dashboards",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dashboards": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "examples": {}
              }
            }
          }
        },
        "servers": [
          {
            "url": "https://api-dev.juyo-intra.com"
          }
        ]
      },
      "servers": [
        {
          "url": "https://api-dev.juyo-intra.com"
        }
      ]
    },
    "/embed/{hostToken}/{token}/embed-token": {
      "get": {
        "tags": [
          "public"
        ],
        "description": "Request an embed token. This token is required when requesting a dashboard",
        "parameters": [
          {
            "in": "path",
            "name": "hostToken",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The host token for which you want to check the available dashboards"
          },
          {
            "in": "path",
            "name": "token",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The hotel token or cluster tokenfor which you want to check the available dashboards"
          }
        ],
        "responses": {
          "200": {
            "description": "On success, will return an embed token. This token is only valid for a short period of time.",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    }
                  }
                },
                "examples": {}
              }
            }
          }
        },
        "servers": [
          {
            "url": "https://api-dev.juyo-intra.com"
          }
        ]
      },
      "servers": [
        {
          "url": "https://api-dev.juyo-intra.com"
        }
      ]
    }
  }
