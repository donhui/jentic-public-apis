      },
      "put": {
        "tags": [
          "private"
        ],
        "description": "Update an embed hotel",
        "parameters": [
          {
            "in": "path",
            "name": "hostToken",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The host token for which you want to update the hotel"
          },
          {
            "in": "path",
            "name": "hotelToken",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The hotel token for the hotel that you want to update"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "integer"
                  },
                  "hotelId": {
                    "type": "integer"
                  },
                  "tier": {
                    "type": "string"
                  }
                }
              },
              "examples": {
                "0": {
                  "value": "{\n    \"username\": \"my-unique-embed-user@email.com\",\n    \"userId\": 123,\n    \"hotelId\": 456,\n    \"tier\": \"juyoPackage1 | juyoPackage2 | juyoPackage3\"\n}"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        },
        "servers": [
          {
            "url": "https://api-dev.juyo-intra.com"
          }
        ]
