      "servers": [
        {
          "url": "https://api-dev.juyo-intra.com"
        }
      ]
    },
    "/internal/embed/{hostToken}/add-cluster": {
      "post": {
        "tags": [
          "private"
        ],
        "description": "Add a cluster with a unique embed user for a host",
        "parameters": [
          {
            "in": "path",
            "name": "hostToken",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The host token for which you want to add a cluster"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "clusterToken": {
                    "type": "string"
                  },
                  "clusterName": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "integer"
                  },
                  "tier": {
                    "type": "string"
                  },
                  "currency": {
                    "type": "string"
                  },
                  "currencyHtml": {
                    "type": "string"
                  }
                }
              },
              "examples": {
                "0": {
                  "value": "{\n    \"clusterToken\": \"abc\",\n    \"clusterName\": \"test\"\n    \"username\": \"my-unique-embed-user@email.com\",\n    \"hotelId\": 456,\n    \"tier\": \"juyoPackage1 | juyoPackage2 | juyoPackage3\",\n    \"currency: \"EUR\",\n    \"currencyHtml\": \"&euro;\"\n}"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        },
        "servers": [
          {
            "url": "https://api-dev.juyo-intra.com"
          }
        ]
      },
      "servers": [
        {
          "url": "https://api-dev.juyo-intra.com"
        }
      ]
    },
