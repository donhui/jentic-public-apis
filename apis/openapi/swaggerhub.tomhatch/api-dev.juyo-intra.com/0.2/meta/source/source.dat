{
  "openapi": "3.0.1",
  "info": {
    "title": "api-dev.juyo-intra.com",
    "description": "Api documentation for the embed endpoints",
    "version": "0.2",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/TomHatch/api-dev.juyo-intra.com/0.2/swagger.json"
  },
  "tags": [
    {
      "name": "private",
      "description": "Secured, only Juyo can access this."
    },
    {
      "name": "public",
      "description": "Anyone with a valid host token can access these."
    }
  ],
  "servers": [
    {
      "url": "https://api-dev.juyo-intra.com"
    }
  ],
  "paths": {
    "/internal/embed/{hostToken}/add-hotel": {
      "post": {
        "tags": [
          "private"
        ],
        "description": "Add a hotel with a unique embed user for a host",
        "parameters": [
          {
            "in": "path",
            "name": "hostToken",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "The host token for which you want to add an hotel"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "hotelToken": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "integer"
                  },
                  "hotelId": {
                    "type": "integer"
                  },
                  "tier": {
                    "type": "string"
                  }
                }
              },
              "examples": {
                "0": {
                  "value": "{\n    \"hotelToken\": \"abc\",\n    \"username\": \"my-unique-embed-user@email.com\",\n    \"userId\": 123,\n    \"hotelId\": 456,\n    \"tier\": \"juyoPackage1 | juyoPackage2 | juyoPackage3\"\n}"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        },
        "servers": [
          {
            "url": "https://api-dev.juyo-intra.com"
          }
        ]
      },
      "servers": [
        {
          "url": "https://api-dev.juyo-intra.com"
        }
      ]
    },
