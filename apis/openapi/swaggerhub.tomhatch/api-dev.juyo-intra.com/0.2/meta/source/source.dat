              "type": "string"
            },
            "required": true,
            "description": "The cluster token for the cluster that you want to update"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "clusterName": {
                    "type": "string"
                  },
                  "userId": {
                    "type": "integer"
                  },
                  "tier": {
                    "type": "string"
                  },
                  "currency": {
                    "type": "string"
                  },
                  "currencyHtml": {
                    "type": "string"
                  }
                }
              },
              "examples": {
                "0": {
                  "value": "{\n    \"clusterName\": \"test\"\n    \"username\": \"my-unique-embed-user@email.com\",\n    \"hotelId\": 456,\n    \"tier\": \"juyoPackage1 | juyoPackage2 | juyoPackage3\",\n    \"currency: \"EUR\",\n    \"currencyHtml\": \"&euro;\"\n}"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        },
        "servers": [
