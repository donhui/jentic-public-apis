{
  "openapi": "3.0.3",
  "info": {
    "title": "Tankerkoenig API",
    "description": "German realtime gas/diesel prices. Provides real-time fuel price data for gas stations across Germany under an open data/open source license, even for commercial use.",
    "version": "4.0.6",
    "contact": {
      "name": "Tankerkoenig",
      "url": "https://creativecommons.tankerkoenig.de"
    },
    "license": {
      "name": "Creative Commons",
      "url": "https://creativecommons.org/licenses/by/4.0/"
    },
    "x-jentic-source-url": "https://creativecommons.tankerkoenig.de/swagger/"
  },
  "servers": [
    {
      "url": "https://creativecommons.tankerkoenig.de/api/v4",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Stations",
      "description": "Gas station search and lookup operations"
    },
    {
      "name": "Statistics",
      "description": "Aggregate fuel price statistics"
    },
    {
      "name": "Complaints",
      "description": "Submit corrections for inaccurate station data"
    }
  ],
  "paths": {
    "/stations/search": {
      "get": {
        "tags": ["Stations"],
        "summary": "Search nearby gas stations",
        "description": "Retrieves nearby gas stations with current fuel prices based on geographic coordinates and search radius.",
        "operationId": "searchStations",
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "UUID-formatted API key",
            "schema": {
              "type": "string",
              "format": "uuid",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
            }
          },
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "description": "Latitude of the search center",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lng",
            "in": "query",
            "required": true,
            "description": "Longitude of the search center",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "rad",
            "in": "query",
            "required": false,
            "description": "Search radius in kilometers (0-25)",
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": 0,
              "maximum": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with list of nearby stations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StationSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stations/ids": {
      "get": {
        "tags": ["Stations"],
        "summary": "Get stations by IDs",
        "description": "Fetches specific gas stations by their UUIDs with current fuel prices.",
        "operationId": "getStationsByIds",
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "UUID-formatted API key",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "ids",
            "in": "query",
            "required": true,
            "description": "Comma-separated list of station UUIDs",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lat",
            "in": "query",
            "required": false,
            "description": "Latitude for distance calculation",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lng",
            "in": "query",
            "required": false,
            "description": "Longitude for distance calculation",
            "schema": {
              "type": "number",
              "format": "double"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with station details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StationSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stations/postalcode": {
      "get": {
        "tags": ["Stations"],
        "summary": "Search stations by postal code",
        "description": "Searches gas stations by German postal code.",
        "operationId": "getStationsByPostalCode",
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "UUID-formatted API key",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "postalcode",
            "in": "query",
            "required": true,
            "description": "Postal code to search (e.g., '70372')",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with stations in the postal code area",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StationSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stats": {
      "get": {
        "tags": ["Statistics"],
        "summary": "Get fuel price statistics",
        "description": "Retrieves aggregate fuel price statistics across Germany including mean, median, and count for Diesel, E5, and E10.",
        "operationId": "getStatistics",
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "UUID-formatted API key",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with fuel price statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatisticsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Service unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/complaint": {
      "post": {
        "tags": ["Complaints"],
        "summary": "Submit a complaint",
        "description": "Submits corrections for inaccurate gas station data such as wrong prices, addresses, or status.",
        "operationId": "submitComplaint",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ComplaintRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Complaint submitted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComplaintResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "apikey",
        "in": "query",
        "description": "UUID-formatted API key passed as a query parameter"
      }
    },
    "schemas": {
      "Station": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique station identifier"
          },
          "country": {
            "type": "string",
            "description": "Country code"
          },
          "name": {
            "type": "string",
            "description": "Station name"
          },
          "brand": {
            "type": "string",
            "description": "Brand name of the station"
          },
          "street": {
            "type": "string",
            "description": "Street address"
          },
          "postalCode": {
            "type": "string",
            "description": "Postal code"
          },
          "place": {
            "type": "string",
            "description": "City or town name"
          },
          "coords": {
            "$ref": "#/components/schemas/Coordinates"
          },
          "isOpen": {
            "type": "boolean",
            "description": "Whether the station is currently open"
          },
          "closesAt": {
            "type": "string",
            "format": "date-time",
            "description": "Next closing time"
          },
          "opensAt": {
            "type": "string",
            "format": "date-time",
            "description": "Next opening time"
          },
          "openingTimes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OpeningTime"
            },
            "description": "Regular opening times schedule"
          },
          "dist": {
            "type": "number",
            "format": "double",
            "description": "Distance from search coordinates in km"
          },
          "fuels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Fuel"
            },
            "description": "Available fuels and their current prices"
          }
        }
      },
      "Coordinates": {
        "type": "object",
        "properties": {
          "lat": {
            "type": "number",
            "format": "double",
            "description": "Latitude"
          },
          "lng": {
            "type": "number",
            "format": "double",
            "description": "Longitude"
          }
        }
      },
      "OpeningTime": {
        "type": "object",
        "properties": {
          "day": {
            "type": "string",
            "description": "Day of the week"
          },
          "open": {
            "type": "string",
            "description": "Opening time (HH:MM)"
          },
          "close": {
            "type": "string",
            "description": "Closing time (HH:MM)"
          }
        }
      },
      "Fuel": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": ["diesel", "lpg", "gasoline", "cng"],
            "description": "Fuel category"
          },
          "name": {
            "type": "string",
            "description": "Fuel name (e.g., Diesel, Super E5, Super E10)"
          },
          "price": {
            "type": "number",
            "format": "float",
            "description": "Current price per liter in EUR"
          },
          "lastChange": {
            "$ref": "#/components/schemas/PriceChange"
          }
        }
      },
      "PriceChange": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When the price last changed"
          },
          "amount": {
            "type": "number",
            "format": "float",
            "description": "Amount of the price change"
          }
        }
      },
      "StationSearchResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the request was successful"
          },
          "stations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Station"
            }
          }
        }
      },
      "StatisticsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "diesel": {
            "$ref": "#/components/schemas/FuelStatistics"
          },
          "e5": {
            "$ref": "#/components/schemas/FuelStatistics"
          },
          "e10": {
            "$ref": "#/components/schemas/FuelStatistics"
          }
        }
      },
      "FuelStatistics": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Number of stations reporting this fuel type"
          },
          "mean": {
            "type": "number",
            "format": "float",
            "description": "Mean price"
          },
          "median": {
            "type": "number",
            "format": "float",
            "description": "Median price"
          }
        }
      },
      "ComplaintRequest": {
        "type": "object",
        "required": ["apikey", "id", "type", "correction"],
        "properties": {
          "apikey": {
            "type": "string",
            "format": "uuid",
            "description": "API key"
          },
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Station UUID"
          },
          "type": {
            "type": "string",
            "enum": ["name", "status", "price", "brand", "address", "location"],
            "description": "Type of complaint"
          },
          "correction": {
            "type": "string",
            "description": "The corrected value"
          }
        }
      },
      "ComplaintResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}
