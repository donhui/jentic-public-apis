  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token obtained via /auth/token endpoint"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "accessToken": {
                "type": "string"
              },
              "expiresIn": {
                "type": "integer"
              }
            }
          }
        }
      },
      "BalanceResponse": {
        "type": "object",
        "properties": {
          "usableBalance": {
            "type": "number"
          },
          "pendingBalance": {
            "type": "number"
          },
          "totalBalance": {
            "type": "number"
          }
        }
      },
      "DisbursementRequest": {
        "type": "object",
        "required": [
          "referenceId",
          "amount",
          "disbursementMethod"
        ],
        "properties": {
          "referenceId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "disbursementMethod": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "bankShortCode": {
                "type": "string"
              },
              "bankAccountNo": {
                "type": "string"
              },
              "bankAccountHolderName": {
                "type": "string"
              }
            }
          },
          "recipientEmail": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "DisbursementResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "referenceId": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "VirtualAccountRequest": {
        "type": "object",
        "properties": {
          "bankShortCode": {
            "type": "string"
          },
          "referenceId": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "VirtualAccountResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "virtualAccountNumber": {
            "type": "string"
          },
          "bankShortCode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "amount": {
            "type": "number"
