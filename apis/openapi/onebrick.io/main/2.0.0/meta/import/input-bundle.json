{
  "openapi": "3.0.3",
  "info": {
    "title": "OneBrick Payment API",
    "version": "2.0.0",
    "description": "OneBrick provides financial infrastructure APIs for payments, disbursements, virtual accounts, QRIS, e-wallets, and bank data services in Indonesia.",
    "x-jentic-source-url": "https://onebrick.readme.io/reference/api-introduction",
    "contact": {
      "name": "OneBrick",
      "url": "https://www.onebrick.io",
      "email": "support@onebrick.io"
    }
  },
  "servers": [
    {
      "url": "https://sandbox.onebrick.io/v2",
      "description": "Sandbox Environment"
    },
    {
      "url": "https://api.onebrick.io/v2",
      "description": "Production Environment"
    }
  ],
  "paths": {
    "/auth/token": {
      "post": {
        "operationId": "generateAccessToken",
        "summary": "Generate Public Access Token",
        "description": "Generate a public access token using client credentials. Token is valid for 5 minutes and single-use.",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "parameters": [
          {
            "name": "Client-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client ID"
          },
          {
            "name": "Client-Secret",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client Secret"
          }
        ],
        "responses": {
          "200": {
            "description": "Access token generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/balance": {
      "get": {
        "operationId": "getAccountBalance",
        "summary": "Get Account Balance",
        "description": "Retrieve account balance including usable, pending, and total balance.",
        "tags": [
          "Balance"
        ],
        "responses": {
          "200": {
            "description": "Balance retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BalanceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/top-up/bank/list": {
      "get": {
        "operationId": "listTopUpOptions",
        "summary": "List Top-Up Options",
        "description": "List available top-up bank options.",
        "tags": [
          "Balance"
        ],
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            },
            "description": "Account email"
          }
        ],
        "responses": {
          "200": {
            "description": "Top-up options listed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "bankName": {
                            "type": "string"
                          },
                          "bankCode": {
                            "type": "string"
                          },
                          "accountNumber": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/disbursements": {
      "post": {
        "operationId": "createDisbursement",
        "summary": "Create Disbursement",
        "description": "Create a regular disbursement (money-out) transaction.",
        "tags": [
          "Disbursement"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DisbursementRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Disbursement created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DisbursementResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/bifast-disbursements": {
      "post": {
        "operationId": "createBifastDisbursement",
        "summary": "Create BIFAST Disbursement",
        "description": "Create a BIFAST fast disbursement transaction with sender details.",
        "tags": [
          "Disbursement"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/DisbursementRequest"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "senderName": {
                        "type": "string"
                      },
                      "senderIdentity": {
                        "type": "string"
                      },
                      "senderAddress": {
                        "type": "string"
                      },
                      "senderDob": {
                        "type": "string",
                        "format": "date"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "BIFAST disbursement created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DisbursementResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/bank-account-validation": {
      "get": {
        "operationId": "validateBankAccount",
        "summary": "Validate Bank Account",
        "description": "Validate a recipient bank account number.",
        "tags": [
          "Bank Data"
        ],
        "parameters": [
          {
            "name": "accountNumber",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bankShortCode",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accountNumber": {
                      "type": "string"
                    },
                    "accountName": {
                      "type": "string"
                    },
                    "bankCode": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/disbursements/{disbursementId}": {
      "get": {
        "operationId": "getDisbursementStatus",
        "summary": "Get Disbursement Status",
        "description": "Check disbursement status by ID.",
        "tags": [
          "Disbursement"
        ],
        "parameters": [
          {
            "name": "disbursementId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Disbursement details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DisbursementResponse"
