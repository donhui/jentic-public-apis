              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CmdbInstanceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "CI not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["CMDB API"],
        "summary": "Delete a CMDB instance",
        "description": "Deletes the specified Configuration Item (CI) from the CMDB.",
        "operationId": "deleteCmdbInstance",
        "parameters": [
          {
            "name": "className",
            "in": "path",
            "required": true,
            "description": "Name of the CMDB class.",
            "schema": {
              "type": "string"
            }
          },
          { "$ref": "#/components/parameters/sysId" }
        ],
        "responses": {
          "204": {
            "description": "CI deleted successfully."
          },
          "401": {
            "description": "Authentication required.",
