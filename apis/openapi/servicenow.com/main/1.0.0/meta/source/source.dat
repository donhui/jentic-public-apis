{
  "openapi": "3.0.3",
  "info": {
    "title": "ServiceNow REST API",
    "version": "1.0.0",
    "description": "ServiceNow REST APIs for managing records, attachments, aggregations, import sets, and CMDB configuration items. The Table API provides CRUD operations on any ServiceNow table. The Aggregate API enables statistical queries. The Attachment API manages file attachments. The Import Set API handles bulk data imports. The CMDB API manages Configuration Management Database items.",
    "x-jentic-source-url": "https://developer.servicenow.com/dev.do#!/reference/api/latest/rest/",
    "contact": {
      "name": "ServiceNow Developer Program",
      "url": "https://developer.servicenow.com"
    }
  },
  "externalDocs": {
    "description": "ServiceNow REST API Reference",
    "url": "https://developer.servicenow.com/dev.do#!/reference/api/latest/rest/"
  },
  "servers": [
    {
      "url": "https://{instance}.service-now.com/api",
      "description": "ServiceNow instance REST API endpoint",
      "variables": {
        "instance": {
          "default": "your-instance",
          "description": "Your ServiceNow instance name"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Table API",
      "description": "CRUD operations on any ServiceNow table"
    },
    {
      "name": "Aggregate API",
      "description": "Statistical aggregate queries on table data"
    },
    {
      "name": "Attachment API",
      "description": "Manage file attachments on records"
    },
    {
      "name": "Import Set API",
      "description": "Bulk data import via import sets and transform maps"
    },
    {
      "name": "CMDB API",
      "description": "Configuration Management Database operations"
    }
  ],
  "paths": {
    "/now/table/{tableName}": {
      "get": {
        "tags": ["Table API"],
        "summary": "Retrieve multiple records",
        "description": "Retrieves multiple records for the specified table. Supports filtering, pagination, field selection, and ordering via query parameters.",
        "operationId": "getRecords",
        "parameters": [
          { "$ref": "#/components/parameters/tableName" },
          { "$ref": "#/components/parameters/sysparmQuery" },
          { "$ref": "#/components/parameters/sysparmFields" },
          { "$ref": "#/components/parameters/sysparmLimit" },
          { "$ref": "#/components/parameters/sysparmOffset" },
          { "$ref": "#/components/parameters/sysparmDisplayValue" },
          { "$ref": "#/components/parameters/sysparmExcludeReferenceLink" },
          { "$ref": "#/components/parameters/sysparmView" },
          { "$ref": "#/components/parameters/sysparmQueryNoDomain" },
          { "$ref": "#/components/parameters/sysparmNoCount" },
          { "$ref": "#/components/parameters/sysparmQueryCategory" },
          { "$ref": "#/components/parameters/sysparmSuppressPaginationHeader" }
        ],
        "responses": {
          "200": {
            "description": "Records retrieved successfully. Returns an empty result array if no records match the query.",
            "headers": {
              "X-Total-Count": {
                "$ref": "#/components/headers/X-Total-Count"
              },
              "Link": {
                "$ref": "#/components/headers/Link"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid query or parameters.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions to access the table.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Table API"],
        "summary": "Create a record",
        "description": "Inserts one record in the specified table. Multiple record insertion is not supported.",
        "operationId": "createRecord",
        "parameters": [
          { "$ref": "#/components/parameters/tableName" },
          { "$ref": "#/components/parameters/sysparmFields" },
          { "$ref": "#/components/parameters/sysparmDisplayValue" },
          { "$ref": "#/components/parameters/sysparmExcludeReferenceLink" },
          { "$ref": "#/components/parameters/sysparmView" },
          { "$ref": "#/components/parameters/sysparmInputDisplayValue" },
          { "$ref": "#/components/parameters/sysparmSuppressAutoSysField" }
        ],
        "requestBody": {
          "required": true,
          "description": "Field name-value pairs for the new record",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Record created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid field values or missing required fields.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions to create records in this table.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/table/{tableName}/{sys_id}": {
      "get": {
        "tags": ["Table API"],
        "summary": "Retrieve a record",
        "description": "Retrieves the record identified by the specified sys_id from the specified table.",
        "operationId": "getRecordById",
        "parameters": [
          { "$ref": "#/components/parameters/tableName" },
          { "$ref": "#/components/parameters/sysId" },
          { "$ref": "#/components/parameters/sysparmFields" },
          { "$ref": "#/components/parameters/sysparmDisplayValue" },
          { "$ref": "#/components/parameters/sysparmExcludeReferenceLink" },
          { "$ref": "#/components/parameters/sysparmView" },
          { "$ref": "#/components/parameters/sysparmQueryNoDomain" }
        ],
        "responses": {
          "200": {
            "description": "Record retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Record not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Table API"],
        "summary": "Update a record",
        "description": "Updates the specified record with the name-value pairs in the request body. This method replaces the entire record — any fields not included in the request body are set to empty.",
        "operationId": "updateRecord",
        "parameters": [
          { "$ref": "#/components/parameters/tableName" },
          { "$ref": "#/components/parameters/sysId" },
          { "$ref": "#/components/parameters/sysparmFields" },
          { "$ref": "#/components/parameters/sysparmDisplayValue" },
          { "$ref": "#/components/parameters/sysparmExcludeReferenceLink" },
          { "$ref": "#/components/parameters/sysparmView" },
          { "$ref": "#/components/parameters/sysparmInputDisplayValue" },
          { "$ref": "#/components/parameters/sysparmSuppressAutoSysField" },
          { "$ref": "#/components/parameters/sysparmQueryNoDomain" }
        ],
        "requestBody": {
          "required": true,
          "description": "Complete field name-value pairs for the record (replaces all fields)",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Record not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Table API"],
        "summary": "Partially update a record",
        "description": "Updates the specified record with the name-value pairs in the request body. Only the fields included in the request body are updated; all other fields retain their existing values.",
        "operationId": "patchRecord",
        "parameters": [
          { "$ref": "#/components/parameters/tableName" },
          { "$ref": "#/components/parameters/sysId" },
          { "$ref": "#/components/parameters/sysparmFields" },
          { "$ref": "#/components/parameters/sysparmDisplayValue" },
          { "$ref": "#/components/parameters/sysparmExcludeReferenceLink" },
          { "$ref": "#/components/parameters/sysparmView" },
          { "$ref": "#/components/parameters/sysparmInputDisplayValue" },
          { "$ref": "#/components/parameters/sysparmSuppressAutoSysField" },
          { "$ref": "#/components/parameters/sysparmQueryNoDomain" }
        ],
        "requestBody": {
          "required": true,
          "description": "Field name-value pairs to update (partial update)",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Record not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Table API"],
        "summary": "Delete a record",
        "description": "Deletes the specified record from the specified table.",
        "operationId": "deleteRecord",
        "parameters": [
          { "$ref": "#/components/parameters/tableName" },
          { "$ref": "#/components/parameters/sysId" },
          { "$ref": "#/components/parameters/sysparmQueryNoDomain" }
        ],
        "responses": {
          "204": {
            "description": "Record deleted successfully. No content returned."
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Record not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/stats/{tableName}": {
      "get": {
        "tags": ["Aggregate API"],
        "summary": "Retrieve aggregate statistics",
        "description": "Retrieves records for the specified table and applies aggregate functions such as COUNT, SUM, AVG, MIN, and MAX to specified fields. Supports grouping and having clauses.",
        "operationId": "getAggregateStats",
        "parameters": [
          { "$ref": "#/components/parameters/tableName" },
          { "$ref": "#/components/parameters/sysparmQuery" },
          {
            "name": "sysparm_count",
            "in": "query",
            "description": "If true, returns the number of records matching the query.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "sysparm_avg_fields",
            "in": "query",
            "description": "Comma-separated list of fields for which to calculate the average value.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sysparm_sum_fields",
            "in": "query",
            "description": "Comma-separated list of fields for which to calculate the sum.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sysparm_min_fields",
            "in": "query",
            "description": "Comma-separated list of fields for which to return the minimum value.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sysparm_max_fields",
            "in": "query",
            "description": "Comma-separated list of fields for which to return the maximum value.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sysparm_group_by",
            "in": "query",
            "description": "Comma-separated list of fields by which to group results.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sysparm_orderby",
            "in": "query",
            "description": "Specifies the field to use when ordering results. Prefix with DESC for descending order.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sysparm_having",
            "in": "query",
            "description": "Additional query to filter aggregate results, similar to a SQL HAVING clause.",
            "schema": {
              "type": "string"
            }
          },
          { "$ref": "#/components/parameters/sysparmDisplayValue" }
        ],
        "responses": {
          "200": {
            "description": "Aggregate query completed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AggregateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid query or parameters.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/attachment": {
      "get": {
        "tags": ["Attachment API"],
        "summary": "List attachments",
        "description": "Retrieves attachment metadata. Use query parameters to filter results.",
        "operationId": "getAttachments",
        "parameters": [
          { "$ref": "#/components/parameters/sysparmQuery" },
          { "$ref": "#/components/parameters/sysparmLimit" },
          { "$ref": "#/components/parameters/sysparmOffset" },
          { "$ref": "#/components/parameters/sysparmFields" }
        ],
        "responses": {
          "200": {
            "description": "Attachment metadata retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Attachment API"],
        "summary": "Upload an attachment",
        "description": "Uploads a file as an attachment to the specified record. Use multipart form data or binary body with appropriate headers.",
        "operationId": "createAttachment",
        "parameters": [
          {
            "name": "table_name",
            "in": "query",
            "description": "Name of the table to attach the file to.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "table_sys_id",
            "in": "query",
            "description": "Sys_id of the record to attach the file to.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "file_name",
            "in": "query",
            "description": "Name of the file to attach.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Binary file content to upload",
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload"
                  }
                },
                "required": ["file"]
              }
            },
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attachment uploaded successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/attachment/{sys_id}": {
      "get": {
        "tags": ["Attachment API"],
        "summary": "Get attachment metadata",
        "description": "Retrieves the metadata for the specified attachment.",
        "operationId": "getAttachmentById",
        "parameters": [
          {
            "name": "sys_id",
            "in": "path",
            "required": true,
            "description": "Sys_id of the attachment record.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attachment metadata retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Attachment not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Attachment API"],
        "summary": "Delete an attachment",
        "description": "Deletes the specified attachment record and its associated file.",
        "operationId": "deleteAttachment",
        "parameters": [
          {
            "name": "sys_id",
            "in": "path",
            "required": true,
            "description": "Sys_id of the attachment to delete.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Attachment deleted successfully."
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Attachment not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/attachment/{sys_id}/file": {
      "get": {
        "tags": ["Attachment API"],
        "summary": "Download attachment file",
        "description": "Downloads the binary file content associated with the specified attachment.",
        "operationId": "getAttachmentFile",
        "parameters": [
          {
            "name": "sys_id",
            "in": "path",
            "required": true,
            "description": "Sys_id of the attachment whose file content to download.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content retrieved successfully.",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Attachment not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/import/{tableName}": {
      "post": {
        "tags": ["Import Set API"],
        "summary": "Insert into import set",
        "description": "Inserts incoming data into a specified staging table and triggers the associated transform map to process the data into target tables.",
        "operationId": "createImportSetRecord",
        "parameters": [
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "description": "Name of the import set (staging) table.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Field name-value pairs for the import set record",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecordInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Import set record created and transformed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportSetResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "Insufficient permissions.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/import/{tableName}/insertMultiple": {
      "post": {
        "tags": ["Import Set API"],
        "summary": "Insert multiple import set records",
        "description": "Inserts multiple records into a specified staging table and triggers the associated transform map to process the data.",
        "operationId": "createMultipleImportSetRecords",
        "parameters": [
          {
            "name": "tableName",
            "in": "path",
            "required": true,
            "description": "Name of the import set (staging) table.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Array of records to insert into the import set",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "records": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/RecordInput"
                    },
                    "description": "Array of record objects to import"
                  }
                },
                "required": ["records"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Import set records created and transformed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportSetMultipleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/cmdb/instance/{className}": {
      "get": {
        "tags": ["CMDB API"],
        "summary": "List CMDB instances",
        "description": "Retrieves a list of Configuration Items (CIs) for the specified CMDB class.",
        "operationId": "getCmdbInstances",
        "parameters": [
          {
            "name": "className",
            "in": "path",
            "required": true,
            "description": "Name of the CMDB class (e.g., cmdb_ci_server, cmdb_ci_computer, cmdb_ci_linux_server).",
            "schema": {
              "type": "string"
            }
          },
          { "$ref": "#/components/parameters/sysparmQuery" },
          { "$ref": "#/components/parameters/sysparmLimit" },
          { "$ref": "#/components/parameters/sysparmOffset" }
        ],
        "responses": {
          "200": {
            "description": "CMDB instances retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CmdbInstanceListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["CMDB API"],
        "summary": "Create a CMDB instance",
        "description": "Creates a new Configuration Item (CI) in the specified CMDB class.",
        "operationId": "createCmdbInstance",
        "parameters": [
          {
            "name": "className",
            "in": "path",
            "required": true,
            "description": "Name of the CMDB class.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "CI attributes and optional related items",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CmdbInstanceInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CMDB instance created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CmdbInstanceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/cmdb/instance/{className}/{sys_id}": {
      "get": {
        "tags": ["CMDB API"],
        "summary": "Get a CMDB instance",
        "description": "Retrieves the specified Configuration Item (CI) and its attributes.",
        "operationId": "getCmdbInstanceById",
        "parameters": [
          {
            "name": "className",
            "in": "path",
            "required": true,
            "description": "Name of the CMDB class.",
            "schema": {
              "type": "string"
            }
          },
          { "$ref": "#/components/parameters/sysId" }
        ],
        "responses": {
          "200": {
            "description": "CMDB instance retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CmdbInstanceResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "CI not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["CMDB API"],
        "summary": "Update a CMDB instance",
        "description": "Updates the specified Configuration Item (CI) with new attribute values and relationships.",
        "operationId": "updateCmdbInstance",
        "parameters": [
          {
            "name": "className",
            "in": "path",
            "required": true,
            "description": "Name of the CMDB class.",
            "schema": {
              "type": "string"
            }
          },
          { "$ref": "#/components/parameters/sysId" }
        ],
        "requestBody": {
          "required": true,
          "description": "Updated CI attributes and optional related items",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CmdbInstanceInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CMDB instance updated successfully.",
