              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "CI not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/now/cmdb/instance/{className}/{sys_id}/relation": {
      "get": {
        "tags": ["CMDB API"],
        "summary": "Get CMDB instance relations",
        "description": "Retrieves the relationships (inbound and outbound) for the specified Configuration Item.",
        "operationId": "getCmdbInstanceRelations",
        "parameters": [
          {
            "name": "className",
            "in": "path",
            "required": true,
            "description": "Name of the CMDB class.",
            "schema": {
              "type": "string"
            }
          },
          { "$ref": "#/components/parameters/sysId" }
        ],
        "responses": {
          "200": {
            "description": "Relations retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CmdbRelationResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "CI not found.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "tableName": {
        "name": "tableName",
        "in": "path",
        "required": true,
        "description": "Name of the table to access (e.g., incident, change_request, problem, cmdb_ci, sys_user, sc_request, kb_knowledge).",
        "schema": {
          "type": "string"
        }
      },
      "sysId": {
        "name": "sys_id",
        "in": "path",
        "required": true,
        "description": "Unique identifier (sys_id) of the record.",
        "schema": {
          "type": "string",
          "pattern": "^[a-f0-9]{32}$"
        }
      },
      "sysparmQuery": {
        "name": "sysparm_query",
        "in": "query",
        "description": "Encoded query string used to filter results. Supports operators: =, !=, ^, ^OR, LIKE, STARTSWITH, ENDSWITH, ORDERBY, ORDERBYDESC. Example: active=true^priority=1^ORDERBYnumber",
        "schema": {
          "type": "string"
        }
      },
      "sysparmFields": {
        "name": "sysparm_fields",
        "in": "query",
        "description": "Comma-separated list of field names to return in the response.",
        "schema": {
          "type": "string"
        }
      },
      "sysparmLimit": {
        "name": "sysparm_limit",
        "in": "query",
        "description": "Maximum number of records to return. Default is determined by the instance configuration (usually 10000 for Table API).",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 10000
        }
      },
      "sysparmOffset": {
        "name": "sysparm_offset",
        "in": "query",
        "description": "Number of records to skip before returning results. Used for pagination.",
        "schema": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "sysparmDisplayValue": {
        "name": "sysparm_display_value",
        "in": "query",
        "description": "Determines the type of data returned: 'true' returns display values, 'false' returns actual database values, 'all' returns both.",
        "schema": {
          "type": "string",
          "enum": ["true", "false", "all"],
          "default": "false"
        }
      },
      "sysparmExcludeReferenceLink": {
        "name": "sysparm_exclude_reference_link",
        "in": "query",
        "description": "If true, excludes Table API links for reference fields. This can improve performance when reference links are not needed.",
        "schema": {
          "type": "boolean",
          "default": false
        }
      },
      "sysparmView": {
        "name": "sysparm_view",
        "in": "query",
        "description": "UI view to determine the returned fields. Overrides sysparm_fields if also specified.",
        "schema": {
          "type": "string"
        }
      },
      "sysparmInputDisplayValue": {
        "name": "sysparm_input_display_value",
        "in": "query",
        "description": "If true, treats input field values as display values. If false (default), input values are treated as actual values.",
        "schema": {
          "type": "boolean",
          "default": false
        }
      },
      "sysparmSuppressAutoSysField": {
        "name": "sysparm_suppress_auto_sys_field",
        "in": "query",
        "description": "If true, suppresses auto-generation of system fields (sys_created_by, sys_created_on, sys_updated_by, sys_updated_on, sys_mod_count).",
        "schema": {
          "type": "boolean",
          "default": false
        }
      },
      "sysparmQueryNoDomain": {
        "name": "sysparm_query_no_domain",
        "in": "query",
        "description": "If true, accesses data across domains if authorized. Only applies to domain-separated instances.",
        "schema": {
          "type": "boolean",
          "default": false
        }
      },
      "sysparmNoCount": {
        "name": "sysparm_no_count",
        "in": "query",
        "description": "If true, does not execute a select count(*) on the table. This can improve query performance on large tables.",
        "schema": {
          "type": "boolean",
          "default": false
        }
      },
      "sysparmQueryCategory": {
        "name": "sysparm_query_category",
        "in": "query",
        "description": "Name of the query category to use for the query. Query categories can control which business rules run.",
        "schema": {
          "type": "string"
        }
      },
      "sysparmSuppressPaginationHeader": {
        "name": "sysparm_suppress_pagination_header",
        "in": "query",
        "description": "If true, suppresses the Link pagination header in the response.",
        "schema": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "headers": {
      "X-Total-Count": {
        "description": "Total number of records matching the query (before pagination). Not returned if sysparm_no_count is true.",
        "schema": {
          "type": "integer"
        }
      },
      "Link": {
        "description": "Pagination links (first, prev, next, last) in standard HTTP Link header format.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Record": {
        "type": "object",
        "description": "A ServiceNow record. Properties depend on the table being accessed. Common system fields are included below.",
        "properties": {
          "sys_id": {
            "type": "string",
            "description": "Unique 32-character identifier for the record.",
            "readOnly": true
          },
          "sys_created_on": {
            "type": "string",
            "description": "Date and time when the record was created.",
            "readOnly": true
          },
          "sys_created_by": {
            "type": "string",
            "description": "User who created the record.",
            "readOnly": true
          },
          "sys_updated_on": {
            "type": "string",
            "description": "Date and time when the record was last updated.",
            "readOnly": true
          },
          "sys_updated_by": {
            "type": "string",
            "description": "User who last updated the record.",
            "readOnly": true
          },
          "sys_mod_count": {
            "type": "string",
            "description": "Number of times the record has been updated.",
            "readOnly": true
          },
          "sys_tags": {
            "type": "string",
            "description": "Tags associated with the record."
          },
          "sys_class_name": {
            "type": "string",
            "description": "Table class name for the record.",
            "readOnly": true
          }
        },
        "additionalProperties": true
      },
      "RecordInput": {
        "type": "object",
        "description": "Field name-value pairs. The valid fields depend on the target table.",
        "additionalProperties": true
      },
      "RecordResponse": {
        "type": "object",
        "description": "Single record response wrapper.",
        "properties": {
          "result": {
            "$ref": "#/components/schemas/Record"
          }
        }
      },
      "RecordListResponse": {
        "type": "object",
        "description": "Multiple records response wrapper.",
        "properties": {
          "result": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Record"
            }
          }
        }
      },
      "AggregateResponse": {
        "type": "object",
        "description": "Response from the Aggregate API containing statistical results.",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "stats": {
                "type": "object",
                "description": "Aggregate statistics for the query.",
                "properties": {
                  "count": {
                    "type": "string",
                    "description": "Number of records matching the query."
                  },
                  "avg": {
                    "type": "object",
                    "description": "Average values keyed by field name.",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "sum": {
                    "type": "object",
                    "description": "Sum values keyed by field name.",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "min": {
                    "type": "object",
                    "description": "Minimum values keyed by field name.",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "max": {
                    "type": "object",
                    "description": "Maximum values keyed by field name.",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              },
              "group_by": {
                "type": "array",
                "description": "Grouped results when sysparm_group_by is used.",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "AttachmentMetadata": {
        "type": "object",
        "description": "Attachment metadata record.",
        "properties": {
          "sys_id": {
            "type": "string",
            "description": "Unique identifier for the attachment."
          },
          "file_name": {
            "type": "string",
            "description": "Name of the attached file."
          },
          "table_name": {
            "type": "string",
            "description": "Table the attachment belongs to."
          },
          "table_sys_id": {
            "type": "string",
            "description": "Sys_id of the record the attachment belongs to."
          },
          "content_type": {
            "type": "string",
            "description": "MIME type of the attachment."
          },
          "size_bytes": {
            "type": "string",
            "description": "File size in bytes."
          },
          "size_compressed": {
            "type": "string",
            "description": "Compressed file size in bytes."
          },
          "hash": {
            "type": "string",
            "description": "MD5 hash of the file content."
          },
          "state": {
            "type": "string",
            "description": "State of the attachment."
          },
          "download_link": {
            "type": "string",
            "description": "URL to download the attachment file."
          },
          "sys_created_on": {
            "type": "string",
            "description": "Date and time when the attachment was created."
          },
          "sys_created_by": {
            "type": "string",
            "description": "User who created the attachment."
          },
          "sys_updated_on": {
            "type": "string",
            "description": "Date and time when the attachment was last updated."
          }
        }
      },
      "AttachmentResponse": {
        "type": "object",
        "properties": {
          "result": {
            "$ref": "#/components/schemas/AttachmentMetadata"
          }
        }
      },
      "AttachmentListResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AttachmentMetadata"
            }
          }
        }
      },
      "ImportSetResult": {
        "type": "object",
        "description": "Result of an import set transformation.",
        "properties": {
          "transform_map": {
            "type": "string",
            "description": "Name of the transform map used."
          },
          "table": {
            "type": "string",
            "description": "Target table name."
          },
          "display_name": {
            "type": "string",
            "description": "Display name of the transform map."
          },
          "display_value": {
            "type": "string",
            "description": "Display value of the target record."
          },
          "record_link": {
            "type": "string",
            "description": "API link to the target record."
          },
          "status": {
            "type": "string",
            "description": "Status of the transform: inserted, updated, error, ignored.",
            "enum": ["inserted", "updated", "error", "ignored"]
          },
          "status_message": {
            "type": "string",
            "description": "Detailed status message."
          },
          "sys_id": {
            "type": "string",
            "description": "Sys_id of the created or updated target record."
          },
          "error_message": {
            "type": "string",
            "description": "Error message if the transform failed."
          }
        }
      },
      "ImportSetResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImportSetResult"
            }
          }
        }
      },
      "ImportSetMultipleResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "import_set": {
                  "type": "string",
                  "description": "Import set number."
                },
                "staging_table": {
                  "type": "string",
                  "description": "Name of the staging table."
                },
                "result": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ImportSetResult"
                  }
                }
              }
            }
          }
        }
      },
      "CmdbInstance": {
        "type": "object",
        "description": "A CMDB Configuration Item (CI).",
        "properties": {
          "attributes": {
            "type": "object",
            "description": "CI attributes (field name-value pairs).",
            "additionalProperties": true
          },
          "inbound_relations": {
            "type": "array",
            "description": "Inbound CI relationships.",
            "items": {
              "$ref": "#/components/schemas/CmdbRelation"
            }
          },
          "outbound_relations": {
            "type": "array",
            "description": "Outbound CI relationships.",
            "items": {
              "$ref": "#/components/schemas/CmdbRelation"
            }
          }
        }
      },
      "CmdbInstanceInput": {
        "type": "object",
        "description": "Input for creating or updating a CMDB CI.",
        "properties": {
          "attributes": {
            "type": "object",
            "description": "CI attributes (field name-value pairs).",
            "additionalProperties": true
          },
          "inbound_relations": {
            "type": "array",
            "description": "Inbound CI relationships to create.",
            "items": {
              "$ref": "#/components/schemas/CmdbRelationInput"
            }
          },
          "outbound_relations": {
            "type": "array",
            "description": "Outbound CI relationships to create.",
            "items": {
              "$ref": "#/components/schemas/CmdbRelationInput"
            }
          },
          "source": {
            "type": "string",
            "description": "Discovery source identifier."
          }
        },
        "required": ["attributes"]
      },
      "CmdbRelation": {
        "type": "object",
        "description": "A CMDB CI relationship.",
        "properties": {
          "sys_id": {
            "type": "string",
            "description": "Sys_id of the relationship record."
          },
          "type": {
            "type": "object",
            "description": "Relationship type.",
            "properties": {
              "display_value": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "target": {
            "type": "object",
            "description": "Target CI of the relationship.",
            "properties": {
              "display_value": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        }
      },
      "CmdbRelationInput": {
        "type": "object",
        "description": "Input for creating a CMDB CI relationship.",
        "properties": {
          "type": {
            "type": "string",
            "description": "Sys_id of the relationship type."
          },
          "target": {
            "type": "string",
            "description": "Sys_id of the target CI."
          }
        },
        "required": ["type", "target"]
      },
      "CmdbInstanceResponse": {
        "type": "object",
        "properties": {
          "result": {
            "$ref": "#/components/schemas/CmdbInstance"
          }
        }
      },
      "CmdbInstanceListResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CmdbInstance"
            }
          }
        }
      },
      "CmdbRelationResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "inbound_relations": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CmdbRelation"
                }
              },
              "outbound_relations": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CmdbRelation"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Standard ServiceNow error response.",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Human-readable error message."
              },
              "detail": {
                "type": "string",
                "description": "Detailed error information."
              }
            },
            "required": ["message"]
          },
          "status": {
            "type": "string",
            "description": "HTTP status text."
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication with ServiceNow username and password."
      },
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authorization code or resource owner password credentials flow.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://{instance}.service-now.com/oauth_auth.do",
            "tokenUrl": "https://{instance}.service-now.com/oauth_token.do",
            "scopes": {
              "useraccount": "Access to user account resources"
            }
          },
          "password": {
            "tokenUrl": "https://{instance}.service-now.com/oauth_token.do",
            "scopes": {
              "useraccount": "Access to user account resources"
            }
          }
        }
      }
    }
  },
  "security": [
    { "basicAuth": [] },
    { "oauth2": ["useraccount"] }
  ]
}