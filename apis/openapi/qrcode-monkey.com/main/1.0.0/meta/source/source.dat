{
  "openapi": "3.0.3",
  "info": {
    "title": "QRCode Monkey",
    "version": "1.0.0",
    "description": "QRCode Monkey API for generating custom QR codes with logos, colors, and design options. Supports PNG, SVG, PDF, and EPS output formats.",
    "x-jentic-source-url": "https://www.qrcode-monkey.com/qr-code-api-with-logo/"
  },
  "servers": [
    {
      "url": "https://api.qrcode-monkey.com/qr"
    }
  ],
  "paths": {
    "/custom": {
      "post": {
        "operationId": "createCustomQrCode",
        "summary": "Create a custom QR code",
        "description": "Generate a custom QR code with optional logo, colors, and design settings. Returns the QR code as an image.",
        "tags": ["QR Code"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/QrCodeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "QR code image",
            "content": {
              "image/png": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "description": "Bad request - invalid parameters" },
          "401": { "description": "Unauthorized" }
        }
      },
      "get": {
        "operationId": "createCustomQrCodeGet",
        "summary": "Create a custom QR code (GET)",
        "description": "Generate a custom QR code using query parameters.",
        "tags": ["QR Code"],
        "parameters": [
          {
            "name": "data",
            "in": "query",
            "required": true,
            "description": "The data to encode in the QR code (URL, text, etc.)",
            "schema": { "type": "string" }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "description": "Size of the QR code in pixels (default 300)",
            "schema": { "type": "integer", "default": 300 }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Output format",
            "schema": { "type": "string", "enum": ["png", "svg", "pdf", "eps"], "default": "png" }
          }
        ],
        "responses": {
          "200": {
            "description": "QR code image",
            "content": {
              "image/png": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/uploadImage": {
      "post": {
        "operationId": "uploadLogo",
        "summary": "Upload a logo image",
        "description": "Upload a logo image to be used in QR code generation.",
        "tags": ["QR Code"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Logo image file"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "file": { "type": "string", "description": "Uploaded file reference" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request - invalid file" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QrCodeRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "string",
            "description": "The data to encode (URL, text, etc.)"
          },
          "config": {
            "$ref": "#/components/schemas/QrCodeConfig"
          },
          "size": {
            "type": "integer",
            "description": "Size in pixels (default 300)",
            "default": 300
          },
          "download": {
            "type": "boolean",
            "description": "Whether to return as downloadable file",
            "default": false
          },
          "file": {
            "type": "string",
            "enum": ["png", "svg", "pdf", "eps"],
            "description": "Output file format",
            "default": "png"
          }
        }
      },
      "QrCodeConfig": {
        "type": "object",
        "properties": {
          "body": {
            "type": "string",
            "description": "Body shape style (square, circle, etc.)",
            "enum": ["square", "circle", "diamond", "star", "rounded"]
          },
          "eye": {
            "type": "string",
            "description": "Eye frame shape"
          },
          "eyeBall": {
            "type": "string",
            "description": "Eye ball shape"
          },
          "bodyColor": {
            "type": "string",
            "description": "Body color (hex code)",
            "default": "#000000"
          },
          "bgColor": {
            "type": "string",
            "description": "Background color (hex code)",
            "default": "#FFFFFF"
          },
          "eye1Color": {
            "type": "string",
            "description": "Color of first eye"
          },
          "eye2Color": {
            "type": "string",
            "description": "Color of second eye"
          },
          "eye3Color": {
            "type": "string",
            "description": "Color of third eye"
          },
          "eyeBall1Color": {
            "type": "string",
            "description": "Color of first eye ball"
          },
          "eyeBall2Color": {
            "type": "string",
            "description": "Color of second eye ball"
          },
          "eyeBall3Color": {
            "type": "string",
            "description": "Color of third eye ball"
          },
          "gradientColor1": {
            "type": "string",
            "description": "First gradient color"
          },
          "gradientColor2": {
            "type": "string",
            "description": "Second gradient color"
          },
          "gradientType": {
            "type": "string",
            "enum": ["linear", "radial"],
            "description": "Gradient type"
          },
          "gradientOnEyes": {
            "type": "boolean",
            "description": "Apply gradient to eyes"
          },
          "logo": {
            "type": "string",
            "description": "Logo image reference or URL"
          },
          "logoMode": {
            "type": "string",
            "enum": ["default", "clean"],
            "description": "Logo rendering mode"
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}