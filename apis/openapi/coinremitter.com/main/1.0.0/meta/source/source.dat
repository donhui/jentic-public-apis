{
  "openapi": "3.0.3",
  "info": {
    "title": "Coinremitter",
    "version": "1.0.0",
    "description": "Coinremitter cryptocurrency payment gateway API for managing wallets, addresses, transactions, invoices, and market rates.",
    "x-jentic-source-url": "https://api.coinremitter.com/docs"
  },
  "servers": [
    {
      "url": "https://api.coinremitter.com/v1",
      "description": "Coinremitter API v1"
    }
  ],
  "tags": [
    { "name": "Wallet", "description": "Wallet and address management" },
    { "name": "Invoice", "description": "Invoice management" },
    { "name": "Rates", "description": "Market rate conversion" }
  ],
  "paths": {
    "/wallet/address/create": {
      "post": {
        "operationId": "createWalletAddress",
        "summary": "Create a new wallet address",
        "tags": ["Wallet"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "Label for the address (max 20 characters)",
                    "maxLength": 20
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Address created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AddressResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Invalid credentials or account inactive",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/wallet/address/validate": {
      "post": {
        "operationId": "validateWalletAddress",
        "summary": "Validate a cryptocurrency address",
        "tags": ["Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["address"],
                "properties": {
                  "address": {
                    "type": "string",
                    "description": "Cryptocurrency address to validate"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "valid": { "type": "boolean" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/wallet/withdraw/estimate": {
      "post": {
        "operationId": "estimateWithdrawalCost",
        "summary": "Estimate the cost of a withdrawal",
        "tags": ["Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount"],
                "properties": {
                  "amount": {
                    "type": "number",
                    "description": "Amount to withdraw"
                  },
                  "address": {
                    "type": "string",
                    "description": "Destination address"
                  },
                  "withdrawal_speed": {
                    "type": "string",
                    "description": "Transaction speed",
                    "enum": ["Low", "Medium", "Priority"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Withdrawal estimate",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WithdrawalEstimateResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/wallet/withdraw": {
      "post": {
        "operationId": "withdrawFromWallet",
        "summary": "Withdraw cryptocurrency from wallet",
        "tags": ["Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["address", "amount"],
                "properties": {
                  "address": {
                    "type": "string",
                    "description": "Destination cryptocurrency address"
                  },
                  "amount": {
                    "type": "number",
                    "description": "Amount to withdraw"
                  },
                  "withdrawal_speed": {
                    "type": "string",
                    "description": "Transaction speed",
                    "enum": ["Low", "Medium", "Priority"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Withdrawal successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WithdrawalResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/wallet/transaction": {
      "post": {
        "operationId": "getTransaction",
        "summary": "Get transaction details by Coinremitter ID",
        "tags": ["Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Coinremitter transaction ID (not blockchain ID)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TransactionResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Transaction not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/wallet/address/transactions": {
      "post": {
        "operationId": "getTransactionsByAddress",
        "summary": "Get all transactions for a specific address",
        "tags": ["Wallet"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["address"],
                "properties": {
                  "address": {
                    "type": "string",
                    "description": "Cryptocurrency address"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Address transactions",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AddressTransactionsResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/wallet/balance": {
      "post": {
        "operationId": "getWalletBalance",
        "summary": "Get wallet balance and details",
        "tags": ["Wallet"],
        "responses": {
          "200": {
            "description": "Wallet balance",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WalletBalanceResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/invoice/create": {
      "post": {
        "operationId": "createInvoice",
        "summary": "Create a new payment invoice",
        "tags": ["Invoice"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount"],
                "properties": {
                  "amount": {
                    "type": "number",
                    "description": "Invoice amount"
                  },
                  "name": {
                    "type": "string",
                    "description": "Customer name"
                  },
                  "email": {
                    "type": "string",
                    "description": "Customer email"
                  },
                  "fiat_currency": {
                    "type": "string",
                    "description": "Fiat currency code for conversion"
                  },
                  "expiry_time_in_minutes": {
                    "type": "integer",
                    "description": "Invoice expiration time in minutes"
                  },
                  "notify_url": {
                    "type": "string",
                    "description": "Webhook notification URL"
                  },
                  "success_url": {
                    "type": "string",
                    "description": "Redirect URL on successful payment"
                  },
                  "fail_url": {
                    "type": "string",
                    "description": "Redirect URL on failed payment"
                  },
                  "description": {
                    "type": "string",
                    "description": "Invoice description"
                  },
                  "custom_data1": {
                    "type": "string",
                    "description": "Custom data field 1"
                  },
                  "custom_data2": {
                    "type": "string",
                    "description": "Custom data field 2"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invoice created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/InvoiceResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/invoice/get": {
      "post": {
        "operationId": "getInvoice",
        "summary": "Get invoice details by ID",
        "tags": ["Invoice"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["invoice_id"],
                "properties": {
                  "invoice_id": {
                    "type": "string",
                    "description": "Invoice ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invoice details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/InvoiceResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Invoice not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/fiat-to-crypto-rate": {
      "post": {
        "operationId": "getFiatToCryptoRate",
        "summary": "Get fiat to cryptocurrency conversion rate",
        "tags": ["Rates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["fiat_amount", "fiat_currency"],
                "properties": {
                  "fiat_amount": {
                    "type": "number",
                    "description": "Fiat amount to convert"
                  },
                  "fiat_currency": {
                    "type": "string",
                    "description": "Fiat currency code"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversion rate",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RateResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/crypto-to-fiat-rate": {
      "post": {
        "operationId": "getCryptoToFiatRate",
        "summary": "Get cryptocurrency to fiat conversion rate",
        "tags": ["Rates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["crypto_amount", "fiat_currency"],
                "properties": {
                  "crypto_amount": {
                    "type": "number",
                    "description": "Cryptocurrency amount to convert"
                  },
                  "fiat_currency": {
                    "type": "string",
                    "description": "Target fiat currency code"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversion rate",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RateResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddressResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "address": { "type": "string" },
              "label": { "type": "string" },
              "qr_code": { "type": "string" },
              "expire_time": { "type": "string" }
            }
          }
        }
      },
      "WithdrawalEstimateResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "transaction_fee": { "type": "string" },
              "processing_fee": { "type": "string" },
              "total_amount": { "type": "string" }
            }
          }
        }
      },
      "WithdrawalResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "txid": { "type": "string" },
              "explorer_url": { "type": "string" },
              "amount": { "type": "string" },
              "transaction_fee": { "type": "string" },
              "processing_fee": { "type": "string" }
            }
          }
        }
      },
      "TransactionResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "txid": { "type": "string" },
              "address": { "type": "string" },
              "amount": { "type": "string" },
              "confirmations": { "type": "integer" },
              "status": { "type": "string" },
              "type": { "type": "string", "enum": ["receive", "send"] },
              "date": { "type": "string" }
            }
          }
        }
      },
      "AddressTransactionsResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "address": { "type": "string" },
              "confirmed_amount": { "type": "string" },
              "pending_amount": { "type": "string" },
              "transactions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "txid": { "type": "string" },
                    "amount": { "type": "string" },
                    "confirmations": { "type": "integer" },
                    "status": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "WalletBalanceResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "balance": { "type": "string" },
              "coin": { "type": "string" },
              "minimum_deposit": { "type": "string" },
              "minimum_withdrawal": { "type": "string" },
              "maximum_withdrawal": { "type": "string" }
            }
          }
        }
      },
      "InvoiceResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "invoice_id": { "type": "string" },
              "url": { "type": "string" },
              "amount": { "type": "string" },
              "status": { "type": "string" },
              "description": { "type": "string" },
              "payment_history": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "txid": { "type": "string" },
                    "amount": { "type": "string" },
                    "date": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "RateResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "rate": { "type": "string" },
              "amount": { "type": "string" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "integer" },
              "message": { "type": "string" }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication"
      },
      "ApiPasswordAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-password",
        "description": "API password for authentication"
      }
    }
  },
  "security": [
    { "ApiKeyAuth": [], "ApiPasswordAuth": [] }
  ]
}