{
  "openapi": "3.0.3",
  "info": {
    "title": "Regal API",
    "description": "Regal is an event-driven outbound contact center platform. The API enables sending events, messages, managing campaigns, dispositions, business profiles, and branded phone numbers.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.regal.io/docs"
  },
  "servers": [
    {
      "url": "https://events.regalvoice.com",
      "description": "Regal Events Server"
    },
    {
      "url": "https://api.regal.ai/v1",
      "description": "Regal API Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Events",
      "description": "Custom event management"
    },
    {
      "name": "Messages",
      "description": "Send messages to contacts"
    },
    {
      "name": "Business Profiles",
      "description": "Manage business profiles"
    },
    {
      "name": "Campaigns",
      "description": "List campaigns"
    },
    {
      "name": "Dispositions",
      "description": "List dispositions"
    },
    {
      "name": "Branded Phone Numbers",
      "description": "Manage branded phone numbers"
    }
  ],
  "paths": {
    "/events": {
      "post": {
        "tags": [
          "Events"
        ],
        "summary": "Post custom event",
        "description": "Create and update contacts or add events to contacts",
        "operationId": "postCustomEvent",
        "servers": [
          {
            "url": "https://events.regalvoice.com"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomEventRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Request accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "API key missing or invalid"
          }
        }
      }
    },
    "/messages/send": {
      "post": {
        "tags": [
          "Messages"
        ],
        "summary": "Send message",
        "description": "Send an SMS message to a recipient",
        "operationId": "sendMessage",
        "servers": [
          {
            "url": "https://api.regal.ai/v1"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Message queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation failure"
          },
          "401": {
            "description": "Unauthorized - missing/invalid credentials"
          }
        }
      }
    },
    "/businessProfiles": {
      "get": {
        "tags": [
          "Business Profiles"
        ],
        "summary": "List business profiles",
        "description": "Retrieve all business profiles for your account",
        "operationId": "listBusinessProfiles",
        "servers": [
          {
            "url": "https://api.regal.ai/v1"
          }
        ],
        "parameters": [
          {
            "name": "nextCursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pagination cursor for next page"
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100,
              "default": 25
            },
            "description": "Number of results per page (max 100)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of business profiles",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessProfileList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/campaigns": {
      "get": {
        "tags": [
          "Campaigns"
        ],
        "summary": "List campaigns",
        "description": "Retrieve all campaigns",
        "operationId": "listCampaigns",
        "servers": [
          {
            "url": "https://api.regal.ai/v1"
          }
        ],
        "parameters": [
          {
            "name": "nextCursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pagination cursor"
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100,
              "default": 25
            },
            "description": "Results per page (max 100)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of campaigns",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/dispositions": {
      "get": {
        "tags": [
          "Dispositions"
        ],
        "summary": "List dispositions",
        "description": "Retrieve configured and system dispositions",
        "operationId": "listDispositions",
        "servers": [
          {
            "url": "https://api.regal.ai/v1"
          }
        ],
        "parameters": [
          {
            "name": "nextCursor",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pagination cursor"
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "maximum": 100,
              "default": 25
            },
            "description": "Results per page (max 100)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of dispositions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DispositionList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/brandedPhoneNumbers": {
      "get": {
        "tags": [
          "Branded Phone Numbers"
        ],
        "summary": "List branded phone numbers",
        "description": "Retrieve branded phone numbers with optional filtering",
        "operationId": "listBrandedPhoneNumbers",
        "servers": [
          {
            "url": "https://api.regal.ai/v1"
          }
        ],
        "parameters": [
          {
            "name": "phoneNumber",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by specific phone number"
          },
          {
            "name": "businessProfileId",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by business profile"
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "submitted for review",
                "approved",
                "rejected",
                "unregistered"
              ]
            },
            "description": "Filter by status"
          },
          {
            "name": "carrier",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by carrier (AT&T, Verizon, etc.)"
          },
          {
            "name": "feature",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "brandedCallerId",
                "spamRemediation"
              ]
            },
            "description": "Filter by feature"
          },
          {
            "name": "detailedStatus",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by detailed status"
          }
        ],
        "responses": {
          "200": {
            "description": "List of branded phone numbers",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrandedPhoneNumberList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": [
          "Branded Phone Numbers"
        ],
        "summary": "Create branded phone number",
        "description": "Register a phone number for branding with carriers",
        "operationId": "createBrandedPhoneNumber",
        "servers": [
          {
            "url": "https://api.regal.ai/v1"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBrandedPhoneNumberRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Phone number registration initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrandedPhoneNumberResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/brandedPhoneNumbers/{phoneNumber}": {
      "patch": {
        "tags": [
          "Branded Phone Numbers"
        ],
        "summary": "Update branded phone number",
        "description": "Partially update a branded phone number registration",
        "operationId": "updateBrandedPhoneNumber",
        "servers": [
          {
            "url": "https://api.regal.ai/v1"
          }
        ],
        "parameters": [
          {
            "name": "phoneNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "E.164 format phone number"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBrandedPhoneNumberRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phone number updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrandedPhoneNumberResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "tags": [
          "Branded Phone Numbers"
        ],
        "summary": "Delete branded phone number",
        "description": "Delete a branded phone number registration. Numbers with active carrier submissions cannot be deleted.",
        "operationId": "deleteBrandedPhoneNumber",
        "servers": [
          {
            "url": "https://api.regal.ai/v1"
          }
        ],
        "parameters": [
          {
            "name": "phoneNumber",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "E.164 format phone number"
          }
        ],
        "responses": {
          "200": {
            "description": "Phone number deleted"
          },
          "400": {
            "description": "Bad request - number has active carrier submissions"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Your Regal API Key"
      }
    },
    "schemas": {
      "CustomEventRequest": {
        "type": "object",
        "required": [
          "userId"
        ],
        "properties": {
          "userId": {
            "type": "string",
            "description": "Unique identifier for the contact"
          },
          "traits": {
            "$ref": "#/components/schemas/ContactTraits"
          },
          "name": {
            "type": "string",
            "description": "Event name"
          },
          "properties": {
            "type": "object",
            "description": "Custom event properties",
            "additionalProperties": true
          },
          "eventSource": {
            "type": "string",
            "description": "Origin source of the event"
          },
          "originalTimestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Client-side timestamp"
          }
        }
      },
      "ContactTraits": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "phones": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "number": {
                  "type": "string"
                },
                "voiceOptIn": {
                  "type": "boolean"
                },
                "smsOptIn": {
                  "type": "boolean"
                }
              }
            }
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "format": "email"
                },
                "emailOptIn": {
                  "type": "boolean"
                }
              }
            }
          },
          "address": {
            "type": "object",
            "properties": {
              "street": {
                "type": "string"
              },
              "city": {
                "type": "string"
              },
              "state": {
                "type": "string"
              },
              "zipcode": {
                "type": "string"
              },
              "country": {
                "type": "string"
              }
            }
          }
        }
      },
      "EventResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "ok"
          }
        }
      },
      "SendMessageRequest": {
        "type": "object",
        "required": [
          "to",
          "channel"
        ],
        "properties": {
          "to": {
            "type": "object",
            "required": [
              "phoneNumber"
            ],
            "properties": {
              "phoneNumber": {
                "type": "string",
                "description": "Recipient phone number"
              },
              "bypassOptIn": {
                "type": "boolean",
                "description": "Override opt-in requirements"
              }
            },
            "description": "The message recipient"
          },
          "channel": {
            "type": "string",
            "enum": [
              "sms"
            ],
            "description": "Message channel"
          },
          "content": {
            "type": "object",
            "properties": {
              "body": {
                "type": "string",
                "description": "Message text"
              },
              "mediaUrls": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uri"
                },
                "description": "Media attachment URLs"
              }
            },
            "description": "The message content"
          },
          "from": {
            "type": "object",
            "properties": {
              "phoneNumber": {
                "type": "string",
                "description": "Sender phone number"
              }
            },
            "description": "The message sender"
          },
          "campaignId": {
            "type": "integer",
            "description": "Campaign ID for SMS campaigns"
          }
        }
      },
      "SendMessageResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "queued"
          },
          "message": {
            "type": "string",
            "example": "enqueued for sms-interaction-job"
          },
          "idempotencyKey": {
            "type": "string"
          }
        }
      },
      "BusinessProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "businessName": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "in review",
              "approved",
              "rejected"
            ]
          },
          "taxId": {
            "type": "string"
          },
          "industry": {
            "type": "string"
          },
          "streetAddress": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "businessProfileDBAs": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "BusinessProfileList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BusinessProfile"
            }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "friendlyId": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "ready",
              "draft"
            ]
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "agent-task",
              "automated"
            ]
          },
          "channel": {
            "type": "string",
            "enum": [
              "phone_call",
              "sms"
            ]
          },
          "dialingMode": {
            "type": "string",
            "enum": [
              "progressive"
            ],
            "nullable": true
          },
          "priority": {
            "type": "integer",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CampaignList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Campaign"
            }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Disposition": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "disposition": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "isSystem": {
            "type": "boolean"
          },
          "conversationHappened": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DispositionList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Disposition"
            }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "CarrierFeature": {
        "type": "object",
        "required": [
          "carrier"
        ],
        "properties": {
          "carrier": {
            "type": "string",
            "description": "Carrier name (AT&T, T-Mobile, Verizon)"
          },
          "features": {
            "type": "object",
            "properties": {
              "spamRemediation": {
                "type": "boolean"
              },
              "brandedCallerId": {
                "type": "boolean"
              }
            }
          }
        }
      },
      "CreateBrandedPhoneNumberRequest": {
        "type": "object",
        "required": [
          "phoneNumber",
          "businessProfileId",
          "carrierFeatures"
        ],
        "properties": {
          "phoneNumber": {
            "type": "string",
            "description": "E.164 format (e.g., +15551234567)"
          },
          "businessProfileId": {
            "type": "string",
            "description": "Business profile ID"
          },
          "carrierFeatures": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CarrierFeature"
            },
            "minItems": 1
          },
          "brandingNameShort": {
            "type": "string",
            "maxLength": 15,
            "description": "Display name (max 15 characters)"
          },
          "brandingNameLong": {
            "type": "string",
            "maxLength": 32,
            "description": "Display name (max 32 characters)"
          },
          "internalName": {
            "type": "string",
            "description": "Internal friendly name"
          },
          "reportingGroup": {
            "type": "string",
            "description": "Analytics categorization name"
          }
        }
      },
      "UpdateBrandedPhoneNumberRequest": {
        "type": "object",
        "properties": {
          "businessProfileId": {
            "type": "string"
          },
          "carrierFeatures": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CarrierFeature"
            }
          },
          "brandingNameShort": {
            "type": "string",
            "maxLength": 15
          },
          "brandingNameLong": {
            "type": "string",
            "maxLength": 32
          },
          "internalName": {
            "type": "string"
          },
          "reportingGroup": {
            "type": "string"
          }
        }
      },
      "BrandedPhoneNumber": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "phoneNumber": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "submitted for review",
              "approved",
              "rejected",
              "unregistered"
            ]
          },
          "detailedStatus": {
            "type": "string"
          },
          "carrier": {
            "type": "string"
          },
          "feature": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BrandedPhoneNumberList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BrandedPhoneNumber"
            }
          },
          "nextCursor": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "BrandedPhoneNumberResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "detailedStatus": {
            "type": "string"
          }
        }
      }
    }
  }
}