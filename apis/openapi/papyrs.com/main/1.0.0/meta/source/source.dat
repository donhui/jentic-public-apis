{
  "openapi": "3.0.3",
  "info": {
    "title": "Papyrs API",
    "description": "The Papyrs API allows developers to integrate their own, or other, services and apps with Papyrs intranet. It provides endpoints for managing pages, widgets, records, search, people, and activity feed.",
    "version": "1.0.0",
    "contact": {
      "name": "Papyrs Support",
      "url": "https://papyrs.com"
    },
    "x-jentic-source-url": "https://papyrs.com/docs/api/"
  },
  "servers": [
    {
      "url": "https://{group_name}.papyrs.com/api/v1",
      "description": "Papyrs API server (SSL-only)",
      "variables": {
        "group_name": {
          "description": "Your Papyrs group/account name",
          "default": "example"
        }
      }
    }
  ],
  "security": [
    {
      "ApiTokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Pages",
      "description": "Manage intranet pages"
    },
    {
      "name": "Records",
      "description": "Manage form records on pages"
    },
    {
      "name": "Widgets",
      "description": "Manage individual widgets (text boxes, headings, attachments) on pages"
    },
    {
      "name": "Search",
      "description": "Search the intranet"
    },
    {
      "name": "People",
      "description": "Manage people in the account"
    },
    {
      "name": "Feed",
      "description": "Post to activity streams and discussions"
    }
  ],
  "paths": {
    "/pages/get/{page_id}/": {
      "get": {
        "operationId": "getPage",
        "summary": "Get a Page",
        "description": "Returns detailed page information including title, content widgets organized in columns, layout, permissions, and notifications.",
        "tags": ["Pages"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful page retrieval",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/pages/all/": {
      "get": {
        "operationId": "getAllPages",
        "summary": "Get all pages",
        "description": "Get a list of all pages visible to the user making the request, ordered by creation date (newest first).",
        "tags": ["Pages"],
        "responses": {
          "200": {
            "description": "Successful page list retrieval",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PageSummary"
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/pages/delete/{page_id}/": {
      "post": {
        "operationId": "deletePage",
        "summary": "Delete a Page",
        "description": "Permanently delete a page.",
        "tags": ["Pages"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Page successfully deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/pages/create/": {
      "post": {
        "operationId": "createPage",
        "summary": "Create a Page",
        "description": "Create a new page with specified title, content widgets, layout, notifications, and permissions.",
        "tags": ["Pages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Page successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/pages/records/{page_id}/": {
      "get": {
        "operationId": "getPageRecords",
        "summary": "List all records for a page",
        "description": "Returns a list of all form records submitted on a page, with pagination support.",
        "tags": ["Records"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Returns the Nth page of results, from new to old. Default: 0",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "items_per_page",
            "in": "query",
            "required": false,
            "description": "Number of items to return, between 1 and 250. Default: 50",
            "schema": {
              "type": "integer",
              "default": 50,
              "minimum": 1,
              "maximum": 250
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful records retrieval",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/RecordField"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/paragraph/get/{widget_id}/": {
      "get": {
        "operationId": "getParagraphWidget",
        "summary": "Get a Paragraph Widget",
        "description": "Get a paragraph (text box) widget from a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/WidgetIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful widget retrieval",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParagraphWidget"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/heading/get/{widget_id}/": {
      "get": {
        "operationId": "getHeadingWidget",
        "summary": "Get a Heading Widget",
        "description": "Get a heading widget from a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/WidgetIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful widget retrieval",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeadingWidget"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/attachment/get/{widget_id}/": {
      "get": {
        "operationId": "getAttachmentWidget",
        "summary": "Get an Attachment Widget",
        "description": "Get an attachment widget from a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/WidgetIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful widget retrieval",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentWidget"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/paragraph/create/": {
      "post": {
        "operationId": "createParagraphWidget",
        "summary": "Create a Paragraph Widget",
        "description": "Create a new text box widget on a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/FormatParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWidgetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Widget successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParagraphWidget"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/heading/create/": {
      "post": {
        "operationId": "createHeadingWidget",
        "summary": "Create a Heading Widget",
        "description": "Create a new heading widget on a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/FormatParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWidgetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Widget successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeadingWidget"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/paragraph/update/{widget_id}/": {
      "post": {
        "operationId": "updateParagraphWidget",
        "summary": "Update a Paragraph Widget",
        "description": "Update an existing text box widget on a page. Note that when updating, the widget ID will change.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/WidgetIdParam"
          },
          {
            "$ref": "#/components/parameters/FormatParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWidgetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Widget successfully updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdatedParagraphWidget"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/heading/update/{widget_id}/": {
      "post": {
        "operationId": "updateHeadingWidget",
        "summary": "Update a Heading Widget",
        "description": "Update an existing heading widget on a page. Note that when updating, the widget ID will change.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/WidgetIdParam"
          },
          {
            "$ref": "#/components/parameters/FormatParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWidgetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Widget successfully updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeadingWidget"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/attachment/create/": {
      "post": {
        "operationId": "createAttachmentWidget",
        "summary": "Create an Attachment Widget",
        "description": "Upload a file and create a new attachment widget on a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attachment widget created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentWidget"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/attachment/update/{widget_id}/": {
      "post": {
        "operationId": "updateAttachmentWidget",
        "summary": "Update an Attachment Widget",
        "description": "Upload a file to add to an existing attachment widget on a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/WidgetIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The file to upload"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attachment widget updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AttachmentWidget"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/paragraph/delete/{widget_id}/": {
      "post": {
        "operationId": "deleteParagraphWidget",
        "summary": "Delete a Paragraph Widget",
        "description": "Delete a paragraph widget from a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/WidgetIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Widget deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/heading/delete/{widget_id}/": {
      "post": {
        "operationId": "deleteHeadingWidget",
        "summary": "Delete a Heading Widget",
        "description": "Delete a heading widget from a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/WidgetIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Widget deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/page/{page_id}/attachment/delete/{widget_id}/": {
      "post": {
        "operationId": "deleteAttachmentWidget",
        "summary": "Delete an Attachment Widget",
        "description": "Delete an attachment widget from a page.",
        "tags": ["Widgets"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          },
          {
            "$ref": "#/components/parameters/WidgetIdParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Widget deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/search/query/": {
      "get": {
        "operationId": "searchQuery",
        "summary": "Search query",
        "description": "Search the intranet for pages, comments, form entries, people, or files using Papyrs' built-in search engine.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "The search query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/people/all/": {
      "get": {
        "operationId": "getAllPeople",
        "summary": "Get all people",
        "description": "Get a list of all people in your account as shown in the People Directory, ordered by join date (newest first). Guest users are not included.",
        "tags": ["People"],
        "responses": {
          "200": {
            "description": "Successful people list retrieval",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Person"
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/people/delete/{user_id}/": {
      "post": {
        "operationId": "deleteUser",
        "summary": "Delete a user",
        "description": "Permanently delete a user from your account. Site administrators only.",
        "tags": ["People"],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "description": "The user ID to delete",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User successfully deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteResponse"
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/feed/post/": {
      "post": {
        "operationId": "postToFeed",
        "summary": "Post to the Activity Stream",
        "description": "Post a comment to the Activity Stream.",
        "tags": ["Feed"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedPostRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully posted to feed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedPost"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    },
    "/feed/post/{page_id}/": {
      "post": {
        "operationId": "postToPageFeed",
        "summary": "Post to a page discussion",
        "description": "Post a comment to the discussion stream on a specific page.",
        "tags": ["Feed"],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedPostRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully posted to page feed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedPost"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiTokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "auth_token",
        "description": "API token generated from Site Settings > Integrations & SSO > API"
      }
    },
    "parameters": {
      "PageIdParam": {
        "name": "page_id",
        "in": "path",
        "required": true,
        "description": "The page ID",
        "schema": {
          "type": "string"
        }
      },
      "WidgetIdParam": {
        "name": "widget_id",
        "in": "path",
        "required": true,
        "description": "The widget ID on the page",
        "schema": {
          "type": "string"
        }
      },
      "FormatParam": {
        "name": "format",
        "in": "query",
        "required": false,
        "description": "Describes the format of the val field. Values: html (default) or text",
        "schema": {
          "type": "string",
          "enum": ["html", "text"],
          "default": "html"
        }
      }
    },
    "schemas": {
      "Page": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique page identifier"
          },
          "title": {
            "type": "string",
            "description": "Page title"
          },
          "slug": {
            "type": "string",
            "description": "URL-friendly page slug"
          },
          "url": {
            "type": "string",
            "description": "Full URL to the page"
          },
          "category": {
            "type": "string",
            "description": "Folder path (e.g. 'Main/Subfolder')"
          },
          "is_public": {
            "type": "boolean",
            "description": "Whether the page is publicly accessible"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp in ISO8601 UTC"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp in ISO8601 UTC"
          },
          "created_by": {
            "type": "string",
            "description": "Name of the creator"
          },
          "json": {
            "type": "array",
            "description": "Page content as a list of columns, each containing a list of widgets",
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Widget"
              }
            }
          },
          "layout": {
            "type": "array",
            "description": "Page layout definition",
            "items": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              }
            }
          },
          "permissions": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "enum": ["no access", "view", "edit"]
            },
            "description": "Map of user IDs to permission levels"
          },
          "notifications": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "enum": ["on", "off"]
            },
            "description": "Map of user IDs to notification settings"
          }
        }
      },
      "PageSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "is_public": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_by": {
            "type": "string"
          }
        }
      },
      "CreatePageRequest": {
        "type": "object",
        "required": ["title", "json"],
        "properties": {
          "title": {
            "type": "string",
            "description": "The title of the new page"
          },
          "json": {
            "type": "array",
            "description": "Page content as columns of widgets",
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Widget"
              }
            }
          },
          "layout": {
            "type": "array",
            "description": "Optional layout definition",
            "items": {
              "type": "array",
              "items": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              }
            }
          },
          "permissions": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "enum": ["no access", "view", "edit"]
            }
          },
          "notifications": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "enum": ["on", "off"]
            }
          },
          "category": {
            "type": "string",
            "description": "Folder path for the page"
          }
        }
      },
      "Widget": {
        "type": "object",
        "properties": {
          "classname": {
            "type": "string",
            "description": "Widget type (Paragraph, Heading, Attachment, etc.)"
          },
          "id": {
            "type": "string",
            "description": "Widget ID"
          },
          "html": {
            "type": "string",
            "description": "HTML content of the widget"
          },
          "text": {
            "type": "string",
            "description": "Plain text content of the widget"
          },
          "val": {
            "type": "string",
            "description": "Value for creating widgets"
          }
        }
      },
      "ParagraphWidget": {
        "type": "object",
        "properties": {
          "classname": {
            "type": "string",
            "example": "Paragraph"
          },
          "id": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "UpdatedParagraphWidget": {
        "type": "object",
        "properties": {
          "classname": {
            "type": "string",
            "example": "Paragraph"
          },
          "id": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "version_of_id": {
            "type": "string",
            "description": "The original widget ID before the update"
          }
        }
      },
      "HeadingWidget": {
        "type": "object",
        "properties": {
          "classname": {
            "type": "string",
            "example": "Heading"
          },
          "id": {
            "type": "string"
          },
          "html": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "AttachmentWidget": {
        "type": "object",
        "properties": {
          "classname": {
            "type": "string",
            "example": "Attachment"
          },
          "id": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AttachmentFile"
            }
          }
        }
      },
      "AttachmentFile": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "description": "File size in bytes"
          },
          "url": {
            "type": "string",
            "description": "Download URL"
          },
          "vanity_size": {
            "type": "string",
            "description": "Human-readable file size"
          }
        }
      },
      "CreateWidgetRequest": {
        "type": "object",
        "required": ["widget"],
        "properties": {
          "widget": {
            "type": "object",
            "required": ["val"],
            "properties": {
              "val": {
                "type": "string",
                "description": "The content value for the widget"
              }
            }
          }
        }
      },
      "RecordField": {
        "type": "object",
        "properties": {
          "field": {
            "type": "string",
            "description": "The name of the record field"
          },
          "value": {
            "description": "The value of the field"
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SearchResult"
            }
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "desc": {
            "type": "string",
            "description": "Description of the result"
          },
          "icon": {
            "type": "string",
            "description": "Icon class for the result"
          },
          "weight": {
            "type": "integer",
            "description": "Search relevance weight"
          },
          "lnk": {
            "type": "string",
            "description": "Link to the result"
          },
          "cat": {
            "type": "string",
            "description": "Result category",
            "enum": ["Page", "File", "Contact", "Form", "Comment"]
          }
        }
      },
      "Person": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "role_id": {
            "type": "string",
            "description": "User role (e.g. 'normal')"
          },
          "subgroup_id": {
            "type": "string"
          },
          "waiting_invite": {
            "type": "boolean",
            "description": "Whether the user has accepted their invitation"
          },
          "avatar_large": {
            "type": "string",
            "description": "URL to the user's large avatar"
          },
          "distinguished_name": {
            "type": "string",
            "description": "LDAP distinguished name if applicable"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "User attributes like Name, Email, Position, Bio, etc."
          }
        }
      },
      "FeedPostRequest": {
        "type": "object",
        "required": ["msg"],
        "properties": {
          "msg": {
            "type": "string",
            "description": "The message to post"
          }
        }
      },
      "FeedPost": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "c": {
            "type": "string",
            "description": "The posted comment content"
          },
          "by": {
            "type": "string",
            "description": "Name of the poster"
          },
          "a": {
            "type": "string",
            "description": "Avatar URL"
          },
          "unsafe_c": {
            "type": "string",
            "description": "Unescaped comment content"
          }
        }
      },
      "DeleteResponse": {
        "type": "object",
        "properties": {
          "deleted": {
            "type": "boolean"
          },
          "id": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Request formatted incorrectly, wrong or missing parameter",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "No permission for this action",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found or no permission to access",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "TooManyRequests": {
        "description": "Rate limit exceeded (default: 6 requests/60 seconds)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}