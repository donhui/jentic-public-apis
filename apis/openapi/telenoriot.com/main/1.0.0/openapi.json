{
  "openapi": "3.0.3",
  "info": {
    "title": "Telenor Managed IoT Cloud REST API",
    "description": "REST API for Telenor Managed IoT Cloud (MIC) platform, enabling management of things, thing types, and IoT data reporting.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.telenorconnexion.com/mic/getting-started/cloud-rest-api/"
  },
  "servers": [
    {
      "url": "https://{apiGatewayRootUrl}/prod",
      "description": "MIC API Gateway",
      "variables": {
        "apiGatewayRootUrl": {
          "default": "api.2.mic.telenorconnexion.com",
          "description": "API Gateway root URL obtainable via manifest endpoint"
        }
      }
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "operationId": "loginUser",
        "tags": [
          "Authentication"
        ],
        "summary": "Authenticate a user and obtain tokens",
        "security": [
          {
            "apiKey": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid credentials format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials or API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/thingtypes": {
      "post": {
        "operationId": "createThingType",
        "tags": [
          "ThingTypes"
        ],
        "summary": "Create a new thing type",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateThingTypeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Thing type created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThingType"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid thing type data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid authorization",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/things": {
      "get": {
        "operationId": "getThing",
        "tags": [
          "Things"
        ],
        "summary": "Retrieve a thing by name",
        "parameters": [
          {
            "name": "thingName",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The name of the thing to retrieve"
          },
          {
            "name": "attributes",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of attributes to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Thing retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Thing"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createThing",
        "tags": [
          "Things"
        ],
        "summary": "Create a new thing",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateThingRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Thing created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Thing"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid thing data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/things/resources": {
      "put": {
        "operationId": "reportThingData",
        "tags": [
          "Things"
        ],
        "summary": "Report data to a thing's resources",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportDataRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data reported successfully"
          },
          "400": {
            "description": "Bad request - invalid data format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "x-api-key",
        "in": "header",
        "description": "API key for accessing the MIC platform"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Authorization token obtained from login endpoint"
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": [
          "userName",
          "password"
        ],
        "properties": {
          "userName": {
            "type": "string",
            "description": "User's login name"
          },
          "password": {
            "type": "string",
            "description": "User's password"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Authorization token for API access"
          },
          "refreshToken": {
            "type": "string",
            "description": "Token used to refresh the authorization token"
          },
          "domainName": {
            "type": "string",
            "description": "Domain name of the authenticated user"
          }
        }
      },
      "CreateThingTypeRequest": {
        "type": "object",
        "required": [
          "id",
          "domain",
          "label"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-_]+$",
            "description": "Unique identifier for the thing type"
          },
          "domain": {
            "type": "string",
            "description": "Domain the thing type belongs to"
          },
          "label": {
            "type": "string",
            "description": "Human-readable label"
          },
          "description": {
            "type": "string",
            "description": "Optional description"
          }
        }
      },
      "ThingType": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "CreateThingRequest": {
        "type": "object",
        "required": [
          "thingName",
          "thingType",
          "domain"
        ],
        "properties": {
          "thingName": {
            "type": "string",
            "description": "Unique name for the thing"
          },
          "thingType": {
            "type": "string",
            "description": "Type of the thing"
          },
          "domain": {
            "type": "string",
            "description": "Domain the thing belongs to"
          }
        }
      },
      "Thing": {
        "type": "object",
        "properties": {
          "thingName": {
            "type": "string"
          },
          "thingType": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "domainTopic": {
            "type": "string"
          },
          "shadow": {
            "type": "object",
            "description": "Thing shadow state"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdBy": {
            "type": "string"
          }
        }
      },
      "ReportDataRequest": {
        "type": "object",
        "required": [
          "thingName",
          "thingType",
          "resources"
        ],
        "properties": {
          "thingName": {
            "type": "string",
            "description": "Name of the thing to report data to"
          },
          "thingType": {
            "type": "string",
            "description": "Type of the thing"
          },
          "resources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Resource"
            }
          }
        }
      },
      "Resource": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Resource name"
          },
          "value": {
            "type": "string",
            "description": "Resource value"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKey": [],
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication and token management"
    },
    {
      "name": "ThingTypes",
      "description": "Manage thing type definitions"
    },
    {
      "name": "Things",
      "description": "Manage IoT things and report data"
    }
  ]
}