      "zonesvodpushnew_geoblock": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if Geo Block should be enabled.<br> Set to N if Geo Block should not to be enabled.",
            "example": "Y"
          },
          "policy": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if geoblock countries list should be allowed.<br> Set to N if geoblock countries list should be blocked",
            "example": "Y"
          },
          "list": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Geoblock countries list values can be AF,DZ,AW,CA etc",
              "example": "AF"
            }
          },
          "ips": {
            "type": "string",
            "description": "List of IPs to whitelist when geoblock is enabled. IPs should be separated by comma. <br>Eg: 192.168.0.1, 192.168.0.2",
            "example": "192.168.0.1"
          }
        }
      },
      "zoneshttppullnew_securetoken": {
        "type": "object",
        "properties": {
          "policy": {
            "type": "string",
            "description": "Values Can be Y or N. <br> Set to Y if secure token should be enabled<br> Set to Y if Secure token should be disabled.",
            "example": "Y"
          },
          "list": {
            "type": "string",
            "description": "The value should be random alpha numeric string, [A-Za-z0-9]",
            "example": "5f1283ceb939b05c"
          },
          "timeout": {
            "type": "integer",
            "description": "Secure token link expiration time in seconds \tmin: 5, max: 25200",
            "format": "int32",
            "example": 300
          },
          "keyip": {
            "type": "string",
            "description": "Add Client IP in token generation for added security",
            "example": "N"
          },
          "ips": {
            "type": "string",
            "description": "IP's listed is excluded from any restrictions",
            "example": "117.251.60.184"
          }
        }
      },
      "postPushZoneSecuretoken": {
        "type": "object",
        "properties": {
          "policy": {
            "type": "string",
            "description": "Values Can be Y or N. <br> Set to Y if secure token should be enabled<br> Set to Y if Secure token should be disabled.",
            "example": "Y"
          },
          "list": {
            "type": "string",
            "description": "Token, The value should be random alpha numeric string, [A-Za-z0-9].",
            "example": "c7d5cfb3212931fa"
          },
          "timeout": {
            "type": "integer",
            "description": "Secure token link expiration time in seconds \tmin: 5, max: 25200",
            "format": "int32",
            "example": 300
          },
          "keyip": {
            "type": "string",
            "description": "Values Can be Y or N. <br> Set to Y if Add Client IP in token generation for added security should be enabled<br> Set to N if Add Client IP in token generation for added security should be disabled.",
            "example": "N"
          },
          "ips": {
            "type": "string",
            "description": "IPs should be separated by comma. <br>Eg: 192.168.0.1, 192.168.0.2",
            "example": "117.251.60.184"
          }
        }
      },
      "postPushZoneImport": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Enter numeric value.",
            "format": "int32"
