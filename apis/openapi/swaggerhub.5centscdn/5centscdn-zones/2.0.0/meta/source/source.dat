  "components": {
    "parameters": {
      "zoneIdParam": {
        "in": "path",
        "name": "zoneid",
        "description": "Zone ID",
        "required": true,
        "style": "simple",
        "explode": false,
        "schema": {
          "type": "string"
        }
      },
      "modeParam": {
        "in": "query",
        "name": "m",
        "description": "Enter reported by",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "typeParam": {
        "in": "query",
        "name": "t",
        "description": "Enter daily or hourly",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "rParam": {
        "in": "query",
        "name": "r",
        "description": "Enter value last_24hrs/hourly or last_7days/hourly or last_30days/daily",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "rangeParam": {
        "in": "query",
        "name": "r",
        "description": "Enter date range",
        "explode": false,
        "schema": {
          "type": "string"
        }
      },
      "queryParam": {
        "in": "query",
        "name": "query",
        "description": "search by filename",
        "schema": {
          "type": "string"
        }
      },
      "markerParam": {
        "in": "query",
        "name": "marker",
        "description": "Set the marker parameter to the name of the last item returned in the previous list.",
        "schema": {
          "type": "string"
        }
      },
      "endmarkerParam": {
        "in": "query",
        "name": "end_marker",
        "description": "Limits the result set to names that are less than the end_marker parameter value.",
        "schema": {
          "type": "string"
        }
      },
      "dirParam": {
        "in": "query",
        "name": "dir",
        "description": "Enter directory name",
        "schema": {
          "type": "string"
        }
      },
      "fileParam": {
        "in": "query",
        "name": "file",
        "description": "Enter file name",
        "schema": {
          "type": "string"
        }
      },
      "mediaParam": {
        "in": "query",
        "name": "media",
        "description": "show detailed media info if 1",
        "schema": {
          "type": "string"
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "createZonePush": {
        "required": [
          "_METHOD",
          "server"
        ],
        "type": "object",
        "properties": {
          "_METHOD": {
            "type": "string",
            "description": "To cast request method  PUT",
            "example": "PUT"
          },
          "server": {
            "type": "integer",
            "format": "int32",
            "example": 30,
            "description": "server.code, Should be one of the server code from the GET /zones/http/push/servers call"
          },
          "cnames": {
            "type": "string",
            "description": "Name that points to actual record. <br>Eg: docs.example.com",
            "example": "docs.example.com"
          },
          "profiles": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32",
              "description": "All file uploaded to /raw folder will be transcoded to selected profiles. Leave empty to disable auto file transcoding. <br>Eg: 7549",
              "example": 7549
            }
          },
          "webhook": {
            "type": "string",
            "description": "Notification will be send every minute after files get transcoded. Enter a valid url where we send the files list as a json raw post data",
            "example": "https://mydomain.com/notify"
          },
          "cache[cache]": {
            "type": "string",
            "description": "This will be the default cache name.The values can be 1d,7d,14d, 1M, 3M, 6M, or 1y",
            "example": "7d"
          },
          "edge": {
            "$ref": "#/components/schemas/zoneshttppushnew_edge"
          },
          "domainlock": {
            "$ref": "#/components/schemas/zoneshttppushnew_domainlock"
          },
          "securetoken": {
            "$ref": "#/components/schemas/zoneshttppushnew_securetoken"
          },
          "geoblock": {
            "$ref": "#/components/schemas/zoneshttppushnew_geoblock"
          },
          "ssl": {
            "$ref": "#/components/schemas/postZoneSSL"
          },
          "bwlimit": {
            "$ref": "#/components/schemas/postZoneBwlimit"
          }
        }
      },
      "zoneshttppushnew_geoblock": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if Geo Block should be enabled.<br> Set to N if Geo Block should not to be enabled.",
            "example": "Y"
          },
          "policy": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if geoblock countries list should be allowed.<br> Set to N if geoblock countries list should be blocked",
            "example": "Y"
          },
          "list": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Geoblock countries list values can be AF,DZ,AW,CA etc",
              "example": "AF"
            }
          }
        }
      },
      "zoneshttpsetting_geoblock": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if Geo Block should be enabled.<br> Set to N if Geo Block should not to be enabled.",
            "example": "Y"
          },
          "policy": {
            "type": "string",
