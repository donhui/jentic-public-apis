            "example": "Y"
          },
          "webp": {
            "type": "string",
            "description": "Values can be Y or N.<br> Set to Y to enable WebP.<br> Set to N to disable WebP.",
            "example": "N"
          },
          "lfo": {
            "type": "string",
            "description": "Values can be Y or N.<br> Set to Y to enable Large File Optimization .<br> Set to N to disable Large File Optimization .",
            "example": "N"
          },
          "prefresh": {
            "type": "string",
            "description": "Values can be Y or N.<br> Set to Y to enable Cache Prefreshing  .<br> Set to N to disable Cache Prefreshing .",
            "example": "N"
          },
          "wp": {
            "type": "string",
            "description": "Values can be Y or N.<br> Set to Y to enable WordPress Bypass Cache for Administration   .<br> Set to N to disable WordPress Bypass Cache for Administration  .",
            "example": "Y"
          },
          "pseudostreaming": {
            "type": "string",
            "description": "Values can be Y or N.<br> Set to Y to enable pseudo stream seeking.<br> Set to N to disable  pseudo stream seeking.",
            "example": "Y"
          }
        }
      },
      "postZone": {
        "type": "object",
        "properties": {
          "cnames": {
            "type": "string",
            "description": "Enter a custom domain. For example: cdn.domain.com, images.domain.com, static.domain.com",
            "example": "cdn.domain.com"
          },
          "profiles": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64",
              "description": "All file uploaded to /raw folder will be transcoded to selected profiles. Leave empty to disable auto file transcoding. <br>Eg: 7549",
              "example": 1
            }
          },
          "webhook": {
            "type": "string",
            "description": "Notification will be send every minute after files get transcoded. Enter a valid url where we send the files list as a json raw post data",
            "example": "https://mydomain.com/notify"
          }
        }
      },
      "postPullZone": {
        "type": "object",
        "properties": {
          "origin": {
            "type": "string",
            "description": "Your Origin Server Host Name",
            "example": "https://mydomain.com"
          },
          "optimize": {
            "type": "string",
            "description": "Values can be http,live or vod",
            "example": "http"
          },
          "cnames": {
            "type": "string",
            "description": "Name that points to actual record. <br>Eg: docs.example.com",
            "example": "docs.example.com"
          }
        }
      },
      "postZoneVodPush": {
        "type": "object",
        "properties": {
          "cnames": {
            "type": "string",
            "description": "Name that points to actual record. <br>Eg: docs.example.com",
            "example": "docs.example.com"
          },
          "profiles": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32",
              "description": "All file uploaded to /raw folder will be transcoded to selected profiles. Leave empty to disable auto file transcoding. <br>Eg: 7549",
              "example": 7549
            }
          },
          "webhook": {
            "type": "string",
            "description": "Notification will be send every minute after files get transcoded. Enter a valid url where we send the files list as a json raw post data",
            "example": "https://mydomain.com/notify"
          }
        }
      },
      "createPullZone": {
        "required": [
          "_METHOD"
        ],
        "type": "object",
        "properties": {
          "_METHOD": {
            "type": "string",
            "description": "To cast request method POST to PUT",
            "example": "PUT"
          },
          "origin": {
            "type": "string",
            "description": "Your Origin Server Host Name",
            "example": "https://mydomain.com"
          },
          "cnames": {
            "type": "string",
            "description": "Name that points to actual record. <br>Eg: docs.example.com",
            "example": "docs.example.com"
          },
          "cache[cache]": {
            "type": "string",
            "description": "This will be the default cache name.The values can be 1d,7d,14d, 1M, 3M, 6M, or 1y",
            "example": "1M"
          },
          "cache[expiry]": {
            "type": "string",
            "description": "This will be the default cache name.The values can be 1d,7d,14d, 1M, 3M, 6M, or 1y",
            "example": "1M"
          },
          "cache[querystring]": {
            "type": "string",
            "description": "Values can be Y or N.<br> Set to Y to enable querystring.<br> Set to N to disable querystring.",
            "example": "N"
          },
          "cache[cachecontrol]": {
            "type": "string",
            "description": "Values can be Y or N.<br> Set to Y to enable cachecontrol.<br> Set to N to disable cachecontrol.",
            "example": "Y"
          },
          "cache[stale]": {
            "type": "string",
            "description": "Values can be Y or N.<br> Set to Y to enable stale.<br> Set to N to disable stale.",
            "example": "Y"
          },
          "cache[revalidate]": {
            "type": "string",
            "description": "Values can be Y or N.<br> Set to Y to enable revalidate.<br> Set to N to disable revalidate.",
            "example": "N"
          },
          "optimize": {
            "type": "string",
            "description": "Values can be http,live or vod",
            "example": "http"
          },
          "shields": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "The value should be CA or FR",
              "example": "CA"
            }
          },
          "originip": {
            "$ref": "#/components/schemas/postZoneOriginip"
          },
          "edge": {
            "$ref": "#/components/schemas/postZoneEdge"
          },
          "seo": {
            "$ref": "#/components/schemas/postZoneSeo"
          },
          "domainlock": {
            "$ref": "#/components/schemas/zoneshttppushnew_domainlock"
          },
          "securetoken": {
            "$ref": "#/components/schemas/zoneshttppullnew_securetoken"
          },
          "geoblock": {
            "$ref": "#/components/schemas/zoneshttppushnew_geoblock"
          },
          "bwlimit": {
            "$ref": "#/components/schemas/postZoneBwlimit"
          },
          "ssl": {
            "$ref": "#/components/schemas/postZoneSSL"
          }
        }
      },
