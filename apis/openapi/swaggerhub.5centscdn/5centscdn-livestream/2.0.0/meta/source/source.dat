      "Postplaylist": {
        "required": [
          "_METHOD",
          "name"
        ],
        "type": "object",
        "properties": {
          "_METHOD": {
            "type": "string",
            "description": "To cast request method POST to PUT",
            "example": "PUT"
          },
          "name": {
            "type": "string",
            "description": "Playlist name.<br>Name should have minimum 2 chars, and maximum 32 chars length."
          },
          "type": {
            "type": "string",
            "enum": [
              "file"
            ],
            "description": "playlist type set as file.",
            "example": "file"
          },
          "loop": {
            "type": "string",
            "enum": [
              "onetime",
              "repeat"
            ],
            "description": "Should the playlist be looped or played onetime only."
          },
          "autorestart": {
            "type": "string",
            "enum": [
              true,
              false
            ],
            "description": "Should the playlist be restarted after update. Set to Yes, to set and reload the schedules. If No, the new playlists will be only reloaded after a stream restart api call."
          },
          "schedule": {
            "type": "string",
            "description": "The values can be  'instant', ' scheduleontime' or 'scheduleondatetime'",
            "example": "instant"
          },
          "scheduleontime": {
            "type": "string",
            "description": "Scheduleontime should be in the format of hh:mm:ss. <br/>It should be used if the 'schedule'  is 'scheduleontime'."
          },
          "repeatfor": {
            "type": "integer",
            "minimum": 1,
            "maximum": 7,
            "description": "Specify how many days the ScheduleOnTime should be repeated for."
          },
          "scheduleondatetime": {
            "type": "string",
            "description": "Scheduleondatetime's format should be yyyy-mm-dd hh:mm:ss . <br>It should be used if  'schedule' is 'scheduleondatetime'."
          },
          "files[file][]": {
            "$ref": "#/components/schemas/streamsscheduledplayliststreamidplaylistnew_files"
          },
          "durations[file][]": {
            "$ref": "#/components/schemas/streamsscheduledplayliststreamidplaylistnew_durations"
          }
        }
      },
      "streamsscheduledplayliststreamidplaylistnew_files": {
        "description": "Relative paths to scheduled file. Only .mp4 file extension supported.",
        "type": "string"
      },
      "streamsscheduledplayliststreamidplaylistnew_durations": {
        "description": "File offset & duration in secs for each scheduled files in the order as give in files[file][].",
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": {
          "type": "integer"
        }
      },
