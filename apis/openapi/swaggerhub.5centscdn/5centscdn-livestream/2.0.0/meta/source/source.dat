  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "CreatePushStream": {
        "required": [
          "_METHOD",
          "name",
          "server"
        ],
        "type": "object",
        "properties": {
          "_METHOD": {
            "type": "string",
            "description": "To cast request method POST to PUT",
            "example": "PUT"
          },
          "name": {
            "type": "string",
            "description": "Stream name.<br>Should be in the format part-1/part-2. Each part should have minimum 3 chars, separated by forward slash \u2018/\u2019, without any space"
          },
          "server": {
            "type": "string",
            "description": "server.code, Should be one of the server code from the GET /streams/push/servers call"
          },
          "ssl": {
            "type": "string",
            "description": "Values can be Y or N. <br>Set to Y if HTTPS should be enabled.<br> Set to N if HTTPS should be disabled.",
            "example": "Y"
          },
          "codec": {
            "type": "string",
            "description": "Values can be h264 or h265. <br>Set Source Stream Codec.",
            "example": "h264"
          },
          "domainlock": {
            "$ref": "#/components/schemas/streamstimeshiftnew_domainlock"
          },
          "geoblock": {
            "$ref": "#/components/schemas/streamstimeshiftnew_geoblock"
          },
          "vprofiles": {
            "$ref": "#/components/schemas/Postvprofiles"
          },
          "aprofiles": {
            "$ref": "#/components/schemas/Postvprofiles"
          },
          "filters": {
            "$ref": "#/components/schemas/Posttranscode_filters"
          },
          "platform": {
            "$ref": "#/components/schemas/Postplatform"
          },
          "record": {
            "$ref": "#/components/schemas/streamspushnew_record"
          },
          "ndvr": {
            "$ref": "#/components/schemas/streamspushnew_ndvr"
          },
          "securetoken": {
            "$ref": "#/components/schemas/streamstimeshiftnew_securetoken"
          }
        }
      },
      "filtersList": {
        "properties": {
          "0": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "serviceid": {
                "type": "integer"
              },
              "type": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "settings": {
                "$ref": "#/components/schemas/settingFilterList"
              }
            }
          }
        }
      },
      "settingFilterList": {
        "properties": {
          "filter": {
            "type": "string"
          },
          "args": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "fontsize": {
                "type": "integer"
              },
              "fontcolor": {
                "type": "string"
              },
              "position": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "scale": {
                "type": "integer"
              }
            }
          }
        }
      },
      "createFileTranscodingFilter": {
        "required": [
          "name",
          "_METHOD"
        ],
        "properties": {
          "_METHOD": {
            "type": "string",
            "description": "To cast request method POST to PUT",
            "example": "PUT"
          },
          "name": {
            "type": "string",
            "description": "Enter fliter name"
          },
          "filter": {
            "type": "string",
            "description": "Filter settings values can be overlay or drawtext"
          },
          "args": {
            "type": "object",
            "properties": {
              "overlay": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "Enter Logo Url eg:http://example.com/logo.png"
                  },
                  "scale": {
                    "type": "integer",
                    "format": "int32",
                    "description": "values can be \tmin: 5, max: 150"
                  },
                  "position": {
                    "type": "string",
                    "description": "position of logo should be topleft,tocenter,topright,centerleft,center,centerright,bottomleft,bottomright,bottomcenter"
                  }
                }
              },
              "drawtext": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Enter watermark text"
                  },
                  "fontsize": {
                    "type": "integer",
                    "format": "int32",
                    "description": "values can be \tmin: 8, max: 64 .eg: 16 ",
                    "example": 16
                  },
                  "fontcolor": {
                    "type": "string",
                    "description": "Enter text font color for example #42A5F5"
                  },
                  "position": {
                    "type": "string",
                    "description": "position of text should be topleft,tocenter,topright,centerleft,center,centerright,bottomleft,bottomright,bottomcenter"
                  }
                }
              }
            }
          }
        }
      },
      "editFileTranscodingFilter": {
        "properties": {
          "args": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "description": "Enter Logo Url eg:http://example.com/logo.png"
              },
              "scale": {
                "type": "integer",
                "format": "int32",
                "description": "values can be \tmin: 5, max: 150"
              },
              "position": {
                "type": "string",
                "description": "position should be topleft,tocenter,topright,centerleft,center,centerright,bottomleft,bottomright,bottomcenter"
              },
              "text": {
                "type": "string",
                "description": "Enter watermark text"
              },
              "fontsize": {
                "type": "integer",
                "format": "int32",
                "description": "values can be \tmin: 8, max: 64 .eg: 16 ",
                "example": 16
              },
              "fontcolor": {
                "type": "string",
                "description": "Enter text font color for example #42A5F5"
              }
            }
          }
        }
      },
      "Postvprofiles": {
        "type": "array",
        "items": {
          "type": "integer"
        },
        "description": "transcode profile values from the GET /streams/settings/profiles call"
      },
      "Postplatform": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Postplatform_inner"
        }
      },
      "Editplatform": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Platform name.<br>Name should have minimum 2 chars, and maximum 32 chars length."
          },
          "rtmp": {
            "type": "string",
            "description": "Your RTMP URL. <br>Eg: rtmp://a.rtmp.youtube.com/live2"
          },
          "key": {
            "type": "string",
            "description": "Your RTMP key. <br>Eg: 5t1d-hvka-50ga-7dj0-38h0"
          },
          "auth": {
            "type": "string",
            "description": "Values Can be Y or N. <br> Set to Y if Publish Auth should be enabled<br> Set to Y if Publish Auth should be disabled.",
            "example": "N"
          },
          "username": {
            "type": "string",
            "description": "Enter Your username.Eg:username"
          },
          "password": {
            "type": "string",
            "description": "Enter Your password.Eg:password"
          },
          "schedule": {
            "type": "string",
            "description": "The values can be  'instant', ' scheduleontime' or 'scheduleondatetime'"
          },
          "scheduleontime": {
            "type": "string",
            "description": "Scheduleontime should be in the format of hh:mm:ss. <br/>It can be use if the 'schedule'  is 'scheduleontime'.Scheduleondatetime's format should be yyyy-mm-dd hh:min:sec . <br>It can be used if  'schedule' is 'scheduleondatetime'."
          },
          "length": {
            "type": "string",
            "description": "Length should be in the format hh:mm:ss. length can be set if type is 'live'."
          },
          "transcodetype": {
            "type": "string",
            "description": "value should be sd,hd or uhd"
          },
          "vprofiles": {
            "$ref": "#/components/schemas/Editplatform_vprofiles"
          },
          "aprofiles": {
            "$ref": "#/components/schemas/Editplatform_vprofiles"
          },
          "filters": {
            "$ref": "#/components/schemas/Posttranscode_filters"
          }
        }
      },
      "Postdisabled": {
        "type": "object",
        "properties": {
          "disabled": {
            "type": "integer",
            "format": "int32",
            "description": "Values can be 0 or 1.<br>Set to 1 if status should be enabled.<br> Set to 0 if status should not to be disabled.",
            "example": 0
          }
        }
      },
      "streamsetting_geoblock": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if Geo Block should be enabled.<br> Set to N if Geo Block should not to be enabled.",
            "example": "Y"
          },
          "policy": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if geoblock countries list should be allowed.<br> Set to N if geoblock countries list should be blocked",
            "example": "N"
          },
          "list": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "Geoblock countries list values can be AF,DZ,AW,CA etc",
              "example": "AF"
            }
          },
          "ips": {
            "type": "string",
            "description": "List of IPs to whitelist when geoblock is enabled. IPs should be separated by comma. <br>Eg: 192.168.0.1, 192.168.0.2",
            "example": "192.168.0.1"
          },
          "mode": {
            "type": "string",
            "description": "The values can be save,append,overwrite",
            "example": "save"
          }
        }
      },
      "streamsetting_rtmpauth": {
        "type": "object",
        "properties": {
          "policy": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if policy should be enabled.<br> Set to N if policy should not to be enabled.",
            "example": "Y"
          },
          "password": {
            "type": "string",
            "description": "enter password"
          },
          "mode": {
            "type": "string",
            "description": "The values can be save,append,overwrite",
            "example": "save"
          }
        }
      },
      "streamsetting_cname": {
        "type": "object",
        "properties": {
          "cname": {
            "type": "string",
            "description": "Name that points to actual record. <br>Eg: docs.example.com"
          },
          "certid": {
            "type": "string",
            "description": "value should be S or L"
          }
        }
      },
      "streamsetting_hash": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if hash stream should be enabled.<br> Set to N if hash should not to be enabled."
          },
          "hashrestream": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if hash restream should be enabled.<br> Set to N if hash restream should not to be enabled."
          },
          "extension": {
            "type": "string",
            "description": "Stream extension value should be .sdp or .mp4"
          },
          "key": {
            "type": "string",
            "description": "Use Hash Salt to change the stream hex instantly"
          }
        }
      },
      "streamsetting_record": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if record should be enabled.<br> Set to N if record should be disabled"
          },
          "retention": {
            "type": "integer",
            "format": "int32",
            "description": "To specify the Retention period.<br>A digit, min: 1, max: 14 eg: 7 (7 days of DVR)"
          },
          "mode": {
            "type": "string",
            "description": "The values can be save,append,overwrite",
            "example": "save"
          }
        }
      },
      "streamsetting_ndvr": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "string",
            "description": "Values can be Y or N.<br>Set to Y if nDVR should be enabled.<br> Set to N if nDVR should be disabled",
            "example": "Y"
          },
          "retention": {
            "type": "integer",
            "format": "int32",
            "description": "To specify the Rewind Period (Mins), min: 5, max: 180<br> Eg: 5 (5 Mins of nDVR)",
            "example": 5
          },
          "mode": {
            "type": "string",
            "description": "The values can be save,append,overwrite",
            "example": "save"
          }
        }
      },
      "transcodingResult": {
        "type": "object",
        "properties": {
          "0": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "serviceid": {
                "type": "integer"
              },
              "type": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "filemode": {
                "type": "string"
              },
              "settings": {
                "$ref": "#/components/schemas/settingsResult"
              },
              "codec": {
                "type": "string"
              }
            }
          }
        }
      },
      "settingsResult": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "f": {
            "type": "string"
          },
          "cv": {
            "type": "string"
          },
          "sv": {
            "type": "string"
          },
          "svvalue": {
            "type": "string"
          },
          "deinterlace": {
            "type": "integer"
          },
          "preset": {
            "type": "string"
          },
          "bv": {
            "type": "integer"
          },
          "bvvalue": {
            "type": "integer"
          },
          "vpass": {
            "type": "integer"
          },
          "fps": {
            "type": "integer"
          },
          "vprofile": {
            "type": "string"
          },
          "ca": {
            "type": "string"
          },
          "aca": {
            "type": "integer"
          },
          "ba": {
            "type": "integer"
          },
          "bavalue": {
            "type": "integer"
          },
          "ara": {
            "type": "integer"
          },
          "now": {
            "type": "integer"
          }
        }
      },
      "streamsetting_profile": {
        "required": [
          "_METHOD",
          "name"
        ],
        "type": "object",
        "properties": {
          "_METHOD": {
            "type": "string",
            "description": "To cast request method POST to PUT",
            "example": "PUT"
          },
          "name": {
            "type": "string",
            "description": "Enter profile new name"
          },
          "filemode": {
            "type": "string",
            "description": "filemode should be sd,hd or uhd",
            "example": "sd"
          },
          "f": {
            "type": "string",
            "description": "Container Format should be mp4",
            "example": "mp4"
          },
          "cv": {
            "type": "string",
            "description": "Video codec should be libx264 or libx265",
            "example": "libx264"
          },
          "sv": {
            "type": "string",
            "description": "Resolution quality should be 2160p,1440p,1080p,720p,576p,480p,360p,240p or 144p",
            "example": "720p"
          },
          "svvalue": {
            "type": "string",
            "description": "Resolution quality format is set 1 define widthXheight"
          },
          "deinterlace": {
            "type": "string",
            "description": "Values can be 1 or 0.<br>Set to 1 if deinterlace should be enabled. <br>Set to 0 if deinterlace should be disabled.",
            "example": 0
          },
          "bvvalue": {
            "type": "integer",
            "format": "int32",
            "description": "To specify the Bitrate.<br>A digit followed min: 128, max: 4096<br> Eg: 800",
            "example": 800
          },
          "fps": {
            "type": "integer",
            "format": "int32",
            "description": "To specify the frame per second.<br>Values can be 24,30,48,50 or 60"
          },
          "vprofile": {
            "type": "string",
            "description": "Values can be disabled,baseline,main or high",
            "example": "disabled"
          },
          "vlevel": {
            "type": "string",
            "description": "Video profile if set baseline the level value should be 3.0 or 3.1. Video profile if set main the level value should be 3.1 or 4.0. Video profile if set high the level value should be  4.0,4.1 or 4.2"
          },
          "ca": {
            "type": "string",
            "description": "audio codec should be aac",
            "example": "aac"
          },
          "aca": {
            "type": "integer",
            "format": "int32",
            "description": "To specify the audio channel(s).<br>Set to 0 if As Source should be enabled. <br>Set to 2 if Stereo should be enabled. <br>Set to 1 if Mono should be enabled.",
            "example": 2
          },
          "bavalue": {
            "type": "string",
            "description": "To specify the Bitrate.<br>A digit followed min: 48, max: 196<br> Eg: 800",
            "example": 80
          },
          "ara": {
            "type": "string",
            "description": "To specify the Sample Rate.<br>Values should be 16000,22050,32000,44100 or 48000",
            "example": 44100
          }
        }
      },
