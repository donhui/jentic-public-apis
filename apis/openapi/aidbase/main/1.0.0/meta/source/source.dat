              "conversation": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ConversationMessage"
                }
              }
            }
          }
        }
      },
      "UpdateTicketRequest": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["open", "assigned", "need_more_info", "resolved", "closed"]
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      },
      "ReplyRequest": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string"
          },
          "persona_id": {
            "type": "string"
          }
        }
      },
      "EmailInbox": {
        "type": "object",
