    "/email-inbox/{inboxId}/emails/{emailId}": {
      "get": {
        "operationId": "getEmail",
        "summary": "Get an email",
        "description": "Retrieve a specific email with full conversation history.",
        "tags": ["EmailInboxes"],
        "parameters": [
          {
            "name": "inboxId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "emailId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Email retrieved",
            "content": {
