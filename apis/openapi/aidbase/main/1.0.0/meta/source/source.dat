            "type": "string",
            "format": "date-time"
          },
          "is_training": {
            "type": "boolean"
          },
          "training_failed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "training_failed_with": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "KnowledgeListResponse": {
        "type": "object",
