{
  "openapi": "3.0.3",
  "info": {
    "title": "Aidbase API",
    "description": "Aidbase is an AI-powered platform that helps businesses enhance self-serve and automate customer support. The API provides endpoints for managing knowledge bases, chatbots, ticket forms, and email inboxes.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.aidbase.ai/apis/introduction/"
  },
  "servers": [
    {
      "url": "https://api.aidbase.ai/v1",
      "description": "Aidbase API v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Knowledge",
      "description": "Knowledge base management"
    },
    {
      "name": "Chatbots",
      "description": "Chatbot management and interactions"
    },
    {
      "name": "TicketForms",
      "description": "Ticket form and ticket management"
    },
    {
      "name": "EmailInboxes",
      "description": "Email inbox and email management"
    }
  ],
  "paths": {
    "/knowledge": {
      "get": {
        "operationId": "listKnowledge",
        "summary": "List all knowledge items",
        "description": "Retrieve all knowledge items for the current account.",
        "tags": ["Knowledge"],
        "responses": {
          "200": {
            "description": "Knowledge items retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/knowledge/{id}": {
      "get": {
        "operationId": "getKnowledge",
        "summary": "Get a knowledge item",
        "description": "Retrieve a specific knowledge item by identifier.",
        "tags": ["Knowledge"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Knowledge item UUID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Knowledge item retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeItemResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Knowledge item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteKnowledge",
        "summary": "Delete a knowledge item",
        "description": "Delete a specific knowledge item.",
        "tags": ["Knowledge"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Knowledge item UUID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Knowledge item deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KnowledgeItemResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
