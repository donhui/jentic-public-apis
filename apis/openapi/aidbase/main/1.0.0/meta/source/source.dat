          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Filter chats created before this date (ISO 8601)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Filter chats created after this date (ISO 8601)",
