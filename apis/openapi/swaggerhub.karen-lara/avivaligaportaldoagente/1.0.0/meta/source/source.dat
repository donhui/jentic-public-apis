{
    "openapi": "3.0.0",
    "info": {
        "description": "This is a example of portal do agente api.  You can find \nout more about Swagger at \n[http://swagger.io](http://swagger.io) or on \n[irc.freenode.net, #swagger](http://swagger.io/irc/).\n",
        "version": "1.0.0",
        "title": "Swagger Portal do agente",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "email": "apiteam@swagger.io"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/karen_lara/AvivaLigaPortalDoAgente/1.0.0/swagger.json"
    },
    "paths": {
        "/register": {
            "post": {
                "summary": "Add new agent or frelancer to cms",
                "operationId": "register",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Register"
                            }
                        },
                        "application/xml": {
                            "schema": {
                                "$ref": "#/components/schemas/Register"
                            }
                        }
                    },
                    "description": "Register new agent or frelancer",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Register"
                                },
                                "examples": {
                                    "response": {
                                        "value": {
                                            "id": 1,
                                            "agency": {
                                                "name": "Test agency",
                                                "cnpj": "00000000000000"
                                            },
                                            "website": "test.com.br",
                                            "active": false,
                                            "email": "test@email.com",
                                            "cpf": "00000000000",
                                            "address": {
                                                "street": "test street",
                                                "number": "001",
                                                "city": "test city",
                                                "state": "test state",
                                                "neighborhood": "test neighborhood",
                                                "zipcode": "00000000",
                                                "complement": ""
                                            },
                                            "type": "register type",
                                            "terms": true,
                                            "institutionalEmails": false
                                        }
                                    }
                                }
                            },
                            "application/xml": {
                                "schema": {
                                    "$ref": "#/components/schemas/Register"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid body format",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                },
                                "examples": {
                                    "response": {
                                        "value": {
                                            "errors": [
                                                {
                                                    "message": "field 'X' are invalid.",
                                                    "code": 1,
                                                    "field": "X"
                                                }
                                            ]
                                        }
                                    }
                                }
                            },
                            "application/xml": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                }
                            }
                        }
                    }
                },
                "tags": [
                    "Agent"
                ]
            }
        }
    },
    "externalDocs": {
        "description": "Find out more about Swagger",
        "url": "http://swagger.io"
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/karen_lara/AvivaLigaPortalDoAgente/1.0.0"
        },
        {
            "url": "http://virtserver.swaggerhub.com/karen_lara/AvivaLigaPortalDoAgente/1.0.0"
        }
    ],
    "components": {
        "responses": {
            "BadRequest": {
                "description": "Invalid body format",
                "content": {
                    "*/*": {
                        "schema": {
                            "$ref": "#/components/schemas/Errors"
                        }
                    }
                }
            }
        },
        "schemas": {
            "Register": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "number",
                        "readOnly": true
                    },
                    "agency": {
                        "$ref": "#/components/schemas/Agency"
                    },
                    "website": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string"
                    },
                    "active": {
                        "type": "boolean",
                        "default": false,
                        "readOnly": true
                    },
                    "name": {
                        "type": "string"
                    },
                    "cpf": {
                        "type": "string"
                    },
                    "address": {
                        "$ref": "#/components/schemas/Address"
                    },
                    "type": {
                        "type": "string"
                    },
                    "terms": {
                        "type": "boolean"
                    },
                    "institutionalEmails": {
                        "type": "boolean",
                        "default": false
                    }
                },
                "required": [
                    "agency",
                    "website",
                    "email",
                    "name",
                    "cpf",
                    "address",
                    "type",
                    "terms"
                ],
                "default": {
                    "agency": {
                        "name": "Test agency",
                        "cnpj": "00000000000000"
                    },
                    "website": "test.com.br",
                    "email": "test@email.com",
                    "cpf": "00000000000",
                    "address": {
                        "street": "test street",
                        "number": "001",
                        "city": "test city",
                        "state": "test state",
                        "neighborhood": "test neighborhood",
                        "zipcode": "00000000",
                        "complement": ""
                    },
                    "type": "register type",
                    "terms": true,
                    "institutionalEmails": false
                }
            },
            "Address": {
                "type": "object",
                "properties": {
                    "street": {
                        "type": "string"
                    },
                    "number": {
                        "type": "string"
                    },
                    "city": {
                        "type": "string"
                    },
                    "state": {
                        "type": "string"
                    },
                    "neighborhood": {
                        "type": "string"
                    },
                    "zipcode": {
                        "type": "number"
                    },
                    "complement": {
                        "type": "string"
                    }
                },
                "required": [
                    "street",
                    "number",
                    "city",
                    "state",
                    "neighborhood"
                ]
            },
            "Agency": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "cnpj": {
                        "type": "string"
                    }
                },
                "required": [
                    "name",
                    "cnpj"
                ]
            },
            "Errors": {
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/Error"
                }
            },
            "Error": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "number"
                    },
                    "field": {
                        "type": "string"
                    }
                },
                "required": [
                    "message",
                    "code"
                ]
            }
        }
    }
}