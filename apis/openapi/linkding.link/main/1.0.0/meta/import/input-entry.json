            }
          },
          "date_added": {
            "type": "string",
            "format": "date-time"
          },
          "date_modified": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BookmarkInput": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "is_archived": {
            "type": "boolean"
          },
          "unread": {
            "type": "boolean"
          },
          "shared": {
            "type": "boolean"
          },
          "tag_names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "BookmarkListResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "next": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "previous": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "results": {
            "type": "array",
            "items": {
