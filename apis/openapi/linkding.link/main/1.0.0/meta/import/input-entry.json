  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token-based authentication. Format: 'Token <token>'"
      }
    },
    "schemas": {
      "Bookmark": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "website_title": {
            "type": "string"
          },
          "website_description": {
            "type": "string"
          },
          "web_archive_snapshot_url": {
            "type": "string",
            "format": "uri"
          },
          "is_archived": {
            "type": "boolean"
          },
          "unread": {
            "type": "boolean"
          },
          "shared": {
            "type": "boolean"
          },
          "tag_names": {
            "type": "array",
            "items": {
