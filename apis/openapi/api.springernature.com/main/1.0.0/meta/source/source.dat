{
  "openapi": "3.0.3",
  "info": {
    "title": "Springer Nature API",
    "description": "The Springer Nature API provides access to metadata, open access content, and full text of scientific articles, chapters, and protocols.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://dev.springernature.com/"
  },
  "servers": [
    {
      "url": "https://api.springernature.com",
      "description": "Springer Nature API production"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/openaccess/json": {
      "get": {
        "operationId": "searchOpenAccessMetadata",
        "summary": "Search open access article metadata",
        "description": "Retrieve metadata for open access articles in JSON format.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query (e.g., keyword:test, doi:10.1234/example)"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          },
          {
            "name": "s",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Start position for results"
          },
          {
            "name": "p",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page length / number of results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "Open access metadata results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/openaccess/jats": {
      "get": {
        "operationId": "getOpenAccessFullText",
        "summary": "Get open access full text in JATS XML",
        "description": "Access full-text content for open access articles and chapters in JATS XML format.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "s",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "p",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JATS XML full text",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/meta/v2/json": {
      "get": {
        "operationId": "searchMetaV2",
        "summary": "Search metadata (v2)",
        "description": "Enhanced metadata search endpoint with additional fields and optimized queries.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query (supports doi, keyword, subject, year, issn, isbn, etc.)"
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "s",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Start position"
          },
          {
            "name": "p",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page length"
          }
        ],
        "responses": {
          "200": {
            "description": "Metadata search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/meta/v1/json": {
      "get": {
        "operationId": "searchMetaV1",
        "summary": "Search metadata (v1)",
        "description": "Initial metadata search endpoint for retrieving essential metadata.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "s",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "p",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Metadata search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/metadata/json": {
      "get": {
        "operationId": "searchLegacyMetadata",
        "summary": "Search metadata (legacy)",
        "description": "Legacy metadata endpoint. New users are encouraged to use meta/v1 or meta/v2.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "s",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "p",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Metadata results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResultResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Springer Nature API key"
      }
    },
    "schemas": {
      "ApiResultResponse": {
        "type": "object",
        "properties": {
          "apiMessage": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "result": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResultMeta"
            }
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Record"
            }
          }
        }
      },
      "ResultMeta": {
        "type": "object",
        "properties": {
          "total": {
            "type": "string"
          },
          "start": {
            "type": "string"
          },
          "pageLength": {
            "type": "string"
          },
          "recordsDisplayed": {
            "type": "string"
          }
        }
      },
      "Record": {
        "type": "object",
        "properties": {
          "contentType": {
            "type": "string"
          },
          "identifier": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "url": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "format": {
                  "type": "string"
                },
                "platform": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
          "title": {
            "type": "string"
          },
          "creators": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "creator": {
                  "type": "string"
                }
              }
            }
          },
          "publicationName": {
            "type": "string"
          },
          "doi": {
            "type": "string"
          },
          "publicationDate": {
            "type": "string"
          },
          "abstract": {
            "type": "string"
          }
        }
      }
    }
  }
}