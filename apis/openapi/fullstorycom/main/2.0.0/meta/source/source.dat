{
  "openapi": "3.0.3",
  "info": {
    "title": "FullStory Server API",
    "description": "The FullStory Server API allows you to create and manage users and events for digital experience analytics. It supports creating individual and batch users and events, retrieving user details, and deleting users.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://developer.fullstory.com"
  },
  "servers": [
    {
      "url": "https://api.fullstory.com",
      "description": "Production API (automatically routed to correct regional data center based on API key prefix)"
    }
  ],
  "paths": {
    "/v2/users": {
      "post": {
        "operationId": "createOrUpdateUser",
        "summary": "Create or update a user",
        "description": "Creates or updates a user with the specified details. This is an upsert operation and is idempotent. The user will not appear in search/analytics until activity is associated.",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created or updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid user data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listUsers",
        "summary": "List users",
        "description": "Retrieve a list of users matching the supplied filter criteria.",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "uid",
            "in": "query",
            "description": "Filter by application-specific user ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "description": "Filter by email address",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/UserResponse"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid filter parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteUserByUid",
        "summary": "Delete a user by UID",
        "description": "Delete a user record identified by the uid query parameter.",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "uid",
            "in": "query",
            "required": true,
            "description": "The application-specific user identifier to delete",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v2/users/{id}": {
      "get": {
        "operationId": "getUserById",
        "summary": "Get a user by FullStory ID",
        "description": "Retrieve details for a single user by their FullStory-generated ID.",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "FullStory-generated user identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteUserById",
        "summary": "Delete a user by FullStory ID",
        "description": "Delete a user record identified by the FullStory-generated ID.",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "FullStory-generated user identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted successfully"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "User not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v2/users/batch": {
      "post": {
        "operationId": "batchCreateOrUpdateUsers",
        "summary": "Batch create or update users",
        "description": "Create or update multiple users in a single request.",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchCreateUsersRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Users created or updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/UserResponse"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid user data in batch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v2/events": {
      "post": {
        "operationId": "createEvent",
        "summary": "Create an event",
        "description": "Creates one event with the specified details. Events can be associated with a user by uid or session by session_id.",
        "tags": ["Events"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEventRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid event data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v2/events/batch": {
      "post": {
        "operationId": "batchCreateEvents",
        "summary": "Batch create events",
        "description": "Batch import multiple events in a single request.",
        "tags": ["Events"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BatchCreateEventsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Events created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/EventResponse"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid event data in batch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key in format: Basic <data_center>.<token>. Data center prefix is 'na1' for North America or 'eu1' for Europe."
      }
    },
    "schemas": {
      "CreateUserRequest": {
        "type": "object",
        "required": ["uid"],
        "properties": {
          "uid": {
            "type": "string",
            "description": "Application-specific unique user identifier"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address (used for searchability in FullStory)"
          },
          "display_name": {
            "type": "string",
            "description": "User display name shown in FullStory UI"
          },
          "properties": {
            "type": "object",
            "description": "Custom properties for the user. Types are inferred from values or declared via the optional schema field.",
            "additionalProperties": true
          },
          "schema": {
            "type": "object",
            "description": "Optional schema declaration for custom property types to override type inference",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Property data type (e.g., str, int, real, date, bool)"
                }
              }
            }
          }
        }
      },
      "BatchCreateUsersRequest": {
        "type": "object",
        "required": ["requests"],
        "properties": {
          "requests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateUserRequest"
            },
            "description": "Array of user creation/update requests"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "FullStory-generated user identifier"
          },
          "uid": {
            "type": "string",
            "description": "Application-specific user identifier"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email"
          },
          "display_name": {
            "type": "string",
            "description": "User display name"
          },
          "app_url": {
            "type": "string",
            "format": "uri",
            "description": "Deep link to the user's profile card in the FullStory app"
          },
          "properties": {
            "type": "object",
            "description": "Custom properties set on the user",
            "additionalProperties": true
          }
        }
      },
      "CreateEventRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Event name (used for searching and filtering in FullStory)"
          },
          "uid": {
            "type": "string",
            "description": "Application-specific user ID to associate the event with"
          },
          "session_id": {
            "type": "string",
            "description": "Session ID to associate the event with"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp in ISO 8601 format. Defaults to current time if omitted."
          },
          "properties": {
            "type": "object",
            "description": "Custom event properties",
            "additionalProperties": true
          },
          "schema": {
            "type": "object",
            "description": "Optional schema declaration for custom property types",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Property data type (e.g., str, int, real, date, bool)"
                }
              }
            }
          }
        }
      },
      "BatchCreateEventsRequest": {
        "type": "object",
        "required": ["requests"],
        "properties": {
          "requests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateEventRequest"
            },
            "description": "Array of event creation requests"
          }
        }
      },
      "EventResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Event name"
          },
          "uid": {
            "type": "string",
            "description": "Associated user ID"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "code": {
            "type": "string",
            "description": "Machine-readable error code"
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}