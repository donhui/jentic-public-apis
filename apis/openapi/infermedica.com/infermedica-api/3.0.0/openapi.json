            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MedicalConcept" }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/risk_factors/{id}": {
      "get": {
        "operationId": "getRiskFactor",
        "summary": "Get a specific risk factor",
        "description": "Retrieve details for a specific risk factor by its ID.",
        "tags": ["Concepts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Risk factor identifier (e.g., p_13).",
            "schema": { "type": "string" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "responses": {
          "200": {
            "description": "Risk factor details.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MedicalConcept" }
