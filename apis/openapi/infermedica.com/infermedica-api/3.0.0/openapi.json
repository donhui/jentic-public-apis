        "responses": {
          "200": {
            "description": "List of lab tests.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MedicalConcept" }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/lab_tests/{id}": {
      "get": {
        "operationId": "getLabTest",
        "summary": "Get a specific lab test",
        "description": "Retrieve details for a specific lab test by its ID.",
        "tags": ["Concepts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Lab test identifier (e.g., lt_100).",
            "schema": { "type": "string" }
          },
          {
            "name": "Model",
            "in": "header",
