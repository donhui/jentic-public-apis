{
  "openapi": "3.0.3",
  "info": {
    "title": "Infermedica API",
    "description": "The Infermedica API provides AI-powered symptom checking, medical diagnosis, and patient triage capabilities. It allows developers to build healthcare applications that can assess symptoms, suggest possible conditions, conduct diagnostic interviews, and triage patients to the appropriate level of care.",
    "version": "3.0.0",
    "contact": {
      "name": "Infermedica Support",
      "url": "https://developer.infermedica.com"
    },
    "x-jentic-source-url": "https://developer.infermedica.com/docs/"
  },
  "servers": [
    {
      "url": "https://api.infermedica.com/v3",
      "description": "Infermedica API v3 Production"
    }
  ],
  "security": [
    {
      "AppIdAppKey": []
    }
  ],
  "tags": [
    {
      "name": "Diagnosis",
      "description": "Core diagnostic interview and condition assessment"
    },
    {
      "name": "Triage",
      "description": "Patient triage and urgency assessment"
    },
    {
      "name": "NLP",
      "description": "Natural language processing for medical text"
    },
    {
      "name": "Concepts",
      "description": "Medical concept database queries"
    },
    {
      "name": "Info",
      "description": "API and model information"
    },
    {
      "name": "Suggest",
      "description": "Symptom and evidence suggestions"
    },
    {
      "name": "Explain",
      "description": "Diagnosis explanation"
    },
    {
      "name": "Red Flags",
      "description": "Emergency symptom detection"
    }
  ],
  "paths": {
    "/info": {
      "get": {
        "operationId": "getModelInfo",
        "summary": "Get model information",
        "description": "Returns details about the current medical model, including last update date and counts of conditions, symptoms, and risk factors.",
        "tags": ["Info"],
        "parameters": [
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier (e.g., infermedica-en, infermedica-de).",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "responses": {
          "200": {
            "description": "Model information.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ModelInfo" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/diagnosis": {
      "post": {
        "operationId": "runDiagnosis",
        "summary": "Run diagnostic interview step",
        "description": "Core diagnostic endpoint. Accepts patient demographics and evidence (symptoms, risk factors) and returns possible conditions with probabilities and the next interview question. The API is stateless; each request must include all previously collected evidence.",
        "tags": ["Diagnosis"],
        "parameters": [
          {
            "name": "Interview-Id",
            "in": "header",
            "required": true,
            "description": "Unique interview session identifier (UUID format).",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          },
          {
            "name": "Dev-Mode",
            "in": "header",
            "description": "Set to true to exclude request from analytics.",
            "schema": { "type": "string", "enum": ["true", "false"] }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DiagnosisRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Diagnosis result with conditions and next question.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DiagnosisResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "405": { "$ref": "#/components/responses/MethodNotAllowed" }
        }
      }
    },
    "/triage": {
      "post": {
        "operationId": "runTriage",
        "summary": "Assess patient triage level",
        "description": "Categorizes the patient case into a triage level based on symptom severity and condition likelihood. Returns one of five urgency levels from emergency_ambulance to self_care.",
        "tags": ["Triage"],
        "parameters": [
          {
            "name": "Interview-Id",
            "in": "header",
            "required": true,
            "description": "Unique interview session identifier (UUID format).",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DiagnosisRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Triage assessment result.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TriageResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/parse": {
      "post": {
        "operationId": "parseText",
        "summary": "Parse medical text using NLP",
        "description": "Analyzes free-text medical input and extracts mentions of symptoms, risk factors, and other medical concepts. Returns structured evidence that can be used in diagnosis requests.",
        "tags": ["NLP"],
        "parameters": [
          {
            "name": "Interview-Id",
            "in": "header",
            "required": true,
            "description": "Unique interview session identifier.",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ParseRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parsed medical concepts from text.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ParseResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/suggest": {
      "post": {
        "operationId": "suggestSymptoms",
        "summary": "Suggest related symptoms",
        "description": "Based on provided evidence, suggests additional symptoms that may be relevant for the patient to report. Useful for guided symptom input.",
        "tags": ["Suggest"],
        "parameters": [
          {
            "name": "Interview-Id",
            "in": "header",
            "required": true,
            "description": "Unique interview session identifier.",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DiagnosisRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of suggested symptoms.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/SuggestedSymptom" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/explain": {
      "post": {
        "operationId": "explainDiagnosis",
        "summary": "Explain diagnosis reasoning",
        "description": "Provides an explanation of why a specific condition was suggested, including which evidence supports or contradicts it.",
        "tags": ["Explain"],
        "parameters": [
          {
            "name": "Interview-Id",
            "in": "header",
            "required": true,
            "description": "Unique interview session identifier.",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ExplainRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Explanation of the diagnosis.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ExplainResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/red_flags": {
      "post": {
        "operationId": "getRedFlags",
        "summary": "Check for emergency red flags",
        "description": "Evaluates patient evidence for emergency symptoms (red flags) that may require immediate medical attention.",
        "tags": ["Red Flags"],
        "parameters": [
          {
            "name": "Interview-Id",
            "in": "header",
            "required": true,
            "description": "Unique interview session identifier.",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DiagnosisRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Red flag assessment.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/RedFlag" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "searchMedicalConcepts",
        "summary": "Search medical concepts",
        "description": "Search for symptoms, conditions, risk factors, and lab tests by name or keyword.",
        "tags": ["Concepts"],
        "parameters": [
          {
            "name": "phrase",
            "in": "query",
            "required": true,
            "description": "Search phrase.",
            "schema": { "type": "string" }
          },
          {
            "name": "sex",
            "in": "query",
            "description": "Filter results by patient sex.",
            "schema": { "type": "string", "enum": ["male", "female"] }
          },
          {
            "name": "age.value",
            "in": "query",
            "description": "Patient age value for filtering.",
            "schema": { "type": "integer" }
          },
          {
            "name": "age.unit",
            "in": "query",
            "description": "Patient age unit.",
            "schema": { "type": "string", "enum": ["year", "month"], "default": "year" }
          },
          {
            "name": "max_results",
            "in": "query",
            "description": "Maximum number of results.",
            "schema": { "type": "integer", "default": 8 }
          },
          {
            "name": "types",
            "in": "query",
            "description": "Comma-separated list of concept types to include.",
            "schema": { "type": "string" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MedicalConcept" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/symptoms": {
      "get": {
        "operationId": "listSymptoms",
        "summary": "List all symptoms",
        "description": "Retrieve a list of all available symptoms in the medical model.",
        "tags": ["Concepts"],
        "parameters": [
          {
            "name": "age.value",
            "in": "query",
            "description": "Filter symptoms applicable to this age.",
            "schema": { "type": "integer" }
          },
          {
            "name": "age.unit",
            "in": "query",
            "description": "Age unit.",
            "schema": { "type": "string", "enum": ["year", "month"], "default": "year" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of symptoms.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/MedicalConcept" }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/symptoms/{id}": {
      "get": {
        "operationId": "getSymptom",
        "summary": "Get a specific symptom",
        "description": "Retrieve details for a specific symptom by its ID.",
        "tags": ["Concepts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Symptom identifier (e.g., s_47).",
            "schema": { "type": "string" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "responses": {
          "200": {
            "description": "Symptom details.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MedicalConcept" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/conditions": {
      "get": {
        "operationId": "listConditions",
        "summary": "List all conditions",
        "description": "Retrieve a list of all available medical conditions in the model.",
        "tags": ["Concepts"],
        "parameters": [
          {
            "name": "age.value",
            "in": "query",
            "description": "Filter conditions applicable to this age.",
            "schema": { "type": "integer" }
          },
          {
            "name": "age.unit",
            "in": "query",
            "description": "Age unit.",
            "schema": { "type": "string", "enum": ["year", "month"], "default": "year" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of conditions.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ConditionDetail" }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/conditions/{id}": {
      "get": {
        "operationId": "getCondition",
        "summary": "Get a specific condition",
        "description": "Retrieve details for a specific medical condition by its ID.",
        "tags": ["Concepts"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Condition identifier (e.g., c_87).",
            "schema": { "type": "string" }
          },
          {
            "name": "Model",
            "in": "header",
            "description": "Language model identifier.",
            "schema": { "type": "string", "default": "infermedica-en" }
          }
        ],
        "responses": {
          "200": {
            "description": "Condition details.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConditionDetail" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
