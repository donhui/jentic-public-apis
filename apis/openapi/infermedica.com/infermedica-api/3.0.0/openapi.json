  },
  "components": {
    "securitySchemes": {
      "AppIdAppKey": {
        "type": "apiKey",
        "in": "header",
        "name": "App-Id",
        "description": "Application ID and App-Key headers are both required. App-Id identifies your application, App-Key authenticates it."
      },
      "AppKey": {
        "type": "apiKey",
        "in": "header",
        "name": "App-Key",
        "description": "Application authentication key. Must be provided alongside App-Id."
      }
    },
    "schemas": {
      "DiagnosisRequest": {
        "type": "object",
        "required": ["sex", "age"],
        "description": "Request body for diagnosis, triage, suggest, and red_flags endpoints.",
        "properties": {
          "sex": {
            "type": "string",
            "enum": ["male", "female"],
            "description": "Patient biological sex."
          },
          "age": {
            "type": "object",
            "required": ["value"],
            "description": "Patient age.",
            "properties": {
              "value": {
                "type": "integer",
                "minimum": 0,
                "maximum": 1560,
                "description": "Age value (1-130 years or 0-1560 months)."
              },
              "unit": {
                "type": "string",
                "enum": ["year", "month"],
                "default": "year",
                "description": "Age unit."
              }
            }
          },
          "evidence": {
            "type": "array",
            "description": "Array of observed medical evidence.",
            "items": { "$ref": "#/components/schemas/Evidence" }
          },
          "extras": {
            "type": "object",
            "description": "Additional configuration options.",
            "properties": {
              "enable_symptom_duration": {
                "type": "boolean",
                "description": "Enable symptom duration tracking."
              },
              "interview_mode": {
                "type": "string",
                "enum": ["default", "triage"],
                "description": "Interview mode."
              },
              "enable_explanations": {
                "type": "boolean",
                "description": "Include contextual explanations."
              },
              "enable_third_person_questions": {
                "type": "boolean",
                "description": "Use third-person phrasing in questions."
              },
              "include_condition_details": {
                "type": "boolean",
                "description": "Include full condition metadata."
              },
              "disable_intimate_content": {
                "type": "boolean",
                "description": "Exclude intimate/sensitive topics."
              },
              "disable_groups": {
                "type": "boolean",
                "description": "Return only single-type questions."
              }
            }
          }
        }
      },
      "Evidence": {
        "type": "object",
        "required": ["id", "choice_id"],
        "description": "A piece of medical evidence (symptom, risk factor, or lab test observation).",
        "properties": {
          "id": {
            "type": "string",
            "description": "Medical concept identifier (e.g., s_47 for symptoms, p_13 for risk factors, lt_100 for lab tests)."
          },
          "choice_id": {
            "type": "string",
            "enum": ["present", "absent", "unknown"],
            "description": "Whether the evidence is present, absent, or unknown."
          },
          "source": {
            "type": "string",
            "enum": ["initial", "suggest", "predefined", "red_flags"],
            "description": "Source of the evidence. 'initial' marks user-reported symptoms."
          },
          "duration": {
            "type": "object",
            "description": "Duration of the symptom.",
            "properties": {
              "value": { "type": "integer" },
              "unit": { "type": "string", "enum": ["day", "week", "month", "year"] }
            }
          }
        }
      },
      "DiagnosisResponse": {
        "type": "object",
        "description": "Response from the diagnosis endpoint.",
        "properties": {
          "question": { "$ref": "#/components/schemas/Question" },
          "conditions": {
            "type": "array",
            "description": "Possible conditions sorted by probability (highest first).",
            "items": { "$ref": "#/components/schemas/ConditionProbability" }
          },
          "should_stop": {
            "type": "boolean",
            "description": "Whether the interview should stop (sufficient evidence collected)."
          },
          "has_emergency_evidence": {
            "type": "boolean",
            "description": "Whether emergency symptoms were detected."
          },
          "extras": {
            "type": "object",
            "description": "Additional experimental attributes."
          }
        }
      },
      "Question": {
        "type": "object",
        "description": "An interview question to ask the patient.",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["single", "group_single", "group_multiple", "duration"],
            "description": "Question type determining how answers should be collected."
          },
          "text": {
            "type": "string",
            "description": "The question text to display."
          },
          "items": {
            "type": "array",
            "description": "Evidence items related to this question.",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "choices": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "enum": ["present", "absent", "unknown"] },
                      "label": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "extras": { "type": "object" }
        }
      },
      "ConditionProbability": {
        "type": "object",
        "description": "A condition with its assessed probability.",
        "properties": {
          "id": { "type": "string", "description": "Condition identifier." },
          "name": { "type": "string", "description": "Medical name of the condition." },
          "common_name": { "type": "string", "description": "Patient-friendly name." },
          "probability": {
            "type": "number",
            "format": "double",
            "minimum": 0,
            "maximum": 1,
            "description": "Probability score (0.0 to 1.0)."
          }
        }
      },
      "TriageResponse": {
        "type": "object",
        "description": "Triage assessment result.",
        "properties": {
          "triage_level": {
            "type": "string",
            "enum": ["emergency_ambulance", "emergency", "consultation_24", "consultation", "self_care"],
            "description": "Urgency level of the patient case."
          },
          "serious": {
            "type": "array",
            "description": "Alarming observations detected.",
            "items": { "$ref": "#/components/schemas/SeriousObservation" }
          },
          "root_cause": {
            "type": "string",
            "description": "Rationale for the triage decision."
          }
        }
      },
      "SeriousObservation": {
        "type": "object",
        "description": "A serious observation that influenced the triage level.",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "common_name": { "type": "string" },
          "seriousness": {
            "type": "string",
            "enum": ["serious", "emergency", "emergency_ambulance"],
            "description": "Level of seriousness."
          }
        }
      },
      "ParseRequest": {
        "type": "object",
        "required": ["text"],
        "description": "Request body for the NLP parse endpoint.",
        "properties": {
          "text": {
            "type": "string",
            "description": "Free-text medical input to parse (e.g., 'I have a headache and fever')."
          },
          "age": {
            "type": "object",
            "properties": {
              "value": { "type": "integer" },
              "unit": { "type": "string", "enum": ["year", "month"] }
            }
          },
          "sex": {
            "type": "string",
            "enum": ["male", "female"]
          },
          "include_tokens": {
            "type": "boolean",
            "description": "Include tokenized text in response."
          },
          "correct_spelling": {
            "type": "boolean",
            "description": "Enable spelling correction."
          }
        }
      },
      "ParseResponse": {
        "type": "object",
        "description": "Result of NLP text parsing.",
        "properties": {
          "mentions": {
            "type": "array",
            "description": "Medical concepts identified in the text.",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string", "description": "Medical concept ID." },
                "name": { "type": "string", "description": "Concept name." },
                "common_name": { "type": "string" },
                "orth": { "type": "string", "description": "Original text span." },
                "choice_id": { "type": "string", "enum": ["present", "absent", "unknown"] },
                "head_position": { "type": "integer" },
                "positions": {
                  "type": "array",
                  "items": { "type": "integer" }
                }
              }
            }
          },
          "obvious": {
            "type": "boolean",
            "description": "Whether the text is obvious enough for automated processing."
          },
          "tokens": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "ExplainRequest": {
        "type": "object",
        "required": ["sex", "age", "target"],
        "description": "Request body for the explain endpoint.",
        "properties": {
          "sex": { "type": "string", "enum": ["male", "female"] },
          "age": {
            "type": "object",
            "properties": {
              "value": { "type": "integer" },
              "unit": { "type": "string", "enum": ["year", "month"] }
            }
          },
          "evidence": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Evidence" }
          },
          "target": {
            "type": "string",
            "description": "Condition ID to explain (e.g., c_87)."
          }
        }
      },
      "ExplainResponse": {
        "type": "object",
        "description": "Explanation of why a condition was suggested.",
        "properties": {
          "supporting_evidence": {
            "type": "array",
            "description": "Evidence supporting the condition.",
            "items": { "$ref": "#/components/schemas/EvidenceExplanation" }
          },
          "conflicting_evidence": {
            "type": "array",
            "description": "Evidence conflicting with the condition.",
            "items": { "$ref": "#/components/schemas/EvidenceExplanation" }
          },
          "unconfirmed_evidence": {
            "type": "array",
            "description": "Evidence not yet confirmed.",
            "items": { "$ref": "#/components/schemas/EvidenceExplanation" }
          }
        }
      },
      "EvidenceExplanation": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "common_name": { "type": "string" }
        }
      },
      "RedFlag": {
        "type": "object",
        "description": "An emergency red flag symptom.",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "common_name": { "type": "string" },
          "seriousness": { "type": "string" }
        }
      },
      "SuggestedSymptom": {
        "type": "object",
        "description": "A suggested symptom for the patient to evaluate.",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "common_name": { "type": "string" }
        }
      },
      "MedicalConcept": {
        "type": "object",
        "description": "A medical concept (symptom, risk factor, or lab test).",
        "properties": {
          "id": { "type": "string", "description": "Unique concept identifier." },
          "name": { "type": "string", "description": "Medical name." },
          "common_name": { "type": "string", "description": "Patient-friendly name." },
          "sex_filter": { "type": "string", "enum": ["male", "female", "both"], "description": "Sex applicability." },
          "category": { "type": "string", "description": "Category classification." },
          "children": {
            "type": "array",
            "description": "Child concepts (sub-symptoms).",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "parent_relation": { "type": "string" }
              }
            }
          },
          "image_url": { "type": "string", "format": "uri", "description": "Optional image URL." },
          "image_source": { "type": "string", "description": "Image attribution." }
        }
      },
      "ConditionDetail": {
        "type": "object",
        "description": "Detailed condition information.",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "common_name": { "type": "string" },
          "sex_filter": { "type": "string", "enum": ["male", "female", "both"] },
          "category": { "type": "string" },
          "prevalence": { "type": "string", "enum": ["very_rare", "rare", "moderate", "common"] },
          "severity": { "type": "string", "enum": ["mild", "moderate", "severe"] },
          "acuteness": { "type": "string", "enum": ["chronic", "chronic_with_exacerbations", "acute_potentially_chronic", "acute"] },
          "triage_level": { "type": "string" },
          "icd10_code": { "type": "string", "description": "ICD-10 classification code." },
          "extras": { "type": "object" }
        }
      },
      "ModelInfo": {
        "type": "object",
        "description": "Information about the current medical model.",
        "properties": {
          "updated_at": { "type": "string", "format": "date-time", "description": "Last model update timestamp." },
          "conditions_count": { "type": "integer", "description": "Number of conditions in the model." },
          "symptoms_count": { "type": "integer", "description": "Number of symptoms in the model." },
          "risk_factors_count": { "type": "integer", "description": "Number of risk factors in the model." },
          "lab_tests_count": { "type": "integer", "description": "Number of lab tests in the model." }
        }
      },
      "Error": {
        "type": "object",
        "description": "Error response.",
        "properties": {
          "message": { "type": "string", "description": "Error message." },
          "details": { "type": "object", "description": "Additional error details." }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid JSON, missing required parameters, or malformed request.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Forbidden": {
        "description": "Invalid or missing App-Id/App-Key credentials.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found or invalid URL.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "MethodNotAllowed": {
        "description": "Wrong HTTP method used for this endpoint.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  }
}
