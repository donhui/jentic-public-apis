{
  "openapi": "3.0.3",
  "servers": [
    {
      "url": "https://api.nutribot.io",
      "description": "NutriBot Production API"
    }
  ],
  "info": {
    "version": "1.0.0",
    "title": "Nutribot - Zapier API",
    "description": "Nutribot API documentation for Zapier integration",
    "x-jentic-source-url": "https://app.swaggerhub.com/apis/ALTCONNECT/Nutribot-Zapier/1.0.0"
  },
  "paths": {
    "/admin/oauth/token": {
      "post": {
        "tags": [
          "Login"
        ],
        "summary": "User login",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  },
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string"
                  }
                },
                "required": [
                  "grant_type",
                  "client_id",
                  "client_secret",
                  "username",
                  "password",
                  "scope"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ok",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "operationId": "createAuthToken"
      }
    },
    "/admin/api/account": {
      "get": {
        "tags": [
          "Account"
        ],
        "summary": "User account",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserAccountDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "operationId": "getUserAccount"
      }
    },
    "/admin/api/mc/zapier/new-customers": {
      "get": {
        "tags": [
          "Customers"
        ],
        "summary": "Get customers",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZapierCustoserListDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "operationId": "getNewCustomers"
      }
    },
    "/admin/api/mc/zapier/new-orders": {
      "get": {
        "tags": [
          "Orders"
        ],
        "summary": "Get orders",
        "parameters": [
          {
            "name": "orderStatus",
            "in": "query",
            "description": "Filter parameter or parameters selected from dropdown list in zapier trigger NEW_ORDER",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "paymentStatus",
            "in": "query",
            "description": "Filter parameter or parameters selected from dropdown list in zapier trigger NEW_ORDER",
            "required": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ZapierOrderListDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "400": {
            "description": "Bad Request"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "operationId": "getNewOrders"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header"
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "required": [
          "access_token",
          "expires_in",
          "refresh_token",
          "scope",
          "token_type"
        ],
        "properties": {
          "scope": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer"
          },
          "refresh_token": {
            "type": "string"
          },
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          }
        },
        "example": {
          "access_token": "access_token",
          "refresh_token": "refresh_token",
          "scope": "scope",
          "token_type": "token_type",
          "expires_in": 0
        }
      },
      "UserAccountDto": {
        "properties": {
          "accountOwner": {
            "type": "boolean"
          },
          "activated": {
            "type": "boolean"
          },
          "authorities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "code": {
            "type": "string"
          },
          "companyCode": {
            "type": "string"
          },
          "companyId": {
            "type": "number",
            "format": "int64"
          },
          "companyName": {
            "type": "string"
          },
          "countryCode": {
            "type": "string"
          },
          "createdBy": {
            "type": "string"
          },
