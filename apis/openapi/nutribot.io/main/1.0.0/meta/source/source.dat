            "type": "boolean"
          },
          "defaultCode": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "emailSubscription": {
            "type": "string"
          },
          "firstDayOfWeek": {
            "type": "number",
            "format": "int64"
          },
          "firstName": {
            "type": "string"
          },
          "id": {
            "type": "number",
            "format": "int64"
          },
          "langKey": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
