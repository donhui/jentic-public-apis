{
  "openapi": "3.0.3",
  "info": {
    "title": "Vuepak API",
    "version": "1.0",
    "description": "Vuepak is an AI-powered multichannel outreach platform with email, SMS, tasks, multimedia delivery, and unified analytics. This API provides access to address books, contacts, leads, and subscription management.",
    "x-jentic-source-url": "https://www.vuepak.com/docs/api_documentation.pdf"
  },
  "servers": [
    {
      "url": "https://oauth.vuepak.com",
      "description": "Vuepak OAuth / API Server"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "OAuth 2.0 authorization and token management"
    },
    {
      "name": "Address Books",
      "description": "Manage address books and subscriptions"
    },
    {
      "name": "Contacts",
      "description": "Retrieve contact information"
    },
    {
      "name": "Leads",
      "description": "Retrieve lead information"
    },
    {
      "name": "User",
      "description": "Authenticated user information"
    }
  ],
  "paths": {
    "/oauth/authorize": {
      "get": {
        "operationId": "authorizeUser",
        "summary": "Initiate OAuth 2.0 authorization",
        "description": "Redirects the user to the Vuepak authorization page to grant access.",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The OAuth client ID"
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "uri" },
            "description": "The URI to redirect to after authorization"
          },
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["code"] },
            "description": "The OAuth response type"
          },
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Requested access scopes"
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to authorization page"
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Obtain an access token",
        "description": "Exchange an authorization code for an access token.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "client_id", "client_secret", "code", "redirect_uri"],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": ["authorization_code"],
                    "description": "The grant type"
                  },
                  "client_id": {
                    "type": "string",
                    "description": "The OAuth client ID"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "The OAuth client secret"
                  },
                  "code": {
                    "type": "string",
                    "description": "The authorization code received"
                  },
                  "redirect_uri": {
                    "type": "string",
                    "format": "uri",
                    "description": "The redirect URI used in the authorization request"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token issued successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid grant or parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid client credentials",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/addressbooks": {
      "get": {
        "operationId": "listAddressBooks",
        "summary": "List address books",
        "description": "Retrieve all address books for the authenticated user.",
        "tags": ["Address Books"],
        "security": [{ "oauth2": [] }],
        "responses": {
          "200": {
            "description": "List of address books",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AddressBook" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/contacts": {
      "get": {
        "operationId": "listContacts",
        "summary": "List contacts",
        "description": "Retrieve contacts, optionally filtered by address book.",
        "tags": ["Contacts"],
        "security": [{ "oauth2": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Address book ID to filter contacts"
          }
        ],
        "responses": {
          "200": {
            "description": "List of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Contact" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/contacts/company": {
      "get": {
        "operationId": "listCompanyContacts",
        "summary": "List company contacts",
        "description": "Retrieve company-level contacts.",
        "tags": ["Contacts"],
        "security": [{ "oauth2": [] }],
        "responses": {
          "200": {
            "description": "List of company contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Contact" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/leads": {
      "get": {
        "operationId": "listLeads",
        "summary": "List leads",
        "description": "Retrieve leads, optionally filtered by address book.",
        "tags": ["Leads"],
        "security": [{ "oauth2": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Address book ID to filter leads"
          }
        ],
        "responses": {
          "200": {
            "description": "List of leads",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Lead" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/addressbooks/subscribe/{crm}": {
      "post": {
        "operationId": "subscribeToAddressBook",
        "summary": "Subscribe to an address book",
        "description": "Subscribe to a CRM address book for syncing.",
        "tags": ["Address Books"],
        "security": [{ "oauth2": [] }],
        "parameters": [
          {
            "name": "crm",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "CRM identifier to subscribe to"
          }
        ],
        "responses": {
          "200": {
            "description": "Subscription successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SubscriptionResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v1/addressbooks/unsubscribe/{crmName}": {
      "post": {
        "operationId": "unsubscribeFromAddressBook",
        "summary": "Unsubscribe from an address book",
        "description": "Unsubscribe from a CRM address book.",
        "tags": ["Address Books"],
        "security": [{ "oauth2": [] }],
        "parameters": [
          {
            "name": "crmName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "CRM name to unsubscribe from"
          }
        ],
        "responses": {
          "200": {
            "description": "Unsubscription successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SubscriptionResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user info",
        "description": "Retrieve information about the currently authenticated user.",
        "tags": ["User"],
        "security": [{ "oauth2": [] }],
        "responses": {
          "200": {
            "description": "Current user information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://www.vuepak.com/oauth/authorize",
            "tokenUrl": "https://oauth.vuepak.com/api/v1/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The access token"
          },
          "token_type": {
            "type": "string",
            "description": "Token type, typically 'Bearer'"
          },
          "expires_in": {
            "type": "integer",
            "description": "Token expiry time in seconds"
          },
          "refresh_token": {
            "type": "string",
            "description": "Token used to refresh the access token"
          }
        }
      },
      "AddressBook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Address book unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Address book name"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Contact unique identifier"
          },
          "first_name": {
            "type": "string",
            "description": "Contact first name"
          },
          "last_name": {
            "type": "string",
            "description": "Contact last name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email address"
          },
          "phone": {
            "type": "string",
            "description": "Contact phone number"
          },
          "company": {
            "type": "string",
            "description": "Contact company name"
          }
        }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Lead unique identifier"
          },
          "first_name": {
            "type": "string",
            "description": "Lead first name"
          },
          "last_name": {
            "type": "string",
            "description": "Lead last name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Lead email address"
          },
          "phone": {
            "type": "string",
            "description": "Lead phone number"
          },
          "company": {
            "type": "string",
            "description": "Lead company name"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User unique identifier"
          },
          "name": {
            "type": "string",
            "description": "User full name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          }
        }
      },
      "SubscriptionResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the operation was successful"
          },
          "message": {
            "type": "string",
            "description": "Response message"
          }
        }
      }
    }
  }
}