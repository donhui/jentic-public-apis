            "description": "Successful payment",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transactionId": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  },
                  "example": {
                    "transactionId": "TR3453",
                    "status": "Booked Successfully"
                  }
                }
              }
            }
          }
        }
      }
    },
