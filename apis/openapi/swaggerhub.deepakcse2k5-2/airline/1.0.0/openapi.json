  "paths": {
    "/CheckRegistered": {
      "get": {
        "description": "Checks if the customer is registered",
        "operationId": "check_registered",
        "parameters": [
          {
            "name": "mobile_number",
            "in": "query",
            "description": "mobile number of the customer",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response of Check Registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "customer_name": {
                      "type": "string"
                    }
                  },
                  "example": [
                    {
                      "customerName": "Gourav"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/SearchFlight": {
      "get": {
        "description": "search the available flights",
        "operationId": "search_flight",
        "parameters": [
          {
            "name": "origin",
            "in": "query",
            "description": "origin of the flight",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "destination",
            "in": "query",
            "required": true,
            "description": "destination of the flight",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "The departure date",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "mobile",
            "in": "query",
            "required": true,
            "description": "Mobile Number of the customer",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "list of available flights",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "flightNumber": {
                        "type": "string"
                      },
                      "departureTime": {
                        "type": "string"
                      },
                      "arrivalTime": {
                        "type": "string"
                      },
                      "price": {
                        "type": "number"
                      },
                      "availableSeats": {
                        "type": "integer"
                      }
                    }
                  }
                },
                "example": [
                  {
                    "flightNumber": "A1234",
                    "departureTime": "10:00 AM",
                    "arrivalTime": "12:00 PM",
                    "price": 200,
                    "availableSeats": 50
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/BookFlight": {
      "post": {
        "summary": "Book a flight",
        "operationId": "book_flight",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "flightNumber",
                  "passengerName",
                  "passportNumber",
                  "seatNumber"
                ],
                "properties": {
                  "flightNumber": {
                    "type": "string"
                  },
                  "passengerName": {
                    "type": "string"
                  },
                  "passportNumber": {
                    "type": "string"
                  },
                  "seatNumber": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful flight booking",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bookingId": {
                      "type": "string"
                    }
                  },
                  "example": [
                    {
                      "bookingId": "BK234"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
