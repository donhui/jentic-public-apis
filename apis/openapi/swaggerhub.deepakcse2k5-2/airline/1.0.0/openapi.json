        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bookingId": {
                    "type": "string"
                  },
                  "creditCardNumber": {
                    "type": "string"
                  },
                  "cvv": {
                    "type": "string"
                  },
                  "expirationDate": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
