              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "Get List of Countries & States to be used in Address Field",
        "tags": [
          "Location"
        ]
      }
    },
    "/api/mod1/public/financial-info": {
      "get": {
        "operationId": "FinancialInfoController_getFinancialInfo",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetFinancialInfoValuesForFormDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "Values for Financial Info Field",
        "tags": [
          "Financial Info"
        ]
      }
    }
  },
  "info": {
