{
  "openapi": "3.0.3",
  "paths": {
    "/api/mod1/public/form": {
      "get": {
        "operationId": "FormController_find",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Number of items per page",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "sort",
            "required": false,
            "in": "query",
            "description": "Sort Parameters",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "name:ASC",
                  "name:DESC",
                  "createdAt:ASC",
                  "createdAt:DESC",
                  "updatedAt:ASC",
                  "updatedAt:DESC"
                ]
              }
            }
          },
          {
            "name": "filter.createdAt",
            "required": false,
            "in": "query",
            "description": "Filter by createdAt query param.<br>**Format:** filter.createdAt=OPERATION:VALUE<br>**Example**: filter.name=$eq:John<br><br>**Available Operations:**<br><br>$btw,$gt,$gte,$lt,$lte,$eq",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter.updatedAt",
            "required": false,
            "in": "query",
            "description": "Filter by updatedAt query param.<br>**Format:** filter.updatedAt=OPERATION:VALUE<br>**Example**: filter.name=$eq:John<br><br>**Available Operations:**<br><br>$btw,$gt,$gte,$lt,$lte,$eq",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublishedFormsResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "Get all Forms",
        "tags": [
          "Forms"
        ]
      }
    },
    "/api/mod1/public/form/{id}": {
      "get": {
        "operationId": "FormController_findOne",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FormResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Form is password protected or incorrect password"
          },
          "404": {
            "description": "Form not found"
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "Get a Form by its ID",
        "tags": [
          "Forms"
        ]
      }
    },
    "/api/mod1/public/form/{id}/submit": {
      "post": {
        "operationId": "FormController_submitForm",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitFormDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Form submitted successfully"
          },
          "400": {
            "description": "Field validation failed"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Form is not published"
          },
          "404": {
            "description": "Form, config, category, or field not found"
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "Submit a Form",
        "tags": [
          "Forms"
        ]
      }
    },
    "/api/mod1/public/file": {
      "post": {
        "operationId": "FileController_uploadTempFile",
        "parameters": [],
        "requestBody": {
          "required": true,
          "description": "List of Files",
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/FilesUploadDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FilesUploadResponseDto"
                  }
                }
              }
            }
          },
          "400": {
            "description": "File extension could not be determined"
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        },
        "security": [
          {
            "x-api-key": []
          }
        ],
        "summary": "File Upload Endpoint for File Attachment Fields",
        "tags": [
          "File"
        ]
      }
    },
    "/api/mod1/public/location": {
      "get": {
        "operationId": "LocationController_getAllLocationData",
        "parameters": [],
