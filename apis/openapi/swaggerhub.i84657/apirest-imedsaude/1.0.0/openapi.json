{
    "openapi": "3.0.0",
    "info": {
        "description": "Documentação da API REST fornecida pela IMED Saúde.",
        "version": "1.0.0",
        "title": "API Rest - IMED Saúde",
        "contact": {
            "email": "sistemas@clinicaimed.com.br"
        },
        "license": {
            "name": "Clínica IMED",
            "url": "http://clinicaimed.com.br"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/i84657/APIREST_IMEDSAUDE/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "Pacientes Cadastrados",
            "description": "Busca de dados dos pacientes"
        }
    ],
    "paths": {
        "/confirmation": {
            "put": {
                "tags": [
                    "Confirmação"
                ],
                "summary": "Confirma um paciente na agenda do Simah",
                "description": "Realiza a confirmação de um paciente na agenda do Simah (moderna) desde que os dados estejam compatíveis com os dados da agenda. pnome = Nome fornecido; aghora = Hora em que o paciente está agendado conforme fornecido (YYY-MM-DD hh:mm:ss.000); time = data e hora atual conforme exemplo abaixo (MM/DD/YYYY hh:mm:ss)",
                "operationId": "confirmappointment",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Confirm"
                            }
                        },
                        "application/xml": {
                            "schema": {
                                "$ref": "#/components/schemas/Confirm"
                            }
                        }
                    },
                    "description": "Paciente a ser confirmado na agenda",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "{{time}}"
                    },
                    "400": {
                        "description": "A solicitação não pôde ser concluída"
                    }
                }
            }
        },
        "/srchphone": {
            "get": {
                "tags": [
                    "Cadastros"
                ],
                "summary": "Retorna dados dos pacientes por numero de telefone",
                "description": "A API retorna dados dos pacientes que estiverem cadastrados com o número de telefone informado. Caso haja mais de um cadastro no mesmo número os resultados serão concatenados.",
                "operationId": "getpacbyphone",
                "parameters": [
                    {
                        "name": "phoneprefix",
                        "in": "header",
                        "description": "Prefixo de dois digitos do número. Ex: '15'.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "phonenumber",
                        "in": "header",
                        "description": "Número de telefone de 9 digitos a ser buscado.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Requisição bem sucedida",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Erro não específicado"
                    }
                }
            }
        },
        "/srchpac": {
            "get": {
                "tags": [
                    "Cadastros"
                ],
                "summary": "Retorna dados dos pacientes por numero de cpf",
                "description": "A API retorna dados do paciente cadastrado no numero de CPF informado",
                "operationId": "getpacbycpf",
                "parameters": [
                    {
                        "name": "paccpf",
                        "in": "header",
                        "description": "Número de CPF do paciente com 11 digitos e sem caracteres especiais ou letras.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Requisição bem sucedida",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Erro não específicado"
                    }
                }
            }
        },
        "/histpac": {
            "get": {
                "tags": [
                    "Cadastros"
                ],
                "summary": "Retorna os últimos 10 registros do histórico do paciente pelo numero de cpf",
                "description": "A API retorna dados do paciente cadastrado no numero de CPF informado",
                "operationId": "gethistbycpf",
                "parameters": [
                    {
                        "name": "paccpf",
                        "in": "header",
                        "description": "Número de CPF do paciente com 11 digitos e sem caracteres especiais ou letras.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Requisição bem sucedida",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Erro não específicado"
                    }
                }
            }
        },
        "/itemvlr": {
            "get": {
                "tags": [
                    "Cadastros"
                ],
                "summary": "Retorna o preço de um determinado item através do ID",
                "description": "A API retorna o preço do item em reais (R$) configurado para o convênio 'Particular' através do ID informado.",
                "operationId": "getpricebyid",
                "parameters": [
                    {
                        "name": "item",
                        "in": "header",
                        "description": "Número de ID do item",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Requisição bem sucedida",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Erro não específicado"
                    }
                }
            }
        }
    },
    "security": [
        {
            "basicAuth": []
        }
    ],
    "servers": [
        {
            "url": "//connectt.ddns.me:3000/api"
        }
    ],
    "components": {
        "securitySchemes": {
            "basicAuth": {
                "type": "http",
                "scheme": "basic"
            }
        },
        "schemas": {
            "Confirm": {
                "type": "object",
                "required": [
                    "pnome",
                    "time"
                ],
                "properties": {
                    "pnome": {
                        "type": "string",
                        "example": "MARIA DE OLIVEIRA"
                    },
                    "aghora": {
                        "type": "string",
                        "example": "2024-08-03 14:00:00.000"
                    },
                    "time": {
                        "type": "string",
                        "example": "08/01/2024 14:00:00"
                    }
                }
            }
        }
    }
}