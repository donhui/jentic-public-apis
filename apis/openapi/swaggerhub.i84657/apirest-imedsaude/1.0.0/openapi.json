{
  "swagger": "2.0",
  "info": {
    "description": "Documenta\u00e7\u00e3o da API REST fornecida pela IMED Sa\u00fade.",
    "version": "1.0.0",
    "title": "API Rest - IMED Sa\u00fade",
    "contact": {
      "email": "sistemas@clinicaimed.com.br"
    },
    "license": {
      "name": "Cl\u00ednica IMED",
      "url": "http://clinicaimed.com.br"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/i84657/APIREST_IMEDSAUDE/1.0.0/swagger.json"
  },
  "host": "connectt.ddns.me:3000",
  "basePath": "/api",
  "tags": [
    {
      "name": "Pacientes Cadastrados",
      "description": "Busca de dados dos pacientes"
    }
  ],
  "paths": {
    "/confirmation": {
      "put": {
        "tags": [
          "Confirma\u00e7\u00e3o"
        ],
        "summary": "Confirma um paciente na agenda do Simah",
        "description": "Realiza a confirma\u00e7\u00e3o de um paciente na agenda do Simah (moderna) desde que os dados estejam compat\u00edveis com os dados da agenda. pnome = Nome fornecido; aghora = Hora em que o paciente est\u00e1 agendado conforme fornecido (YYY-MM-DD hh:mm:ss.000); time = data e hora atual conforme exemplo abaixo (MM/DD/YYYY hh:mm:ss)",
        "operationId": "confirmappointment",
        "consumes": [
          "application/json",
          "application/xml"
        ],
        "produces": [
          "application/json",
          "application/xml"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Paciente a ser confirmado na agenda",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Confirm"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "{{time}}"
          },
          "400": {
            "description": "A solicita\u00e7\u00e3o n\u00e3o p\u00f4de ser conclu\u00edda"
          }
        }
      }
    },
    "/srchphone": {
      "get": {
        "tags": [
          "Cadastros"
        ],
        "summary": "Retorna dados dos pacientes por numero de telefone",
        "description": "A API retorna dados dos pacientes que estiverem cadastrados com o n\u00famero de telefone informado. Caso haja mais de um cadastro no mesmo n\u00famero os resultados ser\u00e3o concatenados.",
        "operationId": "getpacbyphone",
        "parameters": [
          {
            "name": "phoneprefix",
            "in": "header",
            "description": "Prefixo de dois digitos do n\u00famero. Ex: '15'.",
            "required": true,
            "type": "string"
          },
          {
            "name": "phonenumber",
            "in": "header",
            "description": "N\u00famero de telefone de 9 digitos a ser buscado.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Requisi\u00e7\u00e3o bem sucedida",
            "schema": {
              "type": "string"
            }
          },
          "400": {
            "description": "Erro n\u00e3o espec\u00edficado"
          }
        }
      }
    },
    "/srchpac": {
      "get": {
        "tags": [
          "Cadastros"
        ],
        "summary": "Retorna dados dos pacientes por numero de cpf",
        "description": "A API retorna dados do paciente cadastrado no numero de CPF informado",
        "operationId": "getpacbycpf",
        "parameters": [
          {
            "name": "paccpf",
            "in": "header",
            "description": "N\u00famero de CPF do paciente com 11 digitos e sem caracteres especiais ou letras.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Requisi\u00e7\u00e3o bem sucedida",
            "schema": {
              "type": "string"
            }
          },
          "400": {
            "description": "Erro n\u00e3o espec\u00edficado"
          }
        }
      }
    },
    "/histpac": {
      "get": {
        "tags": [
          "Cadastros"
        ],
        "summary": "Retorna os \u00faltimos 10 registros do hist\u00f3rico do paciente pelo numero de cpf",
        "description": "A API retorna dados do paciente cadastrado no numero de CPF informado",
        "operationId": "gethistbycpf",
        "parameters": [
          {
            "name": "paccpf",
            "in": "header",
            "description": "N\u00famero de CPF do paciente com 11 digitos e sem caracteres especiais ou letras.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Requisi\u00e7\u00e3o bem sucedida",
            "schema": {
              "type": "string"
            }
          },
          "400": {
            "description": "Erro n\u00e3o espec\u00edficado"
          }
        }
      }
    },
    "/itemvlr": {
      "get": {
        "tags": [
          "Cadastros"
        ],
        "summary": "Retorna o pre\u00e7o de um determinado item atrav\u00e9s do ID",
        "description": "A API retorna o pre\u00e7o do item em reais (R$) configurado para o conv\u00eanio 'Particular' atrav\u00e9s do ID informado.",
        "operationId": "getpricebyid",
        "parameters": [
          {
            "name": "item",
            "in": "header",
            "description": "N\u00famero de ID do item",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Requisi\u00e7\u00e3o bem sucedida",
            "schema": {
              "type": "string"
            }
          },
          "400": {
            "description": "Erro n\u00e3o espec\u00edficado"
          }
        }
      }
    }
  },
  "definitions": {
    "Confirm": {
      "type": "object",
      "required": [
        "pnome",
        "time"
      ],
      "properties": {
        "pnome": {
          "type": "string",
          "example": "MARIA DE OLIVEIRA"
        },
        "aghora": {
          "type": "string",
          "example": "2024-08-03 14:00:00.000"
        },
        "time": {
          "type": "string",
          "example": "08/01/2024 14:00:00"
        }
      }
    }
  },
  "securityDefinitions": {
    "basicAuth": {
      "type": "basic"
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ]
}