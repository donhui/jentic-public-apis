{
  "openapi": "3.0.3",
  "info": {
    "title": "Nomics Cryptocurrency API",
    "description": "Nomics cryptocurrency market data API providing prices, volume, market cap, exchange data, and historical aggregates for thousands of cryptocurrencies and exchanges.",
    "version": "1.0.0",
    "contact": {
      "name": "Nomics",
      "url": "https://nomics.com"
    }
  },
  "servers": [
    {
      "url": "https://api.nomics.com/v1",
      "description": "Nomics API v1"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/currencies/ticker": {
      "get": {
        "operationId": "getCurrenciesTicker",
        "summary": "Currencies ticker",
        "description": "Returns price, volume, market cap, and rank for all currencies or a filtered set. This is the primary endpoint for current pricing data.",
        "tags": ["Currencies"],
        "parameters": [
          {
            "name": "ids",
            "in": "query",
            "description": "Comma-separated list of currency IDs to filter (e.g., BTC,ETH,XRP).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "interval",
            "in": "query",
            "description": "Comma-separated list of intervals for price change data (e.g., 1h,1d,7d,30d,365d,ytd).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "convert",
            "in": "query",
            "description": "Currency to convert prices to (e.g., USD, EUR, BTC).",
            "schema": {
              "type": "string",
              "default": "USD"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by status: active, inactive, dead.",
            "schema": {
              "type": "string",
              "enum": ["active", "inactive", "dead"]
            }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Filter type: any, new.",
            "schema": {
              "type": "string",
              "enum": ["any", "new"]
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort order.",
            "schema": {
              "type": "string",
              "enum": ["rank", "first_priced_at"]
            }
          },
          {
            "name": "include-transparency",
            "in": "query",
            "description": "Include transparency grade information.",
            "schema": {
              "type": "string",
              "enum": ["true", "false"]
            }
          },
          {
            "name": "per-page",
            "in": "query",
            "description": "Number of results per page.",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CurrencyTicker"
                  }
                }
              }
            }
          }
        }
      }
    },
