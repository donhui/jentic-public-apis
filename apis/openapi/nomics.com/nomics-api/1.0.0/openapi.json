          },
          "first_candle": {
            "type": "string",
            "format": "date-time"
          },
          "first_trade": {
            "type": "string",
            "format": "date-time"
          },
          "first_order_book": {
            "type": "string",
            "format": "date-time"
          },
          "first_priced_at": {
            "type": "string",
            "format": "date-time"
          },
          "rank": {
            "type": "string",
            "description": "Rank by market cap"
          },
          "rank_delta": {
            "type": "string",
            "description": "Rank change"
          },
          "high": {
            "type": "string",
            "description": "All-time high price"
          },
          "high_timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "1d": {
            "$ref": "#/components/schemas/IntervalData"
          },
          "7d": {
            "$ref": "#/components/schemas/IntervalData"
          },
          "30d": {
            "$ref": "#/components/schemas/IntervalData"
          },
          "365d": {
            "$ref": "#/components/schemas/IntervalData"
          },
          "ytd": {
            "$ref": "#/components/schemas/IntervalData"
          }
        }
      },
      "IntervalData": {
        "type": "object",
        "properties": {
          "volume": {
            "type": "string",
            "description": "Volume for the interval"
          },
          "price_change": {
            "type": "string",
            "description": "Price change for the interval"
          },
          "price_change_pct": {
            "type": "string",
            "description": "Price change percentage"
          },
          "volume_change": {
            "type": "string",
            "description": "Volume change"
          },
          "volume_change_pct": {
            "type": "string",
            "description": "Volume change percentage"
          },
          "market_cap_change": {
            "type": "string",
            "description": "Market cap change"
          },
          "market_cap_change_pct": {
            "type": "string",
            "description": "Market cap change percentage"
          }
        }
      },
      "CurrencyMetadata": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "original_symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "website_url": {
            "type": "string"
          },
          "logo_url": {
            "type": "string"
          },
          "blog_url": {
            "type": "string"
          },
          "discord_url": {
            "type": "string"
          },
          "facebook_url": {
            "type": "string"
          },
