{
  "openapi": "3.0.3",
  "info": {
    "title": "Modrinth API",
    "version": "2.7.0",
    "description": "Modrinth API (Labrinth) provides access to the Modrinth mod hosting platform. Search, create, and manage projects, versions, users, teams, and tags for Minecraft mods, modpacks, resource packs, and shaders.",
    "x-jentic-source-url": "https://docs.modrinth.com/api"
  },
  "servers": [
    {
      "url": "https://api.modrinth.com/v2",
      "description": "Modrinth production API"
    },
    {
      "url": "https://staging-api.modrinth.com/v2",
      "description": "Modrinth staging API"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "searchProjects",
        "summary": "Search for projects",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search query string",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "facets",
            "in": "query",
            "description": "Facet filter string using operations like :, !=, >=, >, <=, <",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "index",
            "in": "query",
            "description": "Sort method",
            "schema": {
              "type": "string",
              "enum": [
                "relevance",
                "downloads",
                "follows",
                "newest",
                "updated"
              ],
              "default": "relevance"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of results to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
