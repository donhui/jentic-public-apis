                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fetch_field/": {
      "get": {
        "tags": ["Fields"],
        "summary": "Fetch field",
        "description": "Get field/parameter configuration by ID.",
        "operationId": "fetchField",
        "parameters": [
          {
            "name": "field_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParameterApiOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fetch_instruction/": {
      "get": {
        "tags": ["Instructions"],
        "summary": "Fetch instruction",
        "description": "Obtain instruction content by ID.",
        "operationId": "fetchInstruction",
        "parameters": [
          {
            "name": "instruction_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InstructionApiOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fetch_documents/": {
      "get": {
        "tags": ["Documents"],
        "summary": "Fetch documents",
        "description": "Query documents with optional date range filtering.",
        "operationId": "fetchDocuments",
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "required": false,
            "description": "Filter documents created after this date (inclusive)",
            "schema": {
              "type": "string",
              "format": "date",
              "nullable": true
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": false,
            "description": "Filter documents created before this date (inclusive)",
            "schema": {
              "type": "string",
              "format": "date",
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fetch_document_data/": {
      "get": {
        "tags": ["Documents"],
        "summary": "Fetch document data",
        "description": "Extract document extraction results by document ID.",
        "operationId": "fetchDocumentData",
        "parameters": [
          {
            "name": "document_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fetch_file/": {
      "get": {
        "tags": ["Documents"],
        "summary": "Fetch file",
        "description": "Download file by document or task ID.",
        "operationId": "fetchFile",
        "parameters": [
          {
            "name": "document_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "nullable": true
            }
          },
          {
            "name": "task_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fetch_files_batch/": {
      "post": {
        "tags": ["Documents"],
        "summary": "Fetch files batch",
        "description": "Fetch multiple files and return them as a ZIP archive. Provide either document IDs, task IDs, or both. At least one must be provided. Fails on first error encountered (all-or-nothing operation).",
        "operationId": "fetchFilesBatch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FetchFilesBatchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ZIP file containing all requested files",
            "content": {
              "application/zip": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Error response with detailed error information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchFileErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/create_folder/": {
      "post": {
        "tags": ["Folders"],
        "summary": "Create folder",
        "description": "Add a new workspace folder.",
        "operationId": "createFolder",
        "requestBody": {
          "required": true,
          "content": {
