{
  "openapi": "3.0.3",
  "info": {
    "title": "Koncile API",
    "description": "Koncile is an AI-powered solution that automates data extraction from documents such as invoices, pay slips, or contracts. Provides document upload, template management, field configuration, and extraction result retrieval.",
    "version": "1.1.0",
    "x-jentic-source-url": "https://api.koncile.ai/documentation"
  },
  "servers": [
    {
      "url": "https://api.koncile.ai",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "API key validation"
    },
    {
      "name": "Documents",
      "description": "Document upload, retrieval, and management"
    },
    {
      "name": "Folders",
      "description": "Workspace folder management"
    },
    {
      "name": "Templates",
      "description": "Document template management"
    },
    {
      "name": "Fields",
      "description": "Extraction field configuration"
    },
    {
      "name": "Instructions",
      "description": "Template instruction management"
    }
  ],
  "paths": {
    "/v1/check_api_key/": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Check API key",
        "description": "Validate API credentials.",
        "operationId": "checkApiKey",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/v1/upload_file/": {
      "post": {
        "tags": ["Documents"],
        "summary": "Upload file",
        "description": "Submit documents for processing with optional folder, template, and document IDs.",
        "operationId": "uploadFile",
        "parameters": [
          {
            "name": "folder_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "nullable": true
            }
          },
          {
            "name": "template_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "nullable": true
            }
          },
          {
            "name": "doc_id",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "nullable": true
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/BodyUploadFile"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fetch_tasks_results/": {
      "get": {
        "tags": ["Documents"],
        "summary": "Fetch task results",
        "description": "Retrieve task outcomes using a task ID.",
        "operationId": "fetchTasksResults",
        "parameters": [
          {
            "name": "task_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiOut"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fetch_all_folders/": {
      "get": {
        "tags": ["Folders"],
        "summary": "Fetch all folders",
        "description": "List all workspace folders.",
        "operationId": "fetchAllFolders",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigsApiOut"
                }
              }
            }
          }
        }
      }
    },
    "/v1/fetch_folder/": {
      "get": {
        "tags": ["Folders"],
        "summary": "Fetch folder",
        "description": "Get specific folder details by ID.",
        "operationId": "fetchFolder",
        "parameters": [
          {
            "name": "folder_id",
            "in": "query",
            "required": true,
