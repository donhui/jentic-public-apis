    "/v1/delete_folder/": {
      "delete": {
        "tags": ["Folders"],
        "summary": "Delete folder",
        "description": "Remove a folder with optional override.",
        "operationId": "deleteFolder",
        "parameters": [
          {
            "name": "folder_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "override",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
