                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/create_field/": {
      "post": {
        "tags": ["Fields"],
        "summary": "Create field",
        "description": "Define a new extraction field parameter.",
        "operationId": "createField",
        "requestBody": {
