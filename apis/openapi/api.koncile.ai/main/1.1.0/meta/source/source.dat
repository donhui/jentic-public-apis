    "/v1/delete_instruction/": {
      "delete": {
        "tags": ["Instructions"],
        "summary": "Delete instruction",
        "description": "Remove an instruction.",
        "operationId": "deleteInstruction",
        "parameters": [
          {
            "name": "instruction_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
