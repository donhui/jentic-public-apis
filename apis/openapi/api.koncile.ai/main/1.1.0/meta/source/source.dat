              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/create_template/": {
      "post": {
        "tags": ["Templates"],
        "summary": "Create template",
        "description": "Create a document template with optional duplication from an existing template.",
        "operationId": "createTemplate",
        "parameters": [
          {
            "name": "template_id",
            "in": "query",
            "required": false,
            "description": "Optional template ID to duplicate from",
            "schema": {
              "type": "integer",
