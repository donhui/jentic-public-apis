    "/tx": {
      "post": {
        "operationId": "broadcastTransaction",
        "summary": "Broadcast transaction",
        "description": "Broadcast a raw transaction to the network.",
        "tags": [
          "Transactions"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "text/plain": {
              "schema": {
                "type": "string",
                "description": "Raw transaction hex"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction ID of the broadcast transaction",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid transaction"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
