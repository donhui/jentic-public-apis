{
  "openapi": "3.0.3",
  "info": {
    "title": "Mempool API",
    "version": "1.0.0",
    "description": "Open-source Bitcoin blockchain explorer API providing access to mempool data, blocks, transactions, addresses, mining pools, fees, and Lightning Network data.",
    "x-jentic-source-url": "https://mempool.space/docs/api/rest"
  },
  "servers": [
    {
      "url": "https://mempool.space/api"
    }
  ],
  "paths": {
    "/block/{hash}": {
      "get": {
        "operationId": "getBlock",
        "summary": "Get block by hash",
        "description": "Returns details about a block given its hash.",
        "tags": [
          "Blocks"
        ],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "description": "Block hash",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Block details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Block"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/block/{hash}/header": {
      "get": {
        "operationId": "getBlockHeader",
        "summary": "Get block header",
        "tags": [
          "Blocks"
        ],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Block header as hex string",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/block/{hash}/status": {
      "get": {
        "operationId": "getBlockStatus",
        "summary": "Get block status",
        "tags": [
          "Blocks"
        ],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Block status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "in_best_chain": {
                      "type": "boolean"
                    },
                    "height": {
                      "type": "integer"
                    },
                    "next_best": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/block/{hash}/txs": {
      "get": {
        "operationId": "getBlockTransactions",
        "summary": "Get block transactions",
        "description": "Returns a list of transactions in a block (up to 25 per page).",
        "tags": [
          "Blocks"
        ],
        "parameters": [
          {
            "name": "hash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_index",
            "in": "query",
            "required": false,
            "description": "Transaction start index for pagination",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of transactions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Transaction"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/block/{hash}/txids": {
      "get": {
        "operationId": "getBlockTxids",
