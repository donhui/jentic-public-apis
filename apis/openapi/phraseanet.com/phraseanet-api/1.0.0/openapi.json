{
  "openapi": "3.0.3",
  "info": {
    "title": "Phraseanet API",
    "version": "1.0.0",
    "description": "Digital asset management API. Search, manage, and organize records, stories, baskets, and feeds. Supports media asset operations including metadata management and embedding.",
    "x-jentic-source-url": "https://docs.phraseanet.com/4.0/en/Devel/API/V1.html"
  },
  "servers": [{"url": "https://{instance}.phraseanet.com/api/v1", "variables": {"instance": {"default": "your-instance", "description": "Your Phraseanet instance name"}}}],
  "paths": {
    "/me/": {
      "get": {"operationId": "getCurrentUser", "summary": "Get current user info", "tags": ["User"], "responses": {"200": {"description": "User info"}, "401": {"description": "Unauthorized"}}}
    },
    "/records/search/": {
      "post": {
        "operationId": "searchRecords", "summary": "Search records", "tags": ["Records"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchRequest"}}}},
        "responses": {"200": {"description": "Search results", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchResponse"}}}}, "400": {"description": "Bad request"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/records/{databox_id}/{record_id}/": {
      "get": {
        "operationId": "getRecord", "summary": "Get a specific record", "tags": ["Records"],
        "parameters": [{"name": "databox_id", "in": "path", "required": true, "schema": {"type": "integer"}}, {"name": "record_id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Record details"}, "401": {"description": "Unauthorized"}, "404": {"description": "Not found"}}
      }
    },
    "/records/{databox_id}/{record_id}/caption/": {
      "get": {
        "operationId": "getRecordCaption", "summary": "Get record caption/metadata", "tags": ["Records"],
        "parameters": [{"name": "databox_id", "in": "path", "required": true, "schema": {"type": "integer"}}, {"name": "record_id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Caption data"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/records/{databox_id}/{record_id}/setmetadatas/": {
      "post": {
        "operationId": "setRecordMetadatas", "summary": "Set record metadata", "tags": ["Records"],
        "parameters": [{"name": "databox_id", "in": "path", "required": true, "schema": {"type": "integer"}}, {"name": "record_id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {"200": {"description": "Metadata set"}, "400": {"description": "Bad request"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/records/{databox_id}/{record_id}/setstatus/": {
      "post": {
        "operationId": "setRecordStatus", "summary": "Set record status", "tags": ["Records"],
        "parameters": [{"name": "databox_id", "in": "path", "required": true, "schema": {"type": "integer"}}, {"name": "record_id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object"}}}},
        "responses": {"200": {"description": "Status set"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/records/{databox_id}/{record_id}/embed/": {
      "get": {
        "operationId": "getRecordEmbed", "summary": "Get record embed URLs", "tags": ["Records"],
        "parameters": [{"name": "databox_id", "in": "path", "required": true, "schema": {"type": "integer"}}, {"name": "record_id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Embed URLs"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/records/add/": {
      "post": {
        "operationId": "addRecord", "summary": "Add a new record", "tags": ["Records"],
        "requestBody": {"required": true, "content": {"multipart/form-data": {"schema": {"type": "object", "properties": {"file": {"type": "string", "format": "binary"}, "base_id": {"type": "integer"}}}}}},
        "responses": {"200": {"description": "Record added"}, "400": {"description": "Bad request"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/stories/{databox_id}/{story_id}/": {
      "get": {
        "operationId": "getStory", "summary": "Get a story", "tags": ["Stories"],
        "parameters": [{"name": "databox_id", "in": "path", "required": true, "schema": {"type": "integer"}}, {"name": "story_id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Story details"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/baskets/list/": {
      "get": {"operationId": "listBaskets", "summary": "List baskets", "tags": ["Baskets"], "responses": {"200": {"description": "Baskets list"}, "401": {"description": "Unauthorized"}}}
    },
    "/baskets/add/": {
      "post": {
        "operationId": "addBasket", "summary": "Create a basket", "tags": ["Baskets"],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"name": {"type": "string"}}}}}},
        "responses": {"200": {"description": "Basket created"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/baskets/{basket_id}/content/": {
      "get": {
        "operationId": "getBasketContent", "summary": "Get basket content", "tags": ["Baskets"],
        "parameters": [{"name": "basket_id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Basket content"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/feeds/list/": {
      "get": {"operationId": "listFeeds", "summary": "List feeds", "tags": ["Feeds"], "responses": {"200": {"description": "Feeds list"}, "401": {"description": "Unauthorized"}}}
    },
    "/feeds/{feed_id}/content/": {
      "get": {
        "operationId": "getFeedContent", "summary": "Get feed content", "tags": ["Feeds"],
        "parameters": [{"name": "feed_id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Feed content"}, "401": {"description": "Unauthorized"}}
      }
    },
    "/databoxes/list/": {
      "get": {"operationId": "listDataboxes", "summary": "List databoxes", "tags": ["Databoxes"], "responses": {"200": {"description": "Databoxes list"}, "401": {"description": "Unauthorized"}}}
    },
    "/databoxes/{databox_id}/collections/": {
      "get": {
        "operationId": "listCollections", "summary": "List collections in databox", "tags": ["Databoxes"],
        "parameters": [{"name": "databox_id", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {"200": {"description": "Collections list"}, "401": {"description": "Unauthorized"}}
      }
    }
  },
  "components": {
    "schemas": {
      "SearchRequest": {"type": "object", "properties": {"query": {"type": "string"}, "bases": {"type": "array", "items": {"type": "integer"}}, "offset_start": {"type": "integer", "default": 1}, "per_page": {"type": "integer", "default": 10}, "sort": {"type": "string", "enum": ["relevance", "created_on", "random"]}, "record_type": {"type": "string", "enum": ["audio", "video", "image", "document", "flash"]}}},
      "SearchResponse": {"type": "object", "properties": {"offset_start": {"type": "integer"}, "per_page": {"type": "integer"}, "available_results": {"type": "integer"}, "total_results": {"type": "integer"}, "results": {"type": "array", "items": {"type": "object"}}}},
      "ErrorResponse": {"type": "object", "properties": {"meta": {"type": "object"}, "error": {"type": "string"}}}
    },
    "securitySchemes": {
      "oauth2": {"type": "oauth2", "flows": {"authorizationCode": {"authorizationUrl": "/api/oauthv2/authorize", "tokenUrl": "/api/oauthv2/token", "scopes": {}}}}
    }
  },
  "security": [{"oauth2": []}]
}
