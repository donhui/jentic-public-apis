{
  "openapi": "3.0.3",
  "info": {
    "title": "Imagga Image Recognition API",
    "description": "Imagga provides a powerful image recognition REST API for auto-tagging, categorization, color extraction, face detection, content moderation, visual search, cropping, background removal, and OCR. The API analyzes image content and returns structured metadata suitable for digital asset management, content moderation, e-commerce, and media applications.",
    "version": "2.0.0",
    "contact": {
      "name": "Imagga Support",
      "url": "https://imagga.com",
      "email": "sales@imagga.com"
    },
    "x-jentic-source-url": "https://imagga.com/"
  },
  "servers": [
    {
      "url": "https://api.imagga.com/v2",
      "description": "Imagga Production API v2"
    }
  ],
  "tags": [
    {
      "name": "Tags",
      "description": "Auto-tagging and keyword generation for images"
    },
    {
      "name": "Categories",
      "description": "Image categorization using built-in or custom categorizers"
    },
    {
      "name": "Colors",
      "description": "Color extraction from images"
    },
    {
      "name": "Faces",
      "description": "Face detection and recognition"
    },
    {
      "name": "Croppings",
      "description": "Smart image cropping"
    },
    {
      "name": "Uploads",
      "description": "Image upload management"
    },
    {
      "name": "Content Moderation",
      "description": "NSFW and explicit content detection"
    },
    {
      "name": "Text",
      "description": "OCR text recognition in images"
    },
    {
      "name": "Usage",
      "description": "API usage statistics"
    }
  ],
  "paths": {
    "/tags": {
      "get": {
        "operationId": "getTags",
        "summary": "Get image tags",
        "description": "Analyzes an image and returns descriptive keyword tags with confidence scores. Supports over 3,000 pre-defined tags.",
        "tags": ["Tags"],
        "parameters": [
          {
            "name": "image_url",
            "in": "query",
            "description": "URL of the image to analyze",
            "schema": { "type": "string", "format": "uri" }
          },
          {
            "name": "image_upload_id",
            "in": "query",
            "description": "ID of a previously uploaded image",
            "schema": { "type": "string" }
          },
          {
            "name": "language",
            "in": "query",
            "description": "Language for tag names (e.g., en, de, fr, es)",
            "schema": { "type": "string", "default": "en" }
          },
          {
            "name": "threshold",
            "in": "query",
            "description": "Minimum confidence threshold (0-100)",
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of tags to return",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Tags generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TagsResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    },
    "/categories/{categorizer_id}": {
      "get": {
        "operationId": "categorizeImage",
        "summary": "Categorize an image",
        "description": "Categorizes an image using a specified categorizer (built-in or custom-trained).",
        "tags": ["Categories"],
        "parameters": [
          {
            "name": "categorizer_id",
            "in": "path",
            "required": true,
            "description": "The categorizer to use (e.g., 'personal_photos', 'nsfw_beta')",
            "schema": { "type": "string" }
          },
          {
            "name": "image_url",
            "in": "query",
            "description": "URL of the image to categorize",
            "schema": { "type": "string", "format": "uri" }
          },
          {
            "name": "image_upload_id",
            "in": "query",
            "description": "ID of a previously uploaded image",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Image categorized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CategoriesResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    },
    "/colors": {
      "get": {
        "operationId": "getColors",
        "summary": "Extract colors from an image",
        "description": "Extracts dominant colors, foreground colors, and background colors from an image.",
        "tags": ["Colors"],
        "parameters": [
          {
            "name": "image_url",
            "in": "query",
            "description": "URL of the image",
            "schema": { "type": "string", "format": "uri" }
          },
          {
            "name": "image_upload_id",
            "in": "query",
            "description": "ID of a previously uploaded image",
            "schema": { "type": "string" }
          },
          {
            "name": "extract_overall_colors",
            "in": "query",
            "description": "Extract overall dominant colors",
            "schema": { "type": "boolean", "default": true }
          },
          {
            "name": "extract_object_colors",
            "in": "query",
            "description": "Extract foreground object colors",
            "schema": { "type": "boolean", "default": true }
          }
        ],
        "responses": {
          "200": {
            "description": "Colors extracted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ColorsResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    },
    "/faces/detections": {
      "get": {
        "operationId": "detectFaces",
        "summary": "Detect faces in an image",
        "description": "Detects faces in an image and returns bounding box coordinates for each detected face.",
        "tags": ["Faces"],
        "parameters": [
          {
            "name": "image_url",
            "in": "query",
            "description": "URL of the image",
            "schema": { "type": "string", "format": "uri" }
          },
          {
            "name": "image_upload_id",
            "in": "query",
            "description": "ID of a previously uploaded image",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Faces detected successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaceDetectionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    },
    "/faces/similarity": {
      "get": {
        "operationId": "compareFaces",
        "summary": "Compare face similarity",
        "description": "Compares faces between two images and returns a similarity score.",
        "tags": ["Faces"],
        "parameters": [
          {
            "name": "face_id",
            "in": "query",
            "required": true,
            "description": "Face ID from a previous detection",
            "schema": { "type": "string" }
          },
          {
            "name": "second_face_id",
            "in": "query",
            "required": true,
            "description": "Second face ID to compare against",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Face comparison completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FaceSimilarityResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    },
    "/croppings": {
      "get": {
        "operationId": "getCroppings",
        "summary": "Get smart crop suggestions",
        "description": "Returns smart crop coordinates for optimal image cropping based on content analysis.",
        "tags": ["Croppings"],
        "parameters": [
          {
            "name": "image_url",
            "in": "query",
            "description": "URL of the image",
            "schema": { "type": "string", "format": "uri" }
          },
          {
            "name": "image_upload_id",
            "in": "query",
            "description": "ID of a previously uploaded image",
            "schema": { "type": "string" }
          },
          {
            "name": "resolution",
            "in": "query",
            "description": "Target resolution as WxH (e.g., '300x300')",
            "schema": { "type": "string" }
          },
          {
            "name": "no_scaling",
            "in": "query",
            "description": "If true, return crop coordinates without scaling",
            "schema": { "type": "boolean", "default": false }
          }
        ],
        "responses": {
          "200": {
            "description": "Crop suggestions returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CroppingsResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    },
    "/uploads": {
      "post": {
        "operationId": "uploadImage",
        "summary": "Upload an image",
        "description": "Uploads an image for later use with other API endpoints. Returns an upload ID.",
        "tags": ["Uploads"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["image"],
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image file to upload"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    },
    "/uploads/{upload_id}": {
      "get": {
        "operationId": "getUpload",
        "summary": "Get upload details",
        "description": "Retrieves details of a previously uploaded image.",
        "tags": ["Uploads"],
        "parameters": [
          {
            "name": "upload_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Upload details returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      },
      "delete": {
        "operationId": "deleteUpload",
        "summary": "Delete an uploaded image",
        "description": "Deletes a previously uploaded image.",
        "tags": ["Uploads"],
        "parameters": [
          {
            "name": "upload_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Upload deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    },
    "/text": {
      "get": {
        "operationId": "recognizeText",
        "summary": "Recognize text in an image (OCR)",
        "description": "Performs optical character recognition on an image and returns detected text content.",
        "tags": ["Text"],
        "parameters": [
          {
            "name": "image_url",
            "in": "query",
            "description": "URL of the image",
            "schema": { "type": "string", "format": "uri" }
          },
          {
            "name": "image_upload_id",
            "in": "query",
            "description": "ID of a previously uploaded image",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Text recognized successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TextRecognitionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/RateLimited" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    },
    "/usage": {
      "get": {
        "operationId": "getUsage",
        "summary": "Get API usage statistics",
        "description": "Returns current API usage statistics for your account.",
        "tags": ["Usage"],
        "responses": {
          "200": {
            "description": "Usage statistics returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsageResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalError" }
        },
        "security": [{ "BasicAuth": [] }]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication using your Imagga API key as username and API secret as password. Obtain credentials at https://imagga.com/auth/signup"
      }
    },
    "schemas": {
      "TagsResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "tags": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Tag"
                }
              }
            }
          },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "confidence": {
            "type": "number",
            "format": "float",
            "description": "Confidence score (0-100)"
          },
          "tag": {
            "type": "object",
            "properties": {
              "en": {
                "type": "string",
                "description": "Tag name in the requested language"
              }
            }
          }
        }
      },
      "CategoriesResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "categories": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "confidence": { "type": "number", "format": "float" },
                    "name": {
                      "type": "object",
                      "properties": {
                        "en": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "ColorsResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "colors": {
                "type": "object",
                "properties": {
                  "background_colors": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Color" }
                  },
                  "foreground_colors": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Color" }
                  },
                  "image_colors": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Color" }
                  }
                }
              }
            }
          },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "Color": {
        "type": "object",
        "properties": {
          "r": { "type": "integer", "description": "Red channel (0-255)" },
          "g": { "type": "integer", "description": "Green channel (0-255)" },
          "b": { "type": "integer", "description": "Blue channel (0-255)" },
          "html_code": { "type": "string", "description": "Hex color code" },
          "closest_palette_color": { "type": "string" },
          "closest_palette_color_html_code": { "type": "string" },
          "closest_palette_distance": { "type": "number", "format": "float" },
          "percent": { "type": "number", "format": "float", "description": "Percentage of the image this color occupies" }
        }
      },
      "FaceDetectionResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "faces": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "face_id": { "type": "string" },
                    "confidence": { "type": "number", "format": "float" },
                    "coordinates": {
                      "type": "object",
                      "properties": {
                        "xmin": { "type": "integer" },
                        "ymin": { "type": "integer" },
                        "xmax": { "type": "integer" },
                        "ymax": { "type": "integer" },
                        "width": { "type": "integer" },
                        "height": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "FaceSimilarityResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "score": {
                "type": "number",
                "format": "float",
                "description": "Similarity score between 0 and 100"
              }
            }
          },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "CroppingsResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "croppings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "target_width": { "type": "integer" },
                    "target_height": { "type": "integer" },
                    "x1": { "type": "integer" },
                    "y1": { "type": "integer" },
                    "x2": { "type": "integer" },
                    "y2": { "type": "integer" }
                  }
                }
              }
            }
          },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "UploadResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "upload_id": { "type": "string", "description": "Unique upload identifier" }
            }
          },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "TextRecognitionResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "text": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "string", "description": "Recognized text content" },
                    "coordinates": {
                      "type": "object",
                      "properties": {
                        "xmin": { "type": "integer" },
                        "ymin": { "type": "integer" },
                        "xmax": { "type": "integer" },
                        "ymax": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "UsageResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "object",
            "properties": {
              "monthly_limit": { "type": "integer" },
              "monthly_processed": { "type": "integer" },
              "daily_limit": { "type": "integer" },
              "daily_processed": { "type": "integer" },
              "concurrency_limit": { "type": "integer" }
            }
          },
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": { "$ref": "#/components/schemas/Status" }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Status type (e.g., 'success', 'error')"
          },
          "text": {
            "type": "string",
            "description": "Status description"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "text": { "type": "string", "description": "Error message" }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters or missing image",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid API credentials",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden - feature not available on your plan",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "RateLimited": {
        "description": "Too many requests - rate limit or concurrency limit exceeded",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  },
  "security": [
    {
      "BasicAuth": []
    }
  ]
}
