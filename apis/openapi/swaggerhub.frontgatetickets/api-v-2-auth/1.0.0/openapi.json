{
  "openapi": "3.0.0",
  "info": {
    "title": "API v2 - Auth",
    "version": "1.0.0",
    "contact": {
      "name": "Sam Jones",
      "email": "sam.jones@frontgatetickets.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/frontgatetickets/api-v_2_auth/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "auth",
      "description": "Metadata related requests"
    }
  ],
  "servers": [
    {
      "description": "Local",
      "url": "https://fgtix.localhost:3100/auth/v2/"
    },
    {
      "description": "Development",
      "url": "https://api.nonprod-fgtix.io/dev/sandlot/auth/v2/"
    },
    {
      "description": "Production",
      "url": "https://api.frontgatetickets.com/auth/v2/"
    }
  ],
  "paths": {
    "/access-token": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "operationId": "postAccessToken",
        "summary": "Send login information to get access token",
        "tags": [
          "authentication"
        ],
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/authTokenSuccess"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/authTokenFailure"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "schemas": {
      "authTokenSuccess": {
        "description": "Successful response with auth token in data",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "message": {
            "type": "string",
            "example": null
          },
          "data": {
            "allOf": [
              {
                "$ref": "#/components/schemas/authToken"
              }
            ],
            "description": "Authorization Token Itself"
          }
        },
        "type": "object"
      },
      "authToken": {
        "properties": {
          "accessTokenId": {
            "example": 4337984,
            "type": "integer",
            "description": "Identifier for the access token, mostly useful to FGT devs"
          },
          "token": {
            "example": "dbbc0fd2506d9930b4ea67e002d3c99f",
            "type": "string",
            "description": "Hex identifier of the token to use for later requests"
          },
          "expiry": {
            "example": "2019-03-12T22:23:06-05:00",
            "type": "string",
            "format": "date-time",
            "description": "Time the token will expire"
          },
          "isRestricted": {
            "type": "boolean",
            "description": "Does this token give you access to restricted paths"
          },
          "meta": {
            "allOf": [
              {
                "$ref": "#/components/schemas/tokenMeta"
              }
            ]
          },
          "application": {
            "allOf": [
              {
                "$ref": "#/components/schemas/authApplication"
              }
            ]
          },
          "user": {
            "allOf": [
              {
                "$ref": "#/components/schemas/authUser"
              }
            ]
          },
          "item": {
            "allOf": [
              {
                "$ref": "#/components/schemas/authItem"
              }
            ]
          }
        },
        "type": "object"
      },
      "tokenMeta": {
        "properties": {
          "type": {
            "example": "Application",
            "type": "string"
          },
          "uri": {
            "example": "/application/4337984",
            "type": "string"
          },
          "complete": {
            "type": "boolean"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "modified": {
            "type": "string",
            "format": "date-time"
          }
        },
        "type": "object"
      },
      "authApplication": {
        "properties": {
          "applicationId": {
            "example": 3,
            "type": "integer",
            "description": "Primary key of application record"
          },
          "apiKey": {
            "example": "fe87ba8a33062f1c76e8ed533e8cf1ca",
            "type": "string",
            "description": "Key to use for username when authentication via application"
          },
          "meta": {
            "allOf": [
              {
                "$ref": "#/components/schemas/tokenMeta"
              }
            ]
          }
        },
        "type": "object"
      },
      "authUser": {
        "properties": {
          "userId": {
            "example": 11608,
            "type": "integer",
            "description": "Primary key of user"
          },
          "email": {
            "example": "fgttakauto20@fgtix.com",
            "type": "string",
            "format": "email"
          },
          "meta": {
            "allOf": [
              {
                "$ref": "#/components/schemas/userMeta"
              }
            ]
          }
        },
        "type": "object",
        "nullable": true
      },
      "authItem": {
        "properties": {
          "itemId": {
            "example": 148549427,
            "type": "integer"
          },
          "lookupId": {
            "example": "ASAP17",
            "type": "string"
          },
          "orderId": {
            "example": 42526198,
            "type": "integer"
          }
        },
        "type": "object",
        "nullable": true
      },
      "userMeta": {
        "properties": {
          "uri": {
            "example": "/user/11608",
            "type": "string",
            "description": "Path to REST command to fetch this user"
          }
        },
        "type": "object"
      },
      "authTokenFailure": {
        "properties": {
          "data": {
            "type": "object",
            "nullable": true
          },
          "status": {
            "type": "string",
            "example": "error"
          },
          "message": {
            "type": "string",
            "example": "The provided credentials could not be authorized"
          }
        }
      }
    }
  }
}