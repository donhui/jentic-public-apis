    "/_/public-api/v2/users": {
      "post": {
        "tags": ["Users"],
        "summary": "List users",
        "description": "Retrieves a list of users in the workspace.",
        "operationId": "listUsers",
        "parameters": [
          {
            "$ref": "#/components/parameters/PublicApiVersion"
          }
        ],
        "responses": {
