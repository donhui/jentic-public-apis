            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "users": {
                      "type": "array",
                      "description": "List of users.",
                      "items": {
                        "$ref": "#/components/schemas/User"
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    },
    "/_/public-api/v2/teams": {
      "post": {
        "tags": ["Teams"],
        "summary": "List teams",
        "description": "Retrieves a list of teams in the workspace.",
        "operationId": "listTeams",
        "parameters": [
          {
            "$ref": "#/components/parameters/PublicApiVersion"
          }
        ],
        "responses": {
          "200": {
            "description": "List of teams.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "teams": {
                      "type": "array",
                      "description": "List of teams.",
                      "items": {
                        "$ref": "#/components/schemas/Team"
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    },
    "/_/public-api/v2/meeting_types": {
      "post": {
        "tags": ["Meeting Types"],
        "summary": "List meeting types",
        "description": "Retrieves a list of meeting types configured in the workspace.",
        "operationId": "listMeetingTypes",
        "parameters": [
          {
            "$ref": "#/components/parameters/PublicApiVersion"
          }
        ],
        "responses": {
          "200": {
            "description": "List of meeting types.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meeting_types": {
                      "type": "array",
                      "description": "List of meeting types.",
                      "items": {
                        "$ref": "#/components/schemas/MeetingType"
                      }
                    }
                  }
                }
              }
            }
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Use a Personal Access Token, Workspace Access Token, or OAuth2 access token."
      }
    },
    "parameters": {
      "PublicApiVersion": {
        "name": "Public-Api-Version",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string",
          "default": "2025-10-31"
        },
        "description": "API version header. Current version: 2025-10-31."
      },
      "RecordingId": {
        "name": "recording_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        },
        "description": "The unique identifier of the recording."
      }
    },
    "responses": {
      "RateLimitExceeded": {
        "description": "Rate limit exceeded. Maximum 300 requests per minute.",
        "headers": {
          "x-ratelimit-limit": {
            "description": "Max number of requests allowed per window (300/min).",
            "schema": {
              "type": "integer"
            }
          },
          "x-ratelimit-remaining": {
            "description": "Number of requests remaining in the current window.",
            "schema": {
              "type": "integer"
            }
          },
          "Retry-After": {
            "description": "Number of seconds you must wait before submitting another request.",
            "schema": {
              "type": "integer"
            }
          }
        }
      }
    },
    "schemas": {
      "OAuthTokenResponse": {
        "type": "object",
        "properties": {
          "token_type": {
            "type": "string",
            "description": "Always 'bearer'.",
            "example": "bearer"
          },
          "access_token": {
            "type": "string",
            "description": "Token to be used in the Authorization header."
          },
          "refresh_token": {
            "type": "string",
            "description": "Token to be used to refresh the access_token."
          },
          "expires_in": {
            "type": "integer",
            "description": "Number of seconds the access_token will live for after generation."
          }
        }
      },
      "Recording": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the recording."
          },
          "title": {
            "type": "string",
            "description": "Title of the recording."
          },
          "source": {
            "type": "string",
            "description": "Source platform of the recording (e.g., 'zoom')."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Shareable URL for the recording."
          },
          "media_type": {
            "type": "string",
            "description": "Type of media (e.g., 'video', 'audio')."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags associated with the recording."
          },
          "start_datetime": {
            "type": "string",
            "format": "date-time",
            "description": "Start date and time of the recording."
          },
          "teams": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Team"
            },
            "description": "Teams the recording is shared with."
          },
          "participants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Participant"
            },
            "description": "Participants in the recording. Only included when requested via the include parameter."
          }
        }
      },
      "Participant": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the participant."
          },
          "name": {
            "type": "string",
            "description": "Name of the participant."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the participant."
          }
        }
      },
      "TranscriptSegment": {
        "type": "object",
        "properties": {
          "participant_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "ID of the participant."
          },
          "speaker": {
            "type": "string",
            "description": "Name of the participant."
          },
          "start": {
            "type": "integer",
            "description": "Timestamp in milliseconds from the recording of when this section started."
          },
          "end": {
            "type": "integer",
            "description": "Timestamp in milliseconds from the recording of when this section ended."
          },
          "text": {
            "type": "string",
            "description": "Text of this transcript section."
          }
        }
      },
      "UploadUrlResponse": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the upload; will be present in the upload hooks if an upload_status hook exists."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to upload the file to."
          },
          "max_duration_sec": {
            "type": "integer",
            "description": "Maximum duration in seconds the upload can be."
          },
          "max_upload_bytes": {
            "type": "integer",
            "description": "Maximum size in bytes the upload can be."
          }
        }
      },
      "Hook": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the hook."
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the hook is enabled."
          },
          "hook_url": {
            "type": "string",
            "format": "uri",
            "description": "Endpoint called when the event is triggered."
          },
          "hook_type": {
            "type": "string",
            "enum": [
              "recording_added",
              "recording_updated",
              "recording_deleted",
              "highlight_added",
              "highlight_updated",
              "highlight_deleted",
              "story_added",
              "story_updated",
              "story_deleted",
              "upload_status"
            ],
            "description": "Type of event notifications the hook receives."
          },
          "include": {
            "type": "object",
            "description": "Include configuration for the hook payload."
          },
          "inserted_at": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time the hook was created."
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the user."
          },
          "name": {
            "type": "string",
            "description": "Name of the user."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the user."
          }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the team."
          },
          "name": {
            "type": "string",
            "description": "Name of the team."
          }
        }
      },
      "MeetingType": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the meeting type."
          },
          "name": {
            "type": "string",
            "description": "Name of the meeting type."
          },
          "scope": {
            "type": "string",
            "enum": ["internal", "external"],
            "description": "Scope of the meeting type."
          }
        }
      },
      "RecordingFilter": {
        "type": "object",
        "description": "Filter criteria for recordings.",
        "properties": {
          "title_search": {
            "type": "string",
            "description": "Search recordings by title."
          }
        }
      },
      "RecordingInclude": {
        "type": "object",
        "description": "Options for including additional data with recordings.",
        "properties": {
          "participants": {
            "type": "boolean",
            "description": "Include participant details in the response."
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Always true on success."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "OAuth2",
      "description": "OAuth2 authentication endpoints."
    },
    {
      "name": "Recordings",
      "description": "Manage meeting recordings, transcripts, and media."
    },
    {
      "name": "Hooks",
      "description": "Manage webhooks for event notifications."
    },
    {
      "name": "Users",
      "description": "List workspace users."
    },
    {
      "name": "Teams",
      "description": "List workspace teams."
    },
    {
      "name": "Meeting Types",
      "description": "List meeting type configurations."
    }
  ]
}