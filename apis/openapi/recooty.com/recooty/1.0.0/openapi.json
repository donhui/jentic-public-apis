                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Interviews"],
        "summary": "Schedule interview",
        "operationId": "createInterview",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InterviewInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Interview scheduled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Interview"
                }
              }
            }
          }
        }
      }
    },
    "/interview/bulk": {
      "post": {
        "tags": ["Interviews"],
        "summary": "Create multiple interviews",
        "operationId": "bulkCreateInterviews",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["interviews"],
                "properties": {
                  "interviews": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/InterviewInput"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Interviews created successfully"
          }
        }
      }
    },
    "/interview/{interview}": {
      "get": {
        "tags": ["Interviews"],
        "summary": "Get interview details",
        "operationId": "getInterview",
        "parameters": [
          {
            "name": "interview",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Interview details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Interview"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Interviews"],
        "summary": "Update interview",
        "operationId": "updateInterview",
        "parameters": [
          {
            "name": "interview",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InterviewInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Interview updated"
          }
        }
      },
      "delete": {
        "tags": ["Interviews"],
        "summary": "Cancel interview",
        "operationId": "deleteInterview",
        "parameters": [
          {
            "name": "interview",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Interview cancelled"
          }
        }
      }
    },
    "/interview/{interview}/scorecard": {
      "post": {
        "tags": ["Interviews"],
        "summary": "Create interview scorecard",
        "operationId": "createScorecard",
        "parameters": [
          {
            "name": "interview",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "scores": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "criterion": {
                          "type": "string"
                        },
                        "score": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 5
                        },
                        "notes": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "overall_rating": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "recommendation": {
                    "type": "string",
                    "enum": ["strong_hire", "hire", "no_hire", "strong_no_hire"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Scorecard created"
          }
        }
      }
    },
