{
  "openapi": "3.0.3",
  "info": {
    "title": "Recooty API",
    "version": "1.0.0",
    "description": "Recooty AI recruitment and applicant tracking system API. Manage jobs, applications, interviews, candidates, and talent pools.",
    "x-jentic-source-url": "https://app.recooty.com/settings/integrations/api-docs"
  },
  "servers": [
    {
      "url": "https://app.recooty.com",
      "description": "Production API server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication and session management"
    },
    {
      "name": "Jobs",
      "description": "Job posting management"
    },
    {
      "name": "Applications",
      "description": "Application and candidate management"
    },
    {
      "name": "Interviews",
      "description": "Interview scheduling and scoring"
    },
    {
      "name": "Talent Pool",
      "description": "Talent pool management"
    },
    {
      "name": "Reports",
      "description": "Analytics and reporting"
    },
    {
      "name": "Templates",
      "description": "Email template management"
    },
    {
      "name": "Integrations",
      "description": "Third-party integrations"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User login",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "format": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string"
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          }
        }
      }
    },
    "/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "User logout",
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "Successfully logged out"
          }
        }
      }
    },
    "/jobs": {
      "get": {
        "tags": ["Jobs"],
        "summary": "List all jobs",
        "operationId": "listJobs",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["open", "closed", "draft"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Job"
                      }
                    },
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Jobs"],
        "summary": "Create job posting",
        "operationId": "createJob",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          }
        }
      }
    },
    "/jobs/{job_post}": {
      "get": {
        "tags": ["Jobs"],
        "summary": "Get job details",
        "operationId": "getJob",
        "parameters": [
          {
            "$ref": "#/components/parameters/JobPostParameter"
          }
        ],
        "responses": {
          "200": {
            "description": "Job details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      },
      "put": {
        "tags": ["Jobs"],
        "summary": "Update job",
        "operationId": "updateJob",
        "parameters": [
          {
            "$ref": "#/components/parameters/JobPostParameter"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JobInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Job updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      },
      "delete": {
        "tags": ["Jobs"],
        "summary": "Delete job",
        "operationId": "deleteJob",
        "parameters": [
          {
            "$ref": "#/components/parameters/JobPostParameter"
          }
        ],
        "responses": {
          "204": {
            "description": "Job deleted successfully"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      }
    },
    "/jobs/{job_post}/skills": {
      "get": {
        "tags": ["Jobs"],
        "summary": "Get job skills",
        "operationId": "getJobSkills",
        "parameters": [
          {
            "$ref": "#/components/parameters/JobPostParameter"
          }
        ],
        "responses": {
          "200": {
            "description": "List of job skills",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "required": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{job}/application/update-status": {
      "post": {
        "tags": ["Applications"],
        "summary": "Update application status",
        "operationId": "updateApplicationStatus",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["application_id", "status"],
                "properties": {
                  "application_id": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": ["new", "screening", "interview", "offer", "hired", "rejected"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Application status updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Application"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{job}/application/move-to-job": {
      "post": {
        "tags": ["Applications"],
        "summary": "Move application to different job",
        "operationId": "moveApplication",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["application_id", "target_job_id"],
                "properties": {
                  "application_id": {
                    "type": "string"
                  },
                  "target_job_id": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Application moved successfully"
          }
        }
      }
    },
    "/jobs/{job}/application/{application}": {
      "delete": {
        "tags": ["Applications"],
        "summary": "Delete application",
        "operationId": "deleteApplication",
        "parameters": [
          {
            "name": "job",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "application",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Application deleted successfully"
          }
        }
      }
    },
    "/application/store_candidate/{jobPost}": {
      "post": {
        "tags": ["Applications"],
        "summary": "Add candidate to job",
        "operationId": "addCandidate",
        "parameters": [
          {
            "name": "jobPost",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "first_name", "last_name"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "resume_url": {
                    "type": "string",
                    "format": "uri"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Candidate added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Application"
                }
              }
            }
          }
        }
      }
    },
    "/interview": {
      "get": {
        "tags": ["Interviews"],
