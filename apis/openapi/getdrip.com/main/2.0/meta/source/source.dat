{
  "openapi": "3.0.3",
  "info": {
    "title": "Drip API",
    "description": "The Drip REST API allows you to manage subscribers, campaigns, workflows, events, tags, and more for your Drip email marketing account.",
    "version": "2.0",
    "x-jentic-source-url": "https://developer.drip.com/"
  },
  "servers": [
    {
      "url": "https://api.getdrip.com"
    }
  ],
  "security": [
    {
      "basicAuth": []
    },
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Accounts", "description": "Manage Drip accounts" },
    { "name": "Broadcasts", "description": "Manage single-email campaigns" },
    { "name": "Campaigns", "description": "Manage email series campaigns" },
    { "name": "Subscribers", "description": "Manage subscribers" },
    { "name": "Tags", "description": "Manage subscriber tags" },
    { "name": "Events", "description": "Track custom events" },
    { "name": "Forms", "description": "View forms" },
    { "name": "Conversions", "description": "Manage conversion goals" },
    { "name": "CustomFields", "description": "View custom fields" },
    { "name": "Workflows", "description": "Manage automation workflows" },
    { "name": "Webhooks", "description": "Manage webhooks" },
    { "name": "Users", "description": "View authenticated user" },
    { "name": "Orders", "description": "Manage shopper activity orders" },
    { "name": "Products", "description": "Manage shopper activity products" },
    { "name": "Carts", "description": "Manage shopper activity carts" }
  ],
  "paths": {
    "/v2/accounts": {
      "get": {
        "tags": ["Accounts"],
        "operationId": "listAccounts",
        "summary": "List all accounts",
        "responses": {
          "200": {
            "description": "List of accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accounts": { "type": "array", "items": { "$ref": "#/components/schemas/Account" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/accounts/{account_id}": {
      "get": {
        "tags": ["Accounts"],
        "operationId": "getAccount",
        "summary": "Fetch a specific account",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Account details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accounts": { "type": "array", "items": { "$ref": "#/components/schemas/Account" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/broadcasts": {
      "get": {
        "tags": ["Broadcasts"],
        "operationId": "listBroadcasts",
        "summary": "List all broadcasts",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "maximum": 1000 } },
          { "name": "status", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of broadcasts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "broadcasts": { "type": "array", "items": { "$ref": "#/components/schemas/Broadcast" } },
                    "meta": { "$ref": "#/components/schemas/PaginationMeta" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/broadcasts/{broadcast_id}": {
      "get": {
        "tags": ["Broadcasts"],
        "operationId": "getBroadcast",
        "summary": "Fetch a specific broadcast",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "broadcast_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Broadcast details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "broadcasts": { "type": "array", "items": { "$ref": "#/components/schemas/Broadcast" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/campaigns": {
      "get": {
        "tags": ["Campaigns"],
        "operationId": "listCampaigns",
        "summary": "List all campaigns",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["draft", "active", "paused", "all"] } }
        ],
        "responses": {
          "200": {
            "description": "List of campaigns",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaigns": { "type": "array", "items": { "$ref": "#/components/schemas/Campaign" } },
                    "meta": { "$ref": "#/components/schemas/PaginationMeta" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/campaigns/{campaign_id}": {
      "get": {
        "tags": ["Campaigns"],
        "operationId": "getCampaign",
        "summary": "Fetch a specific campaign",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "campaign_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Campaign details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaigns": { "type": "array", "items": { "$ref": "#/components/schemas/Campaign" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/campaigns/{campaign_id}/activate": {
      "post": {
        "tags": ["Campaigns"],
        "operationId": "activateCampaign",
        "summary": "Activate a campaign",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "campaign_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Campaign activated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/campaigns/{campaign_id}/pause": {
      "post": {
        "tags": ["Campaigns"],
        "operationId": "pauseCampaign",
        "summary": "Pause a campaign",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "campaign_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Campaign paused" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/campaigns/{campaign_id}/subscribers": {
      "get": {
        "tags": ["Campaigns"],
        "operationId": "listCampaignSubscribers",
        "summary": "List subscribers of a campaign",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "campaign_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "List of subscribers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscribers": { "type": "array", "items": { "$ref": "#/components/schemas/Subscriber" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Campaigns"],
        "operationId": "subscribeToCampaign",
        "summary": "Subscribe someone to a campaign",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "campaign_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subscribers": { "type": "array", "items": { "$ref": "#/components/schemas/SubscriberInput" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Subscribed to campaign" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/subscribers": {
      "get": {
        "tags": ["Subscribers"],
        "operationId": "listSubscribers",
        "summary": "List all subscribers",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 100, "maximum": 1000 } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["active", "unsubscribed", "removed"] } },
          { "name": "tags", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of subscribers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscribers": { "type": "array", "items": { "$ref": "#/components/schemas/Subscriber" } },
                    "meta": { "$ref": "#/components/schemas/PaginationMeta" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Subscribers"],
        "operationId": "createOrUpdateSubscriber",
        "summary": "Create or update a subscriber",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subscribers": { "type": "array", "items": { "$ref": "#/components/schemas/SubscriberInput" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscriber created or updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscribers": { "type": "array", "items": { "$ref": "#/components/schemas/Subscriber" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/subscribers/{subscriber_id}": {
      "get": {
        "tags": ["Subscribers"],
        "operationId": "getSubscriber",
        "summary": "Fetch a specific subscriber",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "subscriber_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Subscriber details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "subscribers": { "type": "array", "items": { "$ref": "#/components/schemas/Subscriber" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "tags": ["Subscribers"],
        "operationId": "deleteSubscriber",
        "summary": "Delete a subscriber",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "subscriber_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Subscriber deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/subscribers/batches": {
      "post": {
        "tags": ["Subscribers"],
        "operationId": "batchCreateOrUpdateSubscribers",
        "summary": "Batch create or update subscribers",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "batches": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "subscribers": { "type": "array", "items": { "$ref": "#/components/schemas/SubscriberInput" } }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Batch created" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/unsubscribes/batches": {
      "post": {
        "tags": ["Subscribers"],
        "operationId": "batchUnsubscribe",
        "summary": "Batch unsubscribe subscribers",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "batches": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "subscribers": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "email": { "type": "string" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Batch unsubscribe initiated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/subscribers/{subscriber_id}/remove": {
      "post": {
        "tags": ["Subscribers"],
        "operationId": "removeSubscriberFromCampaign",
        "summary": "Remove a subscriber from a campaign",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "subscriber_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Subscriber removed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/tags": {
      "get": {
        "tags": ["Tags"],
        "operationId": "listTags",
        "summary": "List all tags",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of tags",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tags": { "type": "array", "items": { "$ref": "#/components/schemas/Tag" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Tags"],
        "operationId": "applyTagToSubscriber",
        "summary": "Apply a tag to a subscriber",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "email": { "type": "string" },
                        "tag": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Tag applied" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/subscribers/{subscriber_id}/tags/{tag}": {
      "delete": {
        "tags": ["Tags"],
        "operationId": "removeTagFromSubscriber",
        "summary": "Remove a tag from a subscriber",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "subscriber_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "tag", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Tag removed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/events": {
      "post": {
        "tags": ["Events"],
        "operationId": "recordEvent",
        "summary": "Record a custom event",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "events": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/EventInput" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Event recorded" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/events/batches": {
      "post": {
        "tags": ["Events"],
        "operationId": "batchRecordEvents",
        "summary": "Batch record events",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "batches": { "type": "array", "items": { "type": "object" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Batch events recorded" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/event_actions": {
      "get": {
        "tags": ["Events"],
        "operationId": "listEventActions",
        "summary": "List custom event actions",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of event actions" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/forms": {
      "get": {
        "tags": ["Forms"],
        "operationId": "listForms",
        "summary": "List all forms",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of forms",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "forms": { "type": "array", "items": { "$ref": "#/components/schemas/Form" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/forms/{form_id}": {
      "get": {
        "tags": ["Forms"],
        "operationId": "getForm",
        "summary": "Fetch a specific form",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "form_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Form details" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/goals": {
      "get": {
        "tags": ["Conversions"],
        "operationId": "listConversions",
        "summary": "List all conversions",
        "parameters": [
          { "name": "account_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of conversions" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v2/{account_id}/goals/{conversion_id}": {
      "get": {
        "tags": ["Conversions"],
        "operationId": "getConversion",
        "summary": "Fetch a specific conversion",
        "parameters": [
