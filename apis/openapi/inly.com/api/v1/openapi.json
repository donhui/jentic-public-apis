    "/zapier/webhooks/subscribe": {
      "post": {
        "summary": "Subscribe to webhook events",
        "tags": [
          "Webhooks"
        ],
        "security": [
          {
            "api_key": []
          }
        ],
        "parameters": [
          {
            "name": "X-API-KEY",
            "in": "header",
            "required": true,
            "description": "Zapier API key",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "description": "Subscription ID"
                    },
                    "status": {
                      "type": "string",
                      "description": "Subscription status"
                    }
                  },
                  "required": [
                    "id",
                    "status"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "target_url": {
                    "type": "string",
                    "description": "URL to receive webhook notifications"
                  },
                  "event": {
                    "type": "string",
                    "description": "Event type to subscribe to"
                  }
                },
                "required": [
                  "target_url",
                  "event"
                ]
              }
            }
          }
        }
      }
    },
