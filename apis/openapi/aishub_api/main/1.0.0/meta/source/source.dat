{
  "openapi": "3.0.3",
  "info": {
    "title": "AISHub API",
    "description": "AISHub API provides access to AIS vessel position data and receiving station information. Rate limited to one request per minute.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://aishub.net/api"
  },
  "servers": [
    {
      "url": "https://data.aishub.net",
      "description": "AISHub Data Server"
    }
  ],
  "tags": [
    {
      "name": "AIS Data",
      "description": "Vessel AIS position data"
    },
    {
      "name": "Stations",
      "description": "AIS receiving station information"
    }
  ],
  "paths": {
    "/ws.php": {
      "get": {
        "operationId": "getaisdata",
        "summary": "Retrieve AIS vessel data",
        "description": "Retrieves vessel AIS data with optional filtering by geographic area, MMSI, or IMO numbers. Rate limited to one request per minute.",
        "tags": [
          "AIS Data"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "description": "AISHub username for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Data encoding: 0 for AIS format, 1 for human-readable",
            "schema": {
              "type": "integer",
              "default": 0,
              "enum": [
                0,
                1
              ]
            }
          },
          {
            "name": "output",
            "in": "query",
            "description": "Output format: xml, json, or csv",
            "schema": {
              "type": "string",
              "default": "xml",
              "enum": [
                "xml",
                "json",
                "csv"
              ]
            }
          },
          {
            "name": "compress",
            "in": "query",
            "description": "Compression: 0=none, 1=ZIP, 2=GZIP, 3=BZIP2",
            "schema": {
              "type": "integer",
              "default": 0,
              "enum": [
                0,
                1,
                2,
                3
              ]
            }
          },
          {
            "name": "latmin",
            "in": "query",
            "description": "Minimum latitude for geographic boundary (degrees)",
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "latmax",
            "in": "query",
            "description": "Maximum latitude for geographic boundary (degrees)",
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "lonmin",
            "in": "query",
            "description": "Minimum longitude for geographic boundary (degrees)",
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "lonmax",
            "in": "query",
            "description": "Maximum longitude for geographic boundary (degrees)",
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "mmsi",
            "in": "query",
            "description": "Single or comma-separated MMSI numbers",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "imo",
            "in": "query",
            "description": "Single or comma-separated IMO numbers",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "interval",
            "in": "query",
            "description": "Maximum position age in minutes",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "AIS data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AISRecord"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid username",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/stations.php": {
      "get": {
        "operationId": "getstations",
        "summary": "Retrieve AIS station information",
        "description": "Retrieves information about AIS receiving stations including location, ship counts, and update timestamps.",
        "tags": [
          "Stations"
        ],
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "description": "AISHub username for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "output",
            "in": "query",
            "description": "Output format: xml, json, or csv",
            "schema": {
              "type": "string",
              "default": "xml",
              "enum": [
                "xml",
                "json",
                "csv"
              ]
            }
          },
          {
            "name": "compress",
            "in": "query",
            "description": "Compression: 0=none, 1=ZIP, 2=GZIP, 3=BZIP2",
            "schema": {
              "type": "integer",
              "default": 0,
              "enum": [
                0,
                1,
                2,
                3
              ]
            }
          },
          {
            "name": "id",
            "in": "query",
            "description": "Specific station ID to retrieve",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Station data retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StationRecord"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid username",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "usernameQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "username",
        "description": "AISHub username provided upon joining, passed as query parameter"
      }
    },
    "schemas": {
      "AISRecord": {
        "type": "object",
        "properties": {
          "MMSI": {
            "type": "integer",
            "description": "Maritime Mobile Service Identity"
          },
          "TIME": {
            "type": "string",
            "description": "Position timestamp in UTC"
          },
          "LONGITUDE": {
            "type": "number",
            "format": "float",
            "description": "Geographic longitude"
          },
          "LATITUDE": {
            "type": "number",
            "format": "float",
            "description": "Geographic latitude"
          },
          "COG": {
            "type": "number",
            "format": "float",
            "description": "Course over ground in degrees"
          },
          "SOG": {
            "type": "number",
            "format": "float",
            "description": "Speed over ground in knots"
          },
          "HEADING": {
            "type": "integer",
            "description": "True heading in degrees"
          },
          "NAVSTAT": {
            "type": "integer",
            "description": "Navigation status"
          },
          "IMO": {
            "type": "integer",
            "description": "IMO number"
          },
          "NAME": {
            "type": "string",
            "description": "Vessel name"
          },
          "CALLSIGN": {
            "type": "string",
            "description": "Radio call sign"
          },
          "TYPE": {
            "type": "integer",
            "description": "Ship type"
          },
          "A": {
            "type": "integer",
            "description": "Dimension to bow"
          },
          "B": {
            "type": "integer",
            "description": "Dimension to stern"
          },
          "C": {
            "type": "integer",
            "description": "Dimension to port"
          },
          "D": {
            "type": "integer",
            "description": "Dimension to starboard"
          },
          "DRAUGHT": {
            "type": "number",
            "format": "float",
            "description": "Current draught"
          },
          "DEST": {
            "type": "string",
            "description": "Destination"
          },
          "ETA": {
            "type": "string",
            "description": "Estimated time of arrival"
          }
        }
      },
      "StationRecord": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "integer",
            "description": "Station identifier"
          },
          "LAST_UPDATE": {
            "type": "string",
            "description": "Last update timestamp"
          },
          "COUNTRY": {
            "type": "string",
            "description": "Station country"
          },
          "LATITUDE": {
            "type": "number",
            "format": "float"
          },
          "LONGITUDE": {
            "type": "number",
            "format": "float"
          },
          "SHIPS": {
            "type": "integer",
            "description": "Number of ships tracked"
          },
          "CONTRIBUTOR": {
            "type": "string",
            "description": "Station contributor information"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  },
  "security": [
    {
      "usernameQuery": []
    }
  ]
}