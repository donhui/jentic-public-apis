    "/email": {
      "post": {
        "operationId": "sendTransactionalEmail",
        "summary": "Send transactional email",
        "tags": ["Transactional Email"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransactionalEmail"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email sent successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/email/batch": {
      "post": {
        "operationId": "sendBatchTransactionalEmail",
        "summary": "Send batch transactional emails",
        "tags": ["Transactional Email"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TransactionalEmail"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch emails sent successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
