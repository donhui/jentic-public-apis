    "/campaigns/send": {
      "post": {
        "operationId": "sendCampaign",
        "summary": "Send a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["campaignId", "addressBookIds"],
                "properties": {
                  "campaignId": {
                    "type": "integer"
                  },
                  "addressBookIds": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  },
                  "sendDate": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Campaign sent successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
