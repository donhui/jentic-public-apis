{
  "openapi": "3.0.3",
  "info": {
    "title": "Westlaw API",
    "version": "1.0.0",
    "description": "Legal research and analytics platform API",
    "x-jentic-source-url": "https://developer.clarivate.com/"
  },
  "servers": [
    {
      "url": "https://api.clarivate.com"
    }
  ],
  "security": [
    {
