{
  "openapi": "3.0.3",
  "info": {
    "title": "SurveyRock API",
    "version": "1.0.0",
    "description": "SurveyRock is a survey creation tool. API v1 provides access to surveys, distributors, responses and respondents.",
    "x-jentic-source-url": "https://www.surveyrock.com/home/api-documentation-v1.html"
  },
  "servers": [
    {
      "url": "https://api.surveyrock.com/sv1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/distributors/create_distributor": {
      "post": {
        "tags": [
          "Distributors"
        ],
        "summary": "Create a distributor",
        "operationId": "createDistributor",
        "parameters": [
          {
            "name": "survey_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Survey ID"
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "web_link"
              ]
            },
            "description": "Type of distributor"
          },
          {
            "name": "title",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Name of distributor. Defaults to 'New Web Link'."
          }
        ],
        "responses": {
          "200": {
            "description": "Distributor created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DistributorResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too many requests"
          }
        }
      }
    },
    "/distributors/get_distributor_list": {
      "get": {
        "tags": [
          "Distributors"
        ],
        "summary": "List all distributors for a survey",
        "operationId": "listDistributors",
        "parameters": [
          {
            "name": "survey_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Survey ID"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sort order, e.g. date_created or -date_created"
          },
          {
            "name": "created_after",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by creation date (YYYY-MM-DD HH:MM:SS)"
          },
          {
            "name": "created_before",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter by creation date"
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated fields to return"
          }
        ],
        "responses": {
          "200": {
            "description": "List of distributors",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DistributorListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too many requests"
          }
        }
      }
    },
    "/responses/get_respondent_list": {
      "get": {
        "tags": [
          "Responses"
        ],
        "summary": "List respondents",
        "operationId": "listRespondents",
        "parameters": [
          {
            "name": "survey_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Survey ID"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of respondents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too many requests"
          }
        }
      }
    },
    "/responses/get_number_of_responses": {
      "get": {
        "tags": [
          "Responses"
        ],
        "summary": "Get number of responses",
        "operationId": "getNumberOfResponses",
        "parameters": [
          {
            "name": "survey_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Survey ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Response count",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseCountResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too many requests"
          }
        }
      }
    },
    "/responses/get_response_details": {
      "get": {
        "tags": [
          "Responses"
        ],
        "summary": "Get response details",
        "operationId": "getResponseDetails",
        "parameters": [
          {
            "name": "response_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Response ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Response details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too many requests"
          }
        }
      }
    },
    "/surveys/get_survey_list": {
      "get": {
        "tags": [
          "Surveys"
        ],
        "summary": "List surveys",
        "operationId": "listSurveys",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of surveys",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too many requests"
          }
        }
      }
    },
    "/surveys/get_survey_details": {
      "get": {
        "tags": [
          "Surveys"
        ],
        "summary": "Get survey details",
        "operationId": "getSurveyDetails",
        "parameters": [
          {
            "name": "survey_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Survey ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Survey details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Too many requests"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "OAuth 2.0 Bearer Token from API Access page"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "status_text": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "Distributor": {
        "type": "object",
        "properties": {
          "distributor_id": {
            "type": "integer"
          },
          "date_created": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "DistributorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "status_text": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "distributor": {
                "$ref": "#/components/schemas/Distributor"
              }
            }
          }
        }
      },
      "DistributorListResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "status_text": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "distributors": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Distributor"
                }
              }
            }
          }
        }
      },
      "ResponseCountResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "status_text": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "completed": {
                "type": "integer"
              },
              "started": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "status_text": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}