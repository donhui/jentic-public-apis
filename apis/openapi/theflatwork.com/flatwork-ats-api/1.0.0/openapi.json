{
  "openapi": "3.0.3",
  "info": {
    "title": "Flatwork ATS API",
    "version": "1.0.0",
    "description": "Flatwork Recruit applicant tracking system API for managing job listings, candidate submissions, evaluations, comments, and talent pools.",
    "x-jentic-source-url": "https://theflatwork.readme.io/reference/login"
  },
  "servers": [
    {
      "url": "https://flatwork-ats-api.prod.theflatwork.com"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate and obtain session token",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
