{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "Betala Staging",
      "url": "http://api.betala-staging.no/api/v2.0"
    },
    {
      "description": "Betala Production",
      "url": "http://api.betala.no/api/v2.0"
    }
  ],
  "info": {
    "description": "This is the documentation of the accounting reporting APIs that are available in Betala.",
    "version": "1.0.0",
    "title": "Betala accounting reproting APIs",
    "contact": {
      "email": "zakaria@hoopla.no"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/zak-betala/Betala_iizy_integration/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "iizy-integration",
      "description": "Operations available for the iizy intergation"
    }
  ],
  "paths": {
    "/iizy/betala": {
      "get": {
        "security": [
          {
            "apiKeyAuth": []
          }
        ],
        "tags": [
          "iizy-integration"
        ],
        "summary": "search organization sales data",
        "operationId": "GetOrganizationSalesData",
        "description": "By passing in the appropriate options, you can search for\nthe sales data of the organization. This will be used later by an accounting\nsystem reporting.\n",
        "parameters": [
          {
            "in": "query",
            "name": "from",
            "description": "start search date time",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time",
              "example": "2024-04-05T00:00:00Z"
            }
          },
          {
            "in": "query",
            "name": "to",
            "description": "end search date time",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date-time",
              "example": "2024-04-05T05:00:00Z"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results matching criteria",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad input parameter"
          },
          "401": {
            "description": "Not authorized to access to the sales data"
          },
          "403": {
            "description": "Authentication required"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SearchResult": {
        "type": "object",
        "required": [
          "articles",
          "transactions"
        ],
        "properties": {
          "articles": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sales_area": {
                  "type": "string",
                  "example": "Sales area for iizy demo"
                },
                "article-group": {
                  "type": "string",
                  "example": "Mat"
                },
                "vat_rate": {
                  "type": "string",
                  "example": "12%"
                },
                "total_vat": {
                  "type": "number",
                  "example": 112.56
                },
                "total": {
                  "type": "integer",
                  "example": 1050
                }
              }
            }
          },
          "transactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "organization_identifier": {
                  "type": "string",
                  "example": "betala"
                },
                "sales_point_group_name": {
                  "type": "string",
                  "example": "Food Truck Demo"
                },
                "sales_point_name": {
                  "type": "string",
                  "example": "Sales point food track"
                },
                "pos_report_id": {
                  "type": "string",
                  "example": ""
                },
                "operator_first_name": {
                  "type": "string",
                  "example": " John"
                },
                "operator_last_name": {
                  "type": "string",
                  "example": "Smith"
                },
                "pos_purchase_id": {
                  "type": "string",
                  "example": "5cbc654b-0ff3-46ce-b87e-1451f5d6b76a"
                },
                "pos_purchase_finalized_date": {
                  "type": "string",
                  "example": "05.04.2024"
                },
                "pos_purchase_finalized_time": {
                  "type": "string",
                  "example": "02:44:46.616"
                },
                "device_id": {
                  "type": "string",
                  "example": "450-921-374"
                },
                "pretty_device_id": {
                  "type": "string",
                  "example": ""
                },
                "refund_id": {
                  "type": "string",
                  "example": ""
                },
                "refund_finalized_date": {
                  "type": "string",
                  "example": ""
                },
                "refund_finalized_time": {
                  "type": "string",
                  "example": ""
                },
                "transaction_type": {
                  "type": "string",
                  "example": "BAX"
                },
                "terminal_id": {
                  "type": "string",
                  "example": "12345678"
                },
                "terminal_id_fallback": {
                  "type": "string",
                  "example": "BAX: 123456-12345678\nCVM: ONLINE PIN\nVi"
                },
                "issuer_id": {
                  "type": "string",
                  "example": "3"
                },
                "readable_issuer_id": {
                  "type": "string",
                  "example": "Visa"
                },
                "product_id": {
                  "type": "number",
                  "example": 120219
                },
                "product_name": {
                  "type": "string",
                  "example": "Sushi"
                },
                "general_ledger_account": {
                  "type": "number",
                  "example": 4002
                },
                "vat_factor": {
                  "type": "string",
                  "example": "12%"
                },
                "product_price_inc_vat": {
                  "type": "number",
                  "example": 150
                },
                "product_vat": {
                  "type": "number",
                  "example": 150
                },
                "sum_price_ex_vat": {
                  "type": "number",
                  "example": 133.92
                },
                "sum_vat": {
                  "type": "number",
                  "example": 16.08
                },
                "sum_price_inc_vat": {
                  "type": "number",
                  "example": 150
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Please provide your API key (that you have generated from your Betala portal) in the format: IIZY_API_KEY:<your-api-key>"
      }
    }
  }
}