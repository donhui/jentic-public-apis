{
  "openapi": "3.0.3",
  "info": {
    "title": "Robin API",
    "description": "Robin API for managing workspaces, spaces, users, organizations, devices, desk reservations, and free-busy scheduling.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.robinpowered.com/"
  },
  "servers": [
    {
      "url": "https://api.robinpowered.com/v1.0"
    }
  ],
  "security": [
    {
      "accessToken": []
    }
  ],
  "tags": [
    { "name": "Organizations", "description": "Organization management" },
    { "name": "Users", "description": "User management and presence" },
    { "name": "Spaces", "description": "Space management and events" },
    { "name": "Devices", "description": "Device management within spaces" },
    { "name": "Reservations", "description": "Desk and seat reservations" },
    { "name": "FreeBusy", "description": "Free-busy scheduling queries" },
    { "name": "Authentication", "description": "Authentication" },
    { "name": "Me", "description": "Current authenticated user" }
  ],
  "paths": {
    "/auth": {
      "post": {
        "operationId": "authenticate",
        "summary": "Exchange credentials for an access token",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
