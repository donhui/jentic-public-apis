          },
          "failureReason": {
            "$ref": "#/components/schemas/ManualActionFailureReason"
          }
        }
      },
      "PayoutCreationStatus": {
        "type": "string",
        "description": "The initiation status of the payout: \n* `ACCEPTED` - The payout has been **accepted** by pawaPay for processing.\n* `REJECTED` - The payout request has been **rejected** by pawaPay. See failureReason for details. \n* `DUPLICATE_IGNORED` - The payout has been **ignored** as a duplicate of and already accepted payout. Deduplication is based on `payoutId`.\n",
        "enum": [
          "ACCEPTED",
          "REJECTED",
          "DUPLICATE_IGNORED"
        ]
      },
      "PayoutFailureReason": {
        "required": [
          "failureCode"
        ],
        "type": "object",
        "properties": {
          "failureCode": {
            "type": "string",
            "description": "Possible payout failure codes: \n* `PAWAPAY_WALLET_OUT_OF_FUNDS` - Your pawaPay wallet does not have enough funds to complete this payout.\n* `RECIPIENT_NOT_FOUND` - The phone number specified as the receipient does not belong to the provider. \n* `WALLET_LIMIT_REACHED` - The recipient has reached a limit on their wallet that stops them from being able to accept this payout. \n* `MANUALLY_CANCELLED` - The payout was enqueued and subsequently cancelled from the pawaPay Dashboard or through the [Cancel Enqueued Payout](/v2/api-reference/payouts/cancel-enqueued-payout) endpoint.\n* `UNSPECIFIED_FAILURE` - The provider confirmed the payment has failed, but did not provide any information about the reason of the failure.\n* `UNKNOWN_ERROR` - An unknown error has occured.\n",
            "example": "WALLET_LIMIT_REACHED",
            "enum": [
              "PAWAPAY_WALLET_OUT_OF_FUNDS",
              "RECIPIENT_NOT_FOUND",
              "WALLET_LIMIT_REACHED",
              "MANUALLY_CANCELLED",
              "UNSPECIFIED_FAILURE",
              "UNKNOWN_ERROR"
            ]
          },
          "failureMessage": {
            "type": "string",
            "description": "Description of the reason for this failure",
            "example": "Recipient's address is blocked"
          }
        }
      },
      "PayoutSearchResult": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/SearchResultStatus"
          },
          "data": {
            "$ref": "#/components/schemas/Payout"
          }
        }
      },
      "SearchResultStatus": {
        "type": "string",
        "description": "The result of this operation.\n- `FOUND` - The payment was found in pawaPay.\n- `NOT_FOUND` - The payment was not found in pawaPay.\n",
        "enum": [
          "FOUND",
          "NOT_FOUND"
        ]
      },
      "PayoutStatus": {
        "type": "string",
        "description": "Possible payout statuses: \n* `ACCEPTED` - The payout has been **accepted** by pawaPay for processing. \n* `ENQUEUED` - The payout has been **accepted**, but has been enqueued for processing later. Read more about [enqueued payouts](/v2/docs/payouts#handling-enqueued-payouts-and-provider-availability). \n* `PROCESSING` - The payout has been submitted to the provider and is being processed.\n* `IN_RECONCILIATION` - The payout is being reconciled currently to determine it's final status.\n* `COMPLETED` - The payout has been successfully processed. This is a **final status.**\n* `FAILED` - The payout has been processed, but failed. This is a **final status.**. See `failureReason` for details.\n",
        "enum": [
          "ACCEPTED",
          "ENQUEUED",
          "PROCESSING",
          "IN_RECONCILIATION",
          "COMPLETED",
          "FAILED"
        ]
      },
      "RefundStatus": {
        "type": "string",
        "description": "Possible refund statuses: \n* `ACCEPTED` - The refund has been **accepted** by pawaPay for processing. \n* `ENQUEUED` - The refund has been **accepted**, but has been enqueued for processing later. Read more about [enqueued refunds](/v2/docs/refunds#handling-enqueued-refunds-and-provider-availability). \n* `PROCESSING` - The refund has been submitted to the provider and is being processed.\n* `IN_RECONCILIATION` - The refund is being reconciled currently to determine it's final status.\n* `COMPLETED` - The refund has been successfully processed. This is a **final status.**\n* `FAILED` - The refund has been processed, but failed. This is a **final status.**. See `failureReason` for details.\n",
        "enum": [
          "ACCEPTED",
          "ENQUEUED",
          "PROCESSING",
          "IN_RECONCILIATION",
          "COMPLETED",
          "FAILED"
        ]
      },
