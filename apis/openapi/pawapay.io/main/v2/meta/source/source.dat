      "RefundInitiationFailureReason": {
        "required": [
          "failureReason"
        ],
        "type": "object",
        "properties": {
          "failureCode": {
            "type": "string",
            "description": "Reason for the failure:\n* `NO_AUTHENTICATION` - The API token was not found in the request headers.\n* `AUTHENTICATION_ERROR` - The API token in the request headers is not valid.\n* `AUTHORISATION_ERROR` - The API Token in the request header is not authorised to make this request.\n* `HTTP_SIGNATURE_ERROR` - The signature you have passed with the request did not pass verification.\n* `INVALID_INPUT` - We were unable to parse the payload of the request.\n* `MISSING_PARAMETER` - A mandatory parameter was missing from the request body.\n* `UNSUPPORTED_PARAMETER` - An unsupported parameter was found in the request body.\n* `INVALID_PARAMETER` - A parameter had an incorrect value.\n* `DUPLICATE_METADATA_FIELD` - A duplicate field was found in payment metadata.\n* `REFUNDS_NOT_ALLOWED` - Refunds are not enabled with the provider on your pawaPay account.\n* `INVALID_PHONE_NUMBER` - The phone number provided is in the wrong format.\n* `INVALID_AMOUNT` - The amount contains decimals which is not supported by the provider.\n* `INVALID_CURRENCY` - The currency is not supported by the provider.\n* `INVALID_PROVIDER` - The provider is not valid for this request. \n* `PROVIDER_TEMPORARILY_UNAVAILABLE` - The provider is not currently not able to accept payments. \n* `NOT_FOUND` - The deposit to refund was not found.\n* `INVALID_STATE` - The deposit to refund is not in 'COMPLETED' status or has already been refunded.\n* `UNKNOWN_ERROR` - The provider is not valid for this request.\n",
            "enum": [
              "NO_AUTHENTICATION",
              "AUTHENTICATION_ERROR",
              "AUTHORISATION_ERROR",
              "HTTP_SIGNATURE_ERROR",
              "INVALID_INPUT",
              "MISSING_PARAMETER",
              "UNSUPPORTED_PARAMETER",
              "INVALID_PARAMETER",
              "DUPLICATE_METADATA_FIELD",
              "REFUNDS_NOT_ALLOWED",
              "INVALID_PHONE_NUMBER",
              "INVALID_AMOUNT",
              "AMOUNT_OUT_OF_BOUNDS",
              "PAWAPAY_WALLET_OUT_OF_FUNDS",
              "INVALID_CURRENCY",
              "INVALID_PROVIDER",
              "NOT_FOUND",
              "INVALID_STATE",
              "UNKNOWN_ERROR"
            ]
          },
          "failureMessage": {
            "type": "string",
            "description": "A description of the failure"
          }
        }
      },
      "AuthorizationFailureReason": {
        "required": [
          "failureReason"
        ],
        "type": "object",
        "properties": {
          "failureCode": {
            "type": "string",
            "description": "Reason for the failure:\n* `AUTHORISATION_ERROR` - The API Token in the request header is not authorised to make this request.\n* `DEPOSITS_NOT_ALLOWED` - Deposits are not enabled with the provider on your pawaPay account.\n* `PAYOUTS_NOT_ALLOWED` - Payouts are not enabled with the provider on your pawaPay account.\n* `REMITTANCES_NOT_ALLOWED` - Remittances are not enabled with the provider on your pawaPay account.\n* `REFUNDS_NOT_ALLOWED` - Refunds are not enabled with the provider on your pawaPay account.\n",
            "enum": [
              "AUTHORISATION_ERROR",
              "DEPOSITS_NOT_ALLOWED",
              "PAYOUTS_NOT_ALLOWED",
              "REMITTANCES_NOT_ALLOWED",
              "REFUNDS_NOT_ALLOWED"
            ]
          },
          "failureMessage": {
            "type": "string",
            "description": "A description of the failure"
          }
        }
      },
      "AuthenticationFailureReason": {
        "required": [
          "failureReason"
        ],
        "type": "object",
        "properties": {
          "failureCode": {
            "type": "string",
            "description": "Reason for the failure:\n* `NO_AUTHENTICATION` - The API token was not found in the request headers.\n* `AUTHENTICATION_ERROR` - The API token in the request headers is not valid.\n* `HTTP_SIGNATURE_ERROR` - The signature you have passed with the request did not pass verification.\n",
            "enum": [
