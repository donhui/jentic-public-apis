          "REJECTED",
          "DUPLICATE_IGNORED"
        ]
      },
      "RefundFailureReason": {
        "required": [
          "failureCode"
        ],
        "type": "object",
        "properties": {
          "failureCode": {
            "type": "string",
            "description": "Possible refund failure codes: \n* `PAWAPAY_WALLET_OUT_OF_FUNDS` - Your pawaPay wallet does not have enough funds to complete this refund.\n* `RECIPIENT_NOT_FOUND` - The phone number specified for the receipient does not belong to the provider. \n* `WALLET_LIMIT_REACHED` - The recipient has reached a limit on their wallet that stops them from receiving this refund. \n* `UNSPECIFIED_FAILURE` - The provider confirmed the payment has failed, but did not provide any information about the reason of the failure.\n* `UNKNOWN_ERROR` - An unknown error has occured.\n",
            "example": "WALLET_LIMIT_REACHED",
            "enum": [
              "PAWAPAY_WALLET_OUT_OF_FUNDS",
              "RECIPIENT_NOT_FOUND",
              "WALLET_LIMIT_REACHED",
              "UNSPECIFIED_FAILURE",
              "UNKNOWN_ERROR"
            ]
          },
          "failureMessage": {
            "type": "string",
            "description": "Description of the reason for this failure",
            "example": "Recipient's address is blocked"
          }
        }
      },
      "DepositInitiationFailureReason": {
        "required": [
          "failureReason"
        ],
        "type": "object",
        "properties": {
          "failureCode": {
            "type": "string",
            "description": "Reason for the failure:\n* `NO_AUTHENTICATION` - The API token was not found in the request headers.\n* `AUTHENTICATION_ERROR` - The API token in the request headers is not valid.\n* `AUTHORISATION_ERROR` - The API Token in the request header is not authorised to make this request.\n* `HTTP_SIGNATURE_ERROR` - The signature you have passed with the request did not pass verification.\n* `INVALID_INPUT` - We were unable to parse the payload of the request.\n* `MISSING_PARAMETER` - A mandatory parameter was missing from the request body.\n* `UNSUPPORTED_PARAMETER` - An unsupported parameter was found in the request body.\n* `INVALID_PARAMETER` - A parameter had an incorrect value.\n* `DUPLICATE_METADATA_FIELD` - A duplicate field was found in payment metadata.\n* `DEPOSITS_NOT_ALLOWED` - Deposits are not enabled with the provider on your pawaPay account.\n* `INVALID_PHONE_NUMBER` - The phone number provided is in the wrong format.\n* `INVALID_AMOUNT` - The amount contains decimals which is not supported by the provider.\n* `AMOUNT_OUT_OF_BOUNDS` - The amount is outside of this providers transaction limits.\n* `INVALID_CURRENCY` - The currency is not supported by the provider.\n* `INVALID_PROVIDER` - The provider is not valid for this request. \n* `PROVIDER_TEMPORARILY_UNAVAILABLE` - The provider is not currently not able to accept payments. \n* `UNKNOWN_ERROR` - The provider is not valid for this request.\n",
            "enum": [
              "NO_AUTHENTICATION",
              "AUTHENTICATION_ERROR",
              "AUTHORISATION_ERROR",
              "HTTP_SIGNATURE_ERROR",
              "INVALID_INPUT",
              "MISSING_PARAMETER",
              "UNSUPPORTED_PARAMETER",
              "INVALID_PARAMETER",
              "DUPLICATE_METADATA_FIELD",
              "DEPOSITS_NOT_ALLOWED",
              "INVALID_PHONE_NUMBER",
              "INVALID_AMOUNT",
              "AMOUNT_OUT_OF_BOUNDS",
              "INVALID_CURRENCY",
              "INVALID_PROVIDER",
              "PROVIDER_TEMPORARILY_UNAVAILABLE",
              "UNKNOWN_ERROR"
            ]
          },
          "failureMessage": {
            "type": "string",
            "description": "A description of the failure"
          }
        }
      },
      "PayoutInitiationFailureReason": {
        "required": [
          "failureReason"
        ],
        "type": "object",
        "properties": {
          "failureCode": {
            "type": "string",
            "description": "Reason for the failure:\n* `NO_AUTHENTICATION` - The API token was not found in the request headers.\n* `AUTHENTICATION_ERROR` - The API token in the request headers is not valid.\n* `AUTHORISATION_ERROR` - The API Token in the request header is not authorised to make this request.\n* `HTTP_SIGNATURE_ERROR` - The signature you have passed with the request did not pass verification.\n* `INVALID_INPUT` - We were unable to parse the payload of the request.\n* `MISSING_PARAMETER` - A mandatory parameter was missing from the request body.\n* `UNSUPPORTED_PARAMETER` - An unsupported parameter was found in the request body.\n* `INVALID_PARAMETER` - A parameter had an incorrect value.\n* `DUPLICATE_METADATA_FIELD` - A duplicate field was found in payment metadata.\n* `PAYOUTS_NOT_ALLOWED` - Payouts are not enabled with the provider on your pawaPay account.\n* `INVALID_PHONE_NUMBER` - The phone number provided is in the wrong format.\n* `INVALID_AMOUNT` - The amount contains decimals which is not supported by the provider.\n* `PAWAPAY_WALLET_OUT_OF_FUNDS` - Your pawaPay wallet does not have the funds to complete this refund.\n* `INVALID_CURRENCY` - The currency is not supported by the provider.\n* `INVALID_PROVIDER` - The provider is not valid for this request. \n* `PROVIDER_TEMPORARILY_UNAVAILABLE` - The provider is not currently not able to accept payments. \n* `UNKNOWN_ERROR` - The provider is not valid for this request.\n",
            "enum": [
              "NO_AUTHENTICATION",
              "AUTHENTICATION_ERROR",
              "AUTHORISATION_ERROR",
              "HTTP_SIGNATURE_ERROR",
              "INVALID_INPUT",
              "MISSING_PARAMETER",
              "UNSUPPORTED_PARAMETER",
              "INVALID_PARAMETER",
              "DUPLICATE_METADATA_FIELD",
              "PAYOUTS_NOT_ALLOWED",
              "INVALID_PHONE_NUMBER",
              "INVALID_AMOUNT",
              "PAWAPAY_WALLET_OUT_OF_FUNDS",
              "INVALID_CURRENCY",
              "INVALID_PROVIDER",
              "PROVIDER_TEMPORARILY_UNAVAILABLE",
              "UNKNOWN_ERROR"
            ]
          },
          "failureMessage": {
            "type": "string",
            "description": "A description of the failure"
          }
        }
      },
      "RemittanceInitiationFailureReason": {
        "required": [
          "failureReason"
        ],
        "type": "object",
        "properties": {
          "failureCode": {
            "type": "string",
            "description": "Reason for the failure:\n* `NO_AUTHENTICATION` - The API token was not found in the request headers.\n* `AUTHENTICATION_ERROR` - The API token in the request headers is not valid.\n* `AUTHORISATION_ERROR` - The API Token in the request header is not authorised to make this request.\n* `HTTP_SIGNATURE_ERROR` - The signature you have passed with the request did not pass verification.\n* `INVALID_INPUT` - We were unable to parse the payload of the request.\n* `MISSING_PARAMETER` - A mandatory parameter was missing from the request body.\n* `UNSUPPORTED_PARAMETER` - An unsupported parameter was found in the request body.\n* `INVALID_PARAMETER` - A parameter had an incorrect value.\n* `DUPLICATE_METADATA_FIELD` - A duplicate field was found in payment metadata.\n* `REMITTANCES_NOT_ALLOWED` - Remittances are not enabled with the provider on your pawaPay account.\n* `INVALID_PHONE_NUMBER` - The phone number provided is in the wrong format.\n* `INVALID_AMOUNT` - The amount contains decimals which is not supported by the provider.\n* `PAWAPAY_WALLET_OUT_OF_FUNDS` - Your pawaPay wallet does not have the funds to complete this refund.\n* `INVALID_CURRENCY` - The currency is not supported by the provider.\n* `INVALID_PROVIDER` - The provider is not valid for this request. \n* `PROVIDER_TEMPORARILY_UNAVAILABLE` - The provider is not currently not able to accept payments. \n* `UNKNOWN_ERROR` - The provider is not valid for this request.\n",
            "enum": [
              "NO_AUTHENTICATION",
              "AUTHENTICATION_ERROR",
              "AUTHORISATION_ERROR",
              "HTTP_SIGNATURE_ERROR",
              "INVALID_INPUT",
              "MISSING_PARAMETER",
              "UNSUPPORTED_PARAMETER",
              "INVALID_PARAMETER",
              "DUPLICATE_METADATA_FIELD",
              "REMITTANCES_NOT_ALLOWED",
              "INVALID_PHONE_NUMBER",
              "INVALID_AMOUNT",
              "PAWAPAY_WALLET_OUT_OF_FUNDS",
              "INVALID_CURRENCY",
              "INVALID_PROVIDER",
              "PROVIDER_TEMPORARILY_UNAVAILABLE",
              "UNKNOWN_ERROR"
            ]
          },
          "failureMessage": {
            "type": "string",
