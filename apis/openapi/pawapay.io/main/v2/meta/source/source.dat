      "ClientReference": {
        "type": "string",
        "description": "A reference to an entity in your system that this payment relates to. For example, an invoice ID, customer ID etc.",
        "example": "INV-123456"
      },
      "CustomerMessage": {
        "minLength": 4,
        "maxLength": 22,
        "type": "string",
        "pattern": "^[a-zA-Z0-9 ]+$",
        "description": "A short narration for the transaction. \nDepending on the 'provider', this message may be visible to the customer in the SMS receipt or within their transaction history.\n\nDefaults to your company name as registered on your pawaPay account trimmed to fit the length limitations.\n",
        "example": "Note of 4 to 22 chars"
      },
      "PayoutCreationResponse": {
        "required": [
          "payoutId",
