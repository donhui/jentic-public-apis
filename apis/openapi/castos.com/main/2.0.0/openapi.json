        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "website": {
            "type": "string"
          },
          "author_name": {
            "type": "string"
          },
          "owner_name": {
            "type": "string"
          },
          "owner_email": {
            "type": "string",
            "format": "email"
          },
          "language": {
            "type": "string"
          },
          "copyright": {
            "type": "string"
          },
          "episode_feed_count": {
            "type": "integer"
          }
        }
      },
      "EpisodeInput": {
        "type": "object",
