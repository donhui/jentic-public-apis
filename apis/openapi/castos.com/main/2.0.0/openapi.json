        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PodcastInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated podcast",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deletePodcast",
        "summary": "Delete a podcast",
        "description": "Remove a podcast.",
        "tags": [
          "Podcasts"
        ],
        "parameters": [
          {
            "name": "podcast_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
