{
  "openapi": "3.0.3",
  "info": {
    "title": "Castos API",
    "version": "2.0.0",
    "description": "Castos is a podcast hosting platform for creators. This API allows you to manage podcasts, episodes, private subscribers, and categories.",
    "x-jentic-source-url": "https://app.castos.com/docs/api/index.html",
    "contact": {
      "email": "hello@castos.com",
      "url": "https://castos.com"
    }
  },
  "servers": [
    {
      "url": "https://app.castos.com/api/v2",
      "description": "Castos API v2 server"
    }
  ],
  "paths": {
    "/podcasts": {
      "get": {
        "operationId": "listPodcasts",
        "summary": "List podcasts",
        "description": "List the authenticated user's podcasts.",
        "tags": [
          "Podcasts"
        ],
        "responses": {
          "200": {
            "description": "List of podcasts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Podcast"
                          }
                        }
                      }
                    },
                    "status": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPodcast",
        "summary": "Create a podcast",
        "description": "Create a new podcast.",
        "tags": [
          "Podcasts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PodcastInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created podcast",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardResponse"
                }
              }
            }
          }
        }
      }
    },
