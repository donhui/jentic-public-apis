{
  "openapi": "3.0.3",
  "info": {
    "title": "Semaphore CI API",
    "description": "REST API for Semaphore CI/CD platform. Manage workflows, pipelines, jobs, promotions, deployment targets, self-hosted agents, and artifact retention policies.",
    "version": "v1alpha",
    "x-jentic-source-url": "https://docs.semaphore.io/reference/api"
  },
  "servers": [
    {
      "url": "https://{organization}.semaphoreci.com/api/v1alpha",
      "description": "Semaphore CI organization API",
      "variables": {
        "organization": {
          "default": "myorg",
          "description": "Your Semaphore organization name"
        }
      }
    }
  ],
  "paths": {
    "/plumber-workflows": {
      "get": {
        "operationId": "listWorkflows",
        "summary": "List workflows for a project",
        "tags": [
          "Workflows"
        ],
        "parameters": [
          {
            "name": "project_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "branch_name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of workflows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Workflow"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "runWorkflow",
        "summary": "Run a new workflow",
        "tags": [
          "Workflows"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RunWorkflowRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunWorkflowResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
