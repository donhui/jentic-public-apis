      "ConditionalLogicPayload": {
        "type": "object",
        "title": "ConditionalLogicPayload",
        "description": "Payload for CONDITIONAL_LOGIC block type. Used for form logic and branching.",
        "properties": {
          "conditionals": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Conditional"
            },
