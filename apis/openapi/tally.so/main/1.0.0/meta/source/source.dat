          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConditionalAction"
            },
            "description": "Actions executed when conditions are satisfied."
          },
          "logicalOperator": {
            "type": "string",
            "enum": [
              "AND",
              "OR"
            ],
            "description": "How to combine top-level conditions (AND/OR)."
          },
          "updateUuid": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "UUID of the logic block being updated; null when creating."
          }
        },
        "required": [
          "actions",
          "conditionals",
          "logicalOperator"
        ]
      },
