          },
          "selfEmailBody": {
            "type": "string",
            "nullable": true
          },
          "hasRespondentEmailNotifications": {
            "type": "boolean",
            "default": false
          },
          "respondentEmailTo": {
            "type": "string",
            "nullable": true
          },
          "respondentEmailReplyTo": {
            "type": "string",
            "nullable": true
          },
          "respondentEmailSubject": {
            "type": "string",
            "nullable": true
          },
          "respondentEmailFromName": {
            "type": "string",
            "nullable": true
          },
          "respondentEmailBody": {
            "type": "string",
            "nullable": true
          },
          "hasProgressBar": {
            "type": "boolean",
            "default": false
          },
          "hasPartialSubmissions": {
            "type": "boolean",
            "default": false
          },
          "pageAutoJump": {
            "type": "boolean",
            "default": false
          },
          "saveForLater": {
            "type": "boolean",
            "default": true
          },
          "styles": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "submissionsDataRetentionDuration": {
            "type": "integer",
            "format": "int64",
            "minimum": 0,
            "nullable": true
          },
          "submissionsDataRetentionUnit": {
            "type": "string",
            "maxLength": 12,
            "nullable": true
          }
        }
      },
      "Form": {
        "type": "object",
