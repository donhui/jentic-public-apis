                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string",
                            "description": "Webhook ID"
                          },
                          "formId": {
                            "type": "string",
                            "description": "Form ID the webhook is attached to"
                          },
                          "url": {
                            "type": "string",
                            "description": "The webhook endpoint URL"
                          },
                          "signingSecret": {
                            "type": "string",
                            "nullable": true,
                            "description": "Secret used to sign webhook payloads"
                          },
                          "httpHeaders": {
                            "type": "array",
                            "nullable": true,
