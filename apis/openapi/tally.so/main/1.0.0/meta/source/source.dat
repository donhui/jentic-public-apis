        "description": "Payload for HEADING_2 block type. Used for H2 headings.",
        "properties": {
          "html": {
            "$ref": "#/components/schemas/Html"
          },
          "isHidden": {
            "$ref": "#/components/schemas/IsHidden"
          },
          "columnListUuid": {
            "$ref": "#/components/schemas/ColumnListUuid"
