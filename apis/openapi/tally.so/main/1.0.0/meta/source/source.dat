                            "items": {
                              "type": "object",
                              "properties": {
                                "name": {
                                  "type": "string",
                                  "description": "Header name"
                                },
                                "value": {
                                  "type": "string",
                                  "description": "Header value"
                                }
                              }
                            }
                          },
                          "eventTypes": {
