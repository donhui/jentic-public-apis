              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "Tag to filter the data by",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Incident likelihood over time data for the last 4 quarters",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "required": [
                    "entries"
                  ],
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "description": "Array of incident likelihood data for the last 4 quarters",
                      "items": {
                        "type": "object",
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
