    "/vendor-detection/portfolios/{portfolioId}": {
      "get": {
        "tags": [
          "vendor-detection"
        ],
        "summary": "Get third party vendors by portfolio ID",
        "description": "Returns a list of third-party vendors used by the companies in a given portfolio",
        "parameters": [
          {
            "name": "portfolioId",
            "in": "path",
            "description": "Portfolio id to use",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "c2f0cbc8-844a-424f-8f75-1bf219aab9ff"
          },
          {
            "name": "domain",
            "in": "query",
            "description": "Name of domain to filter by\n(Not compatible with `product` query, filter by one or the other)",
            "schema": {
              "type": "string"
            },
            "example": "example.com"
          },
          {
            "name": "product",
            "in": "query",
            "description": "Name of product to filter by\n(Not compatible with `domain` query, filter by one or the other)",
            "schema": {
              "type": "string"
            },
            "example": "Example"
          },
          {
            "name": "page",
            "in": "query",
            "description": "Which page of results to return",
            "schema": {
              "minimum": 1,
              "type": "integer"
            },
            "example": 1
          },
          {
            "name": "limit",
            "in": "query",
            "description": "How many results to return",
            "schema": {
              "maximum": 5000,
              "minimum": 1,
              "type": "integer",
              "default": 100
            },
            "example": 100
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Link": {
                "description": "URL to be used to used to fetch additional pages of results",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PortfolioVendors"
                }
              },
              "text/html": {
                "schema": {
                  "$ref": "#/components/schemas/PortfolioVendors"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {}
          },
          "401": {
            "description": "Unauthorized",
            "content": {}
          },
          "403": {
            "description": "Company must be added to a portfolio first",
            "content": {}
          },
          "404": {
            "description": "Company not found",
            "content": {}
          },
          "default": {
            "description": "Error Payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              },
              "text/html": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
