    "/vendor-portfolio-automation/ingested-vendors": {
      "get": {
        "tags": [
          "VendorPortfolioAutomation"
        ],
        "summary": "retrieve all ingested vendors regardless of if the",
        "description": "retrieve all ingested vendors regardless of if they correspond to known SecurityScorecard domains",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "page number, defaults to 0 for the first page",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "number of vendors per page (max: 500, default: 50)",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "sort vendors, supported criteria: (-)vendor_name, (-)source, (-)source_id, (-)domain, (-)suggestion_confidence, (-)created_at (default: vendor_name)",
            "schema": {
              "type": "string",
              "default": "vendor_name"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "filter based on a partial match vendor name, SSC domain or SCC company name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sources",
            "in": "query",
            "description": "filter by vendor sources - vendors matching ANY of the provided sources will be returned",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "source_ids",
            "in": "query",
            "description": "filter based on the source_id of the vendor record",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "vendor_name",
            "in": "query",
            "description": "filter based on the source vendor_name of the vendor record. Supports exact match only, if you need partial match use 'search' instead",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "is_dismissed",
            "in": "query",
            "description": "filter based on if the vendor has been dismissed by a user",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "is_overridden",
            "in": "query",
            "description": "filter based on if the vendor's scorecard_id has been set by a user",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A page in a list of VendorPortfolioAutomationIngestedRecords",
            "content": {
              "application/json": {
                "schema": {
                  "required": [
                    "entries",
                    "page",
                    "size"
                  ],
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "description": "processed vendor details from ingest"
                      }
                    },
                    "page": {
                      "type": "integer"
                    },
                    "size": {
                      "type": "integer"
                    }
                  },
                  "additionalProperties": false,
                  "description": "A page in a list of VendorPortfolioAutomationIngestedRecords"
                }
              }
            }
          },
          "403": {
            "description": "No response body",
            "content": {}
          }
        }
      }
    },
