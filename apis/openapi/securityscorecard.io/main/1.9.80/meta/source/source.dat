    "/v2/users/by-username/{username}": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "get user by username",
        "description": "get user by username",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "description": "username of an existing user",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "a person that uses any system at SecurityScorecard",
            "content": {
              "application/json": {
                "schema": {
                  "required": [
                    "created",
                    "customer_id",
                    "email",
                    "id",
                    "roles",
                    "username"
                  ],
                  "type": "object",
                  "properties": {
                    "id": {
                      "pattern": "^[\\da-z-]{16,}$",
                      "type": "string",
                      "description": "a user id",
                      "format": "uuid"
                    },
                    "username": {
                      "type": "string"
                    },
                    "email": {
                      "pattern": "^\\S+@\\S+\\.\\S+$",
                      "type": "string",
                      "format": "email"
                    },
                    "first_name": {
                      "type": "string"
                    },
                    "last_name": {
                      "type": "string"
                    },
                    "is_bot": {
                      "type": "boolean",
                      "description": "true if user is not human, this kind of users is used by customer integration apps"
                    },
                    "has_access_tokens": {
                      "type": "boolean",
                      "description": "true if the user has access tokens"
                    },
                    "created": {
                      "type": "string",
                      "description": "creation datetime",
                      "format": "date-time"
                    },
                    "customer_id": {
                      "type": "string",
                      "description": "the organization id of the user"
                    },
                    "roles": {
                      "type": "array",
                      "description": "collection of user access levels",
                      "items": {
                        "type": "string"
                      }
                    },
                    "vendor_id": {
                      "type": "string",
                      "description": "vendor that is associated with the user and organization"
                    },
                    "last_logged_in": {
                      "type": "string",
                      "description": "last activity date",
                      "format": "date-time"
                    },
                    "notification_last_read": {
                      "type": "string",
                      "description": "notification last read date",
                      "format": "date-time"
                    },
                    "settings": {
                      "type": "object",
                      "additionalProperties": false,
                      "description": "User settings"
                    },
                    "teams": {
                      "type": "array",
                      "description": "teams the user is member of",
                      "items": {
                        "type": "object",
                        "additionalProperties": false
                      }
                    },
                    "metadata": {
                      "type": "object",
                      "additionalProperties": false,
                      "description": "user's metadata"
                    },
                    "two_factor_enabled": {
                      "type": "boolean",
                      "description": "true if the user has 2fa enabled"
                    }
                  },
                  "additionalProperties": false,
                  "description": "a person that uses any system at SecurityScorecard"
                }
              }
            }
          }
        }
      }
    },
