            "content": {}
          }
        }
      }
    },
    "/companies/{scorecard_identifier}/expanded-risk": {
      "get": {
        "tags": [
          "scores"
        ],
        "summary": "Get a company's expanded risk",
        "parameters": [
          {
            "name": "scorecard_identifier",
            "in": "path",
            "description": "primary identifier of a company or scorecard",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example.com"
          },
          {
            "name": "category",
            "in": "query",
            "description": "optionally filter events by category",
            "schema": {
              "type": "string",
              "enum": [
                "adverse",
                "corruption",
                "financial crime",
                "high risk industry",
                "pep",
                "relative or associate",
                "sanctions",
                "state owned company",
                "terrorism",
                "watchlist"
              ]
            },
            "example": "watchlist"
          },
          {
            "name": "confidence",
            "in": "query",
            "description": "optionally filter events by confidence",
            "schema": {
              "type": "string",
              "enum": [
                "low",
                "unlikely",
                "medium",
                "high"
              ]
            },
            "example": "high"
          },
          {
            "name": "page",
            "in": "query",
            "description": "optionally specify which page of results to return",
            "schema": {
              "minimum": 1,
              "type": "integer"
            },
            "example": 1
          },
          {
            "name": "limit",
            "in": "query",
            "description": "optionally specify how many results to return",
            "schema": {
              "maximum": 5000,
              "minimum": 1,
              "type": "integer"
            },
            "example": 100
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Link": {
                "description": "URL to be used to used to fetch additional pages of results",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/ExpandedRiskEvents"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {}
          },
          "401": {
            "description": "Unauthorized",
            "content": {}
          },
          "403": {
            "description": "Company must be added to a portfolio first",
            "content": {}
          },
          "404": {
            "description": "Company not found",
            "content": {}
          },
          "default": {
            "description": "Error Payload",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/ExpandedRiskErrorResponse"
                }
              }
            }
          }
        }
      }
    },
