{
  "openapi": "3.0.1",
  "info": {
    "title": "SecurityScorecard API",
    "description": "REST API for the SecurityScorecard platform: manage portfolios, companies, scores, findings, and integrations.\n\nThis documentation is built from two kinds of sources.\n\n## Internal API docs (`servicesWithInternalApiDocs`)\n\nSpecs are fetched at runtime from other microservices/repositories. Those sections are dynamic and reflect the live specs exposed by each service.\n\n- [audit](https://users.prod.ssc.camp/api-docs)\n- [authentication-policies](https://users.prod.ssc.camp/api-docs)\n- [eval](https://eval.prod.ssc.camp/api-docs)\n- [feedback](https://measurements.prod.ssc.camp/api-docs)\n- [fluxus](https://fluxus-rest-api.prod.ssc.camp/docs/fluxus.json)\n- [footprint](https://footprint.prod.ssc.camp/api-docs)\n- [managed-services](https://users.prod.ssc.camp/api-docs)\n- [max](https://max-api.prod.ssc.camp/api-docs)\n- [measurements](https://measurements.prod.ssc.camp/api-docs)\n- [plans](https://plans.prod.ssc.camp/api-docs)\n- [subscriptions](https://subscriptions.prod.ssc.camp/api-docs)\n- [users](https://users.prod.ssc.camp/api-docs)\n- [zzzzzz](https://users.prod.ssc.camp/api-docs)\n\n## External API docs (`servicesWithExternalApiDocs`)\n\nSpecs are bundled in this repository (local Swagger 2.0 files or static definitions). They are versioned and maintained here rather than fetched from elsewhere.",
    "contact": {
      "name": "SecurityScorecard Support",
      "email": "support@securityscorecard.io"
    },
    "version": "1.9.80",
    "x-logo": {
      "url": "https://platform.securityscorecard.io/images/ssc-logo-white-stacked.svg",
      "backgroundColor": "#222830"
    },
    "x-jentic-source-url": "https://api.securityscorecard.io/api-docs/"
  },
  "servers": [
    {
      "url": "https://api.securityscorecard.io/"
    }
  ],
  "security": [
    {
      "Token": []
    }
  ],
  "paths": {
    "/portfolios": {
      "get": {
        "tags": [
          "portfolios"
        ],
        "summary": "Get all portfolios you have access to",
        "responses": {
          "200": {
            "description": "the list of portfolios",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/PortfolioList"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "portfolios"
        ],
        "summary": "Create a new portfolio",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PortfolioCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "the created portfolio",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/Portfolio"
                }
              }
            }
          }
        },
        "x-codegen-request-body-name": "body"
      }
    },
    "/portfolios/companies/bulk-upload": {
      "put": {
        "tags": [
          "Portfolio",
          "portfolios"
        ],
        "summary": "Add companies in bulk to a portfolios",
        "description": "Add companies in bulk to a portfolios",
        "parameters": [
          {
            "name": "auth_mechanism",
            "in": "query",
            "description": "propaged auth mechanism to distinguish platform requests and API integrations",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "companies",
                  "portfolios"
                ],
                "type": "object",
                "properties": {
                  "portfolios": {
                    "type": "array",
                    "description": "list of portfolio IDs",
                    "items": {
                      "type": "string"
                    }
                  },
                  "companies": {
                    "type": "array",
                    "description": "company domains",
                    "items": {
                      "type": "string"
                    }
                  },
                  "bulkInvite": {
                    "type": "boolean",
                    "description": "t/f if the upload was created via csv bulk upload"
                  },
                  "tagType": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "No response body",
            "content": {}
          }
        },
        "x-codegen-request-body-name": "body"
      }
    },
    "/portfolios/{portfolio_id}": {
      "put": {
        "tags": [
          "portfolios"
        ],
        "summary": "Edit a portfolio",
        "parameters": [
          {
            "name": "portfolio_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "55e448c4e4b0c986fd66ff12"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PortfolioEdit"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "the edited portfolio",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/Portfolio"
                }
              }
            }
          }
        },
        "x-codegen-request-body-name": "body"
      },
      "delete": {
        "tags": [
          "portfolios"
        ],
        "summary": "Delete a portfolio",
        "parameters": [
          {
            "name": "portfolio_id",
            "in": "path",
            "description": "id of a portfolio you have write access to",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "55e448c4e4b0c986fd66ff12"
          }
        ],
        "responses": {
          "204": {
            "description": "No response body",
            "content": {}
          }
        }
      }
    },
    "/portfolios/{portfolio_id}/companies": {
      "get": {
        "tags": [
          "portfolios"
        ],
        "summary": "Get all companies in a portfolio",
        "parameters": [
          {
            "name": "portfolio_id",
            "in": "path",
            "description": "a portfolio unique id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "55e448c4e4b0c986fd66ff12"
          },
          {
            "name": "grade",
            "in": "query",
            "description": "company score grade filter",
            "schema": {
              "type": "string"
            },
            "example": "A"
          },
          {
            "name": "industry",
            "in": "query",
            "description": "industry filter",
            "schema": {
              "type": "string"
            },
            "example": "retail"
          },
          {
            "name": "vulnerability",
            "in": "query",
            "description": "CVE vulnerability filter",
            "schema": {
              "type": "string"
            },
            "example": "CVE-2016-0800"
          },
          {
            "name": "issue_type",
            "in": "query",
            "description": "issue type filter",
            "schema": {
              "type": "string"
            },
            "example": "service_vuln_host_medium"
          },
          {
            "name": "status",
            "in": "query",
            "description": "company status",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "inactive"
              ]
            },
            "example": "inactive"
          },
          {
            "name": "had_breach_within_last_days",
            "in": "query",
            "description": "companies with breaches in last N days",
            "schema": {
              "type": "number"
            },
            "example": 15
          }
        ],
        "responses": {
          "200": {
            "description": "the list of companies",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/PortfolioCompaniesList"
                }
              }
            }
          }
        }
      }
    },
    "/portfolios/{id}/companies/all": {
      "delete": {
        "tags": [
          "Portfolio",
          "portfolios"
        ],
        "summary": "Remove all companies from a portfolio",
        "description": "Remove all companies from a portfolio",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "portfolio id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No response body",
            "content": {}
          }
        }
      }
    },
    "/portfolios/{portfolio_id}/companies/{domain}": {
      "put": {
        "tags": [
          "portfolios"
        ],
        "summary": "Add company to portfolio",
        "parameters": [
          {
            "name": "portfolio_id",
            "in": "path",
            "description": "a portfolio unique id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "55e448c4e4b0c986fd66ff12"
          },
          {
            "name": "domain",
            "in": "path",
            "description": "a company's internet domain. this parameter accepts any valid internet domain.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example.com"
          }
        ],
        "responses": {
          "200": {
            "description": "added company's summary",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/AddCompanyResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "portfolios"
        ],
        "summary": "Remove company from portfolio",
        "parameters": [
          {
            "name": "portfolio_id",
            "in": "path",
            "description": "id of a portfolio you have write access to",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "55e448c4e4b0c986fd66ff12"
          },
          {
            "name": "domain",
            "in": "path",
            "description": "company primary domain",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example.com"
          }
        ],
        "responses": {
          "204": {
            "description": "No response body",
            "content": {}
          }
        }
      }
    },
    "/portfolios/{portfolio_id}/expanded-risk": {
      "get": {
        "tags": [
          "portfolios"
        ],
        "summary": "Get all expanded risk events in a portfolio",
        "parameters": [
          {
            "name": "portfolio_id",
            "in": "path",
            "description": "a portfolio unique id",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "cf4f5858-2b59-41ba-853c-8a506528d491"
          },
          {
            "name": "category",
            "in": "query",
            "description": "optionally filter events by category",
            "schema": {
              "type": "string",
              "enum": [
                "adverse",
                "corruption",
                "financial crime",
                "high risk industry",
                "pep",
                "relative or associate",
                "sanctions",
                "state owned company",
                "terrorism",
                "watchlist"
              ]
            },
            "example": "watchlist"
          },
          {
            "name": "confidence",
            "in": "query",
            "description": "optionally filter events by confidence",
            "schema": {
              "type": "string",
              "enum": [
                "low",
                "unlikely",
                "medium",
                "high"
              ]
            },
            "example": "high"
          },
          {
            "name": "page",
            "in": "query",
            "description": "optionally specify which page of results to return",
            "schema": {
              "minimum": 1,
              "type": "integer"
            },
            "example": 1
          },
          {
            "name": "limit",
            "in": "query",
            "description": "optionally specify how many results to return",
            "schema": {
              "maximum": 5000,
              "minimum": 1,
              "type": "integer"
            },
            "example": 100
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Link": {
                "description": "URL to be used to used to fetch additional pages of results",
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/ExpandedRiskEvents"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {}
          },
          "401": {
            "description": "Unauthorized",
            "content": {}
          },
          "403": {
            "description": "Company must be added to a portfolio first",
            "content": {}
          },
          "404": {
            "description": "Company not found",
            "content": {}
          },
          "default": {
            "description": "Error Payload",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/ExpandedRiskErrorResponse"
                }
              }
            }
          }
        }
      }
    },
