            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "stringified object with value for column to sort by and operator",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "page number, 0 is the first page",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "page size, the amount of items per page (max: 200)",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "hide_report_body",
            "in": "query",
            "description": "pass true if we dont need the report body",
            "schema": {
              "type": "string",
              "default": "false"
            }
          },
          {
            "name": "published_at",
            "in": "query",
            "description": "published at filter, accept stringified object with date value and operator",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "customer_domain",
            "in": "query",
            "description": "Customer Domain whoes report is needed comma separated",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "is_legacy_report",
            "in": "query",
            "description": "pass false if we dont need the legacy reports",
            "schema": {
              "type": "string",
              "default": "true"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of likelihood assessment data",
