    "/companies/{scorecard_identifier}/history/factors/score": {
      "get": {
        "tags": [
          "scores"
        ],
        "summary": "Get a company's historical factor scores",
        "description": "Note: each entry in the response will have scores for each factor, you can obtain the factors currently available from [factor metadata](#tag/metadata%2Fpaths%2F~1metadata~1factors%2Fget)",
        "parameters": [
          {
            "name": "scorecard_identifier",
            "in": "path",
            "description": "primary identifier of a company or scorecard",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example.com"
          },
          {
            "name": "date_from",
            "in": "query",
            "description": "history start date",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "example": "2019-03-14"
          },
          {
            "name": "date_to",
            "in": "query",
            "description": "history end date",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "example": "2019-04-24"
          },
          {
            "name": "timing",
            "in": "query",
            "description": "date granularity, it could be \"daily\" (default), \"weekly\" or \"monthly\"",
