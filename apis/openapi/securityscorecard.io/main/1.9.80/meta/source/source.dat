        "tags": [
          "V1"
        ],
        "summary": "Gets executive summary for the customer",
        "operationId": "getV1CustomerExecutiveSummary",
        "responses": {
          "200": {
            "description": "Executive summary for the customer",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "required": [
                    "body",
                    "created_at",
                    "created_by",
                    "title",
                    "updated_at",
                    "updated_by"
                  ],
                  "type": "object",
                  "properties": {
                    "title": {
                      "type": "string",
                      "description": "Title of the executive summary"
                    },
                    "body": {
                      "type": "string",
                      "description": "Body of the executive summary"
                    },
                    "created_at": {
                      "type": "string",
                      "description": "Date and time the executive summary was created"
                    },
                    "updated_at": {
                      "type": "string",
                      "description": "Date and time the executive summary was last updated"
                    },
                    "created_by": {
                      "type": "string",
                      "description": "User who created the executive summary"
                    },
                    "updated_by": {
                      "type": "string",
                      "description": "User who last updated the executive summary"
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          "204": {
            "description": "No executive summary found.",
            "content": {}
          },
          "403": {
            "description": "Access denied due to insufficient permissions.",
            "content": {}
          }
        }
      }
    },
    "/max/v1/customer/findings": {
      "get": {
        "tags": [
          "V1"
        ],
        "summary": "Gets triaged and reported findings of a customer having the id",
        "operationId": "getV1CustomerFindings",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "page number, 0 is the first page",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "page size, the amount of items per page (max: 200)",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "stringified object with value for column to sort by and operator",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "with_hostname",
            "in": "query",
            "description": "true for findings with hostname",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "all_dates",
            "in": "query",
            "description": "Default is false and retrieves 15 days findings, if allDates is true will return 30 days findings",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "domain",
            "in": "query",
            "description": "Issue domain filter, it also accepts a comma separated list of domains",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "business_impacts",
            "in": "query",
            "description": "Business impact filter, it also accepts a comma separated list of business impacts",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "incident_likelihoods",
            "in": "query",
            "description": "Incident likelihood filter, it also accepts a comma separated list of incident likelihoods",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hostname_matches",
            "in": "query",
            "description": "true for findings that have matching vendor domain and hostname",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_severity",
            "in": "query",
            "description": "Max Severity filter, it also accepts a comma separated list of severities",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "issue_category",
            "in": "query",
            "description": "Category filter, it also accepts a comma separated list of categories",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "issue_type_name",
            "in": "query",
            "description": "Issue type filter, it also accepts a comma separated list of issue types",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "issue_type_key",
            "in": "query",
            "description": "Issue type key filter, it also accepts a comma separated list of issue types",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hostname",
            "in": "query",
            "description": "Hostname filter, it also accepts a comma separated list of hostnames",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "vendor_id",
            "in": "query",
            "description": "Vendor ID filter, it also accepts a comma separated list of vendor ids",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "vendor_domain",
            "in": "query",
            "description": "Vendor domain filter, it also accepts a comma separated list of domains",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "vendor_name",
            "in": "query",
            "description": "Vendor name filter, it also accepts a comma separated list of strings",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "last_seen",
            "in": "query",
            "description": "First seen filter, accept stringified object with date value and operator",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "first_seen",
            "in": "query",
            "description": "Last seen filter, accept stringified object with date value and operator",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "first_observed_at",
            "in": "query",
            "description": "First observed at filter, date filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cve_severity",
            "in": "query",
            "description": "CVE severity filter, it also accepts a comma separated list of severities",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cve_exploited",
            "in": "query",
            "description": "true for findings related with a known exploited CVE",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "edited_at",
            "in": "query",
            "description": "get the findings that have ben edited at a specific date",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "triaged_at",
            "in": "query",
            "description": "get the findings that have ben triaged in a specific date range",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tiers",
            "in": "query",
            "description": "The tiers to filter the findings. Optional, defaults to all tiers.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date_updated_at",
            "in": "query",
            "description": "get the findings that have ben triaged in a specific date range",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "published_at",
            "in": "query",
            "description": "get the findings that have ben triaged in a specific date range",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "word or phrase to search for",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Gets the list of findings",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "required": [
                    "entries",
                    "page",
                    "size",
                    "total"
                  ],
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false
                      }
                    },
                    "page": {
                      "type": "integer"
                    },
                    "size": {
                      "type": "integer"
                    },
                    "total": {
                      "type": "integer"
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
