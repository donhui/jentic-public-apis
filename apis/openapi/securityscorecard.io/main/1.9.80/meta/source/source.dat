    "/scorecard-tags/{id}": {
      "put": {
        "tags": [
          "Tag",
          "scorecard-tags"
        ],
        "summary": "Update a scorecard tag",
        "description": "Update a scorecard tag",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "scorecard tag id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
