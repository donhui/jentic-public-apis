      },
      "VendorScore": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "public company name"
          },
          "domain": {
            "type": "string",
            "description": "primary domain of the company"
          },
          "type": {
            "type": "string",
            "description": "company industry"
          },
          "size": {
            "type": "string",
            "description": "company estimated size (employees)"
          },
