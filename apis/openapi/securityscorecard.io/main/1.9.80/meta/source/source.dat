    "/companies/{scorecard_identifier}/summary-factors": {
      "get": {
        "tags": [
          "scores"
        ],
        "summary": "Get a company information, scorecard summary, factor scores and issue counts",
        "parameters": [
          {
            "name": "scorecard_identifier",
            "in": "path",
            "description": "primary identifier of a company or scorecard",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "example.com"
          },
          {
            "name": "severity",
            "in": "query",
            "description": "optionally filter issues by severity",
            "schema": {
              "type": "string",
              "enum": [
                "positive",
                "info",
                "low",
                "medium",
                "high"
              ]
            },
            "example": "high"
          },
          {
            "name": "severity_in",
            "in": "query",
            "description": "optionally filter issues by comma separated severity list",
            "schema": {
              "type": "string"
            },
            "example": "high,medium"
          }
        ],
        "responses": {
          "200": {
            "description": "company's summary and factors",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/CompanySummaryFactors"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request: The scorecard_identifier or the authorization header is malformed.",
            "content": {}
          },
          "401": {
            "description": "Unauthorized",
            "content": {}
          },
          "403": {
            "description": "Company needs to be added to a portfolio first",
            "content": {}
          },
          "404": {
            "description": "Company not found",
            "content": {}
          }
        }
      }
    },
