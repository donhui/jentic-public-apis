          },
          "scorecard_id": {
            "type": "string",
            "example": "aea7dae2-370f-4279-a458-4c7cb9661778"
          },
          "source_url": {
            "type": "string",
            "example": "https://example.com/scanned"
          },
          "sub_category": {
            "type": "string",
            "example": "SOE: Govt Owned Corp"
          },
          "updated_date": {
            "type": "string",
            "format": "date-time",
            "example": "2020-01-01T00:00:00Z"
          }
