              }
            }
          },
          "403": {
            "description": "No response body",
            "content": {}
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FactorList": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FactorListItem"
            }
          }
        },
        "additionalProperties": false
      },
      "FactorListItem": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "permanent key for this factor"
          },
          "name": {
            "type": "string",
            "description": "human-readable name"
          },
          "description": {
            "type": "string",
            "description": "human-readable description"
          }
        },
        "additionalProperties": false
      },
      "IssueTypeList": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssueTypeListItem"
            }
          }
        },
        "additionalProperties": false
      },
      "IssueTypeListItem": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "permanent key for this issue type"
          },
          "severity": {
            "type": "string",
            "description": "severity of this type of issue",
            "enum": [
              "POSITIVE",
              "INFO",
              "LOW",
              "MEDIUM",
              "HIGH"
            ]
          },
          "short_description": {
            "type": "string",
            "description": "human-readable name"
          },
          "long_description": {
            "type": "string",
            "description": "human-readable description"
          },
          "recommendation": {
            "type": "string",
            "description": "steps to resolve the issue"
          }
        },
        "additionalProperties": false
      },
      "CompanyScoreHistory": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "description": "list of historical scores (this can be empty if the company hasn't been scored yet)",
            "items": {
              "$ref": "#/components/schemas/CompanyScoreHistoryEntry"
            }
          }
        },
        "additionalProperties": false
      },
      "CompanyFactorScoreHistory": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "description": "list of historical factor scores (this can be empty if the company hasn't been scored yet)",
            "items": {
              "$ref": "#/components/schemas/CompanyFactorScoreHistoryEntry"
            }
          }
        },
        "additionalProperties": false
      },
      "CompanyScoreHistoryEntry": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "description": "primary domain of the company"
          },
          "date": {
            "type": "string",
            "description": "effective date for this score",
            "format": "date-time"
          },
          "score": {
            "type": "integer",
            "description": "company security score from 0 to 100"
          }
        },
        "additionalProperties": false
      },
      "CompanyFactorScoreHistoryEntry": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "description": "effective date for this score",
            "format": "date-time"
          },
          "factors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "factor key"
                },
                "score": {
                  "type": "integer",
                  "description": "company factor security score from 0 to 100"
                }
              }
            }
          }
        },
        "additionalProperties": true
      },
      "IndustryScoreHistory": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IndustryScoreHistoryEntry"
            }
          }
        },
        "additionalProperties": false
      },
      "IndustryScoreHistoryEntry": {
        "type": "object",
        "properties": {
          "industry": {
            "type": "string",
            "description": "industry (permanent key)"
          },
          "date": {
            "type": "string",
            "description": "effective date for these scores",
            "format": "date-time"
          },
          "minScore": {
            "type": "integer",
            "description": "minimum score for companies on this industry"
          },
          "maxScore": {
            "type": "integer",
            "description": "maximum score for companies on this industry"
          },
          "avgScore": {
            "type": "number",
            "description": "average score for companies on this industry"
          }
        },
        "additionalProperties": false
      },
      "BusinessImpact": {
        "type": "string",
        "description": "Business impact of the company. One of low, medium, high, critical, none",
        "enum": [
          "low",
          "medium",
          "high",
          "critical",
          "none"
        ]
      },
      "LifecycleStatus": {
        "type": "string",
        "description": "Status of the company in the company lifecycle. One of new, assess, respond, monitor",
        "enum": [
          "new",
          "assess",
          "respond",
          "monitor"
        ]
      },
      "DataTypesShared": {
        "type": "string",
        "description": "Data types shared with the company. Any of PII, PHI, sensitive, financial",
        "enum": [
          "PII",
          "PHI",
          "sensitive",
          "financial"
        ]
      },
      "Risk": {
        "type": "object",
        "properties": {
          "risk_score": {
            "type": "number",
            "description": "The aggregate score of all 1st and 2nd connections detected for a company.",
            "format": "integer",
            "example": 83.0
          }
        },
        "description": "Supply chain risk",
        "enum": [
          "low",
          "medium",
          "high",
          "critical",
          "none"
        ]
      },
      "BusinessUnit": {
        "type": "string",
        "description": "Business unit that manages the relationship with the company. One of product, engineering, HR, finance, legal, compliance, sales, marketing, IT, R&D, other",
        "enum": [
          "product",
          "engineering",
          "HR",
          "finance",
          "legal",
          "compliance",
          "sales",
          "marketing",
          "IT",
          "R&D",
          "other"
        ]
      },
      "ContractEndDate": {
        "type": "string",
        "description": "Date on which the company's contract ends",
        "format": "date-time"
      },
      "CompanyId": {
        "type": "string",
        "description": "Customer internal ID assigned to the company",
        "example": "example-id"
      },
      "InternalContact": {
        "type": "string",
        "description": "Customer internal user email who maintain the relationship with the company",
        "format": "email",
        "example": "user@example.com"
      },
      "Company": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "ID of the company",
            "format": "uuid"
          },
          "domain": {
            "type": "string",
            "description": "Domain of the company",
            "example": "example.com"
          },
          "name": {
            "type": "string",
            "description": "Name of the company",
            "example": "Example Inc"
          },
          "added_date": {
            "type": "string",
            "description": "Date on which the company started to be followed",
            "format": "date-time"
          },
          "tags": {
            "type": "array",
            "description": "Tags visible to the current user that are linked to the company",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "name": {
                  "type": "string",
                  "example": "Example-Tag-01"
                }
              }
            }
          },
          "portfolios": {
            "type": "array",
            "description": "Portfolios visible to the current user where the company belongs to",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "name": {
                  "type": "string",
                  "example": "Example Portfolio"
                }
              }
            }
          },
          "monitored": {
            "type": "boolean",
            "description": "Flag that determines if the company is monitored (belongs to at least one portfolio) or non-monitored"
          },
          "business_impact": {
            "$ref": "#/components/schemas/BusinessImpact"
          },
          "lifecycle_status": {
            "$ref": "#/components/schemas/LifecycleStatus"
          },
          "data_types_shared": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataTypesShared"
            }
          },
          "risk": {
            "$ref": "#/components/schemas/Risk"
          },
          "business_unit": {
            "$ref": "#/components/schemas/BusinessUnit"
          },
          "contract_end_date": {
            "$ref": "#/components/schemas/ContractEndDate"
          },
          "vendor_id": {
            "$ref": "#/components/schemas/CompanyId"
          },
          "internal_contact": {
            "$ref": "#/components/schemas/InternalContact"
          }
        }
      },
      "Note": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "note": {
            "type": "string",
            "example": "Example note description"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_by": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "first_name": {
                "type": "string",
                "example": "John"
              },
              "last_name": {
                "type": "string",
                "example": "Doe"
              },
              "username": {
                "type": "string",
                "example": "john_doe"
              }
            }
          },
          "updated_by": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "first_name": {
                "type": "string",
                "example": "John"
              },
              "last_name": {
                "type": "string",
                "example": "Doe"
              },
              "username": {
                "type": "string",
                "example": "john_doe"
              }
            }
          }
        }
      },
      "CollectionResponse": {
        "type": "object",
        "properties": {
          "page": {
            "minimum": 1,
            "type": "integer",
            "description": "The current page of results"
          },
          "size": {
            "type": "integer",
            "description": "The number of records to be returned per page",
            "example": 100
          },
          "total": {
            "type": "integer",
            "description": "The total number of records matching the given query",
            "example": 999
          }
        }
      },
      "Error": {
        "required": [
          "message",
          "statusCode"
        ],
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human readable message, suitable for showing in some UI",
            "example": "company must be added to a portfolio first: example.com"
          },
          "statusCode": {
            "type": "integer",
            "example": 403
          },
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "The field that is causing the error",
            "example": {
              "domain": "example.com"
            }
          },
          "key": {
            "type": "string",
            "description": "Some string to be used for further lookup",
            "example": "company_not_in_a_portfolio"
          }
        }
      },
      "ErrorResponse": {
        "required": [
          "error"
        ],
        "type": "object",
        "properties": {
          "error": {
            "$ref": "#/components/schemas/Error"
          }
        }
      },
      "Vendor": {
        "type": "object",
        "properties": {
          "company": {
            "type": "string",
            "example": "Example Ltd"
          },
          "connection_detail": {
            "type": "string",
            "example": "GET - static.image.example.com OK/200"
          },
          "domain": {
            "type": "string",
            "example": "example.com"
          },
          "industry": {
            "type": "string",
            "example": "information_services"
          },
          "observed": {
            "type": "string",
            "format": "date-time"
          },
          "score": {
            "type": "integer",
            "example": 75
          },
          "source": {
            "type": "string",
            "enum": [
              "HTTP requests",
              "Detected libraries",
              "Mail exchange",
              "Enhanced illumination"
            ]
          }
        },
        "description": "A party in the supply chain that makes goods and services available to a company"
      },
      "Vendors": {
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Vendor"
            }
          }
        },
        "description": "Vendors used by a company",
        "allOf": [
          {
            "$ref": "#/components/schemas/CollectionResponse"
          }
        ]
      },
      "Product": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Example"
          }
        },
        "description": "A product used by a vendor"
      },
      "Products": {
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Product"
            }
          }
        },
        "description": "Products used by a vendor",
        "allOf": [
          {
            "$ref": "#/components/schemas/CollectionResponse"
          }
        ]
      },
      "PortfolioVendor": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "example": "example.com"
          },
          "company": {
            "type": "string",
            "example": "Example Ltd"
          },
          "score": {
            "type": "integer",
            "example": 75
          },
          "thirty_day_change": {
            "type": "integer",
            "format": "float",
            "example": -4
          },
          "products_used": {
            "type": "integer",
            "example": 1815
          },
          "connections_count": {
            "type": "integer",
            "example": 184
          },
          "connections_percent": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer"
          }
        },
        "description": "A party in the supply chain that makes goods and services available to a company in a portfolio"
      },
      "PortfolioVendors": {
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PortfolioVendor"
            }
          }
        },
        "description": "Vendors used by companies in a portfolio",
        "allOf": [
          {
            "$ref": "#/components/schemas/CollectionResponse"
          }
        ]
      },
      "IssueContext": {
        "type": "object",
        "properties": {
          "company_incidence_percentage": {
            "type": "number",
            "description": "Percentage of similar companies that have this issue"
          },
          "findings_count_average": {
            "type": "number",
            "description": "Average number of findings of this issue in similar companies"
          }
        },
        "additionalProperties": false
      },
      "ScorePlanItem": {
        "type": "object",
        "properties": {
          "issue_type": {
            "type": "string",
            "description": "issue type key"
          },
          "title": {
            "type": "string",
            "description": "issue type title"
          },
          "findings": {
            "type": "integer",
            "description": "amount of findings of that issue type"
          },
          "remediations": {
            "type": "integer",
            "description": "amount of findings of that issue type that plan suggests to remediate"
          },
          "factor": {
            "type": "string",
            "description": "the factor this issue type belong to"
          },
          "severity": {
            "type": "string",
            "description": "the issue type severity"
          }
        },
        "additionalProperties": false,
        "description": "issue that require remediation"
      },
      "ScorePlan": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "description": "a list of issues to remediate",
            "items": {
              "$ref": "#/components/schemas/ScorePlanItem"
            }
          },
          "size": {
            "type": "integer",
            "description": "the ammount of issue types that require remediation"
          },
          "projected_total_score": {
            "type": "number",
            "description": "the projected company score if all plan issues are resolved,"
          }
        },
        "additionalProperties": false
      },
      "ReportsList": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReportsListItem"
            }
          }
        },
        "additionalProperties": false
      },
      "ReportsListItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "description": "human-readable title for this report"
          },
          "format": {
            "type": "string",
            "description": "file content format"
          },
          "report_type": {
            "type": "string",
            "description": "type of report requested"
          },
          "created_at": {
            "type": "string",
            "description": "time the report was requested",
            "format": "date-time"
          },
          "completed_at": {
            "type": "string",
            "description": "time report generation completed (only when completed)",
            "format": "date-time"
          },
          "download_url": {
            "type": "string",
            "description": "url that can be used to download the completed report (only when completed successfully). that url might respond with a redirect (302) that you'll have to follow to download the file, most http agents will do this automatically."
          }
        },
        "additionalProperties": false
      },
      "CompanyReportCreation": {
        "required": [
          "scorecard_identifier"
        ],
        "type": "object",
        "properties": {
