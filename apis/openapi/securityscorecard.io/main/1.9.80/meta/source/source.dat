        ],
        "summary": "Get customer tags count for the given customer",
        "operationId": "getV1PartnerByCustomeridTagsCount",
        "parameters": [
          {
            "name": "customer_id",
            "in": "path",
            "description": "Customer ID to get tags count for",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tiers",
            "in": "query",
            "description": "Tiers to get tags count for",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "business_impact",
            "in": "query",
            "description": "Business impact to get tags count for",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "incident_likelihood",
            "in": "query",
            "description": "Incident likelihood to get tags count for",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag_type",
            "in": "query",
            "description": "Tag types to get tags count for",
            "schema": {
              "type": "string",
              "enum": [
                "SCORECARD_BUSINESS_IMPACT",
                "SCORECARD_INCIDENT_LIKELIHOOD",
                "SCORECARD_ENGAGEMENT",
                "SCORECARD_LIFECYCLE"
              ]
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "Comma-separated list of tag names to filter vendors by",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Count of tags for the customer",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "required": [
                    "entries"
                  ],
                  "type": "object",
                  "properties": {
                    "entries": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Access denied due to insufficient permissions.",
            "content": {}
          }
        }
      }
    },
