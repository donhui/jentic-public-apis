{
    "openapi": "3.0.0",
    "info": {
        "description": "This is a sample server locationStore server.  You can find \nout more about Swagger at \n[http://swagger.io](http://swagger.io) or on \n[irc.freenode.net, #swagger](http://swagger.io/irc/).\n",
        "version": "v1",
        "title": "Swagger locationStore",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "email": "apiteam@swagger.io"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/hai2members/aws-LocationApi/v1/swagger.json"
    },
    "tags": [
        {
            "name": "location",
            "description": "Everything about your locations",
            "externalDocs": {
                "description": "Find out more",
                "url": "http://swagger.io"
            }
        }
    ],
    "paths": {
        "/location": {
            "post": {
                "tags": [
                    "location"
                ],
                "summary": "Add a new Location to the Fish",
                "operationId": "addLocation",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Location"
                            }
                        },
                        "application/xml": {
                            "schema": {
                                "$ref": "#/components/schemas/Location"
                            }
                        }
                    },
                    "description": "Location object that needs to be added to the store",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Location created"
                    },
                    "405": {
                        "description": "invalid input, object invalid"
                    },
                    "409": {
                        "description": "an existing item already exists"
                    }
                },
                "security": [
                    {
                        "location_auth": [
                            "write:locations",
                            "read:locations"
                        ]
                    }
                ]
            },
            "put": {
                "tags": [
                    "location"
                ],
                "summary": "Update an existing Location",
                "operationId": "updateLocation",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Location"
                            }
                        },
                        "application/xml": {
                            "schema": {
                                "$ref": "#/components/schemas/Location"
                            }
                        }
                    },
                    "description": "Location object that needs to be added to the Fish store",
                    "required": true
                },
                "responses": {
                    "400": {
                        "description": "Invalid ID supplied"
                    },
                    "404": {
                        "description": "Location not found"
                    },
                    "405": {
                        "description": "Validation exception"
                    }
                },
                "security": [
                    {
                        "location_auth": [
                            "write:locations",
                            "read:locations"
                        ]
                    }
                ]
            }
        },
        "/locationName/{locationName}": {
            "get": {
                "tags": [
                    "location"
                ],
                "summary": "Find location by Location Name",
                "description": "Returns a single Location Name",
                "operationId": "getLocationByName",
                "parameters": [
                    {
                        "name": "locationName",
                        "in": "path",
                        "description": "Name of location to return",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Location"
                                }
                            },
                            "application/xml": {
                                "schema": {
                                    "$ref": "#/components/schemas/Location"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid Name supplied"
                    },
                    "404": {
                        "description": "Location Name not found"
                    }
                },
                "security": [
                    {
                        "api_key": []
                    }
                ]
            }
        },
        "/location/{locationId}": {
            "get": {
                "tags": [
                    "location"
                ],
                "summary": "Find location by location",
                "description": "Returns a single location",
                "operationId": "getLocationById",
                "parameters": [
                    {
                        "name": "locationId",
                        "in": "path",
                        "description": "ID of locaation to return",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Location"
                                }
                            },
                            "application/xml": {
                                "schema": {
                                    "$ref": "#/components/schemas/Location"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid ID supplied"
                    },
                    "404": {
                        "description": "Location not found"
                    }
                },
                "security": [
                    {
                        "api_key": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "location"
                ],
                "summary": "Updates a location in the store with form data",
                "operationId": "updatelocationWithForm",
                "parameters": [
                    {
                        "name": "locationId",
                        "in": "path",
                        "description": "ID of location that needs to be updated",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "description": "Updated name of the location",
                                        "type": "string"
                                    },
                                    "status": {
                                        "description": "Updated status of the location",
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "405": {
                        "description": "Invalid input"
                    }
                },
                "security": [
                    {
                        "location_auth": [
                            "write:locations",
                            "read:locations"
                        ]
                    }
                ]
            },
            "delete": {
                "tags": [
                    "location"
                ],
                "summary": "Deletes a location",
                "operationId": "deleteLocation",
                "parameters": [
                    {
                        "name": "api_key",
                        "in": "header",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "locationId",
                        "in": "path",
                        "description": "location id to delete",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        }
                    }
                ],
                "responses": {
                    "400": {
                        "description": "Invalid ID supplied"
                    },
                    "404": {
                        "description": "Pet not found"
                    }
                },
                "security": [
                    {
                        "location_auth": [
                            "write:locations",
                            "read:locations"
                        ]
                    }
                ]
            }
        }
    },
    "externalDocs": {
        "description": "Find out more about Swagger",
        "url": "http://swagger.io"
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/hai2members/LocationApi/1.0.0"
        },
        {
            "url": "http://virtserver.swaggerhub.com/hai2members/LocationApi/1.0.0"
        }
    ],
    "components": {
        "securitySchemes": {
            "location_auth": {
                "type": "oauth2",
                "flows": {
                    "implicit": {
                        "authorizationUrl": "http://petstore.swagger.io/oauth/dialog",
                        "scopes": {
                            "write:locations": "modify locations in your account",
                            "read:locations": "read your locations"
                        }
                    }
                }
            },
            "api_key": {
                "type": "apiKey",
                "name": "api_key",
                "in": "header"
            }
        },
        "schemas": {
            "Location": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "locationName": {
                        "type": "string"
                    },
                    "Country": {
                        "type": "string"
                    },
                    "State": {
                        "type": "string"
                    },
                    "District": {
                        "type": "string"
                    },
                    "createdDateTime": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "Latitude": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "Longitude": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "PinCode": {
                        "type": "integer",
                        "format": "int32"
                    }
                },
                "xml": {
                    "name": "Location"
                }
            },
            "ApiResponse": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "type": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    }
                }
            }
        }
    }
}