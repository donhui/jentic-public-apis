                                "eu-west-1",
                                "eu-west-2",
                                "eu-south-1",
                                "eu-west-3",
                                "eu-north-1",
                                "me-south-1",
                                "sa-east-1"
                            ]
                        }
                    }
                },
                "xml": {
                    "name": "fullscan"
                }
            },
            "multiscan": {
                "type": "object",
                "required": [
                    "name",
                    "photoUrls"
                ],
                "properties": {
                    "aws_access_key_id": {
                        "type": "string",
                        "example": "<access-key>"
                    },
                    "aws_secret_access_key": {
                        "type": "string",
                        "example": "<secret-key>"
                    },
                    "services": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "example": "RDS"
                        }
                    },
                    "regions": {
                        "type": "array",
                        "items": {
