                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/fullscan"
                            }
                        }
                    },
                    "description": "gets aws assets from the credentails given",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Resultant aws resources",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "global": {
                                            "type": "object",
                                            "properties": {
                                                "S3": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object",
                                                        "properties": {
                                                            "Operation": {
                                                                "type": "string"
                                                            },
                                                            "ResourceId": {
                                                                "type": "string"
                                                            },
                                                            "Source": {
                                                                "type": "object"
                                                            },
                                                            "State": {
                                                                "type": "string"
                                                            },
                                                            "Status": {
                                                                "type": "string"
                                                            },
                                                            "Service": {
                                                                "type": "string"
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        },
                                        "regions": {
                                            "type": "object",
                                            "properties": {
                                                "RDS": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object",
                                                        "properties": {
                                                            "Operation": {
                                                                "type": "string"
                                                            },
                                                            "ResourceId": {
                                                                "type": "string"
                                                            },
                                                            "Source": {
                                                                "type": "object"
                                                            },
                                                            "State": {
                                                                "type": "string"
                                                            },
                                                            "Status": {
                                                                "type": "string"
                                                            },
                                                            "Service": {
                                                                "type": "string"
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "405": {
                        "description": "Invalid input"
                    },
                    "500": {
                        "description": "Internal server error"
                    }
                }
            }
        },
        "/multi-scan": {
            "post": {
                "tags": [
                    "scan"
                ],
                "summary": "retrieves the given services data",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/multiscan"
                            }
                        }
                    },
                    "description": "gets aws assets from the credentails and from the given services",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Resultant aws resources",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "global": {
                                            "type": "object",
                                            "properties": {
