    "components": {
        "schemas": {
            "fullscan": {
                "type": "object",
                "required": [
                    "name",
                    "photoUrls"
                ],
                "properties": {
                    "aws_access_key_id": {
                        "type": "string",
                        "example": "<access-key>"
                    },
                    "aws_secret_access_key": {
                        "type": "string",
                        "example": "<secret-key>"
                    },
                    "regions": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": [
                                "ALL_REGIONS",
                                "us-east-1",
                                "us-east-2",
                                "us-west-1",
                                "us-west-2",
                                "af-south-1",
                                "ap-east-1",
                                "ap-southeast-3",
                                "ap-south-1",
                                "ap-northeast-3",
