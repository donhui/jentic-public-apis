{
  "swagger": "2.0",
  "info": {
    "description": "Sync resources and post it to the firestore and does the data tracking\n",
    "version": "1.0.0",
    "title": "AWS Sync Service",
    "contact": {
      "email": "venkat.emmandi@netenrich.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/netenrich7/aws-asset-sync-service/1.0.0/swagger.json"
  },
  "paths": {
    "/assets-sync-jobs": {
      "post": {
        "tags": [
          "scan"
        ],
        "summary": "Sync resources and post it to the firestore and does the data tracking",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "gets data from the aws and post it to the firestore and do the tracking updates to the postgres db",
            "required": true,
            "schema": {
              "$ref": "#/definitions/aws-sync"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Resultant aws resources",
            "schema": {
              "type": "object",
              "properties": {
                "jobid": {
                  "type": "integer",
                  "example": 562627
                },
                "syncStatus": {
                  "type": "string",
                  "enum": [
                    "STARTED",
                    "FAILED"
                  ]
                },
                "statusMessage": {
                  "type": "string",
                  "enum": [
                    "SUCCESS",
                    "FAILED"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal server error",
            "schema": {
              "type": "object",
              "properties": {
                "syncStatus": {
                  "type": "string",
                  "enum": [
                    "FAILED"
                  ]
                },
                "statusMessage": {
                  "type": "string",
                  "enum": [
                    "FAILED",
                    "SUCCESS",
                    "Customized Message"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "aws-sync": {
      "type": "object",
      "required": [
        "name",
        "photoUrls"
      ],
      "properties": {
        "source": {
          "type": "string",
          "example": "<AWS>"
        },
        "syncType": {
          "type": "string",
          "example": "<fullSync>",
          "enum": [
            "fullSync"
          ]
        },
        "jobType": {
          "type": "string",
          "example": "<TRIGGERED>",
          "enum": [
            "TRIGGERED",
            "SCHEDULED"
          ]
        },
        "clientRequests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "example": "C-69-2675434782"
              },
              "instances": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "format": "int32",
                  "example": 321
                }
              }
            }
          }
        }
      },
      "xml": {
        "name": "fullscan"
      }
    }
  },
  "schemes": [
    "https",
    "http"
  ],
  "host": "virtserver.swaggerhub.com",
  "basePath": "/netenrich7/aws-asset-sync-service/1.0.0"
}