{
    "openapi": "3.0.0",
    "info": {
        "description": "Sync resources and post it to the firestore and does the data tracking\n",
        "version": "1.0.0",
        "title": "AWS Sync Service",
        "contact": {
            "email": "venkat.emmandi@netenrich.com"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/netenrich7/aws-asset-sync-service/1.0.0/swagger.json"
    },
    "paths": {
        "/assets-sync-jobs": {
            "post": {
                "tags": [
                    "scan"
                ],
                "summary": "Sync resources and post it to the firestore and does the data tracking",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/aws-sync"
                            }
                        }
                    },
                    "description": "gets data from the aws and post it to the firestore and do the tracking updates to the postgres db",
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Resultant aws resources",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "jobid": {
                                            "type": "integer",
                                            "example": 562627
                                        },
                                        "syncStatus": {
                                            "type": "string",
                                            "enum": [
                                                "STARTED",
                                                "FAILED"
                                            ]
                                        },
                                        "statusMessage": {
                                            "type": "string",
                                            "enum": [
                                                "SUCCESS",
                                                "FAILED"
                                            ]
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request"
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "syncStatus": {
                                            "type": "string",
                                            "enum": [
                                                "FAILED"
                                            ]
                                        },
                                        "statusMessage": {
                                            "type": "string",
                                            "enum": [
                                                "FAILED",
                                                "SUCCESS",
                                                "Customized Message"
                                            ]
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/netenrich7/aws-asset-sync-service/1.0.0"
        },
        {
            "url": "http://virtserver.swaggerhub.com/netenrich7/aws-asset-sync-service/1.0.0"
        }
    ],
    "components": {
        "schemas": {
            "aws-sync": {
                "type": "object",
                "required": [
                    "name",
                    "photoUrls"
                ],
                "properties": {
                    "source": {
                        "type": "string",
                        "example": "<AWS>"
                    },
                    "syncType": {
                        "type": "string",
                        "example": "<fullSync>",
                        "enum": [
                            "fullSync"
                        ]
                    },
                    "jobType": {
                        "type": "string",
                        "example": "<TRIGGERED>",
                        "enum": [
                            "TRIGGERED",
                            "SCHEDULED"
                        ]
                    },
                    "clientRequests": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "example": "C-69-2675434782"
                                },
                                "instances": {
                                    "type": "array",
                                    "items": {
                                        "type": "integer",
                                        "format": "int32",
                                        "example": 321
                                    }
                                }
                            }
                        }
                    }
                },
                "xml": {
                    "name": "fullscan"
                }
            }
        }
    }
}