  "components": {
    "securitySchemes": {
      "AccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Access-Token",
        "description": "Access token for API authentication"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "PageInfo": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          },
          "total_number": {
            "type": "integer"
          },
          "total_page": {
            "type": "integer"
          }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "campaign_id": {
            "type": "string"
          },
          "campaign_name": {
            "type": "string"
          },
          "advertiser_id": {
            "type": "string"
          },
          "objective_type": {
            "type": "string",
            "enum": [
              "TRAFFIC",
              "CONVERSIONS",
              "APP_INSTALL",
              "REACH",
              "VIDEO_VIEWS",
              "LEAD_GENERATION",
              "CATALOG_SALES",
              "ENGAGEMENT"
            ]
          },
          "budget_mode": {
            "type": "string",
            "enum": [
              "BUDGET_MODE_INFINITE",
              "BUDGET_MODE_DAY",
              "BUDGET_MODE_TOTAL"
            ]
          },
          "budget": {
            "type": "number"
          },
          "status": {
            "type": "string"
          },
          "create_time": {
            "type": "string"
          },
          "modify_time": {
            "type": "string"
          }
        }
      },
      "AdGroup": {
        "type": "object",
        "properties": {
          "adgroup_id": {
            "type": "string"
          },
          "campaign_id": {
            "type": "string"
          },
          "advertiser_id": {
            "type": "string"
          },
          "adgroup_name": {
            "type": "string"
          },
          "placement_type": {
            "type": "string"
          },
          "budget": {
            "type": "number"
          },
          "schedule_type": {
            "type": "string"
          },
          "optimization_goal": {
            "type": "string"
          },
          "bid_type": {
            "type": "string"
          },
          "bid_price": {
            "type": "number"
          },
          "billing_event": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Ad": {
        "type": "object",
        "properties": {
          "ad_id": {
            "type": "string"
          },
          "adgroup_id": {
            "type": "string"
          },
          "advertiser_id": {
            "type": "string"
          },
          "ad_name": {
            "type": "string"
          },
          "ad_text": {
            "type": "string"
          },
          "image_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "video_id": {
            "type": "string"
          },
          "call_to_action": {
            "type": "string"
          },
          "landing_page_url": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CustomAudience": {
        "type": "object",
        "properties": {
          "custom_audience_id": {
            "type": "string"
          },
          "advertiser_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "audience_type": {
            "type": "string"
          },
          "audience_sub_type": {
            "type": "string"
          },
          "cover_num": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Pixel": {
        "type": "object",
        "properties": {
          "pixel_id": {
            "type": "string"
          },
          "advertiser_id": {
            "type": "string"
          },
          "pixel_name": {
            "type": "string"
          },
          "pixel_code": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Catalog": {
        "type": "object",
        "properties": {
          "catalog_id": {
            "type": "string"
          },
          "bc_id": {
            "type": "string"
          },
          "catalog_name": {
            "type": "string"
          },
          "catalog_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "request_id": {
            "type": "string"
          }
        }
      }
    },
    "parameters": {
      "AdvertiserId": {
        "name": "advertiser_id",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Advertiser ID"
      },
      "Page": {
        "name": "page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 1
        }
      },
      "PageSize": {
        "name": "page_size",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 10,
          "maximum": 1000
        }
      }
    }
  }
}