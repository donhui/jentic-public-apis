                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/documents/{id}/activities": {
      "get": {
        "operationId": "getDocumentActivities",
        "summary": "Get document activity log",
