{
  "openapi": "3.0.3",
  "info": {
    "title": "Signaturely API",
    "description": "Electronic signature API for creating, sending, and managing documents and templates.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.signaturely.com/"
  },
  "servers": [
    {
      "url": "https://api.signaturely.com/api/v1",
      "description": "Production"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key from Settings > API in the Signaturely app"
      }
    },
    "schemas": {
      "Signer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "name": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "SignerInput": {
        "type": "object",
        "required": [
          "name",
          "email"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string"
          },
          "fields": {
            "type": "object"
          }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "sourceIP": {
            "type": "string",
            "nullable": true
          },
          "signers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Signer"
            },
            "nullable": true
          },
          "documentId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Folder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "parentId": {
            "type": "string",
            "nullable": true
          },
          "documentsCount": {
            "type": "integer"
          },
          "foldersCount": {
            "type": "integer"
          }
        }
      },
      "TeamMember": {
        "type": "object",
        "properties": {
          "appSumoStatus": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "WebhookSubscription": {
        "type": "object",
        "properties": {
          "hookUrl": {
            "type": "string",
            "format": "uri"
          },
          "event": {
            "type": "string"
          }
        }
      },
      "ActivityEntry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ApiResult": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/document_sign/api/request_by_template": {
      "post": {
        "operationId": "createDocumentFromTemplate",
        "summary": "Create document from template",
        "description": "Create and send a document for signing based on an existing template.",
        "tags": [
          "Documents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "templateId",
                  "signers"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  },
                  "templateId": {
                    "type": "string"
                  },
                  "testMode": {
                    "type": "boolean"
                  },
                  "signers": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/SignerInput"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Document"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/document_sign/api/bulk_send": {
      "post": {
        "operationId": "bulkSendDocuments",
        "summary": "Bulk send documents from template",
        "tags": [
          "Documents"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "templateId",
                  "signers"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  },
                  "templateId": {
                    "type": "string"
                  },
                  "testMode": {
                    "type": "boolean"
                  },
                  "signers": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/SignerInput"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/documents": {
      "get": {
        "operationId": "listDocuments",
        "summary": "List recent documents",
        "tags": [
          "Documents"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Document"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/documents/api/templates": {
      "get": {
        "operationId": "listTemplates",
        "summary": "List available templates",
        "tags": [
          "Templates"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Template"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/documents/{documentId}/signers": {
      "get": {
        "operationId": "getDocumentSigners",
        "summary": "Get document signers",
        "tags": [
          "Documents"
        ],
        "parameters": [
          {
            "name": "documentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Signer"
