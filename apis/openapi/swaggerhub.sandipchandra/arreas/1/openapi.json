  "paths": {
    "/arrears": {
      "post": {
        "description": "Create a new arrears",
        "tags": [
          "ArrearsController"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "createArrears",
            "schema": {
              "$ref": "#/definitions/createArrearsData"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Arrears has been created Successfully",
            "schema": {
              "$ref": "#/definitions/createArrearsResponse"
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/arrears/tenure": {
      "get": {
        "description": "Retrieve number of high Arrears for a particular asset type based on the query string parameter count, by default order by descending.",
        "tags": [
          "ArrearsController"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "count",
            "type": "integer",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved details for all arrears",
            "schema": {
              "$ref": "#/definitions/tenureArrearsResponseListData"
            }
          },
          "404": {
            "description": "Arrears not found for asset type requested"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/arrears/asset/{targetType}": {
      "get": {
        "description": "Retrieve number of high Arrears for a particular asset type based on the query string parameter count, by default order by descending.",
        "tags": [
          "ArrearsController"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "targetType",
            "type": "string",
            "enum": [
              "estate",
              "block"
            ],
            "required": true
          },
          {
            "in": "query",
            "name": "count",
            "type": "integer",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved details for all arrears",
            "schema": {
              "$ref": "#/definitions/assetArrearsResponseListData"
            }
          },
          "404": {
            "description": "Arrears not found for asset type requested"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  },
