  "paths": {
    "/account/summary": {
      "get": {
        "operationId": "getAccountSummary",
        "description": "gets total relative statistics to the estate or block",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "targettype",
            "type": "string",
            "enum": [
              "Estate",
              "Block"
            ],
            "required": true
          },
          {
            "in": "query",
            "name": "targetid",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved details",
            "schema": {
              "$ref": "#/definitions/accountSummaryResponse"
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Account Summary not found for target id and target type requested"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "post": {
        "operationId": "createAccountSummary",
        "description": "total relative statistics to the estate or block",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "targettype",
            "type": "string",
            "required": true
          },
          {
            "in": "query",
            "name": "targetid",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "assetSummary",
            "required": true,
            "schema": {
              "$ref": "#/definitions/accountSummaryRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Account Summary has been created successfully",
            "schema": {
              "$ref": "#/definitions/accountSummaryResponse"
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/account/summary/{id}": {
      "put": {
        "description": "Update total summary for the requested target id and target type",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "Account ID",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "accountSummary",
            "schema": {
              "$ref": "#/definitions/accountSummaryResponse"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/accountSummaryResponse"
            }
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Not found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/accounts/person/{targetid}": {
      "get": {
        "operationId": "getPersonAccounts",
        "description": "gets a collection of accounts for a person or organisation",
