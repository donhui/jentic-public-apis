                        }
                    },
                    {
                        "in": "query",
                        "name": "appuser_id",
                        "description": "User id",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "limit",
                        "description": "Data limit to extract. Must be less then 1000",
                        "schema": {
                            "type": "integer",
                            "maximum": 1000
                        }
                    },
                    {
                        "in": "query",
                        "name": "offset",
                        "description": "Data start",
                        "schema": {
                            "type": "integer",
                            "minimum": 0
                        }
                    },
                    {
                        "in": "query",
                        "name": "update",
