    "paths": {
        "/": {
            "get": {
                "tags": [
                    "developers"
                ],
                "summary": "NO IMPORT VIA CSV",
                "operationId": "/api/v1/users",
                "description": "Returns all the users, registered or cancelled, for a profile.|\nIt's usefull to get the id to use in other APIs\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "profile_id",
                        "description": "iCatalogue profile's id",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "api_key",
                        "description": "iCatalogue Api Key",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "format",
                        "description": "Data type to return; XML/JSON",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "xml",
                                "json"
                            ]
                        }
                    },
                    {
                        "in": "query",
                        "name": "limit",
                        "description": "Data limit to extract. Must be less then 1000",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "in": "query",
                        "name": "offset",
                        "description": "Data start",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "in": "query",
                        "name": "update",
                        "description": "Extract data changed after",
                        "schema": {
                            "type": "string",
                            "pattern": "\\d{14}"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "search results matching criteria"
                    },
                    "400": {
                        "description": "bad input parameter"
                    },
                    "401": {
                        "description": "invalid authorization"
                    },
                    "500": {
                        "description": "internal server error"
                    }
                }
            }
        }
    },
