{
  "openapi": "3.0.3",
  "info": {
    "title": "Revelator Music API",
    "description": "API for managing music distribution accounts, artists, analytics, and related lookups on the Revelator platform.",
    "version": "1.0.0",
    "contact": {
      "name": "Revelator API Support",
      "url": "https://api-docs.revelator.com/en/getting-started"
    }
  },
  "servers": [
    {
      "url": "https://api.revelator.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    },
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    { "name": "AccountManagement", "description": "Account signup, login, and tier management" },
    { "name": "UserManagement", "description": "User lookup, update, and invitation endpoints" },
    { "name": "Enterprise", "description": "Enterprise and client management" },
    { "name": "Lookups", "description": "Reference data for currencies, countries, genres, stores, etc." },
    { "name": "Artists", "description": "Artist CRUD operations" },
    { "name": "Analytics", "description": "Reporting and analytics data" }
  ],
  "paths": {
    "/partner/account/signup": {
      "post": {
        "tags": ["AccountManagement"],
        "operationId": "createChildAccount",
        "summary": "Create a child account, user, and entities",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignupResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/partner/account/upgrade": {
      "post": {
        "tags": ["AccountManagement"],
        "operationId": "upgradeAccount",
        "summary": "Modify account tier",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpgradeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account upgraded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/partner/account/login": {
      "post": {
        "tags": ["AccountManagement"],
        "operationId": "loginUser",
        "summary": "Authenticate a user and obtain a bearer token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/partner/users": {
      "get": {
        "tags": ["UserManagement"],
        "operationId": "getUserIdentifiers",
        "summary": "Get user identifiers by email",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "email" },
            "description": "Email address of the user to look up"
          }
        ],
        "responses": {
          "200": {
            "description": "User identifiers retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserIdentifiers"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "tags": ["UserManagement"],
        "operationId": "updateUser",
        "summary": "Update a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/partner/invitation": {
      "get": {
        "tags": ["UserManagement"],
        "operationId": "getInvitationInfo",
        "summary": "Get invitation information",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "email" },
            "description": "Email address of the invited user"
          },
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Invitation code"
          }
        ],
        "responses": {
          "200": {
            "description": "Invitation info retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvitationInfo"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/account/forgotpassword": {
      "post": {
        "tags": ["AccountManagement"],
        "operationId": "forgotPassword",
        "summary": "Initiate password recovery",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "email" },
            "description": "Email address for password recovery"
          },
          {
            "name": "enterpriseId",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Enterprise identifier"
          },
          {
            "name": "redirect",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "uri" },
            "description": "Redirect URL after password reset"
          }
        ],
        "responses": {
          "200": {
            "description": "Password recovery email sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/enterprise/clients/{enterpriseId}": {
      "get": {
        "tags": ["Enterprise"],
        "operationId": "getClient",
        "summary": "Get client information by enterprise ID",
        "parameters": [
          {
            "$ref": "#/components/parameters/EnterpriseIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Client info retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/enterprise/clients/all": {
      "get": {
        "tags": ["Enterprise"],
        "operationId": "listClients",
        "summary": "List all clients with pagination",
        "parameters": [
          {
            "name": "pageNumber",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1 },
            "description": "Page number for pagination"
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 25 },
            "description": "Number of records per page"
          },
          {
            "name": "orderByProperty",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Property name to sort results by"
          },
          {
            "name": "searchText",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Free-text search filter"
          }
        ],
        "responses": {
          "200": {
            "description": "Client list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClientList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/enterprises/{enterpriseId}/terminate": {
      "post": {
        "tags": ["Enterprise"],
        "operationId": "terminateEnterprise",
        "summary": "Terminate an enterprise account",
        "parameters": [
          {
            "$ref": "#/components/parameters/EnterpriseIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Account terminated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/common/lookup/currencies": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listCurrencies",
        "summary": "List available currencies",
        "responses": {
          "200": {
            "description": "Currency list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Currency" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/countries": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listCountries",
        "summary": "List countries",
        "parameters": [
          {
            "name": "isDistributionCountry",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "Filter to distribution countries only"
          },
          {
            "name": "isReportingCountry",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "Filter to reporting countries only"
          }
        ],
        "responses": {
          "200": {
            "description": "Country list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Country" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/timezoneIds": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listTimezones",
        "summary": "List available timezones",
        "responses": {
          "200": {
            "description": "Timezone list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TimezoneId" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/musicstyles": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listMusicStyles",
        "summary": "List music genres",
        "responses": {
          "200": {
            "description": "Music style list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LookupItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/pricetiers": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listPriceTiers",
        "summary": "List pricing tier options",
        "responses": {
          "200": {
            "description": "Price tier list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LookupItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/languages": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listLanguages",
        "summary": "List available languages",
        "responses": {
          "200": {
            "description": "Language list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LookupItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/stores": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listStores",
        "summary": "List digital service providers (DSPs)",
        "responses": {
          "200": {
            "description": "Store list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Store" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/contributorRoles": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listContributorRoles",
        "summary": "List contributor roles",
        "responses": {
          "200": {
            "description": "Contributor role list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LookupItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/MonetizationPolicies": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listMonetizationPolicies",
        "summary": "List monetization policies",
        "responses": {
          "200": {
            "description": "Monetization policy list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LookupItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/trackProperties": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listTrackProperties",
        "summary": "List track properties",
        "responses": {
          "200": {
            "description": "Track property list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LookupItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/ContributorRolesGroups": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listContributorRolesGroups",
        "summary": "List contributor role groups",
        "responses": {
          "200": {
            "description": "Contributor role group list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LookupItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/contactRoles": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listContactRoles",
        "summary": "List contact roles",
        "responses": {
          "200": {
            "description": "Contact role list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LookupItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/common/lookup/sources": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listSources",
        "summary": "List social media sources",
        "responses": {
          "200": {
            "description": "Source list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LookupItem" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/content/track/lookups": {
      "get": {
        "tags": ["Lookups"],
        "operationId": "listTrackLookups",
        "summary": "List track metadata options",
        "responses": {
          "200": {
            "description": "Track lookup data retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrackLookups"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/enterprises/{enterpriseId}/artists": {
      "get": {
        "tags": ["Artists"],
        "operationId": "listArtists",
        "summary": "List artists for an enterprise",
        "parameters": [
          {
            "$ref": "#/components/parameters/EnterpriseIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Artist list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Artist" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "tags": ["Artists"],
        "operationId": "createArtist",
        "summary": "Create a new artist",
        "parameters": [
          {
            "$ref": "#/components/parameters/EnterpriseIdPath"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateArtistRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Artist created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Artist"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/enterprises/{enterpriseId}/artists/summary": {
      "get": {
        "tags": ["Artists"],
        "operationId": "getArtistSummary",
        "summary": "Get artist summary for an enterprise",
        "parameters": [
          {
            "$ref": "#/components/parameters/EnterpriseIdPath"
          }
        ],
        "responses": {
          "200": {
            "description": "Artist summary retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArtistSummary"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/enterprises/{enterpriseId}/artists/{artistId}": {
      "get": {
        "tags": ["Artists"],
        "operationId": "getArtist",
        "summary": "Get a specific artist by ID",
        "parameters": [
          {
            "$ref": "#/components/parameters/EnterpriseIdPath"
          },
          {
            "name": "artistId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Unique artist identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Artist retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Artist"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/enterprises/{enterpriseId}/analytics/{dataSet}/{aggregationDimension}": {
      "get": {
        "tags": ["Analytics"],
        "operationId": "getAnalytics",
        "summary": "Get analytics data for a given dataset and aggregation dimension",
        "parameters": [
          {
            "$ref": "#/components/parameters/EnterpriseIdPath"
          },
          {
            "name": "dataSet",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The analytics dataset to query (e.g., streams, revenue)"
          },
          {
            "name": "aggregationDimension",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Dimension by which to aggregate results (e.g., country, store, track)"
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics data retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token obtained via the login endpoint. Valid for 8 hours. Pass as: Authorization: Bearer <token>"
      },
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Partner API key. Pass as: Authorization: YOUR_PARTNER_API_KEY"
      }
    },
    "parameters": {
      "EnterpriseIdPath": {
        "name": "enterpriseId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Unique enterprise identifier"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid or missing parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing authentication credentials",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          }
        },
        "required": ["code", "message"]
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "SignupRequest": {
        "type": "object",
        "required": ["email", "password", "enterpriseName", "type", "partnerApiKey", "partnerUserId"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address for the new account"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "Password for the new account"
          },
          "enterpriseName": {
            "type": "string",
            "description": "Name of the enterprise to create"
          },
          "type": {
            "type": "string",
            "description": "Account type or tier"
          },
          "partnerApiKey": {
            "type": "string",
            "description": "Partner API key for authorization"
          },
          "partnerUserId": {
            "type": "string",
            "description": "Partner-side user identifier"
          }
        }
      },
      "SignupResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "enterpriseId": {
            "type": "integer",
            "description": "ID of the newly created enterprise"
          },
          "userId": {
            "type": "integer",
            "description": "ID of the newly created user"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "UpgradeRequest": {
        "type": "object",
        "required": ["partnerAPIKey", "enterpriseId", "newType"],
        "properties": {
          "partnerAPIKey": {
            "type": "string",
            "description": "Partner API key for authorization"
          },
          "enterpriseId": {
            "type": "integer",
            "description": "Enterprise to upgrade"
          },
          "newType": {
            "type": "string",
            "description": "New account tier"
          },
          "newMaxArtists": {
            "type": "integer",
            "description": "New maximum number of artists allowed"
          },
          "newStoreAccess": {
            "type": "string",
            "description": "New store access level"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["partnerApiKey"],
        "properties": {
          "partnerUserId": {
            "type": "string",
            "description": "Partner-side user identifier (alternative to username+password)"
          },
          "username": {
            "type": "string",
            "description": "Username for authentication"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "Password for authentication"
          },
          "partnerApiKey": {
            "type": "string",
            "description": "Partner API key"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Bearer token valid for 8 hours"
          },
          "enterpriseId": {
            "type": "integer",
            "description": "Enterprise ID of the authenticated user"
          },
          "userId": {
            "type": "integer",
            "description": "User ID of the authenticated user"
          },
          "expiresIn": {
            "type": "integer",
            "description": "Token expiry time in seconds (28800 = 8 hours)"
          }
        }
      },
      "UserIdentifiers": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer"
          },
          "enterpriseId": {
            "type": "integer"
          },
          "partnerUserId": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "required": ["partnerAPIKey", "partnerUserId"],
        "properties": {
          "partnerAPIKey": {
            "type": "string",
            "description": "Partner API key for authorization"
          },
          "partnerUserId": {
            "type": "string",
            "description": "Current partner-side user identifier"
          },
          "newPartnerUserId": {
            "type": "string",
            "description": "New partner-side user identifier"
          },
          "newPassword": {
            "type": "string",
            "format": "password",
            "description": "New password for the user"
          }
        }
      },
      "InvitationInfo": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "code": {
            "type": "string"
          },
          "enterpriseId": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "description": "Invitation status"
          }
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "enterpriseId": {
            "type": "integer"
          },
          "enterpriseName": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ClientList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Client"
            }
          },
          "totalCount": {
            "type": "integer"
          },
          "pageNumber": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          }
        }
      },
      "LookupItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Display name"
          }
        }
      },
      "Currency": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "code": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "name": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          }
        }
      },
      "Country": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code"
          },
          "isDistributionCountry": {
            "type": "boolean"
          },
          "isReportingCountry": {
            "type": "boolean"
          }
        }
      },
      "TimezoneId": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "IANA timezone identifier"
          },
          "displayName": {
            "type": "string"
          }
        }
      },
      "Store": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "description": "DSP name"
          },
          "logoUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "TrackLookups": {
        "type": "object",
        "properties": {
          "genres": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LookupItem" }
          },
          "languages": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LookupItem" }
          },
          "contributorRoles": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LookupItem" }
          },
          "trackProperties": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LookupItem" }
          }
        }
      },
      "Artist": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique artist identifier"
          },
          "name": {
            "type": "string",
            "description": "Artist display name"
          },
          "enterpriseId": {
            "type": "integer"
          },
          "imageUrl": {
            "type": "string",
            "format": "uri"
          },
          "genres": {
            "type": "array",
            "items": { "type": "string" }
          },
          "createdDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateArtistRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Artist display name"
          },
          "genres": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of genre names or IDs"
          },
          "imageUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL of the artist image"
          }
        }
      },
      "ArtistSummary": {
        "type": "object",
        "properties": {
          "totalArtists": {
            "type": "integer"
          },
          "totalReleases": {
            "type": "integer"
          },
          "totalTracks": {
            "type": "integer"
          }
        }
      },
      "AnalyticsResponse": {
        "type": "object",
        "properties": {
          "dataSet": {
            "type": "string",
            "description": "The queried dataset name"
          },
          "aggregationDimension": {
            "type": "string",
            "description": "The aggregation dimension used"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AnalyticsDataPoint"
            }
          }
        }
      },
      "AnalyticsDataPoint": {
        "type": "object",
        "properties": {
          "dimension": {
            "type": "string",
            "description": "Value of the aggregation dimension"
          },
          "value": {
            "type": "number",
            "description": "Metric value"
          },
          "count": {
            "type": "integer",
            "description": "Number of records aggregated"
          }
        }
      }
    }
  }
}