{
    "openapi": "3.0.0",
    "info": {
        "description": "API for Branch details",
        "version": "1.0.1",
        "title": "Branch Service REST API",
        "termsOfService": "urn:tos",
        "contact": {
            "name": "Close Brothers",
            "url": "http://www.closebrothers.com",
            "email": "pr-technical@closebrothers.com"
        },
        "license": {},
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/closebrothersretailb/branch-service_rest_api/1.0.1/swagger.json"
    },
    "tags": [
        {
            "name": "branch",
            "description": "Branch Service"
        }
    ],
    "paths": {
        "/branch/v1/branches": {
            "get": {
                "tags": [
                    "branch"
                ],
                "summary": "Returns a list of all active branches, including the branch code, id and name.",
                "operationId": "retrieveAllBranchesUsingGET",
                "responses": {
                    "200": {
                        "description": "Returns a list of active branch summaries",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/BranchSummary"
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "An unexpected error occurred. Please try again later or contact the help desk on servicedeskmf@closebrothers.com",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/InternalError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/branch/v1/branches/{branchId}": {
            "get": {
                "tags": [
                    "branch"
                ],
                "summary": "Finds a branch by branch ID and returns details.",
                "operationId": "retrieveBranchUsingGET",
                "parameters": [
                    {
                        "name": "branchId",
                        "in": "path",
                        "description": "details for the branch to be retrieved based on this branch id.",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 38
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success. Branch found.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Branch"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Branch id not found.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "An unexpected error occurred. Please try again later or contact the help desk on servicedeskmf@closebrothers.com",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/InternalError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "//localhost:57323"
        }
    ],
    "components": {
        "schemas": {
            "Branch": {
                "type": "object",
                "properties": {
                    "address": {
                        "$ref": "#/components/schemas/BranchAddress"
                    },
                    "branchCategory": {
                        "type": "string",
                        "example": "Internal Sales",
                        "description": "Branch category"
                    },
                    "branchCluster": {
                        "type": "string",
                        "example": "Central",
                        "description": "Branch cluster"
                    },
                    "branchId": {
                        "type": "string",
                        "example": 150274,
                        "description": "Id of the Branch - sent to vendor to identify the branch"
                    },
                    "branchPhoneNumber": {
                        "type": "string",
                        "example": "01234567890",
                        "description": "The office number"
                    },
                    "branchRegion": {
                        "type": "string",
                        "example": "South",
                        "description": "Branch region"
                    },
                    "callCreditBranchId": {
                        "type": "string",
                        "example": 11,
                        "description": "The identifier send to Call Credit to identify the branch"
                    },
                    "carsAgreementPrefix": {
                        "type": "string",
                        "example": 15,
                        "description": "The branch prefix we add to agreements before they are on-boarded into CARS"
                    },
                    "carsBranchCode": {
                        "type": "string",
                        "example": "20-00",
                        "description": "The branch code in CARS"
                    },
                    "companyCode": {
                        "type": "string",
                        "example": "CBMF",
                        "description": "Determines which close brothers business - I.E. CBMF, CFCI, FAF, etc"
                    },
                    "companyPhoneNumber": {
                        "type": "string",
                        "example": "01234567891",
                        "description": "The office number"
                    },
                    "documentCompanyCode": {
                        "type": "string",
                        "example": "CCF",
                        "description": "Is CNMF, CBMS. Can probably need to be removed."
                    },
                    "email": {
                        "type": "string",
                        "example": "test@closebrothers.com",
                        "description": "The email address for the branch"
                    },
                    "experianBranchId": {
                        "type": "string",
                        "example": 12,
                        "description": "The identifier send to Experian to identify the branch"
                    },
                    "faxNumber": {
                        "type": "string",
                        "example": "01234567892",
                        "description": "The fax number for the office"
                    },
                    "feeVariantCode": {
                        "type": "string",
                        "example": "STD",
                        "description": "Code of fee variant for branch"
                    },
                    "feeVariantDescription": {
                        "type": "string",
                        "example": "Standard",
                        "description": "Description of fee variant for branch"
                    },
                    "live": {
                        "type": "boolean",
                        "example": true,
                        "description": "Is this an active branch?"
                    },
                    "locality": {
                        "type": "string",
                        "example": "South East",
                        "description": "The area used for MI reporting - I.E. NE, MID, SE, SC, WA for North East, Midlands, South East, Scotland and Wales"
                    },
                    "military": {
                        "type": "boolean",
                        "example": false,
                        "description": "Denotes whether or not the branch handles military proposals"
                    },
                    "name": {
                        "type": "string",
                        "example": "Leicester Branch",
                        "description": "The name of the branch"
                    },
                    "proposalDestination": {
                        "type": "string",
                        "example": "FPS_UK",
                        "description": "To which system will this branch send proposals - e.g. POWERCURVE, FPS etc."
                    },
                    "risPartnerCode": {
                        "type": "string",
                        "example": "JIGSAW",
                        "description": "The code identifying the RIS partner set for the branch - I.E. Jigsaw or Angelo Scottish"
                    }
                },
                "title": "Branch",
                "description": "The details for a specific branch"
            },
            "BranchAddress": {
                "type": "object",
                "properties": {
                    "buildingName": {
                        "type": "string",
                        "example": "Rose Cottage",
                        "description": "The name of the build"
                    },
                    "buildingNumber": {
                        "type": "string",
                        "example": 12,
                        "description": "The number of the building"
                    },
                    "county": {
                        "type": "string",
                        "example": "Glascow",
                        "description": "The name of the county"
                    },
                    "departmentName": {
                        "type": "string",
                        "example": "Key Accounts",
                        "description": "The name of the department"
                    },
                    "dependentLocality": {
                        "type": "string",
                        "example": "Blantyre",
                        "description": "The name of the Town - I.E. Holmfirth"
                    },
                    "doubleDependentLocality": {
                        "type": "string",
                        "example": "Tyre Industrial Estate",
                        "description": "The name of the village or small town - I.E. Meltham"
                    },
                    "organisationName": {
                        "type": "string",
                        "example": "Basingstoke",
                        "description": "The name of the branch"
                    },
                    "poBox": {
                        "type": "string",
                        "example": 10,
                        "description": "The PO BOX address"
                    },
                    "postTown": {
                        "type": "string",
                        "example": "GLASGOW",
                        "description": "The name of the postal town - I.E. Huddersfield"
                    },
                    "postcode": {
                        "type": "string",
                        "example": "AB1 CD2",
                        "description": "The postal code"
                    },
                    "street": {
                        "type": "string",
                        "example": "Bloomfield Road",
                        "description": "The name of the street"
                    },
                    "subBuildingName": {
                        "type": "string",
                        "example": "Meadow View",
                        "description": "The subsection of the building. I.E Flat, suite number"
                    },
                    "subBuildingNumber": {
                        "type": "string",
                        "example": "Floor 1",
                        "description": "The subsection of the building. I.E Flat, suite number"
                    },
                    "thoroughfare": {
                        "type": "string",
                        "example": "Cypress",
                        "description": "The name of the main road"
                    }
                },
                "title": "BranchAddress",
                "description": "The standard address elements as described by the post office"
            },
            "BranchSummary": {
                "type": "object",
                "properties": {
                    "branchCategory": {
                        "type": "string",
                        "example": "Internal Sales",
                        "description": "Branch category"
                    },
                    "branchCluster": {
                        "type": "string",
                        "example": "Central",
                        "description": "Branch cluster"
                    },
                    "branchId": {
                        "type": "string",
                        "example": 70,
                        "description": "The id of the branch"
                    },
                    "branchRegion": {
                        "type": "string",
                        "example": "South",
                        "description": "Branch region"
                    },
                    "carsBranchCode": {
                        "type": "string",
                        "example": "20-00",
                        "description": "The branch code in CARS"
                    },
                    "name": {
                        "type": "string",
                        "example": "Basingstoke",
                        "description": "The name of the branch"
                    },
                    "proposalDestination": {
                        "type": "string",
                        "example": "FPS_UK",
                        "description": "The system to which proposals will be submitted for this branch"
                    }
                },
                "title": "BranchSummary",
                "description": "A short summary for specific branch, usually used when data on a set of branches is provided as summary."
            },
            "Error": {
                "type": "object",
                "properties": {
                    "errorcode": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    }
                },
                "title": "Error",
                "description": "An error message, with associated error code."
            },
            "Errors": {
                "type": "object",
                "properties": {
                    "errors": {
                        "type": "array",
                        "description": "The error messages and associated error codes that occurred.",
                        "items": {
                            "$ref": "#/components/schemas/Error"
                        }
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "description": "The timestamp at which the error occurred."
                    },
                    "uuid": {
                        "type": "string",
                        "description": "The uuid (X-CBMF-UUID) of the request during which the error occurred."
                    }
                },
                "title": "Errors",
                "description": "A set of errors, with messages, associated error codes and additional info. (Multiple error messages may occur at  once, for example, during validation of an input object model with multiple invalid field values.)"
            },
            "InternalError": {
                "type": "object",
                "properties": {
                    "error": {
                        "$ref": "#/components/schemas/Error"
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "description": "The timestamp at which the error occurred."
                    },
                    "uuid": {
                        "type": "string",
                        "description": "The uuid (X-CBMF-UUID) of the request during which the error occurred."
                    }
                },
                "title": "InternalError",
                "description": "An error, with associated message, error code and additional info."
            }
        }
    }
}