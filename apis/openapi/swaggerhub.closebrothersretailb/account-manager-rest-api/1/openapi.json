{
    "openapi": "3.0.0",
    "info": {
        "description": "Account Manager details",
        "version": "1",
        "title": "Account Manager REST API",
        "termsOfService": "urn:tos",
        "contact": {
            "name": "Close Brothers",
            "url": "http://www.closebrothers.com",
            "email": "pr-technical@closebrothers.com"
        },
        "license": {},
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/closebrothersretailb/account-manager_rest_api/1/swagger.json"
    },
    "tags": [
        {
            "name": "account-manager-service",
            "description": "Account Manager Service"
        }
    ],
    "paths": {
        "/account-manager/v1/account-managers": {
            "get": {
                "tags": [
                    "account-manager-service"
                ],
                "summary": "Returns a list of account managers (in summary view) with the given branch id, or, if the branch id is not specified, returns a list of all account managers for all known branches.",
                "operationId": "getAccountManagers",
                "parameters": [
                    {
                        "name": "branchId",
                        "in": "query",
                        "description": "Restricts the list of returned account managers by branch id. If omitted, all account managers will be returned. If not a valid branch id, an empty list will be returned.",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 38
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Returns the list of matching account manager summaries.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/AccountManagerSummary"
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "An unexpected error occurred. Please try again later or contact the help desk on servicedeskmf@closebrothers.com",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/InternalError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/account-manager/v1/account-managers/{accountManagerId}": {
            "get": {
                "tags": [
                    "account-manager-service"
                ],
                "summary": "Returns the Account Manager detail view for the account manager with the given id.",
                "operationId": "getAccountManagerDetail",
                "parameters": [
                    {
                        "name": "accountManagerId",
                        "in": "path",
                        "description": "The unique id of the account manager to be returned.",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 38
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Returns the detail view of the account manager with the given id.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AccountManager"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Account manager id not found.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "An unexpected error occurred. Please try again later or contact the help desk on servicedeskmf@closebrothers.com.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/InternalError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "//localhost:8732"
        }
    ],
    "components": {
        "schemas": {
            "AccountManager": {
                "type": "object",
                "properties": {
                    "accountManagerId": {
                        "type": "string",
                        "example": 94846,
                        "description": "Account Manager ID"
                    },
                    "accountManagerName": {
                        "type": "string",
                        "example": "John Smith",
                        "description": "Account Manager Name"
                    },
                    "branchId": {
                        "type": "string",
                        "example": 70,
                        "description": "Branch Id"
                    },
                    "branchName": {
                        "type": "string",
                        "example": "Basingstoke",
                        "description": "Branch Name"
                    },
                    "carsLuagent01Code": {
                        "type": "string",
                        "example": "47-900",
                        "description": "CARS short code for account manager"
                    },
                    "companyCode": {
                        "type": "string",
                        "example": "CMF",
                        "description": "CBMF company this dealer belongs to"
                    },
                    "emailAddress": {
                        "type": "string",
                        "example": "johnsmith@hotmail.com",
                        "description": " Email Address"
                    },
                    "live": {
                        "type": "boolean",
                        "example": true,
                        "description": "Whether this account manager is currently active."
                    },
                    "phoneNumber": {
                        "type": "string",
                        "example": "01234567890",
                        "description": " Phone number"
                    },
                    "salesManager": {
                        "type": "boolean",
                        "example": true,
                        "description": "Whether this account manager is also a sales manager"
                    }
                },
                "title": "AccountManager",
                "description": "Account manager detail view."
            },
            "AccountManagerSummary": {
                "type": "object",
                "properties": {
                    "accountManagerId": {
                        "type": "string",
                        "example": 94846,
                        "description": "The unique id of this account manager."
                    },
                    "accountManagerName": {
                        "type": "string",
                        "example": "John Smith",
                        "description": "The human-readable name of this account manager."
                    },
                    "branchId": {
                        "type": "string",
                        "example": 70,
                        "description": "The unique id of this account manager's branch."
                    },
                    "branchName": {
                        "type": "string",
                        "example": "Basingstoke",
                        "description": "The human-readable name of this account manager's branch."
                    }
                },
                "title": "AccountManagerSummary",
                "description": "Account manager summary view."
            },
            "Error": {
                "type": "object",
                "properties": {
                    "errorcode": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    }
                },
                "title": "Error",
                "description": "An error message, with associated error code."
            },
            "Errors": {
                "type": "object",
                "properties": {
                    "errors": {
                        "type": "array",
                        "description": "The error messages and associated error codes that occurred.",
                        "items": {
                            "$ref": "#/components/schemas/Error"
                        }
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "description": "The timestamp at which the error occurred."
                    },
                    "uuid": {
                        "type": "string",
                        "description": "The uuid (X-CBMF-UUID) of the request during which the error occurred."
                    }
                },
                "title": "Errors",
                "description": "A set of errors, with messages, associated error codes and additional info. (Multiple error messages may occur at  once, for example, during validation of an input object model with multiple invalid field values.)"
            },
            "InternalError": {
                "type": "object",
                "properties": {
                    "error": {
                        "$ref": "#/components/schemas/Error"
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "description": "The timestamp at which the error occurred."
                    },
                    "uuid": {
                        "type": "string",
                        "description": "The uuid (X-CBMF-UUID) of the request during which the error occurred."
                    }
                },
                "title": "InternalError",
                "description": "An error, with associated message, error code and additional info."
            }
        }
    }
}