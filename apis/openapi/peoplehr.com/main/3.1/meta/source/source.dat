{
  "openapi": "3.0.3",
  "info": {
    "title": "PeopleHR API",
    "version": "3.1",
    "description": "PeopleHR API for HR administration. All API calls need the API key to be passed along with the JSON data sent as part of the HTTP request. Rate limit: 30 calls per minute per IP address.",
    "contact": {
      "name": "PeopleWeb API Support",
      "url": "https://www.peoplehr.com/",
      "email": "customerservices@peoplehr.com"
    },
    "termsOfService": "https://www.peoplehr.com/terms.html",
    "x-jentic-source-url": "https://apidocs.peoplehr.com/"
  },
  "servers": [
    {
      "url": "https://api.peoplehr.net/v3.1"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "APIKey",
        "in": "header",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "ApiRequest": {
        "type": "object",
        "required": [
          "APIKey",
          "Action"
        ],
        "properties": {
          "APIKey": {
            "type": "string",
            "description": "API key for authentication"
          },
          "Action": {
            "type": "string",
            "description": "The action to perform"
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "isError": {
            "type": "boolean"
          },
          "Status": {
            "type": "integer",
            "description": "0=Success, 2=Invalid API Key, 5=API key does not exist"
          },
          "Message": {
            "type": "string"
          },
          "Result": {
            "type": "object"
          }
        }
      },
      "EmployeeDetail": {
        "type": "object",
        "properties": {
          "EmployeeId": {
            "$ref": "#/components/schemas/FieldValue"
          },
          "FirstName": {
            "$ref": "#/components/schemas/FieldValue"
          },
          "LastName": {
            "$ref": "#/components/schemas/FieldValue"
          },
          "EmailId": {
            "$ref": "#/components/schemas/FieldValue"
          },
          "Department": {
            "$ref": "#/components/schemas/FieldValue"
          },
          "JobRole": {
            "$ref": "#/components/schemas/FieldValue"
          },
          "StartDate": {
            "$ref": "#/components/schemas/FieldValue"
          },
          "Company": {
            "$ref": "#/components/schemas/FieldValue"
          },
          "Location": {
            "$ref": "#/components/schemas/FieldValue"
          },
          "ReportsTo": {
            "$ref": "#/components/schemas/FieldValue"
          }
        }
      },
      "FieldValue": {
        "type": "object",
        "properties": {
          "DisplayValue": {
            "type": "string"
          },
          "FieldName": {
            "type": "string"
          },
          "FieldId": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/Employee": {
      "post": {
        "summary": "Check Authentication",
        "operationId": "Employee_CheckAuthentication",
        "tags": [
          "Employee"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "APIKey",
                  "Action"
                ],
                "properties": {
                  "APIKey": {
                    "type": "string",
                    "description": "API key for authentication"
                  },
                  "Action": {
                    "type": "string",
                    "description": "The action to perform",
                    "example": "CheckAuthentication"
                  },
                  "EmailAddress": {
                    "type": "string"
                  },
                  "Password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
      }
    },
