{
  "openapi": "3.0.3",
  "info": {
    "title": "Codeforces API",
    "description": "Codeforces competitive programming platform API. Provides access to contest data, user profiles, problem sets, ratings, standings, and blog entries.",
    "version": "1.0.0",
    "contact": {
      "name": "Codeforces",
      "url": "https://codeforces.com"
    },
    "x-jentic-source-url": "https://codeforces.com/apiHelp"
  },
  "servers": [
    {
      "url": "https://codeforces.com/api",
      "description": "Codeforces API Production"
    }
  ],
  "tags": [
    {
      "name": "Blog",
      "description": "Blog entry operations"
    },
    {
      "name": "Contest",
      "description": "Contest information and standings"
    },
    {
      "name": "Problemset",
      "description": "Problem set browsing"
    },
    {
      "name": "RecentActions",
      "description": "Recent site activity"
    },
    {
      "name": "User",
      "description": "User profile and rating data"
    }
  ],
  "security": [],
  "paths": {
    "/blogEntry.comments": {
      "get": {
        "tags": ["Blog"],
        "summary": "Get blog entry comments",
        "description": "Returns a list of comments to the specified blog entry.",
        "operationId": "getBlogEntryComments",
        "parameters": [
          {
            "name": "blogEntryId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Blog entry ID"
          },
          {
            "name": "apiKey",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "API key for authorized requests"
          },
          {
            "name": "time",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Current time in UNIX format (for authorized requests)"
          },
          {
            "name": "apiSig",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "API signature hash (for authorized requests)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of comments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["OK", "FAILED"]
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Comment"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/blogEntry.view": {
      "get": {
        "tags": ["Blog"],
        "summary": "View blog entry",
        "description": "Returns a blog entry.",
        "operationId": "viewBlogEntry",
        "parameters": [
          {
            "name": "blogEntryId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Blog entry ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Blog entry",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["OK", "FAILED"]
                    },
                    "result": {
                      "$ref": "#/components/schemas/BlogEntry"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/contest.hacks": {
      "get": {
        "tags": ["Contest"],
        "summary": "Get contest hacks",
        "description": "Returns list of hacks in the specified contest. Full information is available only after the contest ends.",
        "operationId": "getContestHacks",
        "parameters": [
          {
            "name": "contestId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Contest ID"
          },
          {
            "name": "asManager",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "If true, returns hacks as contest manager (requires authorization)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of hacks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["OK", "FAILED"]
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Hack"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/contest.list": {
      "get": {
        "tags": ["Contest"],
        "summary": "List contests",
        "description": "Returns information about all available contests.",
        "operationId": "listContests",
        "parameters": [
          {
            "name": "gym",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "If true, gym contests are returned; otherwise, regular contests."
          }
        ],
        "responses": {
          "200": {
            "description": "List of contests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["OK", "FAILED"]
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Contest"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/contest.ratingChanges": {
      "get": {
        "tags": ["Contest"],
        "summary": "Get contest rating changes",
        "description": "Returns rating changes after the contest.",
        "operationId": "getContestRatingChanges",
        "parameters": [
          {
            "name": "contestId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Contest ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of rating changes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["OK", "FAILED"]
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/RatingChange"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/contest.standings": {
      "get": {
        "tags": ["Contest"],
        "summary": "Get contest standings",
        "description": "Returns the description of the contest and the requested part of the standings.",
        "operationId": "getContestStandings",
        "parameters": [
          {
            "name": "contestId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Contest ID"
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "1-based index of the standings row to start from"
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of standings rows to return"
          },
          {
            "name": "handles",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Semicolon-separated list of handles to show in standings"
          },
          {
            "name": "room",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Room number for schoolchildren contests"
          },
          {
            "name": "showUnofficial",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "If true, all participants (including virtual/out of competition) are shown"
          },
          {
            "name": "asManager",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "If true, returns standings as contest manager"
          }
        ],
        "responses": {
          "200": {
            "description": "Contest standings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["OK", "FAILED"]
                    },
                    "result": {
                      "type": "object",
                      "properties": {
                        "contest": {
                          "$ref": "#/components/schemas/Contest"
                        },
                        "problems": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Problem"
                          }
                        },
                        "rows": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/RanklistRow"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/contest.status": {
      "get": {
        "tags": ["Contest"],
        "summary": "Get contest submissions",
        "description": "Returns submissions for specified contest. Optionally can return submissions of a single user.",
        "operationId": "getContestStatus",
        "parameters": [
          {
            "name": "contestId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Contest ID"
          },
          {
            "name": "handle",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Codeforces user handle"
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "1-based index of the first submission to return"
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of submissions to return"
          },
          {
            "name": "asManager",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "If true, returns submissions as contest manager"
          }
        ],
        "responses": {
          "200": {
            "description": "List of submissions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["OK", "FAILED"]
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Submission"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/problemset.problems": {
      "get": {
        "tags": ["Problemset"],
        "summary": "Get problemset problems",
        "description": "Returns all problems from problemset. Problems can be filtered by tags.",
        "operationId": "getProblemsetProblems",
        "parameters": [
          {
            "name": "tags",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Semicolon-separated list of tags"
          },
          {
            "name": "problemsetName",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Custom problemset short name (e.g., 'acmsguru')"
          }
        ],
        "responses": {
          "200": {
            "description": "Problems and problem statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["OK", "FAILED"]
                    },
                    "result": {
                      "type": "object",
                      "properties": {
                        "problems": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Problem"
                          }
                        },
                        "problemStatistics": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/ProblemStatistics"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/problemset.recentStatus": {
      "get": {
        "tags": ["Problemset"],
        "summary": "Get recent submissions",
