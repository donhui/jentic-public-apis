  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "apiKey",
        "description": "Codeforces API key. Required for authorized methods. Used with apiSig and time parameters for HMAC-based authentication. Generate at https://codeforces.com/settings/api"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "handle": {
            "type": "string",
            "description": "Codeforces user handle"
          },
          "email": {
            "type": "string",
            "description": "User email (only for authorized requests)"
          },
          "vkId": {
            "type": "string"
          },
          "openId": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "organization": {
            "type": "string"
          },
          "contribution": {
            "type": "integer",
            "description": "User contribution value"
          },
          "rank": {
            "type": "string",
            "description": "Localized rank name"
          },
          "rating": {
            "type": "integer",
            "description": "Current rating"
          },
          "maxRank": {
            "type": "string",
            "description": "Localized maximum rank name"
          },
          "maxRating": {
            "type": "integer",
            "description": "Maximum rating achieved"
          },
          "lastOnlineTimeSeconds": {
            "type": "integer",
            "description": "Time of last visit (UNIX timestamp)"
          },
          "registrationTimeSeconds": {
            "type": "integer",
            "description": "Registration time (UNIX timestamp)"
          },
          "friendOfCount": {
            "type": "integer"
          },
          "avatar": {
            "type": "string",
            "description": "URL to user avatar"
          },
          "titlePhoto": {
            "type": "string",
            "description": "URL to user title photo"
          }
        },
        "required": ["handle"]
      },
      "BlogEntry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "originalLocale": {
            "type": "string"
          },
          "creationTimeSeconds": {
            "type": "integer"
          },
          "authorHandle": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "modificationTimeSeconds": {
            "type": "integer"
          },
          "allowViewHistory": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rating": {
            "type": "integer"
          }
        },
        "required": ["id", "authorHandle", "title"]
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "creationTimeSeconds": {
            "type": "integer"
          },
          "commentatorHandle": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "parentCommentId": {
            "type": "integer"
          },
          "rating": {
            "type": "integer"
          }
        },
        "required": ["id", "commentatorHandle", "text"]
      },
      "Contest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["CF", "IOI", "ICPC"]
          },
          "phase": {
            "type": "string",
            "enum": ["BEFORE", "CODING", "PENDING_SYSTEM_TEST", "SYSTEM_TEST", "FINISHED"]
          },
          "frozen": {
            "type": "boolean"
          },
          "durationSeconds": {
            "type": "integer"
          },
          "startTimeSeconds": {
            "type": "integer"
          },
          "relativeTimeSeconds": {
            "type": "integer"
          },
          "preparedBy": {
            "type": "string"
          },
          "websiteUrl": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "difficulty": {
            "type": "integer"
          },
          "kind": {
            "type": "string"
          },
          "icpcRegion": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "season": {
            "type": "string"
          }
        },
        "required": ["id", "name", "type", "phase"]
      },
      "Problem": {
        "type": "object",
        "properties": {
          "contestId": {
            "type": "integer"
          },
          "problemsetName": {
            "type": "string"
          },
          "index": {
            "type": "string",
            "description": "Problem short name, usually a letter or letter with digit"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["PROGRAMMING", "QUESTION"]
          },
          "points": {
            "type": "number"
          },
          "rating": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["index", "name", "type"]
      },
      "ProblemStatistics": {
        "type": "object",
        "properties": {
          "contestId": {
            "type": "integer"
          },
          "index": {
            "type": "string"
          },
          "solvedCount": {
            "type": "integer"
          }
        },
        "required": ["index", "solvedCount"]
      },
      "Submission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "contestId": {
            "type": "integer"
          },
          "creationTimeSeconds": {
            "type": "integer"
          },
          "relativeTimeSeconds": {
            "type": "integer"
          },
          "problem": {
            "$ref": "#/components/schemas/Problem"
          },
          "author": {
            "$ref": "#/components/schemas/Party"
          },
          "programmingLanguage": {
            "type": "string"
          },
          "verdict": {
            "type": "string",
            "enum": ["FAILED", "OK", "PARTIAL", "COMPILATION_ERROR", "RUNTIME_ERROR", "WRONG_ANSWER", "PRESENTATION_ERROR", "TIME_LIMIT_EXCEEDED", "MEMORY_LIMIT_EXCEEDED", "IDLENESS_LIMIT_EXCEEDED", "SECURITY_VIOLATED", "CRASHED", "INPUT_PREPARATION_CRASHED", "CHALLENGED", "SKIPPED", "TESTING", "REJECTED"]
          },
          "testset": {
            "type": "string",
            "enum": ["SAMPLES", "PRETESTS", "TESTS", "CHALLENGES", "TESTS1", "TESTS2", "TESTS3", "TESTS4", "TESTS5", "TESTS6", "TESTS7", "TESTS8", "TESTS9", "TESTS10"]
          },
          "passedTestCount": {
            "type": "integer"
          },
          "timeConsumedMillis": {
            "type": "integer"
          },
          "memoryConsumedBytes": {
            "type": "integer"
          },
          "points": {
            "type": "number"
          }
        },
        "required": ["id", "problem", "author", "programmingLanguage"]
      },
      "Party": {
        "type": "object",
        "properties": {
          "contestId": {
            "type": "integer"
          },
          "members": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Member"
            }
          },
          "participantType": {
            "type": "string",
            "enum": ["CONTESTANT", "PRACTICE", "VIRTUAL", "MANAGER", "OUT_OF_COMPETITION"]
          },
          "teamId": {
            "type": "integer"
          },
          "teamName": {
            "type": "string"
          },
          "ghost": {
            "type": "boolean"
          },
          "room": {
            "type": "integer"
          },
          "startTimeSeconds": {
            "type": "integer"
          }
        },
        "required": ["members", "participantType"]
      },
      "Member": {
        "type": "object",
        "properties": {
          "handle": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "required": ["handle"]
      },
      "RatingChange": {
        "type": "object",
        "properties": {
          "contestId": {
            "type": "integer"
          },
          "contestName": {
            "type": "string"
          },
          "handle": {
            "type": "string"
          },
          "rank": {
            "type": "integer"
          },
          "ratingUpdateTimeSeconds": {
            "type": "integer"
          },
          "oldRating": {
            "type": "integer"
          },
          "newRating": {
            "type": "integer"
          }
        },
        "required": ["contestId", "contestName", "handle", "rank", "oldRating", "newRating"]
      },
      "Hack": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "creationTimeSeconds": {
            "type": "integer"
          },
          "hacker": {
            "$ref": "#/components/schemas/Party"
          },
          "defender": {
            "$ref": "#/components/schemas/Party"
          },
          "verdict": {
            "type": "string",
            "enum": ["HACK_SUCCESSFUL", "HACK_UNSUCCESSFUL", "INVALID_INPUT", "GENERATOR_INCOMPILABLE", "GENERATOR_CRASHED", "IGNORED", "TESTING", "OTHER"]
          },
          "problem": {
            "$ref": "#/components/schemas/Problem"
          },
          "test": {
            "type": "string"
          },
          "judgeProtocol": {
            "type": "object",
            "properties": {
              "manual": {
                "type": "string"
              },
              "protocol": {
                "type": "string"
              },
              "verdict": {
                "type": "string"
              }
            }
          }
        },
        "required": ["id", "hacker", "defender"]
      },
      "RanklistRow": {
        "type": "object",
        "properties": {
          "party": {
            "$ref": "#/components/schemas/Party"
          },
          "rank": {
            "type": "integer"
          },
          "points": {
            "type": "number"
          },
          "penalty": {
            "type": "integer"
          },
          "successfulHackCount": {
            "type": "integer"
          },
          "unsuccessfulHackCount": {
            "type": "integer"
          },
          "problemResults": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProblemResult"
            }
          },
          "lastSubmissionTimeSeconds": {
            "type": "integer"
          }
        },
        "required": ["party", "rank", "points"]
      },
      "ProblemResult": {
        "type": "object",
        "properties": {
          "points": {
            "type": "number"
          },
          "penalty": {
            "type": "integer"
          },
          "rejectedAttemptCount": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": ["PRELIMINARY", "FINAL"]
          },
          "bestSubmissionTimeSeconds": {
            "type": "integer"
          }
        },
        "required": ["points", "rejectedAttemptCount", "type"]
      },
      "RecentAction": {
        "type": "object",
        "properties": {
          "timeSeconds": {
            "type": "integer"
          },
          "blogEntry": {
            "$ref": "#/components/schemas/BlogEntry"
          },
          "comment": {
            "$ref": "#/components/schemas/Comment"
          }
        },
        "required": ["timeSeconds"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["FAILED"]
          },
          "comment": {
            "type": "string",
            "description": "Error description"
          }
        },
        "required": ["status", "comment"]
      }
    }
  }
}
