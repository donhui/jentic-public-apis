    "/user.ratedList": {
      "get": {
        "tags": ["User"],
        "summary": "Get rated user list",
        "description": "Returns the list of all rated users sorted by decreasing rating.",
        "operationId": "getUserRatedList",
        "parameters": [
          {
            "name": "activeOnly",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "If true, only users who participated in at least one rated contest in the last month are returned"
          },
          {
            "name": "includeRetired",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "If true, retired users are included"
          },
          {
            "name": "contestId",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "If specified, only participants of this contest are returned"
          }
        ],
        "responses": {
          "200": {
            "description": "Rated user list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": ["OK", "FAILED"]
                    },
                    "result": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/User"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
