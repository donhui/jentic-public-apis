    "/user.info": {
      "get": {
        "tags": ["User"],
        "summary": "Get user info",
        "description": "Returns information about one or more users.",
        "operationId": "getUserInfo",
        "parameters": [
          {
            "name": "handles",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Semicolon-separated list of handles (max 10000)"
          },
          {
            "name": "checkHistoricHandles",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "If true, historic handles are also searched"
