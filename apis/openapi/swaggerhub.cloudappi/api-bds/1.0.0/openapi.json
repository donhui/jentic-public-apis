          "bb"
        ],
        "operationId": "newContractBB",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "request_body",
            "schema": {
              "$ref": "#/definitions/bb_new_contract_request"
            },
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "schema": {
              "$ref": "#/definitions/standard_bb_result"
            },
            "examples": {
              "application/json": {
                "result": {
                  "http_code": 200,
                  "status": "OK",
                  "timestamp": "16-03-2020 11:23:05",
                  "info": "Request made successfully",
                  "data": {
                    "DataPercentByTerm": {
                      "PERCENT_INTERES": 0.8,
                      "COD_TERM": 1
                    },
                    "LTV": 0.9,
                    "CAPTACION": "N"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/responses/bad_request_response"
          },
          "401": {
            "$ref": "#/responses/unauthorized_response"
          },
          "403": {
            "$ref": "#/responses/forbidden_response"
          },
          "429": {
            "$ref": "#/responses/too_many_requests_response"
          },
          "default": {
            "$ref": "#/responses/server_error_response"
          }
        }
      }
    },
