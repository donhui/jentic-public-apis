                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/standard_bb_result"
                                },
                                "examples": {
                                    "response": {
                                        "value": {
                                            "result": {
                                                "http_code": 200,
                                                "status": "OK",
                                                "timestamp": "16-03-2020 11:23:05",
                                                "info": "Request made successfully",
                                                "data": {
                                                    "DataPercentByTerm": {
                                                        "PERCENT_INTERES": 0.8,
                                                        "COD_TERM": 1
                                                    },
