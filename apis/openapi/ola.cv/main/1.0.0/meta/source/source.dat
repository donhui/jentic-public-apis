{
  "openapi": "3.0.3",
  "info": {
    "title": "Ola CV Domain API",
    "version": "1.0.0",
    "description": "API for managing .cv domains, DNS zones, DNS records, and contacts on the Ola.cv platform.",
    "x-jentic-source-url": "https://docs.ola.cv/"
  },
  "servers": [
    {
      "url": "https://developer.ola.cv/api/v1",
      "description": "Production API server"
    }
  ],
  "paths": {
    "/contacts": {
      "get": {
        "operationId": "listContacts",
        "summary": "List contacts",
        "tags": ["Contacts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Contact" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createContact",
        "summary": "Create a contact",
        "tags": ["Contacts"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Contact created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/Contact" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "operationId": "getContact",
        "summary": "Get a contact by ID",
        "tags": ["Contacts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/Contact" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Contact not found" }
        }
      },
      "delete": {
        "operationId": "deleteContact",
        "summary": "Delete a contact",
        "tags": ["Contacts"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Contact not found" }
        }
      }
    },
    "/domains/check": {
      "post": {
        "operationId": "checkDomainAvailability",
        "summary": "Check domain availability",
        "tags": ["Domains"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "fees",
            "in": "query",
            "schema": { "type": "string", "enum": ["registration", "all"] }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["domains"],
                "properties": {
                  "domains": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Domain availability results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/domains": {
      "get": {
        "operationId": "listDomains",
        "summary": "List registered domains",
        "tags": ["Domains"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of domains",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Domain" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "registerDomain",
        "summary": "Register a new domain",
        "tags": ["Domains"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DomainRegistrationInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Domain registered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/Domain" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/domains/{id}": {
      "get": {
        "operationId": "getDomain",
        "summary": "Get domain details",
        "tags": ["Domains"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Domain details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/Domain" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Domain not found" }
        }
      },
      "post": {
        "operationId": "updateDomain",
        "summary": "Update domain",
        "tags": ["Domains"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DomainUpdateInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Domain updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/Domain" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Domain not found" }
        }
      }
    },
    "/domains/{id}/renew": {
      "post": {
        "operationId": "renewDomain",
        "summary": "Renew a domain",
        "tags": ["Domains"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "registrant"],
                "properties": {
                  "name": { "type": "string" },
                  "registrant": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Domain renewed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/Domain" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Domain not found" }
        }
      }
    },
    "/domains/{id}/zone": {
      "get": {
        "operationId": "getDomainZone",
        "summary": "Get DNS zone for a domain",
        "tags": ["DNS Zones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "DNS zone for domain",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/Zone" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Domain not found" }
        }
      }
    },
    "/zones": {
      "get": {
        "operationId": "listZones",
        "summary": "List DNS zones",
        "tags": ["DNS Zones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of zones",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Zone" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/zones/{id}": {
      "get": {
        "operationId": "getZone",
        "summary": "Get a DNS zone",
        "tags": ["DNS Zones"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Zone details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/Zone" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Zone not found" }
        }
      }
    },
    "/zones/{id}/records": {
      "get": {
        "operationId": "listDnsRecords",
        "summary": "List DNS records in a zone",
        "tags": ["DNS Records"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated DNS records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/DnsRecord" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createDnsRecord",
        "summary": "Create a DNS record",
        "tags": ["DNS Records"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DnsRecordInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "DNS record created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/DnsRecord" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/zones/{zoneId}/records/{recordId}": {
      "get": {
        "operationId": "getDnsRecord",
        "summary": "Get a DNS record",
        "tags": ["DNS Records"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "zoneId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "recordId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "DNS record details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/DnsRecord" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Record not found" }
        }
      },
      "post": {
        "operationId": "updateDnsRecord",
        "summary": "Update a DNS record",
        "tags": ["DNS Records"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "zoneId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "recordId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DnsRecordInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "DNS record updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/DnsRecord" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Record not found" }
        }
      },
      "delete": {
        "operationId": "deleteDnsRecord",
        "summary": "Delete a DNS record",
        "tags": ["DNS Records"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "zoneId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "recordId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "DNS record deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Record not found" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token from developer account"
      }
    },
    "schemas": {
      "Contact": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "fax": { "type": "string" },
          "organization": { "type": "string" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "postcode": { "type": "string" },
          "country": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ContactInput": {
        "type": "object",
        "required": ["name", "email", "phone", "address", "city", "postcode", "country"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "fax": { "type": "string" },
          "organization": { "type": "string" },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "postcode": { "type": "string" },
          "country": { "type": "string", "description": "ISO 3166 country code" }
        }
      },
      "Domain": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "registrant": { "type": "string" },
          "admin": { "type": "string" },
          "tech": { "type": "string" },
          "billing": { "type": "string" },
          "nameservers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "auto_renew": { "type": "boolean" },
          "registration_date": { "type": "string", "format": "date-time" },
          "expiration_date": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "DomainRegistrationInput": {
        "type": "object",
        "required": ["name", "registrant"],
        "properties": {
          "name": { "type": "string" },
          "registrant": { "type": "string" },
          "admin": { "type": "string" },
          "tech": { "type": "string" },
          "billing": { "type": "string" },
          "nameservers": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "DomainUpdateInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "registrant": { "type": "string" },
          "admin": { "type": "string" },
          "tech": { "type": "string" },
          "billing": { "type": "string" },
          "auto_renew": { "type": "boolean" },
          "nameservers": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "Zone": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "name_servers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "DnsRecord": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "name": { "type": "string" },
          "ttl": { "type": "integer" },
          "content": { "type": "string" },
          "priority": { "type": "integer" },
          "comment": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "DnsRecordInput": {
        "type": "object",
        "required": ["type", "name", "ttl", "content"],
        "properties": {
          "type": { "type": "string", "description": "DNS record type (A, AAAA, CNAME, MX, TXT, etc.)" },
          "name": { "type": "string" },
          "ttl": { "type": "integer" },
          "content": { "type": "string" },
          "priority": { "type": "integer", "description": "Required for MX records" },
          "comment": { "type": "string" }
        }
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "tags": [
    { "name": "Contacts", "description": "Contact management for domain registration" },
    { "name": "Domains", "description": "Domain registration and management" },
    { "name": "DNS Zones", "description": "DNS zone management" },
    { "name": "DNS Records", "description": "DNS record management" }
  ]
}