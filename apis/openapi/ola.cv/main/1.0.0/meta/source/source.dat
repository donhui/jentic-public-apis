              "AAAA",
              "CNAME",
              "MX",
              "TXT",
              "DKIM",
              "SPF",
              "DMARC",
              "SRV"
            ],
            "description": "DNS record type"
          },
          "name": {
            "type": "string",
            "description": "Record name or @ for root"
          },
          "ttl": {
            "type": "integer",
            "minimum": 60,
            "maximum": 86400,
            "description": "TTL in seconds"
          },
          "content": {
            "type": "string",
            "description": "Record content/value"
          },
          "comment": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "description": "Required for MX, SRV, URI types"
          }
