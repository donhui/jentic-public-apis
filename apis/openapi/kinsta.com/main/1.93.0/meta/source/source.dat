{
  "openapi": "3.0.3",
  "info": {
    "title": "Kinsta API",
    "version": "1.93.0",
    "description": "REST API for managing Kinsta WordPress hosting platform. Enables programmatic management of sites, environments, domains, backups, plugins, themes, and more.",
    "x-jentic-source-url": "https://api-docs.kinsta.com/"
  },
  "servers": [
    {
      "url": "https://api.kinsta.com/v2"
    }
  ],
  "paths": {
    "/sites": {
      "get": {
        "operationId": "listSites",
        "summary": "List all sites",
        "description": "Returns a list of all WordPress sites in your company account.",
        "tags": ["Sites"],
        "responses": {
          "200": {
            "description": "Successful response with list of sites",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "company": {
                      "type": "object",
                      "properties": {
                        "sites": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Site"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "post": {
        "operationId": "createSite",
        "summary": "Create a new site",
        "description": "Creates a new WordPress site.",
        "tags": ["Sites"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSiteRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Site creation initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "401": {
            "description": "Unauthorized",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/sites/{site_id}": {
      "get": {
        "operationId": "getSite",
        "summary": "Get a site",
        "description": "Returns details of a specific site.",
        "tags": ["Sites"],
        "parameters": [
          {
            "name": "site_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "site": { "$ref": "#/components/schemas/Site" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "operationId": "deleteSite",
        "summary": "Delete a site",
        "description": "Deletes a specific site.",
        "tags": ["Sites"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "202": { "description": "Deletion initiated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OperationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments": {
      "get": {
        "operationId": "listEnvironments",
        "summary": "List site environments",
        "description": "Returns all environments for a site.",
        "tags": ["Environments"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of environments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "site": {
                      "type": "object",
                      "properties": {
                        "environments": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/Environment" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "createEnvironment",
        "summary": "Create a new environment",
        "tags": ["Environments"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["display_name", "source_env_id"],
                "properties": {
                  "display_name": { "type": "string" },
                  "source_env_id": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Environment creation initiated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OperationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments/{env_id}": {
      "delete": {
        "operationId": "deleteEnvironment",
        "summary": "Delete an environment",
        "tags": ["Environments"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "202": { "description": "Deletion initiated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OperationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments/{env_id}/backups": {
      "get": {
        "operationId": "listBackups",
        "summary": "List backups for an environment",
        "tags": ["Backups"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of backups",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "environment": {
                      "type": "object",
                      "properties": {
                        "backups": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/Backup" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "createBackup",
        "summary": "Create a manual backup",
        "tags": ["Backups"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tag": { "type": "string", "description": "A label for the backup" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Backup creation initiated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OperationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments/{env_id}/domains": {
      "get": {
        "operationId": "listDomains",
        "summary": "List domains for an environment",
        "tags": ["Domains"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of domains",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "environment": {
                      "type": "object",
                      "properties": {
                        "domains": { "type": "array", "items": { "$ref": "#/components/schemas/Domain" } }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "addDomain",
        "summary": "Add a domain to an environment",
        "tags": ["Domains"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["domain_name"],
                "properties": {
                  "domain_name": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Domain addition initiated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OperationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments/{env_id}/plugins": {
      "get": {
        "operationId": "listPlugins",
        "summary": "List plugins for an environment",
        "tags": ["Plugins"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of plugins",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "environment": {
                      "type": "object",
                      "properties": {
                        "container_info": {
                          "type": "object",
                          "properties": {
                            "wp_plugins": { "type": "array", "items": { "$ref": "#/components/schemas/Plugin" } }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments/{env_id}/themes": {
      "get": {
        "operationId": "listThemes",
        "summary": "List themes for an environment",
        "tags": ["Themes"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of themes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "environment": {
                      "type": "object",
                      "properties": {
                        "container_info": {
                          "type": "object",
                          "properties": {
                            "wp_themes": { "type": "array", "items": { "$ref": "#/components/schemas/Theme" } }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments/{env_id}/logs": {
      "get": {
        "operationId": "getLogs",
        "summary": "Get logs for an environment",
        "tags": ["Logs"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Log entries", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments/{env_id}/analytics": {
      "get": {
        "operationId": "getAnalytics",
        "summary": "Get analytics for an environment",
        "tags": ["Analytics"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Analytics data", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments/{env_id}/cache": {
      "post": {
        "operationId": "clearCache",
        "summary": "Clear site cache",
        "tags": ["Cache"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "202": { "description": "Cache clear initiated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OperationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/sites/{site_id}/environments/{env_id}/sftp-accounts": {
      "get": {
        "operationId": "listSftpAccounts",
        "summary": "List SFTP accounts",
        "tags": ["SFTP"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of SFTP accounts", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "createSftpAccount",
        "summary": "Create an SFTP account",
        "tags": ["SFTP"],
        "parameters": [
          { "name": "site_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "env_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "202": { "description": "SFTP account creation initiated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OperationResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/domains/{domain_id}/dns-records": {
      "get": {
        "operationId": "listDnsRecords",
        "summary": "List DNS records for a domain",
        "tags": ["DNS"],
        "parameters": [
          { "name": "domain_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of DNS records", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "operationId": "createDnsRecord",
        "summary": "Create a DNS record",
        "tags": ["DNS"],
        "parameters": [
          { "name": "domain_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": { "description": "DNS record created", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/company/users": {
      "get": {
        "operationId": "listCompanyUsers",
        "summary": "List company users",
        "tags": ["Company"],
        "responses": {
          "200": { "description": "List of users", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/company/api-keys": {
      "get": {
        "operationId": "listApiKeys",
        "summary": "List API keys",
        "tags": ["Company"],
        "responses": {
          "200": { "description": "List of API keys", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/company/domains": {
      "get": {
        "operationId": "listCompanyDomains",
        "summary": "List company domains",
        "tags": ["Company"],
        "responses": {
          "200": { "description": "List of domains", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/company/available-regions": {
      "get": {
        "operationId": "listAvailableRegions",
        "summary": "List available regions",
        "tags": ["Company"],
        "responses": {
          "200": { "description": "List of available regions", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/company/activity-logs": {
      "get": {
        "operationId": "listActivityLogs",
        "summary": "List activity logs",
        "tags": ["Company"],
        "responses": {
          "200": { "description": "Activity log entries", "content": { "application/json": { "schema": { "type": "object" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/operations/{operation_id}": {
      "get": {
        "operationId": "getOperation",
        "summary": "Get operation status",
        "description": "Returns the status of an asynchronous operation.",
        "tags": ["Operations"],
        "parameters": [
          { "name": "operation_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Operation status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OperationResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Site": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "display_name": { "type": "string" },
          "status": { "type": "string" },
          "site_labels": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Environment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "display_name": { "type": "string" },
          "is_premium": { "type": "boolean" }
        }
      },
      "Domain": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "Backup": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "type": { "type": "string" }
        }
      },
      "Plugin": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "version": { "type": "string" },
          "update_available": { "type": "boolean" }
        }
      },
      "Theme": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string" },
          "version": { "type": "string" },
          "update_available": { "type": "boolean" }
        }
      },
      "CreateSiteRequest": {
        "type": "object",
        "required": ["display_name", "region"],
        "properties": {
          "display_name": { "type": "string" },
          "region": { "type": "string" },
          "install_mode": { "type": "string" },
          "is_subdomain_multisite": { "type": "boolean" },
          "admin_email": { "type": "string" },
          "admin_password": { "type": "string" },
          "admin_user": { "type": "string" },
          "site_title": { "type": "string" },
          "woocommerce": { "type": "boolean" },
          "wp_language": { "type": "string" }
        }
      },
      "OperationResponse": {
        "type": "object",
        "properties": {
          "operation_id": { "type": "string" },
          "message": { "type": "string" },
          "status": { "type": "integer" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "status": { "type": "integer" }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Kinsta API key as Bearer token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}
