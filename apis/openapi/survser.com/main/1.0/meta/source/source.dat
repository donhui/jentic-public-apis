{
  "openapi": "3.0.3",
  "info": {
    "title": "Survser Public API",
    "description": "Survser offers a powerful API that allows users to programmatically access survey data, enabling deeper integrations and custom analytics workflows. The API provides endpoints to retrieve survey responses and list surveys.",
    "version": "1.0",
    "x-jentic-source-url": "https://docs.survser.com/docs/api"
  },
  "servers": [
    {
      "url": "https://survser.com/api/public",
      "description": "Survser Public API"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Surveys",
      "description": "Operations for managing and retrieving surveys"
    },
    {
      "name": "Responses",
      "description": "Operations for retrieving survey responses"
    }
  ],
  "paths": {
    "/response/list": {
      "get": {
        "operationId": "getSurveyResponses",
        "summary": "Get Survey Responses",
        "description": "Retrieve responses for a specific survey. Responses are returned in reverse chronological order, providing a timely view of the latest feedback.",
        "tags": ["Responses"],
        "parameters": [
          {
            "name": "surveyId",
            "in": "query",
            "required": true,
            "description": "The ID of the survey for which you want to retrieve responses. You can find the survey ID in the URL when visiting the insights page of a survey (e.g., survser.com/surveys/<id>/insights).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Your API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved survey responses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SurveyResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/survey/list": {
      "get": {
        "operationId": "getSurveys",
        "summary": "Get Surveys",
        "description": "Provides a list of all surveys created within your Survser account, allowing you to programmatically access survey details and metadata.",
        "tags": ["Surveys"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Your API key for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved list of surveys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Survey"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key passed as a query parameter. You can find your API key in the account settings on the Survser platform."
      }
    },
    "schemas": {
      "SurveyResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the response",
            "example": "65de65cbeb43bb8306bd8e2e"
          },
          "complete": {
            "type": "boolean",
            "description": "Whether the survey response is complete"
          },
          "survey": {
            "type": "string",
            "description": "ID of the survey this response belongs to",
            "example": "65dc8291c792ce90d6e39167"
          },
          "responses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionResponse"
            }
          },
          "user": {
            "$ref": "#/components/schemas/ResponseUser"
          },
          "anonIdentifier": {
            "type": "string",
            "description": "Anonymous identifier for untracked users",
            "example": "fad509c3-600c-4880-a7f0-86956ff891ff"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the response was created"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the response was last updated"
          }
        }
      },
      "QuestionResponse": {
        "type": "object",
        "properties": {
          "questionId": {
            "type": "string",
            "description": "ID of the question",
            "example": "fb2c4922-cb55-4a35-b97d-9341b8c4b0c5"
          },
          "questionFormat": {
            "type": "string",
            "description": "Format type of the question (e.g., csat, nps, form)",
            "example": "csat"
          },
          "answer": {
            "$ref": "#/components/schemas/Answer"
          }
        }
      },
      "Answer": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "description": "The answer value"
          },
          "text": {
            "type": "string",
            "description": "Human-readable text of the answer"
          },
          "field": {
            "type": "string",
            "nullable": true,
            "description": "Optional field identifier"
          }
        }
      },
      "ResponseUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Internal user ID"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email address"
          },
          "userId": {
            "type": "string",
            "description": "External user ID"
          },
          "name": {
            "type": "string",
            "description": "User's name"
          },
          "isTracked": {
            "type": "boolean",
            "description": "Whether the user is being tracked"
          },
          "project": {
            "type": "string",
            "description": "Project ID the user belongs to"
          },
          "isDemo": {
            "type": "boolean",
            "description": "Whether this is a demo user"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Survey": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the survey",
            "example": "65e1fd3fa9dee5805c89da88"
          },
          "name": {
            "type": "string",
            "description": "Name of the survey",
            "example": "Custom Survey"
          },
          "status": {
            "type": "string",
            "description": "Current status of the survey",
            "enum": ["active", "inactive", "draft"],
            "example": "active"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the survey was created"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the survey was last updated"
          },
          "displayCount": {
            "type": "integer",
            "description": "Number of times the survey has been displayed"
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Question"
            }
          }
        }
      },
      "Question": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the question"
          },
          "format": {
            "type": "string",
            "description": "Format type of the question (e.g., form, csat, nps)"
          },
          "text": {
            "type": "string",
            "description": "The question text"
          },
          "subtext": {
            "type": "string",
            "description": "Additional subtext for the question"
          },
          "allowMultiple": {
            "type": "boolean",
            "description": "Whether multiple answers are allowed"
          },
          "autoSubmit": {
            "type": "boolean",
            "description": "Whether the question auto-submits"
          },
          "noAnswer": {
            "type": "boolean",
            "description": "Whether no answer is permitted"
          },
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionAnswer"
            }
          }
        }
      },
      "QuestionAnswer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the answer option"
          },
          "value": {
            "type": "integer",
            "description": "Numeric value of the answer"
          },
          "label": {
            "type": "string",
            "description": "Display label for the answer"
          },
          "type": {
            "type": "string",
            "description": "Type of the answer option"
          },
          "inputType": {
            "type": "string",
            "description": "Input type for form fields (e.g., email, date, text)"
          },
          "required": {
            "type": "boolean",
            "description": "Whether this answer field is required"
          }
        }
      }
    }
  }
}