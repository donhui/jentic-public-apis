          }
        }
      },
      "UserUpdateDto": {
        "type": "object",
        "required": [
          "currentPassword"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "jane@doe.com",
            "description": "email of the user. Has to be unique."
          },
          "newPassword": {
            "type": "string",
            "example": "my_new_password",
            "description": "new password"
          },
          "currentPassword": {
            "type": "string",
            "example": "password",
            "description": "current password"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "advertiser",
              "gamer"
            ]
          }
        }
      },
      "UserCreationDto": {
        "type": "object",
        "required": [
          "email",
          "password",
          "role"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "jane@doe.com",
            "description": "email of the user. Has to be unique."
          },
          "password": {
            "type": "string",
            "example": "my_password",
            "description": "Only bcrypt hashes of passwords are stored in the database, plain text passwords are never stored or logged."
          },
          "role": {
            "type": "string",
            "description": "If roles include 'admin', authentication is required and the user executing the request also has to have the 'admin' role, thus only allowing admin users to create new admin accounts.",
            "enum": [
              "advertiser",
              "gamer",
              "admin"
            ]
          }
        }
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "example": 1
          },
          "email": {
            "type": "string",
            "example": "jane@doe.com",
            "description": "email of the user. Has to be unique."
          },
          "role": {
            "type": "string",
            "example": "advertiser",
            "enum": [
              "admin",
              "advertiser",
              "gamer"
            ]
          },
          "confirmed": {
            "type": "boolean",
            "example": true,
            "description": "Indicates whether the user has confirmed his e-mail address by clicking the confirmation link."
          },
          "createdDateTime": {
            "type": "string",
            "example": "2018-01-22T11:51:22.012Z",
            "description": "Timestamp when the resource was created."
          },
          "_links": {
            "type": "object",
            "properties": {
              "self": {
                "type": "object",
                "properties": {
                  "href": {
                    "type": "string",
                    "example": "/v1/users/1"
                  }
                }
              }
            }
          }
        }
      },
      "UserCollectionDto": {
        "type": "object",
        "properties": {
          "value": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserDto"
            }
          },
          "_links": {
            "type": "object",
            "description": "JSON HAL pagination links",
            "properties": {
              "self": {
                "type": "object",
                "properties": {
                  "href": {
                    "type": "string",
                    "example": "/v1/users?$skip=20&$top=20"
                  }
                }
              },
              "next": {
                "type": "object",
                "properties": {
                  "href": {
                    "type": "string",
                    "example": "/v1/users?$skip=40&$top=20"
                  }
                }
              },
              "prev": {
                "type": "object",
                "properties": {
                  "href": {
                    "type": "string",
                    "example": "/v1/users?$skip=0&$top=20"
                  }
                }
              }
            }
          }
        }
      },
      "PasswordResetRequestCreationDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jane@doe.com",
            "description": "email address of the user"
          }
        }
      },
      "PasswordResetRequestDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "c10e36ae-258d-49ca-b733-44aa0b7cb667",
            "description": "Token required to execute a password reset"
          },
          "expirationDateTime": {
            "type": "string",
            "example": "2018-11-01T11:51:22.012Z",
            "description": "Timestamp the token expires and can no longer be used to reset the password."
          }
        }
      },
      "PasswordResetCreationDto": {
        "type": "object",
        "properties": {
          "newPassword": {
            "type": "string",
            "example": "my_password",
            "description": "new user password"
          },
          "token": {
            "type": "string",
            "example": "c10e36ae-258d-49ca-b733-44aa0b7cb667",
            "description": "Token received from a POST to /v1/users/password/reset_request"
          }
        }
      },
      "TokenRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jane@doe.com",
            "description": "email address of the user"
          },
          "password": {
            "type": "string",
            "example": "my_password",
            "description": "password of the user"
          }
        }
