{
  "openapi": "3.0.3",
  "info": {
    "title": "AI For Thai API",
    "description": "AI For Thai (AIFORTHAI) provides a suite of Thai-language artificial intelligence APIs developed by NECTEC (National Electronics and Computer Technology Center) of Thailand. The platform offers natural language processing, speech processing, image processing, and chatbot services tailored for the Thai language.",
    "version": "1.0.0",
    "contact": {
      "name": "AI For Thai Support",
      "url": "https://aiforthai.in.th"
    },
    "x-jentic-source-url": "https://aiforthai.in.th/index.php"
  },
  "servers": [
    {
      "url": "https://api.aiforthai.in.th",
      "description": "AI For Thai Production API Server"
    }
  ],
  "tags": [
    {
      "name": "Text Processing",
      "description": "Thai text analysis and NLP operations"
    },
    {
      "name": "Speech",
      "description": "Thai speech recognition and synthesis"
    },
    {
      "name": "Image",
      "description": "Image analysis and recognition"
    },
    {
      "name": "Translation",
      "description": "Thai language translation services"
    },
    {
      "name": "Chatbot",
      "description": "Conversational AI services"
    }
  ],
  "paths": {
    "/textsum": {
      "post": {
        "operationId": "summarizeText",
        "summary": "Summarize Thai text",
        "description": "Generates a summary of the provided Thai text content.",
        "tags": ["Text Processing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully summarized text",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TextSummaryResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/word-tokenize": {
      "post": {
        "operationId": "tokenizeWords",
        "summary": "Tokenize Thai text into words",
        "description": "Segments Thai text into individual words/tokens using NECTEC's word segmentation engine.",
        "tags": ["Text Processing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully tokenized text",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenizeResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/pos-tagging": {
      "post": {
        "operationId": "posTag",
        "summary": "Part-of-speech tagging for Thai text",
        "description": "Analyzes Thai text and assigns part-of-speech tags to each word.",
        "tags": ["Text Processing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully tagged text",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/POSTagResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/ner": {
      "post": {
        "operationId": "recognizeNamedEntities",
        "summary": "Named entity recognition for Thai text",
        "description": "Identifies and classifies named entities (persons, organizations, locations, etc.) in Thai text.",
        "tags": ["Text Processing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully recognized named entities",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NERResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/sentiment": {
      "post": {
        "operationId": "analyzeSentiment",
        "summary": "Sentiment analysis for Thai text",
        "description": "Analyzes the sentiment (positive, negative, neutral) of Thai text content.",
        "tags": ["Text Processing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully analyzed sentiment",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SentimentResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/speech-to-text": {
      "post": {
        "operationId": "speechToText",
        "summary": "Convert Thai speech to text",
        "description": "Transcribes Thai audio input into text using speech recognition.",
        "tags": ["Speech"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/AudioInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully transcribed audio",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpeechToTextResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/text-to-speech": {
      "post": {
        "operationId": "textToSpeech",
        "summary": "Convert Thai text to speech",
        "description": "Synthesizes Thai text into audio speech output.",
        "tags": ["Speech"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TTSInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully synthesized speech",
            "content": {
              "audio/wav": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/translate": {
      "post": {
        "operationId": "translateText",
        "summary": "Translate text to/from Thai",
        "description": "Translates text between Thai and English or other supported languages.",
        "tags": ["Translation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully translated text",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/object-detection": {
      "post": {
        "operationId": "detectObjects",
        "summary": "Detect objects in an image",
        "description": "Detects and classifies objects within an uploaded image.",
        "tags": ["Image"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully detected objects",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ObjectDetectionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/ocr": {
      "post": {
        "operationId": "recognizeText",
        "summary": "Optical character recognition for Thai text",
        "description": "Extracts Thai text from images using optical character recognition.",
        "tags": ["Image"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ImageInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully recognized text",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OCRResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    },
    "/chatbot": {
      "post": {
        "operationId": "sendChatMessage",
        "summary": "Send a message to the Thai chatbot",
        "description": "Sends a message to the AI-powered Thai chatbot and receives a conversational response.",
        "tags": ["Chatbot"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully received chatbot response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Apikey",
        "description": "API key obtained from the AI For Thai developer portal at https://aiforthai.in.th"
      }
    },
    "schemas": {
      "TextInput": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "Thai text content to process"
          }
        }
      },
      "AudioInput": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Audio file containing Thai speech (WAV, MP3)"
          }
        }
      },
      "TTSInput": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "Thai text to synthesize into speech"
          },
          "speaker": {
            "type": "string",
            "description": "Voice speaker identifier",
            "default": "default"
          }
        }
      },
      "TranslateInput": {
        "type": "object",
        "required": ["text", "source", "target"],
        "properties": {
          "text": {
            "type": "string",
            "description": "Text to translate"
          },
          "source": {
            "type": "string",
            "description": "Source language code",
            "enum": ["th", "en"]
          },
          "target": {
            "type": "string",
            "description": "Target language code",
            "enum": ["th", "en"]
          }
        }
      },
      "ImageInput": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Image file to process (JPEG, PNG)"
          }
        }
      },
      "ChatInput": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "Chat message in Thai"
          },
          "session_id": {
            "type": "string",
            "description": "Session identifier for conversation context"
          }
        }
      },
      "TextSummaryResponse": {
        "type": "object",
        "properties": {
          "summary": {
            "type": "string",
            "description": "Summarized text"
          },
          "status": {
            "type": "string",
            "description": "Processing status"
          }
        }
      },
      "TokenizeResponse": {
        "type": "object",
        "properties": {
          "tokens": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of segmented words/tokens"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "POSTagResponse": {
        "type": "object",
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "word": {
                  "type": "string"
                },
                "tag": {
                  "type": "string",
                  "description": "Part-of-speech tag"
                }
              }
            },
            "description": "Array of word-tag pairs"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "NERResponse": {
        "type": "object",
        "properties": {
          "entities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "type": {
                  "type": "string",
                  "description": "Entity type (PERSON, ORGANIZATION, LOCATION, DATE, etc.)"
                },
                "start": {
                  "type": "integer"
                },
                "end": {
                  "type": "integer"
                }
              }
            }
          },
          "status": {
            "type": "string"
          }
        }
      },
      "SentimentResponse": {
        "type": "object",
        "properties": {
          "sentiment": {
            "type": "string",
            "enum": ["positive", "negative", "neutral"],
            "description": "Detected sentiment"
          },
          "confidence": {
            "type": "number",
            "format": "float",
            "description": "Confidence score between 0 and 1"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "SpeechToTextResponse": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Transcribed Thai text"
          },
          "confidence": {
            "type": "number",
            "format": "float"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "TranslateResponse": {
        "type": "object",
        "properties": {
          "translated_text": {
            "type": "string",
            "description": "Translated text"
          },
          "source_language": {
            "type": "string"
          },
          "target_language": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ObjectDetectionResponse": {
        "type": "object",
        "properties": {
          "objects": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": {
                  "type": "string",
                  "description": "Detected object label"
                },
                "confidence": {
                  "type": "number",
                  "format": "float"
                },
                "bounding_box": {
                  "type": "object",
                  "properties": {
                    "x_min": { "type": "number" },
                    "y_min": { "type": "number" },
                    "x_max": { "type": "number" },
                    "y_max": { "type": "number" }
                  }
                }
              }
            }
          },
          "status": {
            "type": "string"
          }
        }
      },
      "OCRResponse": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Recognized text from image"
          },
          "regions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": { "type": "string" },
                "bounding_box": {
                  "type": "object",
                  "properties": {
                    "x_min": { "type": "number" },
                    "y_min": { "type": "number" },
                    "x_max": { "type": "number" },
                    "y_max": { "type": "number" }
                  }
                }
              }
            }
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "response": {
            "type": "string",
            "description": "Chatbot response message"
          },
          "session_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid or missing parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Too many requests - rate limit exceeded",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ]
}
