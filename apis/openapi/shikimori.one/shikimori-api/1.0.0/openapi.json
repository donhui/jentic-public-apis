{
  "openapi": "3.0.3",
  "info": {
    "title": "Shikimori API",
    "description": "API for Shikimori, a social network and database for anime and manga fans. Provides access to anime, manga, characters, users, clubs, topics, and more. OAuth2 is used for authentication. All requests must include a User-Agent header with your application name. Rate limited to 5 requests per second and 90 requests per minute.",
    "version": "1.0.0",
    "contact": {
      "name": "Shikimori",
      "url": "https://shikimori.one"
    }
  },
  "servers": [
    {
      "url": "https://shikimori.one",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "paths": {
    "/api/animes": {
      "get": {
        "tags": ["Animes"],
        "summary": "List animes",
        "operationId": "listAnimes",
        "security": [],
        "parameters": [
          {"name": "page", "in": "query", "schema": {"type": "integer", "minimum": 1, "maximum": 100000}},
          {"name": "limit", "in": "query", "schema": {"type": "integer", "maximum": 50}},
          {"name": "order", "in": "query", "schema": {"type": "string", "enum": ["id", "ranked", "kind", "popularity", "name", "aired_on", "episodes", "status", "random", "updated_at"]}},
          {"name": "kind", "in": "query", "schema": {"type": "string", "enum": ["tv", "movie", "ova", "ona", "special", "tv_special", "music", "pv", "cm"]}},
          {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["anons", "ongoing", "released"]}},
          {"name": "season", "in": "query", "schema": {"type": "string"}, "description": "e.g. summer_2017, 2016, 2014_2016, 199x"},
          {"name": "score", "in": "query", "schema": {"type": "integer"}, "description": "Minimal anime score"},
          {"name": "duration", "in": "query", "schema": {"type": "string", "enum": ["S", "D", "F"]}},
          {"name": "rating", "in": "query", "schema": {"type": "string", "enum": ["none", "g", "pg", "pg_13", "r", "r_plus", "rx"]}},
          {"name": "genre", "in": "query", "schema": {"type": "string"}, "description": "Comma-separated genre IDs"},
          {"name": "studio", "in": "query", "schema": {"type": "string"}, "description": "Comma-separated studio IDs"},
          {"name": "franchise", "in": "query", "schema": {"type": "string"}, "description": "Comma-separated franchise IDs"},
          {"name": "censored", "in": "query", "schema": {"type": "boolean"}},
          {"name": "mylist", "in": "query", "schema": {"type": "string", "enum": ["planned", "watching", "rewatching", "completed", "on_hold", "dropped"]}},
          {"name": "ids", "in": "query", "schema": {"type": "string"}, "description": "Comma-separated IDs"},
          {"name": "exclude_ids", "in": "query", "schema": {"type": "string"}, "description": "Comma-separated IDs to exclude"},
          {"name": "search", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "List of animes",
            "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/AnimeBasic"}}}}
          }
        }
      }
    },
