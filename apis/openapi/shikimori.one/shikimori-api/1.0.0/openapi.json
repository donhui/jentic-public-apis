    "/api/comments": {
      "get": {
        "tags": ["Comments"],
        "summary": "List comments",
        "operationId": "listComments",
        "security": [],
        "parameters": [
          {"name": "commentable_id", "in": "query", "required": true, "schema": {"type": "integer"}},
          {"name": "commentable_type", "in": "query", "required": true, "schema": {"type": "string", "enum": ["Topic", "User"]}},
