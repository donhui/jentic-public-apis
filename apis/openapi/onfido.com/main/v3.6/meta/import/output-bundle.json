{
  "openapi": "3.0.0",
  "info": {
    "title": "Onfido Public API v3.6",
    "version": "v3.6",
    "description": "The Onfido Public API (v3.6)",
    "contact": {
      "name": "Onfido",
      "url": "https://public.support.onfido.com"
    },
    "license": {
      "name": "MIT"
    },
    "x-jentic-source-url": "https://raw.githubusercontent.com/onfido/onfido-openapi-spec/master/openapi.yaml"
  },
  "servers": [
    {
      "url": "https://api.{region}.onfido.com/v3.6",
      "variables": {
        "region": {
          "enum": [
            "eu",
            "us",
            "ca"
          ],
          "default": "eu"
        }
      }
    }
  ],
  "paths": {},
  "components": {
    "securitySchemes": {
      "Token": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header"
      },
      "OAuth2ClientCredentials": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://api.default.onfido.com/v3.6/oauth/token",
            "scopes": {
              "all_scopes": "All scopes"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "Token": []
    },
    {
      "OAuth2ClientCredentials": []
    }
  ],
  "tags": [],
  "externalDocs": {
    "url": "https://documentation.onfido.com"
  }
}