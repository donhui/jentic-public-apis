{
  "openapi": "3.0.3",
  "info": {
    "title": "Rossum Document Processing API",
    "version": "v1",
    "description": "Rossum AI-powered document processing API for automated data extraction from invoices, receipts, and other documents. Provides intelligent document capture, classification, and data validation capabilities.",
    "x-jentic-source-url": "https://elis.rossum.ai/api/docs/"
  },
  "servers": [
    {
      "url": "https://{domain}.rossum.app/api",
      "description": "Rossum API endpoint",
      "variables": {
        "domain": {
          "default": "example",
          "description": "Your Rossum domain selected during account creation"
        }
      }
    }
  ],
  "paths": {
    "/v1/auth/login": {
      "post": {
        "operationId": "login",
        "summary": "User Login",
        "description": "Authenticate with username and password to obtain an access token. Token is valid for approximately 162 hours by default.",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "max_token_lifetime_s": {
                    "type": "integer",
                    "description": "Optional maximum token lifetime in seconds"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "key": {
                      "type": "string",
                      "description": "Access token"
                    },
                    "user": {
                      "type": "string",
                      "description": "User resource URL"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/auth/token": {
      "post": {
        "operationId": "exchangeJwtToken",
        "summary": "Exchange JWT Token",
        "description": "Exchange a JWT token for a Rossum access token. Supports EdDSA and RS512 signatures with maximum 60-second validity.",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "token"
                ],
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "JWT token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token exchanged",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "key": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
