      "Order": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "description": "The order ID. Will usually be 6 hex characters, but can also be 9 hex characters if the site has a very large number of orders. Randomly assigned.\n"
          },
          "status": {
            "$ref": "#/components/schemas/OrderStatus",
            "description": "One of `pending`, `unfulfilled`, `fulfilled`, `disputed`, `dispute-lost`, or `refunded`\n"
          },
          "comment": {
            "type": "string",
            "description": "A comment string for this order editable by API user (not used by Webflow)."
