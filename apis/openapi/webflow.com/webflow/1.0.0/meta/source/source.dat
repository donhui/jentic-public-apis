          },
          "offset": {
            "type": "integer",
            "default": 0,
            "description": "The offset specified for pagination"
          },
          "total": {
            "type": "integer",
            "description": "Total number of items in the collection"
          }
        },
        "description": "Results from product list",
        "title": "ProductList"
      },
      "SkuFieldPrice": {
