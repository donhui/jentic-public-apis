          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of errors"
          }
        },
        "description": "A list of items removed",
        "title": "RemovedItems"
      },
      "PublishedItems": {
        "type": "object",
        "properties": {
