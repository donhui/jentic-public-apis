            "default": "product-name",
            "description": "Slug of the item"
          },
          "name": {
            "type": "string",
            "default": "Product Name",
            "description": "item name"
          },
          "_archived": {
            "type": "boolean",
            "default": false,
            "description": "item archive status"
          },
          "_draft": {
            "type": "boolean",
            "default": false,
            "description": "item draft status"
          },
          "sku-properties": {
            "type": "array",
            "items": {
