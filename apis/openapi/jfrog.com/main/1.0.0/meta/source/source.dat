                                  "type": "string"
                                },
                                "risk": {
                                  "type": "string"
                                },
                                "risk_reason": {
                                  "type": "string"
                                },
                                "is_eol": {
                                  "type": "boolean"
                                },
                                "eol_message": {
                                  "type": "string"
                                },
                                "latest_version": {
                                  "type": "string"
                                },
                                "newer_versions": {
                                  "type": "integer"
                                },
                                "cadence": {
                                  "type": "integer"
                                },
