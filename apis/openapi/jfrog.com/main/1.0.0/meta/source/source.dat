          "Searches"
        ],
        "summary": "List Docker Repositories",
        "description": "Lists all Docker repositories (the registry's _catalog) hosted in an Artifactory Docker repository. Since 4.4.3. The n and last pagination parameters are supported from version 5.4.6. Both parameters refer to an integer.",
        "operationId": "listDockerRepositories",
        "parameters": [
          {
            "name": "repo-key",
            "in": "path",
