    "/promotion/records/{name}/{version}": {
      "post": {
        "tags": [
          "Release Lifecycle",
          "PromotionResource"
        ],
        "summary": "Promote Release Bundle v2 Version",
        "description": "Promotes the selected Release Bundle v2 version.",
        "operationId": "createPromotion",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Release bundle name",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\w[\\w\\-.]*$"
            }
          },
          {
            "name": "version",
            "in": "path",
            "description": "Release bundle version",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\w[\\w\\-.+]*$"
            }
          },
          {
            "name": "async",
            "in": "query",
            "description": "Determines whether the operation should be asynchronous (true) or synchronous (false). The default value is true.",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "operation",
            "in": "query",
            "description": "Determines how to perform the promotion. 'copy' copies contents to target repository (default). 'move' moves contents from last promotion repository to target repository.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "copy",
                "move"
              ],
              "default": "copy"
            }
          },
          {
            "name": "project",
            "in": "query",
            "description": "The project key used to determine the Release Bundles repository",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repository_key",
            "in": "query",
            "description": "The Release Bundles repository identifier",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePromotionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submitted (asynchronous) - The request to promote the Release Bundle version was submitted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromoteBundleResponse"
                }
              }
            }
          },
          "201": {
            "description": "Promoted (synchronous) - The Release Bundle version was promoted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromoteBundleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - The request was malformed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - Authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The Release Bundle name or version does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "409": {
            "description": "Conflict - Can occur when trying to promote when another promotion is in progress, or when artifact already exists at target with different checksum.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Release Lifecycle",
          "PromotionResource"
        ],
        "summary": "Get Release Bundle v2 Version Promotions",
        "description": "Returns the details of all promotions for the specified Release Bundle v2 version. All promotion records are provided regardless of status, including failed attempts.",
        "operationId": "getPromotionsByVersion",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Release bundle name",
