    "/promotion/rollback/{name}/{version}": {
      "post": {
        "tags": [
          "Release Lifecycle",
          "PromotionResource"
        ],
        "summary": "Roll Back Release Bundle v2 Version Promotion",
        "description": "Removes the latest promotion of a Release Bundle v2 version and restores the version to its previous environment, including the properties and evidence that were present when the version was first created.",
        "operationId": "rollbackPromotion",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Release bundle name",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\w[\\w\\-.]*$"
            }
          },
          {
            "name": "version",
            "in": "path",
            "description": "Release bundle version",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\w[\\w\\-.+]*$"
            }
          },
          {
            "name": "from_environment",
            "in": "query",
            "description": "The name of the current environment in which the Release Bundle version is located. The rollback is executed from this environment.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "async",
            "in": "query",
            "description": "Determines whether the operation should be asynchronous (true) or synchronous (false). The default value is true.",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "project",
            "in": "query",
            "description": "Optional project key associated with the promotion",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "description": "Optional details for the rollback promotion, such as a overwrite_strategy. If not provided, a default empty request is used.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRollbackPromotionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submitted (Async) - The rollback request was submitted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RollbackPromotionResponse"
                }
              }
            }
          },
          "201": {
            "description": "Rolled Back (Sync) - The promotion was rolled back successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RollbackPromotionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - Authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/promotion/records/{name}": {
      "get": {
        "tags": [
          "Release Lifecycle",
          "PromotionResource"
        ],
        "summary": "Get Release Bundle v2 Promotions",
        "description": "Returns the records of all promotions for the specified Release Bundle v2 (regardless of version). All promotion records are provided regardless of status, including failed attempts.",
        "operationId": "getPromotions",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Release bundle name",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\w[\\w\\-.]*$"
            }
          },
          {
            "name": "project",
            "in": "query",
            "description": "The project key used to determine the Release Bundles repository",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repository_key",
            "in": "query",
            "description": "The Release Bundles repository identifier",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include",
            "in": "query",
            "description": "Returns any error messages generated when creating the promotion",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Sets the number of records to skip before returning the query response. Used for pagination purposes.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Sets the maximum number of versions to return at one time. Used for pagination purposes.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "filter_by",
            "in": "query",
            "description": "Defines a filter for the list of promotions. You can filter according to bundle_version, promotion_environment, promotion_created_by",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Defines the criterion by which to order the list of promotions (created, created_millis, created_by, release_bundle_version, environment)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "created",
                "created_millis",
                "created_by",
                "release_bundle_version",
                "environment"
              ]
            }
          },
          {
            "name": "order_asc",
            "in": "query",
            "description": "Defines whether to list the promotions in ascending (true) or descending (false) order. The default value is false.",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
