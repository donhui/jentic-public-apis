                                "services_scan": {
                                  "type": "boolean"
                                },
                                "secrets_scan": {
                                  "type": "boolean"
                                },
                                "applications_scan": {
                                  "type": "boolean"
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "repo_paths_config": {
                      "type": "object",
                      "properties": {
