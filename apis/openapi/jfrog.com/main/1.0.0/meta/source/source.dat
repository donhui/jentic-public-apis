          },
          {
            "name": "n",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of consecutive repositories"
          },
          {
            "name": "last",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Last tag value from previous response"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "repositories": {
                      "type": "array",
