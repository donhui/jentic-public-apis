    "/api/v2/ci/build": {
      "post": {
        "operationId": "scan-build-v2",
        "summary": "Scan Build V2",
        "description": "Triggers a CI build scan (v2 API). Invokes scanning of a build that was uploaded to Artifactory as requested by a CI server. Requires the Manage Xray Metadata permission.",
        "tags": [
          "Xray",
          "Scanning V2"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "build_name": {
                    "type": "string",
                    "description": "Name of the build."
                  },
                  "build_number": {
                    "type": "string",
                    "description": "Build number."
                  },
                  "project": {
                    "type": "string",
                    "description": "Project key the build belongs to."
                  },
                  "rescan": {
                    "type": "boolean",
                    "description": "Flag to rescan the build."
                  }
                },
                "required": [
                  "build_name",
                  "build_number"
                ]
              },
              "example": {
                "build_name": "my-build",
                "build_number": "8"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Build scan initiated.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "info": {
                      "type": "string",
                      "description": "Status message about the scan progress."
                    }
                  }
                },
                "example": {
                  "info": "\u201cScan of build name 'my-build', build number '8' is in progress\u201d"
                }
              }
            }
          },
          "400": {
            "description": "Request is missing mandatory fields",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "403": {
            "description": "Permission denied",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "415": {
            "description": "Failed to parse scan build request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/ci/build/{build_name}/{build_number}": {
      "get": {
        "operationId": "get-builds-scan-results",
        "summary": "Get Build Scan Results",
        "description": "Returns CI build scan results for a specific build. Returns violations only if it determines a build failure. To retrieve full scan results including vulnerabilities, use the include_vulnerabilities parameter. Requires the Manage Xray Metadata permission.",
        "tags": [
          "Xray",
          "Scanning V2"
        ],
        "parameters": [
          {
            "name": "build_name",
            "in": "path",
            "description": "Name of the build.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "build_number",
            "in": "path",
            "description": "Build number.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "projectKey",
            "in": "query",
            "description": "Project key the build belongs to.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include_vulnerabilities",
            "in": "query",
            "description": "Whether to include CVEs in the response.",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Build scan results returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "build_name": {
                      "type": "string",
                      "description": "Name of the build."
                    },
                    "build_number": {
                      "type": "string",
                      "description": "Number of the build."
                    },
                    "project": {
                      "type": "string",
                      "description": "Project associated with the build."
                    },
                    "status": {
                      "type": "string",
                      "description": "Status of the build (e.g. completed)."
                    },
                    "more_details_url": {
                      "type": "string",
                      "description": "URL for more details about the build scan."
                    },
                    "fail_build": {
                      "type": "boolean",
                      "description": "Whether the build should fail."
                    },
                    "violations": {
                      "type": "array",
                      "description": "Detected violations.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "issue_id": {
                            "type": "string"
                          },
                          "summary": {
                            "type": "string"
                          },
                          "severity": {
                            "type": "string",
                            "description": "Possible values: Critical, High, Medium, Low, Information, Unknown."
                          },
                          "type": {
                            "type": "string",
                            "description": "Violation type: security, license, or operational_risk."
                          },
                          "watch_name": {
                            "type": "string"
                          },
                          "fail_build": {
                            "type": "boolean"
                          }
                        }
                      }
                    },
                    "vulnerabilities": {
                      "type": "array",
                      "description": "Detected vulnerabilities (only if include_vulnerabilities=true).",
                      "items": {
                        "type": "object",
                        "properties": {
                          "issue_id": {
                            "type": "string"
                          },
                          "summary": {
                            "type": "string"
                          },
                          "severity": {
                            "type": "string"
                          },
                          "provider": {
                            "type": "string"
                          },
                          "cves": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "cve": {
                                  "type": "string"
                                },
                                "cvss_v3_score": {
                                  "type": "string"
                                },
                                "cvss_v3_vector": {
                                  "type": "string"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Permission denied",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Build does not exist or is not indexed in Xray",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "error": "Build doesn't exist or not indexed in Xray"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/component/searchByCves": {
      "post": {
        "operationId": "find-component-by-cve",
        "summary": "Find Component by CVE",
        "description": "Searches for components that are directly affected by the specified CVEs. Returns a list of matching components grouped by CVE, including component name, package type, version, and a link to the instance.\n\nRequires the Reports Manager permission.\n",
        "tags": [
          "Xray",
          "Search V1"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cves": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "cves"
                ]
              },
              "example": {
                "cves": [
                  "CVE-2024-12085"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Valid response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "cve_details": {
                        "type": "string"
                      },
                      "components": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "type": "string"
                            },
                            "package_type": {
                              "type": "string"
                            },
                            "version": {
                              "type": "string"
                            },
                            "link": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "name",
                            "package_type",
                            "version",
                            "link"
                          ]
                        }
                      }
                    },
                    "required": [
                      "cve_details",
                      "components"
                    ]
                  }
                },
                "example": [
                  {
                    "cve_details": "CVE-2024-12085",
                    "components": [
                      {
                        "name": "debian:jessie:rsync",
                        "package_type": "Debian",
                        "version": "3.1.1-3+deb8u2",
                        "link": "https://instanceid.jfrog.io/"
                      },
                      {
                        "name": "ubuntu:jammy:rsync",
                        "package_type": "Debian",
                        "version": "3.2.7-0ubuntu0.22.04.2",
                        "link": "https://instanceid.jfrog.io/"
                      },
                      {
                        "name": "8:rsync",
                        "package_type": "Rpm",
                        "version": "0:3.1.3-12.el8",
                        "link": "https://instanceid.jfrog.io/"
                      },
                      {
                        "name": "8:rsync",
                        "package_type": "Rpm",
                        "version": "0:3.1.3-14.el8_6.5",
                        "link": "https://instanceid.jfrog.io/"
                      },
                      {
                        "name": "8:rsync",
                        "package_type": "Rpm",
                        "version": "0:3.1.3-19.el8",
                        "link": "https://instanceid.jfrog.io/"
                      },
                      {
                        "name": "8:rsync",
                        "package_type": "Rpm",
                        "version": "0:3.1.3-19.el8_7.1",
                        "link": "https://instanceid.jfrog.io/"
                      }
                    ]
                  }
                ]
              }
            }
          },
          "400": {
            "description": "Got invalid CVE",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "415": {
            "description": "Failed to parse request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/component/searchCvesByComponents": {
      "post": {
        "operationId": "find-cves-by-component",
        "summary": "Find CVEs by Component",
        "description": "Searches for CVEs that affect the specified components. Each component is identified by its component ID (e.g., gav://commons-collections:commons-collections:3.2.1). Returns CVE IDs grouped by component. If a component is not found, the response includes an error field for that component.\n\nRequires the Reports Manager permission.\n",
        "tags": [
          "Xray",
          "Search V1"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "components_id": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "components_id"
                ]
              },
              "example": {
                "components_id": [
                  "gav://commons-collections:commons-collections:3.2.1",
                  "c2"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Valid Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "component": {
                        "type": "string"
                      },
                      "cves": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": [
                      "component",
                      "cves"
                    ]
                  }
                },
                "example": [
                  {
                    "component": "gav://commons-collections:commons-collections:3.2.1",
                    "cves": [
                      "CVE-2017-15708"
                    ]
                  },
                  {
                    "component": "c2",
                    "error": "Failed to get component",
                    "cves": []
                  }
                ]
              }
            }
          },
          "415": {
            "description": "Failed to parse request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "description": "Failed to search CVEs of components",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/search/impactedResources": {
      "get": {
        "operationId": "search-resources-by-vulnerability-and-package",
        "summary": "Search Resources by Vulnerability and Package",
        "description": "Search all resources (Artifacts, Builds, Release Bundles, etc.) that include a specific package or are impacted by a specific vulnerability (CVE or XRAY ID). Supports three search modes:\n\n- **Mode 1 - By Vulnerability**: `vulnerability` is required.\n- **Mode 2 - By Package Version**: `name` and `type` are required; `version` is optional.\n- **Mode 3 - By Package (all versions)**: `name` and `type` are required; omit `version`.\n\n**SBOM Requirement**: This capability depends on the SBOM Service. Self-Hosted users must enable the SBOM feature and complete the SBOM migration. If SBOM is disabled, the API returns 403.\n\n**Pagination**: Use `last_key` from the response to fetch subsequent pages; an empty `last_key` indicates no further results. Limit defaults to 1000, maximum 10000.\n\nRequires the Reports Manager permission. Since Xray 3.131.\n",
        "tags": [
          "Xray",
          "Search V2"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of resources to return. Default: 1000. Maximum: 10000.",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "last_key",
            "in": "query",
            "description": "Pagination cursor from the previous response. Include this value to retrieve the next page.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "vulnerability",
            "in": "query",
            "description": "Vulnerability ID in CVE format (CVE-YYYY-NNNNN) or XRAY format (XRAY-N). Required for Mode 1.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Package name. Required for Mode 2 and Mode 3.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Package type (e.g., npm, maven, pypi). Required for Mode 2 and Mode 3.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "description": "Package version. When provided with name and type, searches for a specific version.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "namespace",
            "in": "query",
            "description": "Package namespace. Default: public.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ecosystem",
            "in": "query",
            "description": "Package ecosystem. Default: generic.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search completed successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "array",
                      "description": "Array of resources matching the search criteria.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "description": "Resource type: Artifact, Build, ReleaseBundle, ReleaseBundleV2, AppVersion, Component."
                          },
                          "name": {
                            "type": "string",
                            "description": "Name of the resource."
                          },
                          "path": {
                            "type": "string",
                            "description": "Artifact path in the repository."
                          },
                          "repo": {
                            "type": "string",
                            "description": "Repository name."
                          },
                          "version": {
                            "type": "string",
                            "description": "Version of the resource."
                          },
                          "artifact_name": {
                            "type": "string",
                            "description": "Name of the artifact within an aggregation."
                          },
                          "artifact_pkg_version": {
                            "type": "object",
                            "description": "Package version info for the artifact containing the impacted package.",
                            "properties": {
                              "type": {
                                "type": "string"
                              },
                              "name": {
                                "type": "string"
                              },
                              "namespace": {
                                "type": "string"
                              },
                              "version": {
                                "type": "string"
                              },
                              "ecosystem": {
                                "type": "string"
                              }
                            }
                          },
                          "scan_date": {
                            "type": "string",
                            "description": "ISO 8601 timestamp of when the resource was last scanned."
                          },
                          "impacted_pkg_version": {
                            "type": "object",
                            "description": "Package version info for the impacted package matching the search.",
                            "properties": {
                              "type": {
                                "type": "string"
                              },
                              "name": {
                                "type": "string"
                              },
                              "namespace": {
                                "type": "string"
                              },
                              "version": {
                                "type": "string"
                              },
                              "ecosystem": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    },
                    "last_key": {
                      "type": "string",
                      "description": "Pagination cursor. Empty string means no more results."
                    }
                  }
                },
                "example": {
                  "result": [
                    {
                      "type": "Artifact",
                      "name": "app.jar",
                      "path": "libs-release-local/com/example/app/1.0.0/app-1.0.0.jar",
                      "repo": "libs-release-local",
                      "scan_date": "2024-01-15T10:30:00Z",
                      "artifact_pkg_version": {
                        "type": "maven",
                        "name": "app",
                        "namespace": "com.example",
                        "version": "1.0.0",
                        "ecosystem": "generic"
                      },
                      "impacted_pkg_version": {
                        "type": "maven",
                        "name": "log4j-core",
                        "namespace": "org.apache.logging.log4j",
                        "version": "2.14.1",
                        "ecosystem": "generic"
                      }
                    }
                  ],
                  "last_key": "eyJwcmltYXJ5S2V5IjoiMTIzNDU2Nzg5MCJ9"
                }
              }
            }
          },
          "400": {
            "description": "Missing required parameters or invalid values.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "error": "Mandatory parameters: \"vulnerability\" OR (\"type\", \"name\", [\"version\"])"
                }
              }
            }
          },
          "403": {
            "description": "Permission denied or SBOM feature is disabled.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "error": "SBOM is disabled"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              },
              "example": {
                "result": [
                  {
                    "type": "Artifact",
                    "name": "app.jar",
                    "path": "libs-release-local/com/example/app/1.0.0/app-1.0.0.jar",
                    "repo": "libs-release-local",
                    "scan_date": "2024-01-15T10:30:00Z",
                    "artifact_pkg_version": {
                      "type": "maven",
                      "name": "app",
                      "namespace": "com.example",
                      "version": "1.0.0",
                      "ecosystem": "generic"
                    },
                    "impacted_pkg_version": {
                      "type": "maven",
                      "name": "log4j-core",
                      "namespace": "org.apache.logging.log4j",
                      "version": "2.14.1",
                      "ecosystem": "generic"
                    }
                  }
                ],
                "last_key": "eyJwcmltYXJ5IjoiMTIzNDU2Nzg5MCIsInNlY29uZGFyeSI6ImFiY2RlZjEyMzQ1Njc4OTAifQ=="
              }
            }
          }
        }
      }
    },
    "/api/v1/configuration/workersCount": {
      "get": {
        "operationId": "get-the-workers-count",
        "summary": "Get the Workers Count",
        "description": "Returns the current worker thread counts for each processing lane (index, persist, analysis, alert, impact analysis, notification). Each lane has separate counts for new content and existing content processing.\n\nAvailable for Self-Hosted installation only, not in JFrog SaaS. Requires System Admin permission.\n",
        "tags": [
          "Xray",
          "System V1"
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "index": {
                      "type": "object",
                      "properties": {
                        "new_content": {
                          "type": "integer"
                        },
                        "existing_content": {
                          "type": "integer"
                        }
                      },
                      "required": [
                        "new_content",
                        "existing_content"
                      ]
                    },
                    "persist": {
                      "type": "object",
                      "properties": {
                        "new_content": {
                          "type": "integer"
                        },
                        "existing_content": {
                          "type": "integer"
                        }
                      },
                      "required": [
                        "new_content",
                        "existing_content"
                      ]
                    },
                    "analysis": {
                      "type": "object",
                      "properties": {
                        "new_content": {
                          "type": "integer"
                        },
                        "existing_content": {
                          "type": "integer"
                        }
                      },
                      "required": [
                        "new_content",
                        "existing_content"
                      ]
                    },
                    "alert": {
                      "type": "object",
                      "properties": {
                        "new_content": {
                          "type": "integer"
                        },
                        "existing_content": {
                          "type": "integer"
                        }
                      },
                      "required": [
                        "new_content",
                        "existing_content"
                      ]
                    },
                    "impact_analysis": {
                      "type": "object",
                      "properties": {
                        "new_content": {
                          "type": "integer"
                        }
                      },
                      "required": [
                        "new_content"
                      ]
                    },
                    "notification": {
                      "type": "object",
                      "properties": {
                        "new_content": {
                          "type": "integer"
                        }
                      },
                      "required": [
                        "new_content"
                      ]
                    }
                  },
                  "required": [
                    "index",
                    "persist",
                    "analysis",
                    "alert",
                    "impact_analysis",
                    "notification"
                  ]
                },
                "example": {
                  "index": {
                    "new_content": 8,
                    "existing_content": 4
                  },
                  "persist": {
                    "new_content": 8,
                    "existing_content": 4
                  },
                  "analysis": {
                    "new_content": 8,
                    "existing_content": 4
                  },
                  "alert": {
                    "new_content": 8,
                    "existing_content": 4
                  },
                  "impact_analysis": {
                    "new_content": 4
                  },
                  "notification": {
                    "new_content": 8
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "description": "Failed to get worker settings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "configuring-the-workers-count",
        "summary": "Update Workers Count",
        "description": "Updates the worker thread counts for each processing lane. Changes require a system restart to take effect.\n\nAvailable for Self-Hosted installation only, not in JFrog SaaS. Requires System Admin permission.\n",
        "tags": [
          "Xray",
          "System V1"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "index": {
                    "type": "object",
                    "properties": {
                      "new_content": {
                        "type": "integer",
                        "description": "Number of workers for indexing new content."
                      },
                      "existing_content": {
                        "type": "integer",
                        "description": "Number of workers for indexing existing content."
                      }
                    }
                  },
                  "persist": {
                    "type": "object",
                    "properties": {
                      "new_content": {
                        "type": "integer"
                      },
                      "existing_content": {
                        "type": "integer"
                      }
                    }
                  },
                  "analysis": {
                    "type": "object",
                    "properties": {
                      "new_content": {
                        "type": "integer"
                      },
                      "existing_content": {
                        "type": "integer"
                      }
                    }
                  },
                  "alert": {
                    "type": "object",
                    "properties": {
                      "new_content": {
                        "type": "integer"
                      },
                      "existing_content": {
                        "type": "integer"
                      }
                    }
                  },
                  "impact_analysis": {
                    "type": "object",
                    "properties": {
                      "new_content": {
                        "type": "integer"
                      }
                    }
                  },
                  "notification": {
                    "type": "object",
                    "properties": {
                      "new_content": {
                        "type": "integer"
                      }
                    }
                  }
                }
              },
              "example": {
                "index": {
                  "new_content": 8,
                  "existing_content": 4
                },
                "persist": {
                  "new_content": 8,
                  "existing_content": 4
                },
                "analysis": {
                  "new_content": 8,
                  "existing_content": 4
                },
                "alert": {
                  "new_content": 8,
                  "existing_content": 4
                },
                "impact_analysis": {
                  "new_content": 4
                },
                "notification": {
                  "new_content": 8
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Failed to parse workers count",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "415": {
            "description": "Unsupported media type",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "500": {
            "description": "Failed to update workers count",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/git/repositories": {
      "get": {
        "operationId": "get-git-repositories",
        "summary": "Get Git Repositories",
        "description": "Retrieves a list of all git repositories that have been scanned. Allows fetching comprehensive information about git repositories based on scans that have been performed. You can apply various filters to refine the results.\n\nRequires a user with READ permissions. Since Xray 3.122.\n",
        "tags": [
          "Xray",
          "Source Code V1"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination. Default: 1.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results per page. Default: 50.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "required": false,
            "description": "Sort field: id, name, or last_scanned_date.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "description": "Sort direction: asc or desc.",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of git repositories retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "page": {
                      "type": "integer"
                    },
                    "limit": {
                      "type": "integer"
                    },
                    "total_count": {
                      "type": "integer"
                    },
                    "repositories": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer",
                            "description": "Unique identifier."
                          },
                          "url": {
                            "type": "string",
                            "description": "Repository URL."
                          },
                          "name": {
                            "type": "string",
                            "description": "Repository name."
                          },
                          "git_project": {
                            "type": "string",
                            "description": "Owning project name."
                          },
                          "git_provider": {
                            "type": "string",
                            "description": "Provider: GitHub, GitLab, Bitbucket, Azure, or unknown."
                          },
                          "last_scanned_date": {
                            "type": "string",
                            "description": "ISO 8601 timestamp of the last scan."
                          },
                          "last_scanned_commit": {
                            "type": "string",
                            "description": "Hash of the last scanned commit."
                          },
                          "scanned_branches": {
                            "type": "array",
                            "description": "Branches that were scanned.",
                            "items": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "page": 1,
                  "limit": 10,
                  "total_count": 1,
                  "repositories": [
                    {
                      "id": 12,
                      "url": "https://git.jfrog.info/projects/XSC/repos/xsc-service",
                      "name": "xsc-service",
                      "git_project": "XSC",
                      "git_provider": "github",
                      "last_scanned_date": "2024-08-10T10:13:48Z",
                      "last_scanned_commit": "0ba779e5",
                      "scanned_branches": [
                        "main"
                      ]
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/v1/git/repositories/{repository_id}/branches": {
      "get": {
        "operationId": "get-git-repository-branches",
        "summary": "Get Branches for a Repository",
        "description": "Retrieves all branches that belong to a specific repository. Allows fetching all Git branches associated with a given repository identified by its repository_id.\n\nRequires a user with READ permissions. Since Xray 3.122.\n",
        "tags": [
          "Xray",
          "Source Code V1"
        ],
        "parameters": [
          {
            "name": "repository_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the repository.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination. Default: 1.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results per page. Default: 50.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "required": false,
            "description": "Sort field: name or last_scanned_date.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "description": "Sort direction: asc or desc.",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Branches retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "page": {
                      "type": "integer"
                    },
                    "limit": {
                      "type": "integer"
                    },
                    "total_count": {
                      "type": "integer"
                    },
                    "repository_id": {
                      "type": "integer"
                    },
                    "repository_url": {
                      "type": "string"
                    },
                    "repository_name": {
                      "type": "string"
                    },
                    "branches": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string",
                            "description": "Branch name."
                          },
                          "last_scanned_date": {
                            "type": "string",
                            "description": "ISO 8601 timestamp of the last scan on this branch."
                          },
                          "last_scanned_commit": {
                            "type": "string",
                            "description": "Hash of the last scanned commit for the branch."
                          },
                          "scanned_commits_count": {
                            "type": "integer",
                            "description": "Total number of commits scanned for this branch."
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "page": 1,
                  "limit": 10,
                  "total_count": 1,
                  "repository_id": 12,
                  "repository_url": "https://git.jfrog.info/projects/XSC/repos/xsc-service",
                  "repository_name": "xsc-service",
                  "branches": [
                    {
                      "name": "main",
                      "last_scanned_commit": "0ba779e5",
                      "last_scanned_date": "2024-08-10T10:13:48Z",
                      "scanned_commits_count": 1
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters."
          },
          "404": {
            "description": "Repository not found: repository_id does not exist."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/v1/git/repositories/{repository_id}/commits": {
      "get": {
        "operationId": "get-git-repository-commits",
        "summary": "Get Commits for a Branch",
        "description": "Retrieves all commits that were scanned for a specific branch within a repository. The branch_name query parameter is required.\n\nRequires a user with READ permissions. Since Xray 3.122.\n",
        "tags": [
          "Xray",
          "Source Code V1"
        ],
        "parameters": [
          {
            "name": "repository_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the repository.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "branch_name",
            "in": "query",
            "required": true,
            "description": "The name of the branch for which you want to retrieve commits.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number for pagination. Default: 1.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results per page. Default: 50.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "required": false,
            "description": "Sort field: author or last_scanned_date.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "description": "Sort direction: asc or desc.",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Commits retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "page": {
                      "type": "integer"
                    },
                    "limit": {
                      "type": "integer"
                    },
                    "total_count": {
                      "type": "integer"
                    },
                    "repository_id": {
                      "type": "integer"
                    },
                    "repository_url": {
                      "type": "string"
                    },
                    "repository_name": {
                      "type": "string"
                    },
                    "branch_name": {
                      "type": "string"
                    },
                    "commits": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "hash": {
                            "type": "string",
                            "description": "The hash of the commit."
                          },
                          "author": {
                            "type": "string",
                            "description": "The author of the commit."
                          },
                          "scan_date": {
                            "type": "string",
                            "description": "ISO 8601 timestamp of when the commit was scanned."
                          },
                          "commit_message": {
                            "type": "string",
                            "description": "The message associated with the commit."
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "page": 1,
                  "limit": 10,
                  "total_count": 1,
                  "repository_id": 12,
                  "repository_url": "https://git.jfrog.info/projects/XSC/repos/xsc-service",
                  "repository_name": "xsc-service",
                  "branch_name": "main",
                  "commits": [
                    {
                      "hash": "0ba779e5",
                      "author": "JFrog the Frog",
                      "scan_date": "2024-08-10T10:13:48Z",
                      "commit_message": "This is my commit message"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/v1/git/repositories/{repository_id}/commits/{commit_hash}/scan-results": {
      "get": {
        "operationId": "get-git-commit-scan-results",
        "summary": "Get Scan Results for a Commit",
        "description": "Retrieves the scan results data associated with a specific commit in a branch of a repository. The scan results provide insights into vulnerabilities, SBOM components, operational risks, secrets, IaC issues, and SAST findings detected at the time of the commit.\n\nIf the same commit was scanned multiple times (e.g., by different jobs), the API returns findings from all scans. It does not deduplicate issues across scans.\n\nRequires a user with READ permissions. Since Xray 3.122.\n",
        "tags": [
          "Xray",
          "Source Code V1"
        ],
        "parameters": [
          {
            "name": "repository_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the repository.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "commit_hash",
            "in": "path",
            "required": true,
            "description": "The hash of the commit for which to retrieve scan results.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "branch_name",
            "in": "query",
            "required": true,
            "description": "The name of the branch that contains the commit.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Scan results retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "repository_id": {
                      "type": "integer"
                    },
                    "repository_url": {
                      "type": "string"
                    },
                    "repository_name": {
                      "type": "string"
                    },
                    "branch_name": {
                      "type": "string"
                    },
                    "commit_hash": {
                      "type": "string"
                    },
                    "scan_results": {
                      "type": "object",
                      "description": "Detailed scan results for the commit.",
                      "properties": {
                        "cves": {
                          "type": "array",
                          "description": "CVEs found in the commit.",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "description": "Unique identifier (e.g., XRAY-XXXX)."
                              },
                              "severity": {
                                "type": "string",
                                "description": "Severity level: Critical, High, Medium, Low."
                              },
                              "severity_source": {
                                "type": "string",
                                "description": "Source of severity rating (e.g., CVSS V3 from NVD)."
                              },
                              "jfrog_severity": {
                                "type": "string",
                                "description": "JFrog Research severity level."
                              },
                              "summary": {
                                "type": "string",
                                "description": "Brief description of the vulnerability."
                              },
                              "cve": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string",
                                    "description": "CVE identifier (e.g., CVE-2022-2911)."
                                  },
                                  "cvss_v2": {
                                    "type": "string"
                                  },
                                  "cvss_v3": {
                                    "type": "string"
                                  },
                                  "cwes": {
                                    "type": "array",
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "cwe_id": {
                                          "type": "string"
                                        },
                                        "name": {
                                          "type": "string"
                                        }
                                      }
                                    }
                                  }
                                }
                              },
                              "components": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "id": {
                                      "type": "string",
                                      "description": "Component identifier (e.g., pypi://werkzeug:1.0.1)."
                                    },
                                    "type": {
                                      "type": "string"
                                    },
                                    "name": {
                                      "type": "string"
                                    },
                                    "version": {
                                      "type": "string"
                                    },
                                    "fixed_versions": {
                                      "type": "array",
                                      "items": {
                                        "type": "string"
                                      }
                                    }
                                  }
                                }
                              },
                              "contextual_analysis": {
                                "type": "object",
                                "description": "Contextual analysis (applicability) results for this CVE.",
                                "properties": {
                                  "applicability_result": {
                                    "type": "string",
                                    "description": "Applicability status (e.g., applicable, not_applicable)."
                                  },
                                  "cve": {
                                    "type": "string",
                                    "description": "The CVE identifier this analysis relates to."
                                  },
                                  "scanner_description": {
                                    "type": "string",
                                    "description": "Explanation from the contextual analysis scanner."
                                  },
                                  "applicability_evidence": {
                                    "type": "object",
                                    "properties": {
                                      "file": {
                                        "type": "string",
                                        "description": "File path where the vulnerability is applicable."
                                      },
                                      "start_line": {
                                        "type": "integer",
                                        "description": "Line number in the file."
                                      }
                                    }
                                  }
                                }
                              },
                              "jfrog_research_information": {
                                "type": "object",
                                "description": "JFrog Security Research analysis for this CVE.",
                                "properties": {
                                  "severity": {
                                    "type": "string",
                                    "description": "JFrog Research severity assessment."
                                  },
                                  "summary": {
                                    "type": "string",
                                    "description": "Research summary."
                                  },
                                  "details": {
                                    "type": "string",
                                    "description": "Detailed research analysis."
                                  },
                                  "remediation": {
                                    "type": "string",
                                    "description": "Recommended remediation steps."
                                  },
                                  "severity_reasons": {
                                    "type": "array",
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "name": {
                                          "type": "string"
                                        },
                                        "description": {
                                          "type": "string"
                                        },
                                        "is_positive": {
                                          "type": "boolean"
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        },
                        "sbom": {
                          "type": "array",
                          "description": "SBOM components detected in the commit.",
                          "items": {
                            "type": "object",
                            "properties": {
                              "component_id": {
                                "type": "string",
                                "description": "Component identifier (e.g., pypi://werkzeug:1.0.1)."
                              },
                              "component_name": {
                                "type": "string"
                              },
                              "component_version": {
                                "type": "string"
                              },
                              "package_type": {
                                "type": "string"
                              },
                              "licenses": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "key": {
                                      "type": "string",
                                      "description": "License key/name."
                                    },
                                    "link": {
                                      "type": "string",
                                      "description": "License reference URL."
                                    }
                                  }
                                }
                              }
                            }
                          }
                        },
                        "operational_risks": {
                          "type": "array",
                          "description": "Operational risks identified during the scan.",
                          "items": {
                            "type": "object",
                            "properties": {
                              "component_id": {
                                "type": "string"
                              },
                              "component_name": {
                                "type": "string"
                              },
                              "component_version": {
                                "type": "string"
                              },
                              "risk": {
                                "type": "string",
                                "description": "Risk level."
                              },
                              "risk_reason": {
                                "type": "string"
                              },
                              "is_eol": {
                                "type": "boolean"
                              },
                              "released": {
                                "type": "string"
                              },
                              "latest_version": {
                                "type": "string"
                              },
                              "cadence": {
                                "type": "integer",
                                "description": "Release cadence."
                              }
                            }
                          }
                        },
                        "secrets": {
                          "type": "array",
                          "description": "Secrets detected in the code.",
                          "items": {
                            "type": "object",
                            "properties": {
                              "jfrog_severity": {
                                "type": "string"
                              },
                              "id": {
                                "type": "string",
                                "description": "Exposure ID."
                              },
                              "description": {
                                "type": "string"
                              },
                              "abbreviation": {
                                "type": "string"
                              },
                              "cwe": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string"
                                  }
                                }
                              },
                              "file": {
                                "type": "string",
                                "description": "File path where the secret was found."
                              },
                              "start_line": {
                                "type": "integer"
                              },
                              "origin": {
                                "type": "string"
                              }
                            }
                          }
                        },
                        "iac": {
                          "type": "array",
                          "description": "Infrastructure as Code issues identified.",
                          "items": {
                            "type": "object",
                            "properties": {
                              "jfrog_severity": {
                                "type": "string"
                              },
                              "id": {
                                "type": "string",
                                "description": "Issue ID."
                              },
                              "file": {
                                "type": "string"
                              },
                              "start_line": {
                                "type": "integer"
                              },
                              "abbreviation": {
                                "type": "string"
                              },
                              "description": {
                                "type": "string"
                              }
                            }
                          }
                        },
                        "sast": {
                          "type": "array",
                          "description": "Static Application Security Testing results.",
                          "items": {
                            "type": "object",
                            "properties": {
                              "jfrog_severity": {
                                "type": "string"
                              },
                              "id": {
                                "type": "string",
                                "description": "Issue ID."
                              },
                              "file": {
                                "type": "string"
                              },
                              "start_line": {
                                "type": "integer"
                              },
                              "abbreviation": {
                                "type": "string"
                              },
                              "fingerprint": {
                                "type": "string"
                              },
                              "description": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/v1/system/liveness": {
      "get": {
        "operationId": "system-liveness",
        "summary": "System Liveness",
        "description": "Kubernetes-style liveness probe. Returns 200 if the Xray service is alive, or 503 if health checks have failed. No authentication required.\n",
        "tags": [
          "Xray",
          "System V1"
        ],
        "responses": {
          "200": {
            "description": "Service is alive.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "OK"
                }
              }
            }
          },
          "503": {
            "description": "Service is unhealthy."
          }
        }
      }
    },
    "/api/v1/system/ping": {
      "get": {
        "operationId": "ping-request",
        "summary": "Ping",
        "description": "Simple health check endpoint. Returns a pong response to verify the Xray service is responding. No authentication required.\n",
        "tags": [
          "Xray",
          "System V1"
        ],
        "responses": {
          "200": {
            "description": "Xray is responding.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "pong"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/system/readiness": {
      "get": {
        "operationId": "system-readiness",
        "summary": "System Readiness",
        "description": "Kubernetes-style readiness probe. Returns 200 if all dependent services are ready. Supports an optional `noCache` query parameter to bypass cached results. No authentication required.\n",
        "tags": [
          "Xray",
          "System V1"
        ],
        "parameters": [
          {
            "name": "noCache",
            "in": "query",
            "required": false,
            "description": "Bypass cached readiness result and check live status.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Service is ready.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "OK"
                }
              }
            }
          },
          "503": {
            "description": "Service is not ready (dependencies unavailable)."
          }
        }
      }
    },
    "/api/v1/system/version": {
      "get": {
        "operationId": "get-version",
        "summary": "Get Version",
        "description": "Returns the Xray version and revision number. No authentication required by default (can be configured to require Read permission via `authenticateRequestForSystemVersion` setting).\n",
        "tags": [
          "Xray",
          "System V1"
        ],
        "responses": {
          "200": {
            "description": "Version information retrieved successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "xray_version": {
                      "type": "string",
                      "description": "Current Xray version."
                    },
                    "xray_revision": {
                      "type": "string",
                      "description": "Current Xray revision/build number."
                    }
                  }
                },
                "example": {
                  "xray_version": "3.140.0",
                  "xray_revision": "31400900"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/violations": {
      "post": {
        "operationId": "get-violations",
        "summary": "Get Violations",
        "description": "Gets Xray violations based on a set of search criteria. Returns violations with details about severity, type, infected components, and impacted artifacts. Use the `filters` object to narrow results by violation type, watch, severity, time range, CVE, issue ID, and specific resources. Use the `pagination` object to control sorting and paging.\n\nStarting from Xray version 3.42.3, JFrog Security CVE Research and Enrichment data is supported in the response. Fields short_description, full_description, and remediation are markdown.\n\nRequires a user with Read permissions.\n",
        "tags": [
          "Xray",
          "Violations V1"
        ],
        "parameters": [
          {
            "name": "projectKey",
            "in": "query",
            "description": "When included, the response is scoped to the specified project.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ViolationsSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_violations": {
                      "type": "integer"
                    },
                    "violations": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "description": {
                            "type": "string"
                          },
                          "severity": {
                            "type": "string"
                          },
                          "type": {
                            "type": "string"
                          },
                          "infected_components": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "created": {
                            "type": "string"
                          },
                          "watch_name": {
                            "type": "string"
                          },
                          "issue_id": {
                            "type": "string"
                          },
                          "violation_details_url": {
                            "type": "string"
                          },
                          "impacted_artifacts": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "applicability": {
                            "type": "null"
                          }
                        },
                        "required": [
                          "description",
                          "severity",
                          "type",
                          "infected_components",
                          "created",
                          "watch_name",
                          "issue_id",
                          "violation_details_url",
                          "impacted_artifacts"
                        ]
                      }
                    }
                  },
                  "required": [
                    "total_violations",
                    "violations"
                  ]
                },
                "example": {
                  "total_violations": 1,
                  "violations": [
                    {
                      "description": "Number of new versions and Version Age",
                      "severity": "High",
                      "type": "Operational_Risk",
                      "infected_components": [
                        "gav://joda-time:joda-time:2.9.9"
                      ],
                      "created": "2022-03-24T14:54:42+02:00",
                      "watch_name": "OpRiskWatch",
                      "issue_id": "1ea7a8e0904b4a6c1a837e8ab437e0892dd00ad203814f3b9edfd2a3d8be3b88",
                      "violation_details_url": "http://test.jfrog.io/xray/api/v1/violations?watch_id=8d5a6d7364154c5c2455993a&issue_id=1ea7a8e0904b4a6c1a837e8ab437e0892dd00ad203814f3b9edfd2a3d8be3b88&comp_id=gav:%2F%2Forg.jruby:jruby-complete:9.2.0.0",
                      "impacted_artifacts": [
                        "default/generic-local/jruby-complete-9.2.0.0.jar"
                      ],
                      "applicability": null
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/violations/ignored": {
      "post": {
        "operationId": "list-ignored-violations",
        "summary": "List Ignored Violations",
        "description": "Returns ignored violations by filters. Accepts objective filters (vulnerabilities, licenses, cves, operational_risk, exposures) and scope filters (policies, watches, components, artifacts, builds, release-bundles, etc.) in the request body. Pagination parameters are passed as query parameters.\n\nRequires the \"Manage Watches\" permission. Since Xray 3.11. Applicable to JFrog SaaS and Self-Hosted.\n",
        "tags": [
          "Xray",
          "Violations V1"
        ],
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "description": "Offset for pagination.",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Limit for pagination.",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Field to order results. Possible values: updated, severity.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Filters for listing ignored violations. All fields are optional.\n",
                "properties": {
                  "vulnerabilities": {
                    "type": "array",
                    "description": "List of vulnerability IDs (XRAY-nnnnn) to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "licenses": {
                    "type": "array",
                    "description": "List of licenses to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "cves": {
                    "type": "array",
                    "description": "List of CVEs to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "operational_risk": {
                    "type": "array",
                    "description": "List of operational risk packages to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "exposures": {
                    "type": "array",
                    "description": "List of exposures to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "packages": {
                    "type": "array",
                    "description": "List of packages to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "policies": {
                    "type": "array",
                    "description": "List of policies to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "watches": {
                    "type": "array",
                    "description": "List of watches to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "projects": {
                    "type": "array",
                    "description": "List of projects to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "git_repositories": {
                    "type": "array",
                    "description": "List of git repositories to filter by.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "components": {
                    "type": "array",
                    "description": "List of components to filter by (name required, version optional).",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "docker-layers": {
                    "type": "array",
                    "description": "List of Docker layer SHA256 hashes.",
                    "items": {
                      "type": "string"
                    }
                  },
                  "artifacts": {
                    "type": "array",
                    "description": "List of artifacts to filter by (name required).",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "builds": {
                    "type": "array",
                    "description": "List of builds to filter by.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "release-bundles": {
                    "type": "array",
                    "description": "List of release bundles to filter by.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "release_bundles_v2": {
                    "type": "array",
                    "description": "List of v2 release bundles to filter by.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              },
              "example": {
                "vulnerabilities": [
                  "XRAY-521512"
                ],
                "artifacts": [
                  {
                    "name": "docker://redis"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully retrieved ignored violations.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "description": "List of ignored violations.",
                      "items": {
                        "type": "object"
                      }
                    },
                    "total_count": {
                      "type": "integer",
                      "description": "Total count of matching ignored violations."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Failed to parse filters or invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "error": "Failed to parse filters"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "error": "Failed to list ignored user issues by filters"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/violations/restore": {
      "post": {
        "operationId": "restore-ignored-violations",
        "summary": "Restore Ignored Violations",
        "description": "Restores violations that were previously ignored by an Ignore Rule. The violations are identified by their violation IDs. Maximum of 500 violations can be restored per request (configurable).\n\nRequires the \"Manage Watches\" permission. Since Xray 3.16. Applicable to JFrog SaaS and Self-Hosted.\n",
        "tags": [
          "Xray",
          "Violations V1"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ids"
                ],
                "properties": {
                  "ids": {
                    "type": "array",
                    "description": "Array of violation IDs to restore.",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "example": {
                "ids": [
                  "id1",
                  "id2"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Violations restored successfully."
          },
          "400": {
            "description": "No violation IDs provided, or too many IDs (limit 500 per request).\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "error": "At least one ignored violation id must be provided"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "error": "Failed to restore ignored violations"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/violations/ignored/{watch_name}": {
      "get": {
        "operationId": "get-ignored-violations",
        "summary": "Get Ignored Violations",
        "description": "Gets a list of all ignored violations on a specific watch. Returns violation details along with the ignore rule information that caused each violation to be suppressed.\n\nRequires the \"Manage Watches\" permission. Since Xray 3.11.\n",
        "tags": [
          "Xray",
          "Violations V1"
        ],
        "parameters": [
          {
            "name": "watch_name",
            "in": "path",
            "description": "The name of the watch to retrieve ignored violations for.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "prod-watch"
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Limit of violations to retrieve. Default: 500.",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Offset for pagination. Default: 1.",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Order by severity or updated. Default: updated.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "severity",
                "updated"
              ]
            }
          }
