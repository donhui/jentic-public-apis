                  "public_key": {
                    "type": "string",
                    "description": "Public GPG key content (ASCII-armored)"
                  },
                  "private_key": {
                    "type": "string",
                    "description": "Private GPG key content (ASCII-armored)"
                  },
                  "alias": {
                    "type": "string",
                    "description": "Alias name for the key pair"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success - Key set",
