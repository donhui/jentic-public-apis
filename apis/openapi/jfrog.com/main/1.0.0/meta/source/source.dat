                                },
                                "committers": {
                                  "type": "string"
                                },
                                "released": {
                                  "type": "string"
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "errors": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "identifier": {
                            "type": "string"
                          },
                          "error": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "artifacts": [
                    {
                      "general": {
                        "name": "moment-2.29.3.tar.gz",
                        "component_id": "moment-2.29.3.tar.gz",
