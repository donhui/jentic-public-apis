    "/v1/security/token": {
      "post": {
        "tags": [
          "Distribution",
          "Token"
        ],
        "summary": "Create or Refresh Token",
        "description": "Creates a new access token (grant_type=client_credentials) or refreshes an existing one (grant_type=refresh_token).\nRequest must be application/x-www-form-urlencoded.\n\n**Create token (client_credentials):** Requires username and optionally scope, expires_in, refreshable.\nSupported scopes are admin and groups. Non-admin users can only create tokens for themselves and cannot request admin scope.\n\n**Refresh token (refresh_token):** Requires grant_type, refresh_token, and access_token; optionally expires_in and refreshable.\n",
        "operationId": "createOrRefreshToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "description": "OAuth2 grant type",
                    "enum": [
                      "client_credentials",
                      "refresh_token"
                    ],
                    "default": "client_credentials"
                  },
                  "username": {
                    "type": "string",
                    "description": "Required for client_credentials; user to create token for"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Space-separated scopes (e.g. \"admin\" or \"groups\")"
                  },
                  "expires_in": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Token validity in seconds (0 or omitted for default)",
                    "default": 0
                  },
                  "refreshable": {
                    "type": "boolean",
                    "description": "Whether the token can be refreshed"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Required for refresh_token grant; the refresh token"
                  },
                  "access_token": {
                    "type": "string",
                    "description": "Required for refresh_token grant; the current access token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK - Token refreshed (refresh_token grant)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "201": {
            "description": "Created - New token created (client_credentials grant)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid parameters or grant type",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Not allowed to create token for this user or with requested scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Distribution",
          "Token"
        ],
        "summary": "Get Token Infos",
        "description": "Returns information about tokens (e.g. token ID, issuer, subject, expiry). Requires admin permission.",
        "operationId": "getTokenInfos",
        "responses": {
          "200": {
            "description": "Success - List of token info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokensResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - Admin permission required.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/security/token/revoke": {
      "post": {
        "tags": [
          "Distribution",
          "Token"
        ],
        "summary": "Revoke Token",
        "description": "Revokes a token by providing either the token value (access or refresh token) or the token ID.\nRequest must be application/x-www-form-urlencoded. See RFC 7009 (Token Revocation).\nRequires admin permission.\n",
        "operationId": "revokeToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "The access token or refresh token to revoke (mutually exclusive with token_id)"
                  },
                  "token_id": {
                    "type": "string",
                    "description": "The ID of the token to revoke (mutually exclusive with token)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success - Token revoked"
          },
          "400": {
            "description": "Bad Request - Missing or invalid parameters (e.g. both token and token_id provided)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - Admin permission required.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - Token not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/security/permissions": {
      "get": {
        "tags": [
          "Distribution",
          "Permissions"
        ],
        "summary": "Get All Permissions",
        "description": "Returns all destination permissions configured in the Distribution service. Requires admin permissions.",
        "operationId": "getAllDistributionPermissions",
        "responses": {
          "200": {
            "description": "Success - List of permissions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DestinationPermission"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/security/permissions/{permission_name}": {
      "get": {
        "tags": [
          "Distribution",
          "Permissions"
        ],
        "summary": "Get Permission by Name",
        "description": "Returns a specific destination permission by name. Requires admin permissions.",
        "operationId": "getDistributionPermissionByName",
        "parameters": [
          {
            "name": "permission_name",
            "in": "path",
            "required": true,
            "description": "Permission name",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success - Permission details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DestinationPermission"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified permission was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Distribution",
          "Permissions"
        ],
        "summary": "Create or Update Destination Permission by Name",
        "description": "Creates or updates a destination permission that controls which users and groups can\ndistribute or delete release bundles to specific edge nodes.\n\nThe `distribution_destinations` field is required and defines the target edge nodes\nusing site name, city name, and/or country code filters. The `principals` field defines\nwhich users and groups are granted which actions (distribute, delete).\n\nIf a permission with the given name does not exist, it will be created. If it already\nexists, it will be updated.\n\nRequires admin permissions.\n",
        "operationId": "setDistributionPermission",
        "parameters": [
          {
            "name": "permission_name",
            "in": "path",
            "required": true,
            "description": "Permission name to create or update",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Permission configuration with destination rules and principal actions",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DestinationPermission"
              },
              "examples": {
                "allSites": {
                  "summary": "Grant distribute and delete to a user for all sites",
                  "value": {
                    "distribution_destinations": [
                      {
                        "siteName": "*"
                      }
                    ],
                    "principals": {
                      "users": {
                        "admin_user": [
                          "distribute",
                          "delete"
                        ]
                      },
                      "groups": {
                        "dev-team": [
                          "distribute"
                        ]
                      }
                    }
                  }
                },
                "specificSite": {
                  "summary": "Grant distribute to a group for a specific site",
                  "value": {
                    "distribution_destinations": [
                      {
                        "siteName": "edge-node-1"
                      },
                      {
                        "siteName": "edge-node-2"
                      }
                    ],
                    "principals": {
                      "groups": {
                        "release-managers": [
                          "distribute",
                          "delete"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success - Permission created or updated. Returns the persisted permission.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DestinationPermission"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid permission configuration (e.g., missing distribution_destinations).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict - A permission conflict occurred.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Distribution",
          "Permissions"
        ],
        "summary": "Delete Permission by Name",
        "description": "Deletes a destination permission by name. Requires admin permissions.",
        "operationId": "deleteDistributionPermission",
        "parameters": [
          {
            "name": "permission_name",
            "in": "path",
            "required": true,
            "description": "Permission name to delete",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content - Permission deleted successfully"
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified permission was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/maintenance/stuck_distributions": {
      "get": {
        "tags": [
          "Distribution",
          "Maintenance"
        ],
        "summary": "Get Stuck Distributions",
        "description": "Returns a list of distributions that are currently stuck in a non-final state.\nUse this endpoint to identify distributions that may need to be unlocked using\nthe maintenance execute endpoint with the UNLOCK_STUCK action type.\n\nRequires admin permissions.\n",
        "operationId": "getStuckDistributions",
        "responses": {
          "200": {
            "description": "Success - List of stuck distributions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StuckDistribution"
                  }
                },
                "example": [
                  {
                    "bundleName": "my-bundle",
                    "bundleVersion": "1.0.0",
                    "releaseBundlesSchema": "RBV1",
                    "distributionFriendlyId": 42,
                    "status": "IN_PROGRESS",
                    "distributionTrackerId": 12345
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - Admin permission required.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/maintenance/generate_token/{actionType}": {
      "get": {
        "tags": [
          "Distribution",
          "Maintenance"
        ],
        "summary": "Generate Maintenance Execution Token",
        "description": "Generates a time-limited encrypted token required to execute a maintenance action.\nThe token must be used within 3 minutes. Pass the returned token as the request body\nto the execute endpoint.\n\nRequires admin permissions.\n",
        "operationId": "generateMaintenanceExecutionToken",
        "parameters": [
          {
            "name": "actionType",
            "in": "path",
            "required": true,
            "description": "The type of maintenance action to generate a token for",
            "schema": {
              "type": "string",
              "enum": [
                "STOP_ALL",
                "UNLOCK_STUCK"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success - Token generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "description": "Encrypted time-limited execution token (valid for 3 minutes)"
                    }
                  }
                },
                "example": {
                  "token": "encrypted_token_string"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid action type.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - Admin permission required.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/maintenance/execute/{actionType}": {
      "post": {
        "tags": [
          "Distribution",
          "Maintenance"
        ],
        "summary": "Execute Maintenance Action",
        "description": "Executes a maintenance action using a previously generated token. Two action types are supported:\n\n- **UNLOCK_STUCK**: Unlocks all stuck distributions, allowing them to be retried or cleaned up.\n  Returns a report listing the stuck distributions and whether they were unlocked.\n- **STOP_ALL**: Force-stops all in-progress distributions across the cluster, aborts all\n  non-final trackers in the database, and flushes the task queue. Returns a report with\n  affected tracker counts and queue flush status.\n\nThe `dryRun` query parameter (defaults to `true`) allows previewing what would be affected\nwithout actually performing the action.\n\nRequires admin permissions.\n",
        "operationId": "executeMaintenanceAction",
        "parameters": [
          {
            "name": "actionType",
            "in": "path",
            "required": true,
            "description": "The type of maintenance action to execute",
            "schema": {
              "type": "string",
              "enum": [
                "STOP_ALL",
                "UNLOCK_STUCK"
              ]
            }
          },
          {
            "name": "dryRun",
            "in": "query",
            "required": false,
            "description": "If true (default), simulates the action without executing it. Set to false to actually perform the action.",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "The encrypted execution token obtained from the generate_token endpoint",
          "content": {
            "text/plain": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted - Action executed (or dry-run result). Response schema depends on actionType.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/UnlockStuckReport"
                    },
                    {
                      "$ref": "#/components/schemas/ForceStopAllReport"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid action type or token validation failed (expired, wrong action type).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - Admin permission required.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/maintenance/distributeByLastDays": {
      "post": {
        "tags": [
          "Distribution",
          "Maintenance"
        ],
        "summary": "Distribute by Last Days",
        "description": "Redistributes all release bundles that were distributed within a specified time window to a target edge node.\nThe time window is defined by a date and a number of days to look back from that date.\nFor example, specifying `date: \"2025-03-11\"` and `lastNumberOfDays: 7` will redistribute all release bundles\nthat were distributed in the 7-day window ending on March 11, 2025.\n\nThe `lastNumberOfDays` value must be between 1 and the configured maximum (default: 7).\n\nRequires admin permissions.\n",
        "operationId": "distributeByLastDays",
        "requestBody": {
          "required": true,
          "description": "Configuration for the time-based redistribution",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DistributeByLastDaysRequest"
              },
              "examples": {
                "redistributeLastWeek": {
                  "summary": "Redistribute last 7 days to an edge node",
                  "value": {
                    "date": "2025-03-11",
                    "lastNumberOfDays": 7,
                    "edgeName": "edge-node-1",
                    "autoCreateMissingRepositories": true
                  }
                },
                "redistributeLastDay": {
                  "summary": "Redistribute last day to an edge node",
                  "value": {
                    "date": "2025-03-11",
                    "lastNumberOfDays": 1,
                    "edgeName": "edge-node-1",
                    "autoCreateMissingRepositories": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success - Redistribution triggered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DistributeByLastDaysResponse"
                },
                "example": {
                  "totalTriggered": 3,
                  "triggered": [
                    "release-bundles-v2/my-bundle/1.0.0",
                    "release-bundles-v2/my-bundle/1.1.0",
                    "release-bundles-v2/another-bundle/2.0.0"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid date format, lastNumberOfDays out of range, or edge node not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - Admin permission required.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/metrics": {
      "get": {
        "tags": [
          "Artifacts & Storage",
          "Metrics"
        ],
        "summary": "Get the Open Metrics for Artifactory",
        "description": "Returns all open metrics collected for Artifactory in OpenMetrics/Prometheus exposition text format (`text/plain`). This feature is supported on the Self-Hosted platform, with a Pro, Pro X, Enterprise X, or Enterprise+ license.\n\n**Security**: Requires a valid admin user.\n\nUse `Accept: text/plain` or `Accept: */*` in the request header.\n",
        "operationId": "getOpenMetricsForArtifactory",
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "description": "Must be `text/plain; version=0.0.4` (Prometheus exposition format).",
            "schema": {
              "type": "string",
              "enum": [
                "text/plain; version=0.0.4"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved open metrics in OpenMetrics text format.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Metrics in OpenMetrics/Prometheus exposition text format.",
                  "example": "# HELP jfrt_runtime_heap_freememory_bytes Free heap memory in bytes\n# TYPE jfrt_runtime_heap_freememory_bytes gauge\njfrt_runtime_heap_freememory_bytes 5.36870912e+08\n"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - Authentication failed. A valid token is required."
          },
          "403": {
            "description": "Permission Denied - The user does not have admin permissions."
          },
          "406": {
            "description": "Not Acceptable - The server cannot produce a response matching the Accept header. This endpoint only serves text/plain. Ensure your request uses `Accept: text/plain` or `Accept: */*`."
          }
        }
      }
    },
    "/v1/system/ping": {
      "get": {
        "tags": [
          "Distribution",
          "System"
        ],
        "summary": "Distribution Ping",
        "description": "Health check that indicates whether the Distribution service is running and its dependent services (e.g. Artifactory, Access) are available.\nReturns a JSON body with status. May allow unauthenticated access depending on platform configuration; otherwise returns 401.\n",
        "operationId": "distributionPing",
        "security": [],
        "responses": {
          "200": {
            "description": "Success - Service and dependent services are alive",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                },
                "example": {
                  "message": "ok",
                  "status_code": 200
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Unauthenticated access is forbidden (e.g. when anonymous access is disabled)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                },
                "example": {
                  "detail": "Unauthenticated access to the following path '/v1/system/ping' is forbidden.",
                  "message": "Authentication failed - Forbidden",
                  "status_code": 401
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error - One or more dependent services are unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/system/info": {
      "get": {
        "tags": [
