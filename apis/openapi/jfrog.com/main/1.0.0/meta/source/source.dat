    "/search/license": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "License Search",
        "description": "Search for artifacts that were already tagged with license information and their respective licenses. To search by specific license values use Property Search with the 'artifactory.licenses' property. When the autofind parameter is specified Artifactory will try to automatically find new license information and return it as part of the result in the found field. Default parameter values when unspecified unapproved=1, unknown=1, notfound=0, neutral=0, approved=0, autofind=0. Can limit search to specific repositories (local, remote-cache or virtual).\n\nNotes: Requires Artifactory Pro\n\nSince: 2.3.0\n\nSecurity: Requires an admin user\n",
        "operationId": "searchLicense",
        "parameters": [
          {
            "name": "unapproved",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Include unapproved licenses"
          },
          {
            "name": "unknown",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Include unknown licenses"
          },
          {
            "name": "notfound",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Include not found licenses"
          },
          {
            "name": "neutral",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Include neutral licenses"
          },
          {
            "name": "approved",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Include approved licenses"
          },
          {
            "name": "autofind",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Automatically find new license information"
          },
          {
            "name": "repos",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of repository keys to limit search to"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "uri": {
                            "type": "string",
                            "description": "URI of the artifact (may contain spaces)"
                          },
                          "license": {
                            "type": "string"
                          },
                          "found": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string",
                            "enum": [
                              "approved",
                              "unapproved",
                              "neutral",
                              "unknown"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing required parameters or invalid query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/versions": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "Artifact Version Search",
        "description": "Search for all available artifact versions by GroupId and ArtifactId in local, remote or virtual repositories. Search can be limited to specific repositories (local, remote and virtual) by settings the repos parameter. Release/integration versions Unless the version parameter is specified, both release and integration versions are returned. When version is specified, e.g. 1.0-SNAPSHOT, result includes only integration versions. Remote searches By default only local and cache repositories are used. When specifying remote=1, Artifactory searches for versions on remote repositories. Filtering results (Artifactory 3.0.2+) The version parameter can accept the * and/or ? wildcards which will then filter the final result to match only those who match the given version pattern.\n\nNotes: Requires Artifactory Pro\n\nSince: 2.6.0\n\nSecurity: Requires a privileged user (can be anonymous)\n",
        "operationId": "searchVersions",
        "parameters": [
          {
            "name": "g",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "GroupId"
          },
          {
            "name": "a",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "ArtifactId"
          },
          {
            "name": "v",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Version pattern (supports wildcards * and ?)"
          },
          {
            "name": "remote",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            },
            "description": "When specifying remote=1, Artifactory searches for versions on remote repositories. NOTE! that this can dramatically slow down the search."
          },
          {
            "name": "repos",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of repository keys to limit search to"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "version": {
                            "type": "string"
                          },
                          "integration": {
                            "type": "boolean"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing required parameters or invalid query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/latestVersion": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "Artifact Latest Version Search Based on Layout",
        "description": "Search for the latest artifact version by groupId and artifactId, based on the definitions in the Repository Layouts. This API is based on a Maven-specific algorithm for sorting versions. Search can be limited to specific repositories (local, remote-cache, or virtual) by settings the repos parameter. Latest release vs. latest integration Unless the version parameter is specified, the search returns the latest artifact release version. When version is specified, e.g. 1.0-SNAPSHOT, the result is the latest integration version. Remote searches By default only local and cache repositories will be used. When specifying remote=1, Artifactory searches for versions on remote repositories. Filtering results (Artifactory 3.0.2+) The version parameter can accept the * and/or ? wildcards which will then filter the final result to match only those who match the given version pattern. Artifact path pattern The [org] and [module] fields must be specified in the artifact path pattern of the repository layout for this call to work.\n\nNotes: Requires Artifactory Pro\n\nSince: 2.6.0\n\nSecurity: Requires a privileged user (can be anonymous)\n",
        "operationId": "searchLatestVersion",
        "parameters": [
          {
            "name": "g",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "GroupId"
          },
          {
            "name": "a",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "ArtifactId"
          },
          {
            "name": "v",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Version pattern (supports wildcards * and ?)"
          },
          {
            "name": "remote",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            },
            "description": "When specifying remote=1, Artifactory searches for versions on remote repositories."
          },
          {
            "name": "repos",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of repository keys to limit search to"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Latest version string"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing required parameters or invalid query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/versions/{repo}/{path}": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "Artifact Latest Version Search Based on Properties",
        "description": "Search for artifacts with the latest value in the version property. Only artifacts with the version property expressly defined in lowercase will be returned. \n\nThis API is based on a Maven-specific algorithm for sorting versions. \n\nResults can be filtered by specifying additional properties. \n\n- {repo} Specify a repository to search through or replace with \"_any\" to search through all repositories. \n- {path} Specify a path to search through or replace with \"_any\" to search through all paths. \n- listFiles=0 (default) Artifactory will only retrieve the latest version. \n- listFiles=1 Artifactory will retrieve the latest version and the corresponding files. \n\nYou may specify filters to restrict the set of artifacts that are searched by adding any properties to your search URL.\n\nNotes: Requires Artifactory Pro\n\nSince: 3.1.1\n\nSecurity: Requires a privileged user (can be anonymous)\n",
        "operationId": "searchLatestVersionByProperties",
        "parameters": [
          {
            "name": "repo",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Specify a repository to search through or replace with \"_any\" to search through all repositories"
          },
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Specify a path to search through or replace with \"_any\" to search through all paths"
          },
          {
            "name": "listFiles",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ],
              "default": 0
            },
            "description": "listFiles=0 (default) Artifactory will only retrieve the latest version. listFiles=1 Artifactory will retrieve the latest version and the corresponding files."
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "version": {
                      "type": "string"
                    },
                    "artifacts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "uri": {
                            "type": "string",
                            "format": "uri"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing required parameters or invalid query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified resource was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/buildArtifacts": {
      "post": {
        "tags": [
          "Searches"
        ],
        "summary": "Build Artifacts Search",
        "description": "Find all the artifacts related to a specific build.\n\nNotes: Requires Artifactory Pro\n\nSince: 2.6.5\n\nSecurity: Requires a privileged user (can be anonymous)\n",
        "operationId": "searchBuildArtifacts",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "buildName": {
                    "type": "string",
                    "description": "The build name for search by"
                  },
                  "buildNumber": {
                    "type": "string",
                    "description": "The build number to search by, can be LATEST to search for the latest build number"
                  },
                  "buildStatus": {
                    "type": "string",
                    "description": "Optionally search by latest build status (e.g \"Released\")"
                  },
                  "repos": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Optionally refine search for specific repos, omit to search within all repositories"
                  },
                  "mappings": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "input": {
                          "type": "string",
                          "description": "Regexp pattern to search by"
                        }
                      }
                    },
                    "description": "Optionally refine the search by providing a list of regexp patterns to search by"
                  }
