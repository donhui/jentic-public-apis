              "stopped",
              "cancelled"
            ]
          },
          "description": {
            "type": "string"
          },
          "nodeId": {
            "type": "string"
          },
          "started": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RubyGemVersion": {
        "type": "object",
