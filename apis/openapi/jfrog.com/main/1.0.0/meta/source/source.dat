    "/packages/policies/{policyKey}": {
      "post": {
        "tags": [
          "Cleanup Policies",
          "Package Cleanup Policies"
        ],
        "summary": "Create a Package Cleanup Policy",
        "description": "This API is called to create a new package-level cleanup policy. Packages Cleanup Policies APIs are supported on Artifactory version 7.98.2 and later.",
        "operationId": "createPackageCleanupPolicy",
        "parameters": [
          {
            "name": "policyKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "An ID that is used to identify the cleanup policy. A minimum of three characters is required and can include letters, numbers, underscore and hyphen."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PackageCleanupPolicyRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PackageCleanupPolicyResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestResponse"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      },
      "put": {
        "tags": [
          "Cleanup Policies",
          "Package Cleanup Policies"
        ],
        "summary": "Update a Package-Level Cleanup Policy",
        "description": "This REST API is called to update configuration settings for an existing package-level cleanup policy. A policy cannot be updated if it is currently running.",
        "operationId": "updatePackageCleanupPolicy",
        "parameters": [
          {
            "name": "policyKey",
