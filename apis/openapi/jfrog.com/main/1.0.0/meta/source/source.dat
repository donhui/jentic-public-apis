      "BuildCleanupPolicyRequest": {
        "type": "object",
        "required": [
          "key",
          "itemType",
          "searchCriteria"
        ],
        "properties": {
          "key": {
            "type": "string",
            "description": "A unique identifier for the cleanup policy. A minimum of three characters is required, including letters, numbers, underscore and hyphen."
          },
          "description": {
            "type": "string",
            "maxLength": 256,
            "description": "A brief description of the cleanup policy."
          },
          "cronExp": {
            "type": "string",
            "description": "A cron expression specifying when the cleanup job will run. This parameter is not mandatory, however if left empty the policy will not run automatically and can only be triggered manually."
          },
          "projectKey": {
            "type": "string",
            "description": "This key is obtained from the Project Settings screen. This parameter is used only for project-level cleanup policies."
          },
          "itemType": {
            "type": "string",
            "enum": [
              "build"
            ],
            "description": "The type of items to clean up (build). This field is required."
          },
          "durationInMinutes": {
            "type": "integer",
            "description": "The maximum duration (in minutes) for policy execution, after which the policy will stop running even if not completed."
          },
          "enabled": {
            "type": "boolean",
            "description": "Indicates if the cleanup policy is active (true) or disabled (false). A cleanup policy must be created inactive."
          },
          "deleteArtifacts": {
            "type": "boolean",
            "description": "Deletes the artifacts associated with the build (true to delete)."
          },
          "skipTrashcan": {
            "type": "boolean",
            "description": "A true value means that when this policy is executed, builds will be permanently deleted. false means that when the policy is executed builds will be deleted to the Trash Can."
          },
          "searchCriteria": {
            "$ref": "#/components/schemas/BuildCleanupSearchCriteria"
          }
        }
      },
      "BuildCleanupSearchCriteria": {
        "type": "object",
        "required": [
          "includeAllProjects",
          "includedProjects",
          "includedBuilds"
        ],
        "properties": {
          "includeAllProjects": {
            "type": "boolean",
            "description": "Specifies whether to include all projects in the search (true to include)."
          },
          "includedProjects": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "A list of specific project keys to include in the search."
          },
          "includedBuilds": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BuildTarget"
            },
            "description": "Builds to consider during cleanup."
          },
          "excludeBuildsWithReleaseBundles": {
            "type": "boolean",
            "description": "Specifies whether to exclude builds with release bundles (true to exclude)."
          },
          "createdBeforeInMonths": {
            "type": "integer",
            "minimum": 0,
            "description": "Specifies the time frame for filtering based on item creation date (legacy)."
          },
          "createdBeforeInDays": {
            "type": "integer",
            "minimum": 0,
            "description": "Specifies the time frame for filtering based on item creation date (e.g., 40 days)."
          }
        }
      },
      "BuildTarget": {
        "type": "object",
        "required": [
          "name",
          "projectKey"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the build. Use wildcards at the end to match any suffix."
          },
          "projectKey": {
            "type": "string",
            "description": "The project identifier associated with the build. Leave blank for global level."
          }
        }
      },
      "BuildCleanupPolicyResponse": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "The ID that identifies the policy."
          },
          "description": {
            "type": "string",
            "description": "Description that was defined for the policy."
          },
          "cronExp": {
            "type": "string",
            "description": "The cron expression that determines when the policy is run."
          },
          "projectKey": {
            "type": "string",
            "description": "The project key if this is a project-level policy."
          },
          "itemType": {
            "type": "string",
            "enum": [
              "build"
            ],
            "description": "The type of items (build)."
          },
          "durationInMinutes": {
            "type": "integer",
            "description": "The maximum duration (in minutes) for policy execution."
          },
          "enabled": {
            "type": "boolean",
            "description": "Indicates if the cleanup policy is active (true) or disabled (false)."
          },
          "deleteArtifacts": {
            "type": "boolean",
            "description": "Indicates if artifacts associated with the build are deleted."
          },
          "skipTrashcan": {
            "type": "boolean",
            "description": "Indicates if builds are permanently deleted or sent to Trash Can."
          },
          "searchCriteria": {
            "$ref": "#/components/schemas/BuildCleanupSearchCriteria"
          }
        }
      },
      "CleanupPolicyView": {
        "type": "object",
        "properties": {
          "policies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CleanupPolicyEntry"
            }
          }
        }
      },
      "CleanupPolicyEntry": {
        "type": "object",
        "properties": {
          "itemType": {
            "type": "string",
            "description": "The type of items (package, build, releaseBundle)."
          },
          "policyKey": {
            "type": "string",
            "description": "The unique identifier of the policy."
          },
          "nextRunTime": {
            "type": "integer",
            "format": "int64",
            "description": "The next scheduled run time in epoch milliseconds."
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether the policy is enabled."
          },
          "displayProject": {
            "type": "string",
            "description": "The display name of the project."
          },
          "lastRunData": {
            "$ref": "#/components/schemas/CleanupPolicyLastRun"
          },
          "includedProjects": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of included project keys."
          }
        }
      },
      "CleanupPolicyLastRun": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "The status of the last run."
          },
          "lastRunTime": {
            "type": "integer",
            "format": "int64",
            "description": "The last run time in epoch milliseconds."
          },
          "dryRun": {
            "type": "boolean",
            "description": "Whether the last run was a dry run."
          },
          "runId": {
            "type": "integer",
            "description": "The run ID of the last execution."
          },
          "reportDownloaded": {
            "type": "boolean",
            "description": "Whether the report was downloaded."
          },
          "totalItems": {
            "type": "integer",
            "format": "int64",
            "description": "Total items processed in the last run."
          }
        }
      },
      "CleanupPolicyRunView": {
        "type": "object",
        "properties": {
          "runViews": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CleanupPolicyRunViewEntry"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/Pagination"
          }
        }
      },
      "CleanupPolicyRunViewEntry": {
        "type": "object",
        "properties": {
          "runId": {
            "type": "integer"
          },
          "itemType": {
            "type": "string",
            "enum": [
              "package",
              "build",
              "releaseBundle"
            ]
          },
          "policyKey": {
            "type": "string"
          },
          "displayProject": {
            "type": "string"
          },
          "startTime": {
            "type": "integer",
            "format": "int64"
          },
          "endTime": {
            "type": "integer",
            "format": "int64"
          },
          "totalItems": {
            "type": "integer",
            "format": "int64"
          },
          "cleanedSize": {
            "type": "integer",
            "format": "int64"
          },
          "cleanedItems": {
            "type": "integer",
            "format": "int64"
          },
          "status": {
            "type": "string",
            "enum": [
              "IN_PROGRESS",
              "IN_PROGRESS_WITH_ERRORS",
              "COMPLETED",
              "COMPLETED_WITH_ERRORS",
              "STOPPED",
              "STOPPING",
              "FAILED",
              "PENDING_WARM",
              "PARTIAL_WARMED",
              "WARMED"
            ]
          },
          "triggeredBy": {
            "type": "string"
          },
          "manual": {
            "type": "boolean"
          },
          "dryRun": {
            "type": "boolean"
          },
          "policyTaskId": {
            "type": "integer"
          },
          "includedProjects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "pageSize": {
            "type": "integer",
            "format": "int64",
            "description": "Number of items per page."
          },
          "currentPage": {
            "type": "integer",
            "format": "int64",
            "description": "The current page number."
          },
          "lastPage": {
            "type": "integer",
            "format": "int64",
            "description": "The last page number."
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "Total number of items."
          }
        }
      },
      "RunSummaryResponse": {
        "type": "object",
        "properties": {
          "policySummary": {
            "$ref": "#/components/schemas/PolicySummary"
          },
          "executionSummary": {
            "$ref": "#/components/schemas/ExecutionSummary"
          },
          "processedItemsSummary": {
            "$ref": "#/components/schemas/ProcessedItemsSummary"
          },
          "runConfiguration": {
            "$ref": "#/components/schemas/RunConfiguration"
          }
        }
      },
      "PolicySummary": {
        "type": "object",
        "properties": {
          "policyName": {
            "type": "string"
          },
          "runId": {
            "type": "integer"
          },
          "dryRun": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          },
          "triggeredBy": {
            "type": "string"
          }
        }
      },
      "ExecutionSummary": {
        "type": "object",
        "properties": {
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "finishedAt": {
            "type": "string",
            "format": "date-time"
          },
          "durationMillis": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ProcessedItemsSummary": {
        "type": "object",
        "properties": {
          "itemType": {
            "type": "string"
          },
          "totalItems": {
            "type": "integer",
            "format": "int64"
          },
          "processedItems": {
            "type": "integer",
            "format": "int64"
          },
          "failedItems": {
            "type": "integer",
            "format": "int64"
          },
          "processedPhysicalSizeBytes": {
            "type": "integer",
            "format": "int64"
          },
          "processedVirtualSizeBytes": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "RunConfiguration": {
        "type": "object",
        "properties": {
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdBy": {
            "type": "string"
          },
          "modifiedAt": {
            "type": "string",
            "format": "date-time"
          },
          "modifiedBy": {
            "type": "string"
          },
          "schedule": {
            "$ref": "#/components/schemas/Schedule"
          },
          "description": {
            "type": "string"
          },
          "skipTrashCan": {
            "type": "boolean"
          },
          "target": {
            "$ref": "#/components/schemas/Target"
          },
          "cleanupCriteria": {
            "$ref": "#/components/schemas/CleanupCriteria"
          }
        }
      },
      "Schedule": {
        "type": "object",
        "properties": {
          "cronExpression": {
            "type": "string"
          },
          "maxRunDurationMillis": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "Target": {
        "type": "object",
        "properties": {
          "reposIncluded": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reposExcluded": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "packageTypes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "packagesIncluded": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "packagesExcluded": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "includeAllProjects": {
            "type": "boolean"
          },
          "projectsIncluded": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CleanupCriteria": {
        "type": "object",
        "properties": {
          "createdBefore": {
            "type": "string",
            "description": "Human-readable age derived from createdBeforeInDays (for example, \"30 days\", \"2 months\", \"1 year\")."
          },
          "lastDownloadedBeforeInDays": {
            "type": "integer",
            "format": "int64"
          },
          "keepLastNVersions": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "Searches_ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "integer",
                  "description": "HTTP status code"
                },
                "message": {
                  "type": "string",
                  "description": "Error message"
                }
              }
            }
          }
        }
      },
      "SupportBundleParameters": {
        "type": "object",
        "properties": {
          "configuration": {
            "type": "boolean",
            "default": true,
            "description": "Collect configuration files"
          },
          "system": {
            "type": "boolean",
            "default": true,
            "description": "Collect system information (storage, system properties, CPU, JVM)"
          },
          "collectSlowQueriesFromDatabase": {
            "type": "boolean",
            "default": false,
            "description": "Collect information about the 10 slowest database queries. Supported databases: PostgreSQL, MySQL, MariaDB, MS SQL"
          },
          "logs": {
            "type": "object",
            "properties": {
              "include": {
                "type": "boolean",
                "default": true,
                "description": "Collect system logs"
              },
              "start_date": {
                "type": "string",
                "description": "Start date for log collection. Format: YYYY-MM-DD. Defaults to day before end_date.",
                "example": "2024-08-01"
              },
              "end_date": {
                "type": "string",
                "description": "End date for log collection. Format: YYYY-MM-DD. Defaults to today.",
                "example": "2024-08-01"
              }
            }
          },
          "thread_dump": {
            "type": "object",
            "properties": {
              "count": {
                "type": "integer",
                "default": 1,
                "description": "Number of thread dumps to collect"
              },
              "interval": {
                "type": "integer",
                "default": 0,
                "description": "Interval between thread dumps in milliseconds"
              }
            }
          }
        }
      },
      "SupportBundleConfig": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Support bundle name"
          },
          "description": {
            "type": "string",
            "description": "Support bundle description"
          },
          "parameters": {
            "$ref": "#/components/schemas/SupportBundleParameters"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}