              "type": "string"
            }
          },
          {
            "name": "project",
            "in": "query",
            "description": "The project key used to determine the Release Bundles repository",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repository_key",
            "in": "query",
            "description": "The Release Bundles repository identifier",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Field to order by",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_asc",
            "in": "query",
            "description": "Order ascending",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "limit",
            "in": "query",
