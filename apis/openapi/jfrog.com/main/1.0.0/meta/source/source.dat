          },
          "country_codes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Defines one or more filters for country codes. The default value is [*]."
          }
        }
      },
      "DistributionModifications": {
        "type": "object",
        "properties": {
          "default_path_mapping_by_last_promotion": {
            "type": "boolean",
            "description": "When set to true, the repositories used for the most recent promotion of the Release Bundle version are provided as the path mapping."
          },
          "mappings": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PathMapping"
            },
            "description": "Defines the input and output regex mapping pairs"
          }
        }
      },
      "PathMapping": {
        "type": "object",
        "properties": {
          "input": {
            "type": "string",
            "description": "The input regular expression that defines where the artifacts to distribute are located"
          },
          "output": {
            "type": "string",
            "description": "The output regular expression that defines the target artifact path with parameters from the input regex"
          }
        }
      },
      "DistributeBundleResponse": {
