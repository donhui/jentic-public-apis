                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/security/permissions/{permissionTargetName}": {
      "get": {
        "tags": [
          "Security",
          "Permissions"
        ],
        "summary": "Get Permission Target Details",
        "description": "Returns the details of an Artifactory Permission Target\n\nSince: 2.4.0\n\nNotes: Requires Artifactory Pro. \n\nSecurity: Requires an admin user",
        "operationId": "getPermissionTargetDetails",
        "parameters": [
          {
            "name": "permissionTargetName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The name of the permission target"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified resource was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Security",
          "Permissions"
        ],
        "summary": "Create or Replace Permission Target",
        "description": "Creates a new permission target in the JFrog Unified Platform or replaces an existing permission target\n\nSince: 2.4.0\n\nNotes: Requires Artifactory Pro. \n\n- Missing values will be set to the default values as defined by the consumed type.\n\n- Please note when adding Release Bundles permission targets\n\n- Requires an Edge/Enterprise+ license\n\nOn Edge nodes, the repositories section in the request body can be left empty or contain the \u2018release-bundles\u2019 default repository. No other repositories are allowed. An Enterprise+ license allows you to add any repository\n\nThe default repository in the repository section is \u201crelease-bundles\u201d for both Edge/EntPlus licenses. (if user create permission target with empty repositories section the repository that we put is \u201crelease bundles\u201d)\n\n- To support spaces in the User or Group or Permission names, a Plus symbol (+) is automatically placed when there is a space. This is set by default as the artifactory.\n\nsecurity.api.plus.insteadof.space property is set to true. If you want to use the + (plus) symbol, set the artifactory.security.api.plus.insteadof.space to false.\n\nSecurity: Requires an admin user",
        "operationId": "createOrReplacePermissionTarget",
        "parameters": [
          {
            "name": "permissionTargetName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The name of the permission target"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "repositories"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "The name of the permission target"
                  },
                  "includesPattern": {
                    "type": "string",
                    "description": "A regex pattern that defines which repositories to include in this permission. The default is \"**\" (all)."
                  },
                  "excludesPattern": {
                    "type": "string",
                    "description": "A regex pattern that defines which repositories to explicitly exclude from this permission. The default is \"\" (none)."
                  },
                  "repositories": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Defines the local and remote repositories included as resources for this permission. Note - Virtual repositories are not supported."
                  },
                  "principals": {
                    "type": "object",
                    "properties": {
                      "users": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "m",
                              "d",
                              "w",
                              "n",
                              "r",
                              "mxm",
                              "x"
                            ]
                          }
                        },
                        "description": "Permissions are set/returned according to the following conventions m=admin; d=delete; w=deploy; n=annotate; r=read; mxm=managedXrayMeta; x=distribute"
                      },
                      "groups": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "m",
                              "d",
                              "w",
                              "n",
                              "r",
                              "mxm",
                              "x"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Security",
          "Permissions"
        ],
        "summary": "Delete Permission Target",
        "description": "Deletes an Artifactory permission target.\n\nSince: 2.4.0\n\nNotes: Requires Artifactory Pro. \n\n- To support spaces in the User or Group or Permission names, a Plus symbol (+) is automatically placed when there is a space. This is set by default as the artifactory.security.api.plus.insteadof.space property is set to true. If you want to use the + (plus) symbol, set the artifactory.security.api.plus.insteadof.space to false.\n\nSecurity: Requires an admin user",
        "operationId": "deletePermissionTarget",
        "parameters": [
          {
            "name": "permissionTargetName",
            "in": "path",
            "required": true,
