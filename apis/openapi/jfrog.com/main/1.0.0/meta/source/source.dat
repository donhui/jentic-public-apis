        },
        "responses": {
          "200": {
            "description": "Release bundle scan status returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "overall": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string"
                        },
                        "time": {
                          "type": "string"
                        }
                      }
                    },
                    "details": {
                      "type": "object",
                      "properties": {
                        "sca": {
                          "type": "object",
                          "properties": {
                            "status": {
                              "type": "string"
                            },
                            "time": {
                              "type": "string"
                            }
                          }
                        },
                        "contextual_analysis": {
                          "type": "object",
                          "properties": {
                            "status": {
                              "type": "string"
                            },
                            "time": {
                              "type": "string"
                            }
                          }
                        },
                        "violations": {
                          "type": "object",
                          "properties": {
                            "status": {
                              "type": "string"
                            },
                            "time": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "overall": {
                    "status": "DONE",
                    "time": "2024-06-24T09:04:35Z"
                  },
                  "details": {
                    "sca": {
                      "status": "DONE",
                      "time": "2024-06-24T09:04:35Z"
                    },
                    "contextual_analysis": {
                      "status": "DONE",
