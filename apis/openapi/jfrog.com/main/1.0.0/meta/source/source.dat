                }
              }
            }
          }
        }
      }
    },
    "/search/dependency": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "Builds for Dependency",
        "description": "Find all the builds an artifact is a dependency of (where the artifact is included in the build-info dependencies).\n\nNotes: Requires Artifactory Pro\n\nSince: 2.3.4\n\nSecurity: Requires a privileged user (can be anonymous)\n",
        "operationId": "searchDependency",
        "parameters": [
          {
            "name": "sha1",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "SHA1 checksum"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
