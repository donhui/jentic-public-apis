    "/security/keypair": {
      "post": {
        "tags": [
          "Security",
          "GPG Key Pairs"
        ],
        "summary": "Create Key Pair",
        "description": "Creates a new key pair in Artifactory or replaces an existing pair.\n\nSince: 7.6.0\n\nNotes: Requires Artifactory Pro\n\nYou need to add the --data-binary flag to the call when the keys are provided as part of the JSON payload.\n\nSecurity: Requires an admin user",
        "operationId": "createKeyPair",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "pairName",
                  "pairType",
                  "alias",
                  "privateKey",
                  "publicKey"
                ],
                "properties": {
                  "pairName": {
                    "type": "string",
                    "description": "The name of the key pair (mandatory)"
                  },
                  "pairType": {
                    "type": "string",
                    "enum": [
                      "RSA",
                      "GPG"
                    ],
                    "description": "The type of key pair (mandatory)"
                  },
                  "alias": {
                    "type": "string",
                    "description": "The alias for the key pair (mandatory)"
                  },
                  "privateKey": {
                    "type": "string",
                    "description": "The private key in PEM format (mandatory)"
                  },
                  "publicKey": {
                    "type": "string",
                    "description": "The public key in PEM format (mandatory)"
                  },
                  "passphrase": {
                    "type": "string",
                    "description": "The passphrase for the private key"
                  },
                  "vaultKey": {
                    "type": "string",
                    "description": "Vault key identifier"
                  },
                  "vaultPublicKey": {
                    "type": "object",
                    "description": "Vault public key configuration",
                    "properties": {
                      "path": {
                        "type": "string"
                      },
                      "key": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
