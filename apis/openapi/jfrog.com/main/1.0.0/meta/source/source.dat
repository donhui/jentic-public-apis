          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/policies/forceDisableAll": {
      "put": {
        "tags": [
          "Cleanup Policies",
          "Common Cleanup Policies"
        ],
        "summary": "Disable All Cleanup Policies",
        "description": "This API is called to disable all cleanup policies on the global level. This API disables packages, builds and release bundles policies.",
        "operationId": "disableAllCleanupPolicies",
        "parameters": [
          {
            "name": "projectKey",
            "in": "query",
