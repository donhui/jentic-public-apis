              "$ref": "#/components/schemas/ReportsVulnerabilityContentRow"
            }
          }
        }
      },
      "ReportsVulnerabilityContentRequestBody": {
        "type": "object",
        "properties": {
          "filters": {
            "type": "object",
            "description": "Optional advanced filters (e.g. severity, applicability_result).",
            "additionalProperties": true
          }
        }
      },
      "ReportsCveSearchReportRequest": {
        "type": "object",
        "description": "Request body for generating a CVE Search Report. The CVE and resources scope are required. Filters are optional.\n",
        "required": [
          "cve",
          "resources"
        ],
        "properties": {
          "cve": {
            "type": "string",
            "description": "The CVE identifier to search for (e.g., CVE-2021-45046).",
            "example": "CVE-2021-45046"
          },
          "name": {
            "type": "string",
            "description": "Display name for the report.",
            "example": "report-name"
          },
          "resources": {
            "$ref": "#/components/schemas/ReportsResourcesBlock"
          },
          "filters": {
            "type": "object",
            "description": "Optional filters to narrow the search results.",
            "properties": {
              "vulnerable_component": {
                "type": "string",
                "description": "Wildcard pattern for filtering components."
              },
              "impacted_artifact": {
                "type": "string",
                "description": "Wildcard pattern for filtering artifacts."
              },
              "scan_date": {
                "$ref": "#/components/schemas/ReportsDateRange"
              },
              "runtime_filter": {
                "type": "boolean",
                "description": "Filter by runtime context."
              },
              "ca_filter": {
                "type": "boolean",
                "description": "Filter by contextual analysis results."
              }
            }
          }
        }
      },
      "ReportsReportContentFiltersBody": {
        "type": "object",
        "description": "Optional filters for report table content; pagination is usually via query parameters.",
        "additionalProperties": true
      },
      "ViolationsSearchRequest": {
        "type": "object",
        "description": "Request body for searching violations. Contains a filters object for narrowing results and a pagination object for controlling sort order and paging.\n",
        "properties": {
          "filters": {
            "type": "object",
            "description": "Filtering parameters for the search.",
            "properties": {
              "name_contains": {
                "type": "string",
                "description": "Filter results where the description contains this string."
              },
              "include_details": {
                "type": "boolean",
                "description": "Include additional violation detail properties in the response."
              },
              "violation_type": {
                "type": "string",
                "description": "Filter by violation type.",
                "enum": [
                  "Security",
                  "License",
                  "Operational_Risk"
                ]
              },
              "watch_name": {
                "type": "string",
                "description": "Filter by watch name."
              },
              "min_severity": {
                "type": "string",
                "description": "Filter violations with severity equal to or higher than this value.",
                "enum": [
                  "Critical",
                  "High",
                  "Medium",
                  "Low",
                  "Information",
                  "Unknown"
                ]
              },
              "created_from": {
                "type": "string",
                "format": "date-time",
                "description": "Filter violations created from this time (RFC 3339)."
              },
              "created_until": {
                "type": "string",
                "format": "date-time",
                "description": "Filter violations created until this time (RFC 3339)."
              },
              "issue_id": {
                "type": "string",
                "description": "Filter by issue ID (e.g., XRAY-94620)."
              },
              "cve_id": {
                "type": "string",
                "description": "Filter by CVE ID (e.g., CVE-2019-17531)."
              },
              "resources": {
                "type": "object",
                "description": "Filter by specific resources.",
                "properties": {
                  "artifacts": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "repo": {
                          "type": "string"
                        },
                        "path": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "builds": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "number": {
                          "type": "string"
                        },
                        "project": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "release_bundles": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "release_bundles_v2": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "version": {
                          "type": "string"
                        },
                        "project": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "pagination": {
            "type": "object",
            "description": "Pagination and sorting parameters.",
            "properties": {
              "order_by": {
                "type": "string",
                "description": "Sort field. Valid values: created, summary, severity, type, watcher_name, issue_id.",
                "example": "created"
              },
              "direction": {
                "type": "string",
                "description": "Sort direction.",
                "enum": [
                  "asc",
                  "desc"
                ]
              },
              "limit": {
                "type": "integer",
                "description": "Maximum number of items to return. Default: 25.",
                "example": 25
              },
              "offset": {
                "type": "integer",
                "description": "Page offset. Default: 1.",
                "example": 1
              }
            }
          }
        }
      },
      "ArtifactsDependencyGraphNode": {
        "type": "object",
        "description": "Recursive dependency node (nested components arrays in responses).",
        "properties": {
          "component_name": {
            "type": "string"
          },
          "component_id": {
            "type": "string"
          },
          "package_type": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "created": {
            "type": "string"
          },
          "modified": {
            "type": "string"
          },
          "components": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ArtifactsDependencyGraphNode"
            }
          }
        }
      },
      "ArtifactsCompareArtifactsRequest": {
        "type": "object",
        "required": [
          "source_artifact_path",
          "target_artifact_path"
        ],
        "description": "Two artifact paths to diff (see Get Artifact Delta in Xray documentation).",
        "properties": {
          "source_artifact_path": {
            "type": "string",
            "description": "Path of the source artifact"
          },
          "target_artifact_path": {
            "type": "string",
            "description": "Path of the target artifact"
          }
        }
      },
      "ArtifactsArtifactDependencyGraphResponse": {
        "type": "object",
        "properties": {
          "artifact": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "pkg_type": {
                "type": "string"
              },
              "sha256": {
                "type": "string"
              },
              "sha1": {
                "type": "string"
              },
              "component_id": {
                "type": "string"
              }
            }
          },
          "components": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ArtifactsDependencyGraphNode"
            }
          }
        }
      },
      "ArtifactsArtifactScanStatusRequest": {
        "type": "object",
        "description": "Request body for looking up the scan status of a specific artifact.",
        "properties": {
          "repo": {
            "type": "string",
            "description": "Repository name containing the artifact."
          },
          "path": {
            "type": "string",
            "description": "Path to the artifact in the repository."
          }
        },
        "required": [
          "repo",
          "path"
        ]
      },
      "WatchApiV2Request": {
        "type": "object",
        "description": "Request body for creating or updating a Watch in Xray.",
        "required": [
          "general_data"
        ],
        "properties": {
          "general_data": {
            "type": "object",
            "description": "General information about the Watch.",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the Watch."
              },
              "description": {
                "type": "string",
                "description": "Description of the Watch."
              },
              "active": {
                "type": "boolean",
                "description": "Indicates if the Watch is active. Defaults to true if project_resources is included, false otherwise."
              }
            }
          },
          "project_resources": {
            "type": "object",
            "description": "Resources the Watch monitors and their filters.",
            "properties": {
              "resources": {
                "type": "array",
                "description": "List of resources to watch.",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "description": "Type of the resource to watch.",
                      "enum": [
                        "repository",
                        "build",
                        "releaseBundle",
                        "releaseBundleV2",
                        "all-repos",
                        "all-builds",
                        "all-releaseBundles",
                        "all-releaseBundlesV2",
                        "all-projects",
                        "project",
                        "gitRepository"
                      ]
                    },
                    "name": {
                      "type": "string",
                      "description": "Name of the resource."
                    },
                    "bin_mgr_id": {
                      "type": "string",
                      "description": "Binary manager ID. Omit or set to default."
                    },
                    "repo_type": {
                      "type": "string",
                      "description": "Type of repository (local or remote). Relevant only for repository resources.",
                      "enum": [
                        "local",
                        "remote"
                      ]
                    },
                    "build_repo": {
                      "type": "string",
                      "description": "The build or bundle repository. Relevant only for resources under a project."
                    },
                    "project": {
                      "type": "string",
                      "description": "Project key for the resource."
                    },
                    "filters": {
                      "type": "array",
                      "description": "Filters to apply to the resource.",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": {
                            "type": "string",
                            "description": "Filter type. Acceptable types depend on the resource type.",
                            "enum": [
                              "regex",
                              "path-regex",
                              "package-type",
                              "mime-type",
                              "property",
                              "ant-patterns",
                              "path-ant-patterns"
                            ]
                          },
                          "value": {
                            "description": "Filter value. Type depends on filter type: string for regex/path-regex/package-type/mime-type, object with IncludePatterns/ExcludePatterns arrays for ant-patterns/path-ant-patterns, or object with key/value for property."
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "type"
                  ]
                }
              },
              "global_filters": {
                "type": "array",
                "description": "Global filters applied across all resources.",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "description": "Filter type."
                    },
                    "value": {
                      "description": "Filter value."
                    }
                  }
                }
              }
            }
          },
          "assigned_policies": {
            "type": "array",
            "description": "Policies assigned to the Watch.",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Name of the policy."
                },
                "type": {
                  "type": "string",
                  "description": "Type of the policy.",
                  "enum": [
                    "security",
                    "license",
                    "operational_risk"
                  ]
                }
              },
              "required": [
                "name",
                "type"
              ]
            }
          },
          "watch_recipients": {
            "type": "array",
            "description": "Email addresses that will receive Watch notifications.",
            "items": {
              "type": "string"
            }
          },
          "create_ticket_enabled": {
            "type": "boolean",
            "description": "Indicates whether Jira ticket creation is enabled for this Watch."
          },
          "ticket_profile": {
            "type": "string",
            "description": "Jira profile name for ticket generation."
          },
          "ticket_generation": {
            "type": "object",
            "description": "Ticket generation settings for the Watch.",
            "properties": {
              "create_duplicate_tickets": {
                "type": "object",
                "description": "Settings for creating duplicate tickets.",
                "properties": {
                  "by_version": {
                    "type": "object",
                    "description": "Settings for creating duplicate tickets by version.",
                    "properties": {
                      "build": {
                        "type": "boolean",
                        "description": "Create duplicate tickets for builds."
                      },
                      "package": {
                        "type": "boolean",
                        "description": "Create duplicate tickets for packages."
                      },
                      "release_bundle": {
                        "type": "boolean",
                        "description": "Create duplicate tickets for release bundles."
                      }
                    }
                  }
                }
              },
              "impact_path_profiles_mapping": {
                "type": "object",
                "description": "Mapping of impact path profiles.",
                "properties": {
                  "include": {
                    "type": "array",
                    "description": "Impact path to Jira profile mappings.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "profile": {
                          "type": "string",
                          "description": "Jira profile name."
                        },
                        "pattern": {
                          "type": "string",
                          "description": "Pattern for the impact path."
                        }
                      },
                      "required": [
                        "profile",
                        "pattern"
                      ]
                    }
                  }
                }
              },
              "create_tickets_for_ignored_violation": {
                "type": "boolean",
                "description": "Whether to create Jira tickets for policy violations that have been marked as ignored."
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "integer"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "detail": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "status_code": {
            "type": "integer"
          }
        }
      },
      "MessageStatusResponse": {
        "type": "object",
        "description": "Common response body with message and HTTP status code. Used for ping success and for many error responses (401, 500) across the API.",
        "properties": {
          "message": {
            "type": "string",
            "description": "Human-readable message"
          },
          "status_code": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "detail": {
            "type": "string",
            "description": "Optional extra detail (e.g. path that is forbidden for 401)"
          }
        }
      },
      "SystemInfo": {
        "type": "object",
        "description": "System information for the Distribution service",
        "properties": {
          "version": {
            "type": "string",
            "description": "Distribution service version"
          },
          "serviceId": {
            "type": "string",
            "description": "Formatted service identifier"
          },
          "status": {
            "type": "string",
            "enum": [
              "STABLE",
              "UNSTABLE"
            ],
            "description": "Health status; UNSTABLE when one or more dependent services are unavailable"
          },
          "message": {
            "type": "string",
            "description": "Present when status is UNSTABLE; describes which dependent services are unavailable"
          }
        }
      },
      "RBv2DistributionRequest": {
        "type": "object",
        "description": "Request model for distributing a Release Bundle v2",
        "properties": {
          "dry_run": {
            "type": "boolean",
            "description": "If true, simulates the distribution without actually performing it",
            "default": false
          },
          "distribution_rules": {
            "type": "array",
            "description": "Rules defining target sites and optional filters",
            "items": {
              "$ref": "#/components/schemas/DistributionRule"
            }
          },
          "auto_create_missing_repositories": {
            "type": "boolean",
            "description": "Whether to auto-create missing repositories on target edge nodes"
          },
          "modifications": {
            "type": "object",
            "description": "Path mapping modifications for the distribution"
          },
          "insecure_tls": {
            "type": "boolean",
            "description": "Whether to allow insecure TLS connections to edge nodes"
          }
        }
      },
      "DistributionRequest": {
        "type": "object",
        "description": "Request model for distribution operations",
        "properties": {
          "dry_run": {
            "type": "boolean",
            "description": "If true, simulates the operation without actually performing it",
            "default": false
          },
          "distribution_rules": {
            "type": "array",
            "description": "Rules defining target sites",
            "items": {
              "$ref": "#/components/schemas/DistributionRule"
            }
          },
          "auto_create_missing_repositories": {
            "type": "boolean",
            "description": "Whether to auto-create missing repositories on target edge nodes"
          }
        }
      },
      "DeleteReleaseBundleRequest": {
        "type": "object",
        "description": "Request model for deleting a release bundle from edge nodes",
        "properties": {
          "dry_run": {
            "type": "boolean",
            "description": "If true, simulates the deletion without actually performing it",
            "default": false
          },
          "distribution_rules": {
            "type": "array",
            "description": "Rules defining target sites for deletion",
            "items": {
              "$ref": "#/components/schemas/DistributionRule"
            }
          },
          "on_success": {
            "type": "string",
            "description": "Action to perform on the source after successful remote deletion",
            "enum": [
              "keep",
              "delete"
            ]
          }
        }
      },
      "DistributionRule": {
        "type": "object",
        "description": "Rule defining distribution targets",
        "properties": {
          "site_name": {
            "type": "string",
            "description": "Target site name. Use * to target all sites."
          },
          "city_name": {
            "type": "string",
            "description": "City name filter"
          },
          "country_codes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Country code filters (ISO 3166-1 alpha-2)"
          }
        }
      },
      "DynamicDistributionRequest": {
        "type": "object",
        "description": "Request body for dynamic distribution - release bundle spec and distribution target rules",
        "required": [
          "distribution_rules"
        ],
        "properties": {
          "distribution_rules": {
            "type": "array",
            "description": "Rules defining target edge nodes/sites",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/DistributionRule"
            }
          },
          "spec": {
            "type": "object",
            "description": "Release bundle content spec (queries and optional project key)",
            "properties": {
              "queries": {
                "type": "array",
                "description": "List of queries defining which artifacts to include in the release bundle",
                "items": {}
              },
              "project_key": {
                "type": "string",
                "description": "JFrog project key"
              }
            }
          }
        }
      },
      "DistributionResponse": {
        "type": "object",
        "description": "Response from a distribution or deletion operation (V1/V2 distribute, V1 delete)",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Distribution tracker ID"
          },
          "sites": {
            "type": "array",
            "description": "Target edge nodes the distribution was sent to (or will be sent to)",
            "items": {
              "$ref": "#/components/schemas/PlatformServiceInstance"
            }
          }
        }
      },
      "DynamicDistributionResponse": {
        "type": "object",
        "description": "Response from dynamic distribution - same as DistributionResponse plus the generated release bundle name and version",
        "allOf": [
          {
            "$ref": "#/components/schemas/DistributionResponse"
          },
          {
            "type": "object",
            "required": [
              "name",
              "version"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Generated release bundle name"
              },
              "version": {
                "type": "string",
                "description": "Generated release bundle version"
              }
            }
          }
        ]
      },
      "DistributionTrackerSimple": {
        "type": "object",
        "description": "Simple distribution tracker summary",
        "properties": {
          "distribution_id": {
            "type": "integer",
            "format": "int64",
            "description": "Distribution tracker ID"
          },
          "status": {
            "type": "string",
            "description": "Overall distribution status"
          },
          "distributed_by": {
            "type": "string",
            "description": "User who initiated the distribution"
          },
          "started": {
            "type": "string",
            "description": "Timestamp when the distribution was started"
          },
          "type": {
            "type": "string",
            "description": "Distribution type (distribute, delete)"
          }
        }
      },
      "DistributionProgress": {
        "type": "object",
        "description": "Detailed distribution progress including per-edge-node status",
        "properties": {
          "distribution_id": {
            "type": "integer",
            "format": "int64"
          },
          "status": {
            "type": "string"
          },
          "distributed_by": {
            "type": "string"
          },
          "started": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "edge_nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "service_id": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "PlatformServiceInstance": {
        "type": "object",
        "description": "Platform service instance (edge node) information",
        "properties": {
          "service_id": {
            "type": "string",
            "description": "Unique service identifier"
          },
          "name": {
            "type": "string",
            "description": "Display name of the service instance"
          },
          "type": {
            "type": "string",
            "description": "Service type (e.g. Artifactory)"
          }
        }
      },
      "EdgeNodesInfo": {
        "type": "object",
        "description": "Information about connected edge nodes",
        "properties": {
          "edge_nodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PlatformServiceInstance"
            }
          }
        }
      },
      "PropagationReport": {
        "type": "object",
        "description": "Report of key propagation results across edge nodes"
      },
      "ReleaseBundleCreation": {
        "type": "object",
        "description": "Request model for creating or updating a V1 release bundle"
      },
      "DestinationPermission": {
        "type": "object",
        "description": "Destination permission controlling which users and groups can distribute or delete release bundles to specific edge nodes",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique permission identifier (read-only, assigned by the system)",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "description": "Display name of the permission (read-only, set from the path parameter)",
            "readOnly": true
          },
          "resourceType": {
            "type": "string",
            "description": "Resource type (always \"DESTINATION\")",
            "readOnly": true,
            "enum": [
              "DESTINATION"
            ]
          },
          "distribution_destinations": {
            "type": "array",
            "description": "Rules defining which edge nodes this permission grants access to. Use site name, city name, and/or country codes to target specific nodes.",
            "items": {
              "type": "object",
              "properties": {
                "siteName": {
                  "type": "string",
                  "description": "Target site name. Use \"*\" to match all sites."
                },
                "cityName": {
                  "type": "string",
                  "description": "City name filter"
                },
                "countryCodes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Country code filters (ISO 3166-1 alpha-2)"
                }
              }
            }
          },
          "principals": {
            "type": "object",
            "description": "Users and groups with their permitted actions",
            "properties": {
              "users": {
                "type": "object",
                "description": "Map of username to list of permitted action codes (e.g., \"distribute\", \"delete\")",
                "additionalProperties": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "distribute",
                      "delete"
                    ]
                  }
                }
              },
              "groups": {
                "type": "object",
                "description": "Map of group name to list of permitted action codes (e.g., \"distribute\", \"delete\")",
                "additionalProperties": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "distribute",
                      "delete"
                    ]
                  }
                }
              }
            }
          }
        }
      },
      "StuckDistribution": {
        "type": "object",
        "description": "A distribution that is stuck in a non-final state",
        "properties": {
          "bundleName": {
            "type": "string",
            "description": "Name of the release bundle"
          },
          "bundleVersion": {
            "type": "string",
            "description": "Version of the release bundle"
          },
          "releaseBundlesSchema": {
            "type": "string",
            "description": "Release bundle schema type",
            "enum": [
              "RBV1",
              "RBV2",
              "RBV2_ATW"
            ]
          },
          "distributionFriendlyId": {
            "type": "integer",
            "format": "int64",
            "description": "User-facing distribution ID"
          },
          "status": {
            "type": "string",
            "description": "Current distribution status",
            "enum": [
              "STORING_IN_PROGRESS",
              "XRAY_SCAN_IN_PROGRESS",
              "QUEUED",
              "IN_PROGRESS",
              "VALIDATE",
              "CLOSE_IN_PROGRESS",
              "ABORT_IN_PROGRESS"
            ]
          },
          "distributionTrackerId": {
            "type": "integer",
            "format": "int64",
            "description": "Internal distribution tracker ID"
          }
        }
      },
      "UnlockStuckReport": {
        "type": "object",
        "description": "Report from the UNLOCK_STUCK maintenance action",
        "properties": {
          "stuckDistributions": {
            "type": "array",
            "description": "List of distributions that were identified as stuck",
            "items": {
              "$ref": "#/components/schemas/StuckDistribution"
            }
          },
          "unlocked": {
            "type": "boolean",
            "description": "Whether the stuck distributions were actually unlocked (false if dry-run)"
          }
        }
      },
      "ForceStopAllReport": {
        "type": "object",
        "description": "Report from the STOP_ALL maintenance action",
        "properties": {
          "trackersDbInfo": {
            "type": "object",
            "description": "Database tracker update counts",
            "properties": {
              "affectedEdgeTrackerArtifacts": {
                "type": "integer",
                "description": "Number of edge node tracker artifacts that were (or would be) marked as aborted"
              },
              "affectedEdgeTrackers": {
                "type": "integer",
                "description": "Number of edge node trackers that were (or would be) marked as aborted"
              },
              "affectedTrackers": {
                "type": "integer",
                "description": "Number of distribution trackers that were (or would be) marked as aborted"
              }
            }
          },
          "tasksQueueFlushed": {
            "type": "boolean",
            "description": "Whether the task queue was actually flushed (false if dry-run)"
          }
        }
      },
      "DistributeByLastDaysRequest": {
        "type": "object",
        "description": "Request model for redistributing release bundles from a time window to a target edge node",
        "required": [
          "date",
          "lastNumberOfDays",
          "edgeName"
        ],
        "properties": {
          "date": {
            "type": "string",
            "description": "End date for the time window in YYYY-MM-DD format",
            "example": "2025-03-11"
          },
          "lastNumberOfDays": {
            "type": "integer",
            "description": "Number of days to look back from the specified date. Must be between 1 and the configured maximum (default: 7).",
            "minimum": 1,
            "example": 7
          },
          "edgeName": {
            "type": "string",
            "description": "Name of the target edge node to redistribute the release bundles to",
            "example": "edge-node-1"
          },
          "autoCreateMissingRepositories": {
            "type": "boolean",
            "description": "Whether to automatically create missing repositories on the target edge node",
            "default": false
          }
        }
      },
      "DistributeByLastDaysResponse": {
        "type": "object",
        "description": "Response from the distribute by last days operation",
        "properties": {
          "totalTriggered": {
            "type": "integer",
            "description": "Total number of release bundles triggered for redistribution",
            "example": 3
          },
          "triggered": {
            "type": "array",
            "description": "Identifiers of the release bundles that were triggered for redistribution (format repository/name/version)",
            "items": {
              "type": "string"
            },
            "uniqueItems": true,
            "example": [
              "release-bundles-v2/my-bundle/1.0.0",
              "release-bundles-v2/my-bundle/1.1.0"
            ]
          }
        }
      },
      "SystemSettings": {
        "type": "object",
        "description": "Distribution system settings",
        "properties": {
          "call_home_enabled": {
            "type": "boolean",
            "description": "Whether the Call Home feature is enabled"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "description": "OAuth2 token response (create or refresh)",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The access token value"
          },
          "expires_in": {
            "type": "integer",
            "format": "int64",
            "description": "Token validity in seconds"
          },
          "scope": {
            "type": "string",
            "description": "Granted scopes"
          },
          "token_type": {
            "type": "string",
            "description": "Token type (e.g. Bearer)"
          },
          "refresh_token": {
            "type": "string",
            "description": "Refresh token (when refreshable)"
          }
        }
      },
      "TokenInfo": {
        "type": "object",
        "description": "Token metadata (for list endpoint)",
        "properties": {
          "token_id": {
            "type": "string",
            "description": "Unique token identifier"
          },
          "issuer": {
            "type": "string",
            "description": "Token issuer"
          },
          "subject": {
            "type": "string",
            "description": "Token subject (username)"
          },
          "issued_at": {
            "type": "integer",
            "format": "int64",
            "description": "Issued-at time (epoch seconds)"
          },
          "expiry": {
            "type": "integer",
            "format": "int64",
            "description": "Expiration time (epoch seconds)"
          },
          "refreshable": {
            "type": "boolean",
            "description": "Whether the token can be refreshed"
          }
        }
      },
      "TokensResponse": {
        "type": "object",
        "description": "List of token info",
        "properties": {
          "tokens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TokenInfo"
            }
          }
        }
      },
      "Security_ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "integer",
                  "description": "HTTP status code"
                },
                "message": {
                  "type": "string",
                  "description": "Error message"
                }
              }
            }
          }
        }
      },
      "UserConfiguration": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The username"
          },
          "email": {
            "type": "string",
            "description": "The user's email address"
          },
          "lastLoggedIn": {
            "type": "string",
            "format": "date-time",
            "description": "Last login timestamp in ISO8601 format"
          },
          "realm": {
            "type": "string",
            "description": "The user's authentication realm"
          },
          "admin": {
            "type": "boolean",
            "description": "Whether the user is an administrator"
          },
          "profileUpdatable": {
            "type": "boolean",
            "description": "Whether the user can update their own profile"
          },
          "internalPasswordDisabled": {
            "type": "boolean",
            "description": "Whether internal password authentication is disabled"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of groups the user belongs to"
          },
          "disableUIAccess": {
            "type": "boolean",
            "description": "Whether UI access is disabled for this user"
          },
          "policyViewer": {
            "type": "boolean",
            "description": "Whether the user has policy viewer permissions"
          },
          "policyManager": {
            "type": "boolean",
            "description": "Whether the user has policy manager permissions"
          },
          "watchManager": {
            "type": "boolean",
            "description": "Whether the user has watch manager permissions"
          },
          "reportsManager": {
            "type": "boolean",
            "description": "Whether the user has reports manager permissions"
          },
          "mfaStatus": {
            "type": "string",
            "description": "Multi-factor authentication status",
            "enum": [
              "NONE",
              "ENABLED",
              "DISABLED"
            ]
          },
          "status": {
            "type": "string",
            "description": "User account status",
            "enum": [
              "ENABLED",
              "DISABLED",
              "LOCKED"
            ]
          }
        }
      },
      "CreateBundleSourceRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "release_bundle_name",
          "release_bundle_version"
        ],
        "properties": {
          "release_bundle_name": {
            "type": "string",
            "pattern": "^\\w[\\w\\-.]*$",
            "description": "Release bundle name. Must begin with a letter, underscore, or digit and consist of letters, underscores, dots, hyphens, or digits."
          },
          "release_bundle_version": {
            "type": "string",
            "pattern": "^\\w[\\w\\-.+]*$",
            "description": "Release bundle version. Must begin with a letter, underscore, or digit and consist of letters, underscores, dots, hyphens, plus signs, or digits."
          },
          "skip_docker_manifest_resolution": {
            "type": "boolean",
            "description": "Whether to skip Docker manifest resolution during bundle creation",
            "default": false
          },
          "source_type": {
            "type": "string",
            "enum": [
              "aql",
              "builds",
              "artifacts",
              "release_bundles",
              "packages"
            ],
            "description": "Type of source for the bundle. Supported values are 'aql' (Artifactory Query Language), 'builds', 'artifacts', 'release_bundles', or 'packages'."
          },
          "source": {
            "type": "object",
            "description": "Single source configuration object. The structure depends on the source_type. For artifacts, it may contain path patterns. For builds, it may contain build name and number. For AQL, it may contain AQL query.",
            "additionalProperties": true
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "description": "Multiple source configurations. Use this when you need to include multiple sources in the bundle. Each source object structure depends on the source_type."
          },
          "tag": {
            "type": "string",
            "pattern": "^[\\w\\-.]*$",
            "maxLength": 128,
            "description": "Optional tag to assign to the release bundle. Must not contain spaces or special characters except hyphens, underscores, and dots."
          }
        }
      },
      "CreateBundleResponse": {
        "type": "object",
        "properties": {
          "repository_key": {
            "type": "string",
            "description": "Repository key where the bundle is stored"
          },
          "release_bundle_name": {
            "type": "string",
            "description": "Name of the created release bundle"
          },
          "release_bundle_version": {
            "type": "string",
            "description": "Version of the created release bundle"
          },
          "created": {
            "type": "string",
            "description": "Creation timestamp"
          },
          "tag": {
            "type": "string",
            "description": "Tag assigned to the bundle (only included if not empty)"
          }
        }
      },
      "UpdateBundleSourceRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "release_bundle_name",
          "release_bundle_version"
        ],
        "properties": {
          "release_bundle_name": {
            "type": "string",
            "pattern": "^\\w[\\w\\-.]*$",
            "description": "Release bundle name. Must begin with a letter, underscore, or digit and consist of letters, underscores, dots, hyphens, or digits."
          },
          "release_bundle_version": {
            "type": "string",
            "pattern": "^\\w[\\w\\-.+]*$",
            "description": "Release bundle version. Must begin with a letter, underscore, or digit and consist of letters, underscores, dots, hyphens, plus signs, or digits."
          },
          "add_sources": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "description": "List of source configurations to add to the existing draft bundle. Each source object structure depends on the source_type (aql, builds, artifacts, release_bundles, packages)."
          },
          "filters": {
            "$ref": "#/components/schemas/BundleSourceFilters"
          }
        }
      },
      "UpdateBundleResponse": {
        "type": "object",
        "properties": {
          "repository_key": {
            "type": "string",
            "description": "Repository key where the bundle is stored"
          },
          "release_bundle_name": {
            "type": "string",
            "description": "Name of the updated release bundle"
          },
          "release_bundle_version": {
            "type": "string",
            "description": "Version of the updated release bundle"
          },
          "draft": {
            "type": "boolean",
            "description": "Whether the bundle is still in draft state"
          },
          "updated": {
            "type": "string",
            "description": "Timestamp when the bundle was updated"
          },
          "added_artifacts_count": {
            "type": "integer",
            "description": "Number of artifacts added in this update"
          }
        }
      },
      "BundleSourceFilters": {
        "type": "object",
        "description": "Filters to include or exclude specific artifacts from the bundle",
        "properties": {
          "included": {
            "type": "array",
            "maxItems": 50,
            "items": {
              "$ref": "#/components/schemas/BundleSourceFilter"
            },
            "description": "List of filters for artifacts to include"
          },
          "excluded": {
            "type": "array",
