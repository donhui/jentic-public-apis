      "CreatePromotionRequest": {
        "type": "object",
        "properties": {
          "environment": {
            "type": "string",
            "description": "Name of the target environment for the promotion (deprecated, use stage instead)"
          },
          "stage": {
            "type": "string",
            "description": "Name of the target environment/stage for the promotion"
          },
          "included_repository_keys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Defines specific repositories to include in the promotion. If left undefined, all repositories (except those specifically excluded) are included."
          },
          "excluded_repository_keys": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Defines specific repositories to exclude from the promotion"
          },
          "included_source_paths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Defines specific source paths to include in the promotion"
          },
          "excluded_source_paths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Defines specific source paths to exclude from the promotion"
          },
          "overwrite_strategy": {
            "type": "string",
            "enum": [
              "latest",
              "all",
              "disabled"
            ],
            "default": "disabled",
            "description": "Specifies the strategy for overwriting artifacts when a promotion would overwrite a file that is not part of the release bundle. `disabled` - (default) The promotion will fail if an artifact can't be overwritten. `all` - The promotion will overwrite the artifact regardless it's tag. `latest` - The promotion will overwrite the artifact only if the artifact has tag `latest`."
          },
          "artifact_additional_properties": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BundleItemProperty"
            },
            "description": "Key-value pairs that define properties to add to each promoted artifact on top of any existing properties"
          },
          "promotion_authorization_type": {
            "type": "string",
            "enum": [
              "undefined",
              "app_trust_authorized_promotion"
            ],
            "default": "undefined",
            "description": "Type of promotion authorization"
          }
        }
      },
