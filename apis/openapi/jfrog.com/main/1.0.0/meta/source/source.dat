              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "is_remote_delete_by_distribution",
            "in": "query",
            "description": "Whether this is a remote delete by distribution",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Submitted (async) - The deletion request was submitted successfully."
          },
          "204": {
            "description": "Deleted (sync) - The Release Bundle version was deleted successfully."
          },
          "400": {
            "description": "Bad Request - The request body is malformed or a required parameter is missing.",
            "content": {
