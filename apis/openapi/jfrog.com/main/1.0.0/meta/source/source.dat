                                  "type": "string"
                                },
                                "source_comp_id": {
                                  "type": "string"
                                },
                                "vulnerability_id": {
                                  "type": "string"
                                },
                                "result": {
                                  "type": "string"
                                }
                              },
                              "required": [
                                "component_id",
                                "source_comp_id",
                                "vulnerability_id",
                                "result"
                              ]
                            }
