{
  "openapi": "3.0.3",
  "info": {
    "title": "JFrog Artifactory API",
    "version": "1.0.0",
    "x-jentic-source-url": "https://jfrog.com/help/r/jfrog-rest-apis"
  },
  "servers": [
    {
      "url": "https://{server_name}.jfrog.io/artifactory",
      "variables": {
        "server_name": {
          "default": "myserver",
          "description": "JFrog server name"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Repositories"
    },
    {
      "name": "Xray"
    },
    {
      "name": "Distribution"
    },
    {
      "name": "Security"
    },
    {
      "name": "Release Lifecycle"
    },
    {
      "name": "Artifacts & Storage"
    },
    {
      "name": "Federated Repositories"
    },
    {
      "name": "Cleanup Policies"
    },
    {
      "name": "Searches"
    },
    {
      "name": "System"
    }
  ],
  "paths": {
    "/repositories/{repoKey}": {
      "put": {
        "tags": [
          "Repositories"
        ],
        "summary": "Create Repository",
        "description": "Creates a new repository in Artifactory with the provided configuration. Supported by local, remote, virtual, and Federated repositories.",
        "operationId": "createRepository",
        "parameters": [
          {
            "name": "repoKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The repository key"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Repository already exists or invalid configuration",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Repositories"
        ],
        "summary": "Get Repository Configuration",
        "description": "Returns the current configuration of a repository. Supported by local, remote, virtual, and Federated repositories.",
        "operationId": "getRepositoryConfiguration",
        "parameters": [
          {
            "name": "repoKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The repository key"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/vnd.org.jfrog.artifactory.repositories.LocalRepositoryConfiguration+json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified resource was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Repositories"
        ],
        "summary": "Update Repository Configuration",
        "description": "Updates an existing repository configuration in Artifactory with the provided configuration elements. Supported by local, remote, virtual, and Federated repositories.",
        "operationId": "updateRepositoryConfiguration",
        "parameters": [
          {
            "name": "repoKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The repository key"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified resource was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Repositories"
        ],
        "summary": "Delete Repository",
        "description": "Removes a repository configuration together with the whole repository content. Supported by local, remote, virtual and federated repositories.",
        "operationId": "deleteRepository",
        "parameters": [
          {
            "name": "repoKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The repository key"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified resource was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/v2/repositories/{repoKey}": {
      "get": {
        "tags": [
          "Repositories"
        ],
        "summary": "Get Repository Configuration (v2)",
        "description": "Returns the current configuration of a repository, providing only those fields that are relevant to the package type. Supported by local, remote, virtual, and Federated repositories.",
        "operationId": "getRepositoryConfigurationV2",
        "parameters": [
          {
            "name": "repoKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The repository key"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/vnd.org.jfrog.artifactory.repositories.LocalRepositoryConfiguration+json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified resource was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/v2/repositories/batch": {
      "put": {
        "tags": [
          "Repositories"
        ],
        "summary": "Create Multiple Repositories",
        "description": "Creates multiple repositories using a batch request. The batch request can contain a mix of different package types and repository types.",
        "operationId": "createMultipleRepositories",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "key"
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Repositories created successfully",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Batch limit exceeded, mandatory keys not configured, or repository key conflict",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Repositories"
        ],
        "summary": "Get Batch of Repositories by Name",
        "description": "Returns a batch of repositories defined by name. The default batch size is 100 items (configurable).",
        "operationId": "getBatchOfRepositoriesByName",
        "parameters": [
          {
            "name": "names",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "The repository names to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Repository keys are missing or repository item limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Repositories"
        ],
        "summary": "Update Multiple Repositories",
        "description": "Updates the configuration of multiple repositories using a batch request. The batch request can contain a mix of different package types and repository types.",
        "operationId": "updateMultipleRepositories",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "key"
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Repositories updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Batch limit exceeded or mandatory keys not configured",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Not Found - No repositories found for the specified keys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/repositories": {
      "get": {
        "tags": [
          "Repositories"
        ],
        "summary": "Get Repositories by Type and Project",
        "description": "Returns a list of minimal repository details for all repositories of the specified type. Filter the results using type, packageType, and project parameters.",
        "operationId": "getRepositoriesByTypeAndProject",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "local",
                "remote",
                "virtual",
                "federated",
                "distribution"
              ]
            },
            "description": "Repository type filter"
          },
          {
            "name": "packageType",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "bower",
                "cargo",
                "chef",
                "cocoapods",
                "composer",
                "conan",
                "cran",
                "debian",
                "docker",
                "gems",
                "gitlfs",
                "go",
                "gradle",
                "helm",
                "ivy",
                "maven",
                "nuget",
                "opkg",
                "p2",
                "pub",
                "puppet",
                "pypi",
                "rpm",
                "sbt",
                "swift",
                "terraform",
                "vagrant",
                "yum",
                "generic"
              ]
            },
            "description": "Package type filter"
          },
          {
            "name": "project",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Project key filter"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "type": "string"
                      },
                      "type": {
                        "type": "string"
                      },
                      "description": {
                        "type": "string"
                      },
                      "url": {
                        "type": "string",
                        "format": "uri"
                      },
                      "packageType": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/repositories/existence": {
      "get": {
        "tags": [
          "Repositories"
        ],
        "summary": "Check If Repository Exists",
        "description": "Checks if repositories exist that match the repository types and the project key specified in the query parameters.",
        "operationId": "checkIfRepositoryExists",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "local",
                  "remote",
                  "virtual",
                  "federated",
                  "releaseBundle"
                ]
              }
            },
            "description": "The type of repository to search for. Can be specified multiple times."
          },
          {
            "name": "projectKey",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "The key to the project in which you want to search"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "exists": {
                      "type": "boolean"
                    },
                    "matchingRepoTypes": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "projectKey": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/repositories/configurations": {
      "get": {
        "tags": [
          "Repositories"
        ],
        "summary": "Get All Repository Configurations",
        "description": "Returns a list of all repository configurations.",
        "operationId": "getAllRepositoryConfigurations",
        "parameters": [
          {
            "name": "packageType",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filters the response according to the defined package type. Separate multiple entries with commas."
          },
          {
            "name": "repoType",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filters the response according to the defined repository type. Separate multiple entries with commas."
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "LOCAL": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "REMOTE": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "VIRTUAL": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "FEDERATED": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "RELEASE_BUNDLE": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/repositories/{remoteRepoName}/configuration": {
      "get": {
        "tags": [
          "Repositories"
        ],
        "summary": "Remote Repository Configuration (Deprecated)",
        "description": "Returns the shared configuration of a remote repository. This API is deprecated. Use the Get Repository Configuration API instead.",
        "operationId": "getRemoteRepositoryConfiguration",
        "deprecated": true,
        "parameters": [
          {
            "name": "remoteRepoName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The remote repository name"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
