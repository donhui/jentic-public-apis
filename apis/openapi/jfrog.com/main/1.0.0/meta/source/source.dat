    "/release_bundle/received/{release_bundle_name}/{release_bundle_version}": {
      "delete": {
        "tags": [
          "Release Lifecycle",
          "BundleResource"
        ],
        "summary": "Delete Received Release Bundle v2 Version",
        "description": "Deletes a Release Bundle v2 version that has been received on this Artifactory instance (e.g. as a distribution target).\nUsed for remote delete from Distribution or cleanup of received bundle data. When async is true, returns 200 with a\nsubmission message; when false, returns 204 when deletion completes.\n",
        "operationId": "deleteReceivedBundleVersion",
        "parameters": [
          {
            "$ref": "#/components/parameters/ReceivedReleaseBundleName"
          },
          {
            "$ref": "#/components/parameters/ReceivedReleaseBundleVersion"
          },
          {
            "$ref": "#/components/parameters/ReceivedSourceProjectKeyQueryOptional"
          },
          {
            "$ref": "#/components/parameters/ReceivedAsync"
          },
          {
            "$ref": "#/components/parameters/ReceivedIsRemoteDeleteByDistribution"
          }
        ],
        "responses": {
          "200": {
            "description": "Accepted (async) - Deletion request submitted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncSubmissionResponse"
                }
              }
            }
          },
          "204": {
            "description": "No Content (sync) - The received release bundle version was deleted successfully."
          },
          "400": {
            "description": "Bad Request - Invalid parameters or missing source_project_key when required.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReleaseLifecycle_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReleaseLifecycle_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReleaseLifecycle_ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified Release Bundle version was not received or does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReleaseLifecycle_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/promotion/release-bundles-by-environment/{environment}": {
      "get": {
        "tags": [
          "Release Lifecycle",
          "BundleResource"
        ],
        "summary": "Get Release Bundle v2 Versions in a Specific Environment",
