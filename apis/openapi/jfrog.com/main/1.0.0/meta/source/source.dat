      "BundleVersionSummary": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Status of the bundle version (STARTED, FAILED, COMPLETED, DELETING)"
          },
          "repository_key": {
            "type": "string",
            "description": "Repository key where the bundle is stored"
          },
          "release_bundle_name": {
            "type": "string",
            "description": "Name of the release bundle"
          },
          "release_bundle_version": {
            "type": "string",
            "description": "Version of the release bundle"
          },
          "release_bundle_status": {
            "type": "string",
            "description": "Release bundle status"
          },
          "service_id": {
            "type": "string",
            "description": "The unique identifier of the Artifactory instance where the Release Bundle version was created"
          },
          "created_by": {
            "type": "string",
            "description": "The name of the user who created the Release Bundle. Names longer than 64 characters will appear truncated."
          },
          "created": {
            "type": "string",
            "description": "Timestamp when the new version was created (ISO 8601 format)"
          },
          "tag": {
            "type": "string",
            "description": "The descriptive tag assigned to the Release Bundle version, if any"
          },
          "release_status": {
            "type": "string",
            "description": "Indicates whether the Release Bundle has been promoted successfully to the official release stage (PROD), making it available for consumption. Possible values are pre_release and released. Requires release 7.120.1 or above."
          },
          "current_environment": {
            "type": "string",
            "description": "Indicates the most recent environment (for example, QA, Staging) to which the Release Bundle version was promoted successfully. If the version has not yet been promoted, this value will be an empty string. Requires release 7.120.1 or above."
          },
          "current_stage": {
            "type": "string",
            "description": "Current stage"
          },
          "current_promotion_created": {
            "type": "string",
            "description": "Timestamp of current promotion creation"
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EventMessage"
            },
            "description": "Error messages related to the processing of the operation (only included if not empty)"
          },
          "permissions": {
            "$ref": "#/components/schemas/BundlePermissions",
            "description": "Whether the user has permission to promote, distribute, and delete these Release Bundle versions (only included if not null)"
          }
        }
      },
      "BundleDescriptorModel": {
        "type": "object",
        "description": "Release bundle descriptor model",
        "properties": {
          "service_id": {
            "type": "string",
            "description": "The unique identifier of the Artifactory instance where the Release Bundle version was created"
          },
          "created_by": {
            "type": "string",
            "description": "The name of the user who created the Release Bundle version. Names longer than 64 characters will appear truncated."
          },
          "created": {
            "type": "string",
            "description": "The timestamp when the Release Bundle version was created (ISO 8601 standard)"
          },
          "created_millis": {
            "type": "integer",
            "format": "int64",
            "description": "The timestamp when the Release Bundle version was created (in milliseconds)"
          },
          "total_artifacts_count": {
            "type": "integer",
            "description": "The total number of artifacts included in the Release Bundle version"
