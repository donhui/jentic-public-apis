    "/search/gavc": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "GAVC Search",
        "description": "Search by Maven coordinates - GroupId, ArtifactId, Version & Classifier. The search must contain at least one argument. The search can be limited to specific repositories (local and remote-cache). \n\nNote: This endpoint requires a repository type or layout that supports GAVC, including Maven, Gradle, Ivy, and SBT.\n\nImportant: The exact GroupId and ArtifactId must be provided to search remote repositories.\n\nSince: 2.2.0\n\nSecurity: Requires a privileged user (can be anonymous)\n",
        "operationId": "searchGavc",
        "parameters": [
          {
            "name": "g",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "GroupId"
          },
          {
            "name": "a",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "ArtifactId"
          },
          {
            "name": "v",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Version"
          },
          {
            "name": "c",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Classifier"
          },
          {
            "name": "repos",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of repository keys to limit search to"
          },
          {
            "name": "specific",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "From Artifactory version 7.37.9, this attribute was added to support virtual and remote repositories. Once set to true, the output will be minimized to only include downloadUrl, ext, version, and classifier."
          },
          {
            "name": "X-Result-Detail",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "info",
                "properties",
                "info, properties"
              ]
            },
            "description": "Optional header to include additional details: 'info' (adds all extra information of the found artifact), 'properties' (gets the properties of the found artifact), 'info, properties' (for both)"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "uri": {
                            "type": "string",
                            "description": "URI of the artifact (may contain spaces)"
                          },
                          "downloadUri": {
                            "type": "string",
                            "format": "uri"
                          },
                          "ext": {
                            "type": "string"
                          },
                          "version": {
                            "type": "string"
                          },
                          "classifier": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing required parameters or invalid query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
