                                },
                                "details": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "file_path": {
                                        "type": "string"
                                      },
                                      "details": {
                                        "type": "string"
                                      }
                                    },
                                    "required": [
