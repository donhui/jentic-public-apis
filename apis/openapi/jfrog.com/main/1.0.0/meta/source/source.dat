    "/builds/policies/{policyKey}/enablement": {
      "post": {
        "tags": [
          "Cleanup Policies",
          "Build Cleanup Policies"
        ],
        "summary": "Enable/Disable Build Cleanup Policy",
        "description": "This REST API is called to enable or disable a cleanup policy. A policy must be enabled for it to run according to the automated schedule set in the cron expression or to trigger a run manually. A dry run can be performed on a policy that is disabled.",
        "operationId": "enableDisableBuildCleanupPolicy",
        "parameters": [
          {
            "name": "policyKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID that identifies the policy."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PolicyEnablementRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "400": {
            "$ref": "#/components/responses/BadRequestResponse"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/builds/policies/{policyKey}/run": {
      "put": {
        "tags": [
          "Cleanup Policies",
          "Build Cleanup Policies"
        ],
        "summary": "Manually Run Build Cleanup Policy",
        "description": "This REST API is called to manually run a build cleanup policy.",
        "operationId": "runBuildCleanupPolicy",
        "parameters": [
          {
            "name": "policyKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the policy you want to run."
          },
          {
            "name": "dryRun",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Optional, default is FALSE. Dry runs are used to run a policy without actual cleanup. It produces a report used to determine which packages will be removed if an actual run will be performed."
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunPolicyResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestResponse"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/policies/runs/{runId}": {
      "put": {
        "tags": [
          "Cleanup Policies",
          "Common Cleanup Policies"
        ],
        "summary": "Stop a Running Cleanup Policy",
        "description": "This REST API is called to stop a cleanup policy that is currently running. Once a policy has been stopped, it cannot be resumed from the point where it stopped.",
        "operationId": "stopRunningCleanupPolicy",
        "parameters": [
          {
            "name": "runId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "An ID that identifies the run. This ID is received when calling the Manually Run Release Bundle Cleanup Policy API and Manually Run Package Cleanup Policy API."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PolicyActionRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestResponse"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/policies/runs/forceStopAll": {
      "put": {
        "tags": [
          "Cleanup Policies",
          "Common Cleanup Policies"
        ],
        "summary": "Stop All Running Cleanup Policies",
        "description": "This API is called to stop all running cleanup policies on the global level. This API stops packages, builds and release bundles running policies.",
        "operationId": "stopAllRunningCleanupPolicies",
        "responses": {
          "202": {
            "description": "Accepted"
          },
