    "/release/import": {
      "servers": [
        {
          "url": "/artifactory/api",
          "description": "Artifactory Service API base path"
        }
      ],
      "post": {
        "tags": [
          "Distribution",
          "Export and Import Release Bundle V1"
        ],
        "summary": "Import Release Bundle V1 Version",
        "description": "Imports a previously exported V1 release bundle into Artifactory.\nThis endpoint runs on the Artifactory service (not Distribution) and is the counterpart\nto the air-gap export operation. Use this to import release bundles into air-gapped environments.\n",
        "operationId": "importReleaseBundleV1Version",
        "parameters": [
          {
            "name": "file_name",
            "in": "query",
            "required": true,
            "description": "The name of the exported release bundle zip file to import",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dry_run",
            "in": "query",
            "required": false,
            "description": "If true, validates the import without actually performing it",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success - Release bundle imported",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid file or import parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/keys/pgp": {
      "post": {
        "tags": [
          "Distribution",
          "GPG Keys"
        ],
        "summary": "Set GPG Signing Key for Distribution",
        "description": "Sets a GPG/PGP signing key pair for the Distribution service. The key is used to sign release bundles before distribution.",
        "operationId": "setGpgSigningKey",
