    "/search/aql": {
      "post": {
        "tags": [
          "Searches"
        ],
        "summary": "Artifactory Query Language (AQL)",
        "description": "Flexible and high performance search using Artifactory Query Language.\n\nSince: 3.5.0\n\nSecurity: Requires an authenticated user. Certain domains/queries may require Admin access.\n",
        "operationId": "searchAql",
        "requestBody": {
          "required": true,
          "content": {
            "text/plain": {
              "schema": {
                "type": "string",
                "description": "AQL query string"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "range": {
                      "type": "object",
                      "properties": {
                        "start_pos": {
                          "type": "integer"
                        },
                        "end_pos": {
                          "type": "integer"
                        },
                        "total": {
                          "type": "integer"
                        },
                        "limit": {
                          "type": "integer"
                        },
                        "notification": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing required parameters or invalid query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/artifact": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "Artifact Search (Quick Search)",
        "description": "Artifact search by part of file name. Searches return file info URIs. Can limit search to specific repositories (local or caches). \n\nNote: The search must be performed on the actual source repository (local or remote). Virtual repositories are not supported.\n\nSince: 2.2.0\n\nSecurity: Requires a privileged user (can be anonymous)\n",
        "operationId": "searchArtifact",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Part of file name to search for"
          },
          {
            "name": "repos",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of repository keys to limit search to"
          },
          {
            "name": "X-Result-Detail",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "info",
                "properties",
                "info, properties"
              ]
            },
            "description": "Optional header to include additional details: 'info' (adds all extra information of the found artifact), 'properties' (gets the properties of the found artifact), 'info, properties' (for both)"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "uri": {
                            "type": "string",
                            "description": "URI of the artifact (may contain spaces)"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing required parameters or invalid query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/archive": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "Archive Entries Search (Class Search)",
        "description": "Search archive for classes or any other resources within an archive. Can limit search to specific repositories (local or caches). \n\n**Deprecation Notice**: This API is deprecated and is scheduled for removal in a future version of Artifactory. We strongly recommend using Artifactory Query Language (AQL) for all new development.\n\nSince: 2.2.0\n\nSecurity: Requires a privileged user (can be anonymous)\n",
