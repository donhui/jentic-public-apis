    "/api/v1/on_demand/delete": {
      "post": {
        "operationId": "delete-on-demand-scan-results",
        "summary": "Delete On-Demand Scan Results",
        "description": "Deletes multiple on-demand scan results. Requires Read permission. Since Xray 3.40.0.",
        "tags": [
          "Xray",
          "Scanning V1"
