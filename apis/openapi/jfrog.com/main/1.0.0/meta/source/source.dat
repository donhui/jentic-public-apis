          },
          "500": {
            "description": "Failed to update Watch",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "delete-watch_watches-v2-openapi",
        "summary": "Delete Watch",
        "description": "Deletes a Watch by name.\n\n**Notes:**\n- For Xray version 3.21.2 and above with Projects, a Project Admin with Manage Security Assets privilege can delete a Watch in the scope of a project by using the `projectKey` query parameter.\n- A Watch can include both Global and Project Policies.\n\nRequires the 'Manage Watches' role to be set on the User or Group level.",
        "tags": [
          "Xray",
          "Watches V2"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Name of the Watch to delete.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "projectKey",
            "in": "query",
            "description": "Project key for scoped deletion of a project Watch.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success - Watch deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "info": {
                      "type": "string",
                      "description": "Success message."
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Failed to delete Watch",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Watch not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to delete Watch",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v2/distribution/distribute/{release_bundle_name}/{release_bundle_version}": {
      "post": {
        "tags": [
          "Distribution",
          "Distribute Release Bundle V2"
        ],
        "summary": "Distribute Release Bundle V2 Version",
        "description": "Distributes a Release Bundle v2 to the specified target edge nodes. The distribution rules define which sites receive the bundle. Supports dry-run mode to simulate the distribution without executing it.",
        "operationId": "distributeReleaseBundleV2Version",
        "parameters": [
          {
            "$ref": "#/components/parameters/releaseBundleNamePath"
          },
          {
            "$ref": "#/components/parameters/releaseBundleVersionPath"
          },
          {
            "$ref": "#/components/parameters/repositoryKeyQuery"
          },
          {
            "$ref": "#/components/parameters/projectQuery"
          },
          {
            "name": "X-GPG-PASSPHRASE",
            "in": "header",
            "description": "GPG passphrase for signing the release bundle during distribution",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Distribution configuration including target rules and options",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RBv2DistributionRequest"
              },
              "examples": {
                "distributeToAll": {
                  "summary": "Distribute to all edge nodes",
                  "value": {
                    "dry_run": false,
                    "auto_create_missing_repositories": true,
                    "distribution_rules": [
                      {
                        "site_name": "*"
                      }
                    ]
                  }
                },
                "distributeToSpecificSite": {
                  "summary": "Distribute to a specific site",
                  "value": {
                    "dry_run": false,
                    "distribution_rules": [
                      {
                        "site_name": "edge-node-1"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success - Distribution initiated (or dry-run result)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DistributionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid request or signing key issue.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict - A distribution is already in progress for this release bundle version.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v2/distribution/abort/{release_bundle_name}/{release_bundle_version}": {
      "put": {
        "tags": [
          "Distribution",
          "Distribute Release Bundle V2"
        ],
        "summary": "Abort Release Bundle V2 Distribution",
        "description": "Aborts an in-progress distribution of a Release Bundle v2. Sends abort signals to all edge nodes that are currently receiving the distribution.",
        "operationId": "abortReleaseBundleV2Distribution",
