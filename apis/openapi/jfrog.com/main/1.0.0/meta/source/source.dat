            "maxLength": 255,
            "description": "Package name to filter by"
          },
          "package_version": {
            "type": "string",
            "maxLength": 255,
            "description": "Package version to filter by"
          },
          "path": {
            "type": "string",
            "maxLength": 1350,
            "description": "Artifact path pattern to filter by"
          },
          "sha256": {
            "type": "string",
            "maxLength": 64,
            "description": "SHA-256 checksum to filter by"
          }
        }
      },
      "GetBundleIdsResponse": {
