    "/v1/service_trust/pairing/{usecase}": {
      "post": {
        "tags": [
          "Federated Repositories",
          "Service Trust"
        ],
        "summary": "Generate Pairing Token",
        "description": "Creates a pairing token for the specified use case (e.g., federated-repo/r for read-only unidirectional sync).",
        "operationId": "generatePairingToken",
        "parameters": [
          {
            "name": "usecase",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The use case path (e.g., federated-repo/r for read pairing token)"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pairing_token": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Unknown use case",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": false
