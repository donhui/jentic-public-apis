            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "federations": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "localRepoKey": {
                            "type": "string"
                          },
                          "memberInfoList": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "url": {
                                  "type": "string"
                                },
                                "repoKey": {
                                  "type": "string"
                                },
                                "aggregatedStatus": {
                                  "type": "string"
                                },
                                "isSupported": {
                                  "type": "boolean"
                                },
                                "isDisabled": {
                                  "type": "boolean"
                                },
                                "isInLag": {
                                  "type": "boolean"
                                }
                              }
                            }
                          },
                          "priority": {
                            "type": "string",
                            "enum": [
                              "HIGH",
                              "STANDARD"
