                                "type": "integer"
                              }
                            }
                          }
                        },
                        "all_other_artifacts": {
                          "type": "object",
                          "properties": {
                            "index_new_artifacts": {
                              "type": "boolean"
                            },
                            "retention_in_days": {
                              "type": "integer"
                            }
                          }
                        }
                      }
                    }
