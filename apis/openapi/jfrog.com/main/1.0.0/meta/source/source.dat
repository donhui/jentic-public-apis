                    "status": {
                      "type": "string"
                    },
                    "jfrog_severity": {
                      "type": "string"
                    },
                    "id": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "abbreviation": {
                      "type": "string"
                    },
                    "cwe": {
                      "type": "object",
                      "properties": {
                        "cwe_id": {
                          "type": "string"
                        },
                        "cwe_name": {
                          "type": "string"
                        },
                        "cwe_link": {
                          "type": "string"
                        }
                      }
                    },
                    "fix_cost": {
                      "type": "string"
                    },
                    "outcomes_details": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "description": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "findings": {
                      "type": "object",
                      "properties": {
                        "explanation": {
                          "type": "string"
                        },
                        "justification": {
                          "type": "string"
                        },
                        "mitigation": {
                          "type": "string"
                        },
                        "total_findings": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/{groupCategoryPathPart}/results/details/findings": {
      "get": {
        "operationId": "get-more-exposure-result-findings",
        "summary": "Exposures Scanning - Get Findings",
        "description": "Returns additional findings for an exposure result. Requires Read permission. Since Xray 3.59.4.",
        "tags": [
          "Xray",
          "Scanning V1"
        ],
        "parameters": [
          {
            "name": "groupCategoryPathPart",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "secrets",
                "applications",
                "services",
                "iac"
              ]
            },
            "description": "Exposures category: secrets, applications, services, or iac."
          },
          {
            "name": "repo",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Repository name."
          },
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Path to the artifact."
          },
          {
            "name": "id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Result identifier."
          },
          {
            "name": "first_finding_idx",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "First finding index (0 to total_findings-1)."
          }
        ],
        "responses": {
          "200": {
            "description": "Findings returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "finding_idx": {
                        "type": "integer"
                      },
                      "finding_text": {
                        "type": "string"
                      },
                      "finding_meaning": {
                        "type": "string"
                      },
                      "total_evidences": {
                        "type": "integer"
                      }
                    }
                  }
                },
                "example": [
                  {
                    "finding_idx": 0,
                    "finding_text": "Hardcoded secrets was found in Python files",
                    "finding_meaning": "to_fix",
                    "total_evidences": 1
                  }
                ]
              }
            }
          }
        }
      }
    },
