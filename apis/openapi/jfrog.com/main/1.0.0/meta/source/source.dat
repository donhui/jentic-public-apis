      "get": {
        "tags": [
          "Security",
          "Certificates"
        ],
        "summary": "Get Certificates",
        "description": "Returns a list of installed SSL certificates.\n\nSince: 5.4.0\n\nSecurity: Requires an admin user",
        "operationId": "getCertificates",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "certificateAlias": {
                        "type": "string"
                      },
                      "issuedTo": {
                        "type": "string"
                      },
                      "issuedBy": {
                        "type": "string"
                      },
                      "issuedOn": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "validUntil": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "fingerPrint": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
