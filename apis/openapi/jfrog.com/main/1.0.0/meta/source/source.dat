            "type": "string"
          },
          "cvss_v3_score": {
            "type": "number"
          },
          "cvss_v3_vector": {
            "type": "string"
          }
        }
      },
      "ReportsVulnerabilityContentRow": {
        "type": "object",
        "description": "Vulnerability report row (V2-style; fields vary by release).",
