                    "connection_name": {
                      "type": "string"
                    },
                    "auth_type": {
                      "type": "string"
                    },
                    "username": {
                      "type": "string"
                    },
                    "installation_type": {
                      "type": "string"
                    },
                    "jira_server_url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "skip_proxy": {
                      "type": "boolean"
                    }
                  }
                },
                "examples": {
                  "success": {
                    "value": {
                      "auth_type": "basic",
