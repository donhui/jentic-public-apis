              "type": "string"
            }
          },
          {
            "name": "all",
            "in": "query",
            "description": "Whether to propagate all keys",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success - Propagation report",
