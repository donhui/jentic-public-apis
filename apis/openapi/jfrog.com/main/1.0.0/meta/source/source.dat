    "/v1/keys/pgp/propagate": {
      "post": {
        "tags": [
          "Distribution",
          "GPG Keys"
        ],
        "summary": "Upload and Propagate GPG Signing Keys for Distribution",
        "description": "Propagates GPG/PGP signing keys (used for artifact-level signature verification) to all connected edge nodes. Can propagate a specific key alias or all configured GPG keys. Unlike the release bundle signing key propagation endpoint, this manages GPG keys used for verifying individual artifacts.",
        "operationId": "uploadAndPropagateGpgSigningKeysForDistribution",
        "parameters": [
