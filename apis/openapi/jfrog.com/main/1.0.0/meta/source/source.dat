    "/search/usage": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "Artifacts Not Downloaded Since",
        "description": "Returns all artifacts not downloaded since the specified Java epoch in milliseconds. Optionally include only artifacts created before the specified createdBefore date, otherwise only artifacts created before notUsedSince are returned. Can limit search to specific repositories (local or caches).\n\nSince: 2.2.4\n\nSecurity: Requires a privileged non-anonymous user\n",
        "operationId": "searchUsage",
        "parameters": [
          {
            "name": "notUsedSince",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Java epoch in milliseconds"
          },
          {
            "name": "createdBefore",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Java epoch in milliseconds"
          },
          {
            "name": "repos",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of repository keys to limit search to"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "uri": {
                            "type": "string",
                            "description": "URI of the artifact (may contain spaces)"
                          },
                          "lastDownloaded": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing required parameters or invalid query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/search/dates": {
      "get": {
        "tags": [
          "Searches"
        ],
        "summary": "Artifacts With Date in Date Range",
        "description": "Get all artifacts with specified dates within the given range. Search can be limited to specific repositories (local or caches).\n\nSince: 3.2.1\n\nSecurity: Requires a privileged non-anonymous user\n",
        "operationId": "searchDates",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "required": true,
            "schema": {
              "oneOf": [
                {
                  "type": "integer",
                  "format": "int64"
                },
                {
                  "type": "string",
                  "format": "date-time"
                }
              ]
            },
            "description": "The from parameter can be either a long value for the java epoch (milliseconds since the epoch), or an ISO8601 string value."
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "oneOf": [
                {
                  "type": "integer",
                  "format": "int64"
                },
                {
                  "type": "string",
                  "format": "date-time"
                }
              ]
            },
            "description": "The to parameter can be either a long value for the java epoch (milliseconds since the epoch), or an ISO8601 string value. If to is not provided, now() will be used instead."
          },
          {
            "name": "repos",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated list of repository keys to limit search to"
          },
          {
            "name": "dateFields",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "description": "Comma-separated list of date fields that specify which fields the from and to values should be applied to. The supported date fields are created, lastModified, lastDownloaded."
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "uri": {
                            "type": "string",
                            "description": "URI of the artifact (may contain spaces)"
                          },
                          "created": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "lastModified": {
                            "type": "string",
                            "format": "date-time"
                          },
                          "lastDownloaded": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - If both parameters are omitted, 400 bad request is returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Searches_ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
