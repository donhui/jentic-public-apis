      "put": {
        "operationId": "update-watch_watches-v2-openapi",
        "summary": "Update Watch",
        "description": "Updates an existing Watch. This overwrites the previous Watch configuration and replaces it with the provided parameters. The Watch name in the path takes precedence over the name in the request body.\n\n**Notes:**\n- You cannot update the project_key property.\n- A Watch can include both Global and Project Policies.\n- For Xray version 3.21.2 and above with Projects, a Project Admin with Manage Security Assets privilege can update a Watch in the scope of a project by using the `projectKey` query parameter.\n\nRequires the 'Manage Watches' role to be set on the User or Group level.",
        "tags": [
          "Xray",
          "Watches V2"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Name of the Watch to update.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "projectKey",
            "in": "query",
            "description": "Project key for scoped updates of a project Watch.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WatchApiV2Request"
              },
              "example": {
                "general_data": {
                  "description": "This is a new watch created using API V2",
                  "active": true
                },
                "project_resources": {
                  "resources": [
                    {
                      "type": "all-repos",
                      "filters": [
                        {
                          "type": "package-type",
                          "value": "Docker"
                        },
                        {
                          "type": "package-type",
                          "value": "Debian"
                        }
                      ]
                    }
                  ]
                },
                "assigned_policies": [
                  {
                    "name": "critial_issues",
                    "type": "security"
                  }
                ],
                "create_ticket_enabled": true,
                "ticket_profile": "test",
                "watch_recipients": [
                  "mymail@acme.com",
                  "umac@youremail.com"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success - Watch was successfully updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "info": {
                      "type": "string",
                      "description": "Success message."
                    }
                  }
                },
                "example": {
                  "info": "Watch was successfully updated"
                }
              }
            }
          },
          "400": {
            "description": "Failed to update watch: Watch name is empty",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Failed to update watch: no permissions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Failed to update the watch. Watch not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "415": {
            "description": "Failed to parse request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
