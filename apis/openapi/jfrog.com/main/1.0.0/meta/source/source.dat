                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "ignore_rule_info": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "ignore_rule_type": {
                                "type": "string"
                              },
                              "author": {
                                "type": "string"
                              },
