            "type": "string"
          },
          "physical_path": {
            "type": "string"
          },
          "impact_path": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fixed_versions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "issue_id": {
            "type": "string"
          },
          "project_keys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "applicability": {
            "type": "boolean"
          },
          "applicability_result": {
            "type": "string"
          },
          "vulnerable_components": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "impacted_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "jfrog_severity": {
            "type": "string"
          },
          "cwe": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ReportsVulnerabilityContentResponse": {
        "type": "object",
        "required": [
          "total_rows",
          "rows"
        ],
        "properties": {
          "total_rows": {
            "type": "integer"
          },
          "rows": {
            "type": "array",
