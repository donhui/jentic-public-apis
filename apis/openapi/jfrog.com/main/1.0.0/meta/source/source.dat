            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Security_ErrorResponse"
                }
              }
            }
          }
        }
