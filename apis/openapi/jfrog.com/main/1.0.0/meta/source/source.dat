    "/release_bundle/records/{name}/{version}/tag": {
      "put": {
        "tags": [
          "Release Lifecycle",
          "BundleResource"
        ],
        "summary": "Assign Tag to Release Bundle v2 Version",
        "description": "Assigns a descriptive tag to a Release Bundle v2 version. The tag will appear on the card for the Release Bundle version on the Release Lifecycle stages board.",
        "operationId": "setBundleTag",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Release bundle name",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\w[\\w\\-.]*$"
            }
          },
          {
            "name": "version",
            "in": "path",
            "description": "Release bundle version",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\w[\\w\\-.+]*$"
            }
          },
          {
            "name": "project",
            "in": "query",
            "description": "The project key used to determine the Release Bundles repository. By convention, each project may contain only one Release Bundles system repository with the name <project-key>-release-bundles-v2. This query parameter may be used instead of repository_key.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repository_key",
            "in": "query",
            "description": "The Release Bundles repository identifier that identifies where a Release Bundle version resides. If this parameter and the project query parameter are not specified, the default value of release-bundles-v2 is assumed.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BundleTagRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK - Tag assigned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetBundleTagResponse"
                },
                "example": {
                  "tag": "my first bundle",
                  "release_bundle_name": "my-bundle",
                  "release_bundle_version": "1.0.0"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified Release Bundle version does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Release Lifecycle",
          "BundleResource"
        ],
        "summary": "Delete Release Bundle v2 Version Tag",
        "description": "Deletes the tag from the selected Release Bundle v2 version.",
        "operationId": "deleteBundleTag",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "Release bundle name",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\w[\\w\\-.]*$"
            }
          },
          {
            "name": "version",
            "in": "path",
            "description": "Release bundle version",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^\\w[\\w\\-.+]*$"
            }
          },
          {
            "name": "project",
            "in": "query",
            "description": "The project key used to determine the Release Bundles repository. By convention, each project may contain only one Release Bundles system repository with the name <project-key>-release-bundles-v2. This query parameter may be used instead of repository_key.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "repository_key",
            "in": "query",
            "description": "The Release Bundles repository identifier that identifies where a Release Bundle version resides. If this parameter and the project query parameter are not specified, the default value of release-bundles-v2 is assumed.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted (Sync) - Tag deleted successfully"
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Not Found - The specified Release Bundle version does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
