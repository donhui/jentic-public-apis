    "/v1/dynamic/distribute": {
      "post": {
        "tags": [
          "Distribution",
          "Distribute Release Bundle V1"
        ],
        "summary": "Dynamic Distribute Release Bundle V1",
        "description": "Creates a release bundle from the given spec, signs it (using optional GPG passphrase), and distributes it to the target edge nodes in one request.\nThe release bundle name and version are generated by the service. Distribution rules define which sites receive the bundle.\n",
        "operationId": "distributeDynamicReleaseBundleV1",
        "parameters": [
          {
            "name": "X-GPG-PASSPHRASE",
            "in": "header",
            "description": "GPG passphrase for signing the release bundle (optional if key is not passphrase-protected)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "description": "Release bundle spec and distribution target rules",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DynamicDistributionRequest"
              },
              "examples": {
                "distributeToAll": {
                  "summary": "Distribute to all edge nodes",
                  "value": {
                    "distribution_rules": [
                      {
                        "site_name": "*"
                      }
                    ],
                    "spec": {
                      "queries": []
                    }
                  }
                },
                "distributeToSpecificSite": {
                  "summary": "Distribute to a specific site",
                  "value": {
                    "distribution_rules": [
                      {
                        "site_name": "edge-node-1"
                      }
                    ],
                    "spec": {
                      "queries": []
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted - Dynamic distribution initiated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DynamicDistributionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid request body or signing key issue",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageStatusResponse"
                }
              }
            }
          }
        }
      }
    },
