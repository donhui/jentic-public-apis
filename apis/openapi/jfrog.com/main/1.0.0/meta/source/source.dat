            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include",
            "in": "query",
            "description": "Returns any error messages generated when creating the promotion",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Sets the number of records to skip before returning the query response. Used for pagination purposes.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Sets the maximum number of versions to return at one time. Used for pagination purposes.",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "filter_by",
            "in": "query",
            "description": "Defines a filter for the list of promotions",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "order_by",
            "in": "query",
            "description": "Defines the criterion by which to order the list of promotions (created, created_millis, created_by, environment)",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "created",
                "created_millis",
                "created_by",
                "environment"
              ]
            }
          },
          {
            "name": "order_asc",
            "in": "query",
            "description": "Defines whether to list the promotions in ascending (true) or descending (false) order. The default value is false.",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Fetched - Successfully retrieved promotions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetPromotionsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad Credentials - The provided authentication is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "403": {
            "description": "Permission Denied - The user does not have the necessary permissions to perform this action.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
