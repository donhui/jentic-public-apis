    "/api/v2/watches": {
      "post": {
        "operationId": "create-watch_watches-v2-openapi",
        "summary": "Create Watch",
        "description": "Creates a new Watch. A Watch defines a set of resources (repositories, builds, release bundles, projects) to be monitored by assigned security and license policies.\n\n**Notes:**\n- For Xray version 3.21.2 and above with Projects, a Project Admin with Manage Security Assets privilege can create a Watch in the scope of a project by using the `projectKey` query parameter.\n- A Watch can include both Global and Project Policies.\n\nRequires the 'Manage Watches' role to be set on the User or Group level.",
        "tags": [
          "Xray",
          "Watches V2"
        ],
        "parameters": [
          {
            "name": "projectKey",
            "in": "query",
            "description": "Project key for creating a Watch in the scope of a project.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WatchApiV2Request"
              },
              "example": {
                "general_data": {
                  "name": "example1-watch",
                  "description": "This is an example watch #1",
                  "active": true
                },
                "project_resources": {
                  "resources": [
                    {
                      "type": "repository",
                      "bin_mgr_id": "default",
                      "name": "libs-release-local",
                      "filters": [
                        {
                          "type": "regex",
                          "value": ".*"
                        }
                      ]
                    }
                  ]
                },
                "assigned_policies": [
                  {
                    "name": "medium_vuln_policy",
                    "type": "security"
                  }
                ],
                "watch_recipients": [
                  "mymail@acme.com",
                  "sec@acme.com"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Success - Watch has been successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "info": {
                      "type": "string",
                      "description": "Success message."
                    }
                  }
                },
                "example": {
                  "info": "Watch has been successfully created"
                }
              }
            }
          },
          "400": {
            "description": "Invalid Watch",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "No permission for Watch",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Watch already exists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "error": "Watch already exists"
                }
              }
            }
          },
          "415": {
            "description": "Failed to parse request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to create Watch",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "get-watches_watches-v2-openapi",
        "summary": "Get Watches",
        "description": "Gets a list of all Watches in the system.\n\n**Notes:**\n- For Xray version 3.21.2 and above with Projects, a Project Admin with Manage Security Assets privilege can get a list of Watches in the scope of a project by using the `projectKey` query parameter.\n- A Watch can include both Global and Project Policies.\n\nRequires the 'Manage Watches' role to be set on the User or Group level.",
        "tags": [
          "Xray",
          "Watches V2"
        ],
        "parameters": [
          {
            "name": "projectKey",
            "in": "query",
            "description": "Project key for retrieval of project-scoped Watches.",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success - Watches retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WatchApiV2Request"
                  }
                },
                "example": [
                  {
                    "general_data": {
                      "id": "5bbe364b0fe4dc29f64c25aa",
                      "name": "specific-build-watch",
                      "description": "This is a new watch created using API V2",
                      "active": true
                    },
                    "project_resources": {
                      "resources": [
                        {
                          "type": "build",
                          "name": "release-pipeline"
                        }
                      ]
                    },
                    "assigned_policies": [
                      {
                        "name": "critial_issues",
                        "type": "security"
                      },
                      {
                        "name": "block_policy",
                        "type": "security"
                      }
                    ]
                  },
                  {
                    "general_data": {
                      "id": "6f2s864b0fe4dc29f64r5z9m",
                      "name": "all-repositories",
                      "description": "This is a new watch created using API V2",
                      "active": true
                    },
                    "project_resources": {
                      "resources": [
                        {
                          "type": "all-repos",
                          "filters": [
                            {
                              "type": "package-type",
                              "value": "Docker"
                            },
                            {
                              "type": "package-type",
                              "value": "Debian"
                            }
                          ]
                        }
                      ]
                    },
                    "assigned_policies": [
                      {
                        "name": "critial_issues",
                        "type": "security"
                      }
                    ]
                  }
                ]
              }
            }
          },
          "403": {
            "description": "Failed to get watches: no permissions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to get Watches",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
