          },
          "name": {
            "type": "string",
            "description": "Group name"
          },
          "user_created": {
            "type": "boolean",
            "description": "Whether this group was created by the user"
          },
          "contact_count": {
            "type": "integer",
            "description": "Number of contacts in this group"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        }
      },
      "AddContactToGroupRequest": {
        "type": "object",
        "properties": {
          "contact_id": {
            "type": "string",
            "description": "ID of the contact to add to the group"
          }
        },
        "required": ["contact_id"]
      },
      "AddContactToGroupResponse": {
        "type": "object",
        "properties": {
