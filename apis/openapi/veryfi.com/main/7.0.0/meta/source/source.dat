  "components": {
    "securitySchemes": {
      "ClientId": {
        "type": "apiKey",
        "in": "header",
        "name": "CLIENT-ID",
        "description": "Client ID provided by Veryfi"
      },
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "AUTHORIZATION",
        "description": "API Key authorization in format: apiKey $username:$apiKey"
      }
    },
    "schemas": {
      "Document": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique document identifier",
            "example": 38947300
          },
          "vendor": {
            "type": "object",
            "description": "Vendor information extracted from document",
            "properties": {
              "name": {
                "type": "string",
                "description": "Vendor name"
              },
              "address": {
                "type": "string",
                "description": "Vendor address"
              },
              "category": {
                "type": "string",
                "description": "Vendor category"
              }
            }
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "Document date",
            "example": "2021-08-05T10:24:48.000Z"
          },
          "total": {
            "type": "number",
            "format": "double",
            "description": "Total amount",
            "example": 97.66
          },
          "subtotal": {
            "type": "number",
            "format": "double",
            "description": "Subtotal amount before tax",
            "example": 97.66
          },
          "tax": {
            "type": "number",
            "format": "double",
            "description": "Tax amount",
            "example": 12.5
          },
          "currency_code": {
            "type": "string",
            "description": "ISO 4217 currency code",
            "example": "USD"
          },
          "invoice_number": {
            "type": "string",
            "description": "Invoice or receipt number",
            "example": "98"
          },
          "bill_to_name": {
            "type": "string",
            "description": "Name of the person or entity billed",
            "example": "John Smith"
          },
          "line_items": {
            "type": "array",
            "description": "Line items extracted from document",
            "items": {
              "$ref": "#/components/schemas/LineItem"
            }
          },
          "document_type": {
            "type": "string",
            "description": "Type of document",
            "example": "invoice",
            "enum": ["invoice", "receipt", "business_card", "check", "contract", "tax_form", "bank_statement"]
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when document was created in Veryfi system",
            "example": "2021-08-05T17:24:48.000Z"
          },
          "img_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the document image"
          },
          "is_duplicate": {
            "type": "integer",
            "description": "Flag indicating if document is a duplicate (1 for true, 0 for false)",
            "example": 1
          },
          "duplicate_of": {
            "type": "integer",
            "format": "int64",
            "description": "ID of the original document if this is a duplicate",
            "example": 38995348
          },
          "warnings": {
            "type": "array",
            "description": "Warning messages about document processing",
            "items": {
              "$ref": "#/components/schemas/OperationStatus"
            }
          },
          "external_id": {
            "type": "string",
            "description": "External identifier for the document"
          },
          "tags": {
            "type": "array",
            "description": "Tags associated with the document",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          }
        }
      },
      "DocumentUploadRequest": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "Document file to upload (multipart/form-data)"
          },
          "file_data": {
            "type": "string",
            "description": "Base64 encoded document data"
          },
          "file_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to download document from"
          },
          "external_id": {
            "type": "string",
            "description": "External identifier for tracking"
          },
          "tags": {
            "type": "array",
            "description": "Tags to associate with document",
            "items": {
              "type": "string"
            }
          },
          "categories": {
            "type": "array",
            "description": "Categories to classify document",
            "items": {
              "type": "string"
            }
          },
          "auto_delete": {
            "type": "integer",
            "description": "Automatically delete document after processing (1 for true, 0 for false)",
            "example": 0
          },
          "boost_mode": {
            "type": "integer",
            "description": "Enable boost mode for higher accuracy (1 for true, 0 for false)",
            "example": 0
          },
          "async": {
            "type": "integer",
            "description": "Process document asynchronously (1 for true, 0 for false)",
            "example": 0
          }
        }
      },
      "DocumentUpdateRequest": {
        "type": "object",
        "properties": {
          "vendor": {
            "type": "object",
            "description": "Updated vendor information",
            "properties": {
              "name": {
                "type": "string"
              },
              "address": {
                "type": "string"
              },
              "category": {
                "type": "string"
              }
            }
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "Updated document date"
          },
          "total": {
            "type": "number",
            "format": "double",
            "description": "Updated total amount"
          },
          "subtotal": {
            "type": "number",
            "format": "double",
            "description": "Updated subtotal"
          },
          "tax": {
            "type": "number",
            "format": "double",
            "description": "Updated tax amount"
          },
          "currency_code": {
            "type": "string",
            "description": "Updated currency code"
          },
          "invoice_number": {
            "type": "string",
            "description": "Updated invoice number"
          },
          "bill_to_name": {
            "type": "string",
            "description": "Updated bill to name"
          },
          "notes": {
            "type": "string",
            "description": "Additional notes"
          }
        }
      },
      "LineItem": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "Unique line item identifier",
            "example": 75788890
          },
          "description": {
            "type": "string",
            "description": "Line item description",
            "example": "98 Meat Pty Xchz"
          },
          "quantity": {
            "type": "number",
            "format": "double",
            "description": "Quantity of items",
            "example": 1
          },
          "price": {
            "type": "number",
            "format": "double",
            "description": "Unit price",
            "example": 12.5
          },
          "total": {
            "type": "number",
            "format": "double",
            "description": "Total amount for line item",
            "example": 88.2
          },
          "tax": {
            "type": "number",
            "format": "double",
            "description": "Tax amount",
            "example": 7.66
          },
          "tax_rate": {
            "type": "number",
            "format": "double",
            "description": "Tax rate percentage",
            "example": 7.66
          },
          "sku": {
            "type": "string",
            "description": "Stock keeping unit",
            "example": "038902058959"
          },
          "tags": {
            "type": "array",
            "description": "Tags associated with line item",
            "items": {
              "$ref": "#/components/schemas/Tag"
            }
          }
        }
      },
      "LineItemRequest": {
        "type": "object",
        "properties": {
