{
  "openapi": "3.0.3",
  "info": {
    "title": "Veryfi OCR API",
    "version": "7.0.0",
    "description": "Veryfi OCR API provides multi-modal data extraction from receipts, invoices, business cards, checks, contracts, tax forms, bank statements, and other documents. The API supports 91 currencies and 38 languages, offering intelligent document processing with line item extraction, classification, and fraud detection capabilities.",
    "x-jentic-source-url": "https://veryfi.readme.io",
    "contact": {
      "name": "Veryfi Support",
      "url": "https://www.veryfi.com"
    }
  },
  "servers": [
    {
      "url": "https://api.veryfi.com/api/v7/partner",
      "description": "Veryfi API v7 Production Server"
    }
  ],
  "security": [
    {
      "ClientId": [],
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/documents": {
      "get": {
        "operationId": "getDocuments",
        "summary": "List Documents",
        "description": "Retrieve processed documents or search by filters. Supports searching by OCR text, tags, external IDs, and date ranges.",
        "tags": ["Documents"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search in document OCR text",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tag",
            "in": "query",
            "description": "Filter by tag",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_id",
            "in": "query",
            "description": "Filter by external ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created__gte",
            "in": "query",
            "description": "Filter documents created on or after this datetime",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "created__gt",
            "in": "query",
            "description": "Filter documents created after this datetime",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "created__lte",
            "in": "query",
            "description": "Filter documents created on or before this datetime",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "created__lt",
            "in": "query",
            "description": "Filter documents created before this datetime",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Document"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createDocument",
        "summary": "Process Document",
        "description": "Process a new document and extract fields. Accepts document via file upload, base64 data, or URL. Supports various document types including receipts, invoices, business cards, and more.",
        "tags": ["Documents"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/DocumentUploadRequest"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentUploadRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document processed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Document"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/documents/{document_id}": {
      "get": {
        "operationId": "getDocument",
        "summary": "Get Document",
        "description": "Retrieve a specific document by ID. Optionally include audit trail information.",
        "tags": ["Documents"],
        "parameters": [
          {
            "name": "document_id",
            "in": "path",
            "required": true,
            "description": "Document ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "return_audit_trail",
            "in": "query",
            "description": "Include audit trail in response",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Document"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateDocument",
        "summary": "Update Document",
        "description": "Update document data including vendor information, date, notes, and other extracted fields.",
        "tags": ["Documents"],
        "parameters": [
          {
            "name": "document_id",
            "in": "path",
            "required": true,
            "description": "Document ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Document"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteDocument",
        "summary": "Delete Document",
        "description": "Delete a document from the system.",
        "tags": ["Documents"],
        "parameters": [
          {
            "name": "document_id",
            "in": "path",
            "required": true,
            "description": "Document ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Document deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OperationStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
