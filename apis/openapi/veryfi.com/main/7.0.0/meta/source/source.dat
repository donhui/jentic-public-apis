      "OperationStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Operation status",
            "example": "success"
          },
          "message": {
            "type": "string",
            "description": "Descriptive message about the operation",
            "example": "Operation completed successfully"
          },
          "error": {
            "type": "string",
            "description": "Error details if operation failed"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
