{
  "openapi": "3.0.3",
  "info": {
    "title": "QuickCity Zapier Webhook API",
    "description": "QuickCity is a CRM + marketing suite for real estate agents to help them connect with locals wanting to buy or sell their homes.",
    "version": "1.0.0",
    "contact": {
      "email": "support@quickcity.com"
    },
    "x-jentic-source-url": "https://www.quickcity.com/zapier/api-docs"
  },
  "servers": [
    {
      "url": "https://zapierwebhook-sozxe52s2q-uc.a.run.app",
      "description": "Production server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Leads",
          "Webhooks"
        ],
        "summary": "Execute Zapier action",
        "description": "Execute various actions including retrieving recent leads, subscribing to webhooks, or unsubscribing from webhooks",
        "operationId": "executeZapierAction",
        "parameters": [
          {
            "name": "zapierKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The unique key used to identify the user in the database"
          },
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "getRecentLeads",
                "subscribeHook",
                "unsubscribeHook"
              ]
            },
            "description": "The action to perform"
          },
          {
            "name": "hookUrl",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "Webhook URL (required for subscribeHook and unsubscribeHook actions)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/LeadsResponse"
                    },
                    {
                      "$ref": "#/components/schemas/SubscribeResponse"
                    },
                    {
                      "$ref": "#/components/schemas/UnsubscribeResponse"
                    },
                    {
                      "$ref": "#/components/schemas/DefaultResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Zapier key not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "zapierKey": {
        "type": "apiKey",
        "in": "query",
        "name": "zapierKey",
        "description": "User identifier in the database"
      }
    },
    "schemas": {
      "Lead": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Lead's name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Lead's email address"
          },
          "phone": {
            "type": "string",
            "description": "Lead's phone number"
          },
          "status": {
            "type": "string",
            "description": "Lead status"
          },
          "type": {
            "type": "string",
            "description": "Lead type"
          }
        }
      },
      "LeadsResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Lead"
        },
        "description": "Array of recent leads"
      },
      "SubscribeResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Hook Url Saved"
          },
          "hookUrl": {
            "type": "string",
            "format": "uri",
            "description": "The subscribed webhook URL"
          }
        }
      },
      "UnsubscribeResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Hook Url Deleted"
          },
          "hookUrl": {
            "type": "string",
            "format": "uri",
            "description": "The unsubscribed webhook URL"
          }
        }
      },
      "DefaultResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Zapier Request Received"
          },
          "user": {
            "type": "string",
            "description": "User identifier"
          },
          "displayName": {
            "type": "string",
            "description": "User's display name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User's email address"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Zapier Key Not Found"
          }
        }
      }
    }
  },
  "security": [
    {
      "zapierKey": []
    }
  ],
  "tags": [
    {
      "name": "Leads",
      "description": "Lead management operations"
    },
    {
      "name": "Webhooks",
      "description": "Webhook subscription management"
    }
  ]
}