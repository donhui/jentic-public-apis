{
  "openapi": "3.0.3",
  "info": {
    "title": "QuickCity Zapier Webhook API",
    "version": "1.0.0",
    "description": "QuickCity is a CRM + marketing suite for real estate agents. This API provides integration with Zapier for managing webhooks and retrieving recent leads.",
    "x-jentic-source-url": "https://www.quickcity.com/zapier/api-docs"
  },
  "servers": [
    {
      "url": "https://zapierwebhook-sozxe52s2q-uc.a.run.app",
      "description": "QuickCity Zapier Webhook Server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "executeaction",
        "summary": "Execute Zapier Action",
        "description": "Execute various Zapier actions including getting recent leads, subscribing/unsubscribing webhooks.",
        "tags": [
          "Webhooks",
          "Leads"
        ],
        "parameters": [
          {
            "name": "zapierKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique key identifying the user"
          },
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "getRecentLeads",
                "subscribeHook",
                "unsubscribeHook"
              ]
            },
            "description": "Action to perform"
          },
          {
            "name": "hookUrl",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Webhook URL (required for subscribe/unsubscribe)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/DefaultResponse"
                    },
                    {
                      "$ref": "#/components/schemas/LeadsResponse"
                    },
                    {
                      "$ref": "#/components/schemas/HookResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid zapierKey",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "zapierKey"
      }
    },
    "schemas": {
      "DefaultResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Zapier Request Received"
          },
          "user": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "LeadsResponse": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Lead"
        }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "HookResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "hookUrl": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Webhooks",
      "description": "Webhook management"
    },
    {
      "name": "Leads",
      "description": "Lead retrieval"
    }
  ]
}