{
    "openapi": "3.0.0",
    "info": {
        "title": "Arcopay PSD2 API",
        "description": "La estandarización de la conexión con cualquier banco en tiempo real.",
        "version": "1.3.5",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/Afterbanks/Afterbanks-PSD2-ES/1.3.5/swagger.json"
    },
    "paths": {
        "/listOfSupportedBanks/": {
            "get": {
                "summary": "Listado bancos",
                "description": "Obtén una lista completa de los bancos soportados, así como los nombres de los campos necesarios para dibujar un formulario de login similar al original del banco.",
                "parameters": [
                    {
                        "name": "Accept-version",
                        "in": "header",
                        "description": "Versión de la API que se quiere consumir en versión: v.numeroDeVersion",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "v.1"
                        }
                    },
                    {
                        "name": "countryCode",
                        "in": "query",
                        "description": "Código del país, formato <a href=\"https://en.wikipedia.org/wiki/ISO_3166-1_alpha-2\">ISO 3166-1 alpha-2</a>.<br>Ejemplo: ES para España.<br>Si no se proporciona ningún código, se devolverá la lista completa.",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "showSandbox",
                        "in": "query",
                        "description": "Si no se proporciona ningún valor, no se informará del servicio sandbox. 1 para mostrar únicamente el servicio sandbox.",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "showExtendedInformation",
                        "in": "query",
                        "description": "Si no se proporciona ningún valor, no se informará los parámetros adicionales. 1 para mostrar parámetros adicionales de la llamada.",
                        "required": false,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "tags": [
                    "PSD2"
                ],
                "responses": {
                    "200": {
                        "description": "Array con el listado de bancos soportados y la información necesaria para dibujar su formulario de login",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/listOfSupportedBanks"
                                    }
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/consent/get/": {
            "post": {
                "summary": "Gestiona la obtención del consentimiento por parte del usuario final.",
                "description": "La obtención del consentimiento tanto para Agregación Bancaria como para Iniciar un pago se realiza en dos etapas: </br> 1- Primera llamada a este método, que genera un enlace tipo follow para mostrar al usuario y que acepte el consentimiento. </br> 2- Recepción de la respuesta del usuario en una URL de callback en tu entorno. </br> La llamada a este método responde con un enlace tipo follow link (parámetro \"follow\") para mostrar al usuario final y un identificador único del consentimiento (parámetro \"consentId\") que le permitirá trazar el proceso. Cuando el usuario abra la URL proporcionada y finalice el proceso, recibirá en su sistema, a través de la URL de callback indicada en el parámetro yourConsentCallback, el token junto con al identificador único de este consentimiento \"consentId\" y globalPosition con las cuentas disponibles. El esquema que se envía a esta URL de callback está descrito en la definición consentGetCallback más abajo.",
                "parameters": [
                    {
                        "name": "Accept-version",
                        "in": "header",
                        "description": "Versión de la API que se quiere consumir en versión: v.numeroDeVersion",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "v.1"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "servicekey": {
                                        "description": "Licencia que identifica al cliente. Si no tienes una, puedes solicitarla en https://www.arcopay.io.",
                                        "type": "string"
                                    },
                                    "service": {
                                        "description": "Identificador único para cada banco. El listado de bancos soportados se obtiene en /listOfSupportedBanks/.",
                                        "type": "string"
                                    },
                                    "grantType": {
                                        "description": "Tipo de consentimiento solicitado. Acepta uno de los siguientes: </br> - read: Agregación de Cuentas, obtendrá el token para ser utilizado con el método /transactions/ </br> - payment: Iniciación de Pagos, obtendrá el token para ser utilizado con los métodos /payments/",
                                        "type": "string"
                                    },
                                    "validUntil": {
                                        "description": "Fecha hasta la que se solicita la validez del consentimiento en formato dd-mm-aaaa. El rango permitido va desde la fecha actual, hasta un máximo de 180 días a partir de la fecha actual (algunas entidades solo permiten 90 días, por lo que si la fecha informada supera el máximo permitido, se asignará automáticamente el máximo permitido para dicha entidad)",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "dailyFrequency": {
                                        "description": "Este parámetro solamente aplica si el consentimiento solicitado es de Agregación de Cuentas (grantType=read). Indica el número de refrescos diarios de los que se prevé hacer uso. El rango de valores permitidos es 1 a 4. El valor por defecto es 4.",
                                        "type": "integer"
                                    },
                                    "yourConsentCallback": {
                                        "description": "URL donde recibirá el token generado. Debe ser HTTPS. Vea [/definitions/consentGetCallback](#/definitions/consentGetCallback)",
                                        "type": "string"
                                    },
                                    "urlRedirect": {
                                        "description": "Enlace al que el usuario será redireccionado una vez finalice el proceso de obtención del consentimiento. Durante la redirección, se añadirán algunos parámetros extra en la url, vea [/definitions/urlRedirectConsent](#/definitions/urlRedirectConsent).",
                                        "type": "string"
                                    },
                                    "yourConsentCallbackError": {
                                        "description": "URL donde recibirá información en caso de error. Debe ser HTTPS. Vea [/definitions/consentGetCallbackError](#/definitions/consentGetCallbackError)",
                                        "type": "string"
                                    },
                                    "linkForMobileAppLogin": {
                                        "description": "Parámetro que indica que el enlace de consentimiento será generado para dispositivo móvil, con el fin de poder realizar la autenticación mediante biometría.",
                                        "type": "string",
                                        "default": 0
                                    }
                                },
                                "required": [
                                    "servicekey",
                                    "service",
                                    "grantType",
                                    "validUntil",
                                    "yourConsentCallback"
                                ]
                            }
                        }
                    },
                    "required": true
                },
                "tags": [
                    "PSD2"
                ],
                "responses": {
                    "200": {
                        "description": "Array of elements with consent information",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/consentGet"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/consent/cancel/": {
            "post": {
                "summary": "Borra un consentimiento.",
                "description": "Borra un consentimiento.",
                "parameters": [
                    {
                        "name": "Accept-version",
                        "in": "header",
                        "description": "Versión de la API que se quiere consumir en versión: v.numeroDeVersion",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "v.1"
                        }
                    }
                ],
                "requestBody": {
                    "$ref": "#/components/requestBodies/postConsentCancel_"
                },
                "tags": [
                    "PSD2"
                ],
                "responses": {
                    "200": {
                        "description": "Resultado.",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/consentCancel"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/consent/renew/": {
            "post": {
                "summary": "Renueva un consentimiento existente",
                "description": "Amplía el plazo de caducidad de un token existente hasta un máximo de 180 días a partir de la fecha actual.",
                "parameters": [
                    {
                        "name": "Accept-version",
                        "in": "header",
                        "description": "Versión de la API que se quiere consumir en versión: v.numeroDeVersion",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "v.1"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "servicekey": {
                                        "description": "Licencia que identifica al cliente.",
                                        "type": "string"
                                    },
                                    "token": {
                                        "description": "Token que habrás obtenido a través del método /consent/get.",
                                        "type": "string"
                                    },
                                    "validUntil": {
                                        "description": "Fecha hasta la que se solicita la renovación de validez del consentimiento en formato dd-mm-aaaa. El rango permitido va desde la fecha actual, hasta un máximo de 180 días a partir de la fecha actual (algunas entidades solo permiten 90 días, por lo que si la fecha informada supera el máximo permitido, se asignará automáticamente el máximo permitido para dicha entidad). Si este valor no se informa, se asignará automáticamente el máximo permitido para esta entidad",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "urlRedirect": {
                                        "description": "Necesario únicamente en intentos de renovación de consentimientos obtenidos a través del WidgetPSD2. En caso de haber obtenido el consentimiento a través de la apipsd2 este parámetro no es necesario. Enlace al que el usuario será redireccionado una vez finalice el proceso de renovación del consentimiento.",
                                        "type": "string"
                                    },
                                    "yourConsentCallback": {
                                        "description": "Necesario únicamente en intentos de renovación de consentimientos obtenidos a través del WidgetPSD2. En caso de haber obtenido el consentimiento a través de la apipsd2 este parámetro no es necesario. URL donde recibirá el token generado. Debe ser HTTPS. Vea [/definitions/consentGetCallback](#/definitions/consentGetCallback)",
                                        "type": "string"
                                    },
                                    "yourConsentCallbackError": {
                                        "description": "Necesario únicamente en intentos de renovación de consentimientos obtenidos a través del WidgetPSD2. En caso de haber obtenido el consentimiento a través de la apipsd2 este parámetro no es necesario. URL donde recibirá información en caso de error. Debe ser HTTPS. Vea [/definitions/consentGetCallbackError](#/definitions/consentGetCallbackError)",
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "servicekey",
                                    "token"
                                ]
                            }
                        }
                    },
                    "required": true
                },
                "tags": [
                    "PSD2"
                ],
                "responses": {
                    "200": {
                        "description": "Resultado de la operación.",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/consentRenew"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/consent/info/": {
            "post": {
                "summary": "Información sobre el consentimiento",
                "description": "Devuelve toda la información disponible sobre el consentimiento (token) consultado.",
                "parameters": [
                    {
                        "name": "Accept-version",
                        "in": "header",
                        "description": "Versión de la API que se quiere consumir en versión: v.numeroDeVersion",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "v.1"
                        }
                    }
                ],
                "requestBody": {
                    "$ref": "#/components/requestBodies/postConsentCancel_"
                },
                "tags": [
                    "PSD2"
                ],
                "responses": {
                    "200": {
                        "description": "Toda la información sobre el consentimiento.",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/consentInfo"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/transactions/": {
            "post": {
                "summary": "Posición global y movimientos hasta una fecha dada.",
                "description": "Este endpoint devuelve el listado de productos y los movimientos para cada uno de los productos desde la fecha solicitada hasta el día actual: hasta 2 años de transacciones para productos tipo checking y tipo card. La cabecera de respuesta de cada llamada a este endpoint encontrará un parámetro llamado Debug-id, que contiene un identificador único para cada una de las llamadas que conviene guardar ya que el equipo técnico se lo pedirá para abrir tickets de soporte.",
                "parameters": [
                    {
                        "name": "Accept-version",
                        "in": "header",
                        "description": "Versión de la API que se quiere consumir en versión: v.numeroDeVersion",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "v.1"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "servicekey": {
                                        "description": "Licencia que identifica al cliente. Si no tienes una, puedes solicitarla en https://www.arcopay.io.",
                                        "type": "string"
                                    },
                                    "token": {
                                        "description": "Este token ha sido obtenido previamente siguiendo el flujo de obtención del consentimiento PSD2 mediante el método consent/get.",
                                        "type": "string"
                                    },
                                    "startDate": {
                                        "description": "Fecha desde la que queremos obtener los movimientos en formato dd-mm-aaaa. Obligatorio cuando el valor de \"products\" es distinto de GLOBAL.",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "products": {
                                        "description": "Nombres de productos bancarios (cuentas corrientes o tarjetas), separados por coma. Cabe destacar que en la primera llamada a la API, aún no conocemos los nombres de los productos que el usuario tiene contratados, por lo que este parámetro deberá recibir el valor GLOBAL.",
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "servicekey",
                                    "token",
                                    "startDate",
                                    "products"
                                ]
                            }
                        }
                    },
                    "required": true
                },
                "tags": [
                    "PSD2"
                ],
                "responses": {
                    "200": {
                        "description": "Array con listado de productos bancarios y movimientos.",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/transactions"
                                    }
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/ibanToService/": {
            "post": {
                "summary": "Obtención del nombre del banco vinculado a un IBAN concreto.",
                "description": "Devuelve el nombre del banco al que pertenece el IBAN proporcionado.",
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "servicekey": {
                                        "description": "Licencia que identifica al cliente. Si no tienes una, puedes solicitarla en https://www.afterbanks.com",
                                        "type": "string"
                                    },
                                    "iban": {
                                        "description": "IBAN del que se desea conocer el servicio/banco al que pertenece. El formato aceptado es \"XX0000000000000000000000\". Siendo \"XX\" el código ISO del país, seguido de 2 dígitos de control y otros 20 dígitos que representan el código básico de la cuenta bancaria.",
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "servicekey"
                                ]
                            }
                        }
                    },
                    "required": true
                },
                "tags": [
                    "PSD2"
                ],
                "responses": {
                    "200": {
                        "description": "Servicio al que pertenece un IBAN. El campo \"services\" es un array de objetos, un objeto por cada servicio al que puede pertenecer el IBAN.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ibanToService"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/transactions/categories/": {
            "get": {
                "summary": "Listado de categorías. Solo para las servicekeys con la opción contratada.",
                "description": "Devuelve un listado completo de las categorías utilizadas por el categorizador de movimientos de Arcopay.",
                "parameters": [
                    {
                        "name": "Accept-version",
                        "in": "header",
                        "description": "Versión de la API que se quiere consumir en versión: v.numeroDeVersion",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "v.1"
                        }
                    },
                    {
                        "name": "countryCode",
                        "in": "query",
                        "description": "Código del país, formato ISO 3166-1 alpha-2 (https://en.wikipedia.org/wiki/ISO_3166-1_alpha-2). Por ejemplo ES para España. Si no se proporciona ningún código, se devolverá la lista completa.",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "tags": [
                    "PSD2"
                ],
                "responses": {
                    "200": {
                        "description": "Array con el listado de categorias utilizadas por Arcopay.",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/categories"
                                    }
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/payment/initiate/": {
            "post": {
                "summary": "Inicia un pago",
                "description": "<b>Inicia un pago en modalidad: normal, instantáneo y recurrente.</b><br><ul><li>Al igual que en el método consent/get/, se requiere de la interacción del usuario para procesar el pago, por lo que la llamada a este método responde con un enlace tipo follow link (parámetro \"follow\") para mostrar al usuario final y un identificador único del pago (parámetro \"paymentId\") que le permitirá trazar el proceso.</li><li>Cuando el usuario abra la URL proporcionada se realizará un proceso de Prevención de Blanqueo de Capitales y en caso necesario se realizará una comprobación extra previa al inicio de pago.</li><li>Cuando finalice el proceso, recibirá en su sistema, a través de la URL de callback indicada en el parámetro yourPaymentCallback, el token junto con al identificador único de este pago \"paymentId\".</li><li>El esquema que se envía a esta URL de callback está descrito en la definición paymentInitiateCallback más abajo.<li>Al callback se envía la confirmación de las iniciaciones de pago que han funcionado correctamente.</li><li>Debido a que una vez confirmado el pago, este puede encontrarse en un estado no final, es necesario consultar su estar en /payment/status.</li></ul>",
                "parameters": [
                    {
                        "name": "Accept-version",
                        "in": "header",
                        "description": "Versión de la API que se quiere consumir en versión: v.numeroDeVersion",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "default": "v.1"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "servicekey": {
                                        "description": "Licencia que identifica al cliente.",
                                        "type": "string"
                                    },
                                    "token": {
                                        "description": "Este token ha sido obtenido previamente siguiendo el flujo de obtención del consentimiento PSD2 mediante el método consent/get.",
                                        "type": "string"
                                    },
                                    "paymentType": {
                                        "description": "Tipo de pago: </br><b>- normal</b> -> transferencia normal </br><b>- instant</b> -> transferencia instantánea. Máximo importe permitido 15.000€ (150.000€ a partir de Julio de 2020). Desaconsejamos esta opción, ya que varios bancos cobran comisiones muy altas a los clientes, y sus APIS solamente informan al TPP de la comisión una vez el cliente ha completado o cancelado el pago, en lugar de informar previamente para permitir al TPP seleccionar el tipo de pago en función a la comisión. </br><b>- normalPeriodic</b> -> transferencia normal ejecutada con peridicidad, definida en los parámetros firstQuotaDate, frequency y numberOfQuotas. </br><b>- instantPeriodic</b> -> transferencia instantánea ejecutada con peridicidad, definida en los parámetros firstQuotaDate, frequency y numberOfQuotas. </br><b>- international</b> -> transferencia normal con IBAN de destino fuera de Europa.",
                                        "type": "string"
                                    },
                                    "currency": {
                                        "description": "Código de la divisa en formato [ISO 4217](http://en.wikipedia.org/wiki/ISO_4217).",
                                        "type": "string"
                                    },
                                    "amount": {
                                        "description": "Importe del pago utilizando el punto para decimales. Máximo 2 decimales.",
                                        "type": "number"
                                    },
                                    "sourceIBAN": {
                                        "description": "IBAN de origen con el cual el cliente quiere realizar el pago.",
                                        "type": "string"
                                    },
                                    "destinationIBAN": {
                                        "description": "IBAN de destino.",
                                        "type": "string"
                                    },
                                    "destinationCreditorName": {
                                        "description": "Nombre del titular de la cuenta de destino.",
                                        "type": "string"
                                    },
                                    "paymentDescription": {
                                        "description": "Description o concepto del pago. Máximo 140 caracteres.",
                                        "type": "string"
                                    },
                                    "yourPaymentCallback": {
                                        "description": "URL donde recibirá el token generado. Debe ser HTTPS.",
                                        "type": "string"
                                    },
                                    "firstQuotaDate": {
                                        "description": "Solo obligatorio para pagos recurrentes (pagos por cuotas), es decir, cuando paymentType sea normalPeriodic o instantPeriodic. Fecha en formato dd-mm-aaaa.",
                                        "type": "string",
                                        "format": "date"
                                    },
                                    "frequency": {
                                        "description": "Solo obligatorio para pagos recurrentes (pagos por cuotas), es decir, cuando paymentType sea normalPeriodic o instantPeriodic. Valores permitidos: daily, weekly, everyTwoWeeks, monthly, everyTwoMonths, quarterly, semiAnnual, annual",
                                        "type": "string"
                                    },
                                    "numberOfQuotas": {
                                        "description": "Solo obligatorio para pagos recurrentes (pagos por cuotas), es decir, cuando paymentType sea normalPeriodic o instantPeriodic. Número de veces que se ejecutará la orden de pago. Por ejemplo, si la orden corresponde a la devolución de un préstamo en 60 cuotas. El valor será 60.",
                                        "type": "number"
                                    },
                                    "urlRedirect": {
                                        "description": "Enlace al que será redireccionado el usuario una vez se confirme el pago. Durante la redirección, se añadirán algunos parámetros extra en la url, vea [/definitions/urlRedirectPayment](#/definitions/urlRedirectPayment).",
                                        "type": "string"
                                    },
                                    "yourPaymentCallbackError": {
                                        "description": "URL donde recibirá información en caso de error. Debe ser HTTPS. Vea [/definitions/paymentInitiateCallbackError](#/definitions/paymentInitiateCallbackError)",
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "servicekey",
                                    "token",
                                    "paymentType",
                                    "currency",
                                    "amount",
                                    "sourceIBAN",
                                    "destinationIBAN",
                                    "destinationCreditorName",
                                    "paymentDescription",
                                    "yourPaymentCallback"
                                ]
                            }
                        }
                    },
                    "required": true
                },
                "tags": [
                    "PSD2 Payments"
                ],
                "responses": {
                    "200": {
                        "description": "Array de elementos conteniendo información del pago.",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/paymentInitiate"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "headers": {
                            "Debug-id": {
                                "description": "Identificador único de la petición.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "Versión consumida por la API.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
