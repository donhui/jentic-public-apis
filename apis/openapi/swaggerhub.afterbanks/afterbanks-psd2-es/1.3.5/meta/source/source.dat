                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/accounts/refreshToken/": {
            "post": {
                "summary": "Si dispone de un token de refresco, puede refrescarlo con este método. Este token estará solo disponible dependiendo del caso de uso de algunos clientes.",
                "description": "Dado un token de refresco, realiza el refresco de dicho token e informa el token resultante.",
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "servicekey": {
                                        "description": "Licencia que identifica al cliente.",
                                        "type": "string"
                                    },
                                    "refreshToken": {
                                        "description": "Valor del token de refresco.",
                                        "type": "string"
                                    },
                                    "service": {
                                        "description": "Identificador único para cada banco. El listado de bancos soportados se obtiene en /listOfSupportedBanks/.",
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "servicekey",
                                    "refreshToken",
                                    "service"
                                ]
                            }
                        }
                    },
                    "required": true
                },
                "tags": [
                    "Accounts"
                ],
                "responses": {
                    "200": {
                        "description": "Resultado del refresco",
                        "headers": {
                            "Debug-id": {
                                "description": "Unique request identifier.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "API version consumed.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/refreshToken"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Unexpected error",
                        "headers": {
                            "Debug-id": {
                                "description": "Unique request identifier.",
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "Accept-version": {
                                "description": "API version consumed.",
                                "schema": {
                                    "type": "string"
                                }
                            }
                        },
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/batch/collectCredentials/": {
            "post": {
                "summary": "Procesamiento por lotes de credenciales.",
                "description": "Este endpoint recoge un conjunto de credenciales para su procesado en lote (procesado batch).",
                "requestBody": {
                    "content": {
