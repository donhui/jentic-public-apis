{
  "openapi": "3.0.0",
  "info": {
    "contact": {},
    "description": "Métodos API para Afterbanks - Sofinco",
    "title": "API",
    "version": "1.0.1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Afterbanks/Afterbanks-Sofinco/1.0.1/swagger.json"
  },
  "servers": [
    {
      "url": "https://virtserver.swaggerhub.com/Afterbanks/Afterbanks-Sofinco/1.0.1"
    }
  ],
  "paths": {
    "/getJsonFromLog": {
      "post": {
        "parameters": [
          {
            "description": "Licencia que identifica al cliente. Si no tienes una, puedes solicitarla en https://www.afterbanks.com.",
            "in": "query",
            "name": "servicekey",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "String que identifica la solicitud realizada. Obligatorio cuando no se especifica el parámetro \"date_start\"",
            "in": "query",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Fecha desde la que se quieran obtener logs, formato aaaa-mm-dd. Obligatorio cuando no se especifica el parámetro \"id\"",
            "in": "query",
            "name": "date_start",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Fecha hasta que se quieran obtener logs, formato aaaa-mm-dd, con un máximo de 90 días con respecto al parámetro \"date_start\".",
            "in": "query",
            "name": "date_end",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/RegistroLog"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Resultados que coincidan con los criterios de búsqueda."
          },
          "404": {
            "description": "No autorizado"
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RespuestaError"
                }
              }
            },
            "description": "Error en el proceso de búsqueda."
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "Logs"
        ],
        "description": "Obtén el listado completo de logs del identificador o de la fecha especificado/a, en formato json.\n",
        "operationId": "jsonLogs",
        "summary": "Listado de logs en formato json"
      }
    }
  },
  "components": {
    "schemas": {
      "RegistroLog": {
        "properties": {
          "date": {
            "example": "2016-08-29 09:12:33",
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "format": "id",
            "type": "string"
          },
          "message": {
            "format": "log",
            "type": "string"
          }
        },
        "required": [
          "id",
          "date",
          "message"
        ],
        "type": "object"
      },
      "RespuestaError": {
        "properties": {
          "error": {
            "format": "message",
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "scheme": "basic",
        "type": "http"
      }
    }
  },
  "tags": [
    {
      "name": "Logs"
    }
  ]
}