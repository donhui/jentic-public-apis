              "application/json": {
                "schema": { "$ref": "#/components/schemas/GetAdvisorResponse" }
              }
            }
          },
          "404": { "description": "Advisor not found" }
        }
      }
    },
    "/v2/Advisors/portalidtodefaultadvisorid/{portalId}": {
      "get": {
        "operationId": "mapPortalIdToAdvisorId",
        "summary": "Map portal ID to default advisor ID",
        "tags": ["Advisors"],
        "parameters": [
          {
            "name": "portalId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
