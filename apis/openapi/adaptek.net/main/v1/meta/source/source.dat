    "/v1/Agencies/{agencyId}/Advisors/{advisorId}/Images": {
      "get": {
        "operationId": "getAdvisorProfileImage",
        "summary": "Get advisor profile picture",
        "tags": ["AgencyImages"],
        "parameters": [
          {
            "name": "agencyId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "advisorId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Advisor profile image",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GetAgencyImageResponse" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "uploadAdvisorProfileImage",
        "summary": "Upload advisor profile picture",
        "tags": ["AgencyImages"],
        "parameters": [
          {
            "name": "agencyId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "advisorId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Image uploaded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateAgencyImageResponseModel" }
              }
            }
          }
        }
      }
    },
