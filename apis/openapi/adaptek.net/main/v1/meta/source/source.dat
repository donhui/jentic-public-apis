{
  "openapi": "3.0.3",
  "info": {
    "title": "Adaptek KonnexMe API",
    "description": "API for the KonnexMe Portal by Adaptek. Manage advisors, agencies, applications, files, folders, branding, assets, and various business operations for virtual advisor and client relationship management.",
    "version": "v1",
    "x-jentic-source-url": "https://api.adaptek.net/index.html"
  },
  "servers": [
    {
      "url": "https://api.adaptek.net",
      "description": "Adaptek API server"
    }
  ],
  "tags": [
    {
      "name": "Advisors",
      "description": "Advisor management operations"
    },
    {
      "name": "AlertPreferences",
      "description": "Advisor alert preference management"
    },
    {
      "name": "Availabilities",
      "description": "Advisor availability slot management"
    },
    {
      "name": "Agencies",
      "description": "Agency management"
    },
    {
      "name": "AgencyImages",
      "description": "Agency and advisor image management"
    },
    {
      "name": "Applications",
      "description": "Application tracking and management"
    },
    {
      "name": "ApplicationOutputs",
      "description": "Application output records"
    },
    {
      "name": "Assets",
      "description": "Asset management"
    },
    {
      "name": "ASBAgencyUsers",
      "description": "ASB agency user management"
    },
    {
      "name": "ExternalFmoAgencyUsers",
      "description": "External FMO agency user management"
    },
    {
      "name": "Branding",
      "description": "Branding and resource management"
    },
    {
      "name": "FMOs",
      "description": "FMO (Field Marketing Organization) management"
    },
    {
      "name": "Files",
      "description": "File management"
    },
    {
      "name": "Folders",
      "description": "Folder structure management"
    },
    {
      "name": "FireLight",
      "description": "FireLight integration"
    },
    {
      "name": "GDrive",
      "description": "GDrive integration and organization hierarchy"
    },
    {
      "name": "ClientReviewReport",
      "description": "Client review report operations"
    },
    {
      "name": "CaseCentral",
      "description": "Case Central data conversion"
    },
    {
      "name": "Invitations",
      "description": "Advisor user invitations"
    }
  ],
  "paths": {
    "/v1/Advisors/{advisorId}": {
      "get": {
        "operationId": "getAdvisor",
        "summary": "Retrieve advisor details",
        "tags": ["Advisors"],
        "parameters": [
          {
            "name": "advisorId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Advisor details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GetAdvisorResponse" }
              }
            }
          },
          "404": {
            "description": "Advisor not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResult" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateAdvisor",
        "summary": "Update advisor information",
        "tags": ["Advisors"],
        "parameters": [
          {
            "name": "advisorId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAdvisorCommand" }
            }
          }
        },
        "responses": {
          "200": { "description": "Advisor updated successfully" },
          "400": {
            "description": "Invalid data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResult" }
              }
            }
          }
        }
      }
    },
    "/v1/Advisors/{advisorId}/holdingCompany": {
      "put": {
        "operationId": "assignAdvisorToHoldingCompany",
        "summary": "Assign advisor to holding company",
        "tags": ["Advisors"],
        "parameters": [
          {
            "name": "advisorId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AssignAdvisorCommand" }
            }
          }
        },
        "responses": {
          "200": { "description": "Advisor assigned successfully" },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResult" }
              }
            }
          }
        }
      }
    },
    "/v2/Advisors/{userId}": {
      "get": {
        "operationId": "getAdvisorByPortalId",
        "summary": "Get advisor by portal user ID",
        "tags": ["Advisors"],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
