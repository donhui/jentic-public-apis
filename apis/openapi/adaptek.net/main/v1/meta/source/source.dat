            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpsertAlertPreferenceCommand" }
            }
          }
        },
        "responses": {
          "200": { "description": "Alert preference saved" },
          "201": { "description": "Alert preference created" }
        }
      }
    },
    "/v1/Advisors/{advisorId}/Availabilities": {
      "get": {
