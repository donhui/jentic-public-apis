{
  "openapi": "3.0.3",
  "info": {
    "title": "Issuetrak API",
    "version": "2.0.0",
    "description": "Issuetrak is an operational management platform for issue tracking, help desk, and customer support. The API provides programmatic access to manage issues, users, organizations, and related resources.",
    "x-jentic-source-url": "https://api.issuetrak.com/"
  },
  "servers": [
    {
      "url": "https://api.issuetrak.com",
      "description": "Issuetrak API v2"
    }
  ],
  "paths": {
    "/Authenticate/test": {
      "get": {
        "operationId": "testAuthentication",
        "summary": "Test API token validity",
        "description": "Tests whether the provided API token is valid. Returns 200 if authenticated.",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Authentication successful"
          },
          "401": {
            "description": "Missing or invalid authentication token"
          }
        }
      }
    },
    "/Causes": {
      "get": {
        "operationId": "listCauses",
        "summary": "List causes",
        "description": "Retrieves a paged list of causes.",
        "tags": ["Causes"],
        "parameters": [
          { "$ref": "#/components/parameters/PageNumber" },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/SortField" },
          { "$ref": "#/components/parameters/SortDirection" }
        ],
        "responses": {
          "200": {
            "description": "Paged list of causes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createCause",
        "summary": "Create a cause",
        "tags": ["Causes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCause"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Cause created successfully"
          },
          "400": {
            "description": "Invalid input"
          }
        }
      }
    },
    "/Causes/{iid}": {
      "get": {
        "operationId": "getCause",
        "summary": "Get a cause by ID",
        "tags": ["Causes"],
        "parameters": [
          { "$ref": "#/components/parameters/Iid" }
        ],
        "responses": {
          "200": {
            "description": "Cause details"
          },
          "404": {
            "description": "Cause not found"
          }
        }
      },
      "put": {
        "operationId": "updateCause",
        "summary": "Update a cause",
        "tags": ["Causes"],
        "parameters": [
          { "$ref": "#/components/parameters/Iid" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCause"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Cause updated successfully"
          }
        }
      }
    },
    "/Causes/Search": {
      "post": {
        "operationId": "searchCauses",
        "summary": "Search causes",
        "tags": ["Causes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchFilter"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Paged search results"
          }
        }
      }
    },
