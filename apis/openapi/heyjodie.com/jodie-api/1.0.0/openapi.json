{
  "openapi": "3.0.3",
  "info": {
    "title": "Jodie API",
    "version": "1.0.0",
    "description": "Jodie is an AI-powered calling assistant API providing endpoints for user information and call management with webhook support.",
    "x-jentic-source-url": "https://heyjodie.com/en-us/docs/overview/getting-started/"
  },
  "servers": [
    {
      "url": "https://api.heyjodie.com"
    }
  ],
  "paths": {
    "/api/user": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user information",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "User details"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/calls": {
      "get": {
        "operationId": "listCalls",
        "summary": "List calls",
        "tags": [
          "Calls"
        ],
        "responses": {
          "200": {
            "description": "Call list"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}