{
  "openapi": "3.0.3",
  "info": {
    "title": "Bunny CDN API",
    "description": "Bunny.net CDN API enables comprehensive management of content delivery infrastructure including pull zones, storage zones, DNS, video streaming, purge operations, and analytics. Provides edge network configuration, security controls, and performance optimization.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.bunny.net/reference/bunnynet-api-overview"
  },
  "servers": [
    {
      "url": "https://api.bunny.net",
      "description": "Bunny.net API server"
    }
  ],
  "security": [
    {
      "AccessKey": []
    }
  ],
  "paths": {
    "/pullzone": {
      "get": {
        "summary": "List pull zones",
        "description": "Retrieve a list of all CDN pull zones with optional filtering and pagination",
        "operationId": "listPullZones",
        "tags": ["Pull Zones"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination (0 returns all items as plain array)",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "perPage",
            "in": "query",
            "description": "Items per page",
            "schema": {
              "type": "integer",
              "minimum": 5,
              "maximum": 1000,
              "default": 1000
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Filter results by search term",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeCertificate",
            "in": "query",
            "description": "Include SSL certificate information in hostname responses",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of pull zones",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PullZone"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Create pull zone",
        "description": "Create a new CDN pull zone",
        "operationId": "createPullZone",
        "tags": ["Pull Zones"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PullZoneCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Pull zone created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PullZone"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pullzone/{id}": {
      "get": {
        "summary": "Get pull zone",
        "description": "Retrieve details of a specific pull zone",
        "operationId": "getPullZone",
        "tags": ["Pull Zones"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Pull zone ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pull zone details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PullZone"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "post": {
        "summary": "Update pull zone",
        "description": "Update configuration of an existing pull zone",
        "operationId": "updatePullZone",
        "tags": ["Pull Zones"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Pull zone ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PullZoneUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pull zone updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PullZone"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "summary": "Delete pull zone",
        "description": "Delete a pull zone",
        "operationId": "deletePullZone",
        "tags": ["Pull Zones"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Pull zone ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Pull zone deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/pullzone/{id}/purgeCache": {
      "post": {
        "summary": "Purge pull zone cache",
        "description": "Clear all cached content for a pull zone",
        "operationId": "purgePullZoneCache",
        "tags": ["Purge"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Pull zone ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cache purge initiated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/purge": {
      "post": {
        "summary": "Purge URL from cache",
        "description": "Purge specific URL or URLs from edge cache",
        "operationId": "purgeUrl",
        "tags": ["Purge"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "URL to purge from cache",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "URL purge initiated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/storagezone": {
      "get": {
        "summary": "List storage zones",
        "description": "Retrieve a list of all edge storage zones",
        "operationId": "listStorageZones",
        "tags": ["Storage Zones"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "perPage",
            "in": "query",
            "description": "Items per page",
            "schema": {
              "type": "integer",
              "default": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of storage zones",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StorageZone"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Create storage zone",
        "description": "Create a new edge storage zone",
        "operationId": "createStorageZone",
        "tags": ["Storage Zones"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StorageZoneCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Storage zone created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageZone"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/storagezone/{id}": {
      "get": {
        "summary": "Get storage zone",
        "description": "Retrieve details of a specific storage zone",
        "operationId": "getStorageZone",
        "tags": ["Storage Zones"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Storage zone ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Storage zone details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageZone"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "summary": "Delete storage zone",
        "description": "Delete a storage zone",
        "operationId": "deleteStorageZone",
        "tags": ["Storage Zones"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Storage zone ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Storage zone deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/videolibrary": {
      "get": {
        "summary": "List video libraries",
        "description": "Retrieve a list of all video streaming libraries",
        "operationId": "listVideoLibraries",
        "tags": ["Video Streaming"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "perPage",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of video libraries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/VideoLibrary"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Create video library",
        "description": "Create a new video streaming library",
        "operationId": "createVideoLibrary",
        "tags": ["Video Streaming"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoLibraryCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Video library created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoLibrary"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/videolibrary/{id}": {
      "get": {
        "summary": "Get video library",
        "description": "Retrieve details of a specific video library",
        "operationId": "getVideoLibrary",
        "tags": ["Video Streaming"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Video library ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Video library details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoLibrary"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/statistics": {
      "get": {
        "summary": "Get statistics",
        "description": "Retrieve bandwidth, request, and cache statistics",
        "operationId": "getStatistics",
        "tags": ["Statistics"],
        "parameters": [
          {
            "name": "dateFrom",
            "in": "query",
            "description": "Start date for statistics (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "dateTo",
            "in": "query",
            "description": "End date for statistics (ISO 8601 format)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "pullZone",
            "in": "query",
            "description": "Filter by pull zone ID",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Statistics data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Statistics"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/billing": {
      "get": {
        "summary": "Get billing summary",
        "description": "Retrieve account billing information and charges",
        "operationId": "getBillingSummary",
        "tags": ["Billing"],
        "responses": {
          "200": {
            "description": "Billing summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BillingSummary"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/region": {
      "get": {
        "summary": "List regions",
        "description": "Retrieve available edge regions and locations",
        "operationId": "listRegions",
        "tags": ["Regions"],
        "responses": {
          "200": {
            "description": "List of regions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Region"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "AccessKey": {
        "type": "apiKey",
        "in": "header",
        "name": "AccessKey",
        "description": "Account API key from Bunny.net dashboard"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters"
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key"
      },
      "NotFound": {
        "description": "Resource not found"
      }
    },
    "schemas": {
      "PullZone": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "originUrl": {
            "type": "string",
            "format": "uri"
          },
          "enabled": {
            "type": "boolean"
          },
          "hostnames": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "storageZoneId": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "PullZoneCreate": {
        "type": "object",
        "required": ["name", "originUrl"],
        "properties": {
          "name": {
            "type": "string"
          },
          "originUrl": {
            "type": "string",
            "format": "uri"
          },
          "type": {
            "type": "string",
            "enum": ["Standard", "Volume"]
          }
        }
      },
      "PullZoneUpdate": {
        "type": "object",
        "properties": {
          "originUrl": {
            "type": "string",
            "format": "uri"
          },
          "enabled": {
            "type": "boolean"
          },
          "cachingEnabled": {
            "type": "boolean"
          }
        }
      },
      "StorageZone": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "storageUsed": {
            "type": "integer",
            "format": "int64"
          },
          "filesStored": {
            "type": "integer",
            "format": "int64"
          },
          "region": {
            "type": "string"
          }
        }
      },
      "StorageZoneCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "region": {
            "type": "string",
            "description": "Storage region code"
          }
        }
      },
      "VideoLibrary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "videoCount": {
            "type": "integer"
          },
          "storageUsed": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "VideoLibraryCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "Statistics": {
        "type": "object",
        "properties": {
          "totalBandwidthUsed": {
            "type": "integer",
            "format": "int64"
          },
          "totalRequestsServed": {
            "type": "integer",
            "format": "int64"
          },
          "cacheHitRate": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "BillingSummary": {
        "type": "object",
        "properties": {
          "balance": {
            "type": "number"
          },
          "monthlyCharges": {
            "type": "number"
          },
          "billingRecords": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Region": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "regionCode": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Pull Zones",
      "description": "CDN pull zone management"
    },
    {
      "name": "Storage Zones",
      "description": "Edge storage zone management"
    },
    {
      "name": "Video Streaming",
      "description": "Video library management"
    },
    {
      "name": "Purge",
      "description": "Cache purge operations"
    },
    {
      "name": "Statistics",
      "description": "Usage statistics and analytics"
    },
    {
      "name": "Billing",
      "description": "Billing and account information"
    },
    {
      "name": "Regions",
      "description": "Available edge regions"
    }
  ]
}
