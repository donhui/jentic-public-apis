{
  "openapi": "3.0.3",
  "info": {
    "title": "Oura Ring API",
    "description": "The Oura Ring API v2 provides access to personal health data collected by the Oura Ring, including daily activity, sleep, readiness, heart rate, SpO2, workouts, sessions, and tags.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://cloud.ouraring.com/v2/docs"
  },
  "servers": [
    {
      "url": "https://api.ouraring.com",
      "description": "Oura API production server"
    }
  ],
