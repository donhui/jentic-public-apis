  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Personal access token or OAuth2 access token"
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://cloud.ouraring.com/oauth/authorize",
            "tokenUrl": "https://api.ouraring.com/oauth/token",
            "scopes": {
              "email": "Access email address",
              "personal": "Access personal information",
              "daily": "Access daily summary data",
              "heartrate": "Access heart rate data",
              "workout": "Access workout data",
              "tag": "Access tag data",
              "session": "Access session data",
              "spo2": "Access SpO2 data"
            }
          }
        }
      }
    },
    "schemas": {
      "PersonalInfoResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "age": {
            "type": "integer"
          },
          "weight": {
            "type": "number"
          },
          "height": {
            "type": "number"
          },
          "biological_sex": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "DailyActivityModel": {
        "type": "object",
