          "score": {
            "type": "integer"
          },
          "active_calories": {
            "type": "integer"
          },
          "average_met_minutes": {
            "type": "number"
          },
          "equivalent_walking_distance": {
            "type": "integer"
          },
          "high_activity_met_minutes": {
            "type": "integer"
          },
          "high_activity_time": {
            "type": "integer"
          },
          "inactivity_alerts": {
            "type": "integer"
          },
          "low_activity_met_minutes": {
            "type": "integer"
          },
          "low_activity_time": {
            "type": "integer"
          },
          "medium_activity_met_minutes": {
            "type": "integer"
          },
          "medium_activity_time": {
            "type": "integer"
          },
          "met": {
            "type": "object"
          },
          "meters_to_target": {
            "type": "integer"
          },
          "non_wear_time": {
            "type": "integer"
          },
          "resting_time": {
            "type": "integer"
          },
          "sedentary_met_minutes": {
            "type": "integer"
          },
          "sedentary_time": {
            "type": "integer"
          },
          "steps": {
            "type": "integer"
          },
          "target_calories": {
            "type": "integer"
          },
          "target_meters": {
            "type": "integer"
          },
          "total_calories": {
            "type": "integer"
          },
          "day": {
            "type": "string",
            "format": "date"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DailyActivityListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DailyActivityModel"
            }
          },
          "next_token": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "DailySleepModel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "day": {
            "type": "string",
            "format": "date"
          },
          "score": {
            "type": "integer"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "contributors": {
            "type": "object"
          }
        }
      },
      "DailySleepListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DailySleepModel"
            }
          },
          "next_token": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "DailySpO2Model": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
