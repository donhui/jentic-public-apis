    "/spaces/{space_id}/assets": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" }
      ],
      "get": {
        "operationId": "listAssets",
        "summary": "List Assets",
        "tags": ["Assets"],
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PerPage" },
          { "name": "search", "in": "query", "schema": { "type": "string" }, "description": "Search by filename" },
          { "name": "in_folder", "in": "query", "schema": { "type": "integer" }, "description": "Filter by asset folder ID" }
        ],
        "responses": {
          "200": {
            "description": "A list of assets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "assets": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Asset" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "registerAsset",
        "summary": "Register Asset",
        "description": "Registers a new asset and returns a signed upload URL for direct file upload.",
        "tags": ["Assets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["filename"],
                "properties": {
                  "filename": { "type": "string", "description": "Name of the file to upload" },
                  "size": { "type": "string", "description": "Dimensions of the image (e.g. 400x300)" },
                  "asset_folder_id": { "type": "integer", "description": "ID of the asset folder" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signed upload parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pretty_url": { "type": "string" },
                    "public_url": { "type": "string" },
                    "fields": { "type": "object", "additionalProperties": { "type": "string" } },
                    "post_url": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/spaces/{space_id}/assets/{asset_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" },
        {
          "name": "asset_id",
          "in": "path",
