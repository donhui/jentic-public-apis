          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "asset": { "$ref": "#/components/schemas/AssetInput" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated asset",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "asset": { "$ref": "#/components/schemas/Asset" }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteAsset",
        "summary": "Delete Asset",
        "tags": ["Assets"],
        "responses": {
          "200": {
            "description": "Asset deleted successfully"
          }
        }
      }
    },
    "/spaces/{space_id}/asset_folders": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" }
      ],
      "get": {
        "operationId": "listAssetFolders",
