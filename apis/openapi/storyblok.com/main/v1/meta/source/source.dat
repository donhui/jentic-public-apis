            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "component": { "$ref": "#/components/schemas/Component" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/spaces/{space_id}/components/{component_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" },
        {
          "name": "component_id",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" },
          "description": "Numeric ID of the component"
        }
      ],
      "get": {
        "operationId": "getComponent",
        "summary": "Get Component",
        "tags": ["Components"],
        "responses": {
          "200": {
            "description": "A single component",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "component": { "$ref": "#/components/schemas/Component" }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateComponent",
        "summary": "Update Component",
        "tags": ["Components"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["component"],
                "properties": {
                  "component": { "$ref": "#/components/schemas/ComponentInput" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated component",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "component": { "$ref": "#/components/schemas/Component" }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteComponent",
        "summary": "Delete Component",
        "tags": ["Components"],
        "responses": {
          "200": {
            "description": "Component deleted successfully"
          }
        }
      }
    },
