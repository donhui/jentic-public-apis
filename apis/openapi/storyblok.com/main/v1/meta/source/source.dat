              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "component_group": { "$ref": "#/components/schemas/ComponentGroup" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/spaces/{space_id}/component_groups/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" },
        { "$ref": "#/components/parameters/ResourceId" }
      ],
      "get": {
        "operationId": "getComponentGroup",
        "summary": "Get Component Group",
        "tags": ["Component Groups"],
        "responses": {
