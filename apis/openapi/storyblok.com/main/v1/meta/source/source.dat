                "schema": {
                  "type": "object",
                  "properties": {
                    "components": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Component" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createComponent",
        "summary": "Create Component",
        "tags": ["Components"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["component"],
                "properties": {
                  "component": { "$ref": "#/components/schemas/ComponentInput" }
                }
              }
            }
          }
        },
        "responses": {
