{
  "openapi": "3.0.3",
  "info": {
    "title": "Storyblok Management API",
    "version": "v1",
    "description": "Storyblok's Management API for managing spaces, stories, components, assets, and other content management resources.",
    "x-jentic-source-url": "https://www.storyblok.com/docs/api/management-api"
  },
  "servers": [
    {
      "url": "https://mapi.storyblok.com/v1"
    }
  ],
  "security": [
    {
      "personalAccessToken": []
    }
  ],
  "tags": [
    { "name": "Spaces" },
    { "name": "Stories" },
    { "name": "Components" },
    { "name": "Component Groups" },
    { "name": "Assets" },
    { "name": "Asset Folders" },
    { "name": "Datasources" },
    { "name": "Datasource Entries" },
    { "name": "Collaborators" },
    { "name": "Space Roles" },
    { "name": "Releases" },
    { "name": "Workflow Stages" },
    { "name": "Presets" },
    { "name": "Activities" },
    { "name": "Tasks" },
    { "name": "Webhooks" }
  ],
  "paths": {
    "/spaces": {
      "get": {
        "operationId": "listSpaces",
        "summary": "List Spaces",
        "tags": ["Spaces"],
        "responses": {
          "200": {
            "description": "A list of spaces",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "spaces": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Space" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createSpace",
        "summary": "Create Space",
        "tags": ["Spaces"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["space"],
                "properties": {
                  "space": {
                    "type": "object",
                    "required": ["name"],
                    "properties": {
                      "name": { "type": "string", "description": "Name of the space" },
                      "plan": { "type": "string", "description": "Plan level for the space" }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The created space",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "space": { "$ref": "#/components/schemas/Space" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/spaces/{space_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" }
      ],
      "get": {
        "operationId": "getSpace",
        "summary": "Get Space",
        "tags": ["Spaces"],
        "responses": {
          "200": {
            "description": "A single space",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "space": { "$ref": "#/components/schemas/Space" }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateSpace",
        "summary": "Update Space",
        "tags": ["Spaces"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "space": { "$ref": "#/components/schemas/SpaceInput" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated space",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "space": { "$ref": "#/components/schemas/Space" }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteSpace",
        "summary": "Delete Space",
        "tags": ["Spaces"],
        "responses": {
          "200": {
            "description": "Space deleted successfully"
          }
        }
      }
    },
    "/spaces/{space_id}/stories": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" }
      ],
      "get": {
        "operationId": "listStories",
        "summary": "List Stories",
        "tags": ["Stories"],
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PerPage" },
          { "name": "starts_with", "in": "query", "schema": { "type": "string" }, "description": "Filter by slug prefix" },
          { "name": "by_slugs", "in": "query", "schema": { "type": "string" }, "description": "Filter by comma-separated slugs" },
          { "name": "sort_by", "in": "query", "schema": { "type": "string" }, "description": "Sort field and order (e.g. created_at:desc)" },
          { "name": "search_term", "in": "query", "schema": { "type": "string" }, "description": "Search term to filter stories" },
          { "name": "with_tag", "in": "query", "schema": { "type": "string" }, "description": "Filter by tag" },
          { "name": "is_published", "in": "query", "schema": { "type": "boolean" }, "description": "Filter by published status" },
          { "name": "in_workflow_stages", "in": "query", "schema": { "type": "string" }, "description": "Filter by workflow stage IDs" },
          { "name": "by_uuids", "in": "query", "schema": { "type": "string" }, "description": "Filter by comma-separated UUIDs" },
          { "name": "folder_id", "in": "query", "schema": { "type": "integer" }, "description": "Filter by parent folder ID" },
          { "name": "story_only", "in": "query", "schema": { "type": "boolean" }, "description": "Return only stories (exclude folders)" },
          { "name": "excluding_ids", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated story IDs to exclude" },
          { "name": "excluding_slugs", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated slugs to exclude" },
          { "name": "in_release", "in": "query", "schema": { "type": "string" }, "description": "Filter by release ID" },
          { "name": "scheduled_at_gt", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Filter stories scheduled after this date" },
          { "name": "scheduled_at_lt", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Filter stories scheduled before this date" },
          { "name": "first_published_at_gt", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Filter by first published date (greater than)" },
          { "name": "first_published_at_lt", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Filter by first published date (less than)" },
          { "name": "published_at_gt", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Filter by published date (greater than)" },
          { "name": "published_at_lt", "in": "query", "schema": { "type": "string", "format": "date-time" }, "description": "Filter by published date (less than)" },
          { "name": "text_search", "in": "query", "schema": { "type": "string" }, "description": "Full text search in story content" }
        ],
        "responses": {
          "200": {
            "description": "A list of stories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stories": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Story" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createStory",
        "summary": "Create Story",
        "tags": ["Stories"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["story"],
                "properties": {
                  "story": { "$ref": "#/components/schemas/StoryInput" },
                  "publish": { "type": "boolean", "description": "Publish the story immediately" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The created story",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "story": { "$ref": "#/components/schemas/Story" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/spaces/{space_id}/stories/{story_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" },
        { "$ref": "#/components/parameters/StoryId" }
      ],
      "get": {
        "operationId": "getStory",
        "summary": "Get Story",
        "tags": ["Stories"],
        "responses": {
          "200": {
            "description": "A single story",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "story": { "$ref": "#/components/schemas/Story" }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateStory",
        "summary": "Update Story",
        "tags": ["Stories"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["story"],
                "properties": {
                  "story": { "$ref": "#/components/schemas/StoryInput" },
                  "publish": { "type": "boolean", "description": "Publish the story immediately" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated story",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "story": { "$ref": "#/components/schemas/Story" }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteStory",
        "summary": "Delete Story",
        "tags": ["Stories"],
        "responses": {
          "200": {
            "description": "Story deleted successfully"
          }
        }
      }
    },
    "/spaces/{space_id}/stories/{story_id}/publish": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" },
        { "$ref": "#/components/parameters/StoryId" }
      ],
      "get": {
        "operationId": "publishStory",
        "summary": "Publish Story",
        "tags": ["Stories"],
        "responses": {
          "200": {
            "description": "Story published successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "story": { "$ref": "#/components/schemas/Story" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/spaces/{space_id}/stories/{story_id}/unpublish": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" },
        { "$ref": "#/components/parameters/StoryId" }
      ],
      "get": {
        "operationId": "unpublishStory",
        "summary": "Unpublish Story",
        "tags": ["Stories"],
        "responses": {
          "200": {
            "description": "Story unpublished successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "story": { "$ref": "#/components/schemas/Story" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/spaces/{space_id}/components": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" }
      ],
      "get": {
