            }
          }
        }
      },
      "put": {
        "operationId": "updateComponentGroup",
        "summary": "Update Component Group",
        "tags": ["Component Groups"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["component_group"],
                "properties": {
                  "component_group": { "$ref": "#/components/schemas/ComponentGroupInput" }
                }
