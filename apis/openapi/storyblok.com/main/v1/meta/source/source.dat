                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createComponentGroup",
        "summary": "Create Component Group",
        "tags": ["Component Groups"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["component_group"],
