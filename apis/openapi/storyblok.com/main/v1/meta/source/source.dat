  "components": {
    "securitySchemes": {
      "personalAccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Personal access token or OAuth token. Pass as: token_value"
      }
    },
    "parameters": {
      "SpaceId": {
        "name": "space_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Numeric ID of the space"
      },
      "StoryId": {
        "name": "story_id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Numeric ID of the story"
      },
      "ResourceId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Numeric ID of the resource"
      },
      "Page": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "default": 1 },
        "description": "Page number for pagination"
      },
      "PerPage": {
        "name": "per_page",
        "in": "query",
        "schema": { "type": "integer", "default": 25 },
        "description": "Number of items per page"
      }
    },
    "schemas": {
      "Space": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "domain": { "type": "string" },
          "plan": { "type": "string" },
          "plan_level": { "type": "integer" },
          "owner_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "version": { "type": "integer" },
          "stories_count": { "type": "integer" },
          "assets_count": { "type": "integer" },
          "request_count_today": { "type": "integer" },
          "api_requests": { "type": "integer" },
          "exceeded_requests": { "type": "integer" },
          "first_token": { "type": "string" },
          "environments": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "SpaceInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "plan": { "type": "string" },
          "domain": { "type": "string" }
        }
      },
      "Story": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "full_slug": { "type": "string" },
          "content": { "type": "object", "additionalProperties": true },
          "parent_id": { "type": "integer", "nullable": true },
          "group_id": { "type": "string", "nullable": true },
          "is_folder": { "type": "boolean" },
          "is_startpage": { "type": "boolean" },
          "position": { "type": "integer" },
          "first_published_at": { "type": "string", "format": "date-time", "nullable": true },
          "published_at": { "type": "string", "format": "date-time", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "publish_at": { "type": "string", "format": "date-time", "nullable": true },
          "expire_at": { "type": "string", "format": "date-time", "nullable": true },
          "tag_list": { "type": "array", "items": { "type": "string" } },
          "sort_by_date": { "type": "string", "format": "date-time", "nullable": true },
          "meta_data": { "type": "object", "additionalProperties": true },
          "release_id": { "type": "integer", "nullable": true },
          "lang": { "type": "string" },
          "path": { "type": "string", "nullable": true },
          "alternates": { "type": "array", "items": { "type": "object" } },
          "default_root": { "type": "string", "nullable": true },
          "translated_slugs": {
            "type": "array",
            "items": { "type": "object" },
            "nullable": true
          },
          "localized_paths": {
            "type": "array",
            "items": { "type": "object" },
            "nullable": true
          }
        }
      },
      "StoryInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "description": "Name of the story" },
          "slug": { "type": "string", "description": "URL slug" },
          "content": { "type": "object", "additionalProperties": true, "description": "Story content object" },
          "parent_id": { "type": "integer", "nullable": true, "description": "Parent folder ID" },
          "is_folder": { "type": "boolean", "description": "Whether this is a folder" },
          "default_root": { "type": "string", "description": "Default root component for folders" },
          "position": { "type": "integer", "description": "Position in the tree" },
          "is_startpage": { "type": "boolean", "description": "Whether this is the start page of a folder" },
          "first_published_at": { "type": "string", "format": "date-time", "description": "Override first published date" },
          "translated_slugs": { "type": "array", "items": { "type": "object" }, "description": "Translated slug objects" },
          "group_id": { "type": "string", "description": "Group ID for story grouping" },
          "release_id": { "type": "integer", "nullable": true, "description": "Release ID" },
          "lang": { "type": "string", "description": "Language code" },
          "localized_paths": { "type": "array", "items": { "type": "object" }, "description": "Localized path objects" }
        }
      },
      "Component": {
        "type": "object",
