    },
    "/spaces/{space_id}/asset_folders/{id}": {
      "parameters": [
        { "$ref": "#/components/parameters/SpaceId" },
        { "$ref": "#/components/parameters/ResourceId" }
      ],
      "get": {
        "operationId": "getAssetFolder",
        "summary": "Get Asset Folder",
        "tags": ["Asset Folders"],
        "responses": {
          "200": {
            "description": "A single asset folder",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "asset_folder": { "$ref": "#/components/schemas/AssetFolder" }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateAssetFolder",
        "summary": "Update Asset Folder",
        "tags": ["Asset Folders"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["asset_folder"],
                "properties": {
                  "asset_folder": { "$ref": "#/components/schemas/AssetFolderInput" }
                }
              }
            }
