          "actions": { "type": "array", "items": { "type": "string" } },
          "activated": { "type": "boolean" },
          "secret": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "WebhookEndpointInput": {
        "type": "object",
        "required": ["name", "endpoint"],
        "properties": {
          "name": { "type": "string", "description": "Name of the webhook endpoint" },
          "endpoint": { "type": "string", "description": "URL to receive webhook payloads" },
          "actions": { "type": "array", "items": { "type": "string" }, "description": "List of actions to trigger the webhook (e.g. story.published, story.unpublished)" },
          "activated": { "type": "boolean", "description": "Whether the webhook is active" },
          "secret": { "type": "string", "description": "Secret for signing webhook payloads" }
        }
      }
    }
  }
}