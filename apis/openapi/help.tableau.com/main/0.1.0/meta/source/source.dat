{
  "openapi": "3.0.3",
  "info": {
    "title": "Tableau REST API",
    "version": "0.1.0",
    "description": "Tableau REST API for managing analytics extensions, ask data lenses, and server/site settings. This spec covers the analytics extensions and ask data lens endpoints.",
    "x-jentic-source-url": "https://help.tableau.com/current/api/rest_api/en-us/REST/TAG/index.html"
  },
  "servers": [
    {
      "url": "https://{tableau-server}",
      "description": "Tableau Server",
      "variables": {
        "tableau-server": {
          "default": "your-tableau-server.com",
          "description": "Tableau Server hostname"
        }
      }
    }
  ],
  "security": [
    {
      "tableauAuth": []
    }
  ],
  "paths": {
    "/api/-/settings/server/extensions/analytics": {
      "get": {
        "operationId": "getserveranalyticsextensionssettings",
        "summary": "Get analytics extensions server settings",
        "description": "Gets the enabled/disabled state of analytics extensions on a server.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "responses": {
          "200": {
            "description": "Analytics extensions server settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsExtensionsToggle"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateserveranalyticsextensionssettings",
        "summary": "Update analytics extensions server settings",
        "description": "Enables or disables analytics extensions on a server.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyticsExtensionsToggle"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsExtensionsToggle"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/-/settings/site/extensions/analytics": {
      "get": {
        "operationId": "getsiteanalyticsextensionssettings",
        "summary": "Get analytics extensions site settings",
        "description": "Gets the enabled/disabled state of analytics extensions on a site.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "responses": {
          "200": {
            "description": "Analytics extensions site settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsExtensionsToggle"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updatesiteanalyticsextensionssettings",
        "summary": "Update analytics extensions site settings",
        "description": "Enables or disables analytics extensions on a site.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyticsExtensionsToggle"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsExtensionsToggle"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/-/settings/site/extensions/analytics/connections": {
      "get": {
        "operationId": "listsiteanalyticsextensionsconnections",
        "summary": "List analytics extension connections",
        "description": "Lists a site's analytics extension connections for external services.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "responses": {
          "200": {
            "description": "List of analytics extension connections",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "connections": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AnalyticsExtensionConnection"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createsiteanalyticsextensionconnection",
        "summary": "Create analytics extension connection",
        "description": "Adds a new analytics extension connection for an external service to a site.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyticsExtensionConnectionInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Connection created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsExtensionConnection"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/-/settings/site/extensions/analytics/connections/{connection_luid}": {
      "get": {
        "operationId": "getsiteanalyticsextensionconnection",
        "summary": "Get analytics extension connection details",
        "description": "Get the details of a specified analytics extension connection.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "parameters": [
          {
            "name": "connection_luid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The LUID of the analytics extension connection"
          }
        ],
        "responses": {
          "200": {
            "description": "Connection details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsExtensionConnection"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updatesiteanalyticsextensionconnection",
        "summary": "Update analytics extension connection",
        "description": "Updates the details of specified analytics extension connection.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "parameters": [
          {
            "name": "connection_luid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The LUID of the analytics extension connection"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyticsExtensionConnectionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connection updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsExtensionConnection"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deletesiteanalyticsextensionconnection",
        "summary": "Delete analytics extension connection",
        "description": "Deletes a specific analytics extension connection from a site.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "parameters": [
          {
            "name": "connection_luid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The LUID of the analytics extension connection"
          }
        ],
        "responses": {
          "204": {
            "description": "Connection deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/-/settings/site/extensions/analytics/workbooks/{workbook_luid}/connections": {
      "get": {
        "operationId": "listworkbookanalyticsextensionconnections",
        "summary": "List workbook analytics extension connections",
        "description": "Lists basic details of each analytics extension connection available for a workbook.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "parameters": [
          {
            "name": "workbook_luid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The LUID of the workbook"
          }
        ],
        "responses": {
          "200": {
            "description": "List of connections available for the workbook",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "connections": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AnalyticsExtensionConnection"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/-/settings/site/extensions/analytics/workbooks/{workbook_luid}/selected_connection": {
      "get": {
        "operationId": "getworkbookselectedanalyticsextensionconnection",
        "summary": "Get workbook's selected analytics extension connection",
        "description": "Gets basic details of the analytics extension connection a workbook is currently using.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "parameters": [
          {
            "name": "workbook_luid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The LUID of the workbook"
          }
        ],
        "responses": {
          "200": {
            "description": "Selected connection details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsExtensionConnection"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateworkbookselectedanalyticsextensionconnection",
        "summary": "Update workbook's selected analytics extension connection",
        "description": "Updates the analytics extension connection currently used by a workbook.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "parameters": [
          {
            "name": "workbook_luid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The LUID of the workbook"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "connection_luid": {
                    "type": "string",
                    "description": "The LUID of the connection to select"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Selected connection updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsExtensionConnection"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "removeworkbookselectedanalyticsextensionconnection",
        "summary": "Remove workbook's selected analytics extension connection",
        "description": "Remove the currently used analytics extension connection from a workbook.",
        "tags": [
          "Analytics Extensions Settings"
        ],
        "parameters": [
          {
            "name": "workbook_luid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The LUID of the workbook"
          }
        ],
        "responses": {
          "204": {
            "description": "Connection removed from workbook"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/-/askdata/lenses": {
      "get": {
        "operationId": "listaskdatalenses",
        "summary": "List ask data lenses",
        "description": "Returns a list of ask data lenses in a site. Retired in API 3.22.",
        "tags": [
          "Ask Data Lenses"
        ],
        "deprecated": true,
        "responses": {
          "200": {
            "description": "List of ask data lenses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "lenses": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AskDataLens"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createaskdatalens",
        "summary": "Create an ask data lens",
        "description": "Create an ask data lens. Retired in API 3.22.",
        "tags": [
          "Ask Data Lenses"
        ],
        "deprecated": true,
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AskDataLensInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Lens created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AskDataLens"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/-/askdata/lenses/{lens_id}": {
      "get": {
        "operationId": "getaskdatalens",
        "summary": "Get ask data lens details",
        "description": "Get ask data lens details. Retired in API 3.22.",
        "tags": [
          "Ask Data Lenses"
        ],
        "deprecated": true,
        "parameters": [
          {
            "name": "lens_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the ask data lens"
          }
        ],
        "responses": {
          "200": {
            "description": "Lens details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AskDataLens"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteaskdatalens",
        "summary": "Delete an ask data lens",
        "description": "Delete an ask data lens. Retired in API 3.22.",
        "tags": [
          "Ask Data Lenses"
        ],
        "deprecated": true,
        "parameters": [
          {
            "name": "lens_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The ID of the ask data lens"
          }
        ],
        "responses": {
          "204": {
            "description": "Lens deleted successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnalyticsExtensionsToggle": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "Whether analytics extensions are enabled"
          }
        }
      },
      "AnalyticsExtensionConnection": {
        "type": "object",
        "properties": {
          "connection_luid": {
            "type": "string",
            "description": "Unique identifier for the connection"
          },
          "host": {
            "type": "string",
            "description": "Hostname of the external analytics service"
          },
          "port": {
            "type": "integer",
            "description": "Port number"
          },
          "is_auth_enabled": {
            "type": "boolean",
            "description": "Whether authentication is enabled for this connection"
          },
          "username": {
            "type": "string",
            "description": "Username for authentication"
          },
          "connection_brief": {
            "type": "string",
            "description": "Brief description of the connection"
          }
        }
      },
      "AnalyticsExtensionConnectionInput": {
        "type": "object",
        "properties": {
          "host": {
            "type": "string",
            "description": "Hostname of the external analytics service"
          },
          "port": {
            "type": "integer",
            "description": "Port number"
          },
          "is_auth_enabled": {
            "type": "boolean",
            "description": "Whether authentication is enabled"
          },
          "username": {
            "type": "string",
            "description": "Username for authentication"
          },
          "password": {
            "type": "string",
            "description": "Password for authentication"
          }
        }
      },
      "AskDataLens": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the lens"
          },
          "name": {
            "type": "string",
            "description": "Name of the lens"
          },
          "description": {
            "type": "string",
            "description": "Description of the lens"
          }
        }
      },
      "AskDataLensInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the lens"
          },
          "description": {
            "type": "string",
            "description": "Description of the lens"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "tableauAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Tableau-Auth",
        "description": "Tableau authentication token obtained from sign-in request"
      }
    }
  },
  "tags": [
    {
      "name": "Analytics Extensions Settings",
      "description": "Configure analytics extensions for servers, sites, and workbooks"
    },
    {
      "name": "Ask Data Lenses",
      "description": "Manage ask data lenses (retired in API 3.22)"
    }
  ]
}