{
  "openapi": "3.0.3",
  "info": {
    "title": "The Trade Desk API",
    "version": "v3",
    "description": "The Trade Desk platform API for programmatic advertising management including advertisers, campaigns, ad groups, creatives, bid lists, and audience management.",
    "x-jentic-source-url": "https://partner.thetradedesk.com/v3/portal/api/overview"
  },
  "servers": [
    {
      "url": "https://api.thetradedesk.com"
    }
  ],
  "paths": {
    "/v3/authentication": {
      "post": {
        "operationId": "authenticate",
        "summary": "Authenticate and obtain API token",
        "description": "Authenticate with credentials to obtain an API token for subsequent requests.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["Login", "Password"],
                "properties": {
                  "Login": {
                    "type": "string",
                    "description": "The API login username"
                  },
                  "Password": {
                    "type": "string",
                    "description": "The API login password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
