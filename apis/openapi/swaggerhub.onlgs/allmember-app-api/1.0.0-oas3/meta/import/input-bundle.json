    "/invitecode/get": {
      "post": {
        "tags": [
          "Member Get Member"
        ],
        "operationId": "get-invitecode",
        "description": "Get 'inviteCode' of provided memberId\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "sysDateTime",
                  "memberId"
                ],
                "properties": {
                  "sysDateTime": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2020-07-29T10:52:00+07:00"
                  },
                  "memberId": {
                    "type": "string",
                    "example": "010100005509"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "returnCode": {
                      "type": "string",
                      "example": "00000"
                    },
                    "returnDesc": {
                      "type": "string",
                      "example": "Success"
                    },
                    "returnDescTH": {
                      "type": "string",
                      "example": "ทำรายการสำเร็จ"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "inviteCode": {
                          "type": "string",
                          "example": "XAVB010100005509"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
