{
  "openapi": "3.0.3",
  "info": {
    "title": "Kutetailor Zapier API",
    "description": "Kutetailor is a cloud-based order management platform for custom production. This API provides a Zapier integration endpoint for receiving order status updates.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://s.apifox.cn/d929a6f3-96fe-4b84-ab90-7a360a170c8d/419063350e0"
  },
  "servers": [
    {
      "url": "https://platform.kutetailor.com/api",
      "description": "Production Server"
    }
  ],
  "tags": [
    { "name": "Orders", "description": "Order management operations" }
  ],
  "paths": {
    "/zapier/public/perform": {
      "post": {
        "operationId": "performZapierAction",
        "summary": "Save or update order via Zapier",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": true,
            "description": "Action type: save a new order or update an existing one",
            "schema": {
              "type": "string",
              "enum": ["new", "update"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order status list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ZapierOrderStatusVO"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ZapierOrderStatusVO": {
        "type": "object",
        "properties": {
          "orderNo": {
            "type": "string",
            "description": "Order identifier"
          },
          "status": {
            "type": "integer",
            "description": "Order status code"
          },
          "statusName": {
            "type": "string",
            "description": "Human-readable status name"
          },
          "customerNo": {
            "type": "string",
            "description": "Customer reference number"
          },
          "customerName": {
            "type": "string",
            "description": "Customer name"
          },
          "deliveryDate": {
            "type": "string",
            "description": "Scheduled delivery date"
          },
          "deliveryCode": {
            "type": "string",
            "description": "Delivery identifier"
          },
          "waybillno": {
            "type": "string",
            "description": "Shipment tracking number"
          }
        }
      }
    }
  }
}