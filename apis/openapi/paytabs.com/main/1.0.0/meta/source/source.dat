{
  "openapi": "3.0.3",
  "info": {
    "title": "PayTabs API",
    "version": "1.0.0",
    "description": "PayTabs API provides payment processing services for online merchants. It supports payment page creation, transaction management, refunds, recurring payments, and payment inquiries across multiple payment methods and currencies.",
    "x-jentic-source-url": "https://docs.paytabs.com/"
  },
  "servers": [
    {
      "url": "https://secure.paytabs.sa/payment"
    }
  ],
  "paths": {
    "/request": {
      "post": {
        "operationId": "createPaymentPage",
        "summary": "Create a payment page",
        "description": "Creates a hosted payment page for collecting payment from a customer. Returns a redirect URL where the customer completes the payment.",
        "tags": ["Payments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment page created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payment parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid server key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/query": {
      "post": {
        "operationId": "queryTransaction",
        "summary": "Query a transaction",
        "description": "Queries the status and details of an existing transaction by its reference.",
        "tags": ["Transactions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransactionQueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/refund": {
      "post": {
        "operationId": "refundTransaction",
        "summary": "Refund a transaction",
        "description": "Processes a full or partial refund for a previously completed transaction.",
        "tags": ["Refunds"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefundRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund processed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefundResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid refund request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/capture": {
      "post": {
        "operationId": "captureTransaction",
        "summary": "Capture an authorized transaction",
        "description": "Captures a previously authorized transaction to complete the payment.",
        "tags": ["Transactions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CaptureRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction captured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid capture request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/void": {
      "post": {
        "operationId": "voidTransaction",
        "summary": "Void a transaction",
        "description": "Voids a previously authorized transaction that has not yet been captured.",
        "tags": ["Transactions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VoidRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction voided",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid void request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/token": {
      "post": {
        "operationId": "createToken",
        "summary": "Tokenize a card",
        "description": "Creates a token for a payment card to be used for recurring or future payments.",
        "tags": ["Tokenization"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid token request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PaymentRequest": {
        "type": "object",
        "required": ["profile_id", "tran_type", "tran_class", "cart_id", "cart_description", "cart_currency", "cart_amount"],
        "properties": {
          "profile_id": {
            "type": "integer",
            "description": "Merchant profile ID"
          },
          "tran_type": {
            "type": "string",
            "enum": ["sale", "auth", "register"],
            "description": "Transaction type"
          },
          "tran_class": {
            "type": "string",
            "enum": ["ecom", "recurring", "moto"],
            "description": "Transaction class"
          },
          "cart_id": {
            "type": "string",
            "description": "Unique cart/order identifier"
          },
          "cart_description": {
            "type": "string",
            "description": "Description of the cart/order"
          },
          "cart_currency": {
            "type": "string",
            "description": "Currency code (e.g., SAR, USD, AED)"
          },
          "cart_amount": {
            "type": "number",
            "description": "Total cart amount"
          },
          "callback": {
            "type": "string",
            "format": "uri",
            "description": "Server-to-server callback URL"
          },
          "return": {
            "type": "string",
            "format": "uri",
            "description": "URL to redirect the customer after payment"
          },
          "customer_details": {
            "$ref": "#/components/schemas/CustomerDetails"
          },
          "shipping_details": {
            "$ref": "#/components/schemas/ShippingDetails"
          },
          "hide_shipping": {
            "type": "boolean",
            "description": "Hide shipping information on payment page"
          },
          "paypage_lang": {
            "type": "string",
            "enum": ["en", "ar"],
            "description": "Payment page language"
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "tran_ref": {
            "type": "string",
            "description": "Transaction reference"
          },
          "tran_type": {
            "type": "string"
          },
          "cart_id": {
            "type": "string"
          },
          "cart_description": {
            "type": "string"
          },
          "cart_currency": {
            "type": "string"
          },
          "cart_amount": {
            "type": "string"
          },
          "redirect_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to redirect the customer to the payment page"
          },
          "serviceId": {
            "type": "integer"
          },
          "trace": {
            "type": "string"
          }
        }
      },
      "TransactionQueryRequest": {
        "type": "object",
        "required": ["profile_id", "tran_ref"],
        "properties": {
          "profile_id": {
            "type": "integer",
            "description": "Merchant profile ID"
          },
          "tran_ref": {
            "type": "string",
            "description": "Transaction reference to query"
          }
        }
      },
      "TransactionResponse": {
        "type": "object",
        "properties": {
          "tran_ref": {
            "type": "string"
          },
          "tran_type": {
            "type": "string"
          },
          "cart_id": {
            "type": "string"
          },
          "cart_currency": {
            "type": "string"
          },
          "cart_amount": {
            "type": "string"
          },
          "payment_result": {
            "$ref": "#/components/schemas/PaymentResult"
          },
          "payment_info": {
            "$ref": "#/components/schemas/PaymentInfo"
          },
          "customer_details": {
            "$ref": "#/components/schemas/CustomerDetails"
          }
        }
      },
      "RefundRequest": {
        "type": "object",
        "required": ["profile_id", "tran_type", "tran_class", "cart_id", "cart_description", "cart_currency", "cart_amount", "tran_ref"],
        "properties": {
          "profile_id": {
            "type": "integer"
          },
          "tran_type": {
            "type": "string",
            "enum": ["refund"]
          },
          "tran_class": {
            "type": "string",
            "enum": ["ecom"]
          },
          "cart_id": {
            "type": "string"
          },
          "cart_description": {
            "type": "string"
          },
          "cart_currency": {
            "type": "string"
          },
          "cart_amount": {
            "type": "number",
            "description": "Amount to refund"
          },
          "tran_ref": {
            "type": "string",
            "description": "Original transaction reference to refund"
          }
        }
      },
      "RefundResponse": {
        "type": "object",
        "properties": {
          "tran_ref": {
            "type": "string"
          },
          "tran_type": {
            "type": "string"
          },
          "cart_id": {
            "type": "string"
          },
          "cart_amount": {
            "type": "string"
          },
          "payment_result": {
            "$ref": "#/components/schemas/PaymentResult"
          }
        }
      },
      "CaptureRequest": {
        "type": "object",
        "required": ["profile_id", "tran_type", "tran_class", "cart_id", "cart_description", "cart_currency", "cart_amount", "tran_ref"],
        "properties": {
          "profile_id": {
            "type": "integer"
          },
          "tran_type": {
            "type": "string",
            "enum": ["capture"]
          },
          "tran_class": {
            "type": "string",
            "enum": ["ecom"]
          },
          "cart_id": {
            "type": "string"
          },
          "cart_description": {
            "type": "string"
          },
          "cart_currency": {
            "type": "string"
          },
          "cart_amount": {
            "type": "number"
          },
          "tran_ref": {
            "type": "string",
            "description": "Authorization transaction reference"
          }
        }
      },
      "VoidRequest": {
        "type": "object",
        "required": ["profile_id", "tran_type", "tran_class", "cart_id", "cart_description", "cart_currency", "cart_amount", "tran_ref"],
        "properties": {
          "profile_id": {
            "type": "integer"
          },
          "tran_type": {
            "type": "string",
            "enum": ["void"]
          },
          "tran_class": {
            "type": "string",
            "enum": ["ecom"]
          },
          "cart_id": {
            "type": "string"
          },
          "cart_description": {
            "type": "string"
          },
          "cart_currency": {
            "type": "string"
          },
          "cart_amount": {
            "type": "number"
          },
          "tran_ref": {
            "type": "string",
            "description": "Authorization transaction reference to void"
          }
        }
      },
      "TokenRequest": {
        "type": "object",
        "required": ["profile_id", "tran_type", "tran_class", "cart_id", "cart_description", "cart_currency", "cart_amount"],
        "properties": {
          "profile_id": {
            "type": "integer"
          },
          "tran_type": {
            "type": "string",
            "enum": ["register"]
          },
          "tran_class": {
            "type": "string",
            "enum": ["ecom"]
          },
          "cart_id": {
            "type": "string"
          },
          "cart_description": {
            "type": "string"
          },
          "cart_currency": {
            "type": "string"
          },
          "cart_amount": {
            "type": "number"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "tran_ref": {
            "type": "string"
          },
          "token": {
            "type": "string",
            "description": "Card token for future payments"
          },
          "payment_result": {
            "$ref": "#/components/schemas/PaymentResult"
          }
        }
      },
      "CustomerDetails": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "street1": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code"
          },
          "zip": {
            "type": "string"
          },
          "ip": {
            "type": "string",
            "description": "Customer IP address"
          }
        }
      },
      "ShippingDetails": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "street1": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          }
        }
      },
      "PaymentResult": {
        "type": "object",
        "properties": {
          "response_status": {
            "type": "string",
            "enum": ["A", "H", "P", "V", "E", "D"],
            "description": "A=Authorized, H=Hold, P=Pending, V=Voided, E=Error, D=Declined"
          },
          "response_code": {
            "type": "string"
          },
          "response_message": {
            "type": "string"
          },
          "transaction_time": {
            "type": "string"
          }
        }
      },
      "PaymentInfo": {
        "type": "object",
        "properties": {
          "card_type": {
            "type": "string"
          },
          "card_scheme": {
            "type": "string"
          },
          "payment_description": {
            "type": "string"
          },
          "expiryMonth": {
            "type": "integer"
          },
          "expiryYear": {
            "type": "integer"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          },
          "trace": {
            "type": "string",
            "description": "Trace ID for debugging"
          }
        }
      }
    },
    "securitySchemes": {
      "serverKey": {
        "type": "apiKey",
        "in": "header",
        "name": "authorization",
        "description": "Server key provided by PayTabs (format: SBJN...)"
      }
    }
  },
  "security": [
    {
      "serverKey": []
    }
  ]
}