  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://accounts.snapchat.com/login/oauth2/authorize",
            "tokenUrl": "https://accounts.snapchat.com/login/oauth2/access_token",
            "scopes": {
              "snapchat-marketing-api": "Access Snapchat Marketing API"
            }
          }
        }
      }
    },
    "schemas": {
      "RequestStatus": {
        "type": "object",
        "properties": {
