{
  "openapi": "3.0.3",
  "info": {
    "title": "Spendesk API",
    "version": "1.0.0",
    "description": "Spendesk public API for managing spend data, suppliers, users, purchase orders, analytical fields, webhooks, and accounting exports.",
    "x-jentic-source-url": "https://developer.spendesk.com"
  },
  "servers": [
    {
      "url": "https://api.spendesk.com/v1",
      "description": "Spendesk Production API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "OAuth2 token management"
    },
    {
      "name": "Spend Data",
      "description": "Payables, settlements, wallet, and bank fees"
    },
    {
      "name": "Analytical",
      "description": "Analytical fields, expense categories, and cost centers"
    },
    {
      "name": "Suppliers",
      "description": "Supplier management"
    },
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Webhooks",
      "description": "Webhook subscription management"
    },
    {
      "name": "Purchase Orders",
      "description": "Purchase order management"
    },
    {
      "name": "Accounting",
      "description": "Accounting journal exports (experimental)"
    }
  ],
  "paths": {
    "/auth/token": {
      "post": {
        "operationId": "createauthtoken",
        "summary": "Create access token",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  }
                },
                "required": [
                  "grant_type",
                  "client_id",
                  "client_secret"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/settlements": {
      "get": {
        "operationId": "listsettlements",
        "summary": "Retrieve settlement records",
        "tags": [
          "Spend Data"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Settlements retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SettlementsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/settlements/state": {
      "put": {
        "operationId": "updatesettlementstate",
        "summary": "Update settlement status",
        "tags": [
          "Spend Data"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "state": {
                    "type": "string"
                  }
                },
                "required": [
                  "ids",
                  "state"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settlement state updated"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
