{
  "openapi": "3.0.3",
  "info": {
    "title": "Bullhorn Resume Parsing API",
    "version": "1.0.0",
    "description": "Bullhorn REST API for parsing resumes, creating candidates, managing education, work history, skills, and file attachments.",
    "x-jentic-source-url": "https://bullhorn.github.io/Resume-Parsing/"
  },
  "servers": [
    {
      "url": "https://rest.bullhornstaffing.com/rest-services/{corpToken}",
      "variables": {
        "corpToken": {
          "default": "CORP_TOKEN",
          "description": "Corporation token obtained after authentication"
        }
      }
    }
  ],
  "paths": {
    "/resume/parseToCandidate": {
      "post": {
        "operationId": "parseResumeToCandidate",
        "summary": "Parse a resume file into candidate data",
        "tags": ["Resume"],
        "parameters": [
          {
            "name": "format",
            "in": "query",
            "required": true,
            "description": "Resume file format (e.g., DOC)",
            "schema": { "type": "string" }
          },
          {
            "name": "populateDescription",
            "in": "query",
            "description": "Populate description field with resume content. Values: text, html",
            "schema": { "type": "string", "enum": ["text", "html"] }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Resume file to parse"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parsed candidate data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ParsedResume"
                }
              }
            }
          },
          "400": { "description": "Bad request - invalid file or format" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/entity/Candidate": {
      "put": {
        "operationId": "createCandidate",
        "summary": "Create a new candidate entity",
        "tags": ["Candidates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CandidateInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Candidate created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChangeResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/entity/Candidate/{candidateId}": {
      "get": {
        "operationId": "getCandidate",
        "summary": "Retrieve a candidate entity",
        "tags": ["Candidates"],
        "parameters": [
          { "name": "candidateId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "fields", "in": "query", "description": "Comma-separated list of fields to return", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Candidate data",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Candidate not found" }
        }
      }
    },
    "/entity/CandidateEducation": {
      "put": {
        "operationId": "createCandidateEducation",
        "summary": "Create a candidate education record",
        "tags": ["Education"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EducationInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Education created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChangeResponse" } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/entity/CandidateWorkHistory": {
      "put": {
        "operationId": "createCandidateWorkHistory",
        "summary": "Create a candidate work history record",
        "tags": ["Work History"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WorkHistoryInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Work history created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChangeResponse" } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/entity/CandidateWorkHistory/{workHistoryId}": {
      "get": {
        "operationId": "getCandidateWorkHistory",
        "summary": "Retrieve a work history record",
        "tags": ["Work History"],
        "parameters": [
          { "name": "workHistoryId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "fields", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Work history data",
            "content": { "application/json": { "schema": { "type": "object" } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/entity/Candidate/{candidateId}/primarySkills/{skillIds}": {
      "put": {
        "operationId": "addPrimarySkills",
        "summary": "Add primary skills to a candidate",
        "tags": ["Skills"],
        "parameters": [
          { "name": "candidateId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "skillIds", "in": "path", "required": true, "description": "Comma-separated skill IDs", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Skills added",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChangeResponse" } } }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/options/Skill": {
      "get": {
        "operationId": "getSkillOptions",
        "summary": "Get available skill options",
        "tags": ["Skills"],
        "responses": {
          "200": {
            "description": "List of skill entities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "value": { "type": "integer" },
                      "label": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/file/Candidate/{candidateId}/raw": {
      "put": {
        "operationId": "attachResumeFile",
        "summary": "Attach a resume file to a candidate",
        "tags": ["Files"],
        "parameters": [
          { "name": "candidateId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "externalID", "in": "query", "description": "External identifier for the file", "schema": { "type": "string" } },
          { "name": "fileType", "in": "query", "description": "Type of file being attached", "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File attached",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "fileId": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/entityFiles/Candidate/{candidateId}": {
      "get": {
        "operationId": "getCandidateFiles",
        "summary": "Retrieve files attached to a candidate",
        "tags": ["Files"],
        "parameters": [
          { "name": "candidateId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Entity files list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "EntityFiles": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer" },
                          "type": { "type": "string" },
                          "name": { "type": "string" },
                          "contentType": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ParsedResume": {
        "type": "object",
        "properties": {
          "candidate": { "type": "object" },
          "candidateEducation": {
            "type": "array",
            "items": { "type": "object" }
          },
          "candidateWorkHistory": {
            "type": "array",
            "items": { "type": "object" }
          },
          "skillList": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "CandidateInput": {
        "type": "object",
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "address": { "type": "object" }
        }
      },
      "EducationInput": {
        "type": "object",
        "properties": {
          "school": { "type": "string" },
          "degree": { "type": "string" },
          "major": { "type": "string" },
          "gpa": { "type": "number" },
          "startDate": { "type": "integer", "description": "Unix timestamp in milliseconds" },
          "endDate": { "type": "integer", "description": "Unix timestamp in milliseconds" },
          "candidate": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" }
            }
          }
        }
      },
      "WorkHistoryInput": {
        "type": "object",
        "properties": {
          "companyName": { "type": "string" },
          "title": { "type": "string" },
          "startDate": { "type": "integer", "description": "Unix timestamp in milliseconds" },
          "endDate": { "type": "integer", "description": "Unix timestamp in milliseconds" },
          "comments": { "type": "string" },
          "candidate": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" }
            }
          }
        }
      },
      "ChangeResponse": {
        "type": "object",
        "properties": {
          "changedEntityType": { "type": "string" },
          "changedEntityId": { "type": "integer" },
          "changeType": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://auth.bullhornstaffing.com/oauth/authorize",
            "tokenUrl": "https://auth.bullhornstaffing.com/oauth/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    { "oauth2": [] }
  ]
}