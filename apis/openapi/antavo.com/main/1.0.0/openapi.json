  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key for authentication"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "EventRequest": {
        "type": "object",
        "required": [
          "customer",
          "action",
          "data"
        ],
        "properties": {
          "customer": {
            "type": "string",
            "description": "Unique customer identifier"
          },
          "external_id": {
            "type": "string",
            "description": "External system identifier"
          },
          "action": {
            "type": "string",
            "description": "Event type (e.g., point_add, checkout)"
          },
          "account": {
            "type": "string",
            "description": "Account ID for multi-account setups"
          },
          "data": {
            "type": "object",
            "description": "Event-specific attributes",
            "properties": {
              "points": {
                "type": "integer"
              },
              "effective_timestamp": {
                "type": "number"
              },
              "transaction_id": {
                "type": "string"
