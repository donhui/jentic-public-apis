  "paths": {
    "/docapost-folder/update": {
      "post": {
        "parameters": [
          {
            "description": "Postal code",
            "in": "query",
            "name": "update",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "errors": {
                      "description": "Error messages",
                      "example": [
                        "Code postal mal formatté",
                        "Civilité non valide"
                      ],
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Bad request"
          }
        },
        "tags": [
          "docapost-folder"
        ],
        "description": "Update progress of folder (signing, all signed, canceled)",
        "operationId": "post-docapost-folder-update",
        "summary": "Update progress of folder (signing, all signed, canceled)"
      }
    },
    "/sales": {
      "post": {
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "errors": {
                      "description": "Error messages",
                      "example": [
                        "Code postal mal formatté",
                        "Civilité non valide"
                      ],
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Bad request"
          }
        },
        "tags": [
          "sales"
        ],
        "description": "Create a new sale",
        "operationId": "post-sales",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaleMandateModel"
              }
            }
          },
          "description": "Sale data",
          "required": true
        },
        "summary": "Create a new sale"
      }
    }
  },
  "components": {
