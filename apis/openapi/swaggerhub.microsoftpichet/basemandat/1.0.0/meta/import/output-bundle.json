          "jobtitle": {
            "description": "Jobtitle of the mandate",
            "type": "string"
          },
          "lastname": {
            "description": "Lastname of the mandate",
            "type": "string"
          },
          "mobile_phone": {
            "description": "Mobile phone of the mandate",
            "type": "string"
          },
          "street1": {
            "description": "Street1 of the mandate",
            "type": "string"
          },
          "street2": {
            "description": "Street2 of the mandate",
            "type": "string"
          },
          "street3": {
            "description": "Street3 of the mandate",
            "type": "string"
          },
