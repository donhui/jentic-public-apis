          "program": {
            "$ref": "#/components/schemas/ProgramMandateModel"
          }
        },
        "type": "object"
      },
      "TypeLotMandateModel": {
        "properties": {
          "code": {
            "description": "Code of the type of lot",
            "type": "string"
          },
          "name": {
            "description": "Name of the type of lot",
            "type": "string"
          },
          "room_count": {
            "description": "Number of rooms",
            "format": "int32",
            "type": "integer"
          },
          "type_grouping": {
            "description": "Group of type",
