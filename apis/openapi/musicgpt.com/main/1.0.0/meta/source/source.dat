{
  "openapi": "3.0.3",
  "info": {
    "title": "MusicGPT API",
    "description": "MusicGPT is an AI-powered music and audio generation platform that creates music, converts voices, and processes audio files.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.musicgpt.com/api-documentation/index/introduction"
  },
  "servers": [
    {
      "url": "https://api.musicgpt.com/api/public",
      "description": "MusicGPT API Server"
    }
  ],
  "tags": [
    {
      "name": "Music Generation",
      "description": "AI music generation endpoints"
    },
    {
      "name": "Voice Processing",
      "description": "Voice changing and cover song endpoints"
    },
    {
      "name": "Audio Processing",
      "description": "Audio manipulation and conversion endpoints"
    },
    {
      "name": "Text to Speech",
      "description": "Text to speech conversion"
    },
    {
      "name": "Utilities",
      "description": "Helper and utility endpoints"
    },
    {
      "name": "Streaming",
      "description": "Streaming conversion endpoints"
    }
  ],
  "paths": {
    "/v1/MusicAI": {
      "post": {
        "tags": [
          "Music Generation"
        ],
        "summary": "Music AI",
        "description": "Create music powered by AI using just a prompt, lyrics, or a defined music style.",
        "operationId": "createMusicV1",
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "Text prompt describing the desired output"
                  },
                  "lyrics": {
                    "type": "string",
                    "description": "Optional lyrics for the generation"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Audio file to process"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the audio file to process"
                  },
                  "voice_id": {
                    "type": "string",
                    "description": "Voice ID for voice conversion"
                  },
                  "webhook_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Webhook URL for async callback"
                  }
                }
              }
            }
          }
        }
      }
    },
