    "/public/events": {
      "get": {
        "operationId": "listEvents",
        "summary": "List events",
        "description": "Retrieve organization event logs with optional date filtering.",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Start date (ISO 8601)",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "description": "End date (ISO 8601)",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "actingUserId",
            "in": "query",
            "required": false,
            "description": "Filter by acting user ID",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "itemId",
            "in": "query",
            "required": false,
            "description": "Filter by item ID",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "continuationToken",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
