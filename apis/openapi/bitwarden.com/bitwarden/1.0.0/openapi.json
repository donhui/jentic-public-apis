  "components": {
    "securitySchemes": {
      "OAuth2ClientCredentials": {
        "type": "oauth2",
        "description": "OAuth2 client credentials flow. Obtain tokens from the identity server.",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://identity.bitwarden.com/connect/token",
            "scopes": {
              "api.organization": "Full access to the organization API"
            }
          }
        }
      }
    },
    "schemas": {
      "Member": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "member" },
          "id": { "type": "string", "format": "uuid" },
          "userId": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "twoFactorEnabled": { "type": "boolean" },
          "status": {
            "type": "integer",
            "description": "0=Invited, 1=Accepted, 2=Confirmed, -1=Revoked"
          },
          "type": {
            "type": "integer",
            "description": "0=Owner, 1=Admin, 2=User, 3=Manager, 4=Custom"
          },
          "accessAll": { "type": "boolean" },
          "externalId": { "type": "string", "nullable": true },
          "resetPasswordEnrolled": { "type": "boolean" },
          "collections": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CollectionAccess" }
          }
        }
      },
      "MemberCreateRequest": {
        "type": "object",
        "required": ["email", "type", "accessAll"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "type": { "type": "integer" },
          "accessAll": { "type": "boolean" },
          "externalId": { "type": "string", "nullable": true },
          "collections": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CollectionAccess" }
          }
        }
      },
      "MemberUpdateRequest": {
        "type": "object",
        "required": ["type", "accessAll"],
        "properties": {
          "type": { "type": "integer" },
          "accessAll": { "type": "boolean" },
          "externalId": { "type": "string", "nullable": true },
          "collections": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CollectionAccess" }
          }
        }
      },
      "MemberListResponse": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "list" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Member" }
          },
          "continuationToken": { "type": "string", "nullable": true }
        }
      },
      "Collection": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "collection" },
          "id": { "type": "string", "format": "uuid" },
          "groups": {
            "type": "array",
