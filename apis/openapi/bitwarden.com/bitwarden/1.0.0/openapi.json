{
  "openapi": "3.0.3",
  "info": {
    "title": "Bitwarden Public API",
    "description": "The Bitwarden Public API provides organizations with a suite of tools for managing members, collections, groups, event logs, and policies. Available for Enterprise and Teams organizations. Uses OAuth2 client credentials for authentication.",
    "version": "1.0.0",
    "contact": {
      "name": "Bitwarden Support",
      "url": "https://bitwarden.com"
    },
    "x-jentic-source-url": "https://bitwarden.com/help/api/"
  },
  "servers": [
    {
      "url": "https://api.bitwarden.com",
      "description": "Bitwarden Cloud (US)"
    },
    {
      "url": "https://api.bitwarden.eu",
      "description": "Bitwarden Cloud (EU)"
    }
  ],
  "security": [
    {
      "OAuth2ClientCredentials": []
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "OAuth2 token management" },
    { "name": "Members", "description": "Organization member management" },
    { "name": "Collections", "description": "Organization collection management" },
    { "name": "Groups", "description": "Organization group management" },
    { "name": "Events", "description": "Organization event logs" },
    { "name": "Policies", "description": "Organization policy management" }
  ],
  "paths": {
    "/public/members": {
      "get": {
        "operationId": "listMembers",
        "summary": "List members",
        "description": "Retrieve a list of organization members. Results exceeding 50 items use pagination via continuationToken.",
        "tags": ["Members"],
        "parameters": [
          {
            "name": "continuationToken",
            "in": "query",
            "required": false,
            "description": "Token for retrieving the next page of results",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of members",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MemberListResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      },
      "post": {
        "operationId": "createMember",
        "summary": "Create a member",
        "description": "Invite a new member to the organization.",
        "tags": ["Members"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemberCreateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Member created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Member"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/public/members/{id}": {
      "get": {
        "operationId": "getMember",
        "summary": "Get a member",
        "description": "Retrieve a specific organization member by ID.",
        "tags": ["Members"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Member GUID",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Member details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Member"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      },
      "put": {
        "operationId": "updateMember",
        "summary": "Update a member",
        "description": "Update an existing organization member.",
        "tags": ["Members"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MemberUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Member updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Member"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      },
      "delete": {
        "operationId": "deleteMember",
        "summary": "Delete a member",
        "description": "Remove a member from the organization.",
        "tags": ["Members"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": { "description": "Member deleted" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
