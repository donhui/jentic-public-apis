{
  "openapi": "3.0.3",
  "info": {
    "title": "Eversend Payments API",
    "version": "1.0",
    "description": "Payments infrastructure to fuel your global growth. Eversend provides APIs for wallets, exchanges, payouts, collections, beneficiaries, transactions, cryptocurrency, and virtual debit cards across Africa.",
    "x-jentic-source-url": "https://eversend.readme.io/"
  },
  "servers": [
    {
      "url": "https://api.eversend.co/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Token generation and authentication"
    },
    {
      "name": "Wallets",
      "description": "Wallet management operations"
    },
    {
      "name": "Accounts",
      "description": "Account profile operations"
    },
    {
      "name": "Exchange",
      "description": "Currency exchange operations"
    },
    {
      "name": "Beneficiaries",
      "description": "Beneficiary management"
    },
    {
      "name": "Payouts",
      "description": "Payout operations to mobile money and bank accounts"
    },
    {
      "name": "Collections",
      "description": "Payment collection operations"
    },
    {
      "name": "Transactions",
      "description": "Transaction history and details"
    },
    {
      "name": "Cryptocurrency",
      "description": "Crypto operations and addresses"
    },
    {
      "name": "Cards",
      "description": "Virtual debit card management"
    }
  ],
  "paths": {
    "/auth/token": {
      "get": {
        "operationId": "generateToken",
        "summary": "Generate access token",
        "description": "Generate an access token using client credentials",
        "tags": ["Authentication"],
        "security": [],
        "parameters": [
          {
            "name": "clientId",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client ID credential"
          },
          {
            "name": "clientSecret",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client secret credential"
          }
        ],
        "responses": {
          "200": {
            "description": "Token generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid credentials"
          }
        }
      }
    },
    "/wallets": {
      "get": {
        "operationId": "listWallets",
        "summary": "Retrieve all wallets",
        "description": "Get a list of all wallets for the authenticated user",
        "tags": ["Wallets"],
        "responses": {
          "200": {
            "description": "Wallets retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Wallet"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/wallets/{walletId}": {
      "get": {
        "operationId": "getWallet",
        "summary": "Get specific wallet",
        "description": "Retrieve details of a specific wallet",
        "tags": ["Wallets"],
        "parameters": [
          {
            "name": "walletId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Wallet ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Wallet retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Wallet"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Wallet not found"
          }
        }
      }
    },
    "/wallets/activate": {
      "post": {
        "operationId": "activateWallet",
        "summary": "Activate a wallet",
        "description": "Activate a wallet for use",
        "tags": ["Wallets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "walletId": {
                    "type": "string"
                  }
                },
                "required": ["walletId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Wallet activated successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/wallets/deactivate": {
      "post": {
        "operationId": "deactivateWallet",
        "summary": "Deactivate a wallet",
        "description": "Deactivate a wallet",
        "tags": ["Wallets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "walletId": {
                    "type": "string"
                  }
                },
                "required": ["walletId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Wallet deactivated successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/account": {
      "get": {
        "operationId": "getAccount",
        "summary": "Retrieve account profile",
        "description": "Get account profile information",
        "tags": ["Accounts"],
        "responses": {
          "200": {
            "description": "Account profile retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/exchanges/quotation": {
      "post": {
        "operationId": "createExchangeQuotation",
        "summary": "Create currency exchange quotation",
        "description": "Generate a quotation for currency exchange",
        "tags": ["Exchange"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExchangeQuotationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quotation created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExchangeQuotation"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/exchanges": {
      "post": {
        "operationId": "executeExchange",
        "summary": "Execute currency exchange",
        "description": "Execute a currency exchange transaction",
        "tags": ["Exchange"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExchangeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Exchange executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExchangeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/beneficiaries": {
      "get": {
        "operationId": "listBeneficiaries",
        "summary": "List all beneficiaries",
        "description": "Retrieve a list of all beneficiaries with optional filtering",
        "tags": ["Beneficiaries"],
        "responses": {
          "200": {
            "description": "Beneficiaries retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Beneficiary"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createBeneficiaries",
        "summary": "Create beneficiaries",
        "description": "Create one or more beneficiaries",
        "tags": ["Beneficiaries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBeneficiaryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Beneficiaries created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Beneficiary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/beneficiaries/{beneficiaryId}": {
      "get": {
        "operationId": "getBeneficiary",
        "summary": "Get specific beneficiary",
        "description": "Retrieve details of a specific beneficiary",
        "tags": ["Beneficiaries"],
        "parameters": [
          {
            "name": "beneficiaryId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Beneficiary ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Beneficiary retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Beneficiary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Beneficiary not found"
          }
        }
      },
      "put": {
        "operationId": "updateBeneficiary",
        "summary": "Update beneficiary",
        "description": "Update beneficiary information",
        "tags": ["Beneficiaries"],
        "parameters": [
          {
            "name": "beneficiaryId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Beneficiary ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBeneficiaryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Beneficiary updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Beneficiary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Beneficiary not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteBeneficiary",
        "summary": "Remove beneficiary",
        "description": "Delete a beneficiary from the system",
        "tags": ["Beneficiaries"],
        "parameters": [
          {
            "name": "beneficiaryId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Beneficiary ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Beneficiary deleted successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Beneficiary not found"
          }
        }
      }
    },
    "/beneficiaries/accounts/banks": {
      "post": {
        "operationId": "validateBankDetails",
        "summary": "Validate bank account details",
        "description": "Validate bank account details before creating a beneficiary",
        "tags": ["Beneficiaries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountNumber": {
                    "type": "string"
                  },
                  "bankCode": {
                    "type": "string"
                  },
                  "country": {
                    "type": "string"
                  }
                },
                "required": ["accountNumber", "bankCode", "country"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bank details validated successfully"
          },
          "400": {
            "description": "Bad request - Invalid bank details"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/beneficiaries/accounts/eversend": {
      "post": {
        "operationId": "checkEversendAccount",
        "summary": "Check Eversend account",
        "description": "Verify if an Eversend account exists",
        "tags": ["Beneficiaries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "phoneNumber": {
                    "type": "string"
                  }
                },
                "required": ["phoneNumber"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account check completed"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/payouts/countries": {
      "get": {
        "operationId": "listPayoutCountries",
        "summary": "List supported countries",
        "description": "Get list of countries supported for payouts",
        "tags": ["Payouts"],
        "responses": {
          "200": {
            "description": "Countries retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "code": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/payouts/banks/{country}": {
      "get": {
        "operationId": "listCountryBanks",
        "summary": "Get banks for country",
        "description": "Retrieve list of banks for a specific country",
        "tags": ["Payouts"],
        "parameters": [
          {
            "name": "country",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Country code"
          }
        ],
        "responses": {
          "200": {
            "description": "Banks retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "code": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/payouts/quotation": {
      "post": {
        "operationId": "createPayoutQuotation",
        "summary": "Create payout quotation",
        "description": "Generate a quotation for mobile money or bank payout",
        "tags": ["Payouts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PayoutQuotationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quotation created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PayoutQuotation"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/payouts": {
      "post": {
        "operationId": "executePayout",
        "summary": "Execute payout",
        "description": "Execute a payout to mobile money, bank, or beneficiary",
        "tags": ["Payouts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PayoutRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payout executed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PayoutResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/payouts/quotation/eversend": {
      "post": {
        "operationId": "createEversendPayoutQuotation",
        "summary": "Create Eversend payout quotation",
        "description": "Generate a quotation for Eversend-to-Eversend transfer",
        "tags": ["Payouts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "number"
                  },
                  "currency": {
                    "type": "string"
                  }
                },
                "required": ["amount", "currency"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quotation created successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/payouts/eversend": {
      "post": {
        "operationId": "executeEversendPayout",
        "summary": "Execute Eversend transfer",
        "description": "Send funds via Eversend-to-Eversend transfer",
        "tags": ["Payouts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "number"
                  },
                  "currency": {
                    "type": "string"
                  },
                  "recipient": {
                    "type": "string"
                  }
                },
                "required": ["amount", "currency", "recipient"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer executed successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/collections/fees": {
      "post": {
        "operationId": "calculateCollectionFees",
        "summary": "Calculate collection fees",
        "description": "Calculate charges for a collection transaction",
        "tags": ["Collections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "number"
                  },
                  "currency": {
                    "type": "string"
                  },
                  "method": {
                    "type": "string"
                  }
                },
                "required": ["amount", "currency", "method"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fees calculated successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/collections/otp": {
      "post": {
        "operationId": "requestCollectionOTP",
        "summary": "Request OTP for collection",
        "description": "Request an OTP for mobile money collection",
