          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/collections/sendOTP": {
      "post": {
        "operationId": "sendOTPValidation",
        "summary": "Validate GHS transaction with OTP",
        "description": "Send OTP to validate GHS mobile money transaction",
