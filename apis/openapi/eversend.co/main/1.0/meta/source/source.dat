  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token obtained from /auth/token endpoint"
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "expiresIn": {
            "type": "integer"
          }
        }
      },
      "Wallet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          },
          "balance": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": ["active", "inactive"]
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ExchangeQuotationRequest": {
        "type": "object",
        "properties": {
          "fromCurrency": {
            "type": "string"
          },
          "toCurrency": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          }
        },
        "required": ["fromCurrency", "toCurrency", "amount"]
      },
      "ExchangeQuotation": {
        "type": "object",
        "properties": {
          "quotationId": {
            "type": "string"
          },
          "rate": {
            "type": "number"
          },
          "fee": {
            "type": "number"
          },
          "amountToReceive": {
            "type": "number"
          }
        }
      },
      "ExchangeRequest": {
        "type": "object",
        "properties": {
          "quotationId": {
            "type": "string"
          }
        },
        "required": ["quotationId"]
      },
      "ExchangeResponse": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Beneficiary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "CreateBeneficiaryRequest": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        },
        "required": ["firstName", "lastName", "phoneNumber", "country"]
      },
      "UpdateBeneficiaryRequest": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          }
        }
      },
      "PayoutQuotationRequest": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "destinationCountry": {
            "type": "string"
          },
          "destinationCurrency": {
            "type": "string"
          }
        },
        "required": ["amount", "currency", "destinationCountry", "destinationCurrency"]
      },
      "PayoutQuotation": {
        "type": "object",
        "properties": {
          "quotationId": {
            "type": "string"
          },
          "rate": {
            "type": "number"
          },
          "fee": {
            "type": "number"
          },
          "amountToReceive": {
            "type": "number"
          }
        }
      },
      "PayoutRequest": {
        "type": "object",
        "properties": {
          "quotationId": {
            "type": "string"
          },
          "beneficiaryId": {
            "type": "string"
          }
        },
        "required": ["quotationId"]
      },
      "PayoutResponse": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "MomoCollectionRequest": {
        "type": "object",
        "properties": {
          "phoneNumber": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "otp": {
            "type": "string"
          }
        },
        "required": ["phoneNumber", "amount", "currency"]
      },
      "CollectionResponse": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CryptoAddress": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "coin": {
            "type": "string"
          },
          "chain": {
            "type": "string"
          }
        }
      },
      "CryptoTransaction": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "coin": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CardUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phoneNumber": {
            "type": "string"
          }
        }
      },
      "CreateCardUserRequest": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
