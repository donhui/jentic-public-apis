                    "type": "string"
                  }
                },
                "required": ["transactionId", "otp"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP validated successfully"
          },
          "400": {
            "description": "Bad request - Invalid OTP"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/collections/bankAccounts": {
      "post": {
        "operationId": "collectFromBankAccount",
        "summary": "Initiate NGN bank collection",
        "description": "Initiate a collection from Nigerian bank account",
        "tags": ["Collections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountNumber": {
                    "type": "string"
                  },
                  "bankCode": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number"
                  }
                },
                "required": ["accountNumber", "bankCode", "amount"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collection initiated successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/collections/tempVirtualAccounts": {
      "post": {
        "operationId": "createTempVirtualAccount",
        "summary": "Create temporary virtual account",
        "description": "Create a temporary NGN virtual account for collection",
        "tags": ["Collections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "number"
                  },
                  "reference": {
                    "type": "string"
                  }
                },
                "required": ["amount", "reference"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Virtual account created successfully",
            "content": {
