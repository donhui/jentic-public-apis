    "/tangent/{expression}": {
      "get": {
        "operationId": "findTangent",
        "summary": "Find the tangent line",
        "description": "Finds the tangent line of a function at a given x value. Expression format: c|f(x) where c is the x value and f(x) is the function.",
        "tags": [
          "Math Operations"
        ],
        "parameters": [
          {
            "name": "expression",
            "in": "path",
            "required": true,
            "description": "URL-encoded expression in format c|f(x) where c is the x value",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful result",
