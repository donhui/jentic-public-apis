{
  "openapi": "3.0.3",
  "info": {
    "title": "Newton API",
    "version": "2.0.0",
    "description": "A micro micro-service for advanced math. Newton performs numerical calculations and symbolic math parsing including simplification, factoring, derivatives, integrals, zeroes, tangent lines, area under curves, and trigonometric operations.",
    "x-jentic-source-url": "https://newton.vercel.app"
  },
  "servers": [
    {
      "url": "https://newton.vercel.app/api/v2"
    }
  ],
  "paths": {
    "/simplify/{expression}": {
      "get": {
        "operationId": "simplifyExpression",
        "summary": "Simplify a mathematical expression",
        "description": "Simplifies a given mathematical expression.",
        "tags": [
          "Math Operations"
        ],
        "parameters": [
          {
            "name": "expression",
            "in": "path",
            "required": true,
            "description": "URL-encoded mathematical expression to simplify",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MathResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid expression"
          }
        }
      }
    },
    "/factor/{expression}": {
