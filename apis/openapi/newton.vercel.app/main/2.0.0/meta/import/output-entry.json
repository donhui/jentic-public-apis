    },
    "/area/{expression}": {
      "get": {
        "operationId": "findAreaUnderCurve",
        "summary": "Find area under a curve",
        "description": "Computes the area under a curve between two x values. Expression format: c:d|f(x) where c is start, d is end, and f(x) is the function.",
        "tags": [
          "Math Operations"
        ],
        "parameters": [
          {
            "name": "expression",
            "in": "path",
            "required": true,
