{
    "openapi": "3.0.0",
    "info": {
        "description": "API para el manejo de apuestas de futbol",
        "version": "1.0.0",
        "title": "Apuestas API",
        "contact": {
            "email": "davidcardonalondono@gmail.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/dacardona1/ApuestasAPI/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "administradores",
            "description": "opciones para admins"
        },
        {
            "name": "apostadores",
            "description": "operaciones para apostadores"
        },
        {
            "name": "invitados",
            "description": "operaciones para invitados"
        }
    ],
    "paths": {
        "/torneo/{idTorneo}": {
            "get": {
                "tags": [
                    "administradores",
                    "apostadores"
                ],
                "summary": "busca un torneo",
                "operationId": "buscarTorneo",
                "description": "Enviando un ID valido devuelve la informacion del torneo\n",
                "parameters": [
                    {
                        "in": "path",
                        "name": "idTorneo",
                        "description": "id del torneo a buscar",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "devolver el resultado obtenido",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "items": {
                                        "$ref": "#/components/schemas/Torneo"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "parametro incorrecto"
                    }
                }
            },
            "post": {
                "tags": [
                    "administradores"
                ],
                "summary": "agrega un torneo nuevo",
                "operationId": "agregarTorneo",
                "description": "agrega un nuevo torneo",
                "parameters": [
                    {
                        "in": "path",
                        "name": "idTorneo",
                        "description": "id del torneo a buscar",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Torneo"
                            }
                        }
                    },
                    "description": "Torneo a agregar"
                },
                "responses": {
                    "201": {
                        "description": "torneo creado"
                    },
                    "400": {
                        "description": "objeto invalido"
                    },
                    "409": {
                        "description": "ya existe un objeto con este id"
                    }
                }
            }
        },
        "/cotejo/{idCotejo}": {
            "get": {
                "tags": [
                    "administradores",
                    "apostadores"
                ],
                "summary": "busca un cotejo",
                "operationId": "buscarCotejo",
                "description": "Enviando un ID valido devuelve la informacion del cotejo\n",
                "parameters": [
                    {
                        "in": "path",
                        "name": "idCotejo",
                        "description": "id del cotejo a buscar",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "devolver el resultado obtenido",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "items": {
                                        "$ref": "#/components/schemas/Cotejo"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "parametro incorrecto"
                    }
                }
            },
            "post": {
                "tags": [
                    "administradores"
                ],
                "summary": "agrega un cotejo nuevo",
                "operationId": "agregarCotejo",
                "description": "agrega un nuevo cotejo",
                "parameters": [
                    {
                        "in": "path",
                        "name": "idCotejo",
                        "description": "id del cotejo a buscar",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Cotejo"
                            }
                        }
                    },
                    "description": "Cotejo a agregar"
                },
                "responses": {
                    "201": {
                        "description": "cotejo creado"
                    },
                    "400": {
                        "description": "objeto invalido"
                    },
                    "409": {
                        "description": "ya existe un objeto con este id"
                    }
                }
            }
        },
        "/apuesta/{idApuesta}": {
            "get": {
                "tags": [
                    "apostadores"
                ],
                "summary": "busca una apuesta",
                "operationId": "buscarApuesta",
                "description": "Enviando un ID valido devuelve la informacion de la apuesta\n",
                "parameters": [
                    {
                        "in": "path",
                        "name": "idApuesta",
                        "description": "id de la apuesta a buscar",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "devolver el resultado obtenido",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "items": {
                                        "$ref": "#/components/schemas/Apuesta"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "parametro incorrecto"
                    }
                }
            },
            "post": {
                "tags": [
                    "administradores"
                ],
                "summary": "agrega una apuesta nueva",
                "operationId": "agregarApuesta",
                "description": "agrega un nuevo apuesta",
                "parameters": [
                    {
                        "in": "path",
                        "name": "idApuesta",
                        "description": "id de apuesta a buscar",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Apuesta"
                            }
                        }
                    },
                    "description": "apuesta a agregar"
                },
                "responses": {
                    "201": {
                        "description": "cotejo creado"
                    },
                    "400": {
                        "description": "objeto invalido"
                    },
                    "409": {
                        "description": "ya existe un objeto con este id"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/dacardona1/ApuestasAPI/1.0.0"
        }
    ],
    "components": {
        "schemas": {
            "Torneo": {
                "type": "object",
                "required": [
                    "idTorneo",
                    "nombre",
                    "fechaTorneo"
                ],
                "properties": {
                    "idTorneo": {
                        "type": "string",
                        "example": "t123"
                    },
                    "nombre": {
                        "type": "string",
                        "example": "rusia 2018"
                    },
                    "fechaTorneo": {
                        "type": "string",
                        "format": "int32",
                        "example": "2016-08-29T09:12:33.001Z"
                    }
                }
            },
            "Cotejo": {
                "type": "object",
                "required": [
                    "idCotejo",
                    "nombre",
                    "equipo1",
                    "equipo2",
                    "idTorneo"
                ],
                "properties": {
                    "idCotejo": {
                        "type": "string",
                        "example": "c123"
                    },
                    "nombre": {
                        "type": "string",
                        "example": "semifinal"
                    },
                    "equipo1": {
                        "type": "string",
                        "example": "Croacia"
                    },
                    "equipo2": {
                        "type": "string",
                        "example": "Rusia"
                    },
                    "idTorneo": {
                        "type": "string",
                        "example": "t123"
                    }
                }
            },
            "Apuesta": {
                "type": "object",
                "required": [
                    "idApuesta",
                    "idCotejo",
                    "valor"
                ],
                "properties": {
                    "idApuesta": {
                        "type": "string",
                        "example": "a123"
                    },
                    "idCotejo": {
                        "type": "string",
                        "example": "c123"
                    },
                    "valor": {
                        "type": "integer",
                        "example": 200000
                    }
                }
            }
        }
    }
}