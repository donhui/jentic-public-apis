  "openapi": "3.0.0",
  "servers": [
    {
      "description": "API para el manejo de automotora",
      "url": "https://virtserver.swaggerhub.com/dacardona1/Automotora/1.0.0"
    }
  ],
  "info": {
    "description": "API para el manejo de autos",
    "version": "1.0.0",
    "title": "Automotora API",
    "contact": {
      "email": "davidcardonalondono@gmail.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/dacardona1/Automotora/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "admins",
      "description": "Secured Admin-only calls"
    },
    {
      "name": "developers",
      "description": "Operations available to regular developers"
    },
    {
      "name": "terceros",
      "description": "Operaciones que pueden hacer terceros"
    }
  ],
  "paths": {
    "/sucursal": {
      "get": {
        "tags": [
          "terceros"
        ],
        "summary": "lista las sucursales",
        "operationId": "listSucursal",
        "description": "Lista las sucursales o una especifica\n",
        "parameters": [
          {
            "in": "query",
            "name": "searchString",
            "description": "pasar un criterio de busqueda en el string",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "search results matching criteria",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SucursalItem"
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter"
          }
        }
      },
      "post": {
        "tags": [
          "admins"
        ],
        "summary": "adiciona una nueva sucurusal",
        "operationId": "addSucursal",
        "description": "adiciona una nueva sucursal",
        "responses": {
          "201": {
            "description": "item created"
          },
          "400": {
            "description": "invalid input, object invalid"
          },
          "409": {
            "description": "an existing item already exists"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SucursalItem"
              }
            }
          },
          "description": "Sucursal item to add"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SucursalItem": {
        "type": "object",
        "required": [
          "id",
          "nombre",
          "ciudad",
          "fechaCreada"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "d290f1ee-6c54-4b01-90e6-d701748f0851"
          },
          "nombre": {
            "type": "string",
            "example": "Sucursal gran auto"
          },
          "ciudad": {
            "type": "string",
            "example": "Medellin"
          },
          "manufacturer": {
            "$ref": "#/components/schemas/Manufacturer"
          }
        }
      },
      "Manufacturer": {
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "ACME Corporation"
          },
          "homePage": {
            "type": "string",
            "format": "url",
            "example": "https://www.acme-corp.com"
          },
          "phone": {
            "type": "string",
            "example": "408-867-5309"
          }
        },
        "type": "object"
      }
    }
  }
}