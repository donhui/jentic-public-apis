      "get": {
        "summary": "Получение отчета о бонусной программе",
        "parameters": [
          {
            "name": "month",
            "in": "query",
            "description": "Месяц отчета в формате 'YYYY-MM' (например, '2023-08')",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user_id": {
                      "type": "integer",
                      "description": "id пользователя"
                    },
                    "bonus_points": {
                      "type": "integer",
                      "description": "начисленные баллы"
                    },
                    "bonus_card_number": {
                      "type": "number",
                      "description": "Номер карты"
                    },
                    "total_bookings": {
                      "type": "integer",
                      "description": "Общее количество бронирований в указанном месяце"
                    },
                    "bookings_bc": {
                      "type": "integer",
                      "description": "Количество бронирований с использованием бонусных карт"
                    },
                    "total_bonus": {
                      "type": "number",
                      "description": "Общая сумма начисленных бонусных баллов"
                    },
                    "pct_tick_bon": {
                      "type": "number",
                      "format": "float",
                      "description": "Доля стоимости билетов, оплаченных бонусными баллами (в процентах)"
                    }
                  }
                }
              }
            }
          }
        },
