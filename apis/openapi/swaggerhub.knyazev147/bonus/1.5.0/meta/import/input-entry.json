          {
            "name": "session_id",
            "in": "query",
            "description": "id сеанса",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sessions": {
                      "type": "string"
                    },
                    "sess_seats": {
                      "type": "string"
                    },
                    "sess_date_time": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "страница не найдена"
          },
          "500": {
            "description": "сервер недоступен"
          }
        },
        "tags": [
          "session"
