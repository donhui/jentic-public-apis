{
  "openapi": "3.0.0",
  "info": {
    "description": "This is the API to create a caption with Zapier",
    "version": "1.0.0",
    "title": "Create Caption API",
    "contact": {
      "email": "joshua@imagetocaption.ai"
    },
    "x-jentic-source-url": "https://app.swaggerhub.com/apis-docs/JOSHUA_18/create-caption/1.0.0"
  },
  "servers": [],
  "paths": {
    "/create-caption": {
      "post": {
        "summary": "Creates a caption based on an image input",
        "operationId": "create-caption",
        "description": "Creates caption",
        "responses": {
          "200": {
            "description": "caption created"
          },
          "400": {
            "description": "caption can be max XX long (depended on plan)"
          },
          "402": {
            "description": "no credits left"
          },
          "403": {
            "description": "no subscription or supported plan found"
          },
          "404": {
            "description": "user not found"
          },
          "415": {
            "description": "unsupported media type"
          },
          "500": {
            "description": "Error fetching customer ID"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCaption"
              }
            }
          },
          "description": "Parameters of the caption to be created"
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateCaption": {
        "type": "object",
        "required": [
          "url",
          "language",
          "theme",
          "setting",
          "mood",
          "custom",
          "emojis",
          "hashtags",
          "cta",
          "length"
        ],
        "properties": {
          "url": {
            "type": "string",
            "example": "https://image-to-caption-permament-uploadstore.s3.eu-central-1.amazonaws.com/orangecake.png"
          },
          "language": {
            "type": "string",
            "format": "ISO 3166-1 A-2 format",
            "example": "en"
          },
          "theme": {
            "type": "string",
            "example": "advertisment"
          },
          "setting": {
            "type": "string",
            "example": "Stuttgart"
          },
          "mood": {
            "type": "string",
            "example": "casual"
          },
          "custom": {
            "type": "string",
            "example": "my name is Josh"
          },
          "emojis": {
            "type": "boolean",
            "example": true
          },
          "hashtags": {
            "type": "boolean",
            "example": true
          },
          "cta": {
            "type": "boolean",
            "example": false
          },
          "length": {
            "type": "integer",
            "example": 42
          }
        }
      }
    }
  }
}