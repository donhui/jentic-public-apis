{
  "openapi": "3.0.0",
  "info": {
    "description": "Documenta\u00e7\u00e3o da API de consultas do site [http://www.ecvconsult.com.br](http://www.ecvconsult.com.br)\n",
    "version": "1.0.1",
    "title": "ECV Consult API",
    "contact": {
      "email": "hira.edu@gmail.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/ehiratuka/AppEcvAPI/1.0.1/swagger.json"
  },
  "tags": [
    {
      "name": "review",
      "description": "Revis\u00e3o de Laudos"
    },
    {
      "name": "sistema",
      "description": "Sistema da ECV"
    },
    {
      "name": "auth",
      "description": "Autentica\u00e7\u00e3o de Usu\u00e1rios"
    },
    {
      "name": "message",
      "description": "Sistema de Mensagens"
    },
    {
      "name": "user",
      "description": "Sistema de Usu\u00e1rios"
    }
  ],
  "paths": {
    "/review": {
      "get": {
        "tags": [
          "review"
        ],
        "summary": "Obt\u00e9m um laudo n\u00e3o revisado",
        "responses": {
          "200": {
            "description": "Laudo n\u00e3o revisado obtido com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "laudo": {
                      "$ref": "#/components/schemas/Laudo"
                    },
                    "restante": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/review/aprovar/{laudoId}": {
      "get": {
        "tags": [
          "review"
        ],
        "summary": "Aprova determinado laudo.",
        "parameters": [
          {
            "name": "laudoId",
            "in": "path",
            "description": "ID do Laudo que ser\u00e1 aprovado.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Revis\u00e3o aprovada com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "laudo": {
                      "$ref": "#/components/schemas/Laudo"
                    },
                    "restante": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/review/reprovar/{laudoId}": {
      "get": {
        "tags": [
          "review"
        ],
        "summary": "Reprova determinado laudo.",
        "parameters": [
          {
            "name": "laudoId",
            "in": "path",
            "description": "ID do Laudo que ser\u00e1 reprovado.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Revis\u00e3o reprovada com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "laudo": {
                      "$ref": "#/components/schemas/Laudo"
                    },
                    "restante": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pesquisa/{termo}/{pagina}": {
      "get": {
        "tags": [
          "sistema"
        ],
        "summary": "Pesquisa laudos pelo termo",
        "parameters": [
          {
            "name": "termo",
            "in": "path",
            "description": "Termo que ser\u00e1 pesquisado.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pagina",
            "in": "path",
            "description": "P\u00e1gina do resultado.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de laudos obtida com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "laudos": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Laudo"
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Autoriza\u00e7\u00e3o necess\u00e1ria.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "security": [
          {
            "jwtAuth": []
          }
        ]
      }
    },
    "/auth/signup": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Cadastra um novo usu\u00e1rio.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "senha": {
                    "type": "string"
                  },
                  "documento": {
                    "type": "string"
                  },
                  "recaptcha": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cadastro realizado com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer"
                    },
                    "valid": {
                      "type": "boolean",
                      "default": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro ao cadastrar usu\u00e1rio.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/auth/verify/{token}": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Verifica o cadastro do usu\u00e1rio.",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "description": "Token \u00fanico de autentica\u00e7\u00e3o do usu\u00e1rio.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cadastro verificado com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer"
                    },
                    "valid": {
                      "type": "boolean",
                      "default": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro ao verificar cadastro.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/auth/validate/{type}/{info}": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Valida determinado campo.",
        "parameters": [
          {
            "name": "type",
            "in": "path",
            "description": "Tipo de campo a ser validado",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "email",
                "documento"
              ]
            }
          },
          {
            "name": "info",
            "in": "path",
            "description": "Valor do campo a ser validado",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campo validado com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer"
                    },
                    "valid": {
                      "type": "boolean",
                      "default": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro ao validar campo.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/auth/get/{token}": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Obt\u00e9m o usu\u00e1rio pelo c\u00f3digo de verifica\u00e7\u00e3o.",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "description": "Token \u00fanico de autentica\u00e7\u00e3o do usu\u00e1rio.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Usu\u00e1rio obtido com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer"
                    },
                    "usuario": {
                      "$ref": "#/components/schemas/Usuario"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro ao obter usu\u00e1rio",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/auth/get": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Obt\u00e9m informa\u00e7\u00f5es do usu\u00e1rio logado",
        "responses": {
          "200": {
            "description": "Usu\u00e1rio obtido com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer"
                    },
                    "usuario": {
                      "$ref": "#/components/schemas/Usuario"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Autoriza\u00e7\u00e3o necess\u00e1ria.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          },
          "400": {
            "description": "Erro ao obter usu\u00e1rio logado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "security": [
          {
            "jwtAuth": []
          }
        ]
      }
    },
    "/auth/reset/{email}": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Envia e-mail para recupera\u00e7\u00e3o de senha.",
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "description": "E-mail do usu\u00e1rio",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "E-mail enviado com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer"
                    },
                    "valid": {
                      "type": "boolean",
                      "default": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro ao enviar e-mail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/auth/restore/{token}": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Restaura a senha do usu\u00e1rio",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "description": "Token \u00fanico de autentica\u00e7\u00e3o do usu\u00e1rio.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "senha": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Senha restaurada com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "statusCode": {
                      "type": "integer"
                    },
                    "valid": {
                      "type": "boolean",
                      "default": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro ao restaurar senha",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/message": {
      "post": {
        "tags": [
          "message"
        ],
        "summary": "Envia uma nova mensagem.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nome": {
                    "type": "string"
                  },
                  "assunto": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "telefone": {
                    "type": "string"
                  },
                  "mensagem": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mensagem enviada com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Erro ao enviar mensagem.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Laudo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "chassi": {
            "type": "string"
          },
          "motor": {
            "type": "string"
          },
          "imgsrc": {
            "type": "string"
          },
          "dataInclusao": {
            "type": "string",
            "format": "date-time"
          },
          "dataModificacao": {
            "type": "string",
            "format": "date-time"
          },
          "deletadoFlag": {
            "type": "boolean"
          },
          "revisado": {
            "type": "boolean"
          },
          "aprovado": {
            "type": "boolean"
          }
        }
      },
      "Usuario": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "nome": {
            "type": "string"
          },
          "documento": {
            "type": "string"
          },
          "rg": {
            "type": "string"
          },
          "estadoCivil": {
            "type": "string"
          },
          "telefone": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "verificado": {
            "type": "boolean"
          },
          "codVerificacao": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "sexo": {
            "type": "string"
          },
          "responsavel": {
            "type": "string"
          },
          "documentoResponsavel": {
            "type": "string"
          },
          "nomeResponsavel": {
            "type": "string"
          },
          "dataInclusao": {
            "type": "string",
            "format": "date-time"
          },
          "dataModificacao": {
            "type": "string",
            "format": "date-time"
          },
          "deletadoFlag": {
            "type": "boolean"
          }
        }
      },
      "ErrorModel": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "jwtAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}