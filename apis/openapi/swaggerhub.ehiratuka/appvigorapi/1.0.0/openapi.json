{
  "openapi": "3.0.0",
  "info": {
    "description": "Documenta\u00e7\u00e3o da API de consultas do site [https://www.vigoreng.com.br](https://www.vigoreng.com.br)\n",
    "version": "1.0.0",
    "title": "Vigor Engenharia API",
    "contact": {
      "email": "hira.edu@gmail.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/ehiratuka/AppVigorAPI/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "categoria",
      "description": "Categorias de Servi\u00e7os/Obras"
    },
    {
      "name": "obra",
      "description": "Servi\u00e7os/Obras dispon\u00edveis"
    },
    {
      "name": "message",
      "description": "Sistema de envio de mensagens"
    }
  ],
  "paths": {
    "/categoria": {
      "get": {
        "tags": [
          "categoria"
        ],
        "summary": "Obt\u00e9m uma lista de categorias",
        "responses": {
          "200": {
            "description": "Categorias obtidas com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Categoria"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/obra/destaques": {
      "get": {
        "tags": [
          "obra"
        ],
        "summary": "Obt\u00e9m uma lista de obras destacadas",
        "responses": {
          "200": {
            "description": "Obras destacadas obtidas com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Obra"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/obra/findByCategoria": {
      "get": {
        "tags": [
          "obra"
        ],
        "summary": "Obt\u00e9m uma lista de todas as obras",
        "responses": {
          "200": {
            "description": "Obras obtidas com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Obra"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/obra/findByCategoria/{categoriaSlug}": {
      "get": {
        "tags": [
          "obra"
        ],
        "summary": "Obt\u00e9m uma lista de obras dado uma determinada categoria",
        "parameters": [
          {
            "name": "categoriaSlug",
            "in": "path",
            "description": "Slug da categoria que filtrar\u00e1 as obras",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Obras obtidas com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Obra"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/message": {
      "post": {
        "tags": [
          "message"
        ],
        "summary": "Envia uma nova mensagem",
        "description": "",
        "operationId": "addPet",
        "responses": {
          "200": {
            "description": "Se foi gerado corretamente."
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Message"
              }
            }
          },
          "description": "Mensagem que ser\u00e1 enviado ao servidor",
          "required": true
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Categoria": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "nome": {
            "type": "string"
          },
          "descricao": {
            "type": "string"
          },
          "imagem": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "dataInclusao": {
            "type": "string",
            "format": "date-time"
          },
          "dataModificacao": {
            "type": "string",
            "format": "date-time"
          },
          "deletadoFlag": {
            "type": "boolean"
          }
        }
      },
      "Obra": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "nome": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "descricao": {
            "type": "string"
          },
          "valor": {
            "type": "number",
            "format": "gloat"
          },
          "desconto": {
            "type": "number",
            "format": "gloat"
          },
          "listar": {
            "type": "boolean"
          },
          "dataInclusao": {
            "type": "string",
            "format": "date-time"
          },
          "dataModificacao": {
            "type": "string",
            "format": "date-time"
          },
          "deletadoFlag": {
            "type": "boolean"
          },
          "imagens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Imagem"
            }
          }
        }
      },
      "Imagem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "src": {
            "type": "string"
          },
          "dataInclusao": {
            "type": "string",
            "format": "date-time"
          },
          "dataModificacao": {
            "type": "string",
            "format": "date-time"
          },
          "deletadoFlag": {
            "type": "boolean"
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "assunto": {
            "type": "string"
          },
          "remetente": {
            "type": "string",
            "format": "email"
          },
          "mensagem": {
            "type": "string"
          }
        }
      }
    }
  }
}