{
  "openapi": "3.0.3",
  "info": {
    "title": "Crunchy Bridge API",
    "description": "The Crunchy Bridge API allows you to automate management of PostgreSQL databases managed by Crunchy Bridge, including cluster provisioning, team management, and account operations.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.crunchybridge.com/"
  },
  "servers": [
    {
      "url": "https://api.crunchybridge.com",
      "description": "Crunchy Bridge API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/account": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get current account",
        "description": "Retrieve the currently authenticated user account.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Account details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "400": {
            "description": "Bad request"
          }
        }
      },
      "delete": {
        "operationId": "deleteAccount",
        "summary": "Delete current account",
        "description": "Delete the currently authenticated account. Accounts can only be deleted if no teams for which they are the only admin own any provisioned clusters.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Deleted account details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Conflict - account cannot be deleted"
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/clusters": {
      "get": {
        "operationId": "listClusters",
        "summary": "List clusters",
        "description": "Retrieve clusters across all teams or filter by specific team.",
        "tags": [
          "Clusters"
        ],
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor from a previous response.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of items per page (1-200, default 100).",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 100
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "asc"
            }
          },
          {
            "name": "order_field",
            "in": "query",
            "description": "Field to sort by.",
            "schema": {
              "type": "string",
              "enum": [
                "id",
                "name"
              ]
            }
          },
          {
            "name": "team_id",
            "in": "query",
            "description": "Filter clusters by team ID.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of clusters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "clusters": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Cluster"
                      }
                    },
                    "has_more": {
                      "type": "boolean"
                    },
                    "next_cursor": {
                      "type": "string",
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createCluster",
        "summary": "Create cluster",
        "description": "Provision a new database cluster.",
        "tags": [
          "Clusters"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClusterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Cluster created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cluster"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}": {
      "get": {
        "operationId": "getCluster",
        "summary": "Get cluster",
        "description": "Fetch a specific cluster by identifier.",
        "tags": [
          "Clusters"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Cluster identifier."
          }
        ],
        "responses": {
          "200": {
            "description": "Cluster details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cluster"
                }
              }
            }
          },
          "404": {
            "description": "Cluster not found"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "patch": {
        "operationId": "updateCluster",
        "summary": "Update cluster",
        "description": "Modify cluster properties.",
        "tags": [
          "Clusters"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Cluster identifier."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateClusterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated cluster",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cluster"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "destroyCluster",
        "summary": "Destroy cluster",
        "description": "Delete a database cluster permanently.",
        "tags": [
          "Clusters"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Cluster identifier."
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted cluster details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cluster"
                }
              }
            }
          },
          "404": {
            "description": "Cluster not found"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/status": {
      "get": {
        "operationId": "getClusterStatus",
        "summary": "Get cluster status",
        "description": "Retrieve real-time cluster operational status and metrics.",
        "tags": [
          "Clusters"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Cluster identifier."
          }
        ],
        "responses": {
          "200": {
            "description": "Cluster status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClusterStatus"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/forks": {
      "post": {
        "operationId": "createClusterFork",
        "summary": "Create cluster fork",
        "description": "Generate a point-in-time database clone.",
        "tags": [
          "Clusters"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Source cluster identifier."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClusterForkRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Forked cluster created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cluster"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/actions/disable-ha": {
      "put": {
        "operationId": "disableHighAvailability",
        "summary": "Disable high availability",
        "description": "Remove redundancy from cluster.",
        "tags": [
          "Cluster Actions"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Upgrade operation status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpgradeOperation"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/actions/enable-ha": {
      "put": {
        "operationId": "enableHighAvailability",
        "summary": "Enable high availability",
        "description": "Configure automatic failover capability.",
        "tags": [
          "Cluster Actions"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Upgrade operation status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpgradeOperation"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/actions/ping": {
      "put": {
        "operationId": "pingCluster",
        "summary": "Ping cluster",
        "description": "Test database connectivity and responsiveness.",
        "tags": [
          "Cluster Actions"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ping response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/actions/restart": {
      "put": {
        "operationId": "restartCluster",
        "summary": "Restart cluster",
        "description": "Reboot server or specific service.",
        "tags": [
          "Cluster Actions"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "service": {
                    "type": "string",
                    "enum": [
                      "postgres",
                      "server"
                    ],
                    "default": "server",
                    "description": "Service to restart."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Restarted cluster",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cluster"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/actions/resume": {
      "put": {
        "operationId": "resumeCluster",
        "summary": "Resume cluster",
        "description": "Restart suspended cluster operations.",
        "tags": [
          "Cluster Actions"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resumed cluster",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cluster"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/actions/start-backup": {
      "put": {
        "operationId": "startBackup",
        "summary": "Start backup",
        "description": "Initiate immediate backup capture.",
        "tags": [
          "Cluster Actions"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Backup started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/actions/suspend": {
      "put": {
        "operationId": "suspendCluster",
        "summary": "Suspend cluster",
        "description": "Pause cluster while preserving disk storage.",
        "tags": [
          "Cluster Actions"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Suspended cluster",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Cluster"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/actions/tailscale-connect": {
      "put": {
        "operationId": "tailscaleConnect",
        "summary": "Connect to Tailscale network",
        "description": "Join cluster to Tailscale tailnet.",
        "tags": [
          "Cluster Actions"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "auth_key": {
                    "type": "string",
                    "description": "One-time Tailscale auth token."
                  },
                  "tailscale_oauth_client_id": {
                    "type": "string",
                    "description": "OAuth client reference."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Connection confirmation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/clusters/{cluster_id}/actions/tailscale-disconnect": {
      "put": {
        "operationId": "tailscaleDisconnect",
        "summary": "Disconnect from Tailscale network",
        "description": "Remove cluster from Tailscale tailnet.",
        "tags": [
          "Cluster Actions"
        ],
        "parameters": [
          {
            "name": "cluster_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Disconnection confirmation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/teams": {
      "get": {
        "operationId": "listTeams",
        "summary": "List teams",
        "description": "List teams for which the authenticated account has access.",
        "tags": [
          "Teams"
        ],
        "parameters": [
          {
            "name": "automatic_sso_join_enabled",
            "in": "query",
            "description": "Filter teams joinable via SSO.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum items per page.",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            }
          },
          {
            "name": "order_field",
            "in": "query",
            "description": "Field to sort by.",
            "schema": {
              "type": "string",
              "enum": [
                "id",
                "name"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of teams",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "teams": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Team"
                      }
                    },
                    "has_more": {
                      "type": "boolean"
                    },
                    "next_cursor": {
                      "type": "string",
                      "nullable": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createTeam",
        "summary": "Create team",
        "description": "Create a new team.",
        "tags": [
          "Teams"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTeamRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created team",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Team"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/teams/{team_id}": {
      "get": {
        "operationId": "getTeam",
        "summary": "Get team",
        "description": "Get an existing team.",
        "tags": [
          "Teams"
        ],
        "parameters": [
          {
            "name": "team_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Team identifier."
          }
        ],
        "responses": {
          "200": {
            "description": "Team details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Team"
                }
              }
            }
          },
          "404": {
            "description": "Team not found"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "patch": {
        "operationId": "updateTeam",
        "summary": "Update team",
        "description": "Update an existing team.",
        "tags": [
          "Teams"
        ],
        "parameters": [
          {
            "name": "team_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Team identifier."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTeamRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated team",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Team"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "destroyTeam",
        "summary": "Destroy team",
        "description": "Delete an existing team.",
        "tags": [
          "Teams"
        ],
        "parameters": [
          {
            "name": "team_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Team identifier."
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted team",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Team"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key obtained from account settings at https://crunchybridge.com/account. Format: cbkey_[your_api_key]"
      }
    },
    "schemas": {
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Primary account identifier (EID format)."
          },
          "email": {
            "type": "string",
            "description": "Associated email address."
          },
          "name": {
            "type": "string",
            "description": "Full name."
          },
          "has_password": {
            "type": "boolean",
            "description": "Whether password authentication is configured."
          },
          "has_sso": {
            "type": "boolean",
            "description": "Whether SSO is enabled."
          },
          "multi_factor_enabled": {
            "type": "boolean",
            "description": "MFA activation status."
          },
