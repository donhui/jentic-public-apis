          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteTimeEntry",
        "summary": "Delete a time entry",
        "tags": ["TimeEntries"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "card_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Time entry deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/running_timers.json": {
      "get": {
        "operationId": "listRunningTimers",
        "summary": "List active running timers",
        "tags": ["TimeEntries"],
        "responses": {
          "200": { "description": "List of running timers", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/TimeEntry" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/activities.json": {
      "get": {
        "operationId": "listActivities",
        "summary": "List all activities",
        "tags": ["Activities"],
        "parameters": [{ "name": "page", "in": "query", "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "List of activities", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Activity" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/activities/{user_id}.json": {
      "get": {
        "operationId": "listUserActivities",
        "summary": "List activities for a user",
        "tags": ["Activities"],
        "parameters": [
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "User activities", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Activity" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{project_id}/activities.json": {
      "get": {
        "operationId": "listProjectActivities",
        "summary": "List activities for a project",
        "tags": ["Activities"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Project activities", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Activity" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/notifications.json": {
      "get": {
        "operationId": "listNotifications",
        "summary": "List unread notifications",
        "tags": ["Notifications"],
        "parameters": [{ "name": "page", "in": "query", "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Unread notifications", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Notification" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/notifications/{id}.json": {
      "put": {
        "operationId": "updateNotification",
        "summary": "Mark notification as read or unread",
        "tags": ["Notifications"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "marked": { "type": "boolean" } } } } } },
        "responses": {
          "200": { "description": "Notification updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Notification" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/reports.json": {
      "post": {
        "operationId": "generateReport",
        "summary": "Generate a report",
        "tags": ["Reports"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReportRequest" } } }
        },
        "responses": {
          "200": { "description": "Report generated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Report" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/me.json": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user info",
        "tags": ["Users"],
        "responses": {
          "200": { "description": "Current user", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/users.json": {
      "get": {
        "operationId": "listUsers",
        "summary": "List team users",
        "tags": ["Users"],
        "responses": {
          "200": { "description": "List of users", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth with username:password or api_token: as username"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "budget_amount": { "type": "number" },
          "budget_hours": { "type": "number" },
          "hourly_rate": { "type": "number" },
          "currency_symbol": { "type": "string" },
          "workspace_id": { "type": "integer" },
          "archived": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateProjectRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "budget_amount": { "type": "number" },
          "budget_hours": { "type": "number" },
          "hourly_rate": { "type": "number" },
          "currency_symbol": { "type": "string" },
          "workspace_id": { "type": "integer" },
          "invitees": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      },
      "Card": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "duedate": { "type": "string", "format": "date" },
          "startdate": { "type": "string", "format": "date" },
          "planned_time": { "type": "number" },
          "stage_id": { "type": "integer" },
          "swimlane_id": { "type": "integer" },
          "project_id": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "custom_fields": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateCardRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "duedate": { "type": "string", "format": "date" },
          "startdate": { "type": "string", "format": "date" },
          "planned_time": { "type": "number" },
          "stage_id": { "type": "integer" },
          "swimlane_id": { "type": "integer" },
          "invitees": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "custom_fields": { "type": "object" }
        }
      },
      "UpdateCardRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "duedate": { "type": "string", "format": "date" },
          "startdate": { "type": "string", "format": "date" },
          "planned_time": { "type": "number" },
          "stage_id": { "type": "integer" },
          "swimlane_id": { "type": "integer" },
          "new_project_id": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "custom_fields": { "type": "object" }
        }
      },
      "Stage": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "position": { "type": "integer" }
        }
      },
      "Swimlane": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "position": { "type": "integer" }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "comment": { "type": "string" },
          "user_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "TodoList": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      },
      "Todo": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "done": { "type": "boolean" }
        }
      },
      "TimeEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "tracked": { "type": "number" },
          "logged_date": { "type": "string", "format": "date" },
          "desc": { "type": "string" },
          "user_id": { "type": "integer" }
        }
      },
      "CreateTimeEntryRequest": {
        "type": "object",
        "properties": {
          "tracked": { "type": "number" },
          "logged_date": { "type": "string", "format": "date" },
          "desc": { "type": "string" }
        }
      },
      "Activity": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "action": { "type": "string" },
          "user_id": { "type": "integer" },
          "project_id": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "message": { "type": "string" },
          "marked": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ReportRequest": {
        "type": "object",
        "required": ["report_type"],
        "properties": {
          "report_type": { "type": "string" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "projects": { "type": "array", "items": { "type": "integer" } },
          "users": { "type": "array", "items": { "type": "integer" } },
          "stages": { "type": "array", "items": { "type": "integer" } },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Report": {
        "type": "object",
        "properties": {
          "data": { "type": "object" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      }
    }
  }
}