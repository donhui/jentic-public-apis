{
  "openapi": "3.0.3",
  "info": {
    "title": "Breeze API",
    "version": "1.0.0",
    "description": "Breeze is a simple project management tool that enables teams to plan, track and organize their work.",
    "x-jentic-source-url": "https://www.breeze.pm/api"
  },
  "servers": [
    {
      "url": "https://api.breeze.pm"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    { "name": "Projects", "description": "Project management" },
    { "name": "Workspaces", "description": "Workspace management" },
    { "name": "Cards", "description": "Task/card management" },
    { "name": "Stages", "description": "Stage/list management" },
    { "name": "Swimlanes", "description": "Swimlane management" },
    { "name": "Comments", "description": "Card comments" },
    { "name": "TodoLists", "description": "Todo list management" },
    { "name": "Todos", "description": "Todo item management" },
    { "name": "TimeEntries", "description": "Time tracking" },
    { "name": "Activities", "description": "Activity feed" },
    { "name": "Notifications", "description": "Notification management" },
    { "name": "Reports", "description": "Report generation" },
    { "name": "Users", "description": "User management" }
  ],
  "paths": {
    "/projects.json": {
      "get": {
        "operationId": "listProjects",
        "summary": "List active projects",
        "tags": ["Projects"],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Project" }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createProject",
        "summary": "Create a project",
        "tags": ["Projects"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateProjectRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{id}.json": {
      "get": {
        "operationId": "getProject",
        "summary": "Retrieve a project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Project details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateProject",
        "summary": "Update a project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateProjectRequest" } } }
        },
        "responses": {
          "200": { "description": "Project updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteProject",
        "summary": "Delete a project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Project deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{id}/archive.json": {
      "get": {
        "operationId": "archiveProject",
        "summary": "Archive a project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Project archived", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{id}/reactivate.json": {
      "get": {
        "operationId": "reactivateProject",
        "summary": "Reactivate an archived project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Project reactivated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{id}/people.json": {
      "get": {
        "operationId": "listProjectMembers",
        "summary": "List project members",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List of members", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "addProjectMembers",
        "summary": "Add members to a project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "invitees": { "type": "array", "items": { "type": "string" } }
                },
                "required": ["invitees"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Members added", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{id}/people/{user_id}.json": {
      "delete": {
        "operationId": "removeProjectMember",
        "summary": "Remove a member from a project",
        "tags": ["Projects"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Member removed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/workspaces.json": {
      "get": {
        "operationId": "listWorkspaces",
        "summary": "List workspaces",
        "tags": ["Workspaces"],
        "responses": {
          "200": { "description": "List of workspaces", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Workspace" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createWorkspace",
        "summary": "Create a workspace",
        "tags": ["Workspaces"],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" } } } } }
        },
        "responses": {
          "200": { "description": "Workspace created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Workspace" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/workspaces/{id}.json": {
      "get": {
        "operationId": "getWorkspace",
        "summary": "Retrieve a workspace",
        "tags": ["Workspaces"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Workspace details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Workspace" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateWorkspace",
        "summary": "Update a workspace",
        "tags": ["Workspaces"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" } } } } } },
        "responses": {
          "200": { "description": "Workspace updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Workspace" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteWorkspace",
        "summary": "Delete a workspace",
        "tags": ["Workspaces"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Workspace deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{project_id}/cards.json": {
      "get": {
        "operationId": "listCards",
        "summary": "List cards in a project",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "archived", "in": "query", "schema": { "type": "boolean" } },
          { "name": "only_archived", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": { "description": "List of cards", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Card" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createCard",
        "summary": "Create a card",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateCardRequest" } } }
        },
        "responses": {
          "200": { "description": "Card created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Card" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/projects/{project_id}/cards.json": {
      "get": {
        "operationId": "listCardsV2",
        "summary": "List cards in a project (paginated, v2)",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "archived", "in": "query", "schema": { "type": "boolean" } },
          { "name": "only_archived", "in": "query", "schema": { "type": "boolean" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "hidden", "in": "query", "schema": { "type": "boolean" } },
          { "name": "done", "in": "query", "schema": { "type": "boolean" } },
          { "name": "creator_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "assigned_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Paginated list of cards", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Card" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v2/cards.json": {
      "get": {
        "operationId": "listAllCardsV2",
        "summary": "List cards across all projects (paginated, v2)",
        "tags": ["Cards"],
        "parameters": [
          { "name": "archived", "in": "query", "schema": { "type": "boolean" } },
          { "name": "only_archived", "in": "query", "schema": { "type": "boolean" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "hidden", "in": "query", "schema": { "type": "boolean" } },
          { "name": "done", "in": "query", "schema": { "type": "boolean" } },
          { "name": "creator_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "assigned_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Paginated list of cards", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Card" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{project_id}/stages/{stage_id}/cards.json": {
      "get": {
        "operationId": "listCardsByStage",
        "summary": "List cards in a stage",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "stage_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Cards in stage", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Card" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{project_id}/swimlanes/{swimlane_id}/cards.json": {
      "get": {
        "operationId": "listCardsBySwimlane",
        "summary": "List cards in a swimlane",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "swimlane_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Cards in swimlane", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Card" } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{project_id}/cards/{id}.json": {
      "get": {
        "operationId": "getCard",
        "summary": "Retrieve a card",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Card details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Card" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateCard",
        "summary": "Update a card",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateCardRequest" } } }
        },
        "responses": {
          "200": { "description": "Card updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Card" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteCard",
        "summary": "Delete a card",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Card deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{project_id}/cards/{id}/move.json": {
      "post": {
        "operationId": "moveCard",
        "summary": "Move a card to a different stage",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "stage_id": { "type": "integer" }, "prev_id": { "type": "integer" } } } } }
        },
        "responses": {
          "200": { "description": "Card moved", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Card" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/projects/{project_id}/cards/{id}/people.json": {
      "post": {
        "operationId": "assignCardPeople",
        "summary": "Assign people to a card",
        "tags": ["Cards"],
        "parameters": [
          { "name": "project_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "invitees": { "type": "array", "items": { "type": "string" } } }, "required": ["invitees"] } } }
        },
        "responses": {
          "200": { "description": "People assigned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
