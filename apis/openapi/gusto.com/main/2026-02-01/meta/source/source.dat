    "/v1/companies/{company_id}/payrolls": {
      "get": {
        "operationId": "listPayrolls",
        "summary": "List company payrolls",
        "description": "Retrieve all payrolls for a company.",
        "tags": ["Payroll"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "processing_statuses",
            "in": "query",
            "schema": {"type": "string"}
          },
          {
            "name": "payroll_types",
            "in": "query",
            "schema": {"type": "string"}
          },
          {
            "name": "start_date",
            "in": "query",
            "schema": {"type": "string", "format": "date"}
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {"type": "string", "format": "date"}
          }
        ],
        "responses": {
          "200": {
            "description": "Payrolls retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Payroll"
                  }
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "post": {
        "operationId": "createOffCyclePayroll",
        "summary": "Create an off-cycle payroll",
        "description": "Create an off-cycle payroll for a company.",
        "tags": ["Payroll"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "off_cycle": {"type": "boolean"},
                  "off_cycle_reason": {"type": "string"},
                  "start_date": {"type": "string", "format": "date"},
                  "end_date": {"type": "string", "format": "date"},
                  "check_date": {"type": "string", "format": "date"},
                  "employee_ids": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                },
                "required": ["off_cycle", "check_date"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payroll created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payroll"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "422": {"description": "Unprocessable entity"}
        }
      }
    },
    "/v1/companies/{company_id}/payrolls/{payroll_id}": {
      "get": {
        "operationId": "getPayroll",
        "summary": "Get a payroll",
        "description": "Retrieve a payroll by ID.",
        "tags": ["Payroll"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "payroll_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Payroll retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payroll"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Payroll not found"}
        }
      },
      "put": {
        "operationId": "updatePayroll",
        "summary": "Update a payroll",
        "description": "Update a payroll by ID.",
        "tags": ["Payroll"],
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          },
          {
            "name": "payroll_id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "employee_compensations": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "employee_id": {"type": "string"},
                        "fixed_compensations": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "name": {"type": "string"},
                              "amount": {"type": "string"},
                              "job_id": {"type": "string"}
                            }
                          }
                        },
                        "hourly_compensations": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "name": {"type": "string"},
                              "hours": {"type": "string"},
                              "job_id": {"type": "string"}
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payroll updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payroll"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "422": {"description": "Unprocessable entity"}
        }
      }
    },
