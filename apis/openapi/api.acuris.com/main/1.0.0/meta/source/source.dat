{
  "openapi": "3.0.3",
  "info": {
    "title": "Acuris Compliance API",
    "version": "1.0.0",
    "description": "Search and retrieve individual and business compliance profiles, including sanctions data, PEP screening, and adverse media. Supports PDF report generation with copyrighted evidence access.",
    "x-jentic-source-url": "https://api.acuris.com/compliance/docs/api"
  },
  "servers": [
    {
      "url": "https://api.acuris.com/compliance"
    }
  ],
  "paths": {
    "/individuals": {
      "post": {
        "operationId": "searchIndividuals",
        "summary": "Search individual profiles",
        "description": "Search for individual compliance profiles by name, datasets, and optional filters.",
        "tags": ["Individuals"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IndividualSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results with match scores (max 500 results)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/IndividualProfile" }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized - invalid API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/individuals/{resourceId}": {
      "get": {
        "operationId": "getIndividual",
        "summary": "Get individual profile by ID",
        "description": "Retrieve a specific individual profile by resource ID.",
        "tags": ["Individuals"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "description": "Individual profile resource ID",
            "schema": { "type": "string" }
          },
          {
            "name": "Accept",
            "in": "header",
            "required": false,
            "description": "Response format (application/json or application/pdf)",
            "schema": { "type": "string", "enum": ["application/json", "application/pdf"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Individual profile",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IndividualProfile" }
              },
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "getIndividualPdf",
        "summary": "Get individual profile PDF with comment",
        "description": "Generate a PDF report for an individual profile with an optional user comment.",
        "tags": ["Individuals"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PdfCommentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF report",
            "content": {
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/businesses": {
      "post": {
        "operationId": "searchBusinesses",
        "summary": "Search business profiles",
        "description": "Search for business compliance profiles by name, datasets, and optional filters.",
        "tags": ["Businesses"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BusinessSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results (max 500 results)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/BusinessProfile" }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/businesses/{resourceId}": {
      "get": {
        "operationId": "getBusiness",
        "summary": "Get business profile by ID",
        "tags": ["Businesses"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "Accept",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "enum": ["application/json", "application/pdf"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Business profile",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BusinessProfile" }
              },
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "getBusinessPdf",
        "summary": "Get business profile PDF with comment",
        "tags": ["Businesses"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PdfCommentRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF report",
            "content": {
              "application/pdf": { "schema": { "type": "string", "format": "binary" } }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/individuals/{resourceId}/evidences/copyrighted/{evidenceId}": {
      "get": {
        "operationId": "getIndividualCopyrightedEvidence",
        "summary": "Get copyrighted evidence for individual",
        "tags": ["Evidence"],
        "parameters": [
          { "name": "resourceId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "evidenceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Evidence PDF",
            "content": { "application/pdf": { "schema": { "type": "string", "format": "binary" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/businesses/{resourceId}/evidences/copyrighted/{evidenceId}": {
      "get": {
        "operationId": "getBusinessCopyrightedEvidence",
        "summary": "Get copyrighted evidence for business",
        "tags": ["Evidence"],
        "parameters": [
          { "name": "resourceId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "evidenceId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Evidence PDF",
            "content": { "application/pdf": { "schema": { "type": "string", "format": "binary" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/dictionaries/sanction-bodies": {
      "get": {
        "operationId": "getSanctionBodies",
        "summary": "Get sanctioning bodies dictionary",
        "description": "Retrieve reference data mapping sanctioning body names to IDs for filtering.",
        "tags": ["Dictionaries"],
        "responses": {
          "200": {
            "description": "List of sanctioning bodies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/SanctionBody" }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IndividualSearchRequest": {
        "type": "object",
        "required": ["name", "datasets"],
        "properties": {
          "name": { "type": "string", "description": "Full name to search" },
          "datasets": { "type": "array", "items": { "type": "string" }, "description": "Datasets to search against" },
          "dateOfBirth": { "type": "string", "format": "date" },
          "addresses": { "type": "array", "items": { "type": "object", "properties": { "country": { "type": "string" } } } },
          "countries": { "type": "array", "items": { "type": "string" } }
        }
      },
      "BusinessSearchRequest": {
        "type": "object",
        "required": ["name", "datasets"],
        "properties": {
          "name": { "type": "string" },
          "datasets": { "type": "array", "items": { "type": "string" } },
          "addresses": { "type": "array", "items": { "type": "object", "properties": { "country": { "type": "string" } } } },
          "countries": { "type": "array", "items": { "type": "string" } }
        }
      },
      "IndividualProfile": {
        "type": "object",
        "properties": {
          "resourceId": { "type": "string" },
          "name": { "type": "string" },
          "matchScore": { "type": "number" },
          "datasets": { "type": "array", "items": { "type": "string" } },
          "dateOfBirth": { "type": "string" },
          "nationalities": { "type": "array", "items": { "type": "string" } },
          "aliases": { "type": "array", "items": { "type": "string" } }
        }
      },
      "BusinessProfile": {
        "type": "object",
        "properties": {
          "resourceId": { "type": "string" },
          "name": { "type": "string" },
          "matchScore": { "type": "number" },
          "datasets": { "type": "array", "items": { "type": "string" } },
          "addresses": { "type": "array", "items": { "type": "string" } }
        }
      },
      "PdfCommentRequest": {
        "type": "object",
        "required": ["comment"],
        "properties": {
          "comment": { "type": "string", "maxLength": 500 },
          "userName": { "type": "string" }
        }
      },
      "SanctionBody": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "code": { "type": "integer" }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "x-api-key",
        "in": "header",
        "description": "Acuris API key"
      }
    }
  },
  "security": [
    { "apiKey": [] }
  ]
}