{
  "openapi": "3.0.3",
  "info": {
    "title": "Pterodactyl Panel API",
    "version": "1.0.0",
    "description": "REST API for Pterodactyl Panel, an open-source game server management platform. Includes both Client API (for server users) and Application API (for administrators) covering server management, user administration, node management, location management, and more.",
    "x-jentic-source-url": "https://pterodactyl-api-docs.netvpx.com/"
  },
  "servers": [
    {
      "url": "https://{panel-domain}",
      "description": "Pterodactyl Panel instance",
      "variables": {
        "panel-domain": {
          "default": "panel.example.com",
          "description": "Your Pterodactyl Panel domain"
        }
      }
    }
  ],
  "paths": {
    "/api/client": {
      "get": {
        "operationId": "listServers",
        "summary": "List all accessible servers",
        "description": "Retrieve all servers accessible to the authenticated user.",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "include",
            "in": "query",
            "description": "Comma-separated relationships to include (allocations, variables)",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (max 100)",
            "schema": { "type": "integer", "default": 50, "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "Server list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServerListResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/permissions": {
      "get": {
        "operationId": "getPermissions",
        "summary": "Get available permissions",
        "description": "Retrieve all available permissions assignable to server users.",
        "tags": ["Client - Account"],
        "responses": {
          "200": {
            "description": "Permission categories",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account details",
        "description": "Retrieve authenticated account information.",
        "tags": ["Client - Account"],
        "responses": {
          "200": {
            "description": "Account details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AccountResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account/two-factor": {
      "get": {
        "operationId": "getTwoFactorSetup",
        "summary": "Generate 2FA QR code",
        "description": "Generate a TOTP QR code for two-factor authentication setup.",
        "tags": ["Client - Account"],
        "responses": {
          "200": {
            "description": "2FA setup data with QR code and secret",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "image_url_data": { "type": "string" },
                        "secret": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "enableTwoFactor",
        "summary": "Enable 2FA",
        "description": "Enable two-factor authentication with an authenticator code.",
        "tags": ["Client - Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string", "description": "6-digit TOTP code" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "2FA enabled, recovery tokens returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tokens": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid code",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account/two-factor/disable": {
      "post": {
        "operationId": "disableTwoFactor",
        "summary": "Disable 2FA",
        "description": "Disable two-factor authentication.",
        "tags": ["Client - Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "2FA disabled" },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account/email": {
      "put": {
        "operationId": "updateEmail",
        "summary": "Update email address",
        "description": "Update the account email address.",
        "tags": ["Client - Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Email updated" },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account/password": {
      "put": {
        "operationId": "updatePassword",
        "summary": "Change password",
        "description": "Change the account password.",
        "tags": ["Client - Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["current_password", "password", "password_confirmation"],
                "properties": {
                  "current_password": { "type": "string" },
                  "password": { "type": "string" },
                  "password_confirmation": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Password changed" },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account/api-keys": {
      "get": {
        "operationId": "listApiKeys",
        "summary": "List API keys",
        "description": "List all API keys for the account.",
        "tags": ["Client - Account"],
        "responses": {
          "200": {
            "description": "API key list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ApiKey" }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createApiKey",
        "summary": "Create API key",
        "description": "Create a new API key.",
        "tags": ["Client - Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["description"],
                "properties": {
                  "description": { "type": "string" },
                  "allowed_ips": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API key created (secret token returned only once)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiKey" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account/api-keys/{identifier}": {
      "delete": {
        "operationId": "deleteApiKey",
        "summary": "Delete API key",
        "description": "Delete a specific API key.",
        "tags": ["Client - Account"],
        "parameters": [
          {
            "name": "identifier",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "API key deleted" },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account/activity": {
      "get": {
        "operationId": "getAccountActivity",
        "summary": "Get account activity logs",
        "description": "Retrieve account activity and audit logs.",
        "tags": ["Client - Account"],
        "responses": {
          "200": {
            "description": "Activity logs",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account/ssh-keys": {
      "get": {
        "operationId": "listSshKeys",
        "summary": "List SSH keys",
        "description": "List SSH public keys associated with the account.",
        "tags": ["Client - Account"],
        "responses": {
          "200": {
            "description": "SSH key list",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "addSshKey",
        "summary": "Add SSH key",
        "description": "Add an SSH public key to the account.",
        "tags": ["Client - Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "public_key"],
                "properties": {
                  "name": { "type": "string" },
                  "public_key": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SSH key added",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/account/ssh-keys/remove": {
      "post": {
        "operationId": "removeSshKey",
        "summary": "Remove SSH key",
        "description": "Remove an SSH key by fingerprint.",
        "tags": ["Client - Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["fingerprint"],
                "properties": {
                  "fingerprint": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "SSH key removed" },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}": {
      "get": {
        "operationId": "getServerDetails",
        "summary": "Get server details",
        "description": "Retrieve comprehensive information about a specific server.",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "description": "Server identifier (UUID or short ID)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Server details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServerResource" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}/resources": {
      "get": {
        "operationId": "getServerResources",
        "summary": "Get server resource usage",
        "description": "Fetch real-time resource consumption statistics for a server.",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Resource usage statistics",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ResourceUsage" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}/power": {
      "post": {
        "operationId": "controlServerPower",
        "summary": "Control server power",
        "description": "Manage server power state (start, stop, restart, kill).",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["signal"],
                "properties": {
                  "signal": {
                    "type": "string",
                    "enum": ["start", "stop", "restart", "kill"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Power signal sent" },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}/websocket": {
      "get": {
        "operationId": "getWebsocketAuth",
        "summary": "Get WebSocket credentials",
        "description": "Obtain authentication credentials for WebSocket console connection.",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "WebSocket connection details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": { "type": "string" },
                        "socket": { "type": "string", "description": "WebSocket URL" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}/command": {
      "post": {
        "operationId": "sendServerCommand",
        "summary": "Send console command",
        "description": "Execute a command on the server console.",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["command"],
                "properties": {
                  "command": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Command sent" },
          "400": {
            "description": "Server offline",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}/settings/rename": {
      "post": {
        "operationId": "renameServer",
        "summary": "Rename server",
        "description": "Update server display name and description.",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "maxLength": 255 },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Server renamed" },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}/settings/reinstall": {
      "post": {
        "operationId": "reinstallClientServer",
        "summary": "Reinstall server",
        "description": "Re-run installation script (preserves existing files).",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "202": { "description": "Reinstall initiated" },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}/settings/docker-image": {
      "put": {
        "operationId": "updateDockerImage",
        "summary": "Update Docker image",
        "description": "Change the Docker image used by the server.",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["docker_image"],
                "properties": {
                  "docker_image": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Docker image updated" },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "422": {
            "description": "Invalid image",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}/startup": {
      "get": {
        "operationId": "getStartupConfig",
        "summary": "Get startup configuration",
        "description": "Retrieve environment variables and startup command template.",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Startup configuration",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/client/servers/{server}/startup/variable": {
      "put": {
        "operationId": "updateStartupVariable",
        "summary": "Update startup variable",
        "description": "Modify an environment variable for server startup.",
        "tags": ["Client - Servers"],
        "parameters": [
          {
            "name": "server",
