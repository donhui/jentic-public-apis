  "components": {
    "schemas": {
      "ServerResource": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "server" },
          "attributes": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "external_id": { "type": "string" },
              "uuid": { "type": "string" },
              "identifier": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "status": { "type": "string" },
              "suspended": { "type": "boolean" },
              "limits": { "$ref": "#/components/schemas/ServerLimits" },
              "feature_limits": { "$ref": "#/components/schemas/FeatureLimits" },
              "user": { "type": "integer" },
              "node": { "type": "integer" },
              "allocation": { "type": "integer" },
              "nest": { "type": "integer" },
              "egg": { "type": "integer" },
              "container": { "type": "object" },
              "created_at": { "type": "string", "format": "date-time" },
              "updated_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "ServerLimits": {
        "type": "object",
        "properties": {
          "memory": { "type": "integer", "description": "Memory limit in MB" },
          "swap": { "type": "integer", "description": "Swap in MB" },
          "disk": { "type": "integer", "description": "Disk in MB" },
          "io": { "type": "integer", "description": "IO weight (10-1000)" },
          "cpu": { "type": "integer", "description": "CPU limit in %" },
          "threads": { "type": "string" },
          "oom_disabled": { "type": "boolean" }
        }
      },
      "FeatureLimits": {
        "type": "object",
        "properties": {
          "databases": { "type": "integer" },
          "allocations": { "type": "integer" },
          "backups": { "type": "integer" }
        }
      },
      "ServerListResponse": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "list" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ServerResource" }
          },
          "meta": { "$ref": "#/components/schemas/PaginationMeta" }
        }
      },
      "ResourceUsage": {
        "type": "object",
        "properties": {
          "current_state": { "type": "string" },
          "is_suspended": { "type": "boolean" },
          "resources": {
            "type": "object",
            "properties": {
              "memory_bytes": { "type": "integer" },
              "cpu_absolute": { "type": "number" },
              "disk_bytes": { "type": "integer" },
              "network_rx_bytes": { "type": "integer" },
              "network_tx_bytes": { "type": "integer" },
              "uptime": { "type": "integer" }
            }
          }
        }
      },
      "AccountResponse": {
        "type": "object",
        "properties": {
          "object": { "type": "string" },
          "attributes": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "admin": { "type": "boolean" },
              "username": { "type": "string" },
              "email": { "type": "string" },
              "first_name": { "type": "string" },
              "last_name": { "type": "string" },
              "language": { "type": "string" }
            }
          }
        }
      },
      "ApiKey": {
        "type": "object",
        "properties": {
          "identifier": { "type": "string" },
          "description": { "type": "string" },
          "allowed_ips": { "type": "array", "items": { "type": "string" } },
          "last_used_at": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "UserResource": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "user" },
          "attributes": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "external_id": { "type": "string" },
              "uuid": { "type": "string" },
              "username": { "type": "string" },
              "email": { "type": "string" },
              "first_name": { "type": "string" },
              "last_name": { "type": "string" },
              "language": { "type": "string" },
              "root_admin": { "type": "boolean" },
              "2fa": { "type": "boolean" },
              "created_at": { "type": "string", "format": "date-time" },
              "updated_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["email", "username", "first_name", "last_name"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "username": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "password": { "type": "string" },
          "language": { "type": "string", "default": "en" },
          "root_admin": { "type": "boolean" },
          "external_id": { "type": "string" }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "required": ["email", "username", "first_name", "last_name"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "username": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "password": { "type": "string" },
          "language": { "type": "string" },
          "root_admin": { "type": "boolean" },
          "external_id": { "type": "string" }
        }
      },
      "PaginatedUserList": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "list" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserResource" }
          },
          "meta": { "$ref": "#/components/schemas/PaginationMeta" }
        }
      },
      "CreateServerRequest": {
        "type": "object",
        "required": ["name", "user", "egg", "allocation"],
        "properties": {
          "name": { "type": "string" },
          "user": { "type": "integer" },
          "egg": { "type": "integer" },
          "docker_image": { "type": "string" },
          "startup": { "type": "string" },
          "environment": { "type": "object", "additionalProperties": { "type": "string" } },
          "limits": { "$ref": "#/components/schemas/ServerLimits" },
          "feature_limits": { "$ref": "#/components/schemas/FeatureLimits" },
          "allocation": {
            "type": "object",
            "required": ["default"],
            "properties": {
              "default": { "type": "integer" },
              "additional": { "type": "array", "items": { "type": "integer" } }
            }
          }
        }
      },
      "UpdateBuildRequest": {
        "type": "object",
        "required": ["allocation"],
        "properties": {
          "allocation": { "type": "integer" },
          "memory": { "type": "integer" },
          "swap": { "type": "integer" },
          "disk": { "type": "integer" },
          "io": { "type": "integer" },
          "cpu": { "type": "integer" },
          "threads": { "type": "string" },
          "feature_limits": { "$ref": "#/components/schemas/FeatureLimits" },
          "add_allocations": { "type": "array", "items": { "type": "integer" } },
          "remove_allocations": { "type": "array", "items": { "type": "integer" } },
          "oom_disabled": { "type": "boolean" }
        }
      },
      "NodeResource": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "node" },
          "attributes": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "uuid": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "location_id": { "type": "integer" },
              "fqdn": { "type": "string" },
              "scheme": { "type": "string" },
              "behind_proxy": { "type": "boolean" },
              "public": { "type": "boolean" },
              "maintenance_mode": { "type": "boolean" },
              "memory": { "type": "integer" },
              "memory_overallocate": { "type": "integer" },
              "disk": { "type": "integer" },
              "disk_overallocate": { "type": "integer" },
              "upload_size": { "type": "integer" },
              "daemon_listen": { "type": "integer" },
              "daemon_sftp": { "type": "integer" },
              "daemon_base": { "type": "string" },
              "created_at": { "type": "string", "format": "date-time" },
              "updated_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "CreateNodeRequest": {
        "type": "object",
        "required": ["name", "location_id", "fqdn", "memory", "disk"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "location_id": { "type": "integer" },
          "fqdn": { "type": "string" },
          "scheme": { "type": "string", "default": "https" },
          "behind_proxy": { "type": "boolean", "default": false },
          "public": { "type": "boolean", "default": true },
          "daemon_base": { "type": "string" },
          "daemon_sftp": { "type": "integer" },
          "daemon_listen": { "type": "integer" },
          "memory": { "type": "integer" },
          "memory_overallocate": { "type": "integer", "default": 0 },
          "disk": { "type": "integer" },
          "disk_overallocate": { "type": "integer", "default": 0 },
          "upload_size": { "type": "integer" },
          "maintenance_mode": { "type": "boolean", "default": false }
        }
      },
      "PaginatedNodeList": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "list" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/NodeResource" }
          },
          "meta": { "$ref": "#/components/schemas/PaginationMeta" }
        }
      },
      "LocationResource": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "location" },
          "attributes": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "short": { "type": "string" },
              "long": { "type": "string" },
              "created_at": { "type": "string", "format": "date-time" },
              "updated_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "PaginatedLocationList": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "list" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LocationResource" }
          },
          "meta": { "$ref": "#/components/schemas/PaginationMeta" }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "pagination": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "count": { "type": "integer" },
              "per_page": { "type": "integer" },
              "current_page": { "type": "integer" },
              "total_pages": { "type": "integer" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": { "type": "string" },
                "status": { "type": "string" },
                "detail": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Client API key (ptlc_...) or Application API key (ptla_...) passed as Bearer token. Additional required header: Accept: Application/vnd.pterodactyl.v1+json"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}