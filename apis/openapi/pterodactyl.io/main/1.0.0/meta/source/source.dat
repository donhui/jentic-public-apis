                "properties": {
                  "short": { "type": "string", "minLength": 3, "maxLength": 60 },
                  "long": { "type": "string", "minLength": 3, "maxLength": 191 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Location created",
