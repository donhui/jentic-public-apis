{
  "openapi": "3.0.0",
  "info": {
    "contact": {},
    "description": "Captures Audit Log Information",
    "title": "Auditing",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/absie0873/Auditting/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://virtserver.swaggerhub.com/absie0873/Auditting/1.0.0"
    }
  ],
  "paths": {
    "/audit": {
      "post": {
        "responses": {
          "200": {
            "description": "Audit captured successfully"
          }
        },
        "tags": [
          "audit"
        ],
        "description": "persist the audit log into a file in the json format received. the file will be rotated on a daily basis. The persistance mechanism may be changed at a later date so the persistence element of the solution will be a replaceable.",
        "operationId": "post-audit",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuditLog"
              }
            }
          },
          "description": "The audit log information",
          "required": true
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuditLog": {
        "properties": {
          "action": {
            "description": "the action being logged",
            "enum": [
              "Download",
              "Upload",
              "VirusCheck",
              "Login",
              "Notification"
            ],
            "type": "string"
          },
          "completed": {
            "description": "the time the action completed",
            "format": "date-time",
            "type": "string"
          },
          "filename": {
            "description": "the name of the file being processed where relevant to the action",
            "type": "string"
          },
          "outcome": {
            "description": "indicates whether or not the action completed successfully",
            "enum": [
              "Passed",
              "Failed"
            ],
            "type": "string"
          },
          "session": {
            "description": "the unique session id of the current interaction with the user",
            "type": "string"
          },
          "srn": {
            "description": "the set reference number",
            "type": "string"
          },
          "started": {
            "description": "start date and time that the action was initiated",
            "format": "date-time",
            "type": "string"
          },
          "user": {
            "description": "the unique id of the user (or SYSTEM if initiated by the system)",
            "type": "string"
          }
        },
        "type": "object"
      }
    }
  },
  "tags": [
    {
      "name": "audit"
    }
  ]
}