{
  "openapi": "3.0.0",
  "info": {
    "contact": {},
    "description": "Tracks whether a user has accepted the latest terms and conditions",
    "title": "Terms and Conditions",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/absie0873/Access-Tracking/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://virtserver.swaggerhub.com/absie0873/Access-Tracking/1.0.0"
    }
  ],
  "paths": {
    "/terms-and-conditions": {
      "post": {
        "parameters": [
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "format": "date",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request Successful"
          },
          "500": {
            "description": "The system cannot hold more than one future dated terms and conditions"
          }
        },
        "tags": [
          "terms-and-conditions"
        ],
        "description": "Add the start date that the new terms and conditions becomes effective. By default the end date is set to 31-12-9999\nThe end date of the current terms and conditions is updated to new startDate - 1\nThere will only be one future dated terms and conditions.",
        "operationId": "newTerms"
      }
    },
    "/terms-and-conditions/accept": {
      "post": {
        "parameters": [
          {
            "in": "query",
            "name": "id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request Successful"
          }
        },
        "tags": [
          "terms-and-conditions"
        ],
        "description": "Logs that the user has accepted the current effective (i.e. version where current date between start date and end date) terms of conditions\n",
        "operationId": "acceptTandC"
      }
    },
    "/terms-and-conditions/show": {
      "get": {
        "parameters": [
          {
            "description": "unique identifier of the user",
            "in": "query",
            "name": "id",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            },
            "description": "Request Successful"
          }
        },
        "tags": [
          "terms-and-conditions"
        ],
        "description": "Checks whether the user has accepted the current effective (i.e. version where current date between start date and end date) terms and conditions\nThis is achieved by querying the user_accept_tandc table.\n",
        "operationId": "showTandC"
      }
    }
  },
  "components": {
    "schemas": {
      "Status": {
        "properties": {
          "mustAcceptNewTandC": {
            "type": "boolean"
          }
        },
        "required": [
          "mustAcceptNewTandC"
        ],
        "type": "object"
      }
    }
  },
  "tags": [
    {
      "name": "terms-and-conditions"
    }
  ]
}