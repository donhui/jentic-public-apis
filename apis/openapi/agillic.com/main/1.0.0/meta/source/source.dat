        "summary": "Withdraw consent",
        "description": "Withdraw a consent granted by the recipient.",
        "tags": ["App Push"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["clientAppId", "type"],
                "properties": {
                  "clientAppId": { "type": "string" },
                  "type": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Consent withdrawn" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
