    "/export/files/list": {
      "get": {
        "operationId": "listExportFiles",
        "summary": "List export files",
        "description": "List items and folders at a specified export location.",
        "tags": ["Export"],
        "parameters": [
          {
            "name": "folder",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Files listed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AssetItem" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/export/files/download": {
      "get": {
        "operationId": "downloadExportFile",
        "summary": "Download export file",
        "description": "Download a file. Maximum file size is 1GB.",
        "tags": ["Export"],
        "parameters": [
          {
            "name": "file",
            "in": "query",
            "required": true,
            "description": "Path of the file to download",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "File downloaded",
            "content": {
              "application/octet-stream": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/export/files/delete": {
      "delete": {
        "operationId": "deleteExportFile",
        "summary": "Delete export file",
        "description": "Delete a file or folder.",
        "tags": ["Export"],
        "parameters": [
          {
            "name": "file",
            "in": "query",
            "required": true,
            "description": "Path of the file to delete",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "File deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/export/activity/:execute": {
      "post": {
        "operationId": "executeActivityExport",
        "summary": "Execute activity export",
        "description": "Execute an activity export. Maximum 4-hour export window, from parameter no older than 7 days.",
        "tags": ["Export"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ActivityExportRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Export started",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/export/activity/{taskId}": {
      "get": {
        "operationId": "readExportPage",
        "summary": "Read export page",
        "description": "Returns paginated export results.",
        "tags": ["Export"],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "pageStart",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Export page retrieved",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/export/activity/task/{taskId}": {
      "get": {
        "operationId": "getExportTaskStatus",
        "summary": "Get export task status",
        "description": "Returns processing or completion status of an export task.",
        "tags": ["Export"],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Task status retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskStatus" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OAuthTokenResponse": {
        "type": "object",
        "properties": {
          "token_type": {
            "type": "string",
            "example": "bearer"
          },
          "access_token": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer",
            "example": 7200
          }
        }
      },
      "Recipient": {
        "type": "object",
        "properties": {
          "recipientId": {
            "type": "string"
          },
          "personData": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "RecipientRequest": {
        "type": "object",
        "properties": {
          "personData": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "BulkResponse": {
        "type": "object",
        "properties": {
          "created": { "type": "integer" },
          "updated": { "type": "integer" },
          "warnings": { "type": "integer" },
          "errors": { "type": "integer" }
        }
      },
      "AsyncBatchRequest": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "AsyncDeleteRequest": {
        "type": "object",
        "properties": {
          "recipientIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "TaskResponse": {
        "type": "object",
        "properties": {
          "taskId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "TaskStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["processing", "completed"]
          },
          "details": {
            "type": "object"
          }
        }
      },
      "OneToManyTable": {
        "type": "object",
        "properties": {
          "tableId": { "type": "string" },
          "records": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "eventId": { "type": "string" },
          "name": { "type": "string" },
          "achieved": { "type": "boolean" }
        }
      },
      "Promotion": {
        "type": "object",
        "properties": {
          "promotionId": { "type": "string" },
          "propositions": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "TargetGroup": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "StaticTargetGroupRequest": {
        "type": "object",
        "properties": {
          "targetGroupName": { "type": "string" },
          "recipientIds": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 100
          }
        }
      },
      "CommunicationLog": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date-time" },
          "type": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "GlobalData": {
        "type": "object",
        "properties": {
          "NAME": { "type": "string" },
          "TYPE": { "type": "string" },
          "VALUE": { "type": "string" },
          "DESCRIPTION": { "type": "string" }
        }
      },
      "GlobalDataTable": {
        "type": "object",
        "properties": {
          "tableId": { "type": "string" },
          "records": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "QueueFlowStatus": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "queuedCount": { "type": "integer" },
          "activeCount": { "type": "integer" }
        }
      },
      "QueueFlowSpec": {
        "type": "object",
        "properties": {
          "preGlobalDataUpdates": { "type": "object" },
          "postGlobalDataUpdates": { "type": "object" }
        }
      },
      "RecipientsWithContext": {
        "type": "object",
        "properties": {
          "schemaName": { "type": "string" },
          "recipients": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "recipientId": { "type": "string" },
                "contextData": { "type": "object" }
              }
            }
          }
        }
      },
      "TargetGroupMetadata": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "static": { "type": "boolean" },
          "global": { "type": "boolean" }
        }
      },
      "GlobalDataMetadata": {
        "type": "object",
        "properties": {
          "NAME": { "type": "string" },
          "TYPE": { "type": "string" },
          "DESCRIPTION": { "type": "string" }
        }
      },
      "DeviceRegistration": {
        "type": "object",
        "required": ["appInstallationId", "clientAppId", "osName", "pushNotificationToken"],
        "properties": {
          "appInstallationId": { "type": "string" },
          "clientAppId": { "type": "string" },
          "osName": { "type": "string" },
          "pushNotificationToken": { "type": "string" },
          "clientAppVersion": { "type": "string" },
          "deviceModel": { "type": "string" },
          "osVersion": { "type": "string" },
          "modelDimX": { "type": "integer" },
          "modelDimY": { "type": "integer" },
          "consent": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      },
      "DeviceUnregistration": {
        "type": "object",
        "required": ["appInstallationId", "clientAppId", "osName"],
        "properties": {
          "appInstallationId": { "type": "string" },
          "clientAppId": { "type": "string" },
          "osName": { "type": "string" },
          "clientAppVersion": { "type": "string" },
          "deviceModel": { "type": "string" },
          "osVersion": { "type": "string" },
          "pushNotificationToken": { "type": "string" }
        }
      },
      "ConsentRequest": {
        "type": "object",
        "required": ["clientAppId", "type"],
        "properties": {
          "clientAppId": { "type": "string" },
          "type": { "type": "string" },
          "validUntil": { "type": "string", "format": "date" }
        }
      },
      "FeedbackRequest": {
        "type": "object",
        "required": ["reportId", "clientAppId", "feedbackStatus"],
        "properties": {
          "reportId": { "type": "string" },
          "clientAppId": { "type": "string" },
          "feedbackStatus": { "type": "string" },
          "metadata": { "type": "object" }
        }
      },
      "AssetItem": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "isFolder": { "type": "boolean" },
          "referenced": { "type": "boolean" }
        }
      },
      "ActivityExportRequest": {
        "type": "object",
        "required": ["fileType", "from", "to"],
        "properties": {
          "fileType": { "type": "string" },
          "from": { "type": "string", "format": "date-time" },
          "to": { "type": "string", "format": "date-time" },
          "configuration": { "type": "object" }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth2 bearer token obtained from /oauth2/token endpoint"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Base64-encoded developer_key:developer_secret (not recommended)"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}