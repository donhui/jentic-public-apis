    "/recipients/{recipientId}/events/{eventId}/:achieveEvent": {
      "post": {
        "operationId": "achieveEvent",
        "summary": "Achieve event",
        "description": "Trigger event achievement for a recipient.",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
