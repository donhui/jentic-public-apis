{
  "openapi": "3.0.3",
  "info": {
    "title": "Agillic API",
    "version": "1.0.0",
    "description": "Agillic is a native customer marketing platform enabling brands to connect with audiences across channels through data-driven communication at scale. The API provides endpoints for managing recipients, global data, flows, assets, discovery metadata, app push notifications, and data exports.",
    "x-jentic-source-url": "https://developers.agillic.com/"
  },
  "servers": [
    {
      "url": "https://api-eu1.agillic.net",
      "description": "Agillic EU1 API server"
    }
  ],
  "paths": {
    "/oauth2/token": {
      "post": {
        "operationId": "getOAuthToken",
        "summary": "Get OAuth2 token",
        "description": "Obtain a bearer token using client credentials. Token has a 2-hour TTL.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "client_id", "client_secret"],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": ["client_credentials"]
                  },
                  "client_id": {
                    "type": "string",
                    "description": "Developer Key"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "Developer Secret"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token issued successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid credentials"
          }
        },
        "security": []
      }
    },
    "/recipients": {
      "get": {
        "operationId": "listRecipients",
        "summary": "List recipients",
        "description": "List recipient collections with optional filtering.",
        "tags": ["Recipients"],
        "parameters": [
          {
            "name": "objectResponse",
            "in": "query",
            "schema": { "type": "boolean" }
          },
          {
            "name": "documentId",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "pageStart",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "RSQL filter expression",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipients retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Recipient" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createRecipient",
        "summary": "Create recipient",
        "description": "Create a new recipient.",
        "tags": ["Recipients"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecipientRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Recipient created" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/{recipientId}": {
      "get": {
        "operationId": "getRecipient",
        "summary": "Get recipient",
        "description": "Retrieve a specific recipient by ID.",
        "tags": ["Recipients"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "personDataFields",
            "in": "query",
            "description": "Specific person data fields to return",
            "schema": { "type": "array", "items": { "type": "string" } }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipient retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Recipient" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateRecipient",
        "summary": "Update recipient",
        "description": "Update recipient person data.",
        "tags": ["Recipients"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecipientRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Recipient updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteRecipient",
        "summary": "Delete recipient",
        "description": "Remove a recipient.",
        "tags": ["Recipients"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Recipient deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/:batch": {
      "post": {
        "operationId": "batchUpsertRecipients",
        "summary": "Batch create/update recipients",
        "description": "Bulk create or update recipients (max 1000 recipients, 5MB).",
        "tags": ["Recipients"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/RecipientRequest" }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch operation completed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BulkResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/v2/:upsert": {
      "post": {
        "operationId": "asyncBatchUpsertRecipients",
        "summary": "Async batch upsert recipients",
        "description": "Asynchronous batch upsert of recipients.",
        "tags": ["Recipients"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AsyncBatchRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Task accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/v2/:delete": {
      "post": {
        "operationId": "asyncBatchDeleteRecipients",
        "summary": "Async batch delete recipients",
        "description": "Asynchronous batch delete of recipients.",
        "tags": ["Recipients"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AsyncDeleteRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Task accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaskResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/{recipientId}/oneToManyTables": {
      "get": {
        "operationId": "listOneToManyTables",
        "summary": "List One-to-Many tables",
        "description": "List all One-to-Many tables for a recipient.",
        "tags": ["One-to-Many"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Tables listed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/{recipientId}/oneToManyTables/{tableId}": {
      "get": {
        "operationId": "getOneToManyTable",
        "summary": "Get One-to-Many table",
        "description": "Retrieve a specific One-to-Many table's records for a recipient.",
        "tags": ["One-to-Many"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Table records retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OneToManyTable" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/{recipientId}/oneToManyTables/{tableId}/:batchUpdateRecords": {
      "post": {
        "operationId": "batchUpdateOneToManyRecords",
        "summary": "Batch update One-to-Many records",
        "description": "Update multiple records in a One-to-Many table.",
        "tags": ["One-to-Many"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "type": "object" }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Records updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/{recipientId}/oneToManyTables/{tableId}/:batchDeleteRecords": {
      "post": {
        "operationId": "batchDeleteOneToManyRecords",
        "summary": "Batch delete One-to-Many records",
        "description": "Delete multiple records from a One-to-Many table.",
        "tags": ["One-to-Many"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Records deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/{recipientId}/oneToManyTables/{tableId}/:truncateTable": {
      "post": {
        "operationId": "truncateOneToManyTable",
        "summary": "Truncate One-to-Many table",
        "description": "Clear all records from a One-to-Many table for a recipient.",
        "tags": ["One-to-Many"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tableId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Table truncated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/v2/oneToManyTables/:upsert": {
      "post": {
        "operationId": "asyncUpsertOneToManyRecords",
        "summary": "Async upsert One-to-Many records",
