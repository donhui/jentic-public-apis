        "responses": {
          "200": { "description": "Event achieved" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/{recipientId}/events/{eventId}/:achieveWithContext": {
      "post": {
        "operationId": "achieveEventWithContext",
        "summary": "Achieve event with context",
        "description": "Achieve event with contextual data for a recipient.",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "recipientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "eventId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Contextual data as JSON"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Event achieved with context" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/recipients/v2/events/:achieve": {
      "post": {
        "operationId": "asyncAchieveEvent",
        "summary": "Async achieve event",
        "description": "Asynchronous event achievement with context.",
        "tags": ["Events"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AsyncBatchRequest" }
