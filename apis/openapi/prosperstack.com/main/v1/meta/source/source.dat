        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlowSession"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "$ref": "#/components/responses/Error"
          },
          "404": {
            "description": "Not Found",
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
