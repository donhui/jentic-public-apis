    "/payments": {
      "get": {
        "summary": "List payments",
        "operationId": "listPayments",
        "tags": [
          "payments"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "Filter payments by type",
            "schema": {
              "type": "string",
              "enum": [
                "saved",
                "deflected"
              ]
            }
          },
          {
            "name": "subscriber_id",
            "in": "query",
            "description": "Filter payments by subscriber ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "subscription_id",
            "in": "query",
            "description": "Filter payments by subscription ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "platform_subscriber_id",
            "in": "query",
            "description": "Filter payments by platform subscriber ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "platform_subscription_id",
            "in": "query",
            "description": "Filter payments by platform subscription ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "paid_at",
