    "/offer_links": {
      "get": {
        "summary": "List offer links",
        "operationId": "listOfferLinks",
        "tags": [
          "offer-links"
        ],
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor to retrieve",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Limit of offer links to return",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "data"
                  ],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/OfferLink"
                      }
                    },
                    "next_cursor": {
                      "$ref": "#/components/schemas/Cursor"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "$ref": "#/components/responses/Error"
          }
        }
      },
      "post": {
        "summary": "Create an offer link",
        "description": "This call requires an offer ID and a subscription ID, either as `subscription_id` from ProsperStack or `platform_subscription_id` from your connected subscription platform, e.g. Stripe.",
        "operationId": "createOfferLink",
        "tags": [
          "offer-links"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OfferLinkCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "headers": {
              "Location": {
                "description": "The URL of the created offer link",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OfferLink"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "$ref": "#/components/responses/Error"
          },
          "401": {
            "description": "Unauthorized",
            "$ref": "#/components/responses/Error"
          }
        }
      }
    },
    "/offer_links/{id}": {
      "get": {
        "summary": "Retrieve an offer link",
