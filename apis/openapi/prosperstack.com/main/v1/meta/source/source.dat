  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "schemas": {
      "Event": {
        "type": "object",
        "required": [
          "id",
          "event",
          "data",
          "created_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "evt_ujO4n2g2QbWtGUVg1zJSbC5I"
          },
          "event": {
            "type": "string",
            "enum": [
              "flow_session_completed"
            ],
            "example": "flow_session_completed"
          },
          "data": {
            "type": "object",
            "description": "The payload of the event."
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Cursor": {
        "type": "string",
        "example": "null",
        "nullable": true
      },
      "Error": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "CustomerPortalSession": {
        "type": "object",
        "required": [
          "id",
          "url",
          "created_at",
          "expires_at"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "psess_ShhcPknbB0aaPNk2jyOQajsH"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "The URL of the created customer portal session",
            "example": "https://app.prosperstack.com/p/portal/acct_6Ggu2ID13p2iPA3PPEP1e6Ps/session/psess_ShhcPknbB0aaPNk2jyOQajsH"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Flow": {
        "type": "object",
        "required": [
          "id",
          "name",
          "created_at",
          "updated_at"
