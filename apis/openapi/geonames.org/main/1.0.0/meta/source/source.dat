    "/srtm1JSON": {
      "get": {
        "operationId": "getelevationsrtm1",
        "summary": "Get SRTM1 elevation",
        "description": "Returns elevation in meters using SRTM1 data (approximately 30m resolution).",
        "tags": [
          "Elevation"
        ],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "lng",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "username",
            "in": "query",
            "required": true,
