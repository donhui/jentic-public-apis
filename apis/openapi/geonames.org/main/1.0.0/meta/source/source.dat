    "/extendedFindNearby": {
      "get": {
        "operationId": "extendedFindNearby",
        "summary": "Extended find nearby",
        "description": "Returns the most detailed information available for a given point. In the US it returns address, street, neighborhood, and city. In other countries it returns the closest toponym.",
        "tags": [
          "Geocoding"
        ],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "description": "Latitude",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lng",
            "in": "query",
            "required": true,
            "description": "Longitude",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "username",
            "in": "query",
            "required": true,
            "description": "Your GeoNames username",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Extended nearby information (XML)",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
