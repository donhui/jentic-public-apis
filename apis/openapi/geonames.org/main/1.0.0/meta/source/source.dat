{
  "openapi": "3.0.3",
  "info": {
    "title": "GeoNames API",
    "description": "GeoNames geographical database web services providing geocoding, reverse geocoding, postal code search, elevation data, timezone information, and more.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.geonames.org/export/web-services.html"
  },
  "servers": [
    {
      "url": "https://api.geonames.org",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "PostalCode",
      "description": "Postal code search and lookup"
    },
    {
      "name": "Geocoding",
      "description": "Forward and reverse geocoding"
    },
    {
      "name": "Place",
      "description": "Place and feature information"
    },
    {
      "name": "Country",
      "description": "Country information"
    },
    {
      "name": "Elevation",
      "description": "Elevation data services"
    },
    {
      "name": "Timezone",
      "description": "Timezone information"
    }
  ],
  "paths": {
    "/postalCodeSearchJSON": {
      "get": {
        "operationId": "searchpostalcodes",
        "summary": "Search postal codes",
        "description": "Returns a list of postal codes and places for the placename/postalcode query.",
        "tags": [
          "PostalCode"
        ],
        "parameters": [
          {
            "name": "postalcode",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Postal code to search for"
          },
          {
            "name": "placename",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Place name to search for"
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "ISO country code"
          },
          {
            "name": "countryBias",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Country bias for results"
          },
          {
            "name": "maxRows",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Maximum number of results"
          },
          {
            "name": "style",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "SHORT",
                "MEDIUM",
                "LONG",
                "FULL"
              ]
            }
          },
          {
            "name": "operator",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "AND",
                "OR"
              ]
            }
          },
          {
            "name": "charset",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "isReduced",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "east",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "west",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "north",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "south",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "GeoNames username for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostalCodeSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing username",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/postalCodeLookupJSON": {
      "get": {
        "operationId": "lookuppostalcode",
        "summary": "Lookup postal code",
        "description": "Returns places for a given postal code, sorted by postal code and name.",
        "tags": [
          "PostalCode"
        ],
        "parameters": [
          {
            "name": "postalcode",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maxRows",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "charset",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostalCodeSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/findNearbyPostalCodesJSON": {
      "get": {
        "operationId": "findnearbypostalcodes",
        "summary": "Find nearby postal codes",
        "description": "Returns nearby postal codes sorted by distance for a given location or postal code.",
        "tags": [
          "PostalCode"
        ],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "lng",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "postalcode",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "country",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Radius in km (max 30)"
          },
          {
            "name": "maxRows",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "style",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "SHORT",
                "MEDIUM",
                "LONG",
                "FULL"
              ]
            }
          },
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostalCodeSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/findNearbyPlaceNameJSON": {
      "get": {
        "operationId": "findnearbyplacename",
        "summary": "Find nearby place name",
        "description": "Returns the closest populated place for given coordinates.",
        "tags": [
          "Geocoding"
        ],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
