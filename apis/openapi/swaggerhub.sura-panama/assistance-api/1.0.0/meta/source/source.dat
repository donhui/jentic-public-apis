          },
          "medicalCenter": {
            "description": "Centro Medico",
            "type": "string"
          },
          "commentsDetail": {
            "description": "Detalle o Comentarios",
            "type": "string"
          },
          "deathInjuredInsured": {
            "description": "Hay Fallecidos Asegurado? (Y o N)",
            "type": "string",
            "example": "N"
          },
          "quantityDeathInjuredInsured": {
            "description": "Cantidad de Fallecidos Asegurado",
            "type": "number"
          },
          "deathInjuredThird": {
            "description": "Hay Fallecidos Afectado? (Y o N)",
            "type": "string",
            "example": "N"
          },
          "quantityDeathInjuredThird": {
            "description": "Cantidad de Fallecidos Afectado",
            "type": "number"
          },
          "expressAdjust": {
            "description": "Ajuste Express? (Y o N)",
            "type": "string"
          },
          "payExpressAdjust": {
            "description": "Monto del Ajuste",
            "type": "string",
            "format": "10.00"
          },
          "lawyerInjured": {
            "$ref": "#/components/schemas/lawyerDetail"
          },
          "agentInjured": {
            "$ref": "#/components/schemas/AgentDetail"
          }
        }
      },
      "lawyerDetail": {
        "description": "Informacion del Abogado",
        "properties": {
          "pid": {
            "description": "Identificacion del Abogado",
            "type": "string"
          },
          "name": {
            "description": "Nombre Completo del Abogado",
            "type": "string"
          },
          "contact": {
            "type": "array",
            "items": {
              "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/PeopleContext/1.0.0#/components/schemas/Contact"
            }
          }
        }
      },
      "AgentDetail": {
        "description": "Informaci\u00f3n del Agente del Lesionado (si existe)",
        "properties": {
          "pid": {
            "description": "Identificacion del Abogado",
            "type": "string"
          },
          "name": {
