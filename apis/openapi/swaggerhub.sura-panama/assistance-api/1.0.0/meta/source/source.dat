{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/SURA_PANAMA/assistance-api/1.0.0"
    }
  ],
  "info": {
    "description": "Permite gestionar la trazabilidad de las distintas asistencias que son reportados por los Proveedor asociados a estas acciones. Pueden ser de distintos tipos p.ej. asistencia-vial para siniestros, asistencia en el hogar, asistencia juridica etc.",
    "version": "1.0.0",
    "title": "Assistance API",
    "contact": {
      "email": "esanchez@sura.com.pa"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/SURA_PANAMA/assistance-api/1.0.0/swagger.json"
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/assistance-api/api/movilidad/assistances": {
      "post": {
        "summary": "Cargar las Asistencias Viales",
        "tags": [
          "AssitanceClaim"
        ],
        "operationId": "cargarAsistencias",
        "description": "Permite almacenar todas los reporte de asistencias viales gestionador por el Proveedor.",
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Type"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application-Flow"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Trace-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-User"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RoadAssistanceRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Asistencia creada exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoadAssistanceResponse"
                }
              }
            }
          },
          "500": {
            "description": "Respuesta generica para distintos tipos de errores controlados \n(ej: 400, 401, 403, 404, 500, 502, 503).\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/assistance-api/api/assistances/ping": {
      "get": {
        "summary": "Ping endpoint",
        "description": "Ping endpoint, that ensures your application is up and running",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "pong"
                }
              }
            }
          },
          "500": {
            "description": "Error"
          }
        }
      }
    },
    "/assistance-api/api/assistances/health-check": {
      "get": {
        "summary": "Health check endpoint",
        "description": "Health check endpoint, that run registered checkers",
        "responses": {
          "200": {
            "description": "All checkers were in success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/schemas/SuccessHealthCheck"
                }
              }
            }
          },
          "500": {
            "description": "At least one of the checkers was in error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/schemas/ErrorHealthCheck"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY"
      }
    },
    "schemas": {
      "RoadAssistanceRequest": {
        "type": "object",
        "description": "Parametros de Entrada para manejar la Asistencia de tipo Vial",
        "properties": {
          "registrationDate": {
            "description": "Fecha de Registro que maneja el Proveedor de Asistencia",
            "type": "string",
            "format": "date-time",
            "example": "2016-08-29T09:12:33.001Z"
          },
          "recordId": {
            "description": "Numero de Expediente manejado por el Proveedor de Asistencia",
            "type": "number",
            "example": 12345678
          },
          "statusRecord": {
            "description": "Estado del Expediente",
            "type": "string",
            "example": "PENDIENTE POR LA ASEGURADORA"
          },
          "insurance": {
            "$ref": "#/components/schemas/Insurance"
          },
          "accident": {
            "$ref": "#/components/schemas/Accident"
          },
          "insuranceThird": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InsuranceThirdDetail"
            }
          },
          "injuredDetail": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InjuredDetail"
            }
          }
        }
      },
      "RoadAssistanceResponse": {
        "type": "object",
        "description": "Parametros de Salida para manejar la Asistencia de tipo Vial",
        "properties": {
          "status": {
            "description": "Status del Mensaje (OK / ERR)",
            "type": "string",
            "example": "OK"
          },
          "description": {
            "type": "string",
            "example": "Creacion Exitosa"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number",
                "example": 13
              },
              "recordId": {
                "type": "number",
                "example": 908765
              },
              "registrationDate": {
                "type": "string",
                "format": "date",
                "example": "2025-12-11T08:00:00.000Z"
              }
            }
          }
        }
      },
      "Insurance": {
        "description": "Contexto del Asegurado",
        "properties": {
          "insuranceName": {
            "description": "Nombre de la Aseguradora",
            "type": "string",
            "example": "SURA"
          },
          "isOwner": {
            "description": "Es Propietario del Auto",
            "type": "string",
            "example": "Y-Si N-No"
          },
          "policyNumber": {
            "description": "Numero de Poliza del Asegurado"
          },
          "pid": {
            "description": "Identificaci\u00f3n del Asegurado",
            "type": "string",
            "example": "8-990-1234"
          },
          "givenName": {
            "description": "Nombre del Asegurado",
            "type": "string",
            "example": "Pedro Alberto"
          },
          "lastName": {
            "description": "Apellido del Asegurado",
            "type": "string",
            "example": "Rodriguez Perez"
          },
          "endorsementPlan": {
            "description": "Plan del Endoso",
            "type": "string",
            "example": "FULL EXTRAS PREMIUM"
          },
          "policyType": {
            "description": "Tipo de Poliza",
            "type": "string",
            "example": "COBERTURA COMPLETA; DANOS A TERCERO; SOAT"
          },
          "driver": {
            "$ref": "#/components/schemas/Driver"
          },
          "vehicle": {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/ProductContext/1.0.0#/components/schemas/VehicleCar"
          },
          "locateDanger": {
            "description": "Codigo o Numero donde estan los da\u00f1os con respecto al mapa del vehiculo. Si son varios separar por \"Punto y Coma\"",
            "type": "string",
            "example": "11;15;18;20"
          },
          "comentsAdditional": {
            "description": "Texto de Comentarios Adicionales",
            "type": "string",
            "example": "Se da\u00f1o el guardafango"
          }
        }
      },
      "Accident": {
        "description": "Contexto del Objeto Accidente - Informacion del mismo",
        "properties": {
          "documentAccident": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentAccident"
            }
          },
          "isPlaceAccident": {
            "description": "Este es el Lugar del Accidente (Y o N)",
            "type": "string"
          },
          "claimDate": {
            "description": "Fecha del Siniestro o Accidente",
            "type": "string",
            "format": "date",
            "example": "2016-08-29"
          },
          "hourClaimDate": {
            "description": "Hora del Siniestro o Accidente",
            "type": "string",
            "format": "time",
            "example": "09:12:33.001Z"
          },
          "collisionType": {
            "description": "Tipo de Siniestro",
            "type": "string"
          },
          "crashType": {
            "description": "Tipo de Colision (Mayo o Menor)",
            "type": "string"
          },
          "accidentPurpose": {
            "description": "Causa del Siniestro",
            "type": "string"
          },
          "descriptionAccident": {
            "description": "Descripcion o Narraci\u00f3n de los Hechos",
            "type": "string"
          },
          "location": {
            "$ref": "#/components/schemas/locationDetail"
          },
          "trafficPolicyExist": {
            "description": "Oficial Presente (Y o N)",
            "type": "string"
          },
          "ticketTrafficExist": {
            "description": "Hay Boletas (Y o N)",
            "type": "string"
          },
          "ticketTrafficNumber": {
            "description": "Numero de Boleta",
            "type": "number"
          },
          "hearingDate": {
            "description": "Fecha de la Audiencia",
            "type": "string",
            "format": "date",
            "example": "2025-10-25"
          },
          "courtDate": {
            "description": "Fecha del Juzgado",
            "type": "string",
            "format": "date",
            "example": "2025-10-25"
          },
          "alcoholLevelExist": {
            "description": "Estaba Alcoholizado (Y o N)",
            "type": "string",
            "example": "N"
          },
          "fud": {
            "description": "FUD de Asistencia",
            "type": "string"
          },
          "thirdPartyExist": {
            "description": "Hay Terceros (Y o N)",
            "type": "string"
          },
          "injuriesExistInsured": {
            "description": "Hay Lesionados Asegurado (Y o N)",
            "type": "string"
          },
          "quantityInjuredInsured": {
            "description": "Cantidad de Lesionados Asegurado",
            "type": "number"
          },
          "injuriesExistThird": {
            "description": "Hay Lesionados Tercero (Y o N)",
            "type": "string"
          },
          "quantityInjured": {
            "description": "Cantidad de Lesionados",
            "type": "number"
          },
          "quantityInjuredThird": {
            "description": "Cantidad de Lesionados Tercero",
            "type": "number"
          },
          "responsabilityAccident": {
            "description": "Quien Asume Responsabilidad",
            "type": "string"
          },
          "applyDanger": {
            "description": "Tiene Da\u00f1os (Y o N)",
            "type": "string"
          },
          "locateDanger": {
            "description": "Codigo o Numero donde estan los da\u00f1os con respecto al mapa del vehiculo. Si son varios separar por \"Punto y Coma\"",
            "type": "string"
          },
          "comentsAdditional": {
            "description": "Texto de Comentarios Adicionales",
            "type": "string"
          },
          "inspectorDetail": {
            "$ref": "#/components/schemas/InspectorDetail"
          }
        }
      },
      "InsuranceThirdDetail": {
        "description": "Contexto del Tercero",
        "properties": {
          "thirdType": {
            "description": "Tipo de Tercero : Testigo; Conductor; Propiedad",
            "type": "string",
            "example": "Conductor"
          },
          "insuranceThirdCompany": {
            "description": "Compa\u00f1ia del Seguro del Tercero",
            "type": "string"
          },
          "pid": {
            "description": "Identificaci\u00f3n del Asegurado",
            "type": "string",
            "example": "8-990-1234"
          },
          "givenName": {
            "description": "Primer y Segundo Nombre",
            "type": "string",
            "example": "Elvira"
          },
          "lastName": {
            "description": "Primer y Segundo Apellido",
            "type": "string",
            "example": "Perez"
          },
          "contactsThird": {
            "description": "Lista de medios de contacto de la persona. Ejemplo: mail, tel\u00e9fono, etc.",
            "type": "array",
            "items": {
              "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/PeopleContext/1.0.0#/components/schemas/Contact"
            }
          },
          "driverThird": {
            "$ref": "#/components/schemas/Driver"
          },
          "vehicleThird": {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/ProductContext/1.0.0#/components/schemas/VehicleCar"
          },
          "locateDanger": {
            "description": "Codigo o Numero donde estan los da\u00f1os con respecto al mapa del vehiculo. Si son varios separar por \"Punto y Coma\"",
            "type": "string",
            "example": "11;15;18;20"
          },
          "comentsAdditional": {
            "description": "Texto de Comentarios Adicionales",
            "type": "string",
            "example": "Se da\u00f1o el guardafango"
          }
        }
      },
      "locationDetail": {
        "description": "Localizacion del Accidente",
        "properties": {
          "region": {
            "description": "Provincia o Region (Catalogo)",
            "type": "string",
            "example": "08"
          },
          "district": {
            "description": "Distrito (Catalogo)",
            "type": "string",
            "example": "08"
          },
          "zone": {
            "description": "Corregimiento (Catalogo)",
            "type": "string",
            "example": "0890"
          },
          "address": {
            "description": "Direccion Completa",
            "type": "string",
            "example": "Villa Lobo"
          }
        }
      },
      "Driver": {
        "description": "Contexto del Conductor",
        "properties": {
          "givenName": {
            "description": "Primer y Segundo Nombre",
            "type": "string",
            "example": "Luis Alberto"
          },
          "lastName": {
            "description": "Primer y Segundo Apellido",
            "type": "string",
            "example": "Ortiz Perez"
          },
          "peopleType": {
            "description": "Indica si se trata de una persona natural o jur\u00eddica.",
            "type": "string",
            "example": "LEGAL o NATURAL"
          },
          "gender": {
            "description": "Genero de la Persona",
            "type": "string",
            "example": "M-Masculino | F-Femenino"
          },
          "birthDate": {
            "description": "Fecha de nacimiento de la persona natural o fecha de creaci\u00f3n de la empresa.",
            "type": "string",
            "format": "date",
            "example": "2010-02-03"
          },
          "licenseType": {
            "description": "Tipo de Licencia",
            "type": "string",
            "example": "C"
          },
          "licenseNumber": {
            "description": "Numero de Licencia",
            "type": "string",
            "example": "87dkksjs097"
          },
          "expirationDateLicense": {
            "description": "Fecha de Expiraci\u00f3n o Vencimiento de la Licencia",
            "type": "string",
            "format": "date",
            "example": "1998-02-03"
          },
          "contacts": {
            "description": "Lista de medios de contacto de la persona. Ejemplo: mail, tel\u00e9fono, etc.",
            "type": "array",
            "items": {
              "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/PeopleContext/1.0.0#/components/schemas/Contact"
            }
          }
        }
      },
      "InspectorDetail": {
        "description": "Contexto del Inspector",
        "properties": {
          "providerName": {
            "description": "nombre del Proveedor",
            "type": "string"
          },
          "inspectorName": {
            "description": "nombre del Inspector",
            "type": "string"
          },
          "alcoholLevelPossibleSuspect": {
            "description": "Posible Sospecha de Alcoholemia (Y o N)",
            "type": "string"
          },
          "totalLossPossibleSuspect": {
            "description": "Posible Sospecha de Perdida Total (Y o N)",
            "type": "string"
          },
          "commentsInspector": {
            "description": "Observaciones del Inspector",
            "type": "string"
          },
          "fraudPossibleSuspect": {
            "description": "Posible Sospecha del Fraude (Y o N)",
            "type": "string"
          },
          "commentsFraudInspector": {
            "description": "Comentarios o Motivos del Posible Fraude",
            "type": "string"
          }
        }
      },
      "DocumentAccident": {
        "description": "Informacion de los Documentos y ruta de la Foto",
        "properties": {
          "descriptionDoc": {
            "description": "Descripcion Breve de la Foto",
            "type": "string"
          },
          "urlDoc": {
            "description": "URL del Documento",
            "type": "string"
          }
        }
      },
      "InjuredDetail": {
        "description": "Detalle de los Lesionados (si los hay)",
        "properties": {
          "injuredType": {
            "description": "Tipo de Lesionado (Tercero / Asegurado)",
            "type": "string"
          },
          "pid": {
            "description": "Identificacion del Lesionado",
            "type": "string"
          },
          "givenName": {
            "description": "Primer y Segundo Nombre",
            "type": "string"
          },
          "lastName": {
            "description": "Primer y Segundo Apellido",
            "type": "string"
          },
          "birthDate": {
            "description": "Fecha de Nacimiento",
            "type": "string",
            "format": "date",
            "example": "2010-10-01"
          },
          "injuredMedicalCenter": {
            "description": "Se envia a Centro Medico (Y o N)",
