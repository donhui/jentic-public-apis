  "paths": {
    "/assistance-api/api/movilidad/assistances": {
      "post": {
        "summary": "Cargar las Asistencias Viales",
        "tags": [
          "AssitanceClaim"
        ],
        "operationId": "cargarAsistencias",
        "description": "Permite almacenar todas los reporte de asistencias viales gestionador por el Proveedor.",
        "parameters": [
          {
            "$ref": "#/components/parameters/X-Organization-Id"
          },
          {
            "$ref": "#/components/parameters/X-Organization-Type"
          },
          {
            "$ref": "#/components/parameters/X-Client-Application"
          },
          {
            "$ref": "#/components/parameters/X-Client-Application-Flow"
          },
          {
            "$ref": "#/components/parameters/X-Trace-Id"
          },
          {
            "$ref": "#/components/parameters/X-User"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RoadAssistanceRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Asistencia creada exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RoadAssistanceResponse"
                }
              }
            }
          },
          "500": {
            "description": "Respuesta generica para distintos tipos de errores controlados \n(ej: 400, 401, 403, 404, 500, 502, 503).\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/assistance-api/api/assistances/ping": {
      "get": {
        "summary": "Ping endpoint",
        "description": "Ping endpoint, that ensures your application is up and running",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "pong"
                }
              }
            }
          },
          "500": {
            "description": "Error"
          }
        }
      }
    },
    "/assistance-api/api/assistances/health-check": {
      "get": {
        "summary": "Health check endpoint",
        "description": "Health check endpoint, that run registered checkers",
        "responses": {
          "200": {
            "description": "All checkers were in success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessHealthCheck"
                }
              }
            }
          },
          "500": {
            "description": "At least one of the checkers was in error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorHealthCheck"
                }
              }
            }
          }
        }
      }
    }
  },
