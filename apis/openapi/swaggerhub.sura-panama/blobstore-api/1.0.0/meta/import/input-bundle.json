        "schema": {
          "type": "string"
        }
      },
      "X-Client-Application": {
        "in": "header",
        "name": "x-client-application",
        "schema": {
          "type": "string"
        },
        "required": true,
        "description": "Aplicación cliente desde donde se invocó al API.\n"
      },
      "X-Client-Application-Flow": {
        "in": "header",
        "name": "x-client-application-flow",
        "schema": {
          "type": "string"
        },
        "required": false,
        "description": "Indica el Flow de la aplicación cliente desde donde se invocó al API.\n"
      },
      "X-Trace-Id": {
        "in": "header",
        "name": "x-trace-id",
        "schema": {
          "type": "string"
        },
        "required": true
      },
      "X-User": {
        "in": "header",
        "name": "x-user",
        "schema": {
          "type": "string"
        },
        "required": true,
        "description": "Username del usuario que está conectado a la aplicación cliente cuando se invoca al API.\n"
      }
    }
  },
