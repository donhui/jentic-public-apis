          }
        }
      },
      "GetBlobResponseBody": {
        "type": "object",
        "properties": {
          "blob": {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/schemas/DocumentBlob"
          }
        }
      },
      "SaveDocBlobRequest": {
        "type": "object",
        "description": "Documento a Cargar dentro del BlobStorage en la ruta especifica",
        "properties": {
          "blob": {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/schemas/DocumentBlob"
          }
