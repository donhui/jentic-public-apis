  "paths": {
    "/api/blob/containers": {
      "get": {
        "summary": "Obtener Listado de Contenedores",
        "operationId": "GetContainers",
        "description": "Permite obtener una lista de todos los contenedores o directorios dentro de una cuenta de almacenamiento\n",
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/offsetParam"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/limitParam"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Type"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application-Flow"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Trace-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-User"
          }
        ],
        "responses": {
          "200": {
            "description": "search results matching criteria",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetContainerResponseBody"
                }
              }
            }
          },
          "default": {
            "description": "Respuesta gene\u00e9rica para distintos tipos de errores controlados \n(ej: 400, 401, 402, 403, 404, 500, 501, 502, 503 y 504).\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/api/blob/{containerName}/listblobs": {
      "get": {
        "summary": "Obtener Listado de Blobs en base al Directorio",
        "operationId": "GetListBlobs",
        "description": "Avoid to search a document by Id\n",
        "parameters": [
          {
            "in": "path",
            "name": "containerName",
            "required": true,
            "description": "Nombre del Directorio a buscar los distintos Blobs o Objetos (documentos)",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/offsetParam"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/limitParam"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Type"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application-Flow"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Trace-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-User"
          }
        ],
        "responses": {
          "200": {
            "description": "search results matching criteria",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetListBlobResponseBody"
                }
              }
            }
          },
          "default": {
            "description": "Respuesta gene\u00e9rica para distintos tipos de errores controlados \n(ej: 400, 401, 402, 403, 404, 500, 501, 502, 503 y 504).\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/api/blob/{containerName}/listblob/{blobName}": {
      "get": {
        "summary": "Obtener listado de Blobs por Etiqueta",
        "operationId": "GetListBlobsByEtag",
        "description": "Permite obtener un listado de blobs a partir de una Etiqueta",
        "parameters": [
          {
            "in": "path",
            "name": "containerName",
            "required": true,
            "description": "Nombre del Directorio",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "blobName",
            "required": true,
            "description": "Nombre del Objeto o Documento",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Type"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application-Flow"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Trace-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-User"
          }
        ],
        "responses": {
          "200": {
            "description": "busqueda por criterio exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetBlobResponseBody"
                }
              }
            }
          },
          "default": {
            "description": "Respuesta gene\u00e9rica para distintos tipos de errores controlados \n(ej: 400, 401, 402, 403, 404, 500, 501, 502, 503 y 504).\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/schemas/ErrorModel"
                }
              }
            }
          }
        }
      }
    },
    "/api/blob": {
      "post": {
        "summary": "Permite Cargar un Documento-Binario",
        "operationId": "loadBlobDoc",
        "description": "Permite cargar en el Contenedor o Repositorio un documento binario\n",
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Organization-Type"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Client-Application-Flow"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-Trace-Id"
          },
          {
            "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/parameters/X-User"
          }
        ],
        "responses": {
          "201": {
            "description": "Objeto o Documento Cargado"
          },
          "default": {
            "description": "Respuesta gene\u00e9rica para distintos tipos de errores controlados \n(ej: 400, 401, 402, 403, 404, 500, 501, 502, 503 y 504).\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/domains/SURA_PANAMA/TransversalContext/1.0.0#/components/schemas/ErrorModel"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveDocBlobRequest"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
