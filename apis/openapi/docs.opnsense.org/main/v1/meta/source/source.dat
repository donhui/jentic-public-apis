{
  "openapi": "3.0.3",
  "info": {
    "title": "OPNsense",
    "version": "v1",
    "description": "OPNsense REST API for firewall management including firmware, services, and DNS (Unbound) configuration.",
    "x-jentic-source-url": "https://docs.opnsense.org/development/api.html"
  },
  "servers": [
    {
      "url": "https://{host}/api",
      "variables": {
        "host": {
          "default": "opnsense.example.com",
          "description": "OPNsense firewall hostname"
        }
      }
    }
  ],
  "security": [
    { "basicAuth": [] }
  ],
  "tags": [
    { "name": "Firmware", "description": "Firmware and package management" },
    { "name": "Unbound", "description": "DNS Unbound service management" },
    { "name": "UnboundSettings", "description": "Unbound DNS settings" },
    { "name": "UnboundDiagnostics", "description": "Unbound DNS diagnostics" }
  ],
  "paths": {
    "/core/firmware/get": {
      "get": {
        "operationId": "getFirmwareConfig",
        "summary": "Get firmware configuration",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Firmware configuration",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/set": {
      "post": {
        "operationId": "setFirmwareConfig",
        "summary": "Set firmware configuration",
        "tags": ["Firmware"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/info": {
      "get": {
        "operationId": "getFirmwareInfo",
        "summary": "Get firmware information",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Firmware info",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/running": {
      "get": {
        "operationId": "getFirmwareRunning",
        "summary": "Get running firmware status",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Running firmware status",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/getOptions": {
      "get": {
        "operationId": "getFirmwareOptions",
        "summary": "Get available firmware options",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Firmware options",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/upgradestatus": {
      "get": {
        "operationId": "getFirmwareUpgradeStatus",
        "summary": "Check firmware upgrade progress",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Upgrade status",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/check": {
      "post": {
        "operationId": "checkFirmwareUpdates",
        "summary": "Check for firmware updates",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Update check results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/update": {
      "post": {
        "operationId": "updateFirmware",
        "summary": "Update firmware",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Update initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/upgrade": {
      "post": {
        "operationId": "upgradeFirmware",
        "summary": "Upgrade firmware",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Upgrade initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/status": {
      "post": {
        "operationId": "getFirmwareStatus",
        "summary": "Get current firmware status",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Current status",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/audit": {
      "post": {
        "operationId": "auditFirmware",
        "summary": "Audit firmware",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Audit results",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/health": {
      "post": {
        "operationId": "checkFirmwareHealth",
        "summary": "Check firmware health",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Health status",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/connection": {
      "post": {
        "operationId": "testFirmwareConnection",
        "summary": "Test firmware connection",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Connection status",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/changelog/{version}": {
      "post": {
        "operationId": "getFirmwareChangelog",
        "summary": "Get changelog for a firmware version",
        "tags": ["Firmware"],
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Changelog content",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/install/{pkgName}": {
      "post": {
        "operationId": "installPackage",
        "summary": "Install a package",
        "tags": ["Firmware"],
        "parameters": [
          { "$ref": "#/components/parameters/PkgName" }
        ],
        "responses": {
          "200": {
            "description": "Package installation initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/remove/{pkgName}": {
      "post": {
        "operationId": "removePackage",
        "summary": "Remove a package",
        "tags": ["Firmware"],
        "parameters": [
          { "$ref": "#/components/parameters/PkgName" }
        ],
        "responses": {
          "200": {
            "description": "Package removal initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/reinstall/{pkgName}": {
      "post": {
        "operationId": "reinstallPackage",
        "summary": "Reinstall a package",
        "tags": ["Firmware"],
        "parameters": [
          { "$ref": "#/components/parameters/PkgName" }
        ],
        "responses": {
          "200": {
            "description": "Reinstall initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/details/{pkgName}": {
      "post": {
        "operationId": "getPackageDetails",
        "summary": "Get package details",
        "tags": ["Firmware"],
        "parameters": [
          { "$ref": "#/components/parameters/PkgName" }
        ],
        "responses": {
          "200": {
            "description": "Package details",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/lock/{pkgName}": {
      "post": {
        "operationId": "lockPackage",
        "summary": "Lock a package",
        "tags": ["Firmware"],
        "parameters": [
          { "$ref": "#/components/parameters/PkgName" }
        ],
        "responses": {
          "200": {
            "description": "Package locked",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/unlock/{pkgName}": {
      "post": {
        "operationId": "unlockPackage",
        "summary": "Unlock a package",
        "tags": ["Firmware"],
        "parameters": [
          { "$ref": "#/components/parameters/PkgName" }
        ],
        "responses": {
          "200": {
            "description": "Package unlocked",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/reboot": {
      "post": {
        "operationId": "rebootSystem",
        "summary": "Reboot the system",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Reboot initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/firmware/poweroff": {
      "post": {
        "operationId": "powerOffSystem",
        "summary": "Power off the system",
        "tags": ["Firmware"],
        "responses": {
          "200": {
            "description": "Shutdown initiated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/service/status": {
      "get": {
        "operationId": "getUnboundServiceStatus",
        "summary": "Get Unbound DNS service status",
        "tags": ["Unbound"],
        "responses": {
          "200": {
            "description": "Service status",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/service/start": {
      "post": {
        "operationId": "startUnboundService",
        "summary": "Start Unbound DNS service",
        "tags": ["Unbound"],
        "responses": {
          "200": {
            "description": "Service started",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/service/stop": {
      "post": {
        "operationId": "stopUnboundService",
        "summary": "Stop Unbound DNS service",
        "tags": ["Unbound"],
        "responses": {
          "200": {
            "description": "Service stopped",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/service/restart": {
      "post": {
        "operationId": "restartUnboundService",
        "summary": "Restart Unbound DNS service",
        "tags": ["Unbound"],
        "responses": {
          "200": {
            "description": "Service restarted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/service/reconfigure": {
      "post": {
        "operationId": "reconfigureUnbound",
        "summary": "Reconfigure Unbound DNS",
        "tags": ["Unbound"],
        "responses": {
          "200": {
            "description": "Service reconfigured",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/settings/get": {
      "get": {
        "operationId": "getUnboundSettings",
        "summary": "Get Unbound settings",
        "tags": ["UnboundSettings"],
        "responses": {
          "200": {
            "description": "Unbound settings",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/settings/set": {
      "post": {
        "operationId": "setUnboundSettings",
        "summary": "Update Unbound settings",
        "tags": ["UnboundSettings"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/settings/add_host_override": {
      "post": {
        "operationId": "addUnboundHostOverride",
        "summary": "Add a DNS host override",
        "tags": ["UnboundSettings"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Host override added",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UuidResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/settings/set_host_override/{uuid}": {
      "post": {
        "operationId": "updateUnboundHostOverride",
        "summary": "Update a DNS host override",
        "tags": ["UnboundSettings"],
        "parameters": [
          { "$ref": "#/components/parameters/Uuid" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Host override updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/settings/del_host_override/{uuid}": {
      "post": {
        "operationId": "deleteUnboundHostOverride",
        "summary": "Delete a DNS host override",
        "tags": ["UnboundSettings"],
        "parameters": [
          { "$ref": "#/components/parameters/Uuid" }
        ],
        "responses": {
          "200": {
            "description": "Host override deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/settings/add_forward": {
      "post": {
        "operationId": "addUnboundForward",
        "summary": "Add a DNS forwarder",
        "tags": ["UnboundSettings"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Forwarder added",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UuidResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/diagnostics/stats": {
      "get": {
        "operationId": "getUnboundStats",
        "summary": "Get Unbound DNS statistics",
        "tags": ["UnboundDiagnostics"],
        "responses": {
          "200": {
            "description": "DNS statistics",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/diagnostics/dumpcache": {
      "get": {
        "operationId": "dumpUnboundCache",
        "summary": "Dump Unbound DNS cache",
        "tags": ["UnboundDiagnostics"],
        "responses": {
          "200": {
            "description": "Cache dump",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/core/unbound/overview/totals": {
      "get": {
        "operationId": "getUnboundTotals",
        "summary": "Get DNS query totals",
        "tags": ["UnboundDiagnostics"],
        "parameters": [
          {
            "name": "maximum",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Query totals",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "API key (as username) and API secret (as password)"
      }
    },
    "parameters": {
      "PkgName": {
        "name": "pkgName",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Package name"
      },
      "Uuid": {
        "name": "uuid",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" },
        "description": "Record UUID"
      }
    },
    "schemas": {
      "StatusResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "msg_uuid": { "type": "string" }
        }
      },
      "UuidResponse": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "result": { "type": "string" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/StatusResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required"
      }
    }
  }
}