    "/promoteChatMember": {
      "post": {
        "operationId": "promoteChatMember",
        "summary": "Promote chat member",
        "description": "Promote or demote a user in a supergroup or channel.",
        "tags": [
          "Chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "chat_id",
                  "user_id"
                ],
                "properties": {
                  "chat_id": {
                    "oneOf": [
                      {
                        "type": "integer"
                      },
                      {
                        "type": "string"
                      }
                    ]
                  },
                  "user_id": {
                    "type": "integer"
                  },
                  "is_anonymous": {
                    "type": "boolean"
                  },
                  "can_manage_chat": {
                    "type": "boolean"
                  },
                  "can_post_messages": {
                    "type": "boolean"
                  },
                  "can_edit_messages": {
                    "type": "boolean"
                  },
                  "can_delete_messages": {
                    "type": "boolean"
                  },
                  "can_manage_video_chats": {
                    "type": "boolean"
                  },
                  "can_restrict_members": {
                    "type": "boolean"
                  },
                  "can_promote_members": {
                    "type": "boolean"
                  },
                  "can_change_info": {
                    "type": "boolean"
                  },
                  "can_invite_users": {
                    "type": "boolean"
                  },
                  "can_pin_messages": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Member promoted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/sendVenue": {
      "post": {
        "operationId": "sendVenue",
        "summary": "Send venue information",
        "description": "Send information about a venue.",
        "tags": [
          "Messages"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "chat_id",
                  "latitude",
                  "longitude",
                  "title",
                  "address"
                ],
                "properties": {
                  "chat_id": {
                    "oneOf": [
                      {
                        "type": "integer"
                      },
                      {
                        "type": "string"
                      }
                    ]
                  },
                  "latitude": {
                    "type": "number",
                    "format": "float"
                  },
                  "longitude": {
                    "type": "number",
                    "format": "float"
                  },
                  "title": {
                    "type": "string"
                  },
                  "address": {
                    "type": "string"
                  },
                  "foursquare_id": {
                    "type": "string"
                  },
                  "foursquare_type": {
                    "type": "string"
                  },
                  "google_place_id": {
                    "type": "string"
                  },
                  "google_place_type": {
                    "type": "string"
                  },
                  "disable_notification": {
                    "type": "boolean"
                  },
                  "protect_content": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Venue sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "botToken": {
        "type": "apiKey",
        "in": "path",
        "name": "token",
        "description": "Bot token obtained from @BotFather, included in the URL path"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the request was successful"
          },
          "result": {
            "description": "Result of the request (type varies by method)"
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the result"
          },
          "error_code": {
            "type": "integer",
            "description": "Error code (only present on failure)"
          }
        },
        "required": [
          "ok"
        ]
      },
      "MessageEntity": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Type of the entity",
            "enum": [
              "mention",
              "hashtag",
              "cashtag",
              "bot_command",
              "url",
              "email",
              "phone_number",
              "bold",
              "italic",
              "underline",
              "strikethrough",
              "spoiler",
              "code",
              "pre",
              "text_link",
              "text_mention",
              "custom_emoji"
            ]
          },
          "offset": {
            "type": "integer",
            "description": "Offset in UTF-16 code units to the start of the entity"
          },
          "length": {
            "type": "integer",
            "description": "Length of the entity in UTF-16 code units"
          },
          "url": {
            "type": "string",
            "description": "URL (for text_link type only)"
          },
          "user": {
            "type": "object",
            "description": "Mentioned user (for text_mention type only)"
          },
          "language": {
            "type": "string",
            "description": "Programming language (for pre type only)"
          },
          "custom_emoji_id": {
            "type": "string",
            "description": "Custom emoji identifier"
          }
        },
        "required": [
          "type",
          "offset",
          "length"
        ]
      },
      "ReplyParameters": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "integer",
            "description": "Identifier of the message to reply to"
          },
          "chat_id": {
            "description": "Chat containing the message to reply to",
            "oneOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ]
          },
          "allow_sending_without_reply": {
            "type": "boolean"
          },
          "quote": {
            "type": "string"
          },
          "quote_parse_mode": {
            "type": "string"
          }
        },
        "required": [
          "message_id"
        ]
      }
    }
  },
  "security": [
    {
      "botToken": []
    }
  ]
}