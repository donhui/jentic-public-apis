        "responses": {
          "200": {
            "description": "Validation status of the imported invoice.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationStatus"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request payload.",
