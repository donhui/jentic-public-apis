                "type": "string",
                "description": "Legal organization ID",
                "example": "HRB12345"
              },
              "tradingBusinessName": {
                "type": "string",
                "description": "Trading business name",
                "example": "Muster Handels GmbH"
              }
            }
          },
          "vatId": {
            "type": "string",
            "description": "VAT identification number",
            "example": "DE123456789"
          },
          "banking": {
            "type": "object",
            "description": "Banking information",
            "properties": {
              "iban": {
                "type": "string",
                "description": "International Bank Account Number",
                "example": "DE89370400440532013000"
              },
              "owner": {
                "type": "string",
                "description": "Account owner name",
                "example": "Musterfirma GmbH"
              }
            }
          }
        }
      },
      "ImportBuyer": {
        "type": "object",
