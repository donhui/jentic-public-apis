  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "description": "An API key is required to access the API.  The API key (X-API-KEY) can be generated from within your Faktoora account settings.\n",
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "description": "Represents an error response from the API.",
        "properties": {
          "message": {
            "type": "string",
            "description": "Detailed description of the error.",
            "example": "Invalid request payload"
          },
          "field": {
            "type": "string",
            "description": "The specific field associated with the error, if applicable.",
            "example": "invoiceNumber"
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "description": "Represents validation errors encountered during request processing.",
        "properties": {
          "error": {
            "type": "string",
            "description": "The type of validation error.",
            "example": "InvalidFormat"
          },
          "message": {
            "type": "string",
            "description": "Detailed explanation of the error.",
            "example": "The invoice number format is incorrect."
          },
          "explanation": {
            "type": "string",
            "description": "Additional context or reasoning behind the validation error.",
            "example": "Invoice numbers must match the pattern `INV-YYYYMMDD-XXXX`."
          }
        }
      },
      "Webhook": {
        "type": "object",
        "description": "A webhook allows your application to receive real-time notifications when specific events occur in Faktoora.  For example, when an invoice is created, a webhook can notify your application by making a POST request to a specified URL.\n",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the webhook.",
            "example": "wh_12345"
          },
          "action": {
            "type": "string",
            "description": "The event associated with the webhook notification.",
            "enum": [
              "invoiceCreated"
            ]
          },
          "target": {
            "type": "string",
            "description": "The URL where the webhook notifications are sent.",
            "example": "https://example.com/webhooks/invoice"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the webhook was created.",
            "example": "2023-12-01T10:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "The timestamp when the webhook was last updated.",
            "example": "2023-12-05T15:30:00Z"
          }
        }
      },
      "InvoiceLineItem": {
        "type": "object",
        "required": [
          "id",
          "product"
        ],
        "description": "Represents a product or service included in an invoice.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the invoice position. (BT-126)",
            "example": "1"
          },
          "product": {
            "type": "object",
            "required": [
              "name",
              "quantity",
              "unitCode",
              "price",
              "taxes"
            ],
            "properties": {
              "productId": {
                "type": "string",
                "description": "Custom identifier for the product, assigned by the seller (BT-155).",
                "example": "PRD56789"
              },
              "name": {
                "type": "string",
                "description": "The name of the product or service (BT-153).",
                "example": "Handcrafted Wooden Chair"
              },
              "description": {
                "type": "string",
                "description": "Description of the product or service (BT-154).",
                "example": "Solid oak chair with ergonomic design."
              },
              "quantity": {
                "type": "string",
                "description": "Quantity of the product or service (BT-129).",
                "example": "4"
              },
              "unitCode": {
                "type": "string",
                "description": "Unit code as per UN/ECE Recommendation No. 20 \"Codes for Units of Measure Used in International Trade\"  and UN/ECE Recommendation No. 21 (BT-130).\n",
                "example": "C62",
                "enum": [
                  "C62",
                  "DAY",
                  "HUR",
                  "KGM",
                  "KMT",
                  "KWH",
                  "LS",
                  "LTR",
                  "MIN",
                  "MMK",
                  "MMT",
                  "MTK",
                  "MTQ",
                  "MTR",
                  "NAR",
                  "PR",
                  "SET",
                  "TNE",
                  "WEE",
                  "ANN"
                ]
              },
              "price": {
                "type": "number",
                "format": "float",
                "description": "Price per unit (BT-146).",
                "example": 125.5
              },
              "taxes": {
                "$ref": "#/components/schemas/Taxes"
              },
              "globalId": {
                "type": "object",
                "description": "Can be used to set a global ID for the product e.g. GTIN",
                "required": [
                  "id",
                  "schemeId"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Scheme-specific identifier (BT-157)",
                    "example": "45374900053"
                  },
                  "schemeId": {
                    "type": "string",
                    "description": "ISO 6523 identifier (BT-157-1)",
                    "example": "0088"
                  }
                }
              }
            }
          },
          "buyerAssignedId": {
            "type": "string",
            "description": "Custom identifier for the product, assigned by the buyer (BT-156).",
            "example": "P293"
          },
          "deliveryNote": {
            "type": "string",
            "description": "Reference to a delivery note. This is not allowed for XRechnung",
            "example": "PO5968"
          },
          "deliveryNoteDate": {
            "type": "string",
            "description": "date of the referenced delivery note [YYYMMMDD]. This is not allowed for XRechnung",
            "example": "20250131"
          },
          "orderNumber": {
            "type": "string",
            "description": "Reference to an order on line item level. This is not allowed for XRechnung",
            "example": "PO5968"
          },
          "orderLineId": {
            "type": "string",
            "description": "reference to the order position assigned by the buyer (BT-132)",
            "example": "14.1"
          },
          "orderDate": {
            "type": "string",
            "description": "date of the referenced order [YYYYMMDD]. This is not allowed for XRechnung",
            "example": "20250131"
          },
          "allowance": {
            "type": "array",
            "description": "List of all applicable surcharges and discounts on line item level.",
            "items": {
              "type": "object",
              "required": [
                "indicator",
                "reason",
                "amount"
              ],
              "properties": {
                "indicator": {
                  "type": "string",
                  "enum": [
                    "discount",
                    "surcharge"
                  ],
                  "example": "discount",
                  "description": "Specifies whether it is a discount or surcharge. (BG-27-0 / BG-28-0)"
                },
                "reason": {
                  "type": "string",
                  "example": "Treuerabatt",
                  "description": "Reason for the discount or surcharge. (BT-139 / BT-144)"
                },
                "amount": {
                  "type": "number",
                  "example": 50,
                  "description": "Net amount of the discount or surcharge. (BT-136 / BT-141)"
                }
              }
            }
          },
          "billingPeriod": {
            "type": "object",
            "required": [
              "startDate",
              "endDate"
            ],
            "description": "Billing period covered by the invoice line item (BG-26).",
            "properties": {
              "startDate": {
                "type": "string",
                "example": "20200101",
                "description": "Start date of the billing period [YYYYMMDD] (BT-134)."
              },
              "endDate": {
                "type": "string",
                "example": "20200131",
                "description": "End date of the billing period [YYYYMMDD] (BT-135)."
              }
            }
          }
        }
      },
      "Invoice": {
        "type": "object",
        "description": "Defines the structure of an electronic invoice.",
        "required": [
          "format",
          "issueDate",
          "invoiceNumber",
          "invoiceTypeCode",
          "invoiceItems",
          "buyer"
        ],
        "properties": {
          "format": {
            "type": "string",
            "enum": [
              "simple",
              "zf:1",
              "zf:2",
              "xrechnung",
              "peppol",
              "spain-verifactu",
              "factur-x",
              "fattura-pa"
            ],
            "example": "zf:2",
            "description": "Defines the output format of the invoice:\n- `zf` (ZUGFeRD) with the respective major version (1 or 2).\n- `xrechnung` produces an EN16931-compliant invoice, downloadable as pure XML or ZUGFeRD invoice (XRechnung profile).\n- `peppol` produces an EN16931-compliant invoice, downloadable as pure XML or ZUGFeRD invoice (Peppol profile).\n- `spain-verifactu` produces an EN16931-compliant invoice, downloadable as pure XML or ZUGFeRD invoice (VeriFactu profile).\n- `factur-x` produces an EN16931-compliant invoice, downloadable as pure XML or ZUGFeRD invoice (Factur-X profile).\n- `fattura-pa` produces an EN16931-compliant invoice, downloadable as pure XML or ZUGFeRD invoice (Fattura PA profile).\n"
          },
          "invoiceType": {
            "type": "string",
            "enum": [
              "cash",
              "qrcode",
              "normal"
            ],
            "default": "normal",
            "description": "Specifies the invoice type for processing"
          },
          "invoiceTypeCode": {
            "type": "number",
            "enum": [
              380,
              381,
              384,
              389,
              261,
              386,
              326
            ],
            "example": 380,
            "description": "Specifies the type of invoice based on the CIUS specification (BT-3), a subset of UNTDID 1001:\n- 380: Commercial invoice (Handelsrechnung)\n- 381: Credit note (Gutschriftanzeige)\n- 384: Invoice correction (Rechnungskorrektur)\n- 389: Self-issued invoice (Selbst ausgestellte Rechnung)\n- 261: Self-billed credit note (Selbst ausgestellte Gutschrift)\n- 386: Advance payment invoice (Vorauszahlungsrechnung) - this type is not officially allowed in XRechnung specification\n- 326: Partial invoice (Teilrechnung)\n**Important Notes**:\n- For invoice cancellations (384), set `invoiceReferencedDocument.IssuerAssignedID` to the original invoice number.\n- For general credit notes (381), invoice positions may have positive or negative values.\n"
          },
          "schema": {
            "type": "string",
            "enum": [
              "CII",
              "UBL"
            ],
            "example": "CII",
            "description": "this specifies the invoice standard. This can bei either UBL (https://www.oasis-open.org/committees/ubl/) or CII (Cross Industry Invoice). If you want to create ZUGFeRD invoices you have to use CII. UBL is not allowed in the ZUGFeRD specification."
          },
          "invoiceNumber": {
            "type": "string",
            "example": "RE-202001389",
            "description": "Unique invoice number as per accounting number group (BT-1)."
          },
          "invoiceOrderNumber": {
            "type": "string",
            "description": "Invoice order number",
            "example": "ORD-2024-001"
          },
          "supplierNumber": {
            "type": "string",
            "description": "Supplier number",
            "example": "SUP-001"
          },
          "orderNumber": {
            "type": "string",
            "example": "PO5563",
            "description": "Reference to the related order (BT-14)."
          },
          "shippingOrderNumber": {
            "type": "string",
            "example": "2249366482",
            "description": "Delivery order number. (BT-X-92)"
          },
          "issueDate": {
            "type": "string",
            "example": "20200106",
            "description": "Date the invoice was issued [YYYYMMDD] (BT-2)."
          },
          "dueDate": {
            "type": "string",
            "example": "20200206",
            "description": "Due date for the invoice"
          },
          "deliveryDate": {
            "type": "string",
            "example": "20200416",
            "description": "Date of delivery [YYYYMMDD]. (BT-72)"
          },
          "currency": {
            "type": "string",
            "example": "EUR",
            "description": "Currency of the invoice (BT-5), based on ISO 4217."
          },
          "introduction": {
            "type": "string",
            "example": "Introduction text",
            "description": "Introduction text"
          },
          "reviewMode": {
            "type": "boolean",
            "description": "Create invoice in review mode to use approval workflows via the faktoora UI. This requires the review mode to be activated in the account.",
            "example": false
          },
          "draftOnly": {
            "type": "boolean",
            "description": "Create invoice in draft mode to allow further editing in the faktoora UI",
            "example": false
          },
          "intraCommunityDelivery": {
            "type": "boolean",
            "description": "Indicates if this is an intra-community delivery",
            "example": false
          },
          "roundingAmount": {
            "type": "number",
            "description": "Optional field to reconcile rounding differences (BT-114). Must be a numeric value with 2 decimal places. This amount will be added to BT-115 \n",
            "example": 0.01
          },
          "transport": {
            "type": "array",
            "description": "Legacy transport field \u2013 currently disabled (must be empty array). Use allowances/deductions or a separate invoice position instead.",
            "maxItems": 0,
            "deprecated": true,
            "example": [],
            "items": {
              "type": "object",
              "required": [
                "description",
                "amount",
                "taxes"
              ],
              "properties": {
                "description": {
                  "type": "string",
                  "description": "Transport description",
                  "example": "Shipping costs"
                },
                "amount": {
                  "type": "number",
                  "description": "Transport amount",
                  "example": 50
                },
                "taxes": {
                  "$ref": "#/components/schemas/Taxes"
                }
              }
            }
          },
          "invoiceItems": {
            "type": "array",
            "required": [
              "id",
              "product"
            ],
            "description": "List of products or services included in the invoice. (BG-16)",
            "items": {
              "$ref": "#/components/schemas/InvoiceLineItem"
            }
          },
          "billingPeriod": {
            "type": "object",
            "required": [
              "startDate",
              "endDate"
            ],
            "description": "Billing period covered by the invoice (BG-14).",
            "properties": {
              "startDate": {
                "type": "string",
                "example": 20200101,
                "description": "Start date of the billing period [YYYYMMDD] (BT-73)."
              },
              "endDate": {
                "type": "string",
                "example": 20200131,
                "description": "End date of the billing period [YYYYMMDD] (BT-74)."
              }
            }
          },
          "specifiedTradeSettlementPaymentMeans": {
            "type": "array",
            "description": "Details of payment instructions (BG-16).",
            "items": {
              "type": "object",
              "required": [
                "typeCode"
              ],
              "properties": {
                "typeCode": {
                  "oneOf": [
                    {
                      "type": "number",
                      "enum": [
                        10,
                        20,
                        30,
                        42,
                        48,
                        49,
                        57,
                        58,
                        59,
                        97
                      ]
                    },
                    {
                      "type": "string",
                      "enum": [
                        "ZZZ"
                      ]
                    }
                  ],
                  "example": 58,
                  "description": "Code for payment method:\n- ZZZ: Mutually defined\n- 10: Cash\n- 20: Check\n- 30: Bank transfer\n- 42: Payment to bank account\n- 48: Card payment\n- 49: Direct debit\n- 57: Standing order\n- 58: SEPA Credit Transfer\n- 59: SEPA Direct Debit\n- 97: Report\n (BT-81)"
                },
                "information": {
                  "type": "string",
                  "example": "Zahlung per Lastschrift",
                  "description": "Free-text payment instructions. (BT-82)"
                },
                "paymentReference": {
                  "type": "string",
                  "example": "Reference",
                  "description": "Free-text payment reference."
                },
                "cardNumber": {
                  "type": "string",
                  "example": "2345",
                  "description": "Required if `typeCode` == 48; must be numeric string"
                },
                "holderName": {
                  "type": "string",
                  "example": "holder name",
                  "description": "Allowed only when `typeCode` == 48"
                }
              }
            }
          },
          "specifiedTradePaymentTerms": {
            "type": "array",
            "description": "Details on payment terms (BT-20).",
            "items": {
              "type": "object",
              "properties": {
                "description": {
                  "type": "string",
                  "description": "Free-text payment terms or encoded discounts.\nFor discounts (Skonto), use the following format:\n`#SKONTO#TAGE=14#PROZENT=2.25#BASISBETRAG=357.93#`\n"
                },
                "directDebitMandateID": {
                  "type": "string",
                  "example": "Mandat2020X1",
                  "description": "Direct debit mandate number (BG19/BT-89)."
                },
                "dueDateTime": {
                  "type": "string",
                  "example": 20200412,
                  "description": "Invoice due date [YYYYMMDD]. (BT-9)"
                }
              }
            }
          },
          "specifiedProcuringProject": {
            "type": "object",
            "required": [
              "name",
              "id"
            ],
            "description": "Reference to a specific project (BT-11).",
            "properties": {
              "name": {
                "type": "string",
                "example": "Bauprojekt Alpha",
                "description": "Name of the project."
              },
              "id": {
                "type": "string",
                "example": "P123456",
                "description": "ID of the project."
              }
            }
          },
          "allowance": {
            "type": "array",
            "description": "List of all applicable surcharges and discounts.",
            "items": {
              "type": "object",
              "required": [
                "indicator",
                "reason",
                "amount",
                "taxes"
              ],
              "properties": {
                "indicator": {
                  "type": "string",
                  "enum": [
                    "discount",
                    "surcharge"
                  ],
                  "example": "discount",
                  "description": "Specifies whether it is a discount or surcharge. (BG-27 / BG-28)"
                },
                "reason": {
                  "type": "string",
                  "example": "Treuerabatt",
                  "description": "Reason for the discount or surcharge. (BT-139 / BT-144)"
                },
                "amount": {
                  "type": "number",
                  "example": 50,
                  "description": "Net amount of the discount or surcharge. (BT-136 / BT-141)"
                },
                "taxes": {
                  "$ref": "#/components/schemas/Taxes"
                }
              }
            }
          },
          "deduction": {
            "type": "array",
            "description": "A list of deductions applied to the outstanding balance of the invoice.",
            "items": {
              "type": "object",
              "required": [
                "label",
                "value"
              ],
              "properties": {
                "label": {
                  "type": "string",
                  "example": "Invoice #152",
                  "description": "Reference to the invoice number"
                },
                "value": {
                  "type": "number",
                  "example": 25,
                  "description": "Deduction amount."
                }
              }
            }
          },
          "delivery": {
            "type": "object",
            "description": "Specific delivery address",
            "required": [
              "name",
              "postcode",
              "street",
              "city",
              "country"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the delivery address (BT-71)",
                "example": "DLV-12345"
              },
              "globalId": {
                "type": "object",
                "description": "Can be used to set a global ID. For more information, refer to <a href='https://docs.peppol.eu/poacc/billing/3.0/codelist/ICD/'>this link</a>",
                "required": [
                  "id",
                  "schemeId"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Scheme-specific identifier (BT-71-0)",
                    "example": "45374900053"
                  },
                  "schemeId": {
                    "type": "string",
                    "description": "ISO 6523 identifier (BT-71-1)",
                    "example": "0088"
                  }
                }
              },
              "name": {
                "type": "string",
                "description": "Name associated with the delivery address (BT-70)",
                "example": "Musterlager GmbH"
              },
              "phone": {
                "type": "string",
                "description": "Phone number of the delivery location ",
                "example": "+49 30 12345678"
              },
              "email": {
                "type": "string",
                "description": "Email address for the delivery location",
                "example": "logistik@musterlager.de"
              },
              "postcode": {
                "type": "string",
                "description": "Postal code of the delivery location (BT-78)",
                "example": "10115"
              },
              "street": {
                "type": "string",
                "description": "Street address of the delivery location (BT-75)",
                "example": "Lagerstra\u00dfe 12"
              },
              "LineTwo": {
                "type": "string",
                "description": "Additional line for the delivery location address (BT-76)",
                "example": "Geb\u00e4ude C"
              },
              "LineThree": {
                "type": "string",
                "description": "Further details for the delivery address (e.g., apartment, door) (BT-165)",
                "example": "Raum 204"
              },
              "city": {
                "type": "string",
                "description": "City of the delivery location (BT-77)",
                "example": "Berlin"
              },
              "country": {
                "type": "string",
                "description": "Country of the delivery location (ISO 3166-1 alpha-2 format) (BT-80)",
                "example": "DE"
              },
              "deliveryNote": {
                "type": "string",
                "description": "Additional note for delivery instructions",
                "example": "Bitte am Hintereingang abstellen"
              }
            }
          },
          "seller": {
            "type": "object",
            "required": [
              "name",
              "postcode",
              "street",
              "city",
              "country"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "A unique supplier number assigned by the buyer. (BT-29)",
                "example": "SUP-98234"
              },
              "globalId": {
                "type": "object",
                "description": "Global identifier for the seller, used for standardized identification. (BT-29-0)",
                "required": [
                  "id",
                  "schemeId"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Scheme-specific identifier for the seller.",
                    "example": "75238940123"
                  },
                  "schemeId": {
                    "type": "string",
                    "description": "ISO 6523 identifier for the scheme.",
                    "example": "0088"
                  }
                }
              },
              "name": {
                "type": "string",
                "description": "The name of the seller's business or organization. (BT-27)",
                "example": "Musterfirma GmbH"
              },
              "phone": {
                "type": "string",
                "description": "The seller's contact phone number. Moved to contactPerson.telephoneNumber (BT-42-00)",
                "example": "+49 89 12345678",
                "deprecated": true
              },
              "email": {
                "type": "string",
                "description": "The seller's contact email address. Moved to contactPerson.email(BT-43-00)",
                "example": "kontakt@musterfirma.de",
                "deprecated": true
              },
              "postcode": {
                "type": "string",
                "description": "The postal code of the seller's location. (BT-38)",
                "example": "80331"
              },
              "street": {
                "type": "string",
                "description": "The street address of the seller. (BT-35)",
                "example": "Hauptstra\u00dfe 15"
              },
              "LineTwo": {
                "type": "string",
                "description": "Additional address line for the seller's location. (BT-36)",
                "example": "Geb\u00e4ude A"
              },
              "LineThree": {
                "type": "string",
                "description": "Additional details for the address, such as office or floor. (BT-162)",
                "example": "4. Stock"
              },
              "city": {
                "type": "string",
                "description": "The city where the seller is located. (BT-37)",
                "example": "M\u00fcnchen"
              },
              "country": {
                "type": "string",
                "description": "The country where the seller is located, represented as an ISO 3166-1 alpha-2 code. (BT-40)",
                "example": "DE"
              },
              "specifiedLegalOrganization": {
                "type": "object",
                "description": "Details about the seller's legal organization.",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Legal identification of the company (e.g., Handelsregister entry). (BT-30)",
                    "example": "HRB12345"
                  },
                  "tradingBusinessName": {
                    "type": "string",
                    "description": "The trading name of the business, if different from the legal name. (BT-28)",
                    "example": "Muster Handels GmbH"
                  }
                }
              },
              "vatId": {
                "type": "string",
                "description": "The VAT (Value Added Tax) identifier of the seller. (BT-31)",
                "example": "DE123456789"
              },
              "banking": {
                "type": "object",
                "description": "Banking details of the seller for payment purposes. (BG-17)",
                "required": [
                  "iban",
                  "owner"
                ],
                "properties": {
                  "iban": {
                    "type": "string",
                    "description": "The seller's International Bank Account Number (IBAN). (BT-84)",
                    "example": "DE89370400440532013000"
                  },
                  "owner": {
                    "type": "string",
                    "description": "The name of the account owner. (BT-85)",
                    "example": "Musterfirma GmbH"
                  }
                }
              },
              "peppolId": {
                "type": "string",
                "description": "PEPPOL identifier for the seller for electronic document exchange",
                "example": "0088:7300010000001"
              },
              "creditorReference": {
                "type": "string",
                "description": "Creditor reference for the seller",
                "example": "RF18539007547034"
              }
            }
          },
          "buyer": {
            "type": "object",
            "required": [
              "name",
              "postcode",
              "street",
              "city",
              "country"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "A unique customer number assigned by the seller. (BT-46)",
                "example": "CUST-67489"
              },
              "globalId": {
                "type": "object",
                "description": "Global identifier for the buyer, used for standardized identification.",
                "required": [
                  "id",
                  "schemeId"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Scheme-specific identifier for the buyer. (BT-46-0)",
                    "example": "83940572134"
                  },
                  "schemeId": {
                    "type": "string",
                    "description": "ISO 6523 identifier for the scheme. (BT-46-1)",
                    "example": "0088"
                  }
                }
              },
              "name": {
                "type": "string",
                "description": "The name of the buyer's business or organization.(BT-47)",
                "example": "Beispielkunde AG"
              },
              "phone": {
                "type": "string",
                "description": "The buyer's contact phone number. (BT-57)",
                "example": "+49 30 98765432"
              },
              "email": {
                "type": "string",
                "description": "The buyer's contact email address. (BT-58)",
                "example": "einkauf@beispielkunde.de"
              },
              "postcode": {
                "type": "string",
                "description": "The postal code of the buyer's location. (BT-53)",
                "example": "10117"
              },
              "street": {
                "type": "string",
                "description": "The street address of the buyer. (BT-50)",
                "example": "Friedrichstra\u00dfe 50"
              },
              "LineTwo": {
                "type": "string",
                "description": "Additional address line for the buyer's location. (BT-51)",
                "example": "Abteilung Einkauf"
              },
              "LineThree": {
                "type": "string",
                "description": "Additional details for the address, such as room or floor. (BT-163)",
                "example": "3. Etage"
              },
              "city": {
                "type": "string",
                "description": "The city where the buyer is located. (BT-52)",
                "example": "Berlin"
              },
              "country": {
                "type": "string",
                "description": "The country where the buyer is located, represented as an ISO 3166-1 alpha-2 code. (BT-55)",
                "example": "DE"
              },
              "vatId": {
                "type": "string",
                "description": "The VAT (Value Added Tax) identifier of the buyer. (BT-48) ",
                "example": "DE987654321"
              },
              "definedTradeContact": {
                "type": "object",
                "description": "Contact person on the buyer's side.",
                "properties": {
                  "firstName": {
                    "type": "string",
                    "description": "First name of the contact person. (BT-56)",
                    "example": "Anna"
                  },
                  "lastName": {
                    "type": "string",
                    "description": "Last name of the contact person. (BT-56)",
                    "example": "Schmidt"
                  },
                  "departmentName": {
                    "type": "string",
                    "description": "Department associated with the contact person. (BT-56-0)",
                    "example": "Zentraleinkauf"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Contact person's phone number. (BT-57-00)",
                    "example": "+49 30 55512345"
                  },
                  "email": {
                    "type": "string",
                    "description": "Contact person's email address. (BT-58-00)",
                    "example": "anna.schmidt@beispielkunde.de"
                  }
                }
              },
              "faktooraCustomerId": {
                "type": "string",
                "description": "Internal Faktoora customer identifier"
              },
              "createCustomer": {
                "type": "boolean",
                "description": "Flag to indicate whether to create a new customer"
              },
              "banking": {
                "type": "object",
                "description": "Banking information for the buyer",
                "properties": {
                  "iban": {
                    "type": "string",
                    "description": "The buyer's International Bank Account Number (IBAN)",
                    "example": "DE89370400440532013000"
                  },
                  "owner": {
                    "type": "string",
                    "description": "The name of the account owner",
                    "example": "Beispielkunde AG"
                  }
                }
              },
              "peppolId": {
                "type": "string",
                "description": "PEPPOL identifier for the buyer for electronic document exchange",
                "example": "0088:7300010000002"
              },
              "mandateReference": {
                "type": "string",
                "description": "Direct debit mandate reference for the buyer",
                "example": "MANDATE-2023-001"
              }
            }
          },
          "buyerReference": {
            "type": "object",
            "description": "A structured reference containing identifiers that provide additional details about the buyer or their internal routing requirements. This includes references such as the LeitwegID for public organizations or project codes and internal department identifiers for B2B transactions. (BT-10)",
            "properties": {
              "IssuerAssignedID": {
                "type": "string",
                "description": "An identifier issued by the buyer, typically referencing an associated purchase order. This is used by the seller to link the invoice to a referenced order. (BT-13)",
                "example": "PO-2023-001234"
              },
              "buyerReferenceId": {
                "type": "string",
                "description": "An identifier assigned by the buyer for internal routing purposes, such as contact details, department codes, office identifiers, or project codes. For public organizations, this may include the LeitwegID. (BT-10)",
                "example": "991-33333-84"
              }
            }
          },
          "contractReferencedDocument": {
            "type": "object",
            "description": "Provides a reference to a specific contract related to the invoice. The contract reference should be unique within the context of the specific trade relationship and for a defined period. (BT-12)",
            "properties": {
              "IssuerAssignedID": {
                "type": "string",
                "description": "The unique identifier of the related contract, assigned within the context of the buyer-seller relationship. (BT-12)",
                "example": "CTR-2023-56432"
              }
            }
          },
          "invoiceReferencedDocument": {
            "type": "object",
            "description": "References a previous invoice, such as in the case of credit notes, cancellations, or linked transactions. To be used if: - a previous invoice is being corrected; - a final invoice refers to earlier partial invoices; - a final invoice refers to earlier advance payment invoices. (BG-3)",
            "required": [
              "IssuerAssignedID",
              "issueDateTime"
            ],
            "properties": {
              "IssuerAssignedID": {
                "type": "string",
                "description": "The identification of an invoice previously sent by the seller. (BT-25)",
                "example": "INV-2023-98765"
              },
              "issueDateTime": {
                "type": "string",
                "description": "The date of the referenced invoice in YYYYMMDD format. This should be provided if the referenced invoice number is not unique. (BT-26)",
                "example": "20230315"
              }
            }
          },
          "additionalReferences": {
            "type": "array",
            "description": "List of additional supporting documents or references relevant to the invoice. These documents are known as 'rechnungsbegr\u00fcndende Unterlagen' in ZUGFeRD and are represented in BG-24.",
            "items": {
              "type": "object",
              "required": [
                "IssuerAssignedID",
                "typeCode"
              ],
              "properties": {
                "IssuerAssignedID": {
                  "type": "string",
                  "description": "Identifier of the referenced document. This is the unique ID assigned to the supporting document. (BT-122)",
                  "example": "DOC-2023-45678"
                },
                "uriId": {
                  "type": "string",
                  "description": "The location or URL where the referenced document can be accessed. (BT-124)",
                  "example": "https://example.com/documents/45678"
                },
                "lineId": {
                  "type": "string",
                  "description": "The line item number or identifier in the referenced document.",
                  "example": "1"
                },
                "typeCode": {
                  "type": "string",
                  "description": "The type of the referenced document, classified using standard codes. Example: '916' for invoice-related documents. (BT-122-0)",
                  "example": "916"
                },
                "name": {
                  "type": "string",
                  "description": "A human-readable description of the referenced document. (BT-123)",
                  "example": "Service Agreement"
                },
                "referenceTypeCode": {
                  "type": "string",
                  "description": "Reference type code",
                  "example": "CONTRACT"
                },
                "attachmentBinaryObject": {
                  "type": "object",
                  "description": "The actual attachment of the referenced document. Represents a file embedded within the invoice data. (BT-125)",
                  "required": [
                    "filename",
                    "mimeCode",
                    "data"
                  ],
                  "properties": {
                    "filename": {
                      "type": "string",
                      "description": "The name of the attached file. (BT-125-2)",
                      "example": "contract.pdf"
                    },
                    "mimeCode": {
                      "type": "string",
                      "description": "The MIME type of the attached file, indicating the file format. (BT-125-1)",
                      "enum": [
                        "application/pdf",
                        "image/png",
                        "image/jpeg",
                        "text/csv",
                        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                        "application/vnd.oasis.opendocument.spreadsheet"
                      ],
                      "example": "application/pdf"
                    },
                    "data": {
                      "type": "string",
                      "description": "Base64 encoded content of the file, or a URL pointing to the file. (BT-125)",
                      "example": "JVBERi0xLjMKJcTl8uXrp..."
                    }
                  }
                }
              }
            }
          },
          "notes": {
            "type": "array",
            "description": "Free-form notes relevant to the invoice. Can be used for comments or additional instructions. (BG-1)",
            "items": {
              "type": "object",
              "properties": {
                "SubjectCode": {
                  "type": "string",
                  "description": "A qualifier for the note based on UNCL4451. For more details, refer to <a href='https://service.unece.org/trade/untdid/i96b/uncl/uncl4451.htm'>this link</a>. (BT-21)",
                  "example": "GEN"
                },
                "ContentCode": {
                  "type": "string",
                  "description": "Content code",
                  "example": "Content code"
                },
                "Content": {
                  "type": "string",
                  "description": "The actual content of the note. (BT-22)",
                  "example": "Delivery expected within 5 business days."
                }
              }
            }
          },
          "taxExemptionReasonMessage": {
            "type": "string",
            "description": "Specifies the reason for tax exemption if any line item is categorized under tax category E. This field corresponds to the exemption reason as per EN16931. Examples include references to legal provisions such as Article 226 (11-14) of Directive 2006/112/EC. (BT-120)",
            "example": "VAT exempt under Article 226(11) of Directive 2006/112/EC"
          },
          "template": {
            "type": "object",
            "description": "Template customization for the invoice.",
            "properties": {
              "label": {
                "type": "string",
                "example": "default",
                "description": "Identifier for the customer template."
              },
              "customFields": {
                "type": "object",
                "description": "Custom fields for additional information not covered by the standard payload."
              },
              "subTotalsDefinitions": {
                "type": "array",
                "description": "Set of subtotals defined below the invoice positions.",
                "items": {
                  "type": "object",
                  "required": [
                    "type"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "VAT",
                        "other"
                      ],
                      "example": "VAT",
                      "description": "Calculation logic for the subtotal (e.g., VAT or other)."
                    },
                    "caption": {
                      "type": "string",
                      "example": "19% Umsatzsteuer",
                      "description": "Caption for the subtotal."
                    },
                    "categoryCode": {
                      "type": "string",
                      "enum": [
                        "S",
                        "Z",
                        "E",
                        "AE",
                        "K",
                        "G",
                        "O",
                        "L",
                        "M"
                      ],
                      "description": "Tax category for the subtotal."
                    },
                    "rate": {
                      "type": "integer",
                      "example": 19,
                      "description": "Tax rate applied (integer values only)."
                    },
                    "baseAmount": {
                      "type": "number",
                      "description": "Base amount for the subtotal calculation."
                    },
                    "amount": {
                      "type": "number",
                      "description": "Calculated subtotal amount."
                    }
                  }
                }
              }
            }
          },
          "contactPerson": {
            "type": "object",
            "description": "Information about a designated contact person for the invoice. \nIncludes details such as name, email, phone number, and support ID. This overwrites all contact information (email and phone) in the seller object\n",
            "properties": {
              "name": {
                "type": "string",
                "description": "The full name of the contact person who can be reached for inquiries or support. (BT-41)\n",
                "example": "Anna M\u00fcller"
              },
              "email": {
                "type": "string",
                "format": "email",
                "description": "The email address of the contact person. Use this to send correspondence related to the invoice. (BT-43-00)\n",
                "example": "anna.mueller@beispiel.de"
              },
              "telephoneNumber": {
                "type": "string",
                "description": "The contact person's phone number, including the German country code (+49). (BT-42)\n",
                "example": "+49 30 12345678"
              },
              "faxNumber": {
                "type": "string",
                "description": "The contact person's fax number, including the German country code (+49). (BT-44)\n",
                "example": "+49 30 87654321"
              },
              "supportId": {
                "type": "string",
                "description": "An identifier for the contact person, often used in internal or support systems.\n",
                "example": "SUP-DE-456789"
              }
            }
          },
          "invoiceDelivery": {
            "type": "object",
            "description": "Specifies delivery details for the invoice, including recipients, carbon copies, \nand sender information for email delivery and enques the email for delivery.\n\nNote: The specified email will be send also for `draftOnly` or `reviewMode` invoices, e.g. for external review purposes.\n",
            "required": [
              "recipients",
              "subject"
            ],
            "properties": {
              "recipients": {
                "type": "string",
                "description": "One or more primary recipient email addresses to which the invoice will be sent.  \nMultiple addresses can be provided as a **comma-separated list**.\n",
                "example": "buchhaltung@empfaengerfirma.de,finanzen@empfaengerfirma.de"
              },
              "carbonCopy": {
                "type": "string",
                "description": "Optional email address(es) for additional recipients to receive a carbon copy (CC) of the invoice.  \nMultiple addresses can be provided as a **comma-separated list**.\n",
                "example": "leitung@empfaengerfirma.de,assistenz@empfaengerfirma.de"
              },
              "blindCarbonCopy": {
                "type": "string",
                "description": "Optional email address(es) for recipients to receive a blind carbon copy (BCC) of the invoice.  \nMultiple addresses can be provided as a **comma-separated list**.\n",
                "example": "confidential@finanzfirma.de,auditor@partnerfirma.de"
              },
              "sendUserCopy": {
                "type": "boolean",
                "description": "Indicates whether a copy of the invoice should be sent to the sender as well.\n",
                "example": true
              },
              "sendFormat": {
                "type": "string",
                "enum": [
                  "pdf",
                  "xml"
                ],
                "description": "Indicates wether the invoice is sent as xml file or ZUGFeRD format (if available)",
                "example": "pdf"
              },
              "senderName": {
                "type": "string",
                "description": "The name of the sender, typically the company or person issuing the invoice.\n",
                "example": "Beispiel GmbH"
              },
              "subject": {
                "type": "string",
                "description": "The subject line of the email containing the invoice.\n",
                "example": "Rechnung #12345 - Beispiel GmbH"
              }
            }
          },
          "authorityRegistration": {
            "type": "object",
            "description": "Authority details for the invoice, including Verifactu type, register, and correction mode.\n",
            "properties": {
              "verifactu": {
                "type": "object",
                "required": [
                  "invoiceType"
                ],
                "properties": {
                  "invoiceType": {
                    "type": "string",
                    "description": "The type of Verifactu authority to be used for the invoice. \nThis determines the rules and requirements for invoice processing.\n",
                    "example": "R1"
                  },
                  "correctionMode": {
                    "type": "string",
                    "description": "Specifies the correction mode for the invoice in Corrective Verifactu type (R1, R2, R3, R4, R5). \n",
                    "example": "I"
                  }
                }
              }
            }
          }
        }
      },
      "Taxes": {
        "type": "array",
        "description": "A collection of tax entries applied to an invoice. \nEach entry includes details about the type, category, and rate of the tax.\n",
        "items": {
          "type": "object",
          "required": [
            "typeCode",
            "categoryCode",
            "rate"
          ],
          "properties": {
            "typeCode": {
              "type": "string",
              "description": "Indicates the type of tax applied to the invoice. \nCurrently, only `VAT` (Value Added Tax) is supported.\n",
              "example": "VAT"
            },
            "categoryCode": {
              "type": "string",
              "description": "Specifies the tax category based on the UN/CEFACT standard. \nCommon categories include:\n- `S`: Standard rate.\n- `Z`: Zero rate.\n- `E`: Exempt from VAT (requirees a tax exemption reason)\n- `AE`: VAT Reverse Charge.\n- `K`: Special tax schemes.\n- `G`: Goods-related.\n- `O`: Other.\n- `L`: Leasing-related.\n- `M`: Margin-based schemes.\nFor more details, refer to the [UN/CEFACT code list](https://docs.peppol.eu/poacc/billing/3.0/codelist/UNCL5305/).\n",
              "enum": [
                "S",
                "Z",
                "E",
                "AE",
                "K",
                "G",
                "O",
                "L",
                "M"
              ],
              "example": "S"
            },
            "rate": {
              "type": "integer",
              "description": "The tax rate applied as a percentage (integer value). \nFor example, a value of `16` indicates a 16% tax rate.\n",
              "example": 19
            }
          }
        }
      },
      "ValidationStatus": {
        "type": "object",
        "description": "Represents the current validation status of an imported invoice.\n",
        "properties": {
          "status": {
            "type": "string",
            "description": "Outcome of the invoice validation.\n"
          }
        }
      },
      "ImportStatus": {
        "type": "object",
        "description": "Represents the current processing status of an imported invoice.\nThe import process has three status keys: validationStatus, visualizationStatus, and overallStatus.\nEach status can be 'accepted' (completed), 'pending' (in progress), or 'failed'.\n",
        "properties": {
          "validationStatus": {
            "type": "string",
            "enum": [
              "accepted",
              "failed",
              "pending"
            ],
            "description": "Status of the invoice validation process:\n- `accepted`: Validation report has been generated successfully\n- `pending`: Validation is in progress (less than 5 seconds since import)\n- `failed`: Validation timed out or failed (more than 5 seconds without completion)\n",
            "example": "accepted"
          },
          "visualizationStatus": {
            "type": "string",
            "enum": [
              "accepted",
              "failed",
              "pending"
            ],
            "description": "Status of the PDF visualization generation:\n- `accepted`: PDF has been generated successfully\n- `pending`: PDF generation is in progress (less than 5 seconds since import)\n- `failed`: PDF generation timed out or failed (more than 5 seconds without completion)\n",
            "example": "failed"
          },
          "overallStatus": {
            "type": "string",
            "enum": [
              "accepted",
              "failed",
              "pending"
            ],
            "description": "Combined status of the entire import process:\n- `accepted`: Both validation and visualization completed successfully\n- `failed`: Either validation or visualization (or both) failed\n- `pending`: At least one process is still in progress\n",
            "example": "failed"
          }
        }
      },
      "InvoiceSummary": {
        "type": "object",
        "description": "A concise summary of an imported invoice, providing key information \nabout the seller, payment details, and relevant dates.\n",
        "properties": {
          "sellerName": {
            "type": "string",
            "description": "The full name of the company issuing the invoice. \nThis is typically the supplier or service provider.\n",
            "example": "Mustermann GmbH"
          },
          "buyerReference": {
            "type": "string",
            "description": "The buyer reference the company issuing the invoice. \n",
            "example": "K\u00e4uferkennung"
          },
          "amount": {
            "type": "number",
            "format": "float",
            "description": "The total amount to be paid for the invoice, including applicable taxes.\nRepresented in the invoice's specified currency.\n",
            "example": 773.76
          },
          "taxAmount": {
            "type": "number",
            "format": "float",
            "description": "The contained tax amount of the invoice.\nRepresented in the invoice's specified currency.\n",
            "example": 147.01
          },
          "issueDate": {
            "type": "string",
            "format": "date",
            "description": "The date on which the invoice was officially issued.\nFormat: `YYYY-MM-DD`.\n",
            "example": "2022-01-15"
          },
          "invoiceNumber": {
            "type": "string",
            "description": "A unique identifier for the invoice as assigned by the seller.\nThis is essential for referencing and tracking invoices.\n",
            "example": "Rechnung 2021-001"
          },
          "lastPaymentDate": {
            "type": "string",
            "format": "date",
            "description": "The date by which payment for the invoice is due, as specified by the seller.\nFormat: `YYYY-MM-DD`.\n",
            "example": "2022-02-15"
          },
          "paymentDate": {
            "type": "string",
            "format": "date",
            "description": "The recorded date of payment for the invoice.\nFormat: `YYYY-MM-DD`.\n",
            "example": "2022-01-15"
          },
          "invoiceCurrencyCode": {
            "type": "string",
            "description": "The three-letter ISO 4217 code representing the currency of the invoice.\nExamples: `EUR` for Euro, `USD` for US Dollar.\n",
            "example": "EUR"
          },
          "inputType": {
            "type": "string",
            "description": "Specifies the type of input data for the invoice. \nCommonly used for distinguishing between different invoice formats like `CII` (Cross Industry Invoice).\n",
            "example": "CII"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Shows when the record was created in the faktoora system, ISO 8601 timestamp, UTC \n",
            "example": "2025-08-20T12:34:56Z"
          }
        }
      },
      "ImportLineItems": {
        "type": "object",
        "description": "A structure of line item of an imported invoice.\n",
        "properties": {
          "id": {
            "type": "string",
            "description": "Line item index",
            "example": "1"
          },
          "product": {
            "type": "object",
            "properties": {
              "productId": {
                "type": "string",
                "description": "Article number",
                "example": "ART-001"
              },
              "buyerAssignedId": {
                "type": "string",
                "description": "Buyer assigned identifier",
                "example": "BUYER-REF-123"
              },
              "name": {
                "type": "string",
                "description": "Product description",
                "example": "Premium Office Chair"
              },
              "description": {
                "type": "string",
                "description": "Custom description",
                "example": "Ergonomic office chair with lumbar support"
              },
              "quantity": {
                "type": "number",
                "description": "Product quantity",
                "example": 2.5
              },
              "unitCode": {
                "type": "string",
                "description": "Unit code (mapped or original)",
                "example": "C62"
              },
              "price": {
                "type": "number",
                "description": "Product price",
                "example": 299.99
              },
              "taxes": {
                "$ref": "#/components/schemas/Taxes"
              }
            }
          }
        }
      },
      "Product": {
        "type": "object",
        "description": "Represents a product.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the product. (BT-X-305)",
            "example": "12345"
          },
          "code": {
            "type": "string",
            "description": "The Code of the product.",
            "example": "codeexample"
          },
          "name": {
            "type": "string",
            "description": "The name of the product.",
            "example": "Handcrafted Wooden Chair"
          },
          "description": {
            "type": "string",
            "description": "Description of the product.",
            "example": "Solid oak chair with ergonomic design."
          },
          "unit": {
            "type": "string",
            "description": "Unit of the product.",
            "example": "kg"
          },
          "tax": {
            "type": "number",
            "description": "Tax of the product."
          },
          "price": {
            "type": "number",
            "description": "Price of the product."
          },
          "cost": {
            "type": "number",
            "description": "Tax of the product."
          },
          "inventoryCount": {
            "type": "number",
            "description": "Inventory Count of the product."
          },
          "time": {
            "type": "number",
            "description": "Time of the product."
          },
          "estimate": {
            "type": "number",
            "description": "Estimate of the product."
          },
          "buyerAssignedID": {
            "type": "string",
            "description": "product id assigned by the buyer (BT-156)"
          },
          "additionalReferencedDocument": {
            "type": "object",
            "additionalProperties": true
          },
          "currency": {
            "type": "string",
            "example": "EUR",
            "description": "Currency of the invoice (BT-5), based on ISO 4217."
          },
          "productsOnProductBundles": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "description": "Related Entity ProductsOnProductBundles"
            }
          }
        }
      },
