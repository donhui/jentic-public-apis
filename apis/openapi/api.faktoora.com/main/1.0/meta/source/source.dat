    "/import/outgoing": {
      "get": {
        "tags": [
          "Outgoing Import Invoice"
        ],
        "summary": "List all outgoing imported invoices",
        "description": "Returns a paginated list of all outgoing imported invoices with filtering, sorting, and search capabilities.\n",
        "security": [
          {
            "apiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            },
            "description": "Page number for pagination"
          },
          {
            "in": "query",
            "name": "perPage",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10
            },
            "description": "Number of items per page"
          },
          {
            "in": "query",
            "name": "sort",
            "schema": {
              "type": "string",
              "enum": [
                "faktooraId",
                "invoiceNumber",
                "issueDate",
                "createdAt"
              ]
            },
            "description": "Field to sort by"
          },
          {
            "in": "query",
            "name": "order",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            },
            "description": "Sort order"
          },
          {
            "in": "query",
            "name": "keyword",
            "schema": {
              "type": "string"
            },
            "description": "Search keyword for filtering invoices"
          },
          {
            "in": "query",
            "name": "invoiceNumber",
            "schema": {
              "type": "string"
            },
            "description": "Filter by invoiceNumber"
          },
          {
            "in": "query",
            "name": "startIssueDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter by issue date range start"
          },
          {
            "in": "query",
            "name": "endIssueDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter by issue date range end"
          },
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter by creation date range start"
          },
          {
            "in": "query",
            "name": "endDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter by creation date range end"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of outgoing imported invoices",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/InvoiceItemDto"
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "page": {
                          "type": "integer",
                          "description": "Current page number"
                        },
                        "perPage": {
                          "type": "integer",
                          "description": "Items per page"
                        },
                        "totalPages": {
                          "type": "integer",
                          "description": "Total number of pages"
                        },
                        "totalItems": {
                          "type": "integer",
                          "description": "Total number of items"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized request"
          }
        },
        "operationId": "getImportOutgoing"
      },
      "post": {
        "tags": [
          "Outgoing Import Invoice"
        ],
        "summary": "Import an e-invoice",
        "description": "Upload an e-invoice in XRechnung or ZUGFeRD format for validation and processing.\n",
        "security": [
          {
            "apiKeyAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "The invoice file to be uploaded."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Invoice upload accepted for processing.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "faktooraId": {
                      "type": "string",
                      "description": "Unique identifier for the import task.",
                      "example": "IMP456789"
                    },
                    "detailsPage": {
                      "type": "string",
                      "description": "URL to view the import task details.",
                      "example": "https://faktoora.com/invoice/details/a81bc81b-dead-4e5d-abff-90865d1e13b1"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request payload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized request."
          }
        },
        "operationId": "postImportOutgoing"
      }
    },
