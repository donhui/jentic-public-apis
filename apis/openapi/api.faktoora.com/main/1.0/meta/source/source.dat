    "/import/incoming/{importId}/status": {
      "get": {
        "tags": [
          "Incoming Import Invoice"
        ],
        "summary": "Returns the status of the import task",
        "parameters": [
          {
            "in": "path",
            "name": "importId",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ],
        "description": "this endpoint returns the status of the incoming import tasks. This is the status of the import, NOT the status of the invoice itself. It returns three status keys: validationStatus (validates the invoice against e-invoicing standards (XRechnung/ZUGFeRD)), visualizationStatus (generates a PDF representation of the invoice) and overallStatus (combines both phases to give the complete import state). Possible values are: accepted, failed, pending.\n",
        "security": [
          {
            "apiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Represents the current processing status of an incoming imported invoice.\nThe import process has three status keys: validationStatus (validates the invoice against e-invoicing standards (XRechnung/ZUGFeRD)), visualizationStatus (generates a PDF representation of the invoice), and overallStatus (combines both phases to give the complete import state).\nEach status can be 'accepted' (completed), 'pending' (in progress), or 'failed'.\n",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ImportStatus"
                  }
                }
              }
            }
          },
          "400": {
            "description": "request failed - bad payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "request unauthorized"
          },
          "404": {
            "description": "import status not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Error"
                  }
                }
              }
            }
          }
        },
        "operationId": "getImportIncomingByImportidStatus"
      }
    },
