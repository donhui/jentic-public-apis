      "ImportTaxes": {
        "type": "object",
        "description": "Tax information for an imported invoice, providing detailed tax calculation data including taxable amounts, rates, and exemption details.\n",
        "properties": {
          "taxable": {
            "type": "number",
            "description": "The taxable amount for this VAT category. This is the base amount on which the VAT is calculated.\n",
            "example": 1000
          },
          "exemptReason": {
            "type": "string",
            "description": "The reason for VAT exemption if applicable. This field provides a textual explanation when VAT is not applied.\n",
            "example": "Export to third country"
          },
          "exemptReasonCode": {
            "type": "string",
            "description": "The code representing the reason for VAT exemption. Uses standardized codes for exemption categories.\n",
            "example": "VATEX-EU-G"
          },
          "amount": {
            "type": "number",
            "description": "The calculated VAT amount for this category. This is the actual tax amount to be paid.\n",
            "example": 190
          },
          "rate": {
            "type": "number",
            "description": "The VAT rate applied as a percentage. For example, 19 represents a 19% VAT rate.\n",
            "example": 19
          },
          "category": {
            "type": "string",
            "description": "The VAT category code based on UN/CEFACT standards. Common categories include S (Standard), Z (Zero rate), E (Exempt), etc.\n",
            "example": "S"
          }
        }
      },
      "ImportPaymentTerms": {
        "type": "object",
        "description": "Payment terms information including discount conditions, due dates, and payment instructions for the imported invoice.\n",
        "properties": {
          "day": {
            "type": "number",
            "description": "Number of days for payment terms (e.g., net 30 days).\n",
            "example": 30
          },
          "percentage": {
            "type": "number",
            "description": "Discount percentage for early payment (e.g., 2% discount).\n",
            "example": 2
          },
          "description": {
            "type": "string",
            "description": "Textual description of the payment terms.\n",
            "example": "2% Skonto bei Zahlung innerhalb 14 Tagen, sonst 30 Tage netto"
          },
          "directDebitMandateID": {
            "type": "string",
            "description": "Direct debit mandate identifier for SEPA direct debit payments.\n",
            "example": "MREF12345678"
          },
          "dueDateTime": {
            "type": "string",
            "description": "Due date and time for the payment.\n",
            "example": "20240215"
          }
        }
      },
      "ImportPaymentMeans": {
        "type": "object",
        "description": "Payment means information for an imported invoice, providing details about available payment methods such as bank transfers, credit cards, and direct debits.\n",
        "properties": {
          "typeCode": {
            "type": "string",
            "description": "The payment method type code indicating the kind of payment means (e.g., BANK_TRANSFER, SEPA_DIRECT_DEBIT, BANK_CARD).\n",
            "example": "BANK_TRANSFER"
          },
          "information": {
            "type": "string",
            "description": "Additional information about the payment means.\n",
            "example": "Primary business account"
          },
          "paymentReference": {
            "type": "string",
            "description": "Reference identifier for the payment means.\n",
            "example": "REF-001"
          }
        },
        "additionalProperties": true
      },
      "ImportListItem": {
        "type": "object",
        "properties": {
          "importId": {
            "type": "string",
            "description": "Unique identifier for the import",
            "example": "IMP123456"
          },
          "invoiceNumber": {
            "type": "string",
            "description": "Invoice number from the imported invoice",
            "example": "INV-2024-001"
          },
          "issueDate": {
            "type": "string",
            "format": "date",
            "description": "Issue date of the invoice",
            "example": "2024-01-15"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the import was created by timestamp",
            "example": "2023-12-01T10:00:00Z"
          },
          "status": {
            "type": "string",
            "description": "Status of the imported invoice",
            "example": "created"
          },
          "amount": {
            "type": "number",
            "description": "Amount of the imported invoice",
            "example": 1000
          },
          "invoiceCurrencyCode": {
            "type": "string",
            "description": "Currency code of the imported invoice",
            "example": "EUR"
          },
          "usedProfile": {
            "type": "string",
            "description": "Used profile of the imported invoice",
            "example": "xrechnung"
          },
          "invoiceTypeCode": {
            "type": "integer",
            "description": "Invoice type code of the imported invoice",
            "example": 380
          },
          "detailsPage": {
            "type": "string",
            "description": "URL to view the import task details.",
            "example": "https://faktoora.com/invoiceincoming/details/a81bc81b-dead-4e5d-abff-90865d1e13b1"
          }
        }
      },
      "ImportContent": {
        "type": "object",
        "description": "Complete content structure for imported invoices\n",
        "properties": {
          "seller": {
            "$ref": "#/components/schemas/ImportSeller",
            "description": "Seller information"
          },
          "buyer": {
            "$ref": "#/components/schemas/ImportBuyer",
            "description": "Buyer information"
          },
          "lineitems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImportLineItems"
            },
            "description": "Invoice line items"
          },
          "taxes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImportTaxes"
            },
            "description": "Taxes information"
          },
          "paymentterms": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImportPaymentTerms"
            },
            "description": "Payment terms"
          },
          "paymentmeans": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImportPaymentMeans"
            },
            "description": "Payment means"
          }
        }
      },
      "ImportAttachment": {
        "type": "object",
        "description": "Attachment metadata for imported invoices\n",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier of the attachment"
          },
          "filename": {
            "type": "string",
            "description": "Original filename of the attachment"
          },
          "reference": {
            "type": "string",
            "description": "Reference identifier for the attachment"
          },
          "description": {
            "type": "string",
            "description": "Description of the attachment"
          },
          "uri": {
            "type": "string",
            "description": "URI path of the attachment"
          },
          "mimecode": {
            "type": "string",
            "description": "MIME type of the attachment file"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp of the attachment",
            "example": "2023-12-01T10:00:00Z"
          }
        }
      },
      "ImportSeller": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the seller",
            "example": "SUP-98234"
          },
          "globalId": {
            "type": "object",
