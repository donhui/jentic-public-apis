              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ImportAttachment"
                  }
                }
              }
            }
          },
          "400": {
            "description": "request failed - bad payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
