            "type": "string",
            "description": "Additional address line 2",
            "example": "Geb\u00e4ude A"
          },
          "LineThree": {
            "type": "string",
            "description": "Additional address line 3",
            "example": "4. Stock"
          },
          "city": {
            "type": "string",
            "description": "City name",
            "example": "M\u00fcnchen"
          },
          "country": {
            "type": "string",
            "description": "Country code",
            "example": "DE"
          },
          "specifiedLegalOrganization": {
            "type": "object",
