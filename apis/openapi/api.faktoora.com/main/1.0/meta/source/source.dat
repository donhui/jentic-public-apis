              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "description": "The event associated with the webhook notification.",
                    "enum": [
                      "invoiceCreated"
                    ]
                  },
                  "target": {
                    "type": "string",
                    "description": "The URL where the webhook notifications are sent.",
                    "example": "https://example.com/webhooks/invoice"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook subscription updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Webhook"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request payload."
          },
          "401": {
            "description": "Unauthorized request."
