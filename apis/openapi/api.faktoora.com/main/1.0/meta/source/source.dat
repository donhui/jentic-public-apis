    "/import/{importId}/validation": {
      "get": {
        "tags": [
          "Invoice import"
        ],
        "summary": "Retrieve validation summary for an imported invoice",
        "description": "Returns the validation status for an imported invoice.\n",
        "security": [
          {
            "apiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "importId",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the import task."
