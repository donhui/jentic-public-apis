      "getPropertyFees-r1-response-schema": {
        "type": "object",
        "required": [
          "response"
        ],
        "properties": {
          "response": {
            "type": "object",
            "required": [
              "result",
              "code"
            ],
            "properties": {
              "requestId": {
                "type": "string",
                "description": "The request ID that was passed in the request",
                "example": "15"
              },
              "code": {
                "type": "integer",
                "description": "The success code",
                "enum": [
                  200
                ],
                "example": 200
              },
              "result": {
                "type": "object",
                "properties": {
                  "propertyFees": {
