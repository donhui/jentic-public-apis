                                      "locationName": {
                                        "type": "string",
                                        "description": "Location name",
                                        "example": "Kitchen"
                                      },
                                      "problems": {
                                        "type": "object",
                                        "required": [
                                          "problem"
                                        ],
                                        "properties": {
                                          "problem": {
                                            "type": "array",
                                            "items": {
                                              "type": "object",
                                              "required": [
                                                "maintenanceProblemId",
                                                "problemName"
                                              ],
                                              "properties": {
