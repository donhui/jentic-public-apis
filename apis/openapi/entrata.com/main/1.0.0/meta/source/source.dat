                                        "type": "string",
                                        "description": "Property ID value",
                                        "example": "12345"
                                      },
                                      "OrganizationName": {
                                        "type": "string",
                                        "description": "Remote organization primary key (optional)",
                                        "example": "Entrata External Org"
                                      }
                                    }
                                  },
                                  "MarketingName": {
                                    "type": "string",
                                    "description": "Property marketing name",
                                    "example": "Sunset Apartments"
