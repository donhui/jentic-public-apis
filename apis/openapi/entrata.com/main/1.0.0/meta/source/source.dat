              "type": {
                "type": "string",
                "enum": [
                  "apikey"
                ],
                "description": "Authentication type",
                "example": "apikey"
              }
            }
          },
          "requestId": {
            "type": "string",
            "description": "An arbitrary value sent with the request.",
            "example": "15"
          },
          "method": {
            "type": "object",
            "required": [
              "name",
              "params"
            ],
