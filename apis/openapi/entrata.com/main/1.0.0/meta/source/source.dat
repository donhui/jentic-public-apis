      "sendBudgets-r1-response-schema": {
        "type": "object",
        "required": [
          "response"
        ],
        "properties": {
          "response": {
            "type": "object",
            "required": [
              "result",
              "code"
            ],
            "properties": {
              "requestId": {
                "type": "string",
                "description": "The request ID that was passed in the request",
                "example": "15"
              },
              "code": {
                "type": "integer",
                "description": "The success code",
                "enum": [
                  200
                ],
                "example": 200
              },
              "result": {
                "type": "object",
                "required": [
                  "budgets"
                ],
                "properties": {
                  "budgets": {
                    "type": "object",
                    "required": [
                      "budget"
                    ],
                    "properties": {
                      "budget": {
                        "type": "array",
                        "description": "Results for each budget processed",
                        "items": {
                          "type": "object",
                          "required": [
                            "node",
                            "status",
                            "message"
                          ],
                          "properties": {
                            "node": {
                              "type": "integer",
                              "description": "Node number (sequential order of budget processed)",
                              "example": 1
                            },
                            "status": {
                              "type": "string",
                              "description": "Processing status for this budget",
                              "enum": [
                                "Success",
                                "Failed"
                              ],
                              "example": "Success"
                            },
                            "message": {
                              "type": "string",
                              "description": "Descriptive message about the processing result",
                              "example": "Budget inserted successfully."
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
