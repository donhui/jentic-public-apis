                    "example": "1,2,3,4,5"
                  },
                  "createdOnDateFrom": {
                    "type": "string",
                    "format": "date",
                    "description": "Start date for filtering activities (ISO 8601 format - yyyy-mm-dd)",
                    "example": "2024-01-01"
                  },
                  "createdOnDateTo": {
                    "type": "string",
                    "format": "date",
                    "description": "End date for filtering activities (ISO 8601 format - yyyy-mm-dd), Start date and end date range should not be more than one year.",
