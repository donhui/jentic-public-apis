                            "@attributes": {
                              "type": "object",
                              "properties": {
                                "reference_id": {
                                  "type": "integer",
                                  "description": "Original transaction ID that was being reversed",
                                  "example": 12345
                                },
                                "transaction_id": {
                                  "type": "integer",
                                  "description": "New reversal transaction ID (if successful, null if failed)",
                                  "example": 54321
                                },
                                "status": {
                                  "type": "string",
