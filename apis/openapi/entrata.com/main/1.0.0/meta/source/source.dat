                              "example": 1001
                            },
                            "applicantId": {
                              "type": "integer",
                              "description": "Created applicant ID (if successful)",
                              "example": 2001
                            },
                            "status": {
                              "type": "string",
                              "description": "Processing status",
                              "enum": [
                                "Success",
                                "Failure"
                              ],
                              "example": "Success"
