      "getMitsCollections-r1-request-schema": {
        "description": "Retrieves MITS collections data for a property.",
        "type": "object",
        "required": [
          "auth",
          "method"
        ],
        "properties": {
          "auth": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "apikey"
                ],
                "description": "Authentication type",
                "example": "apikey"
              }
            }
          },
          "requestId": {
            "type": "string",
            "description": "an arbitrary value sent with the request.",
            "example": "15"
          },
          "method": {
            "type": "object",
            "required": [
              "name",
              "params"
            ],
            "properties": {
              "name": {
                "type": "string",
                "enum": [
                  "getMitsCollections"
                ],
                "description": "Method name to be called",
                "example": "getMitsCollections"
              },
              "version": {
                "type": "string",
                "enum": [
                  "r1"
                ],
                "description": "API version",
                "example": "r1"
              },
              "params": {
                "type": "object",
                "required": [
                  "propertyId"
                ],
                "properties": {
                  "propertyId": {
                    "type": "integer",
                    "description": "The ID of the property",
                    "example": 12345
                  },
                  "fromDate": {
                    "type": "string",
                    "pattern": "^(0[1-9]|1[0-2])/(0[1-9]|[12][0-9]|3[01])/[0-9]{4}$",
                    "description": "Filter leases from this date (mm/dd/yyyy) (optional)",
                    "example": "01/01/2024"
                  },
                  "transactionFromDate": {
                    "type": "string",
                    "pattern": "^(0[1-9]|1[0-2])/(0[1-9]|[12][0-9]|3[01])/[0-9]{4}$",
                    "description": "Filter transactions from this date (mm/dd/yyyy) (optional)",
                    "example": "01/01/2024"
                  },
                  "includeEvictions": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Whether to include evictions (0 for false, 1 for true) (optional)",
                    "example": 0
                  }
                },
                "description": "Method parameters"
              }
            }
          }
        }
      },
