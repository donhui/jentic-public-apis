                                          "example": "Entrata External Org"
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      },
                      "Unit": {
                        "type": "object",
                        "properties": {
                          "Identification": {
                            "type": "object",
                            "properties": {
                              "@attributes": {
                                "type": "object",
                                "properties": {
                                  "IDType": {
                                    "type": "string",
                                    "description": "ID type",
                                    "example": "Unit ID"
                                  },
                                  "IDRank": {
                                    "type": "string",
                                    "description": "ID rank",
                                    "example": "primary"
