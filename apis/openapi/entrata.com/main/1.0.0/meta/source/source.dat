                                      "type": "string",
                                      "description": "Vendor address line 1",
                                      "example": "123 Main Street"
                                    },
                                    "vendorAddress2": {
                                      "type": "string",
                                      "description": "Vendor address line 2",
                                      "example": "Suite 100"
