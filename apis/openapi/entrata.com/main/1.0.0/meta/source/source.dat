                "type": "string",
                "description": "The request ID that was passed in the request",
                "example": "15"
              },
              "code": {
                "type": "integer",
                "enum": [
                  200
                ],
                "example": 200
              },
              "result": {
                "type": "object",
                "properties": {
                  "EventTypes": {
                    "type": "object",
                    "required": [
                      "EventType"
                    ],
                    "properties": {
                      "EventType": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "@attributes": {
                              "type": "object",
                              "properties": {
                                "name": {
                                  "type": "string",
                                  "description": "MITS event name",
                                  "example": "EmailFromProspect"
                                },
                                "Id": {
                                  "type": "integer",
                                  "description": "Event type ID",
