{
  "openapi": "3.0.3",
  "info": {
    "title": "AT&T OAuth",
    "description": "AT&T OAuth 2.0 API for obtaining, refreshing, and managing access tokens for AT&T platform APIs.",
    "version": "v4",
    "x-jentic-source-url": "https://developer.att.com/oauth-2/docs"
  },
  "servers": [
    {
      "url": "https://api.att.com"
    }
  ],
  "security": [
    {
      "clientCredentials": []
    }
  ],
  "tags": [
    {
      "name": "OAuth",
      "description": "OAuth 2.0 token operations"
    }
  ],
  "paths": {
    "/oauth/v4/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Get or refresh an access token",
        "description": "Obtains an access token using authorization code, client credentials, or refresh token grant types.",
        "tags": ["OAuth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["client_id", "client_secret", "grant_type"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "App Key identifier"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "App Secret key"
                  },
                  "grant_type": {
                    "type": "string",
                    "description": "OAuth grant type",
                    "enum": ["authorization_code", "client_credentials", "refresh_token"]
                  },
                  "code": {
                    "type": "string",
                    "description": "OAuth authorization code (required for authorization_code grant)"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token (required for refresh_token grant)"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Comma-delimited API scope list (required for client_credentials grant)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token successfully issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters or grant type",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid client credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "clientCredentials": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://api.att.com/oauth/v4/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The access token string"
          },
          "token_type": {
            "type": "string",
            "description": "Token type, typically bearer",
            "example": "bearer"
          },
          "expires_in": {
            "type": "integer",
            "description": "Token lifetime in seconds",
            "example": 172800
          },
          "refresh_token": {
            "type": "string",
            "description": "Refresh token for obtaining new access tokens"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code"
          },
          "error_description": {
            "type": "string",
            "description": "Human-readable error description"
          }
        }
      }
    }
  }
}