{
  "openapi": "3.0.3",
  "info": {
    "title": "Flexpa FHIR API",
    "version": "1.0.0",
    "description": "Flexpa FHIR R4 API for accessing healthcare data including patient records, explanations of benefit, providers, and organizations via FHIR-compliant endpoints.",
    "x-jentic-source-url": "https://www.flexpa.com/docs/tools/api"
  },
  "servers": [
    {
      "url": "https://api.flexpa.com"
    }
  ],
  "paths": {
    "/fhir/{resourceType}/{id}": {
      "get": {
        "operationId": "readResource",
        "summary": "Read Resource",
        "description": "Retrieve a single FHIR resource by its type and ID.",
        "tags": ["FHIR Resources"],
        "parameters": [
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The FHIR resource type (e.g., Patient, ExplanationOfBenefit, Coverage)"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The resource ID"
          }
        ],
        "responses": {
          "200": {
            "description": "FHIR resource retrieved",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/FhirResource"
                }
              }
            }
          },
          "403": { "description": "Insufficient permissions", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } },
          "404": { "description": "Resource not found", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } }
        }
      }
    },
    "/fhir/{resourceType}": {
      "get": {
        "operationId": "searchResources",
        "summary": "Search Resources",
        "description": "Search FHIR resources with filtering, pagination, and includes.",
        "tags": ["FHIR Resources"],
        "parameters": [
          {
            "name": "resourceType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The FHIR resource type to search"
          },
          {
            "name": "_include",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Related resources to include in the response"
          },
          {
            "name": "_revinclude",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Reverse include references"
          },
          {
            "name": "_count",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Number of results per page"
          },
          {
            "name": "_offset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Pagination offset"
          },
          {
            "name": "_total",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Include total count in response"
          },
          {
            "name": "_sort",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Sort order for results"
          }
        ],
        "responses": {
          "200": {
            "description": "FHIR Bundle with search results",
            "content": {
              "application/fhir+json": {
                "schema": {
                  "$ref": "#/components/schemas/Bundle"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } },
          "401": { "description": "Unauthorized", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } }
        }
      }
    },
    "/fhir/Patient/{patientId}/$everything": {
      "get": {
        "operationId": "patientEverything",
        "summary": "Patient $everything",
        "description": "Retrieve all patient-compartmentalized resources.",
        "tags": ["Patient Operations"],
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The patient ID (use $PATIENT_ID wildcard with Patient Access Token)"
          }
        ],
        "responses": {
          "200": {
            "description": "Bundle with complete patient data",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Bundle" }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } },
          "422": { "description": "Processing error", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } }
        }
      }
    },
    "/fhir/Patient/{patientId}/$summary": {
      "get": {
        "operationId": "patientSummary",
        "summary": "Patient $summary",
        "description": "Generate International Patient Summary document.",
        "tags": ["Patient Operations"],
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The patient ID"
          },
          {
            "name": "_section",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Restrict sections by LOINC code"
          }
        ],
        "responses": {
          "200": {
            "description": "Bundle of type document with Composition and PDF",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Bundle" }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } }
        }
      }
    },
    "/fhir/Patient/{patientId}/$health-cards-issue": {
      "post": {
        "operationId": "healthCardsIssue",
        "summary": "Issue Health Cards",
        "description": "Create SMART Health Card verifiable credential for a patient.",
        "tags": ["Patient Operations"],
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The patient ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/fhir+json": {
              "schema": {
                "type": "object",
                "required": ["resourceType", "parameter"],
                "properties": {
                  "resourceType": { "type": "string", "enum": ["Parameters"] },
                  "parameter": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "valueUri": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Health card credential issued",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/FhirResource" }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } }
        }
      }
    },
    "/fhir/Patient/{patientId}/$expunge": {
      "post": {
        "operationId": "patientExpunge",
        "summary": "Expunge Patient Data",
        "description": "Permanently delete all patient compartment data.",
        "tags": ["Patient Operations"],
        "parameters": [
          {
            "name": "patientId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "The patient ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Patient data expunged",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/OperationOutcome" }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } }
        }
      }
    },
    "/fhir/ViewDefinition/$run": {
      "post": {
        "operationId": "runViewDefinition",
        "summary": "Run ViewDefinition",
        "description": "Extract and parse FHIR data using a ViewDefinition resource.",
        "tags": ["ViewDefinition"],
        "parameters": [
          {
            "name": "_count",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Resources per page"
          },
          {
            "name": "_offset",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Pagination offset"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/fhir+json": {
              "schema": {
                "type": "object",
                "required": ["resourceType"],
                "properties": {
                  "resourceType": { "type": "string", "enum": ["Parameters"] },
                  "parameter": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string", "description": "Parameter name (viewResource, patient, _format, _limit)" },
                        "resource": { "type": "object", "description": "ViewDefinition resource" },
                        "valueReference": { "type": "object", "description": "Reference to a patient" },
                        "valueCode": { "type": "string", "description": "Output format: json or csv" },
                        "valueInteger": { "type": "integer", "description": "Maximum rows to return" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "View definition executed",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } }
        }
      }
    },
    "/fhir/metadata": {
      "get": {
        "operationId": "getCapabilityStatement",
        "summary": "Capability Statement",
        "description": "Retrieve the API capability statement. No authentication required.",
        "tags": ["Metadata"],
        "security": [],
        "responses": {
          "200": {
            "description": "CapabilityStatement resource",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/FhirResource" }
              }
            }
          }
        }
      }
    },
    "/fhir/Practitioner": {
      "get": {
        "operationId": "searchPractitioners",
        "summary": "Search Practitioners",
        "description": "Search provider directory by name, NPI, or location.",
        "tags": ["Provider Directory"],
        "parameters": [
          {
            "name": "_project",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Project ID for the provider directory"
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Practitioner name"
          },
          {
            "name": "identifier",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "NPI identifier"
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Address search"
          }
        ],
        "responses": {
          "200": {
            "description": "Bundle of Practitioner resources",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Bundle" }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } }
        }
      }
    },
    "/fhir/Organization": {
      "get": {
        "operationId": "searchOrganizations",
        "summary": "Search Organizations",
        "description": "Search healthcare organizations in provider directory.",
        "tags": ["Provider Directory"],
        "parameters": [
          {
            "name": "_project",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Project ID for the provider directory"
          },
          {
            "name": "name",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Organization name"
          },
          {
            "name": "identifier",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "NPI identifier"
          },
          {
            "name": "address",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Address search"
          }
        ],
        "responses": {
          "200": {
            "description": "Bundle of Organization resources",
            "content": {
              "application/fhir+json": {
                "schema": { "$ref": "#/components/schemas/Bundle" }
              }
            }
          },
          "401": { "description": "Unauthorized", "content": { "application/fhir+json": { "schema": { "$ref": "#/components/schemas/OperationOutcome" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FhirResource": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string" },
          "id": { "type": "string" }
        }
      },
      "Bundle": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string", "enum": ["Bundle"] },
          "type": { "type": "string" },
          "total": { "type": "integer" },
          "link": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "relation": { "type": "string" },
                "url": { "type": "string" }
              }
            }
          },
          "entry": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "resource": { "$ref": "#/components/schemas/FhirResource" }
              }
            }
          }
        }
      },
      "OperationOutcome": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string", "enum": ["OperationOutcome"] },
          "issue": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "severity": { "type": "string" },
                "code": { "type": "string" },
                "diagnostics": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Patient Access Token or Application Access Token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}