              "application/json": {
                "schema": { "$ref": "#/components/schemas/School" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/schools/{id}/buildings": {
      "get": {
        "operationId": "listBuildings",
        "summary": "List buildings for a school",
        "tags": ["Schools"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
