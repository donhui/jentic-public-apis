{
  "openapi": "3.0.3",
  "info": {
    "title": "Schoology REST API",
    "version": "v1",
    "description": "The Schoology API is a RESTful web service that allows programmatic access to the Schoology learning management system. It provides endpoints for managing schools, users, courses, sections, enrollments, grades, assignments, and other educational resources.",
    "x-jentic-source-url": "https://developers.schoology.com/api/"
  },
  "servers": [
    {
      "url": "https://api.schoology.com/v1"
    }
  ],
  "paths": {
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List active users",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "building_id",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Filter by building ID"
          },
          {
            "name": "role_ids",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by role IDs (comma-separated)"
          },
          {
            "name": "parent_access_codes",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by parent access codes"
          },
          {
            "name": "school_uids",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by school UIDs (comma-separated)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of active users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": { "type": "integer" },
                    "user": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/User" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createUser",
        "summary": "Create a user or bulk create users (up to 50)",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "update_existing",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1] },
            "description": "Update existing users if found"
          },
          {
            "name": "ignore_email_conflicts",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1] },
            "description": "Ignore email conflicts"
          },
          {
            "name": "email_conflict_resolution",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Email conflict resolution strategy"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "bulkUpdateUsers",
        "summary": "Bulk update users (up to 50)",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "users": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/UserCreate" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Users updated successfully" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "bulkDeleteUsers",
        "summary": "Bulk delete users",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "uids",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Comma-separated user IDs to delete"
          },
          {
            "name": "option_comment",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comment for deletion"
          },
          {
            "name": "option_keep_enrollments",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1] },
            "description": "Keep enrollments on deletion"
          },
          {
            "name": "email_notification",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1] },
            "description": "Send email notification"
          }
        ],
        "responses": {
          "200": { "description": "Users deleted successfully" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "getUser",
        "summary": "View a single user",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "User ID"
          }
        ],
        "responses": {
          "200": {
            "description": "User details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateUser",
        "summary": "Update a single user",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "User ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated successfully" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete a single user",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "User ID"
          },
          {
            "name": "option_comment",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comment for deletion"
          },
          {
            "name": "option_keep_enrollments",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1] }
          },
          {
            "name": "email_notification",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1] }
          }
        ],
        "responses": {
          "200": { "description": "User deleted successfully" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/me": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current authenticated user info",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "Current user details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/inactive": {
      "get": {
        "operationId": "listInactiveUsers",
        "summary": "List inactive users",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "List of inactive users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/User" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/inactive/{id}": {
      "get": {
        "operationId": "getInactiveUser",
        "summary": "View an inactive user",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "User ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Inactive user details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/reactivate": {
      "put": {
        "operationId": "reactivateUsers",
        "summary": "Reactivate inactive users",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "users": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "uid": { "type": "string" },
                        "option_reenroll": { "type": "integer", "enum": [0, 1] }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Users reactivated successfully" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/languages": {
      "get": {
        "operationId": "listUserLanguages",
        "summary": "List available interface languages",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "Available languages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "language": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": { "type": "string" },
                          "name": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/import/associations/parents": {
      "post": {
        "operationId": "createParentAssociations",
        "summary": "Create parent-child associations",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "associations": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "student_school_uid": { "type": "string" },
                        "parent_school_uid": { "type": "string" },
                        "delete": { "type": "integer", "enum": [0, 1] }
                      },
                      "required": ["student_school_uid", "parent_school_uid"]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Associations created" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/users/import/associations/advisors": {
      "post": {
        "operationId": "createAdvisorAssociations",
        "summary": "Create advisor-student associations",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "associations": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "student_school_uid": { "type": "string" },
                        "advisor_school_uid": { "type": "string" },
                        "delete": { "type": "integer", "enum": [0, 1] }
                      },
                      "required": ["student_school_uid", "advisor_school_uid"]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Associations created" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/app-user-info": {
      "get": {
        "operationId": "getAppUserInfo",
        "summary": "Get app user session info",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "App user session info",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "web_session_timestamp": { "type": "integer" },
                    "api_uid": { "type": "integer" }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/schools": {
      "get": {
        "operationId": "listSchools",
