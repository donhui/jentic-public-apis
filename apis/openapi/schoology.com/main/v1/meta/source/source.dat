              "application/json": {
                "schema": { "$ref": "#/components/schemas/Course" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/courses/{id}": {
      "get": {
        "operationId": "getCourse",
        "summary": "View a course",
        "tags": ["Courses"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Course details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Course" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/courses/{course_id}/sections": {
      "get": {
        "operationId": "listSectionsForCourse",
        "summary": "List sections for a course",
        "tags": ["Sections"],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "include_past",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1] },
            "description": "Include sections with expired grading periods"
          }
        ],
        "responses": {
          "200": {
            "description": "List of sections",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "section": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Section" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "createSection",
        "summary": "Create a section for a course",
        "tags": ["Sections"],
        "parameters": [
          {
            "name": "course_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SectionCreate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Section created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Section" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/sections": {
      "get": {
        "operationId": "listSectionsBySchoolCode",
        "summary": "List sections by school code",
        "tags": ["Sections"],
        "parameters": [
          {
            "name": "section_school_codes",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated section school codes (up to 50)"
          },
          {
            "name": "include_past",
            "in": "query",
            "schema": { "type": "integer", "enum": [0, 1] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of sections",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "section": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Section" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "bulkUpdateSections",
        "summary": "Bulk update sections (up to 50)",
        "tags": ["Sections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sections": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/SectionCreate" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Sections updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "bulkDeleteSections",
        "summary": "Bulk delete sections",
        "tags": ["Sections"],
        "parameters": [
          {
            "name": "section_ids",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Comma-separated section IDs (up to 50)"
          }
        ],
        "responses": {
          "204": { "description": "Sections deleted" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/sections/{id}": {
      "get": {
        "operationId": "getSection",
        "summary": "View a section",
        "tags": ["Sections"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Section details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Section" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateSection",
        "summary": "Update a section",
        "tags": ["Sections"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SectionCreate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Section updated" },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteSection",
        "summary": "Delete a section",
        "tags": ["Sections"],
        "parameters": [
          {
            "name": "id",
