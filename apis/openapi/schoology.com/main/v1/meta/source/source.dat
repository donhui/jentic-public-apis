  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "uid": { "type": "integer" },
          "id": { "type": "integer" },
          "school_id": { "type": "integer" },
          "school_uid": { "type": "string" },
          "name_first": { "type": "string" },
          "name_last": { "type": "string" },
          "name_middle": { "type": "string" },
          "name_first_preferred": { "type": "string" },
          "username": { "type": "string" },
          "primary_email": { "type": "string" },
          "role_id": { "type": "integer" },
          "gender": { "type": "string" },
          "grad_year": { "type": "string" },
          "timezone": { "type": "string" },
          "picture_url": { "type": "string" }
        }
      },
      "UserCreate": {
        "type": "object",
        "required": ["school_uid", "name_first", "name_last", "role_id"],
        "properties": {
          "school_uid": { "type": "string" },
          "name_first": { "type": "string" },
          "name_last": { "type": "string" },
          "name_middle": { "type": "string" },
          "name_first_preferred": { "type": "string" },
          "username": { "type": "string" },
          "primary_email": { "type": "string" },
          "role_id": { "type": "integer" },
          "gender": { "type": "string" },
          "grad_year": { "type": "string" },
          "timezone": { "type": "string" }
        }
      },
      "School": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "address1": { "type": "string" },
          "address2": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "postal_code": { "type": "string" },
          "country": { "type": "string" },
          "website": { "type": "string" },
          "phone": { "type": "string" }
        }
      },
      "Building": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "building_code": { "type": "string" },
          "address1": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "postal_code": { "type": "string" }
        }
      },
      "Course": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "course_code": { "type": "string" },
          "department": { "type": "string" },
          "description": { "type": "string" },
          "credits": { "type": "number" },
          "subject_area": { "type": "string" }
        }
      },
      "Section": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "course_id": { "type": "integer" },
          "school_id": { "type": "integer" },
          "title": { "type": "string" },
          "section_code": { "type": "string" },
          "section_school_code": { "type": "string" },
          "access_code": { "type": "string" },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "meeting_days": { "type": "string" },
          "start_time": { "type": "string" },
          "end_time": { "type": "string" },
          "grading_periods": {
            "type": "array",
            "items": { "type": "integer" }
          }
        }
      },
      "SectionCreate": {
        "type": "object",
        "required": ["title", "grading_periods"],
        "properties": {
          "title": { "type": "string" },
          "section_code": { "type": "string" },
          "section_school_code": { "type": "string" },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "meeting_days": { "type": "string" },
          "start_time": { "type": "string" },
          "end_time": { "type": "string" },
          "grading_periods": {
            "type": "array",
            "items": { "type": "integer" }
          }
        }
      },
      "Enrollment": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "uid": { "type": "integer" },
          "name_first": { "type": "string" },
          "name_last": { "type": "string" },
          "admin": { "type": "integer", "description": "0 for student, 1 for teacher" },
          "status": { "type": "integer", "description": "1=Active, 2=Expired, 3=Invite pending, 4=Request pending, 5=Archived" },
          "picture_url": { "type": "string" }
        }
      },
      "EnrollmentCreate": {
        "type": "object",
        "required": ["uid", "admin", "status"],
        "properties": {
          "uid": { "type": "integer" },
          "admin": { "type": "integer", "enum": [0, 1] },
          "status": { "type": "integer", "enum": [1, 2, 3, 4, 5] }
        }
      },
      "Grade": {
        "type": "object",
        "properties": {
          "enrollment_id": { "type": "integer" },
          "assignment_id": { "type": "integer" },
          "grade": { "type": "string" },
          "exception": { "type": "integer" },
          "max_points": { "type": "number" },
