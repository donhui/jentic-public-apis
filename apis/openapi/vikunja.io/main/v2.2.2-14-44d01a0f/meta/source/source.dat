            "description": "A message telling you everything was migrated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/models.Message"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/models.Message"
                }
              }
            }
          }
        },
        "security": [
          {
            "JWTKeyAuth": []
          }
        ],
        "x-codegen-request-body-name": "migrationCode"
      }
