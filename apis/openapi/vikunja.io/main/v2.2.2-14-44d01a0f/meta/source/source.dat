          "relation_kind": {
            "type": "object",
            "description": "The kind of the relation.",
            "allOf": [
              {
                "$ref": "#/components/schemas/models.RelationKind"
              }
            ]
          },
          "task_id": {
            "type": "integer",
            "description": "The ID of the \"base\" task, the task which has a relation to another."
          }
        }
      },
