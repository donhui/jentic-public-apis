{
  "openapi": "3.0.3",
  "info": {
    "title": "Process Street API",
    "version": "1.1.0",
    "description": "Process Street is a workflow and checklist management platform. This API provides access to workflows, workflow runs, tasks, comments, form fields, data sets, users, and webhooks.",
    "x-jentic-source-url": "https://developer.process.st/"
  },
  "servers": [
    {
      "url": "https://public-api.process.st/api/v1.1",
      "description": "Process Street Production API"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    { "name": "Comments", "description": "Comment management" },
    { "name": "Workflows", "description": "Workflow template management" },
    { "name": "WorkflowRuns", "description": "Workflow run (checklist) management" },
    { "name": "Tasks", "description": "Task management within workflow runs" },
    { "name": "Approvals", "description": "Task approval management" },
    { "name": "FormFields", "description": "Form field and value management" },
    { "name": "DataSets", "description": "Data set and record management" },
    { "name": "Users", "description": "User management" },
    { "name": "Webhooks", "description": "Webhook subscription management" },
    { "name": "Utilities", "description": "Utility endpoints" }
  ],
  "paths": {
    "/comments": {
      "get": {
        "operationId": "listComments",
        "tags": ["Comments"],
        "summary": "List comments sorted by creation date",
        "parameters": [
          { "name": "workflowId", "in": "query", "schema": { "type": "string" } },
          { "name": "workflowRunId", "in": "query", "schema": { "type": "string" } },
          { "name": "taskId", "in": "query", "schema": { "type": "string" } },
          { "name": "_", "in": "query", "schema": { "type": "string" }, "description": "Pagination cursor" }
        ],
        "responses": {
          "200": { "description": "List of comments", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommentListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createComment",
        "tags": ["Comments"],
        "summary": "Create a comment on a task",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateCommentRequest" } } } },
        "responses": {
          "201": { "description": "Comment created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommentResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/comments/{commentId}": {
      "get": {
        "operationId": "getComment",
        "tags": ["Comments"],
        "summary": "Get a comment by ID",
        "parameters": [ { "$ref": "#/components/parameters/CommentId" } ],
        "responses": {
          "200": { "description": "Comment details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommentResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateComment",
        "tags": ["Comments"],
        "summary": "Update comment text",
        "parameters": [ { "$ref": "#/components/parameters/CommentId" } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateCommentRequest" } } } },
        "responses": {
          "204": { "description": "Comment updated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteComment",
        "tags": ["Comments"],
        "summary": "Delete a comment",
        "parameters": [ { "$ref": "#/components/parameters/CommentId" } ],
        "responses": {
          "204": { "description": "Comment deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflows": {
      "get": {
        "operationId": "listWorkflows",
        "tags": ["Workflows"],
        "summary": "List active workflows",
        "parameters": [
          { "name": "name", "in": "query", "schema": { "type": "string" }, "description": "Partial name match filter" },
          { "name": "_", "in": "query", "schema": { "type": "string" }, "description": "Pagination cursor" }
        ],
        "responses": {
          "200": { "description": "List of workflows", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorkflowListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflows/{workflowId}/tasks": {
      "get": {
        "operationId": "listWorkflowTasks",
        "tags": ["Workflows"],
        "summary": "List tasks for a workflow template",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowId" },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of task templates", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaskTemplateListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflows/{workflowId}/form-fields": {
      "get": {
        "operationId": "listWorkflowFormFields",
        "tags": ["FormFields"],
        "summary": "List form fields for a workflow",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowId" },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of form fields", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FormFieldListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflows/{workflowId}/form-fields/{formFieldId}/options": {
      "get": {
        "operationId": "listFormFieldOptions",
        "tags": ["FormFields"],
        "summary": "List options for a form field",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowId" },
          { "$ref": "#/components/parameters/FormFieldId" },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of options", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FormFieldOptionsResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs": {
      "get": {
        "operationId": "listWorkflowRuns",
        "tags": ["WorkflowRuns"],
        "summary": "Search workflow runs",
        "parameters": [
          { "name": "workflowId", "in": "query", "schema": { "type": "string" } },
          { "name": "name", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["Active", "Completed", "Archived"] } }
        ],
        "responses": {
          "200": { "description": "List of workflow runs", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorkflowRunListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createWorkflowRun",
        "tags": ["WorkflowRuns"],
        "summary": "Create a new workflow run",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateWorkflowRunRequest" } } } },
        "responses": {
          "201": { "description": "Workflow run created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorkflowRunResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}": {
      "get": {
        "operationId": "getWorkflowRun",
        "tags": ["WorkflowRuns"],
        "summary": "Get a workflow run by ID",
        "parameters": [ { "$ref": "#/components/parameters/WorkflowRunId" } ],
        "responses": {
          "200": { "description": "Workflow run details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorkflowRunResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateWorkflowRun",
        "tags": ["WorkflowRuns"],
        "summary": "Update a workflow run",
        "parameters": [ { "$ref": "#/components/parameters/WorkflowRunId" } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateWorkflowRunRequest" } } } },
        "responses": {
          "204": { "description": "Workflow run updated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteWorkflowRun",
        "tags": ["WorkflowRuns"],
        "summary": "Delete a workflow run",
        "parameters": [ { "$ref": "#/components/parameters/WorkflowRunId" } ],
        "responses": {
          "200": { "description": "Workflow run deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/undelete": {
      "post": {
        "operationId": "undeleteWorkflowRun",
        "tags": ["WorkflowRuns"],
        "summary": "Restore a deleted workflow run",
        "parameters": [ { "$ref": "#/components/parameters/WorkflowRunId" } ],
        "responses": {
          "200": { "description": "Workflow run restored" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/assignees": {
      "get": {
        "operationId": "listWorkflowRunAssignees",
        "tags": ["WorkflowRuns"],
        "summary": "List workflow run assignees",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of assignees", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AssigneeListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/assignees/{email}": {
      "post": {
        "operationId": "assignUserToWorkflowRun",
        "tags": ["WorkflowRuns"],
        "summary": "Assign user to a workflow run",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/Email" }
        ],
        "responses": {
          "204": { "description": "User assigned" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "unassignUserFromWorkflowRun",
        "tags": ["WorkflowRuns"],
        "summary": "Unassign user from a workflow run",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/Email" }
        ],
        "responses": {
          "204": { "description": "User unassigned" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tasks": {
      "get": {
        "operationId": "listTasks",
        "tags": ["Tasks"],
        "summary": "List tasks for a given query",
        "parameters": [
          { "name": "assigneeEmail", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "workflowId", "in": "query", "schema": { "type": "string" } },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of tasks", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaskListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/tasks": {
      "get": {
        "operationId": "listWorkflowRunTasks",
        "tags": ["Tasks"],
        "summary": "List tasks for a workflow run",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of tasks", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaskListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/tasks/{taskId}": {
      "get": {
        "operationId": "getTask",
        "tags": ["Tasks"],
        "summary": "Get a task by ID",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/TaskId" }
        ],
        "responses": {
          "200": { "description": "Task details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TaskResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateTask",
        "tags": ["Tasks"],
        "summary": "Update task status and due date",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/TaskId" }
        ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateTaskRequest" } } } },
        "responses": {
          "204": { "description": "Task updated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/tasks/{taskId}/assignees": {
      "get": {
        "operationId": "listTaskAssignees",
        "tags": ["Tasks"],
        "summary": "List task assignees",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/TaskId" }
        ],
        "responses": {
          "200": { "description": "List of assignees", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AssigneeListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/tasks/{taskId}/assignees/{email}": {
      "put": {
        "operationId": "assignUserToTask",
        "tags": ["Tasks"],
        "summary": "Assign user to a task",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/TaskId" },
          { "$ref": "#/components/parameters/Email" }
        ],
        "responses": {
          "204": { "description": "User assigned" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "unassignUserFromTask",
        "tags": ["Tasks"],
        "summary": "Unassign user from a task",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/TaskId" },
          { "$ref": "#/components/parameters/Email" }
        ],
        "responses": {
          "204": { "description": "User unassigned" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/approvals": {
      "get": {
        "operationId": "listApprovals",
        "tags": ["Approvals"],
        "summary": "List approved or rejected approvals",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of approvals", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApprovalListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "upsertApproval",
        "tags": ["Approvals"],
        "summary": "Approve or reject a task",
        "parameters": [ { "$ref": "#/components/parameters/WorkflowRunId" } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpsertApprovalRequest" } } } },
        "responses": {
          "204": { "description": "Approval processed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/form-fields": {
      "get": {
        "operationId": "listFormFieldValues",
        "tags": ["FormFields"],
        "summary": "List form field values for a workflow run",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Form field values", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FormFieldValueListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "batchUpdateFormFieldValues",
        "tags": ["FormFields"],
        "summary": "Batch update multiple form field values",
        "parameters": [ { "$ref": "#/components/parameters/WorkflowRunId" } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BatchUpdateFormFieldValuesRequest" } } } },
        "responses": {
          "200": { "description": "Values updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BatchUpdateFormFieldValuesResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/form-fields/{formFieldId}/upload": {
      "post": {
        "operationId": "uploadFormFieldFile",
        "tags": ["FormFields"],
        "summary": "Upload files to a File or MultiFile form field",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/FormFieldId" }
        ],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "file": { "type": "string", "format": "binary" } } } } } },
        "responses": {
          "204": { "description": "File uploaded" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteAllFormFieldFiles",
        "tags": ["FormFields"],
        "summary": "Delete all files from a form field",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/FormFieldId" }
        ],
        "responses": {
          "204": { "description": "Files deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/form-fields/{formFieldId}/upload/{fileId}": {
      "delete": {
        "operationId": "deleteFormFieldFile",
        "tags": ["FormFields"],
        "summary": "Delete a specific file from a form field",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/FormFieldId" },
          { "name": "fileId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "File deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/workflow-runs/{workflowRunId}/tasks/{taskId}/form-fields": {
      "get": {
        "operationId": "listTaskFormFieldValues",
        "tags": ["FormFields"],
        "summary": "List form field values for a specific task",
        "parameters": [
          { "$ref": "#/components/parameters/WorkflowRunId" },
          { "$ref": "#/components/parameters/TaskId" },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Form field values", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FormFieldValueListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/data-sets": {
      "get": {
        "operationId": "listDataSets",
        "tags": ["DataSets"],
        "summary": "List data sets",
        "parameters": [ { "name": "_", "in": "query", "schema": { "type": "string" } } ],
        "responses": {
          "200": { "description": "List of data sets", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataSetListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/data-sets/{dataSetId}/records": {
      "get": {
        "operationId": "listDataSetRecords",
        "tags": ["DataSets"],
        "summary": "List data set records",
        "parameters": [
          { "$ref": "#/components/parameters/DataSetId" },
          { "name": "columns", "in": "query", "schema": { "type": "string" }, "description": "Search filter" },
          { "name": "_", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of records", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataSetRecordListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createDataSetRecord",
        "tags": ["DataSets"],
        "summary": "Create a new data set record",
        "parameters": [ { "$ref": "#/components/parameters/DataSetId" } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateDataSetRecordRequest" } } } },
        "responses": {
          "201": { "description": "Record created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataSetRecordResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/data-sets/{dataSetId}/records/import": {
      "post": {
        "operationId": "importDataSetRecords",
        "tags": ["DataSets"],
        "summary": "Import records from CSV",
        "parameters": [ { "$ref": "#/components/parameters/DataSetId" } ],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "type": "object", "properties": { "strategy": { "type": "string" }, "file": { "type": "string", "format": "binary" }, "key": { "type": "string" } } } } } },
        "responses": {
          "200": { "description": "Import completed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ImportDataSetRecordsResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/data-sets/{dataSetId}/records/{dataSetRecordId}": {
      "get": {
        "operationId": "getDataSetRecord",
        "tags": ["DataSets"],
        "summary": "Get a data set record",
        "parameters": [
          { "$ref": "#/components/parameters/DataSetId" },
          { "$ref": "#/components/parameters/DataSetRecordId" }
        ],
        "responses": {
          "200": { "description": "Record details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataSetRecordResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateDataSetRecord",
        "tags": ["DataSets"],
        "summary": "Update a data set record",
        "parameters": [
          { "$ref": "#/components/parameters/DataSetId" },
          { "$ref": "#/components/parameters/DataSetRecordId" }
        ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateDataSetRecordRequest" } } } },
        "responses": {
          "200": { "description": "Record updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataSetRecordResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteDataSetRecord",
        "tags": ["DataSets"],
        "summary": "Delete a data set record",
        "parameters": [
          { "$ref": "#/components/parameters/DataSetId" },
          { "$ref": "#/components/parameters/DataSetRecordId" }
        ],
        "responses": {
          "200": { "description": "Record deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DataSetRecordResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/users": {
      "get": {
        "operationId": "listUsers",
        "tags": ["Users"],
        "summary": "List users",
        "parameters": [ { "name": "_", "in": "query", "schema": { "type": "string" } } ],
        "responses": {
          "200": { "description": "List of users", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserListResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/webhooks": {
      "post": {
        "operationId": "createWebhook",
        "tags": ["Webhooks"],
        "summary": "Create a webhook subscription",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateWebhookRequest" } } } },
        "responses": {
          "201": { "description": "Webhook created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WebhookResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/webhooks/{webhookId}": {
      "delete": {
        "operationId": "deleteWebhook",
        "tags": ["Webhooks"],
        "summary": "Delete a webhook subscription",
        "parameters": [ { "name": "webhookId", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "responses": {
          "200": { "description": "Webhook deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/testAuth": {
      "get": {
        "operationId": "testAuth",
        "tags": ["Utilities"],
        "summary": "Test authentication and return API key label",
        "responses": {
          "200": { "description": "Auth valid", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TestAuthResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "Process Street API key"
      }
    },
    "parameters": {
      "CommentId": { "name": "commentId", "in": "path", "required": true, "schema": { "type": "string" } },
      "WorkflowId": { "name": "workflowId", "in": "path", "required": true, "schema": { "type": "string" } },
      "WorkflowRunId": { "name": "workflowRunId", "in": "path", "required": true, "schema": { "type": "string" } },
      "TaskId": { "name": "taskId", "in": "path", "required": true, "schema": { "type": "string" } },
      "FormFieldId": { "name": "formFieldId", "in": "path", "required": true, "schema": { "type": "string" } },
      "Email": { "name": "email", "in": "path", "required": true, "schema": { "type": "string", "format": "email" } },
      "DataSetId": { "name": "dataSetId", "in": "path", "required": true, "schema": { "type": "string" } },
      "DataSetRecordId": { "name": "dataSetRecordId", "in": "path", "required": true, "schema": { "type": "string" } }
    },
    "responses": {
      "BadRequest": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "Unauthorized": { "description": "Unauthorized - invalid or missing API key", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
    },
    "schemas": {
      "Error": { "type": "object", "properties": { "message": { "type": "string" }, "code": { "type": "integer" } } },
      "Comment": { "type": "object", "properties": { "id": { "type": "string" }, "text": { "type": "string" }, "workflowRunId": { "type": "string" }, "taskId": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },
      "CommentListResponse": { "type": "object", "properties": { "comments": { "type": "array", "items": { "$ref": "#/components/schemas/Comment" } }, "nextPageId": { "type": "string" } } },
      "CommentResponse": { "type": "object", "properties": { "comment": { "$ref": "#/components/schemas/Comment" } } },
      "CreateCommentRequest": { "type": "object", "properties": { "workflowRunId": { "type": "string" }, "taskId": { "type": "string" }, "text": { "type": "string" } }, "required": ["workflowRunId", "taskId", "text"] },
      "UpdateCommentRequest": { "type": "object", "properties": { "text": { "type": "string" } }, "required": ["text"] },
      "Workflow": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" } } },
      "WorkflowListResponse": { "type": "object", "properties": { "workflows": { "type": "array", "items": { "$ref": "#/components/schemas/Workflow" } }, "nextPageId": { "type": "string" } } },
      "TaskTemplateListResponse": { "type": "object", "properties": { "taskTemplates": { "type": "array", "items": { "type": "object" } }, "nextPageId": { "type": "string" } } },
      "WorkflowRun": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "workflowId": { "type": "string" }, "status": { "type": "string", "enum": ["Active", "Completed", "Archived"] }, "shared": { "type": "boolean" }, "dueDate": { "type": "string", "format": "date-time" }, "createdAt": { "type": "string", "format": "date-time" }, "updatedAt": { "type": "string", "format": "date-time" } } },
      "WorkflowRunListResponse": { "type": "object", "properties": { "workflowRuns": { "type": "array", "items": { "$ref": "#/components/schemas/WorkflowRun" } } } },
      "WorkflowRunResponse": { "type": "object", "properties": { "workflowRun": { "$ref": "#/components/schemas/WorkflowRun" } } },
      "CreateWorkflowRunRequest": { "type": "object", "properties": { "workflowId": { "type": "string" }, "name": { "type": "string" }, "dueDate": { "type": "string", "format": "date-time" }, "shared": { "type": "boolean" } }, "required": ["workflowId", "name"] },
      "UpdateWorkflowRunRequest": { "type": "object", "properties": { "name": { "type": "string" }, "status": { "type": "string", "enum": ["Active", "Completed", "Archived"] }, "shared": { "type": "boolean" }, "dueDate": { "type": "string", "format": "date-time" } } },
      "Task": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "status": { "type": "string" }, "dueDate": { "type": "string", "format": "date-time" } } },
      "TaskListResponse": { "type": "object", "properties": { "tasks": { "type": "array", "items": { "$ref": "#/components/schemas/Task" } }, "nextPageId": { "type": "string" } } },
      "TaskResponse": { "type": "object", "properties": { "task": { "$ref": "#/components/schemas/Task" } } },
      "UpdateTaskRequest": { "type": "object", "properties": { "status": { "type": "string" }, "dueDate": { "type": "string", "format": "date-time" } } },
      "AssigneeListResponse": { "type": "object", "properties": { "assignees": { "type": "array", "items": { "type": "object", "properties": { "email": { "type": "string" }, "name": { "type": "string" } } } }, "nextPageId": { "type": "string" } } },
      "ApprovalListResponse": { "type": "object", "properties": { "approvals": { "type": "array", "items": { "type": "object" } }, "nextPageId": { "type": "string" } } },
      "UpsertApprovalRequest": { "type": "object", "properties": { "approvalTaskId": { "type": "string" }, "subjectTaskId": { "type": "string" }, "status": { "type": "string", "enum": ["Approved", "Rejected"] }, "comment": { "type": "string" } }, "required": ["approvalTaskId", "status"] },
      "FormFieldListResponse": { "type": "object", "properties": { "formFields": { "type": "array", "items": { "type": "object" } }, "nextPageId": { "type": "string" } } },
      "FormFieldOptionsResponse": { "type": "object", "properties": { "options": { "type": "array", "items": { "type": "object" } }, "nextPageId": { "type": "string" } } },
      "FormFieldValueListResponse": { "type": "object", "properties": { "formFieldValues": { "type": "array", "items": { "type": "object" } }, "nextPageId": { "type": "string" } } },
      "BatchUpdateFormFieldValuesRequest": { "type": "object", "properties": { "formFields": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "value": {} } } } } },
      "BatchUpdateFormFieldValuesResponse": { "type": "object", "properties": { "formFieldValues": { "type": "array", "items": { "type": "object" } } } },
      "DataSet": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" } } },
      "DataSetListResponse": { "type": "object", "properties": { "dataSets": { "type": "array", "items": { "$ref": "#/components/schemas/DataSet" } }, "nextPageId": { "type": "string" } } },
      "DataSetRecordListResponse": { "type": "object", "properties": { "records": { "type": "array", "items": { "type": "object" } }, "nextPageId": { "type": "string" } } },
      "DataSetRecordResponse": { "type": "object", "properties": { "record": { "type": "object" } } },
      "CreateDataSetRecordRequest": { "type": "object", "properties": { "cells": { "type": "array", "items": { "type": "object" } } } },
      "UpdateDataSetRecordRequest": { "type": "object", "properties": { "cells": { "type": "array", "items": { "type": "object" } } } },
      "ImportDataSetRecordsResponse": { "type": "object", "properties": { "imported": { "type": "integer" }, "updated": { "type": "integer" } } },
      "UserListResponse": { "type": "object", "properties": { "users": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "email": { "type": "string" } } } }, "nextPageId": { "type": "string" } } },
      "CreateWebhookRequest": { "type": "object", "properties": { "url": { "type": "string", "format": "uri" }, "triggers": { "type": "array", "items": { "type": "string", "enum": ["TaskChecked", "TaskUnchecked", "TaskCheckedUnchecked", "TaskReady", "WorkflowRunCreated", "WorkflowRunCompleted"] } }, "workflowId": { "type": "string" }, "taskId": { "type": "string" } }, "required": ["url", "triggers"] },
      "WebhookResponse": { "type": "object", "properties": { "webhook": { "type": "object", "properties": { "id": { "type": "string" }, "url": { "type": "string" }, "triggers": { "type": "array", "items": { "type": "string" } } } } } },
      "TestAuthResponse": { "type": "object", "properties": { "label": { "type": "string" } } }
    }
  }
}