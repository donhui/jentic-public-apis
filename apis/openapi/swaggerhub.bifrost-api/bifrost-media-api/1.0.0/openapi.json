{
  "swagger": "2.0",
  "info": {
    "description": "These are the functions to manage media upload for different diagnostics",
    "version": "1.0.0",
    "title": "Bifrost Media API",
    "contact": {
      "email": "support@omlabs.io"
    },
    "license": {
      "name": "OM Labs"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/bifrost-api/Bifrost-Media-API/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "tests",
      "description": "Capturing data during the test process"
    },
    {
      "name": "results",
      "description": "Retrieve data to view from previous tests"
    }
  ],
  "paths": {
    "/conditions": {
      "get": {
        "summary": "gets conditions",
        "operationId": "getConditions",
        "description": "Use this to retrieve list of conditions to label data\n",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "code",
            "description": "API key for the system",
            "type": "string",
            "required": true
          },
          {
            "in": "query",
            "name": "tenant_id",
            "description": "Unique identifier for the organization",
            "type": "string",
            "required": true,
            "format": "uuid"
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the list of conditions available to label",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "401": {
            "description": "Invalid API key"
          }
        }
      }
    },
    "/{system}/tests/log/{data_type}": {
      "post": {
        "tags": [
          "tests"
        ],
        "summary": "logs data",
        "operationId": "logData",
        "description": "Use this to generate a 10-minute upload link for the image or video\n",
        "produces": [
          "application/json"
        ],
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "system",
            "description": "Code for the diagnostic system, i.e. grabi, cyclops, etc.",
            "required": true,
            "type": "string"
          },
          {
            "in": "path",
            "name": "data_type",
            "description": "Data type to be uploaded, i.e. image or video",
            "type": "string",
            "required": true
          },
          {
            "in": "query",
            "name": "code",
            "description": "API key for the system",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "<no_name>",
            "description": "Payload to generate appropriate upload link",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LogData"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Data uploaded to all patient records",
            "schema": {
              "$ref": "#/definitions/UploadLink"
            }
          },
          "400": {
            "description": "Data uploaded only to some of the patient records",
            "schema": {
              "$ref": "#/definitions/UploadLink"
            }
          },
          "401": {
            "description": "Invalid API key"
          }
        }
      }
    },
    "/{system}/results/list": {
      "get": {
        "tags": [
          "results"
        ],
        "summary": "lists results",
        "operationId": "listResults",
        "description": "Use this to list all uploaded sessions\n",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "system",
            "description": "Code for the diagnostic system, i.e. grabi, cyclops, etc.",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "code",
            "description": "API key for the system",
            "type": "string",
            "required": true
          },
          {
            "in": "query",
            "name": "tenant_id",
            "type": "string",
            "description": "Unique identifier for organization/hospital",
            "format": "uuid",
            "required": true
          },
          {
            "in": "query",
            "name": "patient_id",
            "type": "string",
            "description": "Unique identifier for patient",
            "required": true,
            "format": "uuid"
          },
          {
            "in": "query",
            "name": "eye",
            "type": "string",
            "description": "Eye imaged, i.e. OS or OD",
            "required": true
          },
          {
            "in": "query",
            "name": "start_date",
            "type": "string",
            "format": "date",
            "description": "Start date in timezone specified, default is organization's timezone",
            "required": true
          },
          {
            "in": "query",
            "name": "end_date",
            "type": "string",
            "format": "date",
            "description": "End date in timezone specified, default is organization's timezone",
            "required": true
          },
          {
            "in": "query",
            "name": "timezone",
            "type": "string",
            "description": "IANA timezone based on which you are doing the search, e.g. Asia/Kolkata"
          }
        ],
        "responses": {
          "200": {
            "description": "List of tests retrieved successfully",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ListItem"
              }
            }
          },
          "401": {
            "description": "Invalid API key"
          }
        }
      }
    },
    "/{system}/results/get": {
      "get": {
        "tags": [
          "results"
        ],
        "summary": "get results",
        "operationId": "getResults",
        "description": "Use this to get results of uploaded session\n",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "system",
            "description": "Code for the diagnostic system, i.e. grabi, cyclops, etc.",
            "required": true,
            "type": "string"
          },
          {
            "in": "query",
            "name": "code",
            "description": "API key for the system",
            "type": "string",
            "required": true
          },
          {
            "in": "query",
            "name": "tenant_id",
            "type": "string",
            "description": "Unique identifier for organization/hospital",
            "format": "uuid",
            "required": true
          },
          {
            "in": "query",
            "name": "patient_id",
            "type": "string",
            "description": "Unique identifier for patient",
            "required": true,
            "format": "uuid"
          },
          {
            "in": "query",
            "name": "id",
            "type": "string",
            "description": "Unique identifier of the session returned by results/list",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Results retrieved successfully",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/MediaData"
              }
            }
          },
          "401": {
            "description": "Invalid API key"
          }
        }
      }
    }
  },
  "definitions": {
    "MediaData": {
      "type": "object",
      "properties": {
        "eye": {
          "type": "string",
          "description": "Eye imaged, i.e. OS or OD",
          "example": "OS"
        },
        "test_date": {
          "type": "string",
          "format": "date-time",
          "description": "The UTC date time of image capture, current time if left blank",
          "example": "2020-10-03T18:30:00"
        },
        "tags": {
          "type": "object",
          "description": "Tags attached to the image for categorization"
        },
        "prediction": {
          "type": "object",
          "description": "Any AI predictions made on the data"
        },
        "comment": {
          "type": "string",
          "description": "Comment left by consultant"
        },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "description": "Data type, i.e. image or video",
                "type": "string",
                "example": "image"
              },
              "url": {
                "description": "The streaming or display URL",
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "age": {
          "type": "integer",
          "format": "int32",
          "description": "Age of the patient at the time of the test"
        }
      }
    },
    "ListItem": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64",
          "description": "Unique identifier for session, usually timestamp"
        },
        "eye": {
          "type": "string",
          "description": "Eye imaged, i.e. OS or OD",
          "example": "OS"
        },
        "test_date": {
          "type": "string",
          "format": "date-time",
          "description": "The UTC date time of image capture, current time if left blank",
          "example": "2020-10-03T18:30:00"
        }
      }
    },
    "UploadLink": {
      "type": "object",
      "properties": {
        "method": {
          "description": "The HTTP method to be used with upload link",
          "type": "string",
          "example": "PUT"
        },
        "url": {
          "description": "The url to which data is to be posted",
          "type": "string",
          "format": "uri"
        },
        "headers": {
          "description": "Key-value pairs to be sent in request headers"
        }
      }
    },
    "LogData": {
      "type": "object",
      "required": [
        "tenant_id",
        "patient_id",
        "eye",
        "file_ext",
        "id"
      ],
      "properties": {
        "tenant_id": {
          "type": "string",
          "description": "Unique identifier for organization/hospital",
          "format": "uuid"
        },
        "patient_id": {
          "type": "string",
          "description": "Unique identifier for patient",
          "format": "uuid"
        },
        "eye": {
          "type": "string",
          "description": "Eye imaged, i.e. OS or OD",
          "example": "OS"
        },
        "file_ext": {
          "type": "string",
          "description": "File extension, i.e. .jpg, .png, .mp4, .video",
          "example": ".mp4"
        },
        "id": {
          "type": "integer",
          "format": "int64",
          "description": "Unique identifier for session, usually timestamp"
        },
        "test_date": {
          "type": "string",
          "format": "date-time",
          "description": "The UTC date time of image capture, current time if left blank",
          "example": "2020-10-03T18:30:00"
        },
        "tags": {
          "type": "object",
          "description": "Tags attached to the image for categorization"
        },
        "prediction": {
          "type": "object",
          "description": "Any AI predictions made on the data"
        },
        "linked_ids": {
          "type": "array",
          "description": "List of other patient IDs for same patient",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        }
      }
    }
  }
}