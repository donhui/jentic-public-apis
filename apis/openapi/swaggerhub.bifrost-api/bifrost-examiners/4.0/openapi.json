    "paths": {
        "/examiner/authenticate/bypass": {
            "post": {
                "summary": "bypasses authentication",
                "operationId": "bypassAuthentication",
                "description": "This API is to be incorporated into the app if you want to authenticate the user without using email/password authentication system\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object"
                            }
                        }
                    },
                    "description": "Key-value pairs of unique tags used internally to identify a user",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successfully retrieved user profile that matched the tags posted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserProfile"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "No profile found with the give tags",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized access. Check API key and try again or contact support@omlabs.io"
                    }
                }
            }
        },
        "/examiner/profile/add": {
            "post": {
                "tags": [
                    "profile"
                ],
                "summary": "adds profile",
                "operationId": "addProfile (POST)",
                "description": "This should be used to create a new profile when the examiner signs up for an account on any Bifrost powered system\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AddRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profile added successfully"
                    },
                    "400": {
                        "description": "An error with cause displayed in body of response",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized access. Check API key and try again or contact support@omlabs.io"
                    }
                }
            }
        },
        "/examiner/profile/get": {
            "get": {
                "tags": [
                    "profile"
                ],
                "summary": "get profile",
                "operationId": "getProfile",
                "description": "This is to retrieve the user profile of the examiner\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "tenant_id",
                        "description": "Unique ID representing the organization/hospital",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    },
                    {
                        "in": "query",
                        "name": "email",
                        "description": "Registered email address of the examiner",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "email"
                        }
                    },
                    {
                        "in": "query",
                        "name": "uuid",
                        "description": "Unique identifier produced by authentication system for email",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User profile retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserProfile"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "An error with cause displayed in body of response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized access. Check API key and try again or contact support@omlabs.io"
                    }
                }
            }
        },
        "/examiner/profile/update": {
            "post": {
                "tags": [
                    "profile"
                ],
                "summary": "update profile",
                "operationId": "updateProfile (POST)",
                "description": "This should be used to update an existing profile of a examiner such as name, picture or languages spoken\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ModifyRequest"
