                    "400": {
                        "description": "An error with cause displayed in body of response",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized access. Check API key and try again or contact support@omlabs.io"
                    },
                    "422": {
                        "description": "Registration parameters not provided in correct format"
                    }
                }
            }
        },
        "/examiner/notifications/register": {
            "post": {
                "tags": [
                    "notifications"
                ],
                "summary": "registers token",
                "operationId": "registersToken (POST)",
                "description": "This should be used to register the user for in-app notifications on firebase\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "$ref": "#/components/requestBodies/NotificationRegister"
                },
                "responses": {
                    "200": {
                        "description": "Registered successfully"
                    },
                    "400": {
                        "description": "An error with cause displayed in body of response",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized access. Check API key and try again or contact support@omlabs.io"
                    },
                    "422": {
                        "description": "Registration parameters not provided in correct format"
                    }
                }
            }
        },
        "/examiner/alerts/count": {
            "get": {
                "tags": [
                    "alerts"
                ],
                "summary": "count all alerts",
                "operationId": "countAlerts",
                "description": "This method should be used get the count of unread alerts\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "email",
                        "description": "Email of the examiner",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "uuid",
                        "description": "Unqiue identifier of the examiner after authentication with email",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "tenant_id",
                        "description": "Unique ID representing the organization/hospital",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Alerts retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "count": {
                                            "description": "Number of alerts unread",
                                            "type": "integer",
                                            "format": "int32"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "An error with cause displayed in body of response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized access. Check API key and try again or contact support@omlabs.io"
                    }
                }
            }
        },
        "/examiner/alerts": {
            "post": {
                "tags": [
                    "alerts"
                ],
                "summary": "post a new alert",
                "operationId": "newAlert",
                "description": "This should be used to add a new alert for the examiner's account\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "$ref": "#/components/requestBodies/NewAlert"
                },
                "responses": {
                    "200": {
                        "description": "Alert added successfully"
                    },
                    "400": {
                        "description": "An error with cause displayed in body of response",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized access. Check API key and try again or contact support@omlabs.io"
                    },
                    "422": {
                        "description": "Alert parameters not provided in correct format",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "get": {
                "tags": [
                    "alerts"
                ],
                "summary": "list all alerts",
                "operationId": "listAlerts",
                "description": "This method should be used to list all the alerts\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "email",
                        "description": "Email of the examiner",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "uuid",
                        "description": "Unqiue identifier of the examiner after authentication with email",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "tenant_id",
                        "description": "Unique ID representing the organization/hospital",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Alerts retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/AlertDetails"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "An error with cause displayed in body of response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized access. Check API key and try again or contact support@omlabs.io"
                    }
                }
            },
            "put": {
                "tags": [
                    "alerts"
                ],
                "summary": "mark alert as read",
                "operationId": "alertRead",
                "description": "This method is used to mark an alert as read\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "$ref": "#/components/requestBodies/NewAlert"
                },
                "responses": {
                    "200": {
                        "description": "Alert marked as read"
                    },
                    "400": {
                        "description": "An error with cause displayed in body of response",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized access. Check API key and try again or contact support@omlabs.io"
                    },
                    "422": {
                        "description": "Alert parameters not provided in correct format",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        }
