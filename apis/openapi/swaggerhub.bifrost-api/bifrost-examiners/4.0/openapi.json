    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/bifrost-api/bifrost-examiners/4.0"
        }
    ],
    "components": {
        "requestBodies": {
            "NotificationRegister": {
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/NotificationRegister"
                        }
                    }
                }
            },
            "NewAlert": {
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/NewAlert"
                        }
                    }
                }
            }
        },
        "schemas": {
            "NewAlert": {
                "type": "object",
                "required": [
                    "tenant_id",
                    "email",
                    "uuid",
                    "title",
                    "message"
                ],
                "properties": {
                    "tenant_id": {
                        "description": "Unique ID representing the organization/hospital",
                        "type": "string",
                        "format": "uuid",
                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5"
                    },
                    "email": {
                        "description": "Email of the examiner",
                        "type": "string",
                        "format": "email",
                        "example": "abc@hospital.com"
                    },
                    "uuid": {
                        "description": "Unqiue identifier of the examiner after authentication with email",
                        "type": "string",
                        "example": "07123kjiusdfslj2lkjfa="
                    },
                    "title": {
                        "type": "string",
                        "description": "Title of the notification"
                    },
                    "message": {
                        "type": "string",
                        "description": "Message content of the notification"
                    },
                    "image": {
                        "type": "string",
                        "format": "uri",
                        "description": "Image to display in expanded mode"
                    },
                    "actions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/AlertAction"
                        }
                    }
                }
            },
            "AlertAction": {
                "type": "object",
                "required": [
                    "type",
                    "label"
                ],
                "properties": {
                    "type": {
                        "type": "string",
                        "description": "Whether button is primary or secondary",
                        "example": "primary/secondary"
                    },
                    "label": {
                        "type": "string",
                        "description": "Label to be displayed on the button"
                    },
                    "url": {
                        "type": "string",
                        "format": "uri",
                        "description": "Url to access on button click"
                    },
                    "method": {
                        "type": "string",
                        "description": "Http method",
                        "example": "GET, PUT or POST"
                    },
                    "payload": {
                        "type": "object",
                        "description": "Data to pass as payload to url"
                    },
                    "headers": {
                        "type": "object",
                        "description": "Headers to pass to url"
                    }
                }
            },
            "AlertDetails": {
                "type": "object",
                "required": [
                    "title",
                    "message"
                ],
                "properties": {
                    "title": {
                        "type": "string",
                        "description": "Title of the notification"
                    },
                    "message": {
                        "type": "string",
                        "description": "Message content of the notification"
                    },
                    "image": {
                        "type": "string",
                        "format": "uri",
                        "description": "Image to display in expanded mode"
                    },
                    "actions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/AlertAction"
                        }
                    }
                }
            },
            "NotificationRegister": {
                "type": "object",
                "required": [
                    "tenant_id",
                    "email",
                    "device_token",
                    "system"
                ],
                "properties": {
                    "tenant_id": {
                        "description": "Unique ID representing the organization/hospital",
                        "type": "string",
                        "format": "uuid",
                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5"
                    },
                    "email": {
                        "description": "Email of the examiner",
                        "type": "string",
                        "format": "email",
                        "example": "abc@hospital.com"
                    },
                    "device_token": {
                        "description": "Firebase cloud messaging registration token to remove/add",
                        "type": "string"
                    },
                    "system": {
                        "description": "connect-care | bifrost",
                        "type": "string",
                        "example": "connect-care"
                    }
                }
            },
            "AddRequest": {
                "type": "object",
                "required": [
                    "tenant_id",
                    "name",
                    "email",
                    "department",
                    "uuid"
                ],
                "properties": {
                    "tenant_id": {
                        "description": "Unique ID representing the organization/hospital",
                        "type": "string",
                        "format": "uuid",
                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5"
                    },
                    "name": {
                        "description": "Name of the examiner",
                        "type": "string",
                        "example": "Dr Abc"
                    },
                    "email": {
                        "description": "Email of the examiner",
                        "type": "string",
                        "format": "email",
                        "example": "abc@hospital.com"
                    },
                    "department": {
                        "description": "Department of the examiner",
                        "type": "string",
                        "example": "comprehensive"
                    },
                    "uuid": {
                        "description": "Unqiue identifier of the examiner after authentication with email",
                        "type": "string",
                        "example": "07123kjiusdfslj2lkjfa="
                    },
                    "pic": {
                        "$ref": "#/components/schemas/Picture"
                    }
                }
            },
            "UserProfile": {
                "required": [
                    "name",
                    "email",
                    "department",
                    "languages",
                    "pic",
                    "qualification",
                    "experience",
                    "registration_number",
                    "phone"
                ],
                "properties": {
                    "name": {
                        "description": "Name of the examiner",
                        "type": "string",
                        "example": "Dr Abc"
                    },
                    "email": {
                        "description": "Email of the examiner",
                        "type": "string",
                        "format": "email",
                        "example": "abc@hospital.com"
                    },
                    "department": {
                        "description": "Department of the examiner",
                        "type": "string",
                        "example": "comprehensive"
                    },
                    "languages": {
                        "description": "List of languages spoken by examiner",
                        "type": "array",
                        "items": {
                            "type": "string",
                            "example": "English"
                        }
                    },
                    "pic": {
                        "$ref": "#/components/schemas/Picture"
                    },
                    "qualification": {
                        "type": "string",
                        "example": "MBBS",
                        "description": "Qualifications of the examiner"
                    },
                    "experience": {
                        "type": "string",
                        "example": "3 years",
                        "description": "Experience of the examiner in the field"
                    },
                    "registration_number": {
                        "type": "string",
                        "description": "Registration number of the doctor"
                    },
                    "phone": {
                        "type": "string",
                        "description": "International format phone number",
                        "example": 919999999999
                    }
                }
            },
            "ModifyRequest": {
                "required": [
                    "tenant_id",
                    "email",
                    "uuid"
                ],
                "properties": {
                    "tenant_id": {
                        "description": "Unique ID representing the organization/hospital",
                        "type": "string",
                        "format": "uuid",
                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5"
                    },
                    "name": {
                        "description": "Name of the examiner",
                        "type": "string",
                        "example": "Dr Abc"
                    },
                    "email": {
                        "description": "Email of the examiner",
                        "type": "string",
                        "format": "email",
                        "example": "abc@hospital.com"
                    },
                    "uuid": {
                        "description": "Unqiue identifier of the examiner after authentication with email",
                        "type": "string",
                        "example": "07123kjiusdfslj2lkjfa="
                    },
                    "languages": {
                        "description": "List of languages spoken by examiner",
                        "type": "array",
                        "items": {
                            "type": "string",
                            "example": "English"
                        }
                    },
                    "pic": {
                        "$ref": "#/components/schemas/Picture"
                    },
                    "qualification": {
                        "type": "string",
                        "example": "MBBS",
                        "description": "Qualifications of the examiner"
                    },
                    "experience": {
                        "type": "string",
                        "example": "3 years",
                        "description": "Experience of the examiner in the field"
                    },
                    "registration_number": {
                        "type": "string",
                        "description": "Medical registration number for the doctor"
                    },
                    "phone": {
                        "type": "string",
                        "description": "Phone number of the examiner",
                        "example": 919999999999
                    }
                }
            },
            "Picture": {
                "type": "object",
                "required": [
                    "raw_data",
                    "file_ext"
                ],
                "properties": {
                    "raw_data": {
                        "description": "Base64-encoded string of image data",
                        "type": "string",
                        "format": "base64"
                    },
                    "file_ext": {
                        "description": "The file extension of the image",
                        "type": "string",
                        "example": ".jpg"
                    }
                }
            }
        }
    }
}