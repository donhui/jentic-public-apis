    "/products/{id}": {
      "get": {
        "summary": "Get product details by ID",
        "description": "<span class='bold'>Service urls:</span><br><span class='links'>http://yourdomain.com/api/rest_admin/products/{product_id}</span><br>OR<br><span class='links'>http://yourdomain.com/index.php?route=rest/product_admin/products&id={product_id}</span>",
        "operationId": "products.details",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
