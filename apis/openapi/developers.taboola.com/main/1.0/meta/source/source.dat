{
  "openapi": "3.0.3",
  "info": {
    "title": "Taboola Backstage API",
    "version": "1.0",
    "description": "The Taboola Backstage API allows programmatic management of advertising campaigns, campaign items, conversion tracking, custom audiences, audience onboarding, and reporting.",
    "x-jentic-source-url": "https://developers.taboola.com/backstage-api/reference"
  },
  "servers": [
    {
      "url": "https://backstage.taboola.com/backstage/api/1.0"
    }
  ],
  "paths": {
    "/auth/oauth/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Obtain an access token",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["client_id", "client_secret", "grant_type"],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "OAuth client ID"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "OAuth client secret"
                  },
                  "grant_type": {
                    "type": "string",
                    "enum": ["client_credentials"],
                    "description": "OAuth grant type"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token granted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/{accountId}/campaigns": {
      "get": {
        "operationId": "listCampaigns",
        "summary": "Get all campaigns for an account",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          },
          {
            "name": "fetch_level",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "R"
            },
            "description": "Controls response scope"
          }
        ],
        "responses": {
          "200": {
            "description": "List of campaigns",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Campaign"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      },
      "post": {
        "operationId": "createCampaign",
        "summary": "Create a new campaign",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "$ref": "#/components/parameters/AccountId"
          }
        ],
