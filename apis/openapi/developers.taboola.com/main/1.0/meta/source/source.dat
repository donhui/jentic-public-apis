  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "OAuth2 access token"
      }
    },
    "parameters": {
      "AccountId": {
        "name": "accountId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Alphabetic string representing a valid advertiser account ID"
      },
      "CampaignId": {
        "name": "campaignId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Campaign ID"
      },
      "ItemId": {
        "name": "itemId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Campaign item ID"
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer"
          }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "advertiser_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "branding_text": {
            "type": "string"
          },
          "cpc": {
            "type": "number",
            "format": "double"
          },
          "spending_limit": {
            "type": "number",
            "format": "double"
          },
          "spending_limit_model": {
            "type": "string",
            "enum": ["MONTHLY", "ENTIRE"]
          },
          "is_active": {
            "type": "boolean"
          },
          "status": {
            "type": "string"
          },
          "approval_state": {
            "type": "string"
          },
          "country_targeting": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "platform_targeting": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CampaignInput": {
        "type": "object",
        "required": ["name", "branding_text", "cpc"],
        "properties": {
          "name": {
            "type": "string"
          },
          "branding_text": {
            "type": "string"
          },
          "cpc": {
            "type": "number",
            "format": "double"
          },
          "spending_limit": {
            "type": "number",
            "format": "double"
          },
          "spending_limit_model": {
            "type": "string",
            "enum": ["MONTHLY", "ENTIRE"]
          },
          "is_active": {
            "type": "boolean"
          },
          "country_targeting": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "platform_targeting": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "value": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CampaignItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "campaign_id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "thumbnail_url": {
            "type": "string",
            "format": "uri"
          },
          "status": {
            "type": "string"
          },
          "approval_state": {
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          }
        }
      },
      "CampaignItemInput": {
        "type": "object",
        "required": ["url", "title"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "thumbnail_url": {
            "type": "string",
            "format": "uri"
          },
          "is_active": {
            "type": "boolean"
          }
        }
      },
      "ConversionRule": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "include_in_total_conversions": {
            "type": "boolean"
          }
        }
      },
      "ConversionRuleInput": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "include_in_total_conversions": {
            "type": "boolean"
          }
        }
      },
      "CustomAudience": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CustomAudienceInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "http_status": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          },
          "offending_field": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
