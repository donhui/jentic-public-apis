            "type": "string",
            "default": "INTERRUPT",
            "enum": [
              "INTERRUPT",
              "APPEND",
              "IGNORE"
            ],
            "description": "Message priority. INTERRUPT: immediately interrupts current interaction. APPEND: announces after current interaction. IGNORE: ignored if agent is busy."
          },
          "interruptable": {
            "type": "boolean",
            "default": true,
            "description": "Whether users can interrupt the broadcast via speech"
          }
