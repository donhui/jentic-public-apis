{
  "openapi": "3.0.3",
  "info": {
    "title": "MiroTalk C2C API",
    "description": "API for external applications that integrate with MiroTalk C2C, a peer-to-peer video calling platform. Allows creating meetings and generating direct join links.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://c2c.mirotalk.com/api/v1/docs"
  },
  "servers": [
    {
      "url": "https://c2c.mirotalk.com/api/v1"
    }
  ],
  "paths": {
    "/meeting": {
      "post": {
        "tags": ["meeting"],
        "summary": "Create meeting",
        "description": "Create a new meeting room and get the meeting URL.",
        "operationId": "createMeeting",
        "responses": {
          "200": {
            "description": "Meeting created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeetingResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "secretApiKey": []
          }
        ]
      }
    },
    "/join": {
      "post": {
        "tags": ["join"],
        "summary": "Create direct join",
        "description": "Create a direct join URL for a specific room and user name.",
        "operationId": "createDirectJoin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JoinRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Direct join URL created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JoinResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "secretApiKey": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "JoinRequest": {
        "type": "object",
        "required": ["room", "name"],
        "properties": {
          "room": {
            "type": "string",
            "description": "The room name to join",
            "example": "test"
          },
          "name": {
            "type": "string",
            "description": "The display name of the user joining",
            "example": "mirotalkc2c"
          }
        }
      },
      "MeetingResponse": {
        "type": "object",
        "properties": {
          "meeting": {
            "type": "string",
            "description": "The meeting URL"
          }
        }
      },
      "JoinResponse": {
        "type": "object",
        "properties": {
          "join": {
            "type": "string",
            "description": "The direct join URL"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "securitySchemes": {
      "secretApiKey": {
        "type": "apiKey",
        "name": "authorization",
        "in": "header",
        "description": "API key secret passed in the authorization header"
      }
    }
  },
  "security": [
    {
      "secretApiKey": []
    }
  ]
}