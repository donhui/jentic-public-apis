{
  "openapi": "3.0.3",
  "info": {
    "title": "Swetrix API",
    "version": "1.0.0",
    "description": "Swetrix is an open-source, lightweight, and privacy-focused web analytics platform. This API provides endpoints for statistics retrieval, event tracking, and project administration.",
    "x-jentic-source-url": "https://swetrix.com/docs"
  },
  "servers": [
    {
      "url": "https://api.swetrix.com",
      "description": "Swetrix API server"
    }
  ],
  "paths": {
    "/v1/log": {
      "get": {
        "operationId": "getTrafficAnalytics",
        "summary": "Get traffic analytics data",
        "description": "Retrieves aggregated traffic analytics data matching the Dashboard's Traffic tab.",
        "security": [
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          },
          {
            "name": "timeBucket",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "minute",
                "hour",
                "day",
                "week",
                "month",
                "year"
              ]
            }
          },
          {
            "name": "period",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "1h",
                "today",
                "yesterday",
                "1d",
                "7d",
                "4w",
                "3M",
                "12M",
                "24M",
                "all"
              ]
            }
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "timezone",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "Etc/GMT"
            }
          },
          {
            "name": "filters",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "JSON array of filter objects"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "periodic",
                "cumulative"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Traffic analytics data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrafficData"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/log/performance": {
      "get": {
        "operationId": "getPerformanceData",
        "summary": "Get performance metrics",
        "description": "Retrieves traffic data with performance metrics including DNS, TLS, connection times.",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectId"
          },
          {
            "name": "timeBucket",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "minute",
                "hour",
                "day",
                "week",
                "month",
                "year"
              ]
            }
          },
          {
            "name": "period",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "measure",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "median",
                "average",
                "p95",
                "quantiles"
              ],
              "default": "median"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Performance data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/log/birdseye": {
      "get": {
        "operationId": "getLogBirdseye",
        "summary": "Get summary of log data",
        "description": "Summary of log data for specified projects with current/previous period comparisons.",
