{
  "openapi": "3.0.3",
  "info": {
    "title": "isDayOff API",
    "version": "1.0.0",
    "description": "Production calendar API for Russia, Kazakhstan, Belarus, Ukraine, Uzbekistan, Turkey, and other countries. Provides information about working, holiday, and non-working days from official sources.",
    "x-jentic-source-url": "https://www.isdayoff.ru"
  },
  "servers": [
    {
      "url": "https://isdayoff.ru"
    }
  ],
  "paths": {
    "/today": {
      "get": {
        "operationId": "getTodayStatus",
        "summary": "Get today's day status",
        "description": "Returns whether today is a working day (0), day off (1), or shortened day (2).",
        "tags": ["DayStatus"],
        "parameters": [
          {
            "name": "cc",
            "in": "query",
            "description": "Country code (ru, kz, by, ua, uz, tr).",
            "schema": { "type": "string", "enum": ["ru", "kz", "by", "ua", "uz", "tr"] }
          },
          {
            "name": "tz",
            "in": "query",
            "description": "Timezone offset or IANA timezone name.",
            "schema": { "type": "string" }
          },
          {
            "name": "pre",
            "in": "query",
            "description": "Include shortened/pre-holiday days (1 = yes, 0 = no).",
            "schema": { "type": "integer", "enum": [0, 1] }
          }
        ],
        "responses": {
          "200": {
            "description": "Day status as plain text (0=working, 1=day off, 2=shortened)",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/tomorrow": {
      "get": {
        "operationId": "getTomorrowStatus",
        "summary": "Get tomorrow's day status",
        "description": "Returns whether tomorrow is a working day, day off, or shortened day.",
        "tags": ["DayStatus"],
        "parameters": [
          {
            "name": "cc",
            "in": "query",
            "description": "Country code.",
            "schema": { "type": "string", "enum": ["ru", "kz", "by", "ua", "uz", "tr"] }
          },
          {
            "name": "tz",
            "in": "query",
            "description": "Timezone offset or IANA timezone name.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Day status as plain text",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/{date}": {
      "get": {
        "operationId": "getDayStatus",
        "summary": "Get day status by date",
        "description": "Returns the working status for a specific date. Accepts YYYYMMDD or YYYY-MM-DD format.",
        "tags": ["DayStatus"],
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "description": "Date in YYYYMMDD or YYYY-MM-DD format.",
            "schema": { "type": "string" }
          },
          {
            "name": "cc",
            "in": "query",
            "description": "Country code.",
            "schema": { "type": "string", "enum": ["ru", "kz", "by", "ua", "uz", "tr"] }
          },
          {
            "name": "pre",
            "in": "query",
            "description": "Include shortened/pre-holiday days.",
            "schema": { "type": "integer", "enum": [0, 1] }
          }
        ],
        "responses": {
          "200": {
            "description": "Day status as plain text",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/getdata": {
      "get": {
        "operationId": "getData",
        "summary": "Get calendar data",
        "description": "Returns calendar data for a year, month, specific day, or date range. Returns a string of 0s and 1s representing each day's status.",
        "tags": ["CalendarData"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "required": true,
            "description": "The year.",
            "schema": { "type": "integer" }
          },
          {
            "name": "month",
            "in": "query",
            "description": "The month (1-12).",
            "schema": { "type": "integer" }
          },
          {
            "name": "day",
            "in": "query",
            "description": "The day of month.",
            "schema": { "type": "integer" }
          },
          {
            "name": "date1",
            "in": "query",
            "description": "Start date for range query (YYYYMMDD).",
            "schema": { "type": "string" }
          },
          {
            "name": "date2",
            "in": "query",
            "description": "End date for range query (YYYYMMDD). Max 366 days from date1.",
            "schema": { "type": "string" }
          },
          {
            "name": "cc",
            "in": "query",
            "description": "Country code.",
            "schema": { "type": "string", "enum": ["ru", "kz", "by", "ua", "uz", "tr"] }
          },
          {
            "name": "pre",
            "in": "query",
            "description": "Include shortened/pre-holiday days.",
            "schema": { "type": "integer", "enum": [0, 1] }
          },
          {
            "name": "delimeter",
            "in": "query",
            "description": "Delimiter between day values in response.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Calendar data as plain text string of day statuses",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/isleap": {
      "get": {
        "operationId": "isLeapYear",
        "summary": "Check if year is a leap year",
        "description": "Returns whether the specified year is a leap year.",
        "tags": ["CalendarData"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "required": true,
            "description": "The year to check.",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Result as plain text (0=not leap, 1=leap year)",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {}
  },
  "security": []
}