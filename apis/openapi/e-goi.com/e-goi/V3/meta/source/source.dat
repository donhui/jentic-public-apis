          }
        ]
      },
      "CampaignEmailSendNowRequest": {
        "title": "Send Email",
        "description": "Campaign email send now request schema",
        "required": [
          "list_id"
        ],
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/AbstractSendEmail"
          },
          {
            "$ref": "#/components/schemas/LimitHourActionSend"
          }
        ]
