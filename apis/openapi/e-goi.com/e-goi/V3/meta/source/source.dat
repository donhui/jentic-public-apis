            "type": "string",
            "example": "example@e-goi.com"
          },
          "email_status": {
            "description": "Email channel status",
            "type": "string",
            "default": "active",
            "enum": [
              "active",
              "inactive"
            ],
            "readOnly": true
          },
          "cellphone": {
            "description": "Cellphone of the contact",
            "type": "string",
            "example": "351-300404336"
          },
          "cellphone_status": {
            "description": "Cellphone channel status",
            "type": "string",
            "default": "active",
            "enum": [
              "active",
              "inactive"
            ],
            "readOnly": true
          },
          "phone": {
            "description": "Phone of the contact",
            "type": "string",
            "example": "351-300404336"
          },
          "phone_status": {
            "description": "Phone channel status",
            "type": "string",
            "default": "active",
            "enum": [
              "active",
              "inactive"
            ],
            "readOnly": true
          },
          "push_token_android": {
            "description": "Android push token of the contact",
            "type": "array",
            "items": {
              "properties": {
                "app_id": {
                  "$ref": "#/components/schemas/pushAppId"
                },
                "token": {
                  "description": "Android push app ID",
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          "push_token_ios": {
            "description": "IOS push token of the contact",
            "type": "array",
            "items": {
              "properties": {
                "app_id": {
                  "$ref": "#/components/schemas/pushAppId"
                },
                "token": {
                  "description": "Ios push app ID",
                  "type": "string"
                }
              },
              "type": "object"
            }
          }
        },
        "type": "object"
      },
      "ContactExtraFieldsSchema": {
