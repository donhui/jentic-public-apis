{
  "openapi": "3.0.3",
  "info": {
    "title": "Microlink API",
    "version": "1.0.0",
    "description": "Microlink API allows you to extract metadata, take screenshots, generate PDFs, and automate browser actions from any URL with a simple HTTP GET request. It retrieves structured data including title, description, images, author, and more from any web page.",
    "x-jentic-source-url": "https://microlink.io"
  },
  "servers": [
    {
      "url": "https://api.microlink.io"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "extractMetadata",
        "summary": "Extract metadata from a URL",
        "description": "Fetches a URL and returns structured metadata including title, description, image, author, publisher, date, language, and logo. Can also take screenshots and generate PDFs.",
        "tags": ["Metadata"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "The target URL to extract metadata from.",
            "schema": {
              "type": "string",
              "format": "uri"
            }
          },
          {
            "name": "screenshot",
            "in": "query",
            "description": "When set to true, takes a screenshot of the target URL.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "pdf",
            "in": "query",
            "description": "When set to true, generates a PDF of the target URL.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "embed",
            "in": "query",
            "description": "Field name to return directly instead of the full JSON response (e.g., 'screenshot.url').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prerender",
            "in": "query",
            "description": "Enable prerendering to handle JavaScript-rendered pages. Values: true, false, auto.",
            "schema": {
              "type": "string",
              "enum": ["true", "false", "auto"]
            }
          },
          {
            "name": "headers",
            "in": "query",
            "description": "Custom HTTP headers to send with the request (JSON encoded).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "data.selector",
            "in": "query",
            "description": "CSS selector to extract custom data from the page.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "data.attr",
            "in": "query",
            "description": "HTML attribute to extract from the selected element.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "data.type",
            "in": "query",
            "description": "Type to coerce the extracted data to (e.g., 'number', 'date').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "palette",
            "in": "query",
            "description": "When set to true, returns the color palette of the image.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "audio",
            "in": "query",
            "description": "When set to true, enables audio extraction.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "video",
            "in": "query",
            "description": "When set to true, enables video extraction.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "meta",
            "in": "query",
            "description": "When set to false, disables metadata extraction. Default: true.",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful metadata extraction",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetadataResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid URL parameter"
          },
          "401": {
            "description": "Unauthorized - invalid API key for pro features"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ImageData": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the image"
          },
          "type": {
            "type": "string",
            "description": "Image type (png, jpg, etc.)"
          },
          "size": {
            "type": "integer",
            "description": "File size in bytes"
          },
          "height": {
            "type": "integer",
            "description": "Image height in pixels"
          },
          "width": {
            "type": "integer",
            "description": "Image width in pixels"
          },
          "size_pretty": {
            "type": "string",
            "description": "Human-readable file size"
          }
        }
      },
      "MetadataData": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Page title"
          },
          "description": {
            "type": "string",
            "description": "Page description"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Canonical URL"
          },
          "publisher": {
            "type": "string",
            "description": "Publisher name"
          },
          "lang": {
            "type": "string",
            "description": "Language code"
          },
          "author": {
            "type": "string",
            "description": "Author name"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "Publication date"
          },
          "image": {
            "$ref": "#/components/schemas/ImageData"
          },
          "logo": {
            "$ref": "#/components/schemas/ImageData"
          },
          "screenshot": {
            "$ref": "#/components/schemas/ImageData"
          }
        }
      },
      "MetadataResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Response status (success or fail)",
            "enum": ["success", "fail"]
          },
          "data": {
            "$ref": "#/components/schemas/MetadataData"
          },
          "statusCode": {
            "type": "integer",
            "description": "HTTP status code of the fetched URL"
          },
          "redirects": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of redirect URLs"
          },
          "headers": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Response headers from the fetched URL"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for pro features (optional for basic usage)"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}
