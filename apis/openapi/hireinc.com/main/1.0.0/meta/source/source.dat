{
  "openapi": "3.0.3",
  "info": {
    "title": "Hire.Inc Zapier API",
    "description": "Hire.Inc is an ATS & AI recruitment app for high performing teams. This API provides Zapier integration endpoints for managing workspaces, job posts, and candidates.",
    "version": "1.0.0",
    "contact": {
      "name": "Hire.Inc"
    },
    "x-jentic-source-url": "https://hireinc.mintlify.app/pages/integration_guide"
  },
  "servers": [
    {
      "url": "https://mgnmzef4kd.us-east-1.awsapprunner.com/api/v1/zapier",
      "description": "Hire.Inc API Server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Workspace",
      "description": "Workspace operations"
    },
    {
      "name": "Jobs",
      "description": "Job post operations"
    },
    {
      "name": "Candidates",
      "description": "Candidate operations"
    }
  ],
  "paths": {
    "/me": {
      "get": {
        "operationId": "getAuthenticatedUserWorkspace",
        "summary": "Get authenticated user workspace data",
        "description": "Get the authenticated user workspace data.",
        "tags": ["Workspace"],
        "responses": {
          "200": {
            "description": "Successfully retrieved the authenticated user workspace data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Workspace"
                }
              }
            }
          }
        }
      }
    },
    "/published-jobs": {
      "get": {
        "operationId": "listPublicJobPosts",
        "summary": "Lists public job posts with form IDs",
        "description": "Lists public job posts.",
        "tags": ["Jobs"],
        "responses": {
          "200": {
            "description": "Successfully retrieved the list of job posts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobPostList"
                }
              }
            }
          }
        }
      }
    },
    "/create-job": {
      "post": {
        "operationId": "createJobPost",
        "summary": "Create a new job post",
        "description": "Create a new job post.",
        "tags": ["Jobs"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateJobPostRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully created the job post",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdResponse"
                }
              }
            }
          }
        }
      }
    },
    "/create-candidate": {
      "post": {
        "operationId": "upsertCandidate",
        "summary": "Upserts candidate",
        "description": "Upserts candidate based on email, and optionally applies to a job.",
        "tags": ["Candidates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpsertCandidateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully upserted the candidate",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IdResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "Workspace": {
        "type": "object",
        "required": ["id", "ownerId"],
        "properties": {
          "id": {
            "type": "string"
          },
          "ownerId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "companyName": {
            "type": "string"
          },
          "companyAlias": {
            "type": "string"
          }
        }
      },
      "JobPostList": {
        "type": "object",
        "required": ["total", "totalPages", "currentPage", "data"],
        "properties": {
          "total": {
            "type": "number"
          },
          "totalPages": {
            "type": "number"
          },
          "currentPage": {
            "type": "number"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/JobPost"
            }
          }
        }
      },
      "JobPost": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "Country": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "iso3": {
                "type": "string"
              }
            }
          },
          "JobBoardForm": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "createdAt": {
                "type": "string"
              },
              "workspaceId": {
                "type": "string"
              }
            }
          },
          "seniority": {
            "type": "string",
            "enum": ["entry", "junior", "midlevel", "senior", "executive"]
          },
          "presence": {
            "type": "string",
            "enum": ["onsite", "remote", "hybrid"]
          },
          "showSalaryOnJobBoard": {
            "type": "boolean"
          },
          "minAnnualSalary": {
            "type": "number"
          },
          "maxAnnualSalary": {
            "type": "number"
          },
          "annualSalaryCurrency": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["fulltime", "parttime", "contract"]
          }
        }
      },
      "CreateJobPostRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 3,
            "maxLength": 255
          },
          "details": {
            "type": "string",
            "maxLength": 10000
          },
          "seniority": {
            "type": "string",
            "enum": ["entry", "junior", "midlevel", "senior", "executive"]
          },
          "type": {
            "type": "string",
            "enum": ["fulltime", "parttime", "contract"]
          },
          "countryIso3": {
            "type": "string",
            "maxLength": 100
          },
          "city": {
            "type": "string",
            "maxLength": 100
          },
          "presence": {
            "type": "string",
            "enum": ["onsite", "remote", "hybrid"]
          },
          "minAnnualSalary": {
            "type": "number",
            "minimum": 0,
            "maximum": 2147483647
          },
          "maxAnnualSalary": {
            "type": "number",
            "minimum": 0,
            "maximum": 2147483647
          },
          "showSalaryOnJobBoard": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "UpsertCandidateRequest": {
        "type": "object",
        "required": ["workspaceId"],
        "properties": {
          "workspaceId": {
            "type": "string"
          },
          "primaryEmail": {
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "email"
            }
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "links": {
            "type": "object"
          },
          "education": {
            "type": "string",
            "nullable": true
          },
          "experienceYears": {
            "type": "number",
            "nullable": true,
            "minimum": 0,
            "maximum": 2147483647
          },
          "resumeUrl": {
            "type": "string",
            "format": "uri"
          },
          "noticeWeeks": {
            "type": "number",
            "nullable": true,
            "minimum": 0,
            "maximum": 2147483647
          },
          "earliestStartDate": {
            "type": "string",
            "nullable": true
          },
          "currentSalary": {
            "type": "number",
            "nullable": true,
            "minimum": 0,
            "maximum": 2147483647
          },
          "currentSalaryCurrency": {
            "type": "string",
            "nullable": true,
            "enum": ["USD", "EUR", "GBP", "EGP", "AED", "SAR"]
          },
          "expectedSalary": {
            "type": "number",
            "nullable": true,
            "minimum": 0,
            "maximum": 2147483647
          },
          "expectedSalaryMax": {
            "type": "number",
            "nullable": true,
            "minimum": 0,
            "maximum": 2147483647
          },
          "expectedSalaryCurrency": {
            "type": "string",
            "nullable": true,
            "enum": ["USD", "EUR", "GBP", "EGP", "AED", "SAR"]
          },
          "isVeteran": {
            "type": "boolean",
            "nullable": true
          },
          "creatorId": {
            "type": "string",
            "nullable": true
          },
          "countryIso3": {
            "type": "string",
            "nullable": true
          },
          "zipCode": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "notes": {
            "type": "string",
            "nullable": true
          },
          "jobId": {
            "type": "string"
          }
        }
      },
      "IdResponse": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string"
          }
        }
      }
    }
  }
}