    "/webhooks/secretkey": {
      "post": {
        "tags": [
          "Webhooks"
        ],
        "operationId": "createSecretKey",
        "summary": "Creates a new secret key",
        "description": "This creates a new secret key per application. It takes an optional validFrom value, a date time in ISO8601 format, e.g. 2019-07-01T22:00:00Z. The secret key will be activated at the given date. If validFrom is not passed, the secret key will be activated immediately. The secret key is used to generate a signature for events published to the callback url.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SecretKeyRequest"
              }
