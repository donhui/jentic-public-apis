                }
              }
            }
          },
          "description": "The co-organizer details",
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Coorganizer"
                  }
                }
