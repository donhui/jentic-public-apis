        ],
        "operationId": "createCoorganizers",
        "summary": "Create co-organizers",
        "description": "Creates co-organizers for the specified webinar. For co-organizers that have a GoTo Webinar account you have to set the parameter 'external' to 'false'. In this case you have to pass the parameter 'organizerKey' only. For co-organizers that have no GoTo Webinar account you have to set the parameter 'external' to 'true'. In this case you have to pass the parameters 'givenName' and 'email'. Since there is no parameter for 'surname' you should pass first and last name to the parameter 'givenName'.\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/organizerKey"
          },
          {
            "$ref": "#/components/parameters/webinarKey"
