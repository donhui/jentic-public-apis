          },
          "experienceType": {
            "description": "Specifies the experience type. The possible values are 'classic', 'broadcast' and 'simulive'.",
            "type": "string"
          },
          "webinarID": {
            "type": "string",
            "description": "The 9-digit webinar ID"
          },
          "webinarType": {
            "type": "integer",
            "format": "int32",
            "description": "The webinar type"
          },
          "numRegLinkClicks": {
            "type": "integer",
            "format": "int32",
