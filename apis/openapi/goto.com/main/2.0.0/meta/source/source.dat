          "email",
          "organizerKey"
        ],
        "properties": {
          "email": {
            "type": "string",
            "description": "The email address of the coorganizer"
          },
          "organizerKey": {
            "type": "integer",
            "format": "int64",
            "description": "The key of the webinar coorganizer"
          }
        }
      }
    }
  }
