          },
          "eventVersion": {
            "type": "string",
            "description": "Version of event being subscribed for. Supported eventVersion is 1.0.0"
          },
          "product": {
            "$ref": "#/components/schemas/Product"
          }
        }
      },
      "Webhook": {
        "description": "Representation of a single webhook",
