            },
            "type": "array"
          },
          "primaryCurrency": {
            "description": "Primary currency for order",
            "example": "SHOPPER",
            "type": "string"
          }
        },
        "type": "object"
      },
      "currencyGroup": {
        "description": "CurrencyGroup object details.",
        "properties": {
          "attributes": {
            "description": "Merchant-defined custom attributes. This is a placeholder for additional info (in key-value pairs).",
            "example": {
              "fxId": "ID123"
            },
            "type": "object"
          },
          "conversionRate": {
            "description": "conversion rate",
            "example": 1,
