          },
          "currency": {
            "description": "Three-letter currency code as defined by ISO-4217",
            "example": "USD",
            "type": "string"
          },
          "employeeId": {
            "description": "Employee (ID or name) who initiated a the credits request",
            "example": "12312232",
            "type": "string"
          },
          "note": {
            "description": "Note",
            "example": "Credit request initiated",
            "type": "string"
          },
          "paymentCounter": {
