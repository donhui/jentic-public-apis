              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/errorResponse"
                },
                "example": {
                  "type": "CLIENT_ERROR",
                  "errorCode": "SERVICE-4001",
                  "message": "Unauthorized request",
                  "errors": [],
                  "context": {
