                },
                "example": {
                  "type": "CLIENT_ERROR",
                  "errorCode": "SERVICE-4001",
                  "message": "Unauthorized request",
                  "errors": [],
                  "context": {
                    "service": "orders",
                    "endpoint": "POST /v3/orders/OrderId_12345"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "headers": {
              "x-fabric-request-id": {
                "$ref": "#/components/headers/xFabricRequestIdResponseHeader"
              }
            },
