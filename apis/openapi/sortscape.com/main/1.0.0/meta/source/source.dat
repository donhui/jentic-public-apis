{
  "openapi": "3.0.3",
  "info": {
    "title": "SortScape API",
    "version": "1.0.0",
    "description": "SortScape is an app that helps lawn and garden maintenance businesses schedule jobs efficiently. This API allows programmatic interaction with SortScape to manage contacts, jobs, and access user information.",
    "x-jentic-source-url": "https://intercom.help/sortscape/en/articles/10796377-api-documentation"
  },
  "servers": [
    {
      "url": "https://api.sortscape.com",
      "description": "SortScape API server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Contacts",
      "description": "Manage contacts in SortScape"
    },
    {
      "name": "Jobs",
      "description": "Access job data"
    },
    {
      "name": "Users",
      "description": "Authenticated user information"
    }
  ],
  "paths": {
    "/api/contacts": {
      "post": {
        "tags": ["Contacts"],
        "summary": "Create Contact",
        "operationId": "createContact",
        "description": "Creates a new contact in the system.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["contact"],
                "properties": {
                  "contact": {
                    "$ref": "#/components/schemas/ContactInput"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Contact created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Entity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/contacts/sample": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Sample Contacts",
        "operationId": "sampleContacts",
        "description": "Returns a sample list of contacts. Designed for integration platforms like Zapier to understand the data structure.",
        "responses": {
          "200": {
            "description": "Sample contacts list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Contact"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/jobs/sample": {
      "get": {
        "tags": ["Jobs"],
        "summary": "Sample Jobs",
        "operationId": "sampleJobs",
        "description": "Returns a sample list of jobs. Designed for integration platforms like Zapier to understand the data structure.",
        "responses": {
          "200": {
            "description": "Sample jobs list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Job"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/oauth/me": {
      "get": {
        "tags": ["Users"],
        "summary": "Get Current User",
        "operationId": "getCurrentUser",
        "description": "Returns information about the authenticated user.",
        "responses": {
          "200": {
            "description": "Current user info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUser"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "oauth2",
        "description": "OAuth 2.0 authentication. Contact SortScape support for client credentials.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://api.sortscape.com/oauth/authorize",
            "tokenUrl": "https://api.sortscape.com/oauth/token",
            "scopes": {
              "read": "Read access",
              "write": "Write access"
            }
          }
        }
      }
    },
    "schemas": {
      "ContactInput": {
        "type": "object",
        "required": ["displayName"],
        "properties": {
          "displayName": {
            "type": "string",
            "description": "Display name for the contact"
          },
          "firstName": {
            "type": "string",
            "description": "First name"
          },
          "lastName": {
            "type": "string",
            "description": "Last name"
          },
          "email": {
            "type": "string",
            "description": "Primary email address"
          },
          "phoneMobile": {
            "type": "string",
            "description": "Mobile phone number"
          },
          "phoneHome": {
            "type": "string",
            "description": "Home phone number"
          },
          "company": {
            "type": "string",
            "description": "Company name"
          },
          "note": {
            "type": "string",
            "description": "Additional notes"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Contact ID"
          },
          "displayName": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phoneMobile": {
            "type": "string"
          },
          "phoneHome": {
            "type": "string",
            "nullable": true
          },
          "company": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Job ID"
          },
          "title": {
            "type": "string",
            "description": "Job title or address"
          },
          "resolved": {
            "type": "boolean",
            "description": "Whether the job is resolved"
          }
        }
      },
      "CurrentUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "email": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}