        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "description": "an authorization header as \"Bearer xxxxxxxxxxxxxx\"",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "departureStation",
            "description": "list of departure station ids, seperete by comma (,)",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "arrivalStation",
            "description": "list of arrival station ids, seperete by comma (,)",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "fromCity",
            "description": "Search for trips departing from a specific city",
            "example": "58ade161b626ad00060bd174",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "toCity",
            "description": "Search for trips arriving to a specific city",
            "example": "58ade15cd8638d00070c04b2",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "departure",
            "description": "the required date in format: \"YYYY-MM-DD\"",
            "schema": {
              "type": "string"
            },
            "required": true
          },
          {
            "in": "query",
            "name": "passengers",
            "description": "amount of passengers [1..15], if not supplied, calculated attributes will assume single passenger",
            "required": false,
            "schema": {
              "type": "number",
              "minimum": 1,
              "maximum": 15
            }
          },
          {
            "in": "query",
            "name": "limit",
            "description": "limit the number of results. default is 100, maximum allowed is 5000",
            "required": false,
            "schema": {
              "type": "number",
              "minimum": 1,
              "maximum": 5000
            }
          },
          {
            "in": "query",
            "name": "offset",
            "description": "result offset. default is zero.",
            "required": false,
            "schema": {
              "type": "number",
              "minimum": 0
            }
          }
        ],
