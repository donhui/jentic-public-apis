{
  "openapi": "3.0.3",
  "info": {
    "title": "Cloud 66 API",
    "description": "Cloud 66 is a DevOps-as-a-Service platform that helps developers build, deploy, and manage applications on any cloud. The API provides programmatic access to manage stacks, servers, services, containers, deployments, environment variables, settings, backups, accounts, and more.",
    "version": "3.0",
    "x-jentic-source-url": "https://developers.cloud66.com/"
  },
  "servers": [
    {
      "url": "https://app.cloud66.com/api/3",
      "description": "Cloud 66 API v3"
    }
  ],
  "security": [
    {
      "oauth2": [
        "public",
        "redeploy",
        "jobs",
        "admin"
      ]
    }
  ],
  "paths": {
    "/stacks.json": {
      "get": {
        "operationId": "listStacks",
        "summary": "List all stacks",
        "description": "Returns a paginated list of all stacks.",
        "tags": [
          "Stacks"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "filter_name",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter_environment",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter_git_repo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter_git_branch",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of stacks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "type": "array",
                      "items": {
                        "": "#/components/schemas/Stack"
                      }
                    },
                    "count": {
                      "type": "integer"
                    },
                    "pagination": {
                      "": "#/components/schemas/Pagination"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stacks": {
      "post": {
        "operationId": "createStack",
        "summary": "Create a new stack",
        "description": "Create a new application stack.",
        "tags": [
          "Stacks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "": "#/components/schemas/StackCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Async result for stack creation",
            "content": {
              "application/json": {
                "schema": {
                  "": "#/components/schemas/AsyncResult"
                }
              }
            }
          }
        }
      }
    },
    "/stacks/{stack_uid}.json": {
      "get": {
        "operationId": "getStack",
        "summary": "Get stack details",
        "description": "Retrieve details of a specific stack.",
        "tags": [
          "Stacks"
        ],
        "parameters": [
          {
            "name": "stack_uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stack details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "response": {
                      "": "#/components/schemas/Stack"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stacks/{stack_uid}/settings.json": {
      "get": {
        "operationId": "listStackSettings",
        "summary": "List stack settings",
        "description": "Retrieve all settings for a stack.",
