    "/stacks/{stack_uid}/deployments.json": {
      "post": {
        "operationId": "redeployStack",
        "summary": "Redeploy a stack",
        "tags": [
          "Deployments"
        ],
        "parameters": [
          {
            "name": "stack_uid",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "git_ref": {
                    "type": "string"
                  },
                  "deploy_strategy": {
                    "type": "string"
                  },
                  "deployment_profile": {
                    "type": "string"
                  },
                  "services": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Redeploy response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    },
                    "queued": {
                      "type": "boolean"
                    },
                    "async_action_id": {
                      "type": "integer",
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
