                      "type": "array",
                      "items": {
                        "": "#/components/schemas/StackSetting"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stacks/{stack_uid}/settings/{key}.json": {
      "put": {
        "operationId": "updateStackSetting",
        "summary": "Update a stack setting",
