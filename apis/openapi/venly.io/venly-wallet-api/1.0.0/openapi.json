{
  "openapi": "3.0.3",
  "info": {
    "title": "Venly Wallet API",
    "version": "1.0.0",
    "description": "Venly (formerly Arkane) provides blockchain wallet, NFT, token, and payment APIs. Includes Wallet API for user/wallet/transaction management, PAY API for fiat on/off ramps and checkout, Token API for ERC20 contract management, and NFT API for NFT contract and token operations.",
    "x-jentic-source-url": "https://docs.venly.io/reference",
    "contact": {}
  },
  "servers": [
    {
      "url": "https://api.venly.io",
      "description": "Production API"
    },
    {
      "url": "https://api-sandbox.venly.io",
      "description": "Sandbox API"
    }
  ],
  "paths": {
    "/auth/realms/Arkane/protocol/openid-connect/token": {
      "post": {
        "operationId": "fetchBearerToken",
        "summary": "Fetch Bearer Token",
        "description": "Retrieves an access token using client credentials. Token is valid for 6 minutes.",
        "tags": [
          "Authentication"
        ],
        "servers": [
          {
            "url": "https://login.venly.io",
            "description": "Production Auth"
          },
          {
            "url": "https://login-sandbox.venly.io",
            "description": "Sandbox Auth"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "client_credentials"
                    ]
                  },
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  }
                },
                "required": [
                  "grant_type",
                  "client_id",
                  "client_secret"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
