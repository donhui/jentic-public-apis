  "components": {
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "refresh_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "enum": [
              "bearer"
            ]
          },
          "expires_in": {
            "type": "integer"
          },
          "scope": {
            "type": "string"
          }
        }
      },
      "Wallet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "secretType": {
            "type": "string"
          },
          "walletType": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateWalletRequest": {
        "type": "object",
        "properties": {
          "secretType": {
            "type": "string",
            "description": "Blockchain type"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "secretType"
        ]
      },
      "Balance": {
        "type": "object",
        "properties": {
          "available": {
            "type": "boolean"
          },
          "secretType": {
            "type": "string"
          },
          "balance": {
            "type": "number"
          },
          "gasBalance": {
            "type": "number"
          },
          "symbol": {
            "type": "string"
          },
          "gasSymbol": {
            "type": "string"
          }
        }
      },
      "TokenBalance": {
        "type": "object",
        "properties": {
          "tokenAddress": {
            "type": "string"
          },
          "rawBalance": {
            "type": "string"
          },
          "balance": {
            "type": "number"
          },
          "decimals": {
            "type": "integer"
          },
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "NFT": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "contract": {
            "type": "object"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "reference": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "transactionHash": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "TransactionRequest": {
        "type": "object",
        "properties": {
          "walletId": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "secretType": {
            "type": "string"
          },
          "value": {
            "type": "number"
          }
        },
