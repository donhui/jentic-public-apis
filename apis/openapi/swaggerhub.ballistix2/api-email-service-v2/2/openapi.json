{
  "swagger": "2.0",
  "info": {
    "description": "This is the inner API definition for the email service. It will also be exposed as an outer API on the API gateway, but that REST API contract is defined in a separate document. Note that all endpoint URL's should be  prefixed with the namespace prefix defined in the container environment variable.",
    "version": "2",
    "title": "Inner API of Email Service V2\n",
    "contact": {
      "email": "service-factory@digipolis.gent"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/BallistiX2/api_email_service_v2/2/swagger.json"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "tags": [
    {
      "name": "Operations on Email messages",
      "description": "Email Controller"
    }
  ],
  "paths": {
    "/v2/historiek": {
      "delete": {
        "tags": [
          "Operations on Email messages"
        ],
        "summary": "Archive all Email messages created before a certain date.",
        "operationId": "archiveUsingPOST",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "*/*"
        ],
        "parameters": [
          {
            "name": "X-Correlation-ID",
            "in": "header",
            "description": "The value of the X-Correlation-ID header is used for correlating distributed actions in the log file.",
            "type": "string",
            "required": false
          },
          {
            "name": "tenantId",
            "in": "header",
            "description": "The value of the tenantId header is used to verify access to the given email address, (this check is currently disabled).",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/v2/emails": {
      "get": {
        "tags": [
          "Operations on Email messages"
        ],
        "summary": "Searches amongst all emails based on the specified criteria.",
        "operationId": "listAllEmailsUsingGET",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "*/*"
        ],
        "parameters": [
          {
            "name": "X-Correlation-ID",
            "in": "header",
            "description": "The value of the X-Correlation-ID header is used for correlating distributed actions in the log file.",
            "type": "string",
            "required": false
          },
          {
            "name": "tenantId",
            "in": "header",
            "description": "The value of the tenantId header is used to verify access to the given email address, (this check is currently disabled).",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/EmailDto"
              }
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "post": {
        "tags": [
          "Operations on Email messages"
        ],
        "summary": "Send an email from a specific email address. The address is specified in the request body DTO.",
        "operationId": "createUsingPOST",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "*/*"
        ],
        "parameters": [
          {
            "name": "X-Correlation-ID",
            "in": "header",
            "description": "The value of the X-Correlation-ID header is used for correlating distributed actions in the log file.",
            "type": "string",
            "required": false
          },
          {
            "name": "tenantId",
            "in": "header",
            "description": "The value of the tenantId header is used to verify access to the given email address, (this check is currently disabled).",
            "type": "string",
            "required": true
          },
          {
            "in": "body",
            "name": "emailCreationDto",
            "description": "emailCreationDto",
            "required": true,
            "schema": {
              "$ref": "#/definitions/EmailCreationDto"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/ResponseEntity"
            }
          },
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/EmailCreationResponseDto"
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/v2/emails/{id}": {
      "get": {
        "tags": [
          "Operations on Email messages"
        ],
        "summary": "Retrieve details of a specific email",
        "operationId": "listUsingGET",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "*/*"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "id",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "X-Correlation-ID",
            "in": "header",
            "description": "The value of the X-Correlation-ID header is used for correlating distributed actions in the log file.",
            "type": "string",
            "required": false
          },
          {
            "name": "tenantId",
            "in": "header",
            "description": "The value of the tenantId header is used to verify access to the given email address, (this check is currently disabled).",
            "type": "string",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/EmailDto"
            }
          },
          "400": {
            "description": "Bad request",
            "schema": {
              "$ref": "#/definitions/ApiError"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    }
  },
