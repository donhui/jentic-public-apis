{
  "openapi": "3.0.3",
  "info": {
    "title": "Veriphone API",
    "description": "Veriphone provides a real-time phone number validation and carrier lookup API. It verifies phone numbers, identifies carriers, determines phone types, and returns formatted representations in international, local, and E.164 formats. Supports validation across all countries with 99.95% SLA.",
    "version": "2.0",
    "contact": {
      "name": "Veriphone Support",
      "email": "support@veriphone.io",
      "url": "https://veriphone.io"
    },
    "x-jentic-source-url": "https://veriphone.io/docs/v2"
  },
  "servers": [
    {
      "url": "https://api.veriphone.io/v2",
      "description": "Veriphone API v2"
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    {
      "name": "Validation",
      "description": "Phone number verification and validation"
    },
    {
      "name": "Examples",
      "description": "Generate example phone numbers"
    }
  ],
  "paths": {
    "/verify": {
      "get": {
        "operationId": "verifyPhoneNumber",
        "summary": "Verify a phone number",
        "description": "Validates a phone number and returns detailed information including validity, phone type, carrier, country, and formatted representations.",
        "tags": ["Validation"],
        "parameters": [
          {
            "name": "phone",
            "in": "query",
            "required": true,
            "description": "The phone number to validate.",
            "schema": {
              "type": "string"
            },
            "example": "+14158586273"
          },
          {
            "name": "default_country",
            "in": "query",
            "required": false,
            "description": "ISO 3166-1 alpha-2 country code (2 characters). Used when phone number is provided in local format without country code.",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            },
            "example": "US"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful verification response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyResponse"
                },
                "example": {
                  "status": "success",
                  "phone": "+14158586273",
                  "phone_valid": true,
                  "phone_type": "mobile",
                  "phone_region": "",
                  "country": "United States",
                  "country_code": "US",
                  "country_prefix": "1",
                  "international_number": "+14158586273",
                  "local_number": "(415) 858-6273",
                  "e164": "+14158586273",
                  "carrier": "T-Mobile USA, Inc."
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Insufficient credits.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Access denied.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "verifyPhoneNumberPost",
        "summary": "Verify a phone number (POST)",
        "description": "Validates a phone number using POST method. Same functionality as GET.",
        "tags": ["Validation"],
        "parameters": [
          {
            "name": "phone",
            "in": "query",
            "required": true,
            "description": "The phone number to validate.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "default_country",
            "in": "query",
            "required": false,
            "description": "ISO 3166-1 alpha-2 country code.",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful verification response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/example": {
      "get": {
        "operationId": "getExampleNumber",
        "summary": "Get an example phone number",
        "description": "Returns an example phone number for a given country and phone type.",
        "tags": ["Examples"],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "The type of phone number to generate. Defaults to 'mobile'.",
            "schema": {
              "type": "string",
              "enum": ["mobile", "fixed_line", "toll_free", "voip", "premium_rate", "shared_cost"],
              "default": "mobile"
            }
          },
          {
            "name": "country_code",
            "in": "query",
            "required": false,
            "description": "ISO 3166-1 alpha-2 country code (2 characters).",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            },
            "example": "US"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with example number.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExampleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "getExampleNumberPost",
        "summary": "Get an example phone number (POST)",
        "description": "Returns an example phone number using POST method. Same functionality as GET.",
        "tags": ["Examples"],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": false,
            "description": "The type of phone number to generate.",
            "schema": {
              "type": "string",
              "enum": ["mobile", "fixed_line", "toll_free", "voip", "premium_rate", "shared_cost"],
              "default": "mobile"
            }
          },
          {
            "name": "country_code",
            "in": "query",
            "required": false,
            "description": "ISO 3166-1 alpha-2 country code.",
            "schema": {
              "type": "string",
              "minLength": 2,
              "maxLength": 2
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with example number.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExampleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid or missing parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key passed as a query parameter. Obtain from the Veriphone dashboard."
      }
    },
    "schemas": {
      "VerifyResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Request result status.",
            "enum": ["success", "error"]
          },
          "phone": {
            "type": "string",
            "description": "The input phone number."
          },
          "phone_valid": {
            "type": "boolean",
            "description": "Whether the phone number is valid."
          },
          "phone_type": {
            "type": "string",
            "description": "The category of the phone number.",
            "enum": ["mobile", "fixed_line", "toll_free", "voip", "premium_rate", "shared_cost"]
          },
          "phone_region": {
            "type": "string",
            "description": "Geographic region associated with the number. Empty for mobile numbers."
          },
          "country": {
            "type": "string",
            "description": "Full country name."
          },
          "country_code": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code."
          },
          "country_prefix": {
            "type": "string",
            "description": "International dialing code/prefix."
          },
          "international_number": {
            "type": "string",
            "description": "Phone number in international format with '+' prefix."
          },
          "local_number": {
            "type": "string",
            "description": "Phone number in local dialing format."
          },
          "e164": {
            "type": "string",
            "description": "Phone number in E.164 standard format."
          },
          "carrier": {
            "type": "string",
            "description": "The phone carrier/service provider name."
          }
        }
      },
      "ExampleResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Request result status.",
            "enum": ["success", "error"]
          },
          "phone_type": {
            "type": "string",
            "description": "The category type of the example number."
          },
          "country_code": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code."
          },
          "country_prefix": {
            "type": "string",
            "description": "International dialing code."
          },
          "international_number": {
            "type": "string",
            "description": "Example number in international format."
          },
          "local_number": {
            "type": "string",
            "description": "Example number in local format."
          },
          "e164": {
            "type": "string",
            "description": "Example number in E.164 format."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["error"]
          },
          "error": {
            "type": "string",
            "description": "Error message describing the issue."
          },
          "error_code": {
            "type": "integer",
            "description": "Numeric error code."
          }
        }
      }
    }
  }
}