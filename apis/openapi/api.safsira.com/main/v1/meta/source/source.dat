{"openapi":"3.0.3","info":{"title":"Safsira API","description":"Safsira is an embedded swag solution for premium, on-demand custom products. This API provides access to manage orders, products, and accounts.","version":"v1","x-jentic-source-url":"https://developers.safsira.com/"},"servers":[{"url":"https://api.safsira.com/v1","description":"Safsira API v1"}],"paths":{"/users/me":{"get":{"summary":"Get current user info","description":"Retrieve the account details of the currently authenticated user, including current account information.","operationId":"getCurrentUser","tags":["Users"],"security":[{"OAuth2":[]}],"parameters":[{"name":"SC-Account-Id","in":"header","required":true,"schema":{"type":"string"},"description":"Account identifier"}],"responses":{"200":{"description":"User details retrieved successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/UserResponse"}}}},"400":{"description":"Bad request"},"401":{"description":"Unauthorized"}}}},"/accounts/":{"get":{"summary":"List available accounts","description":"Returns a paginated list of accounts accessible to the authenticated user.","operationId":"listAccounts","tags":["Accounts"],"security":[{"OAuth2":[]}],"responses":{"200":{"description":"Accounts retrieved successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/AccountsListResponse"}}}},"400":{"description":"Bad request"},"401":{"description":"Unauthorized"}}}},"/orders":{"get":{"summary":"Get orders","description":"Retrieve all orders from your account.","operationId":"listOrders","tags":["Orders"],"security":[{"OAuth2":[]}],"parameters":[{"name":"SC-Account-Id","in":"header","required":true,"schema":{"type":"string"},"description":"Account identifier"}],"responses":{"200":{"description":"Orders retrieved successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/OrdersListResponse"}}}},"400":{"description":"Bad request"},"401":{"description":"Unauthorized"}}}},"/orders/{id}":{"get":{"summary":"Get order by ID","description":"Retrieve a specific order using its identifier.","operationId":"getOrderById","tags":["Orders"],"security":[{"OAuth2":[]}],"parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"string"},"description":"Order identifier"},{"name":"SC-Account-Id","in":"header","required":true,"schema":{"type":"string"},"description":"Account identifier"}],"responses":{"200":{"description":"Order retrieved successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Order"}}}},"400":{"description":"Bad request"},"401":{"description":"Unauthorized"},"404":{"description":"Order not found"}}}},"/orders/":{"post":{"summary":"Create order","description":"Create a new order for custom products after product configuration is complete.","operationId":"createOrder","tags":["Orders"],"security":[{"OAuth2":[]}],"parameters":[{"name":"SC-Account-Id","in":"header","required":true,"schema":{"type":"string"},"description":"Account identifier"}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateOrderRequest"}}}},"responses":{"200":{"description":"Order created successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/Order"}}}},"400":{"description":"Bad request - invalid order data"},"401":{"description":"Unauthorized"}}}}},"components":{"schemas":{"UserResponse":{"type":"object","properties":{"id":{"type":"string"},"email":{"type":"string"},"current_account":{"type":"object","properties":{"id":{"type":"string"},"name":{"type":"string"}}}}},"AccountsListResponse":{"type":"object","properties":{"results":{"type":"array","items":{"$ref":"#/components/schemas/Account"}},"count":{"type":"integer"}}},"Account":{"type":"object","properties":{"id":{"type":"string"},"name":{"type":"string"}}},"OrdersListResponse":{"type":"object","properties":{"results":{"type":"array","items":{"$ref":"#/components/schemas/Order"}},"count":{"type":"integer"}}},"Order":{"type":"object","properties":{"id":{"type":"string"},"external_id":{"type":"string"},"status":{"type":"string"},"line_items":{"type":"array","items":{"$ref":"#/components/schemas/LineItem"}},"shipping_orders":{"type":"array","items":{"$ref":"#/components/schemas/ShippingOrder"}}}},"CreateOrderRequest":{"type":"object","required":["payment_method_id","line_items","shipping_orders"],"properties":{"external_id":{"type":"string","description":"Optional external reference ID"},"payment_method_id":{"type":"string"},"billing_address":{"$ref":"#/components/schemas/Address"},"line_items":{"type":"array","items":{"$ref":"#/components/schemas/LineItemInput"}},"shipping_orders":{"type":"array","items":{"$ref":"#/components/schemas/ShippingOrderInput"}}}},"LineItem":{"type":"object","properties":{"id":{"type":"integer"},"product":{"type":"integer"},"quantity":{"type":"integer"},"attributes":{"type":"object","additionalProperties":{"type":"string"}}}},"LineItemInput":{"type":"object","properties":{"id":{"type":"integer"},"product":{"type":"integer"},"quantity":{"type":"integer"},"attributes":{"type":"object","additionalProperties":{"type":"string"}}}},"ShippingOrder":{"type":"object","properties":{"recipient":{"$ref":"#/components/schemas/Address"},"line_items":{"type":"array","items":{"type":"object","properties":{"id":{"type":"integer"},"quantity":{"type":"integer"}}}}}},"ShippingOrderInput":{"type":"object","properties":{"recipient":{"$ref":"#/components/schemas/Address"},"line_items":{"type":"array","items":{"type":"object","properties":{"id":{"type":"integer"},"quantity":{"type":"integer"}}}}}},"Address":{"type":"object","properties":{"first_name":{"type":"string"},"last_name":{"type":"string"},"email":{"type":"string"},"phone":{"type":"string"},"company":{"type":"string"},"line_1":{"type":"string"},"city":{"type":"string"},"state":{"type":"string"},"postal_code":{"type":"string"},"country":{"type":"string"}}}},"securitySchemes":{"OAuth2":{"type":"oauth2","flows":{"authorizationCode":{"authorizationUrl":"https://login.safsira.com/authorize","tokenUrl":"https://login.safsira.com/oauth/token","scopes":{}}}}}}}
