    "reservation_service_search": {
      "type": "object",
      "required": [
        "booking_id",
        "reservasi_name",
        "reservasi_no_contact",
        "reservasi_room_check_in",
        "reservasi_room_jumlah_kamar",
        "reservasi_total_tarif",
        "reservasi_date_booking",
        "reservasi_payment",
        "reservasi_room_chanel"
      ],
      "properties": {
        "booking_id": {
          "type": "string",
          "example": "18-12-12-001"
        },
        "reservasi_name": {
          "type": "string",
          "example": "adit"
        },
        "reservasi_room_jumlah_kamar": {
          "type": "number",
          "example": 3
        },
        "reservasi_total_tarif": {
          "type": "number",
          "example": 0
        },
        "reservasi_room_chanel": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "example": [
            "walk in",
            "traveloka"
          ]
        }
      }
    },
    "create_reservation_service": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
