        "tags": [
          "Designs"
        ],
        "parameters": [
          {
            "name": "designId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Design details",
            "content": {
              "application/json": {
