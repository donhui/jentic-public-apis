    "/v2/billing/invoice/{invoiceId}/pay/paypal": {
      "post": {
        "operationId": "payinvoicewithpaypal",
        "summary": "Pay Invoice with PayPal",
        "description": "Submit a PayPal payment for an invoice.",
        "tags": [
          "Billing"
        ],
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "transactionId",
                  "amount",
                  "email"
                ],
                "properties": {
                  "transactionId": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "number"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment processed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Invoice"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v3/mockup": {
      "post": {
        "operationId": "createmockup",
        "summary": "Create Mockup",
        "description": "Generate a product mockup image with a design applied.",
        "tags": [
          "Mockups"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "template": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "background": {
                        "type": "string"
                      }
                    }
                  },
                  "product": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "color": {
                        "type": "string"
                      }
                    }
                  },
                  "design": {
                    "type": "object"
                  },
                  "output": {
                    "type": "object",
                    "properties": {
                      "width": {
                        "type": "integer"
                      },
                      "height": {
                        "type": "integer"
                      },
                      "format": {
                        "type": "string",
                        "enum": [
                          "png",
                          "jpg"
                        ]
                      },
                      "padding": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mockup generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string",
                      "description": "URL of the generated mockup image"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth. Password is the API key. Username can be empty."
      }
    },
    "schemas": {
      "Category": {
        "type": "object",
        "properties": {
          "categoryId": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "CategoryDetail": {
        "type": "object",
        "properties": {
          "categoryId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "products": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "colors": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "sizes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "availabilityStatus": {
            "type": "string"
          }
        }
      },
      "ProductItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "size": {
            "type": "string"
          },
          "quantity": {
            "type": "integer"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "address1": {
            "type": "string"
          },
          "address2": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "QuoteRequest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "screenprint",
              "dtg",
              "case",
              "mug",
              "poster"
            ]
          },
          "designId": {
            "type": "string"
          },
          "sides": {
            "type": "object",
            "properties": {
              "front": {
                "type": "number"
              },
              "back": {
                "type": "number"
              },
              "left": {
                "type": "number"
              },
              "right": {
                "type": "number"
              }
            }
          },
          "products": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductItem"
            }
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          },
          "features": {
            "type": "object",
            "properties": {
              "shipping": {
                "type": "string"
              },
              "packing": {
                "type": "string"
              }
            }
          },
          "name": {
            "type": "string"
          }
        }
      },
      "QuoteResponse": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number"
          },
          "shipping": {
            "type": "number"
          },
          "subtotal": {
            "type": "number"
          },
          "tax": {
            "type": "number"
          },
          "fees": {
            "type": "number"
          },
          "orderToken": {
            "type": "string"
          },
          "orderIssues": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "mode": {
            "type": "string"
          }
        }
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string"
          },
          "orderToken": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "total": {
            "type": "number"
          },
          "shipping": {
            "type": "number"
          },
          "subtotal": {
            "type": "number"
          },
          "tax": {
            "type": "number"
          },
          "fees": {
            "type": "number"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "deletedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "DesignRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "screenprint",
              "dtg",
              "case",
              "mug",
              "poster"
            ]
          },
          "sides": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "artwork": {
                  "type": "string",
                  "format": "binary"
                },
                "proof": {
                  "type": "string",
                  "format": "binary"
                },
                "colors": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "dimensions": {
                  "type": "object",
                  "properties": {
                    "width": {
                      "type": "number"
                    },
                    "height": {
                      "type": "number"
                    }
                  }
                },
                "position": {
                  "type": "object",
                  "properties": {
                    "horizontal": {
                      "type": "string"
                    },
                    "offset": {
                      "type": "object",
                      "properties": {
                        "top": {
                          "type": "number"
                        },
                        "bottom": {
                          "type": "number"
                        }
                      }
                    }
                  }
                },
                "resize": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "DesignResponse": {
        "type": "object",
        "properties": {
          "designId": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "validation": {
            "type": "object"
          },
          "sides": {
            "type": "object"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "deletedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "mode": {
            "type": "string"
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "orderId": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "meta": {
            "type": "object"
          }
        }
      },
      "Invoice": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string"
          },
          "orderId": {
            "type": "string"
          },
          "total": {
            "type": "number"
          },
          "balance": {
            "type": "number"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    }
