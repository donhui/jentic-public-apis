{
  "openapi": "3.0.3",
  "info": {
    "title": "POLi Payments API",
    "description": "POLi Online Debit Payments API for New Zealand. Provides transaction initiation, retrieval, daily transaction reports, and financial institution lookup using REST/JSON over HTTPS.",
    "version": "1.0",
    "x-jentic-source-url": "https://docs.polipay.co.nz/"
  },
  "servers": [
    {
      "url": "https://poliapi.apac.paywithpoli.com",
      "description": "Production"
    },
    {
      "url": "https://poliapi.uat3.paywithpoli.com",
      "description": "UAT / Testing"
    }
  ],
  "paths": {
    "/api/v2/Transaction/Initiate": {
      "post": {
        "operationId": "initiateTransaction",
        "summary": "Initiate a POLi transaction",
        "description": "Creates a new POLi payment transaction and returns a URL to redirect the customer to for payment processing.",
        "tags": ["Transactions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InitiateTransactionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitiateTransactionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials"
          }
        },
        "security": [{"basicAuth": []}]
      }
    },
    "/api/v2/Transaction/GetTransaction": {
      "get": {
        "operationId": "getTransaction",
        "summary": "Get transaction details",
        "description": "Retrieves complete transaction details using a valid transaction token.",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "description": "The transaction token to query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionDetails"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials"
          }
        },
        "security": [{"basicAuth": []}]
      }
    },
    "/api/v2/Transaction/GetDailyTransactions": {
      "get": {
        "operationId": "getDailyTransactions",
        "summary": "Get daily transactions",
        "description": "Retrieves a list of transactions for a specified date range, optionally filtered by status codes.",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "Start date in ISO 8601 format (e.g., 2023-06-30T19:45:00+11)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "statusCodes",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of status codes to filter by (e.g., Completed,Initiated,Failed)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "End date in ISO 8601 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily transactions retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DailyTransaction"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials"
          }
        },
        "security": [{"basicAuth": []}]
      }
    },
    "/api/v2/Transaction/GetDailyTransactionsCSV": {
      "get": {
        "operationId": "getDailyTransactionsCSV",
        "summary": "Get daily transactions in CSV format",
        "description": "Retrieves a list of transactions for a specified date range in CSV format.",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": true,
            "description": "Start date in ISO 8601 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "statusCodes",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of status codes to filter by",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "End date in ISO 8601 format",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CSV file with daily transactions",
            "content": {
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [{"basicAuth": []}]
      }
    },
    "/api/Entity/GetFinancialInstitutions": {
      "get": {
        "operationId": "getFinancialInstitutions",
        "summary": "Get supported financial institutions",
        "description": "Retrieves the list of supported banks available to the merchant.",
        "tags": ["Financial Institutions"],
        "responses": {
          "200": {
            "description": "List of financial institutions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FinancialInstitution"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid credentials"
          }
        },
        "security": [{"basicAuth": []}]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Base64-encoded credentials in the format AccessCode:AuthCode"
      }
    },
    "schemas": {
      "InitiateTransactionRequest": {
        "type": "object",
        "required": ["Amount", "CurrencyCode", "MerchantReference", "MerchantHomepageURL", "SuccessURL"],
        "properties": {
          "Amount": {
            "type": "number",
            "format": "double",
            "description": "Transaction charge amount with 2 decimal places"
          },
          "CurrencyCode": {
            "type": "string",
            "maxLength": 3,
            "description": "Currency code (e.g., NZD)",
            "example": "NZD"
          },
          "MerchantReference": {
            "type": "string",
            "maxLength": 100,
            "description": "Unique merchant transaction identifier"
          },
          "MerchantReferenceFormat": {
            "type": "string",
            "maxLength": 50,
            "description": "NZ reconciliation format specification"
          },
          "MerchantData": {
            "type": "string",
            "maxLength": 2000,
            "description": "Internal merchant reference data"
          },
          "MerchantHomepageURL": {
            "type": "string",
            "maxLength": 1000,
            "description": "Merchant website URL displayed on POLi landing page"
          },
          "SuccessURL": {
            "type": "string",
            "maxLength": 1000,
            "description": "Redirect destination for successful transactions"
          },
          "FailureURL": {
            "type": "string",
            "maxLength": 1000,
            "description": "Redirect destination for failed transactions"
          },
          "CancellationURL": {
            "type": "string",
            "maxLength": 1000,
            "description": "Redirect destination for cancelled transactions"
          },
          "NotificationURL": {
            "type": "string",
            "maxLength": 1000,
            "description": "Endpoint for receiving POST notifications (Nudge)"
          },
          "Timeout": {
            "type": "integer",
            "description": "Transaction timeout duration in seconds; defaults to 900"
          },
          "SelectedFICode": {
            "type": "string",
            "description": "Financial institution code for bank pre-selection"
          }
        }
      },
      "InitiateTransactionResponse": {
        "type": "object",
        "properties": {
          "Success": {
            "type": "boolean",
            "description": "Operation status indicator"
          },
          "NavigateURL": {
            "type": "string",
            "description": "URL to redirect customer for payment processing"
          },
          "ErrorCode": {
            "type": "integer",
            "description": "Error identifier if unsuccessful"
          },
          "ErrorMessage": {
            "type": "string",
            "description": "Human-readable error description"
          },
          "TransactionRefNo": {
            "type": "string",
            "description": "POLi-generated transaction reference number"
          }
        }
      },
      "TransactionDetails": {
        "type": "object",
        "properties": {
          "TransactionRefNo": {
            "type": "string",
            "description": "Unique 12-digit POLi transaction reference"
          },
          "TransactionID": {
            "type": "string",
            "description": "32 hexadecimal digit UUID/GUID reference"
          },
          "CurrencyCode": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "CurrencyName": {
            "type": "string"
          },
          "CountryCode": {
            "type": "string",
            "description": "ISO 3166-1 country code"
          },
          "CountryName": {
            "type": "string"
          },
          "PaymentAmount": {
            "type": "number",
            "format": "double",
            "description": "Attempted payment amount"
          },
          "AmountPaid": {
            "type": "number",
            "format": "double",
            "description": "Actual paid amount"
          },
          "EstablishedDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "MerchantEstablishedDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "StartDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "EndDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "BankReceipt": {
            "type": "string",
            "description": "Internet banking receipt number"
          },
          "BankReceiptDateTime": {
            "type": "string"
          },
          "TransactionStatusCode": {
            "type": "string",
            "description": "Terminal transaction status code"
          },
          "ErrorCode": {
            "type": "string"
          },
          "ErrorMessage": {
            "type": "string"
          },
          "FinancialInstitutionCode": {
            "type": "string"
          },
          "FinancialInstitutionCountryCode": {
            "type": "string"
          },
          "FinancialInstitutionName": {
            "type": "string"
          },
          "MerchantReference": {
            "type": "string"
          },
          "MerchantData": {
            "type": "string"
          },
          "MerchantAccountName": {
            "type": "string"
          },
          "MerchantAccountSortCode": {
            "type": "string"
          },
          "MerchantAccountNumber": {
            "type": "string"
          },
          "MerchantAccountSuffix": {
            "type": "string"
          },
          "MerchantEntityID": {
            "type": "string"
          },
          "MerchantName": {
            "type": "string"
          },
          "PayerFirstName": {
            "type": "string"
          },
          "PayerFamilyName": {
            "type": "string"
          },
          "PayerAccountSortCode": {
            "type": "string"
          },
          "PayerAccountNumber": {
            "type": "string"
          },
          "PayerAccountSuffix": {
            "type": "string"
          },
          "IsExpired": {
            "type": "boolean"
          },
          "UserIPAddress": {
            "type": "string"
          },
          "POLiVersionCode": {
            "type": "string"
          }
        }
      },
      "DailyTransaction": {
        "type": "object",
        "properties": {
          "AmountPaid": {
            "type": "number",
            "format": "double"
          },
          "BankReceiptNo": {
            "type": "string"
          },
          "CurrencyCode": {
            "type": "string"
          },
          "EndDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "EstablishedDateTime": {
            "type": "string",
            "format": "date-time"
          },
          "FinancialInstitutionCode": {
            "type": "string"
          },
          "FinancialInstitutionName": {
            "type": "string"
          },
          "MerchantCode": {
            "type": "string"
          },
          "MerchantCommonName": {
            "type": "string"
          },
          "MerchantReference": {
            "type": "string"
          },
          "MerchantData": {
            "type": "string"
          },
          "PaymentAmount": {
            "type": "number",
            "format": "double"
          },
          "TransactionRefNo": {
            "type": "string"
          },
          "TransactionStatusCode": {
            "type": "string"
          }
        }
      },
      "FinancialInstitution": {
        "type": "object",
        "properties": {
          "Name": {
            "type": "string",
            "description": "Financial institution name"
          },
          "Code": {
            "type": "string",
            "description": "Financial institution code"
          },
          "Online": {
            "type": "boolean",
            "description": "Whether the FI is currently online"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "Success": {
            "type": "boolean"
          },
          "ErrorCode": {
            "type": "integer"
          },
          "ErrorMessage": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [
    {"basicAuth": []}
  ]
}