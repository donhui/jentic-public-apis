      "CapturePayment": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "format": "uuid",
            "description": "A unique request ID, required for idempotent retries."
          },
          "merchantReference": {
            "type": "string",
            "description": "The reference/ order id that this payment corresponds to in the merchant's system. \n\nNote: Providing a new value will update any value previously set in the Create Checkout request."
          },
          "amount": {
            "$ref": "#/components/schemas/Money"
          },
          "paymentEventMerchantReference": {
            "type": "string",
            "description": "A unique reference for the individual payment capture event. If provided, the value will appear in the daily settlement file as \"Payment Event ID\"\n"
          }
        },
        "title": "CapturePayment"
