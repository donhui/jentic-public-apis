            "type": "string",
            "description": "The reference/order ID in the merchant's system"
          },
          "shippingAmount": {
            "$ref": "#/components/schemas/Money",
            "description": "The shipping cost amount"
          },
          "taxAmount": {
            "$ref": "#/components/schemas/Money",
            "description": "The tax amount"
          }
        },
