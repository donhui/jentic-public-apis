{
  "openapi": "3.0.3",
  "info": {
    "title": "CoinRanking",
    "version": "2.0.0",
    "description": "Coinranking API provides cryptocurrency market data including coin listings, price history, exchange data, global statistics, and search functionality.",
    "x-jentic-source-url": "https://coinranking.com/api/documentation"
  },
  "servers": [
    {
      "url": "https://api.coinranking.com/v2",
      "description": "Coinranking API v2"
    }
  ],
  "tags": [
    { "name": "Coins", "description": "Cryptocurrency data endpoints" },
    { "name": "Stats", "description": "Global market statistics" },
    { "name": "Search", "description": "Search functionality" },
    { "name": "ReferenceCurrencies", "description": "Reference currency data" },
    { "name": "Tags", "description": "Coin tag endpoints" },
    { "name": "Indicators", "description": "Market indicator endpoints" }
  ],
  "paths": {
    "/coins": {
      "get": {
        "operationId": "listCoins",
        "summary": "List all coins with market data",
        "tags": ["Coins"],
        "parameters": [
          {
            "name": "referenceCurrencyUuid",
            "in": "query",
            "required": false,
            "description": "UUID of the reference currency for price calculations",
            "schema": { "type": "string" }
          },
          {
            "name": "timePeriod",
            "in": "query",
            "required": false,
            "description": "Time period for price change calculation",
            "schema": { "type": "string", "enum": ["1h", "3h", "12h", "24h", "7d", "30d", "3m", "1y", "3y", "5y"], "default": "24h" }
          },
          {
            "name": "tiers",
            "in": "query",
            "required": false,
            "description": "Filter by tier",
            "schema": { "type": "array", "items": { "type": "integer" } }
          },
          {
            "name": "orderBy",
            "in": "query",
            "required": false,
            "description": "Order coins by",
            "schema": { "type": "string", "enum": ["marketCap", "price", "24hVolume", "change", "listedAt"], "default": "marketCap" }
          },
          {
            "name": "orderDirection",
            "in": "query",
            "required": false,
            "description": "Sort direction",
            "schema": { "type": "string", "enum": ["asc", "desc"], "default": "desc" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results (max 5000, default 50)",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Offset for pagination",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "tags",
            "in": "query",
            "required": false,
            "description": "Filter by tags",
            "schema": { "type": "array", "items": { "type": "string" } }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "description": "Search query to filter coins",
            "schema": { "type": "string" }
          },
          {
            "name": "uuids",
            "in": "query",
            "required": false,
            "description": "Filter by specific coin UUIDs",
            "schema": { "type": "array", "items": { "type": "string" } }
          }
        ],
        "responses": {
          "200": {
            "description": "List of coins",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CoinsResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/coins/trending": {
      "get": {
        "operationId": "getTrendingCoins",
        "summary": "Get trending coins",
        "tags": ["Coins"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Pagination offset",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Trending coins",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CoinsResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/coin/{uuid}": {
      "get": {
        "operationId": "getCoinDetails",
        "summary": "Get detailed information for a specific coin",
        "tags": ["Coins"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "description": "UUID of the coin",
            "schema": { "type": "string" }
          },
          {
            "name": "referenceCurrencyUuid",
            "in": "query",
            "required": false,
            "description": "UUID of reference currency",
            "schema": { "type": "string" }
          },
          {
            "name": "timePeriod",
            "in": "query",
            "required": false,
            "description": "Time period for change and history",
            "schema": { "type": "string", "enum": ["1h", "3h", "12h", "24h", "7d", "30d", "3m", "1y", "3y", "5y"], "default": "24h" }
          }
        ],
        "responses": {
          "200": {
            "description": "Coin details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CoinDetailResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/coin/{uuid}/price": {
      "get": {
        "operationId": "getCoinPrice",
        "summary": "Get the current price of a coin",
        "tags": ["Coins"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "description": "UUID of the coin",
            "schema": { "type": "string" }
          },
          {
            "name": "referenceCurrencyUuid",
            "in": "query",
            "required": false,
            "description": "UUID of reference currency",
            "schema": { "type": "string" }
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": false,
            "description": "Unix timestamp for historical price",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Coin price",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "price": { "type": "string" },
                        "timestamp": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/coin/{uuid}/history": {
      "get": {
        "operationId": "getCoinPriceHistory",
        "summary": "Get historical price data for a coin",
        "tags": ["Coins"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "description": "UUID of the coin",
            "schema": { "type": "string" }
          },
          {
            "name": "referenceCurrencyUuid",
            "in": "query",
            "required": false,
            "description": "UUID of reference currency",
            "schema": { "type": "string" }
          },
          {
            "name": "timePeriod",
            "in": "query",
            "required": false,
            "description": "Time period for history",
            "schema": { "type": "string", "enum": ["1h", "3h", "12h", "24h", "7d", "30d", "3m", "1y", "3y", "5y"], "default": "24h" }
          }
        ],
        "responses": {
          "200": {
            "description": "Price history",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PriceHistoryResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/stats": {
      "get": {
        "operationId": "getGlobalStats",
        "summary": "Get global cryptocurrency market statistics",
        "tags": ["Stats"],
        "parameters": [
          {
            "name": "referenceCurrencyUuid",
            "in": "query",
            "required": false,
            "description": "UUID of reference currency",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Global statistics",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GlobalStatsResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/search-suggestions": {
      "get": {
        "operationId": "getSearchSuggestions",
        "summary": "Search for coins, exchanges, and markets",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search query string",
            "schema": { "type": "string" }
          },
          {
            "name": "referenceCurrencyUuid",
            "in": "query",
            "required": false,
            "description": "UUID of reference currency",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/reference-currencies": {
      "get": {
        "operationId": "listReferenceCurrencies",
        "summary": "List available reference currencies",
        "tags": ["ReferenceCurrencies"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Pagination offset",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "types",
            "in": "query",
            "required": false,
            "description": "Filter by type",
            "schema": { "type": "array", "items": { "type": "string", "enum": ["fiat", "coin", "denominator"] } }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "description": "Search query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Reference currencies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "currencies": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/ReferenceCurrency" }
                        },
                        "stats": {
                          "type": "object",
                          "properties": {
                            "total": { "type": "integer" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/tags": {
      "get": {
        "operationId": "listTags",
        "summary": "List all tags used to categorize coins",
        "tags": ["Tags"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Pagination offset",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of tags",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "tags": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/Tag" }
                        },
                        "stats": {
                          "type": "object",
                          "properties": {
                            "total": { "type": "integer" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/coin/{uuid}/indicators/moving-averages": {
      "get": {
        "operationId": "getCoinMovingAverages",
        "summary": "Get moving average indicators for a coin",
        "tags": ["Indicators"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "description": "UUID of the coin",
            "schema": { "type": "string" }
          },
          {
            "name": "referenceCurrencyUuid",
            "in": "query",
            "required": false,
            "description": "UUID of reference currency",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Moving average indicators",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CoinsResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "stats": {
                "type": "object",
                "properties": {
                  "total": { "type": "integer" },
                  "totalCoins": { "type": "integer" },
                  "totalMarkets": { "type": "integer" },
                  "totalExchanges": { "type": "integer" },
                  "totalMarketCap": { "type": "string" },
                  "total24hVolume": { "type": "string" }
                }
              },
              "coins": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Coin" }
              }
            }
          }
        }
      },
      "Coin": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "symbol": { "type": "string" },
          "name": { "type": "string" },
          "color": { "type": "string" },
          "iconUrl": { "type": "string" },
          "marketCap": { "type": "string" },
          "price": { "type": "string" },
          "listedAt": { "type": "integer" },
          "tier": { "type": "integer" },
          "change": { "type": "string" },
          "rank": { "type": "integer" },
          "sparkline": {
            "type": "array",
            "items": { "type": "string", "nullable": true }
          },
          "lowVolume": { "type": "boolean" },
          "coinrankingUrl": { "type": "string" },
          "24hVolume": { "type": "string" },
          "btcPrice": { "type": "string" },
          "contractAddresses": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "CoinDetailResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "coin": {
                "allOf": [
                  { "$ref": "#/components/schemas/Coin" },
                  {
                    "type": "object",
                    "properties": {
                      "description": { "type": "string" },
                      "websiteUrl": { "type": "string" },
                      "links": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": { "type": "string" },
                            "url": { "type": "string" },
                            "type": { "type": "string" }
                          }
                        }
                      },
                      "supply": {
                        "type": "object",
                        "properties": {
                          "confirmed": { "type": "boolean" },
                          "supplyAt": { "type": "integer" },
                          "circulating": { "type": "string" },
                          "total": { "type": "string" },
                          "max": { "type": "string" }
                        }
                      },
                      "allTimeHigh": {
                        "type": "object",
                        "properties": {
                          "price": { "type": "string" },
                          "timestamp": { "type": "integer" }
                        }
                      },
                      "numberOfMarkets": { "type": "integer" },
                      "numberOfExchanges": { "type": "integer" }
                    }
                  }
                ]
              }
            }
          }
        }
      },
      "PriceHistoryResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "change": { "type": "string" },
              "history": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "price": { "type": "string" },
                    "timestamp": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      },
      "GlobalStatsResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "totalCoins": { "type": "integer" },
              "totalMarkets": { "type": "integer" },
              "totalExchanges": { "type": "integer" },
              "totalMarketCap": { "type": "string" },
              "total24hVolume": { "type": "string" },
              "btcDominance": { "type": "number" },
              "bestCoins": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Coin" }
              },
              "newestCoins": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Coin" }
              }
            }
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "coins": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Coin" }
              },
              "exchanges": {
                "type": "array",
                "items": { "type": "object" }
              },
              "markets": {
                "type": "array",
                "items": { "type": "object" }
              }
            }
          }
        }
      },
      "ReferenceCurrency": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "type": { "type": "string" },
          "iconUrl": { "type": "string" },
          "name": { "type": "string" },
          "symbol": { "type": "string" },
          "sign": { "type": "string" }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "coinCount": { "type": "integer" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "type": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-access-token",
        "description": "API key passed via x-access-token header"
      }
    }
  },
  "security": [
    { "ApiKeyAuth": [] }
  ]
}