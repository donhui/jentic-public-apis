          },
          "StartDate": {
            "description": "The start date of the HSL order.",
            "type": "string",
            "format": "date-time"
          },
          "EndDate": {
            "description": "The end date of the HSL order. In case the HSL order is marked as ongoing, this value will be null.",
            "type": "string",
            "format": "date-time"
          },
          "OrdererId": {
            "description": "HSL user id of the person that ordered the HSL order.",
            "type": "integer",
            "format": "int32"
          },
          "OrdererName": {
            "description": "Name of person who ordered this HSL order.",
            "type": "string"
          },
          "OrderDate": {
            "description": "Date when this HSL order was created.",
            "type": "string",
            "format": "date-time"
          },
          "ReceiverProviderUnitId": {
            "description": "The provider unit id that is the receiver of the HSL order.",
            "type": "integer",
            "format": "int32"
          },
          "ReceiverProviderUnitName": {
            "description": "The provider unit name that is the receiver of the HSL order.",
            "type": "string"
          },
          "ConfirmedDate": {
            "description": "Date when this HSL order was confirmed.",
            "type": "string",
            "format": "date-time"
          },
          "LHslJournalId": {
            "description": "HSL journal Id of the patient that this HSL order is about.",
            "type": "integer",
            "format": "int32"
          },
          "ErrorMarkedById": {
            "description": "HSL user id of the person that error marked this HSL order.",
            "type": "integer",
            "format": "int32"
          },
          "ErrorMarkedName": {
            "description": "Name of the person who error marked this HSL order.",
            "type": "string"
          },
          "ErrorMarkedDate": {
            "description": "Datetime in UTC when this HSL order was error marked. Null in case it is not error marked.",
            "type": "string",
            "format": "date-time"
          },
          "OrderText": {
            "description": "The order text of the HSL order",
            "type": "string"
          },
          "Deleted": {
            "description": "If the entity is deleted (only used in delta queries).",
            "type": "boolean"
          },
          "StartTime": {
            "description": "If the order starts at a certain time during the start date, then this field will be filled with the point of time on the format \"HH.mm\", otherwise it will be null.",
            "type": "string"
          },
          "EndTime": {
            "description": "If the order ends at a certain time during the end date, then this field will be filled with the point of time on the format \"HH.mm\", otherwise it will be null.",
            "type": "string"
          }
        },
        "xml": {
          "name": "LifecareHslOrder"
        },
        "type": "object"
      },
