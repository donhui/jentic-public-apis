      "delete": {
        "tags": [
          "ProviderOrderFcv1"
        ],
        "summary": "Api to revoke an order.",
        "operationId": "ProviderOrderFcv1_RevokeOrder",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The external order ID.",
            "required": true,
            "type": "string"
          },
          {
            "name": "domain",
            "in": "query",
            "description": "The domain ID.",
            "required": true,
            "type": "string"
          },
          {
            "name": "key",
            "in": "query",
            "description": "The API key.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Order successfully revoked"
          },
          "404": {
            "description": "Order not found"
          },
          "409": {
            "description": "Order conflict - could not revoke because of current status"
          },
          "501": {
            "description": "Not implemented - feature is not configured in EC"
          }
        }
      }
    },
