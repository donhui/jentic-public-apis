      "WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.LifecareHslActivityPerformedRequest": {
        "description": "List Lifecare HSL activities performed request",
        "required": [
          "domain",
          "key"
        ],
        "properties": {
          "limit": {
            "description": "The limit controls the maximum number of activity performed items (in total) that may be returned. Default is 10000.",
            "type": "integer",
            "format": "int32"
          },
          "offset": {
            "description": "The offset controls how many activity performed items that should be skipped before the read starts.",
            "type": "integer",
            "format": "int32"
          },
          "startDate": {
            "description": "Start date of the search period. Fetches performed activity registrations with performed date at this date or later.\r\nRequired format: yyyy-MM-dd",
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "description": "End date of the search period. Fetches performed activity registrations with performed date at this date or earlier.\r\nRequired format: yyyy-MM-dd",
            "type": "string",
            "format": "date-time"
          },
          "gt": {
            "description": "If specified, gets resources modified after specified time (greater than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with startDate, endDate or includeErrorMarked",
            "type": "string",
            "format": "date-time"
          },
          "lt": {
            "description": "If specified, gets resources modified before specified time (less than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with startDate, endDate or includeErrorMarked",
            "type": "string",
            "format": "date-time"
          },
          "includeErrorMarked": {
            "description": "Controls if the response should include activity performed registrations that are error marked.",
            "type": "boolean"
          },
          "domain": {
            "description": "The domain ID.",
            "type": "string"
          },
          "key": {
            "description": "The API key.",
            "type": "string"
          }
        },
        "xml": {
          "name": "LifecareHslActivityPerformedRequest"
        },
        "type": "object"
      },
      "WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.ActivityPerformed": {
        "description": "Container for information about an activity occurrence performed/not performed registration",
        "properties": {
          "Id": {
            "description": "The id of the activity performed registration",
            "type": "integer",
            "format": "int32"
          },
          "CareProcessId": {
            "description": "The care process id that the activity is a part of",
            "type": "integer",
            "format": "int32"
          },
          "ActivityId": {
            "description": "The activity id that the activity performed/not performed registration is registered on",
            "type": "integer",
            "format": "int32"
          },
          "Curator": {
            "description": "The activity is performed by a curator",
            "type": "boolean"
          },
          "Dietitian": {
            "description": "The activity is performed by a dietitian",
            "type": "boolean"
          },
          "Nurse": {
            "description": "The activity is performed by a nurse",
            "type": "boolean"
          },
          "OccupationalTherapist": {
            "description": "The activity is performed by an occupational therapist",
            "type": "boolean"
          },
          "OtherPersonnel": {
            "description": "The activity is performed by an \"other personnel\"",
            "type": "boolean"
          },
          "Physiotherapist": {
            "description": "The activity is performed by a physiotherapist",
            "type": "boolean"
          },
          "Psychologist": {
            "description": "The activity is performed by a psychologist",
            "type": "boolean"
          },
          "SpeechTherapist": {
            "description": "The activity is performed by a speech therapist",
            "type": "boolean"
          },
          "ActivityType": {
            "description": "The type of the activity. For example investigating or treating.",
            "type": "string",
            "enum": [
              "Investigating",
              "Treating"
            ]
          },
          "PlannedTime": {
            "description": "The activity occurrence planned date and time (Only date if time of the activity is not specified, otherwise in UTC format time) to get a reference to the actual occurence",
            "type": "string",
            "format": "date-time"
          },
          "PerformedTime": {
            "description": "When the activity was performed in UTC format",
            "type": "string",
            "format": "date-time"
          },
          "Performed": {
            "description": "If the activity is registered as performed or not performed",
            "type": "boolean"
          },
          "TimeSpecified": {
            "description": "Indicates if the activity is time specified",
            "type": "boolean"
          },
          "Result": {
            "description": "Contains the result value of the activity performed registration",
            "type": "string"
          },
          "ReasonNotPerformed": {
            "description": "Contains the reason why whole or parts of the activity was not performed",
            "type": "string"
          },
          "MeasuredValues": {
            "description": "Contains the measured value registrations for the activity performed registration",
            "items": {
              "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.MeasuredValue"
            },
            "xml": {
              "name": "MeasuredValue",
              "wrapped": true
            },
            "type": "array"
          },
          "CreatedBy": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.ActivityPerformedUserTimestamp",
            "description": "The user who created this entry originally"
          },
          "ModifiedBy": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.ActivityPerformedUserTimestamp",
            "description": "The user who modified this entry"
          },
          "SignedBy": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.ActivityPerformedUserTimestamp",
            "description": "The user who signed this entry"
          },
          "ErrorMarkedBy": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.ActivityPerformedUserTimestamp",
            "description": "The user who error marked this entry. If it isn't error marked, then this property will be null."
          },
          "ModifiedComment": {
            "description": "Comment about why the registration was modified when for example error marking the registration",
            "type": "string"
          },
          "ActivityPerformedKvas": {
            "description": "A list of the KV\u00c5 codes connected to the activityPerformed",
            "items": {
              "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.ActivityPerformedKva"
            },
            "xml": {
              "name": "ActivityPerformedKva",
              "wrapped": true
            },
            "type": "array"
          },
          "Deleted": {
            "description": "If the activityPerformed is deleted (only used in delta queries).",
            "type": "boolean"
          },
          "SystemStartTime": {
            "description": "The start time in UTC of when this version of the activityPerformed was in use (only used in delta queries).",
            "type": "string",
            "format": "date-time"
          },
          "SystemEndTime": {
            "description": "The end time in UTC of when this version of the activityPerformed was in use (only used in delta queries).\r\nIf SystemEndTime is null, it is the current activity performed history value.",
            "type": "string",
            "format": "date-time"
          }
        },
        "xml": {
          "name": "ActivityPerformed"
        },
        "type": "object"
      },
      "WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.MeasuredValue": {
        "description": "Measured value",
        "properties": {
          "MeasuredTypeId": {
            "description": "Measured type of measured value",
            "type": "integer",
            "format": "int32"
          },
          "Name": {
            "description": "Name of the measured type",
            "type": "string"
          },
          "UnitName": {
            "description": "Name of the measured value unit",
            "type": "string"
          },
          "Value": {
            "description": "Value for measured value",
            "type": "number",
            "format": "double"
          },
          "HighLowValue": {
            "description": "Value for measured value",
            "type": "string",
            "enum": [
              "Undefined",
              "Low",
              "High"
            ]
          },
          "Comment": {
            "description": "Comment for measured value",
            "type": "string"
          },
          "IsFasting": {
            "description": "If measured value is measured after the patient has been fasting",
            "type": "boolean"
          }
        },
        "xml": {
          "name": "MeasuredValue"
        },
        "type": "object"
      },
      "WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.ActivityPerformedUserTimestamp": {
        "description": "Timestamp attached to a user",
        "properties": {
          "IsProviderUser": {
            "description": "If the user timestamp is referencing a provider personnel user or a Lifecare HSL user",
            "type": "boolean"
          },
          "UserId": {
            "description": "The user's id",
            "type": "integer",
            "format": "int32"
          },
          "UserName": {
            "description": "The user's full name",
            "type": "string"
          },
          "UserRole": {
            "description": "The user's role",
            "type": "string"
          },
          "UserSignature": {
            "description": "The user's signature",
            "type": "string"
          },
          "TimeStamp": {
            "description": "Timestamp in UTC. The time that the performed/not performed registration was created/modified/signed/errorMarked depending on context",
            "type": "string",
            "format": "date-time"
          }
        },
        "xml": {
          "name": "ActivityPerformedUserTimestamp"
        },
        "type": "object"
      },
      "WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.ActivityPerformedKva": {
        "description": "Information about the KV\u00c5 used in the activityPerformed",
        "properties": {
          "ActivityPerformedId": {
            "description": "The id of the activity performed registration",
            "type": "integer",
            "format": "int32"
          },
          "KvaCodeId": {
            "description": "The KV\u00c5-code id",
            "type": "integer",
            "format": "int32"
          },
          "KvaCode": {
            "description": "The KV\u00c5-code",
            "type": "string"
          },
          "KvaCodeName": {
            "description": "The KV\u00c5-code codename",
            "type": "string"
          },
          "KvaCodeDescription": {
            "description": "The KV\u00c5-code description.",
            "type": "string"
          },
          "IsPerformed": {
            "description": "Indicates if the KVA code was performed in the registration. One activity performed registration can contain multiple KVA codes where some are performed and some are not performed.",
            "type": "boolean"
          }
        },
        "xml": {
          "name": "ActivityPerformedKva"
        },
        "type": "object"
      },
      "WE.EC.Integration.Contracts.LifecareHslActivity.V1.LifecareHslActivityRequest": {
        "description": "List Lifecare HSL activities request",
        "required": [
          "domain",
          "key"
        ],
        "properties": {
          "limit": {
            "description": "The limit controls the maximum number of activity items (in total) that may be returned. Default is 10000.",
            "type": "integer",
            "format": "int32"
          },
          "offset": {
            "description": "The offset controls how many activity items that should be skipped before the read starts.",
            "type": "integer",
            "format": "int32"
          },
          "startDate": {
            "description": "Start date of the search period. Fetches activities with an end date that is bigger than or equals to this parameter.\r\nRequired format: yyyy-MM-dd",
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "description": "End date of the search period. Fetches activities with a start date that is less than or equals to this parameter.\r\nRequired format: yyyy-MM-dd",
            "type": "string",
            "format": "date-time"
          },
          "gt": {
            "description": "If specified, gets resources modified after specified time (greater than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with startDate, endDate or includeErrorMarked",
            "type": "string",
            "format": "date-time"
          },
          "lt": {
            "description": "If specified, gets resources modified before specified time (less than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with startDate, endDate or includeErrorMarked",
            "type": "string",
            "format": "date-time"
          },
          "includeErrorMarked": {
            "description": "Controls if the response should contain error marked activities or not.",
            "type": "boolean"
          },
          "domain": {
            "description": "The domain ID.",
            "type": "string"
          },
          "key": {
            "description": "The API key.",
            "type": "string"
          }
        },
        "xml": {
          "name": "LifecareHslActivityRequest"
        },
        "type": "object"
      },
      "WE.EC.Integration.Contracts.LifecareHslActivity.V1.Activity": {
        "description": "Activity",
        "properties": {
          "Id": {
            "description": "Id of the activity.",
            "type": "integer",
            "format": "int32"
          },
          "CareProcessId": {
            "description": "Id of the care process that the activity is in.",
            "type": "integer",
            "format": "int32"
          },
          "PatientPersonId": {
            "description": "Person id of the patient.",
            "type": "string"
          },
          "PatientName": {
            "description": "Full name of the patient. Format: \"Surname, Firstname\".",
            "type": "string"
          },
          "LHslJournalId": {
            "description": "The ID of the patients journal.",
            "type": "integer",
            "format": "int32"
          },
          "Type": {
            "description": "The type of activity.",
            "type": "string",
            "enum": [
              "Investigating",
              "Treating"
            ]
          },
          "KvaCode": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.KvaCode",
            "description": "The primary KVA code of the activity."
          },
          "Description": {
            "description": "Activity description.",
            "type": "string"
          },
          "IsWhenNeeded": {
            "description": "Specifies if the activity can be performed when needed.",
            "type": "boolean"
          },
          "PrescriptionCause": {
            "description": "The prescription cause for when needed activities.",
            "type": "string"
          },
          "TimeSpecified": {
            "description": "Indicates if time is specified for this activity. If not time specified, it is handled as an all-day activity.",
            "type": "boolean"
          },
          "StartDate": {
            "description": "The start date of the activity (in case TimeSpecified is set to true, this property also has a time part set in UTC format).",
            "type": "string",
            "format": "date-time"
          },
          "EndDate": {
            "description": "The end date of the activity (in case TimeSpecified is set to true, this property also has a time part set in UTC format). The end date and time of the activities last occurrence + the activities duration. If the activity goes on forever, this property has null as value.",
            "type": "string",
            "format": "date-time"
          },
          "Duration": {
            "description": "The duration of the activity in HH.mm format. If no duration is specified this is set to empty string.",
            "type": "string"
          },
          "TimeWindowMode": {
            "description": "The kind of time window required to moving this activity",
            "type": "string",
            "enum": [
              "AsPlanned",
              "WithinTheSpecifiedTimeWindow"
            ]
          },
          "TimeWindow": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.ActivityTimeWindow",
            "description": "Activity Time Window range"
          },
          "RRule": {
            "description": "If the activity is recurring, this contains the RRule value that specifies how the activity should be recurring.",
            "type": "string"
          },
          "RRuleSummarySwedish": {
            "description": "If the activity is recurring, this contains \"natural\" summary of the RRule in Swedish.",
            "type": "string"
          },
          "RRuleSummaryBritish": {
            "description": "If the activity is recurring, this contains \"natural\" summary of the RRule in British English.",
            "type": "string"
          },
          "WhenDuringDay": {
            "description": "If the activity is not time specified, a when during day could have been chosen and indicating when during the day that the activity should be performed. This contains the code text code value of the chosen 'When during day' value.",
            "type": "integer",
            "format": "int32"
          },
          "WhenDuringDayText": {
            "description": "If the activity is not time specified, a when during day could have been chosen and indicating when during the day that the activity should be performed. This contains the name of the chosen 'When during day' value.",
            "type": "string"
          },
          "AllDayTimesPerDay": {
            "description": "Basis for compensation with information about how many times per day all day activities are planned to be performed. Only applicable for not time specified activities and when feature EC_HSLActivityNumberOfTimesPerDay is enabled. This field will otherwise have the value null.",
            "type": "integer",
            "format": "int32"
          },
          "Nurse": {
            "description": "If this activity should be performed by nurses.",
            "type": "boolean"
          },
          "Physiotherapist": {
            "description": "If this activity should be performed by physiotherapists.",
            "type": "boolean"
          },
          "OccupationalTherapist": {
            "description": "If this activity should be performed by occupational therapists.",
            "type": "boolean"
          },
          "Dietician": {
            "description": "If this activity should be performed by dieticians.",
            "type": "boolean"
          },
          "Curator": {
            "description": "If this activity should be performed by curators.",
            "type": "boolean"
          },
          "SpeechTherapist": {
            "description": "If this activity should be performed by speech therapists.",
            "type": "boolean"
          },
          "Psychologist": {
            "description": "If this activity should be performed by psychologists.",
            "type": "boolean"
          },
          "OtherPersonnel": {
            "description": "If this activity should be performed by care personnel.",
            "type": "boolean"
          },
          "Feedback": {
            "description": "This field can be filled with information about when the activity performer should contact the creator of the activity.",
            "type": "string"
          },
          "NoNotification": {
            "description": "Should not send a signal in case of non-registration for this activity.",
            "type": "boolean"
          },
          "IsMedication": {
            "description": "Is activity medication-related. When customer don't have the delegation-module, we don't know if medication is required and the isMedication field is set to null.",
            "type": "boolean"
          },
          "IsPlanned": {
            "description": "Is the activity planned or not.",
            "type": "boolean"
          },
          "Times": {
            "description": "If the activity is time specified, this property will hold all the time during day when the activity is planned to be performed.",
            "items": {
              "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.ActivityTime"
            },
            "xml": {
              "name": "ActivityTime",
              "wrapped": true
            },
            "type": "array"
          },
          "DelegationMode": {
            "description": "The kind of delegation required to perform this activity. When customer don't have the delegation-module, we don't know if delegation is required and the DelegationMode field is set to null.",
            "type": "string",
            "enum": [
              "NotSpecified",
              "Unit",
              "Patient"
            ]
          },
          "Tasks": {
            "description": "A list of the tasks required to perform this activity",
            "items": {
              "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.ActivityDelegationTask"
            },
            "xml": {
              "name": "ActivityDelegationTask",
              "wrapped": true
            },
            "type": "array"
          },
          "ExtraKvaCodes": {
            "description": "The extra KVA codes that are not the primary KVA code.",
            "items": {
              "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.KvaCode"
            },
            "xml": {
              "name": "KvaCode",
              "wrapped": true
            },
            "type": "array"
          },
          "Goals": {
            "description": "The connected goals for the activity.",
            "items": {
              "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.ActivityGoal"
            },
            "xml": {
              "name": "ActivityGoal",
              "wrapped": true
            },
            "type": "array"
          },
          "PlannedMeasuredTypes": {
            "description": "The planned measured types for the activity.",
            "items": {
              "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.ActivityPlannedMeasuredType"
            },
            "xml": {
              "name": "ActivityPlannedMeasuredType",
              "wrapped": true
            },
            "type": "array"
          },
          "CreatedBy": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.HslUserTimestamp",
            "description": "The user who created this activity."
          },
          "ModifiedBy": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.HslUserTimestamp",
            "description": "The user who last modified this activity."
          },
          "ModifiedComment": {
            "description": "Comment about why the activity was modified when for example error marking the activity.",
            "type": "string"
          },
          "SignedBy": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivity.V1.HslUserTimestamp",
            "description": "The user who last signed this activity."
          },
          "ErrorMarkedBy": {
