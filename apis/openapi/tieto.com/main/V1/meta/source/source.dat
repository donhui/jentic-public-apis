            "type": "string",
            "format": "date-time"
          },
          {
            "name": "lt",
            "in": "query",
            "description": "If specified, gets resources modified before specified time (less than) in UTC.",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "limit",
            "in": "query",
            "description": "The limit controls the maximum number of resources that may be returned.",
