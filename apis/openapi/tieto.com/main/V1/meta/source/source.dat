      "WE.EC.Integration.Contracts.LifecareHslOrderServices.V4.LifecareHslOrderServicesRequest": {
        "required": [
          "domain",
          "key"
        ],
        "properties": {
          "orderId": {
            "description": "If specified, gets the resource with the id.",
            "type": "integer",
            "format": "int32"
          },
          "gt": {
            "description": "If specified, gets resources modified after specified time (greater than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with other search parameters except lt",
            "type": "string",
            "format": "date-time"
          },
          "lt": {
            "description": "If specified, gets resources modified before specified time (less than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with other search parameters except gt",
            "type": "string",
            "format": "date-time"
          },
          "limit": {
            "description": "The limit controls the maximum number of LHslOrderActivity items (in total) that may be returned.",
            "type": "integer",
            "format": "int32"
          },
          "offset": {
            "description": "The offset controls how many LHslOrderActivity items that should be skipped before the read starts.",
            "type": "integer",
            "format": "int32"
          },
          "startDate": {
            "description": "If specified, fetches HSL order services that in local time are starting at or after this date or have started before this date but overlaps into the search range. Won't include HSL order services that has a startdate that is null.\r\nRequired format: yyyy-MM-dd",
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "description": "If specified, fetches HSL order services that in local time have ended at or before this date or that have started before this date but overlaps this searchdate. Won't include HSL order services that has a startdate that is null.\r\nRequired format: yyyy-MM-dd",
            "type": "string",
            "format": "date-time"
          },
          "domain": {
            "description": "The domain ID.",
            "type": "string"
          },
          "key": {
            "description": "The API key.",
            "type": "string"
          }
        },
        "xml": {
          "name": "LifecareHslOrderServicesRequest"
        },
        "type": "object"
      },
      "WE.EC.Integration.Contracts.LifecareHslOrder.V1.LifecareHslOrdersRequest": {
        "required": [
          "domain",
          "key"
        ],
        "properties": {
          "id": {
            "description": "Id of the HSL order.",
            "type": "integer",
            "format": "int32"
          },
          "gt": {
            "description": "If specified, gets resources modified after specified time (greater than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with other search parameters except lt",
            "type": "string",
            "format": "date-time"
          },
          "lt": {
            "description": "If specified, gets resources modified before specified time (less than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with other search parameters except gt",
            "type": "string",
            "format": "date-time"
          },
          "patientPersonId": {
            "description": "Person Id of the patient for which HSL orders should be fetched.\r\nRequired format: YYYYMMDDXXXX.\r\nCan't be combined with \"gt\" or \"lt\" parameters.",
            "type": "string"
          },
          "journalId": {
            "description": "Id of the journal for which HSL orders should be fetched. \r\nCan't be combined with \"gt\" or \"lt\" parameters.",
            "type": "integer",
            "format": "int32"
          },
          "receiverProviderUnitId": {
            "description": "Id of the receiving provider unit for which HSL orders should be fetched. \r\nCan't be combined with \"gt\" or \"lt\" parameters.",
            "type": "integer",
            "format": "int32"
          },
          "patientOrganizationId": {
            "description": "Id of the patient journal organization for which HSL orders should be fetched. \r\nCan't be combined with \"gt\" or \"lt\" parameters.",
            "type": "integer",
            "format": "int32"
          },
          "patientOrganizationUnitId": {
            "description": "Id of the patient journal organization unit for which HSL orders should be fetched. \r\nCan't be combined with \"gt\" or \"lt\" parameters.",
            "type": "string"
          },
          "startDate": {
            "description": "Fetches orders with an end date that is bigger than or equal to this parameter.\r\nRequired format: yyyy-MM-dd.\r\nCan't be combined with \"gt\" or \"lt\" parameters.",
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "description": "Fetches orders with a start date that is less than or equal to this parameter.\r\nRequired format: yyyy-MM-dd.\r\nCan't be combined with \"gt\" or \"lt\" parameters.",
            "type": "string",
            "format": "date-time"
          },
          "limit": {
            "description": "The limit controls the maximum number of resources that may be returned.",
            "type": "integer",
            "format": "int32"
          },
          "offset": {
            "description": "The offset controls the starting point within the returned resources. Default value = 0.",
            "type": "integer",
            "format": "int32"
          },
          "domain": {
            "description": "The domain ID.",
            "type": "string"
          },
          "key": {
            "description": "The API key.",
            "type": "string"
          }
        },
        "xml": {
          "name": "LifecareHslOrdersRequest"
        },
        "type": "object"
      },
