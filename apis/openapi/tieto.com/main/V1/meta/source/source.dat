      "WE.EC.Integration.Contracts.PlannedWorkshift.V1.PlannedWorkshiftsBatchRequest": {
        "description": "When requesting data fill this out as described to get all planned workshifts as they are published in planning.",
        "required": [
          "domain",
          "key"
        ],
        "properties": {
          "ModifiedTime": {
            "description": "If this is your first request set this to the oldest modification time (in UTC) of work shifts you are interested in.\r\nOtherwise set it to the ModifiedTime of the last fetched work shift you got from this service.\r\nNote! The time must be in UTC.",
            "type": "string",
            "format": "date-time"
          },
          "LastSeenWorkshiftId": {
            "description": "If this is your first request, leave this blank.\r\nOtherwise set it to the Id of the last fetched work shift you got from this service.",
            "type": "string"
          },
          "MaxCount": {
            "description": "Maximum number of work shifts to fetch.",
            "type": "integer",
            "format": "int32"
          },
          "domain": {
            "description": "The domain ID.",
            "type": "string"
          },
          "key": {
            "description": "The API key.",
            "type": "string"
          }
        },
        "xml": {
          "name": "PlannedWorkshiftsBatchRequest"
        },
        "type": "object"
      },
      "WE.EC.Integration.Contracts.PlannedWorkshift.V1.PlannedWorkshift": {
        "description": "A work shift.",
        "properties": {
          "Id": {
            "description": "A persistent Id of this work shift.",
            "type": "string"
          },
          "ModificationTime": {
            "description": "When in time (in UTC) this work shift was last modified (or published/unpublished) in planning.\r\nNote! The time is in UTC.",
            "type": "string",
            "format": "date-time"
          },
          "PlanningUnitId": {
            "description": "The Id of the planning unit this work shift belongs to.",
            "type": "string"
          },
          "StartTime": {
            "description": "When this work shift starts.",
            "type": "string",
            "format": "date-time"
          },
          "EndTime": {
            "description": "When this work shift ends.",
            "type": "string",
            "format": "date-time"
          },
          "TravelTimeHome": {
            "description": "The estimated travel time from the last activity to the end position of this work shift.",
            "type": "string"
          },
          "StartPosition": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.PlannedWorkshift.V1.Position",
            "description": "The starting position (address, coordinate)."
          },
          "EndPosition": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.PlannedWorkshift.V1.Position",
            "description": "The ending position (address, coordinate)."
          },
          "TypeOfTransportation": {
            "description": "Starting means of transportation.",
            "type": "string",
            "enum": [
              "Unknown",
              "Car",
              "Bicycle",
              "ElectricBicycle",
              "Walking"
            ]
          },
          "PlannedActivities": {
            "description": "The activities (visits, breaks) of this work shift.",
