              "$ref": "#/definitions/WE.ElderlyCare.HSL.API.Contracts.V2.LHslOrder.ActivityDelegationTask"
            },
            "xml": {
              "name": "ActivityDelegationTask",
              "wrapped": true
            },
            "type": "array"
          },
          "TimeWindowMode": {
            "description": "The kind of time window required to moving this activity",
            "type": "string",
            "enum": [
              "AsPlanned",
              "WithinTheSpecifiedTimeWindow"
            ]
          },
          "TimeWindow": {
            "$ref": "#/definitions/WE.ElderlyCare.HSL.API.Contracts.V2.LHslOrder.ActivityTimeWindow",
            "description": "Activity Time Window range"
          },
          "IsJournalClosed": {
            "description": "Is activity's journal ended",
            "type": "boolean"
          },
          "IsCareProcessClosed": {
            "description": "Is activity's care process ended",
            "type": "boolean"
          },
          "LHslOrderActivities": {
            "description": "The Lifecare HSL order activity information included in the Lifecare HSL order.",
