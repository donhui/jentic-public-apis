          },
          "KvaCodes": {
            "description": "The KVA codes associated with the activity.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "PlannedDates": {
            "description": "The planned dates for the activity.",
            "items": {
              "type": "string",
              "format": "date-time"
            },
            "type": "array"
          },
          "PlannedPerformBy": {
            "description": "The planned performers for the activity.",
            "items": {
              "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityOccurrence.V1.Profession"
            },
            "xml": {
              "name": "Profession",
              "wrapped": true
            },
            "type": "array"
          },
          "JournalOrganizationUnit": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityOccurrence.V1.OrganizationUnit",
            "description": "The journal organization unit for the activity."
          },
          "PerformAtProviderUnit": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityOccurrence.V1.ProviderUnit",
            "description": "The provider unit where the activity will be performed."
          },
          "PerformAtExternalUnit": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityOccurrence.V1.ExternalUnit",
            "description": "The external unit where the activity will be performed."
          }
        },
        "xml": {
          "name": "Activity"
        },
        "type": "object"
      },
