          },
          "PrescriptionCause": {
            "description": "The prescription cause of the activity.",
            "type": "string"
          },
          "KvaCode": {
            "$ref": "#/definitions/WE.ElderlyCare.HSL.API.Contracts.V2.LHslOrder.KvaCode",
