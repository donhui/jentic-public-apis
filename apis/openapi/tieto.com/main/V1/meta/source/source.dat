      "WE.EC.Integration.Contracts.LifecareHslOrderServices.V3.LifecareHslOrderServicesRequest": {
        "required": [
          "domain",
          "key"
        ],
        "properties": {
          "orderId": {
            "description": "If specified, gets the resource with the id.",
            "type": "integer",
            "format": "int32"
          },
          "gt": {
            "description": "If specified, gets resources modified after specified time (greater than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with other search parameters except lt",
            "type": "string",
            "format": "date-time"
          },
          "lt": {
            "description": "If specified, gets resources modified before specified time (less than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with other search parameters except gt",
            "type": "string",
            "format": "date-time"
          },
          "limit": {
            "description": "The limit controls the maximum number of resources that may be returned.",
            "type": "integer",
            "format": "int32"
          },
          "offset": {
            "description": "The offset controls the starting point within the returned resources.",
            "type": "integer",
            "format": "int32"
          },
          "startDate": {
            "description": "If specified, fetches HSL order services that in local time are starting at or after this date or have started before this date but overlaps into the search range. Won't include HSL order services that has a startdate that is null.\r\nRequired format: yyyy-MM-dd",
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "description": "If specified, fetches HSL order services that in local time have ended at or before this date or that have started before this date but overlaps this searchdate. Won't include HSL order services that has a startdate that is null.\r\nRequired format: yyyy-MM-dd",
            "type": "string",
            "format": "date-time"
          },
          "domain": {
            "description": "The domain ID.",
            "type": "string"
          },
          "key": {
            "description": "The API key.",
            "type": "string"
          }
