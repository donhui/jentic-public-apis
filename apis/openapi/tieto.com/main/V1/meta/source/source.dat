            "type": "integer",
            "format": "int32"
          },
          {
            "name": "offset",
            "in": "query",
            "description": "The offset controls the starting point within the returned resources.",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "domain",
            "in": "query",
            "description": "The domain ID.",
            "required": true,
            "type": "string"
          },
          {
            "name": "key",
            "in": "query",
            "description": "The API key.",
            "required": true,
            "type": "string"
          }
