      "WE.EC.Integration.Contracts.ReportedVisit.V1.ReportedVisit": {
        "description": "Reported visit.",
        "required": [
          "ExternalId",
          "ClientPersonId",
          "PersonnelPersonId",
          "PersonnelUserId",
          "ExecutionId",
          "StartTime",
          "Status",
          "IsDoubleManning",
          "StartQuittanceType",
          "EndQuittanceType",
          "ReportingSystem"
        ],
        "properties": {
          "Id": {
            "description": "[Searchable] Unique ID.",
            "type": "integer",
            "format": "int32"
          },
          "ExternalId": {
            "description": "[Searchable] External system unique ID.",
            "type": "string"
          },
          "ReportedWorkshiftId": {
            "description": "[Searchable] Id for the reported workshift, if workshift is used.",
            "type": "string"
          },
          "ClientPersonId": {
            "description": "[Searchable: YYYYMMDDXXXX] Client's person ID, on the format 'YYYYMMDDXXXX'.",
            "type": "string"
          },
          "ServiceCategory": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.Common.V1.CodeText",
            "description": "Service category."
          },
          "Law": {
            "description": "[Searchable] What law the visit is connected to.",
            "type": "string",
            "enum": [
              "FTJ",
              "HSL",
              "LASS",
              "LSS",
              "RFTJ",
              "SFB",
              "SoL"
            ]
          },
          "PersonnelPersonId": {
            "description": "[Searchable: YYYYMMDDXXXX] Personnel's person ID, on the format 'YYYYMMDDXXXX'.",
            "type": "string"
          },
          "PersonnelUserId": {
            "description": "The user ID of the personnel.",
            "type": "string"
          },
          "ExecutionId": {
            "description": "Execution ID.",
            "type": "integer",
            "format": "int32"
          },
          "ProviderUnitId": {
            "description": "[Searchable] Provider unit ID.",
            "type": "integer",
            "format": "int32"
          },
          "StartTime": {
            "description": "Start date and time of the visit.",
            "type": "string",
            "format": "date-time"
          },
          "EndTime": {
            "description": "End date and time of the visit. Don't set if the visit is ongoing.",
            "type": "string",
            "format": "date-time"
          },
          "Status": {
            "description": "[Searchable] Status of the visit.",
            "type": "string",
            "enum": [
              "Started",
              "Completed",
              "Cancelled",
              "Declined",
              "CompletedAndChangedTime"
            ]
          },
          "OriginalStartTime": {
            "description": "The original start date and time (can differ from StartDate if someone have changed the time).",
            "type": "string",
            "format": "date-time"
          },
          "OriginalEndTime": {
            "description": "The original end date and time (can differ from EndDate if someone have changed the time).",
            "type": "string",
            "format": "date-time"
          },
          "LastUpdatedTime": {
            "description": "Last updated time.",
            "type": "string",
            "format": "date-time"
          },
          "IsDoubleManning": {
            "description": "If the visit have been performed by more than one personnel.",
            "type": "boolean"
          },
          "PlannedVisitId": {
            "description": "Planned visit id.",
            "type": "string"
          },
          "PlannedWorkshiftId": {
            "description": "Planned workshift id.",
            "type": "string"
          },
          "Services": {
            "description": "List of services.",
            "items": {
              "$ref": "#/definitions/WE.EC.Integration.Contracts.ReportedVisit.V1.ReportedService"
            },
            "xml": {
              "name": "ReportedService",
              "wrapped": true
            },
            "type": "array"
          },
          "StartQuittanceType": {
            "description": "Quittance type for start of visit.",
            "type": "string",
            "enum": [
              "None",
              "Nfc",
              "Bluetooth",
              "Lock"
            ]
          },
          "EndQuittanceType": {
            "description": "Quittance type for end of visit.",
            "type": "string",
            "enum": [
              "None",
              "Nfc",
              "Bluetooth",
              "Lock"
            ]
          },
          "StartQuittanceId": {
            "description": "ID of the quittance type for start of visit.",
            "type": "string"
          },
          "EndQuittanceId": {
            "description": "ID of the quittance type for end of visit.",
            "type": "string"
          },
          "DeviceId": {
            "description": "The device used when creating the visit (e.g. IMEI-number on a phone).",
            "type": "string"
          },
          "CancelledReason": {
            "description": "Cancelled visit reason (the reason for the cancellation).",
            "type": "string"
          },
          "CancelledMinutes": {
            "description": "Cancelled visit minutes (the number of minutes the visit should have been).",
            "type": "integer",
            "format": "int32"
          },
          "ReportingSystem": {
            "description": "Name of the reporting system.",
            "type": "string"
          },
          "Approved": {
            "description": "[Searchable] True if this has been approved in external system.",
            "type": "boolean"
          },
          "Deleted": {
            "description": "If the entity is deleted (only used in delta queries).",
            "type": "boolean"
          }
        },
        "xml": {
          "name": "ReportedVisit"
        },
        "type": "object"
      },
