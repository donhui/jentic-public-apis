      "WE.EC.Integration.Contracts.LifecareHslJournal.V1.LifecareHslJournalRequest": {
        "required": [
          "domain",
          "key"
        ],
        "properties": {
          "startDate": {
            "description": "Fetches journals with an end date that is bigger than or equal to this parameter.\r\nRequired format: yyyy-MM-dd.\r\nCan't be combined with \"gt\" or \"lt\" parameters.",
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "description": "Fetches journals with a start date that is less than or equal to this parameter.\r\nRequired format: yyyy-MM-dd.\r\nCan't be combined with \"gt\" or \"lt\" parameters.",
            "type": "string",
            "format": "date-time"
          },
          "limit": {
            "description": "The limit controls the maximum number of resources that may be returned.",
            "type": "integer",
            "format": "int32"
          },
          "offset": {
            "description": "The offset controls the starting point within the returned resources. Default value = 0.",
            "type": "integer",
            "format": "int32"
          },
          "gt": {
            "description": "If specified, gets resources modified after specified time (greater than or equals).\r\nRequired format: yyyy-MM-dd.\r\nCan't be combined with other search parameters except lt",
            "type": "string",
            "format": "date-time"
          },
          "lt": {
            "description": "If specified, gets resources modified before specified time (less than or equals).\r\nRequired format: yyyy-MM-dd.\r\nCan't be combined with other search parameters except gt",
            "type": "string",
            "format": "date-time"
          },
          "domain": {
            "description": "The domain ID.",
            "type": "string"
          },
          "key": {
            "description": "The API key.",
            "type": "string"
          }
        },
        "xml": {
          "name": "LifecareHslJournalRequest"
        },
        "type": "object"
      },
