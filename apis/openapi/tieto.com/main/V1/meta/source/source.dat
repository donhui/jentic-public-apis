          },
          "Description": {
            "description": "Activity description.",
            "type": "string"
          },
          "Duration": {
            "description": "The duration of the activity in HH.mm format. If no duration is specified this is set to empty string.",
            "type": "string"
          },
          "Nurse": {
            "description": "If this activity should be performed by nurses.",
            "type": "boolean"
          },
          "Physiotherapist": {
            "description": "If this activity should be performed by physiotherapists.",
            "type": "boolean"
          },
          "OccupationalTherapist": {
            "description": "If this activity should be performed by occupational therapists.",
            "type": "boolean"
          },
          "OtherProfession": {
            "description": "If this activity should be performed by other professions.",
            "type": "boolean"
          },
          "Dietician": {
            "description": "If this activity should be performed by dieticians.",
            "type": "boolean"
          },
          "Curator": {
            "description": "If this activity should be performed by curators.",
            "type": "boolean"
          },
          "SpeechTherapist": {
            "description": "If this activity should be performed by speech therapists.",
            "type": "boolean"
          },
          "Psychologist": {
            "description": "If this activity should be performed by speech psychologists.",
            "type": "boolean"
          },
          "OtherHealthcareProfessionals": {
            "description": "If this activity should be performed by other healthcare professionals.",
            "type": "boolean"
          },
          "OtherPersonnel": {
            "description": "If this activity should be performed by care personnel.",
            "type": "boolean"
          },
          "AssistantNurse": {
            "description": "If this activity should be performed by assistant nurse.",
            "type": "boolean"
          },
          "TimeSpecified": {
            "description": "Indicates if time is specified for this activity. If not timespecified, it is handled as an all-day activity.",
            "type": "boolean"
          },
          "CreatedBy": {
            "$ref": "#/definitions/WE.ElderlyCare.HSL.API.Contracts.V2.LHslOrder.UserTimestamp",
            "description": "The person who created this entry originally."
          },
          "ModifiedBy": {
            "$ref": "#/definitions/WE.ElderlyCare.HSL.API.Contracts.V2.LHslOrder.UserTimestamp",
            "description": "The user who modified this entry originally."
          },
          "ModifiedComment": {
            "description": "Comment about why the activity was modified when for example error marking the activity.",
            "type": "string"
          },
          "SignedBy": {
            "$ref": "#/definitions/WE.ElderlyCare.HSL.API.Contracts.V2.LHslOrder.UserTimestamp",
            "description": "The user who signed this entry. If the activity"
          },
          "ErrorMarkedDateTime": {
            "description": "If the activity is error marked, then this field will contain the date and time in UTC of when it was error marked. If the activity is not error marked, then this field will be null.",
            "type": "string",
            "format": "date-time"
          },
          "ErrorMarkedByName": {
            "description": "If the activity is error marked, then this field will contain the name of the personnel that error marked the hsl order. If the hsl order is not erro marked, then this field will be null.",
            "type": "string"
          },
          "ErrorMarkedBySignature": {
            "description": "If the hsl order is error marked, then this field will contain the signature of the personnel that error marked the hsl order. If the hsl order is not error marked, then this field will be null.",
            "type": "string"
          },
          "ErrorMarkedByRole": {
            "description": "If the hsl order is error marked, then this field will contain the role (at the time of error marking) of the personnel that error marked the hsl order. If the hsl order is not error marked, then this field will be null.",
            "type": "string"
          },
          "Feedback": {
            "description": "This field can be filled with information about when the activity performer should contact the creator of the activity.",
            "type": "string"
          },
          "WhenDuringDay": {
            "description": "If the activity is not timespecified, a when during day could have been chosen and indicating when during the day that the activity should be performed. This contains the code text code value of the chosen 'When during day' value.",
            "type": "integer",
            "format": "int32"
          },
          "WhenDuringDayText": {
            "description": "If the activity is not timespecified, a when during day could have been chosen and indicating when during the day that the activity should be performed. This contains the name of the chosen 'When during day' value.",
            "type": "string"
          },
          "InactivatedDate": {
            "description": "If the activity is inactivated, this will contain the date and time in UTC format when the activity got inactivated. If the activity is not inactivated, then this property will be null.",
            "type": "string",
            "format": "date-time"
          },
          "InactivatedById": {
            "description": "If the activity is inactivated, this will contain the HSL user id of the user that inactivated the activity. If the activity is not inactivated, then this property will be 0",
            "type": "integer",
            "format": "int32"
          },
          "InactivatedSign": {
            "description": "If the activity is inactivated, this will contain the signature of the user that inactivated the activity. If the activity is not inactivated, then this property will be empty.",
            "type": "string"
          },
          "InactivatedName": {
            "description": "If the activity is inactivated, this will contain the name of the user that inactivated the activity. If the activity is not inactivated, then this property will be empty.",
            "type": "string"
          },
          "InactivatedByRole": {
            "description": "If the activity is inactivated, this will contain the role of the user at the moment the user inactivated the activity. If the activity is not inactivated, then this property will be empty.",
            "type": "string"
          },
          "ChangeSetId": {
            "description": "A history id holding together a version of an activity with its subentities.",
            "example": "00000000-0000-0000-0000-000000000000",
            "type": "string",
            "format": "uuid"
          },
          "IsMedication": {
            "description": "Is activity medication-related",
            "type": "boolean"
          },
          "DelegationMode": {
            "description": "The kind of delegation required to perform this activity",
            "type": "string",
            "enum": [
              "NotSpecified",
              "Provider",
              "Patient"
            ]
          },
          "Tasks": {
            "description": "A list of the tasks required to perform this activity",
            "items": {
              "$ref": "#/definitions/WE.ElderlyCare.HSL.API.Contracts.V2.LHslOrder.ActivityDelegationTask"
            },
            "xml": {
              "name": "ActivityDelegationTask",
              "wrapped": true
            },
            "type": "array"
          },
          "TimeWindowMode": {
            "description": "The kind of time window required to moving this activity",
            "type": "string",
            "enum": [
              "AsPlanned",
              "WithinTheSpecifiedTimeWindow"
            ]
          },
          "TimeWindow": {
            "$ref": "#/definitions/WE.ElderlyCare.HSL.API.Contracts.V2.LHslOrder.ActivityTimeWindow",
            "description": "Activity Time Window range"
          },
          "IsJournalClosed": {
            "description": "Is activity's journal ended",
            "type": "boolean"
          },
          "IsCareProcessClosed": {
            "description": "Is activity's care process ended",
            "type": "boolean"
          },
          "LHslOrderActivities": {
            "description": "The Lifecare HSL order activity information included in the Lifecare HSL order.",
            "items": {
              "$ref": "#/definitions/WE.ElderlyCare.HSL.API.Contracts.V2.LHslOrder.LHslOrderActivity"
            },
            "xml": {
              "name": "LHslOrderActivity",
              "wrapped": true
            },
            "type": "array"
          }
        },
        "xml": {
          "name": "LifecareHslOrderService"
        },
        "type": "object"
      },
