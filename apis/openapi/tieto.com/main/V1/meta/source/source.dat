    "/api/v1/lifecare_hsl_activity_occurrence": {
      "get": {
        "tags": [
          "LifecareHslActivityOccurrenceV1"
        ],
        "description": "Fetches activity occurrences information. Only includes the planned dates of the occurrences, not time. Occurrences that are part of HSL orders to provider will show provider unit information for the end of the search period. The same applies to journal organization information.\r\nThe API will max return 10000 planned dates in total, but API logic won't stop in middle of an activity occurrence series for the search period.\r\nMaxFetchedActivityId property from the response can be used to fetch next batch and fetch until not getting anything in the response for same date period.",
        "operationId": "LifecareHslActivityOccurrenceV1_GetHslActivityOccurrences",
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "description": "Start date of the search period.\r\nRequired format: yyyy-MM-dd",
            "required": true,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "endDate",
            "in": "query",
            "description": "End date of the search period. Not inclusive, so for example '2025-02-01' would search occurrences before this date. Search period can't be bigger than 31 days.\r\nRequired format: yyyy-MM-dd",
            "required": true,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "fetchFromActivityId",
            "in": "query",
            "description": "If specified, fetches batch with activity id greater than this value.",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "domain",
            "in": "query",
            "description": "The domain ID.",
            "required": true,
            "type": "string"
          },
          {
            "name": "key",
            "in": "query",
            "description": "The API key.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityOccurrence.V1.ActivityResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/lifecare_hsl_activity_performed": {
      "get": {
        "tags": [
          "LifecareHslActivityPerformedV1"
        ],
        "description": "Get list of Lifecare HSL activities performed.",
        "operationId": "LifecareHslActivityPerformedV1_GetHslActivitesPerformed",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "The limit controls the maximum number of activity performed items (in total) that may be returned. Default is 10000.",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "offset",
            "in": "query",
            "description": "The offset controls how many activity performed items that should be skipped before the read starts.",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "startDate",
            "in": "query",
            "description": "Start date of the search period. Fetches performed activity registrations with performed date at this date or later.\r\nRequired format: yyyy-MM-dd",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "endDate",
            "in": "query",
            "description": "End date of the search period. Fetches performed activity registrations with performed date at this date or earlier.\r\nRequired format: yyyy-MM-dd",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "gt",
            "in": "query",
            "description": "If specified, gets resources modified after specified time (greater than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with startDate, endDate or includeErrorMarked",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "lt",
            "in": "query",
            "description": "If specified, gets resources modified before specified time (less than or equals) in UTC.\r\nRequired format: yyyy-MM-ddTHH:mm:ss.\r\nCan't be combined with startDate, endDate or includeErrorMarked",
            "required": false,
            "type": "string",
            "format": "date-time"
          },
          {
            "name": "includeErrorMarked",
            "in": "query",
            "description": "Controls if the response should include activity performed registrations that are error marked.",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "domain",
            "in": "query",
            "description": "The domain ID.",
            "required": true,
            "type": "string"
          },
          {
            "name": "key",
            "in": "query",
            "description": "The API key.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/definitions/WE.EC.Integration.Contracts.LifecareHslActivityPerformed.V1.ActivityPerformed"
                  },
                  "xml": {
                    "name": "ActivityPerformed",
                    "wrapped": true
                  },
                  "type": "array"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/lifecare_hsl_activity": {
      "get": {
        "tags": [
