              "$ref": "#/definitions/WE.EC.Integration.Contracts.PlannedWorkshift.V1.PlannedActivity"
            },
            "xml": {
              "name": "PlannedActivity",
              "wrapped": true
            },
            "type": "array"
          },
          "Personnel": {
            "$ref": "#/definitions/WE.EC.Integration.Contracts.PlannedWorkshift.V1.PlannedPersonnel",
            "description": "Who is to perform this work shift."
          },
          "IsRevoked": {
            "description": "If true, any previously exported work shift with the same Id has been revoked.",
            "type": "boolean"
          }
        },
        "xml": {
          "name": "PlannedWorkshift"
        },
        "type": "object"
      },
