{
  "openapi": "3.0.3",
  "info": {
    "title": "Illumina BaseSpace API",
    "version": "v1pre3",
    "description": "BaseSpace Sequence Hub REST API provides programmatic access to genomic sequencing data, runs, projects, samples, and files.",
    "x-jentic-source-url": "https://developer.basespace.illumina.com/docs/content/documentation/rest-api/v1-api-reference"
  },
  "servers": [
    {
      "url": "https://api.basespace.illumina.com/v1pre3"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    },
    {
      "AccessTokenHeader": []
    }
  ],
  "tags": [
    {"name": "Users"},
    {"name": "Runs"},
    {"name": "Projects"},
    {"name": "Samples"},
    {"name": "Files"},
    {"name": "AppResults"},
    {"name": "AppSessions"},
    {"name": "Genomes"},
    {"name": "OAuth"}
  ],
  "paths": {
    "/users/current": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Get current user",
        "tags": ["Users"],
        "responses": {
          "200": {"description": "Success"},
          "401": {"description": "Unauthorized"},
          "500": {"description": "Internal server error"}
        }
      }
    },
    "/users/current/runs": {
      "get": {
        "operationId": "listUserRuns",
