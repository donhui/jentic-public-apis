            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not found"},
          "500": {"description": "Internal server error"}
        }
      }
    },
