        "responses": {
          "200": {"description": "Success"},
          "401": {"description": "Unauthorized"},
          "500": {"description": "Internal server error"}
        }
      }
    },
    "/runs/{id}": {
      "get": {
        "operationId": "getRun",
        "summary": "Get run by ID",
        "tags": ["Runs"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {"description": "Success"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not found"},
          "500": {"description": "Internal server error"}
        }
      },
      "delete": {
        "operationId": "deleteRun",
        "summary": "Delete run",
        "tags": ["Runs"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
