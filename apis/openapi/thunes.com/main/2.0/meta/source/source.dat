{
  "openapi": "3.0.3",
  "info": {
    "title": "Thunes Money Transfer API",
    "version": "2.0",
    "description": "Thunes Money Transfer API v2 providing access to cross-border payment services including quotations, transactions, payer discovery, balance management, and reporting.",
    "x-jentic-source-url": "https://docs.thunes.com/money-transfer/v2/"
  },
  "servers": [
    {
      "url": "https://api.thunes.com/v2/money-transfer",
      "description": "Production"
    },
    {
      "url": "https://api-mt.pre.thunes.com/v2/money-transfer",
      "description": "Pre-production"
    }
  ],
  "paths": {
    "/ping": {
      "get": {
        "operationId": "ping",
        "summary": "Check API status",
        "tags": ["Connectivity"],
        "responses": {
          "200": { "description": "API is available" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/services": {
      "get": {
        "operationId": "listServices",
        "summary": "List available services",
        "tags": ["Discovery"],
        "parameters": [
          {
            "name": "country_iso_code",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by country ISO code"
          },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PerPage" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Service" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/payers": {
      "get": {
        "operationId": "listPayers",
        "summary": "List payers with filtering options",
        "tags": ["Discovery"],
        "parameters": [
          {
            "name": "country_iso_code",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "currency",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "service_id",
            "in": "query",
            "schema": { "type": "integer" }
          },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PerPage" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Payer" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/payers/{id}": {
      "get": {
        "operationId": "getPayer",
        "summary": "Get payer details",
        "tags": ["Discovery"],
        "parameters": [
          { "$ref": "#/components/parameters/PayerId" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Payer" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/payers/{id}/rates": {
      "get": {
        "operationId": "getPayerRates",
        "summary": "Retrieve payer rates",
        "tags": ["Discovery"],
        "parameters": [
          { "$ref": "#/components/parameters/PayerId" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Rate" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/countries": {
      "get": {
        "operationId": "listCountries",
        "summary": "List countries",
        "tags": ["Discovery"],
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PerPage" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Country" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lookups/BIC/{swiftBicCode}": {
      "get": {
        "operationId": "lookupBic",
        "summary": "BIC code lookup",
        "tags": ["Discovery"],
        "parameters": [
          {
            "name": "swiftBicCode",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "SWIFT BIC code"
          }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/balances": {
      "get": {
        "operationId": "listBalances",
        "summary": "Retrieve account balances",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Balance" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/balances/{balanceId}/movements": {
      "get": {
        "operationId": "getBalanceMovements",
        "summary": "Get balance movements",
        "tags": ["Account"],
        "parameters": [
          {
            "name": "balanceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "from_date",
            "in": "query",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "to_date",
            "in": "query",
            "schema": { "type": "string", "format": "date-time" }
          },
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PerPage" }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/balances/{balanceId}/topup_instructions": {
      "get": {
        "operationId": "getTopupInstructions",
        "summary": "Get topup instructions",
        "tags": ["Account"],
        "parameters": [
          {
            "name": "balanceId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/reports": {
      "get": {
        "operationId": "listReports",
        "summary": "List reports",
        "tags": ["Reports"],
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/PerPage" }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/reports/{id}": {
      "get": {
        "operationId": "getReport",
        "summary": "Get report details",
        "tags": ["Reports"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/reports/{id}/files": {
      "get": {
        "operationId": "listReportFiles",
        "summary": "List report files",
        "tags": ["Reports"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/reports/{reportId}/files/{id}": {
      "get": {
        "operationId": "getReportFile",
        "summary": "Get report file download URL",
        "tags": ["Reports"],
        "parameters": [
          {
            "name": "reportId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/payers/{id}/{transactionType}/credit-party-information": {
      "post": {
        "operationId": "getCreditPartyInformation",
        "summary": "Retrieve beneficiary information",
        "tags": ["Credit Parties"],
        "parameters": [
          { "$ref": "#/components/parameters/PayerId" },
          {
            "name": "transactionType",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "enum": ["C2C", "C2B", "B2C", "B2B"] }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreditPartyRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/payers/{id}/{transactionType}/credit-party-verification": {
      "post": {
        "operationId": "verifyCreditParty",
        "summary": "Verify account status",
        "tags": ["Credit Parties"],
        "parameters": [
          { "$ref": "#/components/parameters/PayerId" },
          {
            "name": "transactionType",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "enum": ["C2C", "C2B", "B2C", "B2B"] }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreditPartyRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/quotations": {
      "post": {
        "operationId": "createQuotation",
        "summary": "Create a quotation",
        "tags": ["Quotations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/QuotationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quotation created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Quotation" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/quotations/{id}": {
      "get": {
        "operationId": "getQuotation",
        "summary": "Retrieve quotation by ID",
        "tags": ["Quotations"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Quotation" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/quotations/ext-{externalId}": {
      "get": {
        "operationId": "getQuotationByExternalId",
        "summary": "Retrieve quotation by external ID",
        "tags": ["Quotations"],
        "parameters": [
          {
            "name": "externalId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Quotation" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/quotations/{id}/transactions": {
      "post": {
        "operationId": "createTransaction",
        "summary": "Create a transaction from quotation",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TransactionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/quotations/ext-{externalId}/transactions": {
      "post": {
        "operationId": "createTransactionByExternalId",
        "summary": "Create a transaction from external quotation ID",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "externalId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TransactionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions/{id}": {
      "get": {
        "operationId": "getTransaction",
        "summary": "Retrieve a transaction",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions/ext-{externalId}": {
      "get": {
        "operationId": "getTransactionByExternalId",
        "summary": "Retrieve transaction by external ID",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "externalId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions/{id}/confirm": {
      "post": {
        "operationId": "confirmTransaction",
        "summary": "Confirm a transaction",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction confirmed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions/ext-{externalId}/confirm": {
      "post": {
        "operationId": "confirmTransactionByExternalId",
        "summary": "Confirm transaction by external ID",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "externalId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction confirmed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions/{id}/cancel": {
      "post": {
        "operationId": "cancelTransaction",
        "summary": "Cancel a transaction",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions/ext-{externalId}/cancel": {
      "post": {
        "operationId": "cancelTransactionByExternalId",
        "summary": "Cancel transaction by external ID",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "externalId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions/{id}/attachments": {
      "get": {
        "operationId": "listTransactionAttachments",
        "summary": "List transaction attachments",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "addTransactionAttachment",
        "summary": "Add transaction attachment",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "type": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Attachment added" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions/ext-{externalId}/attachments": {
      "get": {
        "operationId": "listTransactionAttachmentsByExternalId",
        "summary": "List transaction attachments by external ID",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "externalId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Successful response" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "addTransactionAttachmentByExternalId",
        "summary": "Add attachment via external ID",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "externalId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "type": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Attachment added" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Page": {
        "name": "page",
        "in": "query",
        "schema": { "type": "integer", "default": 1 },
        "description": "Page number"
      },
      "PerPage": {
        "name": "per_page",
        "in": "query",
        "schema": { "type": "integer", "default": 50, "maximum": 100 },
        "description": "Results per page"
      },
      "PayerId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Payer ID"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "message": { "type": "string" },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      },
      "Service": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "country_iso_code": { "type": "string" },
          "currency": { "type": "string" }
        }
      },
      "Payer": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "country_iso_code": { "type": "string" },
          "currency": { "type": "string" },
          "service": { "$ref": "#/components/schemas/Service" },
          "precision": { "type": "integer" },
          "increment": { "type": "number" }
        }
      },
      "Rate": {
        "type": "object",
        "properties": {
          "source_currency": { "type": "string" },
          "destination_currency": { "type": "string" },
          "rate": { "type": "number" }
        }
      },
      "Country": {
        "type": "object",
        "properties": {
          "iso_code": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Balance": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "currency": { "type": "string" },
          "amount": { "type": "number" },
          "available_amount": { "type": "number" }
        }
      },
      "QuotationRequest": {
        "type": "object",
        "properties": {
          "external_id": { "type": "string" },
          "payer_id": { "type": "integer" },
          "mode": { "type": "string", "enum": ["SOURCE_AMOUNT", "DESTINATION_AMOUNT"] },
          "transaction_type": { "type": "string", "enum": ["C2C", "C2B", "B2C", "B2B"] },
          "source": { "$ref": "#/components/schemas/MoneyAmount" },
          "destination": { "$ref": "#/components/schemas/MoneyAmount" }
        },
        "required": ["payer_id", "mode", "transaction_type", "source", "destination"]
      },
      "Quotation": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "external_id": { "type": "string" },
          "payer_id": { "type": "integer" },
          "mode": { "type": "string" },
          "transaction_type": { "type": "string" },
          "source": { "$ref": "#/components/schemas/MoneyAmount" },
          "destination": { "$ref": "#/components/schemas/MoneyAmount" },
          "sent_amount": { "$ref": "#/components/schemas/MoneyAmount" },
          "fee": { "$ref": "#/components/schemas/MoneyAmount" },
          "wholesale_fx_rate": { "type": "number" },
          "creation_date": { "type": "string", "format": "date-time" },
          "expiration_date": { "type": "string", "format": "date-time" }
        }
      },
      "MoneyAmount": {
        "type": "object",
        "properties": {
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "country_iso_code": { "type": "string" }
        }
      },
      "TransactionRequest": {
        "type": "object",
        "properties": {
          "external_id": { "type": "string" },
          "credit_party_identifier": {
            "type": "object",
            "properties": {
              "msisdn": { "type": "string" },
              "bank_account_number": { "type": "string" },
              "swift_bic_code": { "type": "string" }
            }
          },
          "sender": { "$ref": "#/components/schemas/Party" },
          "beneficiary": { "$ref": "#/components/schemas/Party" },
          "purpose_of_remittance": { "type": "string" }
        },
        "required": ["credit_party_identifier"]
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "external_id": { "type": "string" },
          "status": { "type": "string" },
          "status_message": { "type": "string" },
          "payer_transaction_reference": { "type": "string" },
          "creation_date": { "type": "string", "format": "date-time" },
          "source": { "$ref": "#/components/schemas/MoneyAmount" },
          "destination": { "$ref": "#/components/schemas/MoneyAmount" },
          "sent_amount": { "$ref": "#/components/schemas/MoneyAmount" },
          "fee": { "$ref": "#/components/schemas/MoneyAmount" },
          "wholesale_fx_rate": { "type": "number" },
          "sender": { "$ref": "#/components/schemas/Party" },
          "beneficiary": { "$ref": "#/components/schemas/Party" }
        }
      },
      "Party": {
        "type": "object",
        "properties": {
          "firstname": { "type": "string" },
          "lastname": { "type": "string" },
          "nationality_country_iso_code": { "type": "string" },
          "date_of_birth": { "type": "string", "format": "date" },
          "country_of_birth_iso_code": { "type": "string" },
          "gender": { "type": "string", "enum": ["M", "F"] },
          "address": { "type": "string" },
          "city": { "type": "string" },
          "country_iso_code": { "type": "string" },
          "msisdn": { "type": "string" },
          "email": { "type": "string" },
          "id_type": { "type": "string" },
          "id_number": { "type": "string" }
        }
      },
      "CreditPartyRequest": {
        "type": "object",
        "properties": {
          "credit_party_identifier": {
            "type": "object",
            "properties": {
              "msisdn": { "type": "string" },
              "bank_account_number": { "type": "string" }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication using API key and API secret"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    }
  },
  "security": [
    { "basicAuth": [] }
  ]
}