{
  "openapi": "3.0.3",
  "info": {
    "title": "Faire API",
    "version": "1.0",
    "description": "Faire API for wholesale marketplace operations. Access and manage products, orders, brands, and retailer information. All requests require X-FAIRE-ACCESS-TOKEN header for authentication.",
    "x-jentic-source-url": "https://developers.faire.com/docs"
  },
  "servers": [
    {
      "url": "https://www.faire.com/api/v1",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "faireAccessToken": []
    }
  ],
  "tags": [
    {
      "name": "Products",
      "description": "Product catalog management"
    },
    {
      "name": "Product Options",
      "description": "Product variants and inventory management"
    },
    {
      "name": "Orders",
      "description": "Order processing and fulfillment"
    },
    {
      "name": "Brands",
      "description": "Brand profile information"
    },
    {
      "name": "Retailers",
      "description": "Retailer information"
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List products",
        "description": "Retrieve a list of products, ordered ascending by updated_at",
        "operationId": "listProducts",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 100
            },
            "description": "Number of products to return"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "List of products retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Product"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create product",
        "description": "Create a single inactive product",
        "operationId": "createProduct",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          }
        }
      }
    },
    "/products/{product_id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get product by ID",
        "description": "Fetch a single product by its identifier",
        "operationId": "getProductById",
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Product identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Product retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          },
          "404": {
            "description": "Product not found"
          }
        }
      },
      "patch": {
        "tags": ["Products"],
        "summary": "Update product",
        "description": "Modify an existing product",
        "operationId": "updateProduct",
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Product identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          },
          "404": {
            "description": "Product not found"
          }
        }
      }
    },
    "/products/batch": {
      "post": {
        "tags": ["Products"],
        "summary": "Create multiple products",
        "description": "Create a list of inactive products in batch",
        "operationId": "createProductsBatch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "products": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/ProductInput"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Products created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Product"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          }
        }
      }
    },
    "/products/categories": {
      "get": {
        "tags": ["Products"],
        "summary": "List product categories (deprecated)",
        "description": "Retrieve product category tree",
        "operationId": "listProductCategories",
        "deprecated": true,
        "responses": {
          "200": {
            "description": "Category tree retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "categories": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Category"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          }
        }
      }
    },
    "/products/types": {
      "get": {
        "tags": ["Products"],
        "summary": "List taxonomy types",
        "description": "Retrieve all taxonomy types for product classification",
        "operationId": "listProductTypes",
        "responses": {
          "200": {
            "description": "Taxonomy types retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "types": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/TaxonomyType"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          }
        }
      }
    },
    "/products/{product_id}/options": {
      "post": {
        "tags": ["Product Options"],
        "summary": "Add product option",
        "description": "Add a new variant to an existing product",
        "operationId": "addProductOption",
        "parameters": [
          {
            "name": "product_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Product identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductOptionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product option added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductOption"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          },
          "404": {
            "description": "Product not found"
          }
        }
      }
    },
    "/products/options/{option_id}": {
      "patch": {
        "tags": ["Product Options"],
        "summary": "Update product option",
        "description": "Modify a product variant",
        "operationId": "updateProductOption",
        "parameters": [
          {
            "name": "option_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Product option identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductOptionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product option updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductOption"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          },
          "404": {
            "description": "Product option not found"
          }
        }
      }
    },
    "/products/options/inventory-levels": {
      "patch": {
        "tags": ["Product Options"],
        "summary": "Update inventory levels",
        "description": "Update inventory levels of multiple options at once",
        "operationId": "updateInventoryLevels",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "inventory_levels": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "option_id": {
                          "type": "string"
                        },
                        "available_quantity": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inventory levels updated successfully"
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          }
        }
      }
    },
    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "List orders",
        "description": "Retrieve a list of orders, ordered ascending by updated_at",
        "operationId": "listOrders",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 100
            },
            "description": "Number of orders to return"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination"
          },
          {
            "name": "state",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["NEW", "PROCESSING", "SHIPPED", "DELIVERED", "CANCELLED"]
            },
            "description": "Filter by order state"
          }
        ],
        "responses": {
          "200": {
            "description": "List of orders retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orders": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Order"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          }
        }
      }
    },
    "/orders/{order_id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order by ID",
        "description": "Retrieve a specific order",
        "operationId": "getOrderById",
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Order identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Order retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/orders/{order_id}/processing": {
      "put": {
        "tags": ["Orders"],
        "summary": "Accept order",
        "description": "Accept an order and transition to PROCESSING state",
        "operationId": "acceptOrder",
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Order identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Order accepted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/orders/{order_id}/shipments": {
      "post": {
        "tags": ["Orders"],
        "summary": "Add shipments",
        "description": "Add shipments to an order",
        "operationId": "addOrderShipments",
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Order identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "shipments": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/ShipmentInput"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Shipments added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/orders/{order_id}/items/availability": {
      "post": {
        "tags": ["Orders"],
        "summary": "Update item availability",
        "description": "Mark items as backordered or discontinued",
        "operationId": "updateOrderItemAvailability",
        "parameters": [
          {
            "name": "order_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Order identifier"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "item_id": {
                          "type": "string"
                        },
                        "availability_status": {
                          "type": "string",
                          "enum": ["available", "backordered", "discontinued"]
                        },
                        "expected_date": {
                          "type": "string",
                          "format": "date"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item availability updated successfully"
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/brands/profile": {
      "get": {
        "tags": ["Brands"],
        "summary": "Get brand profile",
        "description": "Retrieve information about the brand associated with the current session",
        "operationId": "getBrandProfile",
        "responses": {
          "200": {
            "description": "Brand profile retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Brand"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          }
        }
      }
    },
    "/retailers/public/{retailer_id}": {
      "get": {
        "tags": ["Retailers"],
        "summary": "Get retailer by ID",
        "description": "Retrieve retailer information by identifier",
        "operationId": "getRetailerById",
        "parameters": [
          {
            "name": "retailer_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Retailer identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Retailer information retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Retailer"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token"
          },
          "404": {
            "description": "Retailer not found"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "faireAccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-FAIRE-ACCESS-TOKEN",
        "description": "Faire API access token obtained from the Faire dashboard"
      }
    },
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Product identifier"
          },
          "brand_id": {
            "type": "string",
            "description": "Brand identifier"
          },
          "name": {
            "type": "string",
            "description": "Product name"
          },
          "description": {
            "type": "string",
            "description": "Product description"
          },
          "active": {
            "type": "boolean",
            "description": "Whether the product is active"
          },
          "wholesale_price_cents": {
            "type": "integer",
            "description": "Wholesale price in cents"
          },
          "retail_price_cents": {
            "type": "integer",
            "description": "Suggested retail price in cents"
          },
          "taxonomy_type": {
            "type": "string",
            "description": "Product taxonomy type"
          },
          "minimum_order_quantity": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProductInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "wholesale_price_cents": {
            "type": "integer"
          },
          "retail_price_cents": {
            "type": "integer"
          },
          "taxonomy_type": {
            "type": "string"
          },
          "minimum_order_quantity": {
            "type": "integer"
          }
        }
      },
      "ProductOption": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "product_id": {
            "type": "string"
          },
          "sku": {
            "type": "string"
          },
          "size": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "available_quantity": {
            "type": "integer"
          },
          "backordered": {
            "type": "boolean"
          }
        }
      },
      "ProductOptionInput": {
        "type": "object",
        "properties": {
          "sku": {
            "type": "string"
          },
          "size": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "available_quantity": {
            "type": "integer"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "parent_id": {
            "type": "string"
          }
        }
      },
      "TaxonomyType": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "order_number": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": ["NEW", "PROCESSING", "SHIPPED", "DELIVERED", "CANCELLED"]
          },
          "retailer_id": {
            "type": "string"
          },
          "brand_id": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItem"
            }
          },
          "total_cents": {
            "type": "integer"
          },
          "shipments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Shipment"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "product_id": {
            "type": "string"
          },
          "product_option_id": {
            "type": "string"
          },
          "quantity": {
            "type": "integer"
          },
          "price_cents": {
            "type": "integer"
          },
          "availability_status": {
            "type": "string",
            "enum": ["available", "backordered", "discontinued"]
          }
        }
      },
      "Shipment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "tracking_number": {
            "type": "string"
          },
          "carrier": {
            "type": "string"
          },
          "shipped_at": {
            "type": "string",
            "format": "date-time"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "order_item_id": {
                  "type": "string"
                },
                "quantity": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "ShipmentInput": {
        "type": "object",
        "required": ["tracking_number", "carrier", "items"],
        "properties": {
          "tracking_number": {
            "type": "string"
          },
          "carrier": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "order_item_id": {
                  "type": "string"
                },
                "quantity": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "Brand": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "website_url": {
            "type": "string"
          },
          "minimum_order_dollars": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Retailer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      }
    }
  }
}
