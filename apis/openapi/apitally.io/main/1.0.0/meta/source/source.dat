{
  "openapi": "3.0.3",
  "info": {
    "title": "Apitally API",
    "description": "Programmatically access request logs and traffic metrics for your apps monitored by Apitally.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.apitally.io/api-reference"
  },
  "servers": [
    {
      "url": "https://api.apitally.io/v1",
      "description": "Apitally API"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/apps": {
      "get": {
        "operationId": "listApps",
        "summary": "List Apps",
        "description": "Retrieve all apps in your team.",
        "tags": ["Apps"],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListAppsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/apps/{app_id}/consumers": {
      "get": {
        "operationId": "listConsumers",
        "summary": "List Consumers",
        "description": "Retrieve all consumers for an app.",
        "tags": ["Consumers"],
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "required": true,
            "description": "App ID",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "requests_since",
            "in": "query",
            "required": false,
            "description": "Filter to consumers that have made requests since the given date and time in ISO 8601 format.",
            "schema": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            },
            "example": "2025-05-14T00:00:00Z"
          },
          {
            "name": "next_token",
            "in": "query",
            "required": false,
            "description": "Token to fetch the next page of consumers, as returned by a previous request.",
            "schema": {
              "type": "string",
              "maxLength": 1024,
              "nullable": true
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of consumers to return.",
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListConsumersResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/apps/{app_id}/endpoints": {
      "get": {
        "operationId": "listEndpoints",
        "summary": "List Endpoints",
        "description": "List API endpoints for an app. Ordered by path and method.",
        "tags": ["Endpoints"],
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "required": true,
            "description": "App ID",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "app_env_id",
            "in": "query",
            "required": false,
            "description": "Filter to environment ID, if provided.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "nullable": true
            }
          },
          {
            "name": "method",
            "in": "query",
            "required": false,
            "description": "Filter to HTTP method(s), comma-separated.",
            "schema": {
              "type": "string",
              "maxLength": 64,
              "nullable": true
            },
            "example": "GET,POST"
          },
          {
            "name": "path",
            "in": "query",
            "required": false,
            "description": "Filter to path pattern, supports wildcards (*).",
            "schema": {
              "type": "string",
              "maxLength": 1024,
              "nullable": true
            },
            "example": "/api/v1/*"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListEndpointsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/apps/{app_id}/request-logs": {
      "get": {
        "operationId": "getRequestLogs",
        "summary": "Get Request Logs",
        "description": "Get request log data for an app. With pagination. Requests to endpoints that have been excluded in the dashboard are excluded here as well.",
        "tags": ["Request Logs"],
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "required": true,
            "description": "App ID",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "app_env_id",
            "in": "query",
            "required": false,
            "description": "Filter to environment ID, if provided.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "nullable": true
            }
          },
          {
            "name": "consumer_id",
            "in": "query",
            "required": false,
            "description": "Filter to consumer ID, if provided.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "nullable": true
            }
          },
          {
            "name": "method",
            "in": "query",
            "required": false,
            "description": "Filter to HTTP method(s), comma-separated.",
            "schema": {
              "type": "string",
              "maxLength": 64,
              "nullable": true
            },
            "example": "GET,POST"
          },
          {
            "name": "path",
            "in": "query",
            "required": false,
            "description": "Filter to path pattern, supports wildcards (*).",
            "schema": {
              "type": "string",
              "maxLength": 1024,
              "nullable": true
            },
            "example": "/api/v1/*"
          },
          {
            "name": "status_code",
            "in": "query",
            "required": false,
            "description": "Filter to HTTP status code(s), comma-separated. Can include code classes (e.g., '4xx').",
            "schema": {
              "type": "string",
              "maxLength": 128,
              "pattern": "^(?:\\d{3}|\\dxx)(?:,(?:\\d{3}|\\dxx))*$",
              "nullable": true
            },
            "example": "2xx,400"
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Start date and time in ISO 8601 format. Defaults to 24 hours ago.",
            "schema": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            },
            "example": "2025-05-14T00:00:00Z"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "description": "End date and time in ISO 8601 format. Defaults to now.",
            "schema": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            },
            "example": "2025-05-15T00:00:00Z"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of records to return per page.",
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "next_token",
            "in": "query",
            "required": false,
            "description": "Token to fetch the next page of records, as returned by a previous request.",
            "schema": {
              "type": "string",
              "maxLength": 1024,
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListRequestLogsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/apps/{app_id}/request-logs/{request_uuid}": {
      "get": {
        "operationId": "getRequestDetails",
        "summary": "Get Request Details",
        "description": "Get detailed information about a specific request, including headers, body, application logs, and spans.",
        "tags": ["Request Logs"],
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "required": true,
            "description": "App ID",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "request_uuid",
            "in": "path",
            "required": true,
            "description": "Request UUID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/apps/{app_id}/traffic": {
      "get": {
        "operationId": "getTraffic",
        "summary": "Get Traffic",
        "description": "Get API traffic data for an app. Grouped by hour or by day. With pagination. Traffic to endpoints that have been excluded in the dashboard is excluded here as well.",
        "tags": ["Traffic"],
        "parameters": [
          {
            "name": "app_id",
            "in": "path",
            "required": true,
            "description": "App ID",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "app_env_id",
            "in": "query",
            "required": false,
            "description": "Filter to environment ID, if provided.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "nullable": true
            }
          },
          {
            "name": "consumer_id",
            "in": "query",
            "required": false,
            "description": "Filter to consumer ID, if provided.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "nullable": true
            }
          },
          {
            "name": "start",
            "in": "query",
            "required": false,
            "description": "Start date and time in ISO 8601 format. Defaults to 24 hours ago if intervals is 'hours', or 30 days ago if intervals is 'days'. Will be rounded down to the beginning of the interval.",
            "schema": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            },
            "example": "2025-05-14T00:00:00Z"
          },
          {
            "name": "end",
            "in": "query",
            "required": false,
            "description": "End date and time in ISO 8601 format. Defaults to now.",
            "schema": {
              "type": "string",
              "format": "date-time",
              "nullable": true
            },
            "example": "2025-05-15T00:00:00Z"
          },
          {
            "name": "intervals",
            "in": "query",
            "required": false,
            "description": "Whether to group by day or by hour.",
            "schema": {
              "type": "string",
              "enum": ["hours", "days"],
              "default": "hours"
            }
          },
          {
            "name": "timezone",
            "in": "query",
            "required": false,
            "description": "Timezone to use for intervals and to interpret start and end if given without offset. Defaults to UTC.",
            "schema": {
              "type": "string",
              "nullable": true
            },
            "example": "America/New_York"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of records to return per page.",
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1,
              "maximum": 1000
            }
          },
          {
            "name": "next_token",
            "in": "query",
            "required": false,
            "description": "Token to fetch the next page of records, as returned by a previous request.",
            "schema": {
              "type": "string",
              "maxLength": 1024,
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListTrafficResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Api-Key",
        "description": "API key for authentication. Manage keys in the Apitally dashboard under Settings > API keys."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "AppEnv": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Environment ID"
          },
          "name": {
            "type": "string",
            "description": "Environment name"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "last_sync_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last sync timestamp"
          }
        },
        "required": ["id", "name", "created_at", "last_sync_at"]
      },
      "AppItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "App ID"
          },
          "name": {
            "type": "string",
            "description": "App name"
          },
          "framework": {
            "type": "string",
            "description": "Framework used by the app"
          },
          "client_id": {
            "type": "string",
            "format": "uuid",
            "description": "Client identifier"
          },
          "envs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AppEnv"
            },
            "description": "List of environments"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          }
        },
        "required": ["id", "name", "framework", "client_id", "envs", "created_at"]
      },
      "ListAppsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AppItem"
            },
            "description": "List of apps"
          }
        },
        "required": ["data"]
      },
      "ConsumerGroup": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Group ID"
          },
          "name": {
            "type": "string",
            "description": "Group name"
          }
        },
        "required": ["id", "name"]
      },
      "ConsumerItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Consumer ID"
          },
          "identifier": {
            "type": "string",
            "description": "Consumer identifier"
          },
          "name": {
            "type": "string",
            "description": "Consumer name"
          },
          "group": {
            "$ref": "#/components/schemas/ConsumerGroup"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "last_request_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last request timestamp"
          }
        },
        "required": ["id", "identifier", "name", "created_at", "last_request_at"]
      },
      "ListConsumersResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConsumerItem"
            },
            "description": "List of consumers"
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more consumers to list"
          },
          "next_token": {
            "type": "string",
            "nullable": true,
            "description": "Token to fetch the next page of consumers, if there are more"
          }
        },
        "required": ["data", "has_more", "next_token"]
      },
      "EndpointItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Endpoint ID"
          },
          "method": {
            "type": "string",
            "description": "HTTP method"
          },
          "path": {
            "type": "string",
            "description": "Endpoint path"
          }
        },
        "required": ["id", "method", "path"]
      },
      "ListEndpointsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EndpointItem"
            },
            "description": "List of endpoints"
          }
        },
        "required": ["data"]
      },
      "RequestLogItem": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the request"
          },
          "request_uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the request"
          },
          "env": {
            "type": "string",
            "description": "Environment"
          },
          "consumer": {
            "type": "string",
            "nullable": true,
            "description": "Consumer identifier"
          },
          "method": {
            "type": "string",
            "description": "HTTP method"
          },
          "path": {
            "type": "string",
            "description": "Request path pattern"
          },
          "url": {
            "type": "string",
            "description": "Full request URL"
          },
          "status_code": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "request_size_bytes": {
            "type": "integer",
            "description": "Size of the request body in bytes"
          },
          "response_size_bytes": {
            "type": "integer",
            "description": "Size of the response body in bytes"
          },
          "response_time_ms": {
            "type": "number",
            "description": "Response time in milliseconds"
          },
          "client_ip": {
            "type": "string",
            "description": "Client IP address"
          },
          "client_country_iso_code": {
            "type": "string",
            "description": "Client country ISO code"
          }
        },
        "required": ["timestamp", "request_uuid", "env", "consumer", "method", "path", "url", "status_code"]
      },
      "ListRequestLogsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RequestLogItem"
            },
            "description": "List of request log entries"
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more records to fetch"
          },
          "next_token": {
            "type": "string",
            "nullable": true,
            "description": "Token to fetch the next page of records, if there are more"
          }
        },
        "required": ["data", "has_more", "next_token"]
      },
      "ExceptionInfo": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Exception type"
          },
          "message": {
            "type": "string",
            "description": "Exception message"
          },
          "stacktrace": {
            "type": "string",
            "description": "Exception stacktrace"
          },
          "sentry_event_id": {
            "type": "string",
            "description": "Sentry event ID if available"
          }
        },
        "required": ["type", "message"]
      },
      "LogEntry": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Log timestamp"
          },
          "message": {
            "type": "string",
            "description": "Log message"
          },
          "level": {
            "type": "string",
            "description": "Log level"
          },
          "logger": {
            "type": "string",
            "description": "Logger name"
          },
          "file": {
            "type": "string",
            "description": "Source file"
          },
          "line": {
            "type": "integer",
            "description": "Line number"
          }
        },
        "required": ["timestamp", "message", "level"]
      },
      "SpanEntry": {
        "type": "object",
        "properties": {
          "span_id": {
            "type": "string",
            "description": "Span ID"
          },
          "parent_span_id": {
            "type": "string",
            "nullable": true,
            "description": "Parent span ID"
          },
          "name": {
            "type": "string",
            "description": "Span name"
          },
          "kind": {
            "type": "string",
            "description": "Span kind"
          },
          "start_time_ns": {
            "type": "integer",
            "description": "Start time in nanoseconds"
          },
          "end_time_ns": {
            "type": "integer",
            "description": "End time in nanoseconds"
          },
          "duration_ns": {
            "type": "integer",
            "description": "Duration in nanoseconds"
          },
          "status": {
            "type": "string",
            "description": "Span status"
          },
          "attributes": {
            "type": "object",
            "additionalProperties": true,
            "description": "Span attributes"
          }
        },
        "required": ["span_id", "name", "kind", "start_time_ns", "end_time_ns", "duration_ns", "status"]
      },
      "RequestDetails": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the request"
          },
          "request_uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the request"
          },
          "env": {
            "type": "string",
            "description": "Environment"
          },
          "consumer": {
            "type": "string",
            "nullable": true,
            "description": "Consumer identifier"
          },
          "method": {
            "type": "string",
            "description": "HTTP method"
          },
          "path": {
            "type": "string",
            "description": "Request path pattern"
          },
          "url": {
            "type": "string",
            "description": "Full request URL"
          },
          "status_code": {
            "type": "integer",
            "description": "HTTP status code"
          },
          "request_size_bytes": {
            "type": "integer",
            "description": "Size of the request body in bytes"
          },
          "response_size_bytes": {
            "type": "integer",
            "description": "Size of the response body in bytes"
          },
          "response_time_ms": {
            "type": "number",
            "description": "Response time in milliseconds"
          },
          "client_ip": {
            "type": "string",
            "description": "Client IP address"
          },
          "client_country_iso_code": {
            "type": "string",
            "description": "Client country ISO code"
          },
          "request_headers": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 2,
              "maxItems": 2
            },
            "description": "Request headers as name-value pairs"
          },
          "response_headers": {
            "type": "array",
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 2,
              "maxItems": 2
            },
            "description": "Response headers as name-value pairs"
          },
          "request_body_json": {
            "type": "string",
            "nullable": true,
            "description": "Request body as JSON string"
          },
          "response_body_json": {
            "type": "string",
            "nullable": true,
            "description": "Response body as JSON string"
          },
          "trace_id": {
            "type": "string",
            "nullable": true,
            "description": "Trace ID"
          },
          "exception": {
            "$ref": "#/components/schemas/ExceptionInfo"
          },
          "logs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LogEntry"
            },
            "description": "Application log entries"
          },
          "spans": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SpanEntry"
            },
            "description": "Trace spans"
          }
        },
        "required": ["timestamp", "request_uuid", "env", "consumer", "method", "path", "url", "status_code"]
      },
      "TrafficItem": {
        "type": "object",
        "properties": {
          "period_start": {
            "type": "string",
            "format": "date-time",
            "description": "Start of the time period"
          },
          "period_end": {
            "type": "string",
            "format": "date-time",
            "description": "End of the time period"
          },
          "requests": {
            "type": "integer",
            "description": "Number of requests"
          },
          "bytes_received": {
            "type": "integer",
            "description": "Bytes received"
          },
          "bytes_sent": {
            "type": "integer",
            "description": "Bytes sent"
          }
        },
        "required": ["period_start", "period_end", "requests", "bytes_received", "bytes_sent"]
      },
      "ListTrafficResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TrafficItem"
            },
            "description": "List of traffic data"
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether there are more records to fetch"
          },
          "next_token": {
            "type": "string",
            "nullable": true,
            "description": "Token to fetch the next page of records, if there are more"
          }
        },
        "required": ["data", "has_more", "next_token"]
      }
    }
  }
}
