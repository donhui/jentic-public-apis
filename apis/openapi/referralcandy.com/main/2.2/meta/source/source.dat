{
  "openapi": "3.0.3",
  "info": {
    "title": "ReferralCandy API",
    "version": "2.2",
    "description": "ReferralCandy grows your brand with referral & affiliate programs. Ideal for eCommerce stores selling one-off & subscription products.",
    "x-jentic-source-url": "https://www.referralcandy.com/api"
  },
  "servers": [
    {
      "url": "https://my.referralcandy.com/api/v2.2",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "referralCandyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Authentication verification"
    },
    {
      "name": "Campaigns",
      "description": "Campaign management"
    },
    {
      "name": "Purchases",
      "description": "Purchase and referral tracking"
    },
    {
      "name": "Contacts",
      "description": "Contact and advocate management"
    },
    {
      "name": "Rewards",
      "description": "Reward management"
    }
  ],
  "paths": {
    "/verify.json": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Verify authentication credentials",
        "description": "Tests that authentication credentials are configured correctly",
        "operationId": "verifyAuth",
        "parameters": [
          {
            "name": "accessID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your access ID from account settings"
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            },
            "description": "Current Unix timestamp in seconds"
          },
          {
            "name": "signature",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "MD5 hash signature for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Verification Ok"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Invalid authentication credentials"
          }
        }
      }
    },
    "/campaigns.json": {
      "get": {
        "tags": ["Campaigns"],
        "summary": "Retrieve list of campaigns",
        "description": "Returns an array of campaigns for the account with IDs, names, join URLs, and states",
        "operationId": "getCampaigns",
        "parameters": [
          {
            "name": "accessID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "signature",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of campaigns",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Campaign"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/purchase.json": {
      "post": {
        "tags": ["Purchases"],
        "summary": "Register a new purchase",
        "description": "Registers a new purchase from the store and returns referral portal URLs",
        "operationId": "createPurchase",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/PurchaseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Purchase registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PurchaseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/referrals.json": {
      "get": {
        "tags": ["Purchases"],
        "summary": "Query for referred purchases",
        "description": "Retrieves referred purchases within a specified time period",
        "operationId": "getReferrals",
        "parameters": [
          {
            "name": "accessID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "signature",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date for query range"
          },
          {
            "name": "to_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date for query range"
          },
          {
            "name": "advocate_email",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by advocate email"
          }
        ],
        "responses": {
          "200": {
            "description": "List of referrals",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Referral"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/referral.json": {
      "post": {
        "tags": ["Purchases"],
        "summary": "Update purchase status",
        "description": "Updates the purchase status of a referred customer (e.g., mark as returned)",
        "operationId": "updateReferral",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["accessID", "timestamp", "signature", "email"],
                "properties": {
                  "accessID": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "integer",
                    "format": "int64"
                  },
                  "signature": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "status": {
                    "type": "string"
                  },
                  "notify": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Referral updated successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/referrer.json": {
      "get": {
        "tags": ["Purchases"],
        "summary": "Query for referrer",
        "description": "Retrieves the referrer of a particular customer",
        "operationId": "getReferrer",
        "parameters": [
          {
            "name": "accessID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "signature",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "email"
            },
            "description": "Email of the customer to query"
          }
        ],
        "responses": {
          "200": {
            "description": "Referrer information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "referrer_email": {
                      "type": "string",
                      "format": "email"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Referrer not found"
          }
        }
      }
    },
    "/contacts.json": {
      "get": {
        "tags": ["Contacts"],
        "summary": "Query for contacts",
        "description": "Returns paginated list of contacts enrolled in campaigns with purchase history",
        "operationId": "getContacts",
        "parameters": [
          {
            "name": "accessID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "signature",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Page number for pagination"
          },
          {
            "name": "campaign_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by campaign ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "contacts": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Contact"
                      }
                    },
                    "total_pages": {
                      "type": "integer"
                    },
                    "current_page": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/signup.json": {
      "post": {
        "tags": ["Contacts"],
        "summary": "Add contact to system",
        "description": "Adds a contact to the system and attempts campaign enrollment, returns referral links",
        "operationId": "signupContact",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["accessID", "timestamp", "signature", "first_name", "email"],
                "properties": {
                  "accessID": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "integer",
                    "format": "int64"
                  },
                  "signature": {
                    "type": "string"
                  },
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact signed up successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "referral_links": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "portal_url": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/invite.json": {
      "post": {
        "tags": ["Contacts"],
        "summary": "Send welcome email",
        "description": "Sends a welcome email to an enrolled contact",
        "operationId": "inviteContact",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["accessID", "timestamp", "signature", "email"],
                "properties": {
                  "accessID": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "integer",
                    "format": "int64"
                  },
                  "signature": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invite sent successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/unsubscribed.json": {
      "put": {
        "tags": ["Contacts"],
        "summary": "Update subscription status",
        "description": "Unsubscribe or resubscribe a contact from the program",
        "operationId": "updateSubscription",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["accessID", "timestamp", "signature", "email", "unsubscribed"],
                "properties": {
                  "accessID": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "integer",
                    "format": "int64"
                  },
                  "signature": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "unsubscribed": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription status updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/rewards.json": {
      "get": {
        "tags": ["Rewards"],
        "summary": "Query rewards",
        "description": "Returns rewards matching specified criteria",
        "operationId": "getRewards",
        "parameters": [
          {
            "name": "accessID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "signature",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by reward status"
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by reward type"
          }
        ],
        "responses": {
          "200": {
            "description": "List of rewards",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Reward"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "tags": ["Rewards"],
        "summary": "Update reward status",
        "description": "Updates the status of a custom reward",
        "operationId": "updateReward",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["accessID", "timestamp", "signature", "reward_id", "status"],
                "properties": {
                  "accessID": {
                    "type": "string"
                  },
                  "timestamp": {
                    "type": "integer",
                    "format": "int64"
                  },
                  "signature": {
                    "type": "string"
                  },
                  "reward_id": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reward updated successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/reward_purchases.json": {
      "get": {
        "tags": ["Rewards"],
        "summary": "Query referred purchases for a reward",
        "description": "Returns referred purchases associated with a specific reward",
        "operationId": "getRewardPurchases",
        "parameters": [
          {
            "name": "accessID",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "timestamp",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "signature",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "reward_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the reward"
          }
        ],
        "responses": {
          "200": {
            "description": "List of purchases",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Purchase"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "referralCandyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "accessID",
        "description": "ReferralCandy authentication requires accessID, timestamp, and signature parameters in each request"
      }
    },
    "schemas": {
      "Campaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "join_url": {
            "type": "string",
            "format": "uri"
          },
          "state": {
            "type": "string",
            "enum": ["ACTIVE", "PAUSED", "STOPPED"]
          }
        }
      },
      "PurchaseRequest": {
        "type": "object",
        "required": ["accessID", "timestamp", "signature", "first_name", "email", "order_timestamp", "browser_ip", "user_agent", "invoice_amount", "currency_code"],
        "properties": {
          "accessID": {
            "type": "string"
          },
          "timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "signature": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "order_timestamp": {
            "type": "integer",
            "format": "int64"
          },
          "browser_ip": {
            "type": "string"
          },
          "user_agent": {
            "type": "string"
          },
          "invoice_amount": {
            "type": "number",
            "format": "double"
          },
          "currency_code": {
            "type": "string"
          },
          "external_reference_id": {
            "type": "string"
          }
        }
      },
      "PurchaseResponse": {
        "type": "object",
        "properties": {
          "referral_portal_url": {
            "type": "string",
            "format": "uri"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Referral": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "advocate_email": {
            "type": "string",
            "format": "email"
          },
          "friend_email": {
            "type": "string",
            "format": "email"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "enrolled_campaigns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "referral_link": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Reward": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string"
          },
          "advocate_email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "Purchase": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string"
          },
          "external_reference_id": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
