  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key passed as 'apikey your-key' in the Authorization header"
      }
    },
    "schemas": {
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "format": "date-time"
          },
          "timeZone": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "featureLevel": {
            "type": "string"
          },
          "signupType": {
            "type": "string",
            "enum": [
              "rsvp",
              "tickets"
            ]
          },
          "website": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "rsvpLimit": {
            "type": "integer"
          },
          "rsvpLeft": {
            "type": "integer"
          },
          "waitlisted": {
            "type": "integer"
          },
          "hasPassed": {
            "type": "boolean"
          },
          "waitlist": {
            "type": "boolean"
          },
          "enableExtraGuests": {
            "type": "boolean"
          },
          "maxExtraGuests": {
            "type": "integer"
          },
          "location": {
            "type": "string"
          },
          "shareTitle": {
            "type": "string"
          },
          "shareDescription": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "timeFormat": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "primaryColor": {
            "type": "string"
          },
          "contrastColor": {
            "type": "string"
          },
          "workspaceId": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Ticket": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "persons": {
            "type": "integer"
          },
          "hashid": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "attending",
              "waitlist",
              "declined",
              "invited",
              "consumed",
              "deletion-requested"
            ]
          },
          "emailStatus": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "checkinAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "waitlistAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "endDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "termsAcceptedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "deletionRequestedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "ticketBatchId": {
            "type": "integer",
            "nullable": true
          },
          "paymentId": {
            "type": "integer",
            "nullable": true
          },
          "eventId": {
            "type": "integer"
          },
          "contactId": {
            "type": "integer"
          },
          "values": {
            "type": "object",
