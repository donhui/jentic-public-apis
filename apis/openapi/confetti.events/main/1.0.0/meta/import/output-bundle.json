{
  "openapi": "3.0.3",
  "info": {
    "title": "Confetti Events API",
    "version": "1.0.0",
    "description": "REST API for managing events, tickets, contacts, payments, webhooks, and workspaces on the Confetti platform.",
    "x-jentic-source-url": "https://docs.confetti.events"
  },
  "servers": [
    {
      "url": "https://api.confetti.events",
      "description": "Production server"
    }
  ],
  "paths": {
    "/events": {
      "get": {
        "operationId": "listevents",
        "summary": "Retrieve a paginated list of events",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "filter[signupType]",
            "in": "query",
            "required": false,
            "description": "Filter by signup type",
            "schema": {
              "type": "string",
              "enum": [
                "rsvp",
                "tickets"
              ]
            }
          },
          {
            "name": "filter[type]",
            "in": "query",
            "required": false,
            "description": "Filter by event type",
            "schema": {
              "type": "string",
              "enum": [
                "future",
                "past"
              ]
            }
          },
          {
            "name": "page[size]",
            "in": "query",
            "required": false,
            "description": "Maximum results per page",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "page[number]",
            "in": "query",
            "required": false,
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "description": "Related resources to include (comma-separated: categories, pages, pages.blocks, speakers, organisers)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Event"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
    "/events/{id}": {
      "get": {
        "operationId": "getevent",
        "summary": "Retrieve a single event by ID",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Event ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "description": "Related resources to include",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
    "/tickets": {
      "get": {
        "operationId": "listtickets",
        "summary": "Retrieve a paginated list of tickets",
        "tags": [
          "Tickets"
        ],
        "parameters": [
          {
            "name": "filter[eventId]",
            "in": "query",
            "required": true,
            "description": "Event ID to filter tickets",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "filter[search]",
            "in": "query",
            "required": false,
            "description": "Search term",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[description]",
            "in": "query",
            "required": false,
            "description": "Filter by description",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[checkedIn]",
            "in": "query",
            "required": false,
            "description": "Filter by check-in status",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "filter[status]",
            "in": "query",
            "required": false,
            "description": "Filter by ticket status",
            "schema": {
              "type": "string",
              "enum": [
                "attending",
                "waitlist",
                "declined",
                "invited",
                "consumed",
                "deletion-requested"
              ]
            }
          },
          {
            "name": "page[size]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "page[number]",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "description": "Related resources to include",
            "schema": {
              "type": "string",
              "default": "addons"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of tickets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Ticket"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      },
      "post": {
        "operationId": "createticket",
        "summary": "Create a new ticket",
        "tags": [
          "Tickets"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTicketRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Ticket created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ticket"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid or missing fields"
          },
          "401": {
            "description": "Unauthorized - Invalid or missing API key"
          }
        }
      }
    },
