      "CreateTicketRequest": {
        "type": "object",
        "required": [
          "eventId",
          "email",
          "status",
          "sendEmailConfirmation"
        ],
        "properties": {
          "eventId": {
            "type": "integer"
          },
          "email": {
            "type": "string",
