        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "workspaceId": {
            "type": "integer"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "phone": {
            "type": "string",
            "description": "Mobile phone number with country code (e.g., +46701234567)"
          },
          "comment": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "categoryIds": {
            "type": "array",
            "items": {
              "type": "integer"
