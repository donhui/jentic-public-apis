{
  "openapi": "3.0.3",
  "info": {
    "title": "Plus AI Presentations API",
    "description": "Plus AI is a presentation generation tool that lets you easily generate presentations with AI. This API allows you to create, list, and poll presentations programmatically.",
    "version": "0.1.0",
    "x-jentic-source-url": "https://guide.plusai.com/ai-for-presentations/presentations-api"
  },
  "servers": [
    {
      "url": "https://api.plusdocs.com/r/v0",
      "description": "Plus AI API server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Presentations",
      "description": "Operations for creating and managing AI-generated presentations"
    }
  ],
  "paths": {
    "/presentation": {
      "post": {
        "operationId": "createPresentation",
        "summary": "Create a presentation",
        "description": "Initiates presentation generation. Returns a polling URL for tracking progress. Rate limited to 3 creation requests per minute.",
        "tags": ["Presentations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePresentationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Presentation creation initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePresentationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/presentation/{presentationId}": {
      "get": {
        "operationId": "getPresentation",
        "summary": "Poll a specific presentation",
        "description": "Check generation status and retrieve the downloadable file when the presentation is complete.",
        "tags": ["Presentations"],
        "parameters": [
          {
            "name": "presentationId",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the presentation",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Presentation details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Presentation"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/presentations": {
      "get": {
        "operationId": "listPresentations",
        "summary": "List all presentations",
        "description": "Retrieve all generated presentations you have created via the Presentations API. Returns the last 100 presentations only.",
        "tags": ["Presentations"],
        "responses": {
          "200": {
            "description": "List of presentations retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Plus AI API key passed as a Bearer token. Requires Pro or Team plan."
      }
    },
    "schemas": {
      "CreatePresentationRequest": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Input text/content for the presentation"
          },
          "language": {
            "type": "string",
            "description": "ISO 639-1 language code. Defaults to 'en'.",
            "default": "en"
          },
          "numberOfSlides": {
            "type": "integer",
            "description": "Maximum number of slides. Max 30. AI determines count if omitted.",
            "maximum": 30
          },
          "includeUserTips": {
            "type": "boolean",
            "description": "Toggle Plus user tips in the presentation"
          },
          "templateId": {
            "type": "string",
            "description": "Custom template identifier to use for the presentation"
          },
          "textHandling": {
            "type": "string",
            "description": "How to handle text content in slides",
            "enum": ["DEFAULT", "PRESERVE", "STRICT"]
          }
        }
      },
      "CreatePresentationResponse": {
        "type": "object",
        "properties": {
          "pollingUrl": {
            "type": "string",
            "description": "URL to poll for presentation generation status"
          },
          "status": {
            "type": "string",
            "description": "Current status of the presentation generation",
            "enum": ["PROCESSING"]
          }
        }
      },
      "Presentation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the presentation"
          },
          "name": {
            "type": "string",
            "description": "Name of the presentation"
          },
          "status": {
            "type": "string",
            "description": "Current status of the presentation",
            "enum": ["PROCESSING", "COMPLETED", "FAILED"]
          },
          "slides": {
            "type": "array",
            "description": "Array of slides in the presentation (available when completed)",
            "items": {
              "$ref": "#/components/schemas/Slide"
            }
          },
          "downloadUrl": {
            "type": "string",
            "description": "URL to download the generated presentation file (available when completed)"
          },
          "url": {
            "type": "string",
            "description": "URL to view the presentation"
          }
        }
      },
      "PresentationList": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/Presentation"
        },
        "description": "Array of presentation objects (last 100)"
      },
      "Slide": {
        "type": "object",
        "properties": {
          "index": {
            "type": "integer",
            "description": "Slide position index"
          },
          "content": {
            "type": "string",
            "description": "Content of the slide"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          }
        }
      }
    }
  }
}