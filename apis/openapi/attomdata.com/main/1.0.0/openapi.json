    "/property/basicprofile": {
      "get": {
        "tags": [
          "Property"
        ],
        "summary": "Returns basic property information and most recent transaction and taxes.",
        "description": "Get basic property information and most recent transaction and taxes for a specific address.",
        "operationId": "propertyBasicProfile",
        "parameters": [
          {
            "name": "apikey",
            "description": "Application Key",
