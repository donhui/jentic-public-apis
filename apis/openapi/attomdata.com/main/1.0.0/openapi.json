{
  "openapi": "3.0.3",
  "info": {
    "version": "1.0.0",
    "title": "ATTOM Property API",
    "description": "",
    "x-jentic-source-url": "https://api.developer.attomdata.com/swagger/spec/propertyapi_property.json"
  },
  "servers": [
    {
      "url": "https://api.gateway.attomdata.com/propertyapi/v1.0.0"
    }
  ],
  "paths": {
    "/property/id": {
      "get": {
        "tags": [
          "Property"
        ],
        "summary": "Returns a list of properties that fit a criteria.",
        "description": "Get a list of property IDs within a specific geography that have a specific number of beds. Use orderby to choose how you want your results sorted.",
        "operationId": "getPropertyIdList",
        "parameters": [
          {
            "name": "apikey",
            "description": "Application Key",
            "in": "header",
            "x-data-threescale-name": "user_keys",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "name": "accept",
            "description": "application/xml or application/json (default)",
            "required": false,
            "in": "header",
            "schema": {
              "type": "string",
              "enum": [
                "application/xml",
                "application/json"
              ]
            }
          },
          {
            "name": "geoid",
            "description": "A list of geographies that this property belongs to. These geoIDs are used by search engine and values should not be exposed to the public.",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "default": "PL0820000"
            }
          },
          {
            "name": "minBeds",
            "description": "The min Bed size to search from.",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "default": "1"
            }
          },
          {
            "name": "maxBeds",
            "description": "The max Bed size to search from.",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "default": "2"
            }
          },
          {
            "name": "orderby",
            "description": "Sort Options",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "calendardate",
                "publisheddate",
                "propertytype",
                "saleamt",
                "avmvalue",
                "assdttlvalue",
                "salesearchdate",
                "saletransactiondate",
                "beds",
                "bathstotal",
                "universalsize",
                "lotsize1",
                "lotsize2"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "list of IDs for properties"
          },
          "403": {
            "description": "apikey invalid/missing"
          },
          "default": {
            "description": "unexpected error"
          }
        }
      }
    },
    "/property/detail": {
      "get": {
        "tags": [
          "Property"
        ],
        "summary": "Returns property details based on an ID.",
        "description": "Get property details based on its attom ID.",
        "operationId": "propertyDetails",
        "parameters": [
          {
            "name": "apikey",
            "description": "Application Key",
            "in": "header",
            "x-data-threescale-name": "user_keys",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "name": "accept",
            "description": "application/xml or application/json (default)",
            "required": false,
            "in": "header",
            "schema": {
              "type": "string",
              "enum": [
                "application/xml",
                "application/json"
              ]
            }
          },
          {
            "name": "attomid",
            "description": "attom id",
            "required": true,
            "in": "query",
            "schema": {
              "type": "string",
              "default": "184713191"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "list of property details"
          },
          "403": {
            "description": "apikey invalid/missing"
          },
          "default": {
            "description": "unexpected error"
          }
        }
      }
    },
    "/property/address": {
      "get": {
        "tags": [
          "Property"
        ],
        "summary": "Returns properties within a zip code.",
        "description": "Get a list of properties within a zip code. Use propertytype and order by to narrow down your results.",
