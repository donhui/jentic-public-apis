{
  "openapi": "3.0.3",
  "info": {
    "title": "Lykdat Fashion Image Search and Deep Tagging API",
    "description": "Lykdat provides fashion image search, item detection, deep tagging, and catalog management APIs for e-commerce applications.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://apidocs.lykdat.com/"
  },
  "servers": [
    {
      "url": "https://cloudapi.lykdat.com/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/search": {
      "post": {
        "operationId": "searchcatalog",
        "summary": "Search Catalog",
        "description": "Execute image searches against your product catalog to find similar fashion items.",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key",
                  "catalog_name"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "Publishable API key"
                  },
                  "catalog_name": {
                    "type": "string",
                    "description": "Catalog name to search"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image binary data"
                  },
                  "image_url": {
                    "type": "string",
                    "description": "Public image URL"
                  },
                  "filter_gender": {
                    "type": "string",
                    "enum": [
                      "male",
                      "female",
                      "unisex"
                    ],
                    "description": "Filter results by gender"
                  },
                  "filter_for_adults": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Filter for adults (1) or kids (0)"
                  },
                  "exclude_gender": {
                    "type": "string",
                    "description": "Gender to exclude from results"
                  },
                  "exclude_id": {
                    "type": "string",
                    "description": "Product ID to exclude from results"
                  },
                  "implicitly_filter_categories": {
                    "type": "integer",
                    "enum": [
                      0,
                      1
                    ],
                    "description": "Whether to implicitly filter categories"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/global/search": {
      "post": {
        "operationId": "globalsearch",
        "summary": "Global Search",
        "description": "Search Lykdat's global product catalog without creating your own catalog.",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "api_key"
                ],
                "properties": {
                  "api_key": {
                    "type": "string",
                    "description": "Publishable API key"
                  },
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image binary data"
                  },
                  "image_url": {
                    "type": "string",
                    "description": "Public image URL"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/detection/items": {
      "post": {
        "operationId": "detectitems",
        "summary": "Detect Fashion Items",
        "description": "Identify fashion items in images and return noun names with bounding boxes.",
        "tags": [
          "Detection"
        ],
        "security": [
          {
            "ApiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image binary data"
                  },
                  "image_url": {
                    "type": "string",
                    "description": "Public image URL"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Detected items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemDetectionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/detection/tags": {
      "post": {
        "operationId": "detecttags",
        "summary": "Deep Tagging",
        "description": "Return fashion tags, labels, and colors relevant to products in images.",
        "tags": [
          "Detection"
        ],
        "security": [
          {
            "ApiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image binary data (jpeg, png, webp, max 3MB)"
                  },
                  "image_url": {
                    "type": "string",
                    "description": "Public image URL"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tags and labels detected",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeepTaggingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/products/alerts/subscribe": {
      "post": {
        "operationId": "subscribeproductalert",
        "summary": "Subscribe to Product Alert",
        "description": "Subscribe users to price change or back-in-stock alerts for products.",
        "tags": [
          "Alerts"
        ],
        "security": [
          {
            "ApiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "subscriber_email",
                  "product_url",
                  "website_name",
                  "type"
                ],
                "properties": {
                  "subscriber_email": {
                    "type": "string",
                    "format": "email",
                    "description": "User email address"
                  },
                  "product_url": {
                    "type": "string",
                    "description": "Product URL to monitor"
                  },
                  "website_name": {
                    "type": "string",
                    "description": "Website name"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "price",
                      "availability"
                    ],
                    "description": "Alert type"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully subscribed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/catalog/update": {
      "post": {
        "operationId": "updatecatalog",
        "summary": "Update Catalog",
        "description": "Update an existing catalog with new products using a CSV/TSV file.",
        "tags": [
          "Catalog"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "admin_api_key",
                  "catalog_name",
                  "import_file",
                  "mode"
                ],
                "properties": {
                  "admin_api_key": {
                    "type": "string",
                    "description": "Admin API key"
                  },
                  "catalog_name": {
                    "type": "string",
                    "description": "Name of the catalog to update"
                  },
                  "import_file": {
                    "type": "string",
                    "format": "binary",
                    "description": "CSV/TSV catalog file (max 25MB)"
                  },
                  "mode": {
                    "type": "string",
                    "enum": [
                      "overwrite",
                      "extend"
                    ],
                    "description": "Update mode"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Catalog updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/images/transcode": {
      "post": {
        "operationId": "transcodeimage",
        "summary": "Transcode Image (BETA)",
        "description": "Transform images to highlight apparel by removing the background.",
        "tags": [
          "Images"
        ],
        "security": [
          {
            "ApiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image binary data"
                  },
                  "image_url": {
                    "type": "string",
                    "description": "Public image URL"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transcoded image",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "image_url": {
                          "type": "string",
                          "description": "URL of the transformed image"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Publishable API key passed in the x-api-key header"
      }
    },
    "schemas": {
      "SearchResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "query_image": {
                "type": "string"
              },
              "result_groups": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ResultGroup"
                }
              }
            }
          }
        }
      },
      "ResultGroup": {
        "type": "object",
        "properties": {
          "average_score": {
            "type": "number"
          },
          "detected_item": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "category": {
                "type": "string"
              },
              "confidence": {
                "type": "number"
              }
            }
          },
          "similar_products": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SimilarProduct"
            }
          }
        }
      },
      "SimilarProduct": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "image_url": {
            "type": "string"
          },
          "product_url": {
            "type": "string"
          }
        }
      },
      "ItemDetectionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "detected_items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "category": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number"
                    },
                    "bounding_box": {
                      "type": "object",
                      "properties": {
                        "x": {
                          "type": "number"
                        },
                        "y": {
                          "type": "number"
                        },
                        "width": {
                          "type": "number"
                        },
                        "height": {
                          "type": "number"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "DeepTaggingResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "colors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number"
                    }
                  }
                }
              },
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "category": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number"
                    }
                  }
                }
              },
              "labels": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "confidence": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "ApiKeyHeader": []
    }
  ],
  "tags": [
    {
      "name": "Alerts",
      "description": "Operations related to Alerts"
    },
    {
      "name": "Catalog",
      "description": "Operations related to Catalog"
    },
    {
      "name": "Detection",
      "description": "Operations related to Detection"
    },
    {
      "name": "Images",
      "description": "Operations related to Images"
    },
    {
      "name": "Search",
      "description": "Operations related to Search"
    }
  ]
}