{
  "openapi": "3.0.3",
  "info": {
    "title": "MarketAux API",
    "description": "MarketAux provides real-time and historical stock market news with entity-level sentiment analysis. Access global financial news, search entities (stocks, commodities, currencies), and retrieve sentiment-scored articles with entity matching.",
    "version": "1.0.0",
    "contact": {
      "name": "MarketAux Support",
      "url": "https://www.marketaux.com/contact"
    },
    "termsOfService": "https://www.marketaux.com/terms",
    "x-jentic-source-url": "https://www.marketaux.com/documentation"
  },
  "servers": [
    {
      "url": "https://api.marketaux.com/v1",
      "description": "MarketAux Production API"
    }
  ],
  "security": [
    {
      "apiTokenQuery": []
    }
  ],
  "tags": [
    {
      "name": "News",
      "description": "Retrieve financial news articles with filtering and sentiment analysis"
    },
    {
      "name": "Entity Stats",
      "description": "Entity-level statistics, trending data, and aggregations"
    },
    {
      "name": "Entity Search",
      "description": "Search and discover entities, types, and industries"
    }
  ],
  "paths": {
    "/news/all": {
      "get": {
        "operationId": "getNews",
        "summary": "Get finance and market news",
        "description": "Retrieve global financial news articles with entity filtering, sentiment scoring, and full-text search. Supports pagination, date ranges, and multiple sort options.",
        "tags": ["News"],
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "description": "Comma-separated list of stock ticker symbols (e.g., AAPL,TSLA,MSFT)",
            "schema": { "type": "string" }
          },
          {
            "name": "entity_types",
            "in": "query",
            "description": "Comma-separated list of entity types to filter by",
            "schema": { "type": "string" }
          },
          {
            "name": "industries",
            "in": "query",
            "description": "Comma-separated list of industries to filter by",
            "schema": { "type": "string" }
          },
          {
            "name": "countries",
            "in": "query",
            "description": "Comma-separated list of country codes to filter by",
            "schema": { "type": "string" }
          },
          {
            "name": "sentiment_gte",
            "in": "query",
            "description": "Minimum sentiment score (-1 to 1)",
            "schema": { "type": "number", "minimum": -1, "maximum": 1 }
          },
          {
            "name": "sentiment_lte",
            "in": "query",
            "description": "Maximum sentiment score (-1 to 1)",
            "schema": { "type": "number", "minimum": -1, "maximum": 1 }
          },
          {
            "name": "min_match_score",
            "in": "query",
            "description": "Minimum entity match score threshold",
            "schema": { "type": "number" }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Full-text search query. Supports AND, OR, NOT operators and phrase matching with quotes.",
            "schema": { "type": "string" }
          },
          {
            "name": "domains",
            "in": "query",
            "description": "Comma-separated list of source domains to include",
            "schema": { "type": "string" }
          },
          {
            "name": "exclude_domains",
            "in": "query",
            "description": "Comma-separated list of source domains to exclude",
            "schema": { "type": "string" }
          },
          {
            "name": "language",
            "in": "query",
            "description": "Language code to filter articles (e.g., en, es, de)",
            "schema": { "type": "string" }
          },
          {
            "name": "published_before",
            "in": "query",
            "description": "Return articles published before this date (YYYY-MM-DD or ISO-8601)",
            "schema": { "type": "string" }
          },
          {
            "name": "published_after",
            "in": "query",
            "description": "Return articles published after this date (YYYY-MM-DD or ISO-8601)",
            "schema": { "type": "string" }
          },
          {
            "name": "published_on",
            "in": "query",
            "description": "Return articles published on this exact date (YYYY-MM-DD)",
            "schema": { "type": "string" }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Field to sort results by",
            "schema": {
              "type": "string",
              "enum": ["published_on", "entity_match_score", "sentiment_score", "relevance_score"]
            }
          },
          {
            "name": "sort_order",
            "in": "query",
            "description": "Sort direction",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results to return per page",
            "schema": { "type": "integer", "default": 3 }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with news articles",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Invalid API token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "402": {
            "description": "Usage limit reached",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "403": {
            "description": "Endpoint access restricted for current plan",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "429": {
            "description": "Rate limit reached",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/news/similar/{uuid}": {
      "get": {
        "operationId": "getSimilarNews",
        "summary": "Find similar news articles",
        "description": "Retrieve articles similar to a specific article identified by UUID.",
        "tags": ["News"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "description": "UUID of the article to find similar articles for",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of similar articles to return",
            "schema": { "type": "integer", "default": 3 }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with similar articles",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NewsResponse" }
              }
            }
          },
          "404": {
            "description": "Article not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/news/uuid/{uuid}": {
      "get": {
        "operationId": "getNewsByUuid",
        "summary": "Get a specific news article by UUID",
        "description": "Retrieve a single news article by its unique identifier.",
        "tags": ["News"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "description": "UUID of the article to retrieve",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with the article",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NewsResponse" }
              }
            }
          },
          "404": {
            "description": "Article not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/news/sources": {
      "get": {
        "operationId": "getNewsSources",
        "summary": "List available news sources",
        "description": "Retrieve a list of available news sources and their domains.",
        "tags": ["News"],
        "parameters": [
          {
            "name": "language",
            "in": "query",
            "description": "Filter sources by language code",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with news sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/Meta" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/NewsSource" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/entity/stats/intraday": {
      "get": {
        "operationId": "getEntityStatsIntraday",
        "summary": "Get entity stats time series",
        "description": "Retrieve entity statistics broken down by time intervals (minute, hour, day, week, month, quarter, year).",
        "tags": ["Entity Stats"],
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "description": "Comma-separated list of stock ticker symbols",
            "schema": { "type": "string" }
          },
          {
            "name": "entity_types",
            "in": "query",
            "description": "Comma-separated list of entity types",
            "schema": { "type": "string" }
          },
          {
            "name": "published_before",
            "in": "query",
            "description": "Filter by date (YYYY-MM-DD or ISO-8601)",
            "schema": { "type": "string" }
          },
          {
            "name": "published_after",
            "in": "query",
            "description": "Filter by date (YYYY-MM-DD or ISO-8601)",
            "schema": { "type": "string" }
          },
          {
            "name": "group_by",
            "in": "query",
            "description": "Time interval grouping",
            "schema": {
              "type": "string",
              "enum": ["minute", "hour", "day", "week", "month", "quarter", "year"]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results per page",
            "schema": { "type": "integer" }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with entity stats time series",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EntityStatsResponse" }
              }
            }
          },
          "403": {
            "description": "Endpoint access restricted for current plan",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/entity/stats/aggregation": {
      "get": {
        "operationId": "getEntityStatsAggregation",
        "summary": "Get entity stats aggregation",
        "description": "Retrieve aggregated entity statistics for a single timeframe.",
        "tags": ["Entity Stats"],
        "parameters": [
          {
            "name": "symbols",
            "in": "query",
            "description": "Comma-separated list of stock ticker symbols",
            "schema": { "type": "string" }
          },
          {
            "name": "entity_types",
            "in": "query",
            "description": "Comma-separated list of entity types",
            "schema": { "type": "string" }
          },
          {
            "name": "published_before",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "published_after",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with aggregated entity stats",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EntityStatsResponse" }
              }
            }
          }
        }
      }
    },
    "/entity/trending/aggregation": {
      "get": {
        "operationId": "getTrendingEntities",
        "summary": "Get trending entities",
        "description": "Identify currently trending entities based on news coverage and sentiment.",
        "tags": ["Entity Stats"],
        "parameters": [
          {
            "name": "entity_types",
            "in": "query",
            "description": "Comma-separated list of entity types",
            "schema": { "type": "string" }
          },
          {
            "name": "countries",
            "in": "query",
            "description": "Comma-separated list of country codes",
            "schema": { "type": "string" }
          },
          {
            "name": "published_before",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "published_after",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with trending entities",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EntityStatsResponse" }
              }
            }
          }
        }
      }
    },
    "/entity/search": {
      "get": {
        "operationId": "searchEntities",
        "summary": "Search entities",
        "description": "Search for available entities by name, symbol, or other criteria.",
        "tags": ["Entity Search"],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search query for entity name or symbol",
            "schema": { "type": "string" }
          },
          {
            "name": "entity_types",
            "in": "query",
            "description": "Filter by entity types",
            "schema": { "type": "string" }
          },
          {
            "name": "countries",
            "in": "query",
            "description": "Filter by country codes",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with matching entities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "meta": { "$ref": "#/components/schemas/Meta" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Entity" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/entity/type/list": {
      "get": {
        "operationId": "listEntityTypes",
        "summary": "List supported entity types",
        "description": "Retrieve the list of supported entity types.",
        "tags": ["Entity Search"],
        "responses": {
          "200": {
            "description": "Successful response with entity types",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/entity/industry/list": {
      "get": {
        "operationId": "listIndustries",
        "summary": "List supported industries",
        "description": "Retrieve the list of supported industries.",
        "tags": ["Entity Search"],
        "responses": {
          "200": {
            "description": "Successful response with industries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiTokenQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "api_token",
        "description": "API token obtained from MarketAux registration at https://www.marketaux.com/register"
      }
    },
    "schemas": {
      "NewsResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/Meta" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/NewsArticle" }
          }
        }
      },
      "NewsArticle": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the article"
          },
          "title": {
            "type": "string",
            "description": "Article headline"
          },
          "description": {
            "type": "string",
            "description": "Article description or summary"
          },
          "snippet": {
            "type": "string",
            "description": "Short text snippet from the article"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the original article"
          },
          "image_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the article's featured image"
          },
          "language": {
            "type": "string",
            "description": "Language code of the article"
          },
          "published_at": {
            "type": "string",
            "format": "date-time",
            "description": "Publication date and time"
          },
          "source": {
            "type": "string",
            "description": "Source domain of the article"
          },
          "relevance_score": {
            "type": "number",
            "description": "Relevance score of the article to the query"
          },
          "entities": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ArticleEntity" }
          }
        }
      },
      "ArticleEntity": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string",
            "description": "Ticker symbol"
          },
          "name": {
            "type": "string",
            "description": "Entity name"
          },
          "exchange": {
            "type": "string",
            "description": "Stock exchange"
          },
          "exchange_long": {
            "type": "string",
            "description": "Full exchange name"
          },
          "country": {
            "type": "string",
            "description": "Country code"
          },
          "type": {
            "type": "string",
            "description": "Entity type"
          },
          "industry": {
            "type": "string",
            "description": "Industry classification"
          },
          "match_score": {
            "type": "number",
            "description": "Entity match confidence score"
          },
          "sentiment_score": {
            "type": "number",
            "description": "Sentiment score for this entity in the article (-1 to 1)"
          },
          "highlights": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "highlight": { "type": "string" },
                "sentiment": { "type": "number" },
                "highlighted_in": { "type": "string" }
              }
            }
          }
        }
      },
      "Entity": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "name": { "type": "string" },
          "exchange": { "type": "string" },
          "country": { "type": "string" },
          "type": { "type": "string" },
          "industry": { "type": "string" }
        }
      },
      "EntityStatsResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/Meta" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/EntityStats" }
          }
        }
      },
      "EntityStats": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Entity key (symbol, exchange, industry, or country)"
          },
          "total_documents": {
            "type": "integer",
            "description": "Total number of documents mentioning this entity"
          },
          "sentiment_avg": {
            "type": "number",
            "description": "Average sentiment score across documents"
          },
          "score": {
            "type": "number",
            "description": "Trending relevance score"
          }
        }
      },
      "NewsSource": {
        "type": "object",
        "properties": {
          "source_id": { "type": "string" },
          "domain": { "type": "string" },
          "language": { "type": "string" }
        }
      },
      "Meta": {
        "type": "object",
        "properties": {
          "found": {
            "type": "integer",
            "description": "Total number of results found"
          },
          "returned": {
            "type": "integer",
            "description": "Number of results returned in this response"
          },
          "limit": {
            "type": "integer",
            "description": "Results per page limit"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code identifier",
                "enum": [
                  "malformed_parameters",
                  "invalid_api_token",
                  "usage_limit_reached",
                  "endpoint_access_restricted",
                  "resource_not_found",
                  "rate_limit_reached",
                  "server_error",
                  "maintenance_mode"
                ]
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message"
              }
            }
          }
        }
      }
    }
  }
}