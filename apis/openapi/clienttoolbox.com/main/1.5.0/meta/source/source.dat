  "components": {
    "securitySchemes": {
      "formAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Auth",
        "description": "Authentication via POST form-data fields user_id and user_api_key. All requests require user_id and user_api_key as POST form-data parameters."
      }
    },
    "requestBodies": {
      "AuthBody": {
        "required": true,
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "$ref": "#/components/schemas/AuthParams"
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication failed - invalid credentials.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "AuthParams": {
        "type": "object",
        "required": ["user_id", "user_api_key"],
        "properties": {
          "user_id": {
            "type": "string",
            "description": "Username of the authorized user."
          },
          "user_api_key": {
            "type": "string",
            "description": "Security token (API key) for authentication."
          },
          "output": {
            "type": "string",
            "description": "Response format. Default is XML; set to 'JSON' for JSON output.",
            "enum": ["JSON", "XML"],
            "default": "XML"
          }
        }
      },
      "CustomerInput": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string",
            "description": "Customer first name."
          },
          "last_name": {
            "type": "string",
            "description": "Customer last name."
          },
          "email": {
            "type": "string",
            "description": "Customer email address."
          },
          "phone": {
            "type": "string",
            "description": "Customer phone number."
          },
          "campaign_id": {
            "type": "string",
            "description": "Campaign to enroll the customer in."
          }
        }
      },
      "TransactionInput": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string",
            "description": "Customer identifier."
          },
          "campaign_id": {
            "type": "string",
            "description": "Campaign identifier."
          },
          "amount": {
            "type": "number",
            "description": "Transaction amount."
          }
        }
      },
      "Customer": {
        "type": "object",
        "properties": {
          "customer_id": {
            "type": "string",
            "description": "Unique customer identifier."
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "CustomerResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Response status.",
            "enum": ["success", "error"]
          },
          "customer": {
            "$ref": "#/components/schemas/Customer"
          }
        }
      },
      "TransactionResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "error"]
          },
          "transaction_id": {
            "type": "string",
            "description": "Transaction identifier."
          }
        }
      },
      "BalanceResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "error"]
          },
          "balance": {
            "type": "number",
            "description": "Current points balance."
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Response status.",
            "enum": ["success", "error"]
          },
          "message": {
            "type": "string",
            "description": "Response message."
          }
        }
      },
      "ErrorResponse": {
