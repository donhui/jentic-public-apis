{
  "openapi": "3.0.3",
  "info": {
    "title": "Loyalty Gator API",
    "description": "Loyalty Gator (Client Toolbox) is a customer loyalty program API that helps manage customers, transactions, campaigns, rewards, reports, and more. All parameters must be passed as POST form-data. SSL/HTTPS is mandatory.",
    "version": "1.5.0",
    "x-jentic-source-url": "https://documentation.clienttoolbox.com/"
  },
  "servers": [
    {
      "url": "https://api.clienttoolbox.com",
      "description": "Primary API server"
    }
  ],
  "tags": [
    {
      "name": "Account",
      "description": "Account management and dashboard"
    },
    {
      "name": "Customers",
      "description": "Customer registration, search, and management"
    },
    {
      "name": "Transactions",
      "description": "Transaction recording and redemption"
    },
    {
      "name": "Campaigns",
      "description": "Loyalty campaign management"
    },
    {
      "name": "Users",
      "description": "Business employee user management"
    },
    {
      "name": "CustomFields",
      "description": "Custom field management for customers, transactions, and rewards"
    },
    {
      "name": "Reports",
      "description": "Audit and marketing reports"
    },
    {
      "name": "Tokens",
      "description": "Token management"
    },
    {
      "name": "Reference",
      "description": "Reference data lookups"
    },
    {
      "name": "EmailTemplates",
      "description": "Email template management (Premium)"
    },
    {
      "name": "SmsTemplates",
      "description": "SMS template management (Premium)"
    },
    {
      "name": "Memberships",
      "description": "Membership program management (Premium)"
    },
    {
      "name": "Boosts",
      "description": "Boost promotion management (Premium)"
    }
  ],
  "paths": {
    "/account_info": {
      "post": {
        "operationId": "getAccountInfo",
        "summary": "Retrieve account details",
        "tags": ["Account"],
        "security": [{ "formAuth": [] }],
        "requestBody": {
          "$ref": "#/components/requestBodies/AuthBody"
        },
        "responses": {
          "200": {
            "description": "Account information retrieved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              },
              "application/xml": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/account_update": {
      "post": {
        "operationId": "updateAccount",
        "summary": "Modify account settings",
        "tags": ["Account"],
        "security": [{ "formAuth": [] }],
        "requestBody": {
          "$ref": "#/components/requestBodies/AuthBody"
        },
        "responses": {
          "200": {
            "description": "Account updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/dashboard_info": {
      "post": {
        "operationId": "getDashboardInfo",
        "summary": "Access dashboard metrics",
        "tags": ["Account"],
        "security": [{ "formAuth": [] }],
        "requestBody": {
          "$ref": "#/components/requestBodies/AuthBody"
        },
        "responses": {
          "200": {
            "description": "Dashboard metrics retrieved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/customer": {
      "post": {
        "operationId": "createCustomer",
        "summary": "Create or register a customer",
        "tags": ["Customers"],
        "security": [{ "formAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "allOf": [
                  { "$ref": "#/components/schemas/AuthParams" },
                  { "$ref": "#/components/schemas/CustomerInput" }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Customer created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CustomerResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/customer_update": {
      "post": {
        "operationId": "updateCustomer",
        "summary": "Modify customer information",
        "tags": ["Customers"],
        "security": [{ "formAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "allOf": [
                  { "$ref": "#/components/schemas/AuthParams" },
                  {
                    "type": "object",
                    "required": ["customer_id"],
                    "properties": {
                      "customer_id": { "type": "string", "description": "Customer identifier." }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Customer updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/customer_search": {
      "post": {
        "operationId": "searchCustomers",
        "summary": "Search customers",
        "tags": ["Customers"],
        "security": [{ "formAuth": [] }],
        "requestBody": {
          "$ref": "#/components/requestBodies/AuthBody"
        },
        "responses": {
          "200": {
            "description": "Customer search results.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "customers": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Customer" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
