{
  "openapi": "3.0.3",
  "info": {
    "title": "Rezdy API",
    "version": "1.0.0",
    "description": "Rezdy is a booking and distribution platform for tours and activities. The API provides agent and supplier functionality for managing products, bookings, availability, and customers.",
    "x-jentic-source-url": "https://www.rezdy.com/api/",
    "contact": {
      "name": "Rezdy API Support"
    }
  },
