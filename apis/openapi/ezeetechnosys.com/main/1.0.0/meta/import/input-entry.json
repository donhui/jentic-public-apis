  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic HTTP authentication using hotel code and authentication token"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "APIKey",
        "description": "API key passed as a query parameter for listing/meta search endpoints"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "Errors": {
            "type": "object",
            "properties": {
              "ErrorCode": {
                "type": "string",
                "description": "Error code"
              },
              "ErrorMessage": {
                "type": "string",
                "description": "Error description"
              }
            }
          }
        }
      },
      "AuthCheckRequest": {
        "type": "object",
        "required": [
          "auth",
          "oprn"
        ],
        "properties": {
          "auth": {
            "type": "string",
            "description": "Unique authentication code"
          },
          "oprn": {
            "type": "string",
            "description": "Operation keyword (e.g., gethotelinfo)",
            "example": "gethotelinfo"
          }
        }
      },
      "AuthCheckResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "error"
            ]
          },
          "msg": {
            "type": "string"
          },
          "hotelname": {
            "type": "string"
          },
          "hotelcode": {
            "type": "integer"
          }
        }
      },
      "PmsConnectivityRequest": {
        "type": "object",
        "required": [
          "RES_Request"
        ],
        "properties": {
          "RES_Request": {
            "type": "object",
            "required": [
              "Request_Type",
              "Authentication"
            ],
            "properties": {
              "Request_Type": {
                "type": "string",
                "description": "Operation type: RoomInfo, RateInfo, InventoryUpdate, RateUpdate, etc."
              },
              "NeedPhysicalRooms": {
                "type": "integer",
                "description": "Set to 1 to include room data"
              },
              "Authentication": {
                "type": "object",
                "required": [
                  "HotelCode",
                  "AuthCode"
                ],
                "properties": {
                  "HotelCode": {
                    "type": "string",
                    "description": "Unique hotel code"
                  },
                  "AuthCode": {
                    "type": "string",
                    "description": "Unique authentication code"
                  }
                }
              }
            }
          }
        }
      },
      "PmsConnectivityResponse": {
        "type": "object",
        "properties": {
          "RoomInfo": {
            "type": "object",
            "properties": {
              "RoomTypes": {
                "type": "object",
                "properties": {
                  "RoomType": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "ID": {
                          "type": "string"
                        },
                        "Name": {
                          "type": "string"
                        },
                        "Rooms": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "RoomID": {
                                "type": "string"
                              },
                              "RoomName": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "RateTypes": {
                "type": "object",
                "properties": {
                  "RateType": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "ID": {
                          "type": "string"
                        },
                        "Name": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              },
              "RatePlans": {
                "type": "object",
                "properties": {
                  "RatePlan": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "RatePlanID": {
                          "type": "string"
                        },
                        "Name": {
                          "type": "string"
                        },
                        "RoomTypeID": {
                          "type": "string"
                        },
                        "RoomType": {
                          "type": "string"
                        },
                        "RateTypeID": {
                          "type": "string"
                        },
                        "RateType": {
                          "type": "string"
                        },
                        "RatePlanType": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "Errors": {
            "type": "object",
            "properties": {
              "ErrorCode": {
                "type": "string"
              },
              "ErrorMessage": {
                "type": "string"
              }
            }
          }
        }
      },
      "ListingResponse": {
        "type": "object",
        "description": "Response varies by request_type. Can be an array of hotels, amenities, room types, or a booking object."
      },
      "PmsDataRequest": {
        "type": "object",
        "required": [
          "Authentication"
        ],
        "properties": {
          "Request_Type": {
            "type": "string"
          },
          "Authentication": {
            "type": "object",
            "properties": {
              "HotelCode": {
                "type": "string"
              },
              "AuthCode": {
                "type": "string"
              }
            }
          }
        }
      },
      "PmsDataResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object"
          },
          "Errors": {
            "type": "object",
            "properties": {
              "ErrorCode": {
                "type": "string"
              },
              "ErrorMessage": {
                "type": "string"
              }
            }
          }
        }
      },
      "KioskRequest": {
        "type": "object",
        "properties": {
          "Request_Type": {
            "type": "string"
          },
          "Authentication": {
            "type": "object",
            "properties": {
              "HotelCode": {
                "type": "string"
              },
              "AuthCode": {
                "type": "string"
              }
            }
          }
        }
