  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "APIKey",
        "description": "API key provided by eZee Technosys"
      }
    },
    "schemas": {
      "RoomInfoRequest": {
        "type": "object",
        "required": [
          "Request_Type",
          "HotelCode",
          "AuthCode"
        ],
        "properties": {
          "Request_Type": {
            "type": "string",
            "enum": [
              "RoomInfo"
            ]
          },
          "HotelCode": {
            "type": "string"
          },
          "AuthCode": {
            "type": "string"
          },
          "NeedPhysicalRooms": {
            "type": "boolean"
          }
        }
      },
      "KioskRequest": {
        "type": "object",
        "required": [
          "Request_Type",
          "HotelCode",
          "AuthCode"
        ],
        "properties": {
          "Request_Type": {
            "type": "string",
            "enum": [
              "RetrieveCurrency",
              "RetrievePayMethods",
              "RetrieveIdentityType",
              "RoomAvailability"
            ],
            "description": "Operation type"
          },
          "HotelCode": {
            "type": "string"
          },
          "AuthCode": {
            "type": "string"
          },
          "RoomData": {
            "type": "object",
            "properties": {
              "from_date": {
                "type": "string",
                "format": "date"
              },
              "to_date": {
                "type": "string",
                "format": "date"
              },
              "RoomID": {
                "type": "string"
              }
            },
            "description": "Required for RoomAvailability request type"
          }
        }
      },
      "HotelListResponse": {
        "type": "object",
        "properties": {
          "hotels": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Hotel"
            }
          }
        }
      },
      "Hotel": {
        "type": "object",
        "properties": {
          "HotelCode": {
            "type": "string"
          },
          "HotelName": {
            "type": "string"
          },
          "Address": {
            "type": "string"
          },
          "City": {
            "type": "string"
          },
          "Country": {
            "type": "string"
          }
        }
      },
      "HotelAmenityResponse": {
        "type": "object",
        "properties": {
          "amenities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "RoomTypeListResponse": {
        "type": "object",
        "properties": {
          "room_types": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "RoomTypeID": {
                  "type": "string"
                },
                "RoomTypeName": {
                  "type": "string"
                },
                "Description": {
                  "type": "string"
                },
                "MaxAdults": {
                  "type": "integer"
                },
                "MaxChildren": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "RoomInfoResponse": {
        "type": "object",
        "properties": {
          "rooms": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "RoomID": {
                  "type": "string"
                },
                "RoomName": {
                  "type": "string"
                },
                "RoomType": {
                  "type": "string"
                },
                "Status": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Hotel",
      "description": "Hotel information and authentication"
    },
    {
      "name": "Room",
      "description": "Room types and availability"
    },
    {
      "name": "Booking",
      "description": "Booking and reservation operations"
    },
    {
      "name": "Configuration",
      "description": "Configuration and lookup data"
    },
    {
      "name": "Kiosk",
      "description": "Kiosk connectivity operations"
    }
  ]
