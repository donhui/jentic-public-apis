{
  "openapi": "3.0.3",
  "info": {
    "title": "eZee/YCS Connectivity API",
    "description": "YCS Connectivity API enables connectivity partners to send and retrieve data for properties. Manage rates, availability, bookings, housekeeping, and more. Supports XML, JSON and CSV response formats.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.ezeetechnosys.com/"
  },
  "servers": [
    {
      "url": "https://live.ipms247.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/index.php/page/service.pos2pms": {
      "post": {
        "tags": [
          "Configuration"
        ],
        "summary": "Check hotel authentication",
        "description": "Checks authentication and returns hotel information if valid. Returns data in XML format.",
        "operationId": "checkHotelAuthentication",
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "$ref": "#/components/schemas/AuthCheckRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication check result",
            "content": {
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/AuthCheckResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failure",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/pmsinterface/pms_connectivity.php": {
      "post": {
        "tags": [
          "PMS Connectivity"
        ],
        "summary": "PMS connectivity operations",
        "description": "Perform various PMS connectivity operations including room info, rates, inventory management. The Request_Type parameter determines the operation. Supports: RoomInfo, RateInfo, InventoryUpdate, RateUpdate, ReservationList, and more.",
        "operationId": "pmsConnectivity",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PmsConnectivityRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Operation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PmsConnectivityResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid auth code or hotel code",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/booking/reservation_api/listing.php": {
      "get": {
        "tags": [
          "Meta Search"
        ],
        "summary": "Hotel listing and meta search operations",
        "description": "Retrieve hotel information, amenities, room types, salutations, countries, extra charges, and more. The request_type parameter determines the operation: HotelList, HotelAmenity, RoomTypeList, ConfiguredDetails, CalculateExtraCharge, RoomList, ExtraCharges, BookingList, ReadBooking, etc.",
        "operationId": "listingOperations",
        "parameters": [
          {
            "name": "request_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "HotelList",
                "HotelAmenity",
                "RoomTypeList",
                "ConfiguredDetails",
                "CalculateExtraCharge",
                "VerifyUser",
                "ConfiguredPGList",
                "RoomList",
                "ProcessBooking",
                "BookingList",
                "ReadBooking",
                "CancelBooking",
                "InsertBooking",
                "ExtraCharges",
                "InsertTravelAgent"
              ]
            },
            "description": "Type of operation to perform"
          },
          {
            "name": "HotelCode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Unique hotel code"
          },
          {
            "name": "GroupCode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Unique group code for chain properties"
          },
          {
            "name": "APIKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique API authentication key"
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "en"
            },
            "description": "Language code (default: en)"
          },
          {
            "name": "publishtoweb",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "1 = all room types, 0 = only published to web (for RoomTypeList)"
          },
          {
            "name": "check_in_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Check-in date (for CalculateExtraCharge, RoomList)"
          },
          {
            "name": "check_out_date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Check-out date (for CalculateExtraCharge)"
          },
          {
            "name": "ExtraChargeId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Extra charge ID (for CalculateExtraCharge)"
          },
          {
            "name": "Total_ExtraItem",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Total extra items (for CalculateExtraCharge)"
          },
          {
            "name": "arrival_from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Arrival from date (for BookingList)"
          },
          {
            "name": "ResNo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Reservation number (for ReadBooking, CancelBooking)"
          },
          {
            "name": "SubNo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sub-reservation number (for CancelBooking)"
          },
          {
            "name": "username",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Username for VerifyUser"
          },
          {
            "name": "password",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Password for VerifyUser"
          },
          {
            "name": "groupcode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Group code for VerifyUser"
          },
          {
            "name": "BookingData",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "JSON-encoded booking data (for InsertBooking)"
          },
          {
            "name": "Process_Data",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "JSON-encoded process data (for ProcessBooking)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListingResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
