{
  "openapi": "3.0.3",
  "info": {
    "title": "eZee Connectivity Portal API",
    "version": "1.0.0",
    "description": "eZee Technosys Connectivity Portal API for hotel property management, room information, reservations, and booking engine integration.",
    "x-jentic-source-url": "https://api.ezeetechnosys.com/"
  },
  "servers": [
    {
      "url": "https://live.ipms247.com",
      "description": "Live production server"
    }
  ],
  "paths": {
    "/booking/reservation_api/listing.php": {
      "get": {
        "operationId": "getHotelList",
        "summary": "Retrieve hotel list",
        "description": "Get a list of hotels by group code or hotel code.",
        "tags": [
          "Hotel"
        ],
        "parameters": [
          {
            "name": "request_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "HotelList"
              ]
            }
          },
          {
            "name": "APIKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "GroupCode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "HotelCode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Hotel list retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HotelListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
