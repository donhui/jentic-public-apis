    "/booking/reservation_api/listing.php?request_type=CalculateExtraCharge": {
      "get": {
        "operationId": "calculateExtraCharge",
        "summary": "Calculate extra charges",
        "description": "Calculate extra charges for a booking based on dates and charge details.",
        "tags": [
          "Booking"
        ],
        "parameters": [
          {
            "name": "request_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "CalculateExtraCharge"
              ]
            }
          },
          {
            "name": "APIKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "HotelCode",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "check_in_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "check_out_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "ExtraChargeId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Total_ExtraItem",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Extra charge calculated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
