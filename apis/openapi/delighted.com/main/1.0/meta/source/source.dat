{
  "openapi": "3.0.3",
  "info": {
    "title": "Delighted API",
    "description": "Delighted customer feedback and NPS survey API",
    "version": "1.0",
    "x-jentic-source-url": "https://app.delighted.com/docs/api"
  },
  "servers": [
    {
      "url": "https://api.delighted.com"
    }
  ],
  "paths": {
    "/v1/people.json": {
      "post": {
        "summary": "Send survey to person",
        "operationId": "send_survey_to_person",
        "tags": [
          "People"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          },
          "required": true
        }
      },
      "get": {
        "summary": "List people",
        "operationId": "list_people",
        "tags": [
          "People"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/v1/people/{id}.json": {
      "delete": {
        "summary": "Delete person",
        "operationId": "delete_person",
        "tags": [
          "People"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/v1/survey_responses.json": {
      "get": {
        "summary": "List survey responses",
        "operationId": "list_survey_responses",
        "tags": [
          "Survey Responses"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "since",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "until",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ]
      },
      "post": {
        "summary": "Create survey response",
        "operationId": "create_survey_response",
        "tags": [
          "Survey Responses"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          },
          "required": true
        }
      }
    },
    "/v1/metrics.json": {
      "get": {
        "summary": "Get metrics",
