  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 Bearer token. See https://github.com/basecamp/bc3-api/blob/master/sections/authentication.md"
      }
    },
    "parameters": {
      "projectId": {
        "name": "projectId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Project (bucket) ID"
      },
      "recordingId": {
        "name": "recordingId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Recording ID"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - missing User-Agent header or invalid Content-Type",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or expired OAuth token",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      },
      "Person": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "attachable_sgid": { "type": "string" },
          "name": { "type": "string" },
          "email_address": { "type": "string", "format": "email" },
          "personable_type": { "type": "string" },
          "title": { "type": "string" },
          "bio": { "type": "string", "nullable": true },
          "location": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "admin": { "type": "boolean" },
          "owner": { "type": "boolean" },
          "client": { "type": "boolean" },
          "employee": { "type": "boolean" },
          "time_zone": { "type": "string" },
          "avatar_url": { "type": "string", "format": "uri" },
          "company": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          },
          "can_ping": { "type": "boolean" },
          "can_manage_projects": { "type": "boolean" },
          "can_manage_people": { "type": "boolean" },
          "can_access_timesheet": { "type": "boolean" },
          "can_access_hill_charts": { "type": "boolean" }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "purpose": { "type": "string" },
          "clients_enabled": { "type": "boolean" },
          "timesheet_enabled": { "type": "boolean" },
          "bookmark_url": { "type": "string", "format": "uri" },
          "url": { "type": "string", "format": "uri" },
          "app_url": { "type": "string", "format": "uri" },
          "dock": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DockItem" }
          }
        }
      },
      "DockItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "name": { "type": "string" },
          "enabled": { "type": "boolean" },
          "position": { "type": "integer" },
          "url": { "type": "string", "format": "uri" },
          "app_url": { "type": "string", "format": "uri" }
        }
      },
      "Recording": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": { "type": "string" },
          "visible_to_clients": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "title": { "type": "string" },
          "inherits_status": { "type": "boolean" },
          "type": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "app_url": { "type": "string", "format": "uri" },
          "bookmark_url": { "type": "string", "format": "uri" },
          "parent": { "$ref": "#/components/schemas/RecordingRef" },
          "bucket": { "$ref": "#/components/schemas/BucketRef" },
          "creator": { "$ref": "#/components/schemas/Person" }
        }
      },
      "RecordingRef": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "type": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "app_url": { "type": "string", "format": "uri" }
        }
      },
      "BucketRef": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "Message": {
        "allOf": [
          { "$ref": "#/components/schemas/Recording" },
          {
            "type": "object",
            "properties": {
              "subject": { "type": "string" },
              "content": { "type": "string" },
              "comments_count": { "type": "integer" },
              "comments_url": { "type": "string", "format": "uri" }
            }
          }
        ]
      },
      "MessageBoard": {
        "allOf": [
          { "$ref": "#/components/schemas/Recording" },
          {
            "type": "object",
            "properties": {
              "messages_count": { "type": "integer" },
              "messages_url": { "type": "string", "format": "uri" }
            }
          }
        ]
      },
      "TodoSet": {
        "allOf": [
          { "$ref": "#/components/schemas/Recording" },
          {
            "type": "object",
            "properties": {
              "completed": { "type": "boolean" },
              "completed_ratio": { "type": "string" },
              "todolists_count": { "type": "integer" }
            }
          }
        ]
      },
      "TodoList": {
        "allOf": [
          { "$ref": "#/components/schemas/Recording" },
          {
            "type": "object",
            "properties": {
              "position": { "type": "integer" },
              "comments_count": { "type": "integer" },
              "comments_url": { "type": "string", "format": "uri" },
              "subscription_url": { "type": "string", "format": "uri" },
              "completed_ratio": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        ]
      },
      "Todo": {
        "allOf": [
          { "$ref": "#/components/schemas/Recording" },
          {
            "type": "object",
            "properties": {
              "position": { "type": "integer" },
              "content": { "type": "string" },
              "description": { "type": "string" },
              "completed": { "type": "boolean" },
              "due_on": { "type": "string", "format": "date", "nullable": true },
              "starts_on": { "type": "string", "format": "date", "nullable": true },
              "assignees": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/Person" }
              },
              "comments_count": { "type": "integer" },
              "comments_url": { "type": "string", "format": "uri" }
            }
          }
        ]
      },
      "Comment": {
