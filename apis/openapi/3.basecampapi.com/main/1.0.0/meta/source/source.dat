{
  "openapi": "3.0.3",
  "info": {
    "title": "Basecamp 3 API",
    "description": "REST API for Basecamp 3. All URLs start with https://3.basecampapi.com/{account_id}/. Responses are JSON only. Authentication is via OAuth 2.0 Bearer tokens.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://github.com/basecamp/bc3-api"
  },
  "servers": [
    {
      "url": "https://3.basecampapi.com/{accountId}",
      "variables": {
        "accountId": {
          "description": "Your Basecamp account ID",
          "default": "999999999"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Projects", "description": "Project management" },
    { "name": "Messages", "description": "Messages on message boards" },
    { "name": "MessageBoards", "description": "Message board containers" },
    { "name": "TodoSets", "description": "To-do set containers" },
    { "name": "TodoLists", "description": "To-do list management" },
    { "name": "Todos", "description": "To-do item management" },
    { "name": "People", "description": "People and user management" },
    { "name": "Comments", "description": "Comments on recordings" },
    { "name": "Documents", "description": "Document management" },
    { "name": "Campfires", "description": "Chat / Campfire management" },
    { "name": "Schedules", "description": "Schedule containers" },
    { "name": "ScheduleEntries", "description": "Schedule entry management" },
    { "name": "Uploads", "description": "File upload management" },
    { "name": "Vaults", "description": "Docs & Files vault management" },
    { "name": "Webhooks", "description": "Webhook management" },
    { "name": "Events", "description": "Activity events on recordings" },
    { "name": "Recordings", "description": "Generic recording operations" },
    { "name": "Templates", "description": "Project template management" },
    { "name": "Questionnaires", "description": "Automatic check-in questionnaires" },
    { "name": "Questions", "description": "Automatic check-in questions" },
    { "name": "QuestionAnswers", "description": "Answers to check-in questions" },
    { "name": "Subscriptions", "description": "Recording subscriptions" },
    { "name": "CardTables", "description": "Card table (kanban) management" },
    { "name": "Chatbots", "description": "Chatbot integration" }
  ],
  "paths": {
    "/projects.json": {
      "post": {
        "operationId": "createProject",
        "summary": "Create a project",
        "tags": ["Projects"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created project",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Project" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "operationId": "listProjects",
        "summary": "Get all projects",
        "tags": ["Projects"],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter by status: archived or trashed",
            "schema": { "type": "string", "enum": ["archived", "trashed"] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Project" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/projects/{projectId}.json": {
      "get": {
        "operationId": "getProject",
        "summary": "Get a project",
        "tags": ["Projects"],
        "parameters": [
          { "$ref": "#/components/parameters/projectId" }
        ],
        "responses": {
          "200": {
            "description": "Project details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Project" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateProject",
        "summary": "Update a project",
        "tags": ["Projects"],
        "parameters": [
          { "$ref": "#/components/parameters/projectId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated project",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Project" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/message_boards/{messageBoardId}.json": {
      "get": {
        "operationId": "getMessageBoard",
        "summary": "Get a message board",
        "tags": ["MessageBoards"],
        "parameters": [
          {
            "name": "messageBoardId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Message board details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageBoard" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/message_boards/{messageBoardId}/messages.json": {
      "get": {
        "operationId": "listMessages",
        "summary": "Get messages",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "messageBoardId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": { "type": "string", "enum": ["created_at", "updated_at"] }
          },
          {
            "name": "direction",
            "in": "query",
            "schema": { "type": "string", "enum": ["desc", "asc"] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Message" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createMessage",
        "summary": "Create a message",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "messageBoardId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["subject", "content"],
                "properties": {
                  "subject": { "type": "string" },
                  "content": { "type": "string", "description": "Rich text (HTML) body" },
                  "category_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created message",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/messages/{messageId}.json": {
      "get": {
        "operationId": "getMessage",
        "summary": "Get a message",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Message details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateMessage",
        "summary": "Update a message",
        "tags": ["Messages"],
        "parameters": [
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subject": { "type": "string" },
                  "content": { "type": "string" },
                  "category_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated message",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/todosets/{todoSetId}.json": {
      "get": {
        "operationId": "getTodoSet",
        "summary": "Get a to-do set",
        "tags": ["TodoSets"],
        "parameters": [
          {
            "name": "todoSetId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "To-do set details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TodoSet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/todosets/{todoSetId}/todolists.json": {
      "get": {
        "operationId": "listTodoLists",
        "summary": "Get to-do lists",
        "tags": ["TodoLists"],
        "parameters": [
          {
            "name": "todoSetId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["archived", "trashed"] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of to-do lists",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TodoList" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createTodoList",
        "summary": "Create a to-do list",
        "tags": ["TodoLists"],
        "parameters": [
          {
            "name": "todoSetId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created to-do list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TodoList" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/todolists/{todoListId}.json": {
      "get": {
        "operationId": "getTodoList",
        "summary": "Get a to-do list",
        "tags": ["TodoLists"],
        "parameters": [
          {
            "name": "todoListId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "To-do list details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TodoList" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateTodoList",
        "summary": "Update a to-do list",
        "tags": ["TodoLists"],
        "parameters": [
          {
            "name": "todoListId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated to-do list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TodoList" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/todolists/{todoListId}/todos.json": {
      "get": {
        "operationId": "listTodos",
        "summary": "Get to-dos",
        "tags": ["Todos"],
        "parameters": [
          {
            "name": "todoListId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["archived", "trashed"] }
          },
          {
            "name": "completed",
            "in": "query",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of to-dos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Todo" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createTodo",
        "summary": "Create a to-do",
        "tags": ["Todos"],
        "parameters": [
          {
            "name": "todoListId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string" },
                  "description": { "type": "string" },
                  "assignee_ids": {
                    "type": "array",
                    "items": { "type": "integer" }
                  },
                  "notify": { "type": "boolean" },
                  "due_on": { "type": "string", "format": "date" },
                  "starts_on": { "type": "string", "format": "date" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created to-do",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Todo" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/todos/{todoId}.json": {
      "get": {
        "operationId": "getTodo",
        "summary": "Get a to-do",
        "tags": ["Todos"],
        "parameters": [
          {
            "name": "todoId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "To-do details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Todo" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "operationId": "updateTodo",
        "summary": "Update a to-do",
        "tags": ["Todos"],
        "parameters": [
          {
            "name": "todoId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string" },
                  "description": { "type": "string" },
                  "assignee_ids": {
                    "type": "array",
                    "items": { "type": "integer" }
                  },
                  "due_on": { "type": "string", "format": "date" },
                  "starts_on": { "type": "string", "format": "date" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated to-do",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Todo" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/todos/{todoId}/completion.json": {
      "post": {
        "operationId": "completeTodo",
        "summary": "Complete a to-do",
        "tags": ["Todos"],
        "parameters": [
          {
            "name": "todoId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "204": { "description": "To-do completed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "uncompleteTodo",
        "summary": "Uncomplete a to-do",
        "tags": ["Todos"],
        "parameters": [
          {
            "name": "todoId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "204": { "description": "To-do uncompleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/todos/{todoId}/position.json": {
      "put": {
        "operationId": "repositionTodo",
        "summary": "Reposition a to-do",
        "tags": ["Todos"],
        "parameters": [
          {
            "name": "todoId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["position"],
                "properties": {
                  "position": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "To-do repositioned" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/people.json": {
      "get": {
        "operationId": "listPeople",
        "summary": "Get all people",
        "tags": ["People"],
        "responses": {
          "200": {
            "description": "List of people",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Person" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/projects/{projectId}/people.json": {
      "get": {
        "operationId": "listProjectPeople",
        "summary": "Get people on a project",
        "tags": ["People"],
        "parameters": [
          { "$ref": "#/components/parameters/projectId" }
        ],
        "responses": {
          "200": {
            "description": "List of people on the project",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Person" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/projects/{projectId}/people/users.json": {
      "put": {
        "operationId": "updateProjectAccess",
        "summary": "Update who can access a project",
        "tags": ["People"],
        "parameters": [
          { "$ref": "#/components/parameters/projectId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer" },
                        "name": { "type": "string" },
                        "email_address": { "type": "string" }
                      }
                    }
                  },
                  "revoke": {
                    "type": "array",
                    "items": { "type": "integer" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Access updated" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/circles/people.json": {
      "get": {
        "operationId": "listPingablePeople",
        "summary": "Get pingable people",
        "tags": ["People"],
        "responses": {
          "200": {
            "description": "List of pingable people",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Person" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/people/{personId}.json": {
      "get": {
        "operationId": "getPerson",
        "summary": "Get a person",
        "tags": ["People"],
        "parameters": [
          {
            "name": "personId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
