    "/projects/recordings.json": {
      "get": {
        "operationId": "listRecordings",
        "summary": "Get recordings across projects",
        "tags": ["Recordings"],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": true,
            "description": "Recording type to filter by",
            "schema": { "type": "string", "enum": ["Comment", "Document", "Kanban::Card", "Kanban::Step", "Message", "Question::Answer", "Schedule::Entry", "Todo", "Todolist", "Upload", "Vault"] }
          },
          {
            "name": "bucket",
            "in": "query",
            "description": "Comma-separated project IDs",
            "schema": { "type": "string" }
          },
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["active", "archived", "trashed"] }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": { "type": "string", "enum": ["created_at", "updated_at"] }
          },
          {
            "name": "direction",
            "in": "query",
            "schema": { "type": "string", "enum": ["desc", "asc"] }
          }
        ],
        "responses": {
          "200": {
            "description": "List of recordings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Recording" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
