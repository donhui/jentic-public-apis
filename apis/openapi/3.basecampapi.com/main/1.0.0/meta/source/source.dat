    "/recordings/{recordingId}/events.json": {
      "get": {
        "operationId": "listEvents",
        "summary": "Get events for a recording",
        "tags": ["Events"],
        "parameters": [
          { "$ref": "#/components/parameters/recordingId" }
        ],
        "responses": {
          "200": {
            "description": "List of events",
