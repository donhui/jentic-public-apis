{
  "openapi": "3.0.3",
  "info": {
    "title": "Deetz API",
    "description": "API for Deetz integrations",
    "version": "1.0.0",
    "x-jentic-source-url": "https://deetz-api-docs.web.app/"
  },
  "servers": [
    {
      "url": "https://us-central1-realtycard-7cdb1.cloudfunctions.net/"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY"
      }
    }
  },
  "paths": {
    "/subscribe": {
      "post": {
        "summary": "Create webhook subscription",
        "description": "Endpoint for creating a webhook suscription",
        "parameters": [
          {
            "in": "query",
            "name": "entity",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "One of registrations, notes, contacts"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "hookUrl": "https://hookurl"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscription successful"
          }
        }
      }
    },
    "/unsubscribe": {
      "post": {
        "summary": "Remove webhook subscription",
        "description": "Endpoint for removing a webhook suscription",
        "parameters": [
          {
            "in": "query",
            "name": "entity",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "One of registrations, notes, contacts"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "hookUrl": "subscriptionId"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Unsubscription successful"
          }
        }
      }
    },
    "/testKey": {
      "get": {
        "summary": "Test API Key",
        "description": "Endpoint for testing the validity of the API Key",
        "responses": {
          "200": {
            "description": "API Key is valid"
          },
          "401": {
            "description": "Unauthorized - Invalid API Key"
          }
        }
      }
    },
    "/getNotes": {
      "get": {
        "summary": "Get notes",
        "description": "Endpoint for retrieving notes",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "example": [
                  {
                    "contactId": "jda9d89323ndnas938",
                    "timestamp": 1709186400,
                    "note": "This is a note",
                    "email": "example@deetz.us"
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/getRegistrations": {
      "get": {
        "summary": "Get registrations",
        "description": "Endpoint for retrieving registrations",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "example": [
                  {
                    "id": "ZvULLCfTkhB6ZDZfaIKC",
                    "createdAt": "2024-02-15T15:39:11.833Z",
                    "address": "123 Main Ave, City, TX 12345, USA",
                    "phoneNumber": "+17085550003",
                    "contact": "ISaVfAY6HBPVjCrqNpy5",
                    "name": "John Doe",
                    "responses": [
                      {
                        "question": "",
                        "id": 0,
                        "type": "text",
                        "value": ""
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/getContacts": {
      "get": {
        "summary": "Get contacts",
        "description": "Endpoint for retrieving contacts",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "example": [
                  {
                    "createdAt": "2024-01-01T00:00:00.000Z",
                    "phoneNumber": "+17085550003",
                    "origin": "registration",
                    "name": "John Doe",
                    "contactType": "lead",
                    "address": "123 Main Ave, City, TX 12345, USA",
                    "email": "john@deetz.us"
                  }
                ]
              }
            }
          }
        }
      }
    }
  }
}