      "description": "SMS template management"
    },
    {
      "name": "Connected Accounts",
      "description": "Connected account management"
    },
    {
      "name": "Send As",
      "description": "Send As identity management"
    },
    {
      "name": "Sequences",
      "description": "Sequence management"
    },
    {
      "name": "Dialer",
      "description": "Dialer management"
    },
    {
      "name": "Bulk Actions",
      "description": "Bulk action operations"
