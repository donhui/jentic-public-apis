    {
      "url": "https://api.close.com/api/v1",
      "description": "Close CRM Production API"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    {
      "name": "Leads",
      "description": "Lead management"
    },
    {
