{
  "openapi": "3.0.3",
  "info": {
    "title": "MailerLite API",
    "version": "1.0.0",
    "description": "Email marketing API for managing subscribers, campaigns, groups, and automations. Provides endpoints for subscriber management, campaign creation and scheduling, and activity tracking.",
    "x-jentic-source-url": "https://developers.mailerlite.com/"
  },
  "servers": [
    {
      "url": "https://connect.mailerlite.com/api"
    }
  ],
  "paths": {
    "/subscribers": {
      "get": {
        "operationId": "listSubscribers",
        "summary": "List all subscribers",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "name": "filter[status]",
            "in": "query",
            "description": "Filter by subscriber status",
            "schema": {
              "type": "string",
              "enum": ["active", "unsubscribed", "unconfirmed", "bounced", "junk"]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results per page (default 25)",
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "include",
            "in": "query",
            "description": "Include related resources (e.g., groups)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of subscribers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Subscriber"
                      }
                    },
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createOrUpdateSubscriber",
        "summary": "Create or update a subscriber",
        "description": "Creates a new subscriber or updates an existing one if the email already exists.",
        "tags": ["Subscribers"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSubscriberRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscriber updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Subscriber"
                    }
                  }
                }
              }
            }
          },
          "201": {
            "description": "Subscriber created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Subscriber"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/subscribers/{subscriberId}": {
      "get": {
        "operationId": "getSubscriber",
        "summary": "Get a subscriber by ID or email",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "name": "subscriberId",
            "in": "path",
            "required": true,
            "description": "Subscriber ID or email address",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Subscriber details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Subscriber"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Subscriber not found"
          }
        }
      },
      "put": {
        "operationId": "updateSubscriber",
        "summary": "Update a subscriber",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "name": "subscriberId",
            "in": "path",
            "required": true,
            "description": "Subscriber ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fields": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "groups": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Group IDs - unlisted groups will be removed"
                  },
                  "status": {
                    "type": "string",
                    "enum": ["active", "unsubscribed", "unconfirmed", "bounced", "junk"]
                  },
                  "subscribed_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "ip_address": {
                    "type": "string"
                  },
                  "opted_in_at": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "optin_ip": {
                    "type": "string"
                  },
                  "unsubscribed_at": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscriber updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Subscriber"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Subscriber not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteSubscriber",
        "summary": "Delete a subscriber",
        "description": "Remove subscriber; information retained for resubscription.",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "name": "subscriberId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Subscriber deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Subscriber not found"
          }
        }
      }
    },
    "/subscribers/{subscriberId}/activity-log": {
      "get": {
        "operationId": "getSubscriberActivityLog",
        "summary": "Get subscriber activity log",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "name": "subscriberId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[log_name]",
            "in": "query",
            "description": "Filter by activity type",
            "schema": {
              "type": "string",
              "enum": ["campaign_send", "automation_email_sent", "email_open", "link_click", "email_bounce", "spam_complaint", "unsubscribed", "email_forward"]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Results per page (default 100)",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Activity log entries"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/subscribers/{subscriberId}/forget": {
      "post": {
        "operationId": "forgetSubscriber",
        "summary": "GDPR-compliant subscriber deletion",
        "description": "Removes subscriber and completely deletes their information within 30 days.",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "name": "subscriberId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Subscriber marked for deletion"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Subscriber not found"
          }
        }
      }
    },
    "/subscribers/import/{importId}": {
      "get": {
        "operationId": "getImportStatus",
        "summary": "Get import report",
        "tags": ["Subscribers"],
        "parameters": [
          {
            "name": "importId",
            "in": "path",
            "required": true,
            "description": "Import ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Import status and statistics"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Import not found"
          }
        }
      }
    },
    "/campaigns": {
      "get": {
        "operationId": "listCampaigns",
        "summary": "List campaigns",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "filter[status]",
            "in": "query",
            "description": "Filter by campaign status",
            "schema": {
              "type": "string",
              "enum": ["sent", "draft", "ready"]
            }
          },
          {
            "name": "filter[type]",
            "in": "query",
            "description": "Filter by campaign type",
            "schema": {
              "type": "string",
              "enum": ["regular", "ab", "resend", "rss"]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of campaigns",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Campaign"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createCampaign",
        "summary": "Create a campaign",
        "tags": ["Campaigns"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCampaignRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Campaign created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Campaign"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Validation error"
          }
        }
      }
    },
    "/campaigns/{campaignId}": {
      "get": {
        "operationId": "getCampaign",
        "summary": "Get a campaign",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "campaignId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Campaign"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Campaign not found"
          }
        }
      },
      "put": {
        "operationId": "updateCampaign",
        "summary": "Update a draft campaign",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "campaignId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCampaignRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Campaign updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteCampaign",
        "summary": "Delete a campaign",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "campaignId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Campaign deleted"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/campaigns/{campaignId}/schedule": {
      "post": {
        "operationId": "scheduleCampaign",
        "summary": "Schedule or send a campaign",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "campaignId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["delivery"],
                "properties": {
                  "delivery": {
                    "type": "string",
                    "enum": ["instant", "scheduled", "timezone_based", "smart_sending"]
                  },
                  "schedule": {
                    "type": "object",
                    "properties": {
                      "date": {
                        "type": "string",
                        "format": "date"
                      },
                      "hours": {
                        "type": "string"
                      },
                      "minutes": {
                        "type": "string"
                      },
                      "timezone_id": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Campaign scheduled"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/campaigns/{campaignId}/cancel": {
      "post": {
        "operationId": "cancelCampaign",
        "summary": "Cancel a scheduled campaign",
        "description": "Cancels a ready campaign, reverting it to draft status.",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "campaignId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign cancelled"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/campaigns/{campaignId}/reports/subscriber-activity": {
      "get": {
        "operationId": "getCampaignSubscriberActivity",
        "summary": "Get campaign subscriber activity",
        "tags": ["Campaigns"],
        "parameters": [
          {
            "name": "campaignId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "filter[type]",
            "in": "query",
            "description": "Filter by activity type",
            "schema": {
              "type": "string",
              "enum": ["opened", "clicked"]
            }
          },
          {
            "name": "filter[search]",
            "in": "query",
            "description": "Search term",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Subscriber activity data"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Subscriber": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["active", "unsubscribed", "unconfirmed", "bounced", "junk"]
          },
          "source": {
            "type": "string"
          },
          "sent": {
            "type": "integer"
          },
          "opens_count": {
            "type": "integer"
          },
          "clicks_count": {
            "type": "integer"
          },
          "open_rate": {
            "type": "number"
          },
          "click_rate": {
            "type": "number"
          },
          "ip_address": {
            "type": "string",
            "nullable": true
          },
          "subscribed_at": {
            "type": "string",
            "format": "date-time"
          },
          "unsubscribed_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "fields": {
            "type": "object",
            "additionalProperties": true
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "CreateSubscriberRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "fields": {
            "type": "object",
            "additionalProperties": true
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": ["active", "unsubscribed", "unconfirmed", "bounced", "junk"]
          },
          "subscribed_at": {
            "type": "string",
            "format": "date-time"
          },
          "ip_address": {
            "type": "string"
          },
          "opted_in_at": {
            "type": "string",
            "format": "date-time"
          },
          "optin_ip": {
            "type": "string"
          },
          "unsubscribed_at": {
            "type": "string",
            "format": "date-time"
          },
          "resubscribe": {
            "type": "boolean",
            "description": "Reactivate unsubscribed subscribers"
          }
        }
      },
      "Campaign": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "account_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["regular", "ab", "resend", "rss"]
          },
          "status": {
            "type": "string"
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateCampaignRequest": {
        "type": "object",
        "required": ["name", "type", "emails"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 255
          },
          "type": {
            "type": "string",
            "enum": ["regular", "ab", "resend"]
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "subject": {
                  "type": "string"
                },
                "from_name": {
                  "type": "string"
                },
                "from": {
                  "type": "string",
                  "format": "email"
                },
                "content": {
                  "type": "string"
                }
              }
            }
          },
          "language_id": {
            "type": "integer"
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "segments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ab_settings": {
            "type": "object"
          },
          "resend_settings": {
            "type": "object"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "per_page": {
            "type": "integer"
          },
          "next_cursor": {
            "type": "string",
            "nullable": true
          },
          "prev_cursor": {
            "type": "string",
            "nullable": true
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "MailerLite API token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}