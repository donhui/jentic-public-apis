  "paths": {
    "/api/v1/communities": {
      "get": {
        "tags": [
          "communities"
        ],
        "summary": "List of communities",
        "description": "Returns communities that you belong to or you are able to view.",
        "operationId": "getApiV1Communities",
        "responses": {
          "200": {
            "description": "List of communities"
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    },
    "/api/v1/communities/{community_id}/users/{user_id}": {
      "delete": {
        "tags": [
          "communities"
        ],
        "summary": "Remove a user from a community",
        "description": "Remove a user from a community given a user_id and a community_id",
        "operationId": "deleteApiV1CommunitiesCommunityIdUsersUserId",
        "parameters": [
          {
            "name": "community_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Remove a user from a community"
          },
          "401": {
            "description": "Unauthenticated"
          },
          "403": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
