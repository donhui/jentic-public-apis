  "components": {
    "schemas": {
      "postApiV1CommunitiesCommunityIdInvite": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "email"
        ],
        "description": "Create an invitation for a user"
      },
      "postApiV1GroupsGroupIdInvite": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "email"
        ],
        "description": "Create a group invitation for an email"
      },
      "postApiV1Webhooks": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string"
          },
          "event": {
            "type": "string",
            "enum": [
              "on_community_join",
              "on_community_leave",
              "on_bundle_enroll",
              "on_course_enroll",
              "on_course_chapter_view",
              "aggregate_course_chapter_views",
              "on_coursework_update",
              "on_badge_award",
              "send_credential"
            ]
          },
          "subject_id": {
            "type": "string"
          },
          "subject_type": {
            "type": "string",
            "enum": [
              "community",
              "course_bundle",
              "course"
            ]
          }
        },
        "required": [
          "url",
          "event",
          "subject_id"
        ],
        "description": "Subscribe to webhook"
      }
    },
