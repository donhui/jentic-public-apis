    "/api/v1/orders/multi": {
      "post": {
        "operationId": "placeBulkOrders",
        "summary": "Place bulk orders",
        "description": "Places multiple orders in a single request. Maximum 5 orders per request.",
        "tags": ["Trading"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["symbol", "orderList"],
                "properties": {
                  "symbol": {
                    "type": "string",
                    "description": "Trading symbol"
                  },
                  "orderList": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/PlaceOrderRequest"
                    },
                    "maxItems": 5
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk orders placed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          }
        }
