    "/api/v1/market/candles": {
      "get": {
        "operationId": "getKlines",
        "summary": "Get klines",
        "description": "Returns candlestick/kline data for a given symbol.",
        "tags": ["Market Data"],
        "security": [],
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "description": "Trading symbol.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "description": "Candlestick type: 1min, 3min, 5min, 15min, 30min, 1hour, 2hour, 4hour, 6hour, 8hour, 12hour, 1day, 1week.",
            "schema": {
              "type": "string",
              "enum": ["1min", "3min", "5min", "15min", "30min", "1hour", "2hour", "4hour", "6hour", "8hour", "12hour", "1day", "1week"]
            }
          },
          {
            "name": "startAt",
            "in": "query",
            "description": "Start time in seconds.",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "endAt",
            "in": "query",
            "description": "End time in seconds.",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "description": "[time, open, close, high, low, volume, turnover]"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
