{
  "openapi": "3.0.3",
  "info": {
    "title": "Agiliron API",
    "description": "Agiliron is a SaaS platform for Omni-Channel Commerce focused on helping Product Based Businesses (Retail, Wholesale, Distribution, eCommerce). The API provides CRUD operations for leads, contacts, accounts, products, orders, inventory, and more.",
    "version": "4.0",
    "x-jentic-source-url": "http://api.agiliron.com"
  },
  "servers": [
    {
      "url": "https://{company}.agiliron.net/agiliron/api-40",
      "description": "Agiliron API Server",
      "variables": {
        "company": {
          "default": "yourCompany",
          "description": "Your Agiliron company subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "apiKeyQuery": []
    }
  ],
  "tags": [
    { "name": "Leads", "description": "Lead management" },
    { "name": "Contacts", "description": "Contact management" },
    { "name": "Accounts", "description": "Account management" },
    { "name": "Products", "description": "Product catalog management" },
    { "name": "SalesOrders", "description": "Sales order management" },
    { "name": "PurchaseOrders", "description": "Purchase order management" },
    { "name": "Quotes", "description": "Quote management" },
    { "name": "Potentials", "description": "Sales opportunity management" },
    { "name": "Inventory", "description": "Inventory management" },
    { "name": "Events", "description": "Event management" },
    { "name": "Tasks", "description": "Task management" },
    { "name": "Tickets", "description": "Support ticket management" },
    { "name": "Notes", "description": "Notes and attachments" }
  ],
  "paths": {
    "/Leads/": {
      "post": {
        "operationId": "createLead",
        "summary": "Add a new lead",
        "tags": ["Leads"],
        "parameters": [
          {
            "name": "Accept",
            "in": "header",
            "schema": { "type": "string", "enum": ["application/json", "application/xml"], "default": "application/json" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Lead" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lead created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LeadResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "getLeads",
        "summary": "Read leads",
        "tags": ["Leads"],
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter criteria for leads"
          },
          {
            "name": "customview",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Custom view name to filter leads"
          },
          {
            "name": "Accept",
            "in": "header",
            "schema": { "type": "string", "enum": ["application/json", "application/xml"], "default": "application/json" }
          }
        ],
        "responses": {
          "200": {
            "description": "Leads retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Lead" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateLead",
        "summary": "Update an existing lead",
        "tags": ["Leads"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Lead" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Lead updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LeadResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteLead",
        "summary": "Delete a lead",
        "tags": ["Leads"],
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Lead identifier to delete"
          }
        ],
        "responses": {
          "200": {
            "description": "Lead deleted successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
