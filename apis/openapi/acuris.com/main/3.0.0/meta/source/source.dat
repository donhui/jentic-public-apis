{
  "openapi": "3.0.3",
  "info": {
    "title": "Acuris Compliance Search API",
    "description": "Search and retrieve individual and business compliance profiles for sanctions, PEP, and adverse media screening.",
    "version": "3.0.0",
    "x-jentic-source-url": "https://api.acuris.com/compliance/docs/api"
  },
  "servers": [
    {
      "url": "https://api.acuris.com/compliance/v3",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Individuals",
      "description": "Individual profile search and retrieval"
    },
    {
      "name": "Businesses",
      "description": "Business profile search and retrieval"
    },
    {
      "name": "Dictionaries",
      "description": "Reference data lookups"
    }
  ],
  "paths": {
    "/individuals": {
      "post": {
        "operationId": "searchIndividuals",
        "summary": "Search individual profiles",
        "description": "Search for individual profiles using name, datasets, and optional filtering parameters. Returns matching profiles with relevance scores.",
        "tags": ["Individuals"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchIndividualsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndividualSearchResults"
                }
              },
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid search parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/individuals/{resourceId}": {
      "get": {
        "operationId": "getIndividualProfile",
        "summary": "Retrieve individual profile",
        "description": "Returns an individual profile by resource ID in JSON or PDF format.",
        "tags": ["Individuals"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "description": "Unique profile resource identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Accept",
            "in": "header",
            "description": "Response format (application/json or application/pdf)",
            "schema": {
              "type": "string",
              "enum": ["application/json", "application/pdf"]
            }
          },
          {
            "name": "Accept-Encoding",
            "in": "header",
            "description": "Accepted encoding",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Individual profile retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IndividualProfile"
                }
              },
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid resource ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "getIndividualProfileWithComment",
        "summary": "Retrieve individual profile PDF with comment",
        "description": "Returns an individual profile PDF with a user-supplied comment embedded in the document.",
        "tags": ["Individuals"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "description": "Unique profile resource identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfilePdfCommentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF with comment generated",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/individuals/{resourceId}/evidences/copyrighted/{evidenceId}": {
      "get": {
        "operationId": "getIndividualCopyrightedEvidence",
        "summary": "Access copyrighted individual evidence",
        "description": "Returns a PDF version of copyrighted evidence for an individual profile.",
        "tags": ["Individuals"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "description": "Profile resource identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "evidenceId",
            "in": "path",
            "required": true,
            "description": "Evidence identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "description": "Must be application/pdf",
            "schema": {
              "type": "string",
              "enum": ["application/pdf"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Evidence PDF returned",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/businesses": {
      "post": {
        "operationId": "searchBusinesses",
        "summary": "Search business profiles",
        "description": "Search for business profiles using name, datasets, and optional filtering parameters.",
        "tags": ["Businesses"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchBusinessesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessSearchResults"
                }
              },
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid search parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/businesses/{resourceId}": {
      "get": {
        "operationId": "getBusinessProfile",
        "summary": "Retrieve business profile",
        "description": "Returns a business profile by resource ID in JSON or PDF format.",
        "tags": ["Businesses"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "description": "Unique profile resource identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Accept",
            "in": "header",
            "description": "Response format (application/json or application/pdf)",
            "schema": {
              "type": "string",
              "enum": ["application/json", "application/pdf"]
            }
          },
          {
            "name": "Accept-Encoding",
            "in": "header",
            "description": "Accepted encoding",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Business profile retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessProfile"
                }
              },
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid resource ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "getBusinessProfileWithComment",
        "summary": "Retrieve business profile PDF with comment",
        "description": "Returns a business profile PDF with a user-supplied comment embedded in the document.",
        "tags": ["Businesses"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "description": "Unique profile resource identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProfilePdfCommentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF with comment generated",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/businesses/{resourceId}/evidences/copyrighted/{evidenceId}": {
      "get": {
        "operationId": "getBusinessCopyrightedEvidence",
        "summary": "Access copyrighted business evidence",
        "description": "Returns a PDF version of copyrighted evidence for a business profile.",
        "tags": ["Businesses"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "description": "Profile resource identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "evidenceId",
            "in": "path",
            "required": true,
            "description": "Evidence identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Accept",
            "in": "header",
            "required": true,
            "description": "Must be application/pdf",
            "schema": {
              "type": "string",
              "enum": ["application/pdf"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Evidence PDF returned",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/dictionaries/sanction-bodies": {
      "get": {
        "operationId": "listSanctionBodies",
        "summary": "List sanctioning bodies",
        "description": "Retrieve a dictionary mapping sanctioning body names to IDs for use in filtering search results.",
        "tags": ["Dictionaries"],
        "responses": {
          "200": {
            "description": "Sanctioning bodies list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SanctionBodiesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "SearchIndividualsRequest": {
        "type": "object",
        "required": ["name", "datasets"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name of the individual to search for"
          },
          "datasets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Datasets to search (e.g. sanctions, pep, adverse-media)"
          },
          "threshold": {
            "type": "integer",
            "description": "Minimum match score threshold (75-100)",
            "minimum": 75,
            "maximum": 100
          },
          "dob": {
            "type": "string",
            "description": "Date of birth (YYYY-MM-DD format)",
            "format": "date"
          },
          "gender": {
            "type": "string",
            "description": "Gender filter",
            "enum": ["male", "female"]
          },
          "addresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Address"
            },
            "description": "Address filters"
          },
          "pepTiers": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "PEP tier filters"
          },
          "sanBodyIdsInclude": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Sanctioning body IDs to include in results"
          },
          "sanBodyIdsExclude": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Sanctioning body IDs to exclude from results"
          }
        }
      },
      "SearchBusinessesRequest": {
        "type": "object",
        "required": ["name", "datasets"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Business name to search for"
          },
          "datasets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Datasets to search"
          },
          "threshold": {
            "type": "integer",
            "description": "Minimum match score threshold (75-100)",
            "minimum": 75,
            "maximum": 100
          },
          "addresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Address"
            },
            "description": "Address filters"
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Country code filters (ISO 3166-1 alpha-2)"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "country": {
            "type": "string",
            "description": "Country code (ISO 3166-1 alpha-2)"
          },
          "city": {
            "type": "string"
          },
          "stateProvince": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          }
        }
      },
      "IndividualSearchResults": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IndividualSearchResult"
            }
          }
        }
      },
      "IndividualSearchResult": {
        "type": "object",
        "properties": {
          "resourceId": {
            "type": "string",
            "description": "Unique profile resource identifier"
          },
          "name": {
            "type": "string",
            "description": "Matched individual name"
          },
          "matchScore": {
            "type": "integer",
            "description": "Relevance score (75-100)"
          },
          "datasets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Matched datasets"
          },
          "gender": {
            "type": "string"
          },
          "dob": {
            "type": "string"
          },
          "nationalities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "IndividualProfile": {
        "type": "object",
        "properties": {
          "resourceId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "gender": {
            "type": "string"
          },
          "dob": {
            "type": "string"
          },
          "nationalities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "addresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Address"
            }
          },
          "datasets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "pepTier": {
            "type": "integer"
          },
          "sanctions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sanction"
            }
          },
          "evidences": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Evidence"
            }
          }
        }
      },
      "BusinessSearchResults": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BusinessSearchResult"
            }
          }
        }
      },
      "BusinessSearchResult": {
        "type": "object",
        "properties": {
          "resourceId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "matchScore": {
            "type": "integer"
          },
          "datasets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "BusinessProfile": {
        "type": "object",
        "properties": {
          "resourceId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "countries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "addresses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Address"
            }
          },
          "datasets": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "sanctions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Sanction"
            }
          },
          "evidences": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Evidence"
            }
          }
        }
      },
      "Sanction": {
        "type": "object",
        "properties": {
          "sanctionBodyId": {
            "type": "integer"
          },
          "sanctionBodyName": {
            "type": "string"
          },
          "listedDate": {
            "type": "string",
            "format": "date"
          },
          "program": {
            "type": "string"
          }
        }
      },
      "Evidence": {
        "type": "object",
        "properties": {
          "evidenceId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "isCopyrighted": {
            "type": "boolean"
          }
        }
      },
      "ProfilePdfCommentRequest": {
        "type": "object",
        "required": ["comment"],
        "properties": {
          "comment": {
            "type": "string",
            "description": "User comment to include in the PDF"
          },
          "userName": {
            "type": "string",
            "description": "Name of the user adding the comment"
          }
        }
      },
      "SanctionBodiesResponse": {
        "type": "object",
        "properties": {
          "sanctionBodies": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SanctionBody"
            }
          }
        }
      },
      "SanctionBody": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Sanctioning body ID"
          },
          "name": {
            "type": "string",
            "description": "Sanctioning body name"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer"
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}