{
  "openapi": "3.0.3",
  "info": {
    "title": "Splunk Enterprise REST API",
    "version": "9.4.0",
    "description": "REST API for managing and interacting with Splunk Enterprise. Provides endpoints for search jobs, saved searches, indexes, data inputs/outputs, users, roles, apps, server management, and KV Store operations.",
    "x-jentic-source-url": "https://dev.splunk.com/enterprise/reference"
  },
  "servers": [
    {
      "url": "https://{host}:8089",
      "variables": {
        "host": {
          "default": "localhost",
          "description": "Splunk server hostname"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Session token management"
    },
    {
      "name": "Search Jobs",
      "description": "Create and manage search jobs"
    },
    {
      "name": "Saved Searches",
      "description": "Manage saved searches and alerts"
    },
    {
      "name": "Alerts",
      "description": "Fired alerts management"
    },
    {
      "name": "Indexes",
      "description": "Index management"
    },
    {
      "name": "Inputs",
      "description": "Data input configuration"
    },
    {
      "name": "Data Receivers",
      "description": "Submit events directly"
    },
    {
      "name": "Data Outputs",
      "description": "Forwarding configuration"
    },
    {
      "name": "Applications",
      "description": "App management"
    },
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Roles",
      "description": "Role and authorization management"
    },
    {
      "name": "Server",
      "description": "Server information and control"
    },
    {
      "name": "Messages",
      "description": "System messages"
    },
    {
      "name": "KV Store",
      "description": "Key-value store collections"
    }
  ],
  "paths": {
    "/services/auth/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "operationId": "createAuthToken",
        "summary": "Authenticate and obtain a session token",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "cookie": {
                    "type": "string",
                    "description": "Set to 1 for cookie-based auth"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthToken"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/services/search/jobs": {
      "get": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "listSearchJobs",
        "summary": "List all search jobs",
        "parameters": [
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 30
            },
            "description": "Maximum results to return. 0 for all."
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Starting index for pagination"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter expression"
          },
          {
            "name": "sort_key",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Field to sort by"
          },
          {
            "name": "sort_dir",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ]
            },
            "description": "Sort direction"
          },
          {
            "name": "output_mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "atom",
                "json",
                "csv",
                "xml"
              ],
              "default": "json"
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SplunkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "createSearchJob",
        "summary": "Create a new search job",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/SearchJobCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchJobSid"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/search/jobs/{search_id}": {
      "get": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "getSearchJob",
        "summary": "Get search job status and details",
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search job SID"
          },
          {
            "name": "output_mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "atom",
                "json",
                "csv",
                "xml"
              ],
              "default": "json"
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchJob"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "deleteSearchJob",
        "summary": "Delete/cancel a search job",
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search job SID"
          }
        ],
        "responses": {
          "200": {
            "description": "Job deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SplunkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/search/jobs/{search_id}/control": {
      "post": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "controlSearchJob",
        "summary": "Control a search job (pause, unpause, finalize, cancel, etc.)",
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search job SID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "action"
                ],
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "pause",
                      "unpause",
                      "finalize",
                      "cancel",
                      "touch",
                      "setttl",
                      "setpriority",
                      "enablepreview",
                      "disablepreview"
                    ]
                  },
                  "ttl": {
                    "type": "integer"
                  },
                  "priority": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SplunkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/search/jobs/{search_id}/results": {
      "get": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "getSearchResults",
        "summary": "Get final search results",
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search job SID"
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Max results"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Starting index for pagination"
          },
          {
            "name": "field_list",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated fields to return"
          },
          {
            "name": "output_mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "atom",
                "csv",
                "json",
                "json_cols",
                "json_rows",
                "raw",
                "xml"
              ]
            },
            "description": "Output format"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Post-processing search"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/search/jobs/{search_id}/results_preview": {
      "get": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "getSearchResultsPreview",
        "summary": "Get preview results from a running search",
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search job SID"
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Max results"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Starting index for pagination"
          },
          {
            "name": "field_list",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated fields to return"
          },
          {
            "name": "output_mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "atom",
                "csv",
                "json",
                "json_cols",
                "json_rows",
                "raw",
                "xml"
              ]
            },
            "description": "Output format"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Post-processing search"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/search/jobs/{search_id}/events": {
      "get": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "getSearchEvents",
        "summary": "Get events from a search job",
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search job SID"
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "Max events"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Starting index for pagination"
          },
          {
            "name": "earliest_time",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Earliest time filter"
          },
          {
            "name": "latest_time",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Latest time filter"
          },
          {
            "name": "field_list",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated fields"
          },
          {
            "name": "max_lines",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Max lines per event raw field"
          },
          {
            "name": "output_mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "atom",
                "json",
                "csv",
                "xml"
              ],
              "default": "json"
            },
            "description": "Response format"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Post-processing search"
          },
          {
            "name": "segmentation",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Event segmentation type"
          },
          {
            "name": "truncation_mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "abstract",
                "truncate"
              ]
            },
            "description": "Truncation mode"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/search/jobs/{search_id}/summary": {
      "get": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "getSearchSummary",
        "summary": "Get field summary for search results",
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search job SID"
          },
          {
            "name": "output_mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "atom",
                "json",
                "csv",
                "xml"
              ],
              "default": "json"
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SplunkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/search/jobs/{search_id}/timeline": {
      "get": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "getSearchTimeline",
        "summary": "Get search timeline data",
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search job SID"
          },
          {
            "name": "output_mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "atom",
                "json",
                "csv",
                "xml"
              ],
              "default": "json"
            },
            "description": "Response format"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SplunkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/search/jobs/{search_id}/search.log": {
      "get": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "getSearchLog",
        "summary": "Get search log for the job",
        "parameters": [
          {
            "name": "search_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search job SID"
          },
          {
            "name": "attachment",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Return as attachment"
          }
        ],
        "responses": {
          "200": {
            "description": "Search log content",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/services/search/jobs/export": {
      "post": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "exportSearchResults",
        "summary": "Stream search results without creating a job",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "search"
                ],
                "properties": {
                  "search": {
                    "type": "string",
                    "description": "SPL query"
                  },
                  "earliest_time": {
                    "type": "string"
                  },
                  "latest_time": {
                    "type": "string"
                  },
                  "output_mode": {
                    "type": "string"
                  },
                  "segmentation": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/services/search/parser": {
      "get": {
        "tags": [
          "Search Jobs"
        ],
        "operationId": "parseSearchQuery",
        "summary": "Parse a search query",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
