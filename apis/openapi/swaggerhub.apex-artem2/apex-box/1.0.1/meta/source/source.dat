        "responses": {
          "200": {
            "description": "\u0423\u0441\u043f\u0435\u0448\u043d\u044b\u0439 \u043e\u0442\u0432\u0435\u0442",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "ProgramId": {
                        "type": "integer",
                        "description": "Id \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b",
                        "example": 1
                      },
                      "name_ru": {
                        "type": "string",
                        "description": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u0433\u0430\u0437\u0430 \u043d\u0430 \u0440\u0443\u0441\u0441\u043a\u043e\u043c",
                        "example": "\u041c\u0435\u0442\u0430\u043d"
                      },
                      "name_eng": {
                        "type": "string",
                        "description": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u0433\u0430\u0437\u0430 \u043d\u0430 \u0430\u043d\u0433\u043b\u0438\u0439\u0441\u043a\u043e\u043c",
                        "example": "Methane"
                      },
                      "InsurancePeriod": {
                        "type": "integer",
                        "description": "\u041f\u0435\u0440\u0438\u043e\u0434 \u0432 \u043c\u0435\u0441\u044f\u0446\u0430\u0445",
                        "example": 12
                      },
                      "InsuranceSum": {
                        "type": "integer",
                        "description": "\u0421\u0442\u0440\u0430\u0445\u043e\u0432\u0430\u044f \u0441\u0443\u043c\u043c\u0430 (\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0441\u0442\u044c)",
                        "example": 6000000
                      },
                      "insurancePremium": {
                        "type": "integer",
                        "description": "\u0421\u0442\u0440\u0430\u0445\u043e\u0432\u0430\u044f \u043f\u0440\u0435\u043c\u0438\u044f",
                        "example": 25000
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "\u041e\u0448\u0438\u0431\u043a\u0430 \u0430\u0443\u0442\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "description": "\u0421\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0435 \u043e\u0431 \u043e\u0448\u0438\u0431\u043a\u0435",
                      "example": "\u041f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u043d\u0435 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u043e\u0432\u0430\u043d"
                    }
                  }
                }
