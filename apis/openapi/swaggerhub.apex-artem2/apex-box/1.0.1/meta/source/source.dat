    "/kaskogaz_calc": {
      "get": {
        "summary": "\u0420\u0430\u0441\u0447\u0435\u0442 \u0441\u0442\u0440\u0430\u0445\u043e\u0432\u043e\u0439 \u043f\u0440\u0435\u043c\u0438\u0438",
        "tags": [
          "\u0421\u0442\u0440\u0430\u0445\u043e\u0432\u0430\u043d\u0438\u0435 \u041a\u0410\u0421\u041a\u041e \u0413\u0410\u0417"
