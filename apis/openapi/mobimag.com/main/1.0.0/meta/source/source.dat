{
  "openapi": "3.0.3",
  "info": {
    "title": "Mobimag API",
    "description": "Mobimag is a platform for publishing and monetizing magazines. This API allows managing contacts and publications.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://documenter.getpostman.com/view/836597/T1LJkU4K"
  },
  "servers": [
    {
      "url": "https://us-central1-mobimagprod.cloudfunctions.net/contacts",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": [],
      "emailAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication operations"
    },
    {
      "name": "Publications",
      "description": "Publication management"
    },
    {
      "name": "Contacts",
      "description": "Contact management"
    }
  ],
  "paths": {
    "/auth": {
      "get": {
        "operationId": "authenticateUser",
        "summary": "Authenticate user",
        "description": "Check that the user's API key and email address is valid.",
        "tags": [
          "Authentication"
        ],
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key or email",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/publications": {
      "get": {
        "operationId": "listPublications",
        "summary": "List user publications",
        "description": "Retrieve a list of publications belonging to the authenticated user.",
        "tags": [
          "Publications"
        ],
        "responses": {
          "200": {
            "description": "List of publications",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Publication"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/list": {
      "get": {
        "operationId": "listContacts",
        "summary": "List contacts",
        "description": "Retrieve a list of contacts for a specific publication.",
        "tags": [
          "Contacts"
        ],
        "parameters": [
          {
            "name": "publication",
            "in": "query",
            "required": true,
            "description": "The publication identifier to filter contacts by",
            "schema": {
              "type": "string"
            },
            "example": "my-publication"
          }
        ],
        "responses": {
          "200": {
            "description": "List of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Contact"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/create": {
      "post": {
        "operationId": "createContact",
        "summary": "Create a contact",
        "description": "Create a new contact for a publication.",
        "tags": [
          "Contacts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateContactRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Contact"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY",
        "description": "API key for authentication"
      },
      "emailAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-EMAIL",
        "description": "Email address associated with the API key"
      }
    },
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean",
            "description": "Whether authentication was successful"
          }
        }
      },
      "Publication": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Publication identifier"
          },
          "name": {
            "type": "string",
            "description": "Publication name"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Contact name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email address"
          },
          "publication": {
            "type": "string",
            "description": "Associated publication identifier"
          },
          "edition": {
            "type": "string",
            "description": "Associated edition/issue identifier"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of contact creation"
          }
        }
      },
      "CreateContactRequest": {
        "type": "object",
        "required": [
          "name",
          "email",
          "publication"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Contact name",
            "example": "John Appleseed"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact email",
            "example": "john@appleseed.com"
          },
          "publication": {
            "type": "string",
            "description": "Publication identifier",
            "example": "my-publication"
          },
          "edition": {
            "type": "string",
            "description": "Edition/issue identifier",
            "example": "my-issue"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp",
            "example": "2020-08-03T03:54:22+0000"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}