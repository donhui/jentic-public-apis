{
  "openapi": "3.0.3",
  "info": {
    "title": "SkootEco API",
    "description": "SkootEco is an accredited climate platform that lets you plant trees, recover plastic, buy carbon offset, and showcase your climate impact.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://skootuk.github.io/public-documentation/#introduction"
  },
  "servers": [
    {
      "url": "https://api.skoot.eco"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "API key validation"
    },
    {
      "name": "Profiles",
      "description": "Profile and allocation operations"
    }
  ],
  "paths": {
    "/api/key/validate": {
      "get": {
        "operationId": "validateApiKey",
        "summary": "Validate API token",
        "description": "Check if an API token is valid.",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Token is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KeyValidationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/profile/{profileId}": {
      "get": {
        "operationId": "getProfile",
        "summary": "Get profile by ID",
        "description": "Retrieve profile information and statistics including trees planted, plastic recovered, and carbon offset.",
        "tags": ["Profiles"],
        "parameters": [
          {
            "name": "profileId",
            "in": "path",
            "required": true,
            "description": "The profile identifier.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Profile"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/profile/{profileId}/allocate": {
      "patch": {
        "operationId": "makeAllocation",
        "summary": "Make an allocation",
        "description": "Allocate trees, plastic bottles, or carbon offset to a profile. Limits: 100 trees/bottles per request, 5t carbon per request.",
        "tags": ["Profiles"],
        "parameters": [
          {
            "name": "profileId",
            "in": "path",
            "required": true,
            "description": "The target profile identifier.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AllocationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Allocation successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Profile"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "KeyValidationResponse": {
        "type": "object",
        "properties": {
          "valid": {
            "type": "string",
            "description": "Validation status",
            "example": "True"
          },
          "_id": {
            "type": "string",
            "description": "Key identifier"
          }
        }
      },
      "AllocationRequest": {
        "type": "object",
        "required": ["allocations"],
        "properties": {
          "metadata": {
            "type": "object",
            "properties": {
              "activity": {
                "type": "string",
                "description": "Activity description"
              },
              "via": {
                "type": "string",
                "description": "Allocation source"
              },
              "with": {
                "type": "string",
                "description": "Allocation context"
              }
            }
          },
          "allocations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Allocation"
            }
          }
        }
      },
      "Allocation": {
        "type": "object",
        "required": ["type", "quantity", "unit"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Type of allocation (trees, plastic, carbon)",
            "enum": ["trees", "plastic", "carbon"]
          },
          "quantity": {
            "type": "number",
            "description": "Quantity to allocate"
          },
          "unit": {
            "type": "string",
            "description": "Unit of measurement"
          },
          "project_id": {
            "type": "string",
            "description": "Optional project identifier for carbon offset"
          }
        }
      },
      "Profile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Profile identifier"
          },
          "statistics": {
            "type": "object",
            "properties": {
              "trees": {
                "type": "integer",
                "description": "Total trees planted"
              },
              "plastic": {
                "type": "integer",
                "description": "Total plastic bottles recovered"
              },
              "carbon_projects": {
                "type": "number",
                "description": "Total carbon offset in metric tonnes"
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}