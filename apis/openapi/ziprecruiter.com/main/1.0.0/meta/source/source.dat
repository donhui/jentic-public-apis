{
  "openapi": "3.0.3",
  "info": {
    "title": "ZipRecruiter Job Search API",
    "description": "The ZipRecruiter Job Search API allows publishers to search for job listings across ZipRecruiter's marketplace. Publishers can integrate job search functionality into their websites and applications.",
    "version": "1.0.0",
    "contact": {
      "name": "ZipRecruiter Publisher Support",
      "url": "https://www.ziprecruiter.com/publishers"
    },
    "x-jentic-source-url": "https://www.ziprecruiter.com/publishers"
  },
  "servers": [
    {
      "url": "https://api.ziprecruiter.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Jobs",
      "description": "Job search operations"
    }
  ],
  "paths": {
    "/jobs/v1": {
      "get": {
        "operationId": "searchJobs",
        "summary": "Search for jobs",
        "description": "Search for job listings on ZipRecruiter matching the specified criteria. Returns paginated results with job details.",
        "tags": ["Jobs"],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search keywords or job title.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "location",
            "in": "query",
            "description": "Location to search (city, state, or ZIP code).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "radius_miles",
            "in": "query",
            "description": "Search radius in miles from the specified location.",
            "schema": {
              "type": "integer",
              "default": 25
            }
          },
          {
            "name": "days_ago",
            "in": "query",
            "description": "Filter to jobs posted within the specified number of days.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "jobs_per_page",
            "in": "query",
            "description": "Number of results per page.",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number for pagination.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "Publisher API key.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "refine_by_salary",
            "in": "query",
            "description": "Filter by minimum annual salary.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "refine_by_tags",
            "in": "query",
            "description": "Filter by job tags (e.g. employment_type:full_time).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful job search results.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid or missing parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Invalid API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden. API key does not have access.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "Publisher API key obtained through the ZipRecruiter publisher program."
      }
    },
    "schemas": {
      "JobSearchResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the request was successful."
          },
          "num_paginable_jobs": {
            "type": "integer",
            "description": "Total number of jobs available for pagination."
          },
          "total_jobs": {
            "type": "integer",
            "description": "Total number of matching jobs."
          },
          "jobs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Job"
            }
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique job identifier."
          },
          "name": {
            "type": "string",
            "description": "Job title."
          },
          "snippet": {
            "type": "string",
            "description": "Brief job description snippet."
          },
          "hiring_company": {
            "$ref": "#/components/schemas/Company"
          },
          "location": {
            "type": "string",
            "description": "Job location."
          },
          "city": {
            "type": "string",
            "description": "City name."
          },
          "state": {
            "type": "string",
            "description": "State code."
          },
          "country": {
            "type": "string",
            "description": "Country code."
          },
          "posted_time": {
            "type": "string",
            "format": "date-time",
            "description": "When the job was posted."
          },
          "posted_time_friendly": {
            "type": "string",
            "description": "Human-readable posting time (e.g. '2 days ago')."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the job listing."
          },
          "source": {
            "type": "string",
            "description": "Source of the job listing."
          },
          "salary_min": {
            "type": "number",
            "nullable": true,
            "description": "Minimum salary."
          },
          "salary_max": {
            "type": "number",
            "nullable": true,
            "description": "Maximum salary."
          },
          "salary_min_annual": {
            "type": "number",
            "nullable": true,
            "description": "Annualized minimum salary."
          },
          "salary_max_annual": {
            "type": "number",
            "nullable": true,
            "description": "Annualized maximum salary."
          },
          "salary_interval": {
            "type": "string",
            "nullable": true,
            "description": "Salary interval (e.g. yearly, monthly, hourly)."
          },
          "job_age": {
            "type": "integer",
            "description": "Age of the posting in days."
          },
          "category": {
            "type": "string",
            "nullable": true,
            "description": "Job category."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Job tags."
          }
        }
      },
      "Company": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Company name."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "Company URL."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Always false for errors."
          },
          "error": {
            "type": "string",
            "description": "Error message."
          },
          "error_code": {
            "type": "string",
            "description": "Machine-readable error code."
          }
        }
      }
    }
  }
}
