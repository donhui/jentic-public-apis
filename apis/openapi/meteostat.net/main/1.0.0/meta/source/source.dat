{
  "openapi": "3.0.3",
  "info": {
    "title": "Meteostat JSON API",
    "version": "1.0.0",
    "description": "The Meteostat JSON API provides access to a large archive of historical weather and climate data. Records are queried by weather station or geo location and can be filtered by date range. Hosted on RapidAPI.",
    "x-jentic-source-url": "https://dev.meteostat.net/"
  },
  "servers": [
    {
      "url": "https://meteostat.p.rapidapi.com",
      "description": "Meteostat API via RapidAPI"
    }
  ],
  "security": [
    {
      "rapidApiKey": []
    }
  ],
  "tags": [
    { "name": "Stations", "description": "Weather station endpoints" },
    { "name": "PointData", "description": "Point (geo location) data endpoints" }
  ],
  "paths": {
    "/stations/nearby": {
      "get": {
        "operationId": "getNearbyStations",
        "summary": "Find nearby weather stations by geo location",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "description": "Latitude of the location",
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "lon",
            "in": "query",
            "required": true,
            "description": "Longitude of the location",
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "radius",
            "in": "query",
            "description": "Radius of the query in meters",
            "schema": { "type": "integer", "default": 100000 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of nearby stations",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NearbyStationsResponse" }
              }
            }
          },
          "400": { "description": "Bad Request - check query parameters" },
          "401": { "description": "Unauthorized - invalid RapidAPI key" }
        }
      }
    },
    "/stations/meta": {
      "get": {
        "operationId": "getStationMeta",
        "summary": "Get meta data for a weather station",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "The Meteostat ID of the weather station",
            "schema": { "type": "string" }
          },
          {
            "name": "wmo",
            "in": "query",
            "description": "The WMO ID of the weather station",
            "schema": { "type": "integer" }
          },
          {
            "name": "icao",
            "in": "query",
            "description": "The ICAO ID of the weather station",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Station meta data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StationMetaResponse" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/stations/hourly": {
      "get": {
        "operationId": "getStationHourlyData",
        "summary": "Get hourly weather data for a station",
        "description": "Historical hourly observations for a weather station. Max 30 days per request.",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "station",
            "in": "query",
            "required": true,
            "description": "The weather station ID",
            "schema": { "type": "string" }
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "description": "Start date (YYYY-MM-DD)",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "description": "End date (YYYY-MM-DD)",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "tz",
            "in": "query",
            "description": "Time zone (tz database format)",
            "schema": { "type": "string", "default": "UTC" }
          },
          {
            "name": "model",
            "in": "query",
            "description": "Fill gaps with model data",
            "schema": { "type": "string", "default": "true" }
          },
          {
            "name": "freq",
            "in": "query",
            "description": "Time frequency for custom aggregation",
            "schema": { "type": "string" }
          },
          {
            "name": "units",
            "in": "query",
            "description": "Unit system (metric, imperial, scientific)",
            "schema": { "type": "string", "default": "metric", "enum": ["metric", "imperial", "scientific"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Hourly weather data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HourlyDataResponse" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/stations/daily": {
      "get": {
        "operationId": "getStationDailyData",
        "summary": "Get daily weather data for a station",
        "description": "Historical daily statistics for a weather station. Max 10 years per request.",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "station",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "model",
            "in": "query",
            "schema": { "type": "string", "default": "true" }
          },
          {
            "name": "freq",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "units",
            "in": "query",
            "schema": { "type": "string", "default": "metric", "enum": ["metric", "imperial", "scientific"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily weather data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DailyDataResponse" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/stations/monthly": {
      "get": {
        "operationId": "getStationMonthlyData",
        "summary": "Get monthly weather data for a station",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "station",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "model",
            "in": "query",
            "schema": { "type": "string", "default": "true" }
          },
          {
            "name": "freq",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "units",
            "in": "query",
            "schema": { "type": "string", "default": "metric", "enum": ["metric", "imperial", "scientific"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Monthly weather data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MonthlyDataResponse" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/stations/normals": {
      "get": {
        "operationId": "getStationClimateNormals",
        "summary": "Get climate normals for a weather station",
        "description": "Long-term averages of historical weather observations, typically calculated over 30-year periods.",
        "tags": ["Stations"],
        "parameters": [
          {
            "name": "station",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start year (YYYY)",
            "schema": { "type": "string" }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End year (YYYY)",
            "schema": { "type": "string" }
          },
          {
            "name": "units",
            "in": "query",
            "schema": { "type": "string", "default": "metric", "enum": ["metric", "imperial", "scientific"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Climate normals data (12 months)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ClimateNormalsResponse" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/point/hourly": {
      "get": {
        "operationId": "getPointHourlyData",
        "summary": "Get hourly weather data for a geographic location",
        "description": "Historical hourly observations for any geographic location. Max 30 days per request.",
        "tags": ["PointData"],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "lon",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "alt",
            "in": "query",
            "description": "Elevation in meters",
            "schema": { "type": "integer" }
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "tz",
            "in": "query",
            "schema": { "type": "string", "default": "UTC" }
          },
          {
            "name": "model",
            "in": "query",
            "schema": { "type": "string", "default": "true" }
          },
          {
            "name": "freq",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "units",
            "in": "query",
            "schema": { "type": "string", "default": "metric", "enum": ["metric", "imperial", "scientific"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Hourly weather data for location",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HourlyDataResponse" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/point/daily": {
      "get": {
        "operationId": "getPointDailyData",
        "summary": "Get daily weather data for a geographic location",
        "tags": ["PointData"],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "lon",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "alt",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "model",
            "in": "query",
            "schema": { "type": "string", "default": "true" }
          },
          {
            "name": "freq",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "units",
            "in": "query",
            "schema": { "type": "string", "default": "metric", "enum": ["metric", "imperial", "scientific"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily weather data for location",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DailyDataResponse" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/point/monthly": {
      "get": {
        "operationId": "getPointMonthlyData",
        "summary": "Get monthly weather data for a geographic location",
        "tags": ["PointData"],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "lon",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "alt",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "start",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "end",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "model",
            "in": "query",
            "schema": { "type": "string", "default": "true" }
          },
          {
            "name": "freq",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "units",
            "in": "query",
            "schema": { "type": "string", "default": "metric", "enum": ["metric", "imperial", "scientific"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Monthly weather data for location",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MonthlyDataResponse" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/point/normals": {
      "get": {
        "operationId": "getPointClimateNormals",
        "summary": "Get climate normals for a geographic location",
        "tags": ["PointData"],
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "lon",
            "in": "query",
            "required": true,
            "schema": { "type": "number", "format": "float" }
          },
          {
            "name": "alt",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start year (YYYY)",
            "schema": { "type": "string" }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End year (YYYY)",
            "schema": { "type": "string" }
          },
          {
            "name": "units",
            "in": "query",
            "schema": { "type": "string", "default": "metric", "enum": ["metric", "imperial", "scientific"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Climate normals for location",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ClimateNormalsResponse" }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "rapidApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-RapidAPI-Key",
        "description": "Your RapidAPI key"
      }
    },
    "schemas": {
      "MetaInfo": {
        "type": "object",
        "properties": {
          "exec_time": { "type": "number", "description": "Execution time in seconds" },
          "generated": { "type": "string", "description": "Timestamp of response generation" }
        }
      },
      "NearbyStationsResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/MetaInfo" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/NearbyStation" }
          }
        }
      },
      "NearbyStation": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Meteostat station ID" },
          "name": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Station name in different languages"
          },
          "distance": { "type": "number", "description": "Distance in meters" }
        }
      },
      "StationMetaResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/MetaInfo" },
          "data": { "$ref": "#/components/schemas/StationMeta" }
        }
      },
      "StationMeta": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "country": { "type": "string", "description": "ISO 3166-1 alpha-2 code" },
          "region": { "type": "string", "description": "ISO 3166-2 region code" },
          "identifier": {
            "type": "object",
            "properties": {
              "national": { "type": "string" },
              "wmo": { "type": "string" },
              "icao": { "type": "string" }
            }
          },
          "location": {
            "type": "object",
            "properties": {
              "latitude": { "type": "number" },
              "longitude": { "type": "number" },
              "elevation": { "type": "integer" }
            }
          },
          "timezone": { "type": "string" },
          "inventory": { "$ref": "#/components/schemas/StationInventory" }
        }
      },
      "StationInventory": {
        "type": "object",
        "properties": {
          "model": { "$ref": "#/components/schemas/DateRange" },
          "hourly": { "$ref": "#/components/schemas/DateRange" },
          "daily": { "$ref": "#/components/schemas/DateRange" },
          "monthly": { "$ref": "#/components/schemas/YearRange" },
          "normals": { "$ref": "#/components/schemas/YearRange" }
        }
      },
      "DateRange": {
        "type": "object",
        "properties": {
          "start": { "type": "string" },
          "end": { "type": "string" }
        }
      },
      "YearRange": {
        "type": "object",
        "properties": {
          "start": { "type": "integer" },
          "end": { "type": "integer" }
        }
      },
      "HourlyDataResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/MetaInfo" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/HourlyRecord" }
          }
        }
      },
      "HourlyRecord": {
        "type": "object",
        "properties": {
          "time": { "type": "string", "description": "YYYY-MM-DD hh:mm:ss" },
          "temp": { "type": "number", "description": "Air temperature in C" },
          "dwpt": { "type": "number", "description": "Dew point in C" },
          "rhum": { "type": "integer", "description": "Relative humidity %" },
          "prcp": { "type": "number", "description": "One hour precipitation in mm" },
          "snow": { "type": "integer", "description": "Snow depth in mm" },
          "wdir": { "type": "integer", "description": "Wind direction in degrees" },
          "wspd": { "type": "number", "description": "Average wind speed in km/h" },
          "wpgt": { "type": "number", "description": "Peak wind gust in km/h" },
          "pres": { "type": "number", "description": "Sea-level air pressure in hPa" },
          "tsun": { "type": "integer", "description": "Sunshine total in minutes" },
          "coco": { "type": "integer", "description": "Weather condition code" }
        }
      },
      "DailyDataResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/MetaInfo" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/DailyRecord" }
          }
        }
      },
      "DailyRecord": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "description": "YYYY-MM-DD" },
          "tavg": { "type": "number", "description": "Average air temperature in C" },
          "tmin": { "type": "number", "description": "Minimum air temperature in C" },
          "tmax": { "type": "number", "description": "Maximum air temperature in C" },
          "prcp": { "type": "number", "description": "Daily precipitation in mm" },
          "snow": { "type": "integer", "description": "Maximum snow depth in mm" },
          "wdir": { "type": "integer", "description": "Average wind direction in degrees" },
          "wspd": { "type": "number", "description": "Average wind speed in km/h" },
          "wpgt": { "type": "number", "description": "Peak wind gust in km/h" },
          "pres": { "type": "number", "description": "Average sea-level pressure in hPa" },
          "tsun": { "type": "integer", "description": "Daily sunshine in minutes" }
        }
      },
      "MonthlyDataResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/MetaInfo" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/MonthlyRecord" }
          }
        }
      },
      "MonthlyRecord": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "description": "First date of the month YYYY-MM-DD" },
          "tavg": { "type": "number" },
          "tmin": { "type": "number" },
          "tmax": { "type": "number" },
          "prcp": { "type": "number" },
          "snow": { "type": "integer" },
          "wdir": { "type": "integer" },
          "wspd": { "type": "number" },
          "wpgt": { "type": "number" },
          "pres": { "type": "number" },
          "tsun": { "type": "integer" }
        }
      },
      "ClimateNormalsResponse": {
        "type": "object",
        "properties": {
          "meta": { "$ref": "#/components/schemas/MetaInfo" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ClimateNormal" }
          }
        }
      },
      "ClimateNormal": {
        "type": "object",
        "properties": {
          "month": { "type": "integer", "description": "Month number (1-12)" },
          "tavg": { "type": "number", "description": "Mean temperature in C" },
          "tmin": { "type": "number", "description": "Average minimum temperature in C" },
          "tmax": { "type": "number", "description": "Average maximum temperature in C" },
          "prcp": { "type": "integer", "description": "Average precipitation in mm" },
          "pres": { "type": "number", "description": "Average sea-level pressure in hPa" },
          "tsun": { "type": "integer", "description": "Average sunshine in minutes" }
        }
      }
    }
  }
}