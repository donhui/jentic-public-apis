            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v3/standard-template/{id}/example": {
      "get": {
        "operationId": "getStandardTemplateExample",
        "summary": "Get standard template example",
        "description": "Retrieve example slide content data for a standard template.",
        "tags": ["Standard Templates"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Template identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TemplateExample" }
