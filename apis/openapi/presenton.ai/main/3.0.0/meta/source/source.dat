          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v3/webhook/unsubscribe": {
      "delete": {
        "operationId": "unsubscribeFromWebhook",
        "summary": "Unsubscribe from webhook",
        "description": "Remove an existing webhook subscription.",
        "tags": ["Webhooks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "The ID of the webhook subscription to unsubscribe from"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Successfully unsubscribed"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v3/webhook/unsubscribe/all": {
      "delete": {
        "operationId": "unsubscribeAllWebhooks",
        "summary": "Unsubscribe from all webhooks",
        "description": "Unsubscribe from all webhook subscriptions of the user.",
        "tags": ["Webhooks"],
        "responses": {
          "204": {
            "description": "Successfully unsubscribed from all webhooks"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API Key in format sk-presenton-xxxxxxxx or JWT token"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "HTTPValidationError": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ValidationError" }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": ["loc", "msg", "type"],
        "properties": {
          "loc": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                { "type": "integer" }
              ]
            },
            "description": "Error location"
          },
          "msg": {
            "type": "string",
            "description": "Error message"
          },
          "type": {
            "type": "string",
            "description": "Error type"
          }
        }
      },
      "AsyncTaskModel": {
        "type": "object",
        "required": ["message", "created_at", "updated_at"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Task identifier"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "completed", "error"],
            "default": "pending",
            "description": "Task status"
          },
          "message": {
            "type": "string",
            "description": "Status message"
          },
          "data": {
            "type": "object",
            "nullable": true,
            "description": "Result payload if task completed"
          },
          "error": {
            "type": "object",
            "nullable": true,
            "description": "Error details if task failed"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Task creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        }
      },
      "ImageAsset": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier"
          },
          "user": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "Associated user ID"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of creation"
          },
          "path": {
            "type": "string",
            "description": "File storage path"
          },
          "is_uploaded": {
            "type": "boolean",
            "default": false,
            "description": "Upload status"
          },
          "extras": {
            "type": "object",
            "nullable": true,
            "description": "Additional metadata"
          },
          "url": {
            "type": "string",
            "nullable": true,
            "description": "Accessible URL to the asset"
          }
        }
      },
      "GeneratePresentationRequest": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "nullable": true,
            "description": "The content for generating the presentation"
          },
          "slides": {
            "type": "array",
            "nullable": true,
            "items": { "type": "object" },
            "description": "Content and layout for each slide"
          },
          "n_slides": {
            "type": "integer",
            "nullable": true,
            "description": "Number of slides to generate"
          },
          "instructions": {
            "type": "string",
            "nullable": true,
            "description": "Instructions for presentation generation"
          },
          "tone": {
            "type": "string",
            "enum": ["default", "casual", "professional", "funny", "educational", "sales_pitch"],
            "default": "default",
            "description": "Presentation tone"
          },
          "verbosity": {
            "type": "string",
            "enum": ["concise", "standard", "text-heavy"],
            "default": "standard",
            "description": "Content verbosity level"
          },
          "content_generation": {
            "type": "string",
            "nullable": true,
            "enum": ["preserve", "enhance", "condense"],
            "description": "Content generation mode"
          },
          "markdown_emphasis": {
            "type": "boolean",
            "default": true,
            "description": "Enable markdown emphasis"
          },
          "web_search": {
            "type": "boolean",
            "default": false,
            "description": "Enable web search for content"
          },
          "image_type": {
            "type": "string",
            "enum": ["stock", "ai-generated"],
            "default": "stock",
            "description": "Type of images to use"
          },
          "theme": {
            "type": "string",
            "nullable": true,
            "description": "Theme name (e.g., edge-yellow, light-rose, mint-blue, professional-blue, professional-dark)"
          },
          "language": {
            "type": "string",
            "nullable": true,
            "description": "Presentation language"
          },
          "standard_template": {
            "type": "string",
            "nullable": true,
            "description": "Template name (e.g., neo-general, neo-modern, neo-standard, neo-swift, general, modern, standard, swift)"
          },
          "smart_design": {
            "type": "string",
            "nullable": true,
            "description": "Smart design selection"
          },
          "include_table_of_contents": {
            "type": "boolean",
            "default": false,
            "description": "Include table of contents slide"
          },
          "include_title_slide": {
            "type": "boolean",
            "default": true,
            "description": "Include title slide"
          },
          "allow_access_to_user_info": {
            "type": "boolean",
            "default": true,
            "description": "Allow access to user information"
          },
          "files": {
            "type": "array",
            "nullable": true,
            "items": { "type": "string" },
            "description": "File IDs uploaded via /api/v3/files/upload"
          },
          "export_as": {
            "type": "string",
            "enum": ["pptx", "pdf", "png"],
            "default": "pptx",
            "description": "Export format"
          },
          "trigger_webhook": {
            "type": "boolean",
            "default": false,
            "description": "Trigger subscribed webhooks on completion"
          }
        }
      },
      "GenerateOutlinesRequest": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "nullable": true,
            "description": "The content for generating the presentation"
          },
          "files": {
            "type": "array",
            "nullable": true,
            "items": { "type": "string" },
            "description": "Files to use for the presentation"
          },
          "n_slides": {
            "type": "integer",
            "nullable": true,
            "description": "Number of slides to generate"
          },
          "language": {
            "type": "string",
            "nullable": true,
            "description": "Presentation language"
          },
          "tone": {
            "type": "string",
            "enum": ["default", "casual", "professional", "funny", "educational", "sales_pitch"],
            "default": "default",
            "description": "Tone style"
          },
          "verbosity": {
            "type": "string",
            "enum": ["concise", "standard", "text-heavy"],
            "default": "standard",
            "description": "Detail level"
          },
          "content_generation": {
            "type": "string",
            "nullable": true,
            "enum": ["preserve", "enhance", "condense"],
            "description": "Content generation mode"
          },
          "include_title_slide": {
            "type": "boolean",
            "default": true,
            "description": "Include title slide"
          },
          "allow_access_to_user_info": {
            "type": "boolean",
            "default": true,
            "description": "Allow access to user information"
          },
          "instructions": {
            "type": "string",
            "nullable": true,
            "description": "Custom instructions"
          }
        }
      },
      "CreateFromJsonRequest": {
        "type": "object",
        "properties": {
          "language": {
            "type": "string",
            "default": "English",
            "description": "Presentation language"
          },
          "title": {
            "type": "string",
            "nullable": true,
            "description": "Presentation title"
          },
          "standard_template": {
            "type": "string",
            "default": "general",
            "description": "Template selection"
          },
          "theme": {
            "type": "string",
            "nullable": true,
            "description": "Theme selection"
          },
          "slides": {
            "type": "array",
            "items": { "type": "object" },
            "default": [],
            "description": "Array of slide objects with layout and content"
          },
          "export_as": {
            "type": "string",
            "enum": ["pptx", "pdf", "png"],
            "default": "pptx",
            "description": "Output format"
          },
          "trigger_webhook": {
            "type": "boolean",
            "default": false,
            "description": "Trigger subscribed webhooks"
          }
        }
      },
      "PresentationResult": {
        "type": "object",
        "properties": {
          "presentation_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique presentation identifier"
          },
          "path": {
            "type": "string",
            "description": "Presentation file path"
          },
          "edit_path": {
            "type": "string",
            "description": "URL for editing the presentation"
          },
          "credits_consumed": {
            "type": "number",
            "description": "Credits used for generation"
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "total_pages": {
            "type": "integer",
            "description": "Total number of pages"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "page_size": {
            "type": "integer",
            "description": "Items per page"
          },
          "results": {
            "type": "array",
            "items": { "type": "object" },
            "description": "Result items"
          }
        }
      },
      "StandardTemplateSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Template identifier"
          },
          "name": {
            "type": "string",
            "description": "Template name"
          },
          "total_layouts": {
            "type": "integer",
            "nullable": true,
            "description": "Total number of layouts"
          }
        }
      },
      "StandardTemplate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Template name"
          },
          "ordered": {
            "type": "boolean",
            "default": false,
            "description": "Whether slides are ordered"
          },
          "slides": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TemplateSlide" },
            "description": "Collection of slide layouts"
          }
        }
      },
      "TemplateSlide": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Slide identifier"
          },
          "name": {
            "type": "string",
            "nullable": true,
            "description": "Slide name"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Slide description"
          },
          "json_schema": {
            "type": "object",
            "description": "JSON schema defining slide structure"
          }
        }
      },
      "TemplateExample": {
        "type": "object",
        "properties": {
          "standard_template": {
            "type": "string",
            "description": "Template name"
          },
          "slides": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "layout": {
                  "type": "string",
                  "description": "Layout type"
                },
                "content": {
                  "type": "object",
                  "description": "Content data"
                }
              }
            },
            "description": "Example slides"
          }
        }
      },
      "WebhookSubscribeRequest": {
        "type": "object",
        "required": ["url", "event"],
        "properties": {
          "url": {
            "type": "string",
            "description": "The URL to send the webhook to"
          },
          "secret": {
            "type": "string",
            "nullable": true,
            "description": "The secret to use for webhook verification"
          },
          "event": {
            "type": "string",
            "enum": ["presentation.generation.completed", "presentation.generation.failed"],
            "description": "The event to subscribe to"
          }
        }
      },
      "WebhookSubscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Webhook subscription identifier"
          },
          "url": {
            "type": "string",
            "description": "Registered webhook URL"
          },
          "event": {
            "type": "string",
            "enum": ["presentation.generation.completed", "presentation.generation.failed"],
            "description": "Subscribed event type"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Subscription creation timestamp"
          }
        }
      }
    }
  }
}