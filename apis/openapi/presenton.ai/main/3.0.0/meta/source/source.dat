          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v3/standard-template/all": {
      "get": {
        "operationId": "getAllStandardTemplates",
        "summary": "Get all standard templates",
        "description": "Retrieve all available standard templates.",
        "tags": ["Standard Templates"],
        "parameters": [
          {
            "name": "include_defaults",
            "in": "query",
            "schema": { "type": "boolean", "default": true },
            "description": "Whether to include default templates"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/StandardTemplateSummary" }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/v3/standard-template/{id}": {
      "get": {
        "operationId": "getStandardTemplateById",
        "summary": "Get standard template by ID",
        "description": "Get a standard template by its identifier.",
        "tags": ["Standard Templates"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Template identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StandardTemplate" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
