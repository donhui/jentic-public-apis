{
  "openapi": "3.0.3",
  "info": {
    "title": "Panther REST API",
    "version": "1.0",
    "description": "The Panther REST API allows interaction with Panther SIEM entities including alerts, API tokens, rules, users, queries, and more. Authentication is via API key passed in the X-API-Key header.",
    "x-jentic-source-url": "https://docs.panther.com/panther-developer-workflows/api/rest"
  },
  "servers": [
    {
      "url": "https://{apiHost}",
      "variables": {
        "apiHost": {
          "default": "api.panther.your-domain.com",
          "description": "Your Panther API host"
        }
      }
    }
  ],
  "paths": {
    "/alerts/{id}": {
      "get": {
        "operationId": "getAlert",
        "summary": "Get an alert by ID",
        "tags": [
          "Alerts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the alert"
          }
        ],
        "responses": {
          "200": {
            "description": "OK response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Alert"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateAlert",
        "summary": "Update the status, assignee, quality or contextTags of an alert",
        "tags": [
          "Alerts"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID of the alert"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateAlertRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK response"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
