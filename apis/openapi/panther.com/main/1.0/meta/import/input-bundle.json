    "/rules": {
      "post": {
        "operationId": "createRule",
        "summary": "Create a Python-based rule",
        "tags": [
          "Rules"
        ],
        "parameters": [
          {
            "name": "run-tests-first",
            "in": "query",
            "description": "Set to false to exclude running tests prior to saving",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "run-tests-only",
            "in": "query",
            "description": "Set to true to run tests without saving",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
