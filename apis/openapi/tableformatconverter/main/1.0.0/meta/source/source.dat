{
  "openapi": "3.0.3",
  "info": {
    "title": "TableConvert API",
    "description": "RESTful API for converting table data between various formats including CSV, Excel, JSON, HTML, Markdown, LaTeX, XML, YAML, and many more. Supports over 370 different conversion combinations.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://tableconvert.com/api/"
  },
  "servers": [
    {
      "url": "https://api.tableconvert.com"
    }
  ],
  "paths": {
    "/convert/csv-to-markdown": {
      "post": {
        "operationId": "convertCsvToMarkdown",
        "summary": "Convert CSV data to Markdown table format",
        "tags": ["Convert"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/ConvertRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Converted data",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Invalid input data" },
          "401": { "description": "Missing or invalid API key" }
        }
      }
    },
    "/convert/excel-to-json": {
      "post": {
        "operationId": "convertExcelToJson",
        "summary": "Convert Excel data to JSON format",
        "tags": ["Convert"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/ConvertRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Converted data",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": { "description": "Invalid input data" },
          "401": { "description": "Missing or invalid API key" }
        }
      }
    },
    "/convert/csv-to-json": {
      "post": {
        "operationId": "convertCsvToJson",
        "summary": "Convert CSV data to JSON format",
        "tags": ["Convert"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/ConvertRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Converted data",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": { "description": "Invalid input data" },
          "401": { "description": "Missing or invalid API key" }
        }
      }
    },
    "/convert/json-to-csv": {
      "post": {
        "operationId": "convertJsonToCsv",
        "summary": "Convert JSON data to CSV format",
        "tags": ["Convert"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/ConvertRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Converted data",
            "content": {
              "text/csv": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Invalid input data" },
          "401": { "description": "Missing or invalid API key" }
        }
      }
    },
    "/convert/html-to-markdown": {
      "post": {
        "operationId": "convertHtmlToMarkdown",
        "summary": "Convert HTML table data to Markdown format",
        "tags": ["Convert"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/ConvertRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Converted data",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Invalid input data" },
          "401": { "description": "Missing or invalid API key" }
        }
      }
    },
    "/convert/markdown-to-html": {
      "post": {
        "operationId": "convertMarkdownToHtml",
        "summary": "Convert Markdown table data to HTML format",
        "tags": ["Convert"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/ConvertRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Converted data",
            "content": {
              "text/html": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Invalid input data" },
          "401": { "description": "Missing or invalid API key" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ConvertRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "string",
            "description": "The table data to convert"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key obtained from TableConvert account"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ]
}