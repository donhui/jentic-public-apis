    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/anexya/audit/2.2.3/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/anexya/audit/2.2.3"
    }
  ],
  "paths": {
    "/audit/api/v1/auth": {
      "put": {
        "tags": [
          "authentication"
        ],
        "summary": "Authenticates to the Audit plugin.",
        "operationId": "authenticate",
        "description": "By passing the username and password, the user is able to authenticate themselves to the Audit plugin. The authentication used in this API is cookie-based authentication. The caller must resend the cookies with each subsequent call.\n",
        "security": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthBody"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Authentication successful",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                },
                "description": "Successfully authenticated. The session ID is returned in a cookie named `JSESSIONID`. You need to include this cookie in subsequent requests.",
                "example": "JSESSIONID=AA67F62F18AD8DFBDCF2869D67A0A115;path=/audit;HttpOnly"
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Bad credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/audit/api/v1/audit/logicaldevices/{logicalDeviceName}/types/audit": {
      "post": {
        "tags": [
          "audit"
        ],
        "summary": "Create and start an audit operation",
        "operationId": "createAndStartOperation",
        "description": "Create and start an audit operation",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "required": true,
            "name": "logicalDeviceName",
            "schema": {
              "type": "string",
              "example": "Hor_Robot_01"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Operation created"
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/audit/api/v1/audit/logicaldevices/{logicalDeviceName}/types/audit/complete": {
      "post": {
        "tags": [
          "audit"
        ],
        "summary": "Complete and stop an already running audit operation",
        "operationId": "completeAndStopOperation",
        "description": "Complete and stop an already running audit operation",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "required": true,
            "name": "logicalDeviceName",
            "schema": {
              "type": "string",
              "example": "Hor_Robot_01"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Operation stopped and completed"
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "JSESSIONID"
      }
    },
    "schemas": {
      "AuthBody": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "example": "operator"
          },
          "password": {
            "type": "string",
            "example": "secret"
          }
        }
      },
      "ErrorResponse": {
        "properties": {
          "error": {
            "type": "string",
            "example": "Error message"
          },
          "code": {
            "type": "integer",
            "example": 400
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "authentication",
      "description": "Calls to authenticate the user"
    },
    {
      "name": "audit",
      "description": "Calls to manupulate the audit operations"
    }
  ]
}