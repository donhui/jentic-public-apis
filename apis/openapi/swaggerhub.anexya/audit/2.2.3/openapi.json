{
  "openapi": "3.0.0",
  "info": {
    "description": "APIs to authenticate and manipulate audit operations.",
    "version": "2.2.3",
    "title": "Basic Audit Plugin APIs",
    "contact": {
      "email": "support@anexya.com"
    },
    "license": {
