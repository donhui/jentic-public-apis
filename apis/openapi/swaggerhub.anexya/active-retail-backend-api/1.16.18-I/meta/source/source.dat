    "/rest/api/v2/brands": {
      "get": {
        "tags": [
          "Brands"
        ],
        "summary": "Get all brands",
        "operationId": "getAllBrands",
        "description": "Retrieves the Brands as an array of Brand objects\n",
        "parameters": [
          {
            "in": "query",
            "name": "continuationToken",
            "required": false,
            "description": "The continuation token is used for pagination. The first call that is made by the client doesn't send a token since there isn't any during the initial call. But later on, if the server returns a continuation token in the response header `AI-ContinuationToken`, that means that there are more records to be fetched and should be sent as query parameter in the next call.",
