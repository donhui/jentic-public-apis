{
  "openapi": "3.0.0",
  "servers": [],
  "info": {
    "description": "This is the Active Retail backend inbound API integration documentation",
    "version": "1.16.18-I",
    "title": "Active Retail backend inbound API",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/anexya/active-retail-backend-api/1.16.18-I/swagger.json"
  },
  "tags": [
    {
      "name": "OAuth",
      "description": "Authentication using OAuth"
    }
  ],
  "paths": {
    "/rest/v2/oauth/token": {
      "post": {
        "tags": [
          "OAuth"
        ],
        "summary": "Get an authentication token",
        "description": "Gets an authentication token.\n\nThe endpoint is protected with the basic authentication. The request must contain an `Authorization`\nheader for basic authentication with REST API client credentials.\nUser credentials must be passed in the request body. The request format must be `application/x-www-form-urlencoded`.\n",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/oauthRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/token"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/oauthError"
                }
              }
            }
          }
        },
        "security": [
          {
            "tokenEndpointBasic": []
          }
        ]
      }
    },
    "/rest/v2/oauth/revoke": {
      "post": {
        "tags": [
          "OAuth"
        ],
        "summary": "Revoke an authentication token",
        "description": "Revokes an authentication token. The endpoint is protected with the basic authentication. The request must\ncontain an `Authorization` header for basic authentication with REST API client credentials.\n",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/tokenRevokeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/rest/api/v2/locations/{name}": {
      "get": {
        "tags": [
          "Locations"
        ],
        "summary": "Get location by name",
        "operationId": "getLocationByName",
        "description": "Retrieves the Location object that matches the name path parameter\n",
        "parameters": [
          {
            "in": "path",
            "name": "name",
            "required": true,
            "description": "The location name",
            "schema": {
              "type": "string",
              "example": "Shipping Dock 01"
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "The access_token is retrieved from /rest/v2/oauth/token. <br/>*Example: Bearer {{access_token}}*\n",
            "schema": {
              "type": "string",
              "example": "Bearer 2YotnFZFEjr1zCsicMWpAA"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Location object matching given name parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/oauthError"
                }
              }
            }
          },
          "404": {
            "description": "Location name was not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "The error related",
                      "example": "Location \"Shipping Dock 01\" not found"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Locations"
        ],
        "summary": "Delete location by name",
        "operationId": "deleteLocationByName",
        "description": "Deletes the Location matching the parameter name\n",
        "parameters": [
          {
            "in": "path",
            "name": "name",
            "required": true,
            "description": "The location name",
            "schema": {
              "type": "string",
              "example": "Shipping Dock 01"
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "The access_token is retrieved from /rest/v2/oauth/token. <br/>*Example: Bearer {{access_token}}*\n",
            "schema": {
              "type": "string",
              "example": "Bearer 2YotnFZFEjr1zCsicMWpAA"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Location was successfully deleted"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/oauthError"
                }
              }
            }
          },
          "404": {
            "description": "Location name was not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "The error related",
                      "example": "Location \"Shipping Dock 01\" not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rest/api/v2/locations/{name}/items": {
      "get": {
        "tags": [
          "Items per location"
        ],
        "summary": "Get items count within a location",
        "operationId": "getItemsCountByLocationName",
        "description": "Retrieves the Location object with the items count\n",
        "parameters": [
          {
            "in": "path",
            "name": "name",
            "required": true,
            "description": "The location name",
            "schema": {
              "type": "string",
              "example": "Shipping Dock 01"
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "The access_token is retrieved from /rest/v2/oauth/token. <br/>*Example: Bearer {{access_token}}*\n",
            "schema": {
              "type": "string",
              "example": "Bearer 2YotnFZFEjr1zCsicMWpAA"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Location object matching given name parameter along with the number of items per barcode within the location",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemsCountByLocationNameResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/oauthError"
                }
              }
            }
          },
          "404": {
            "description": "Location name was not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "The error related",
                      "example": "Location \"Shipping Dock 01\" not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rest/api/v2/locations": {
      "get": {
        "tags": [
          "Locations"
        ],
        "summary": "Get all locations",
        "operationId": "getAllLocations",
        "description": "Retrieves all Locations as an array of Location objects\n",
        "parameters": [
          {
            "in": "query",
            "name": "continuationToken",
            "required": false,
            "description": "The continuation token is used for pagination. The first call that is made by the client doesn't send a token since there isn't any during the initial call. But later on, if the server returns a continuation token in the response header `AI-ContinuationToken`, that means that there are more records to be fetched and should be sent as query parameter in the next call.",
            "schema": {
              "type": "string",
              "example": "eyJvZmZzZXQiOjEsInZlcnNpb24iOiIxNTE3MTY5NjM1NTI5IiwiaGFzaCI6IllxckxuaEhLdXRpb24vVm5PMnNCZHdKMTNOWVx1MDAzZCJ9"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "description": "The number of records to retrieve. If no limit value was provided it defaults to 350.",
            "schema": {
              "type": "integer",
              "example": 350,
              "minimum": 1
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "The access_token is retrieved from /rest/v2/oauth/token. <br/>*Example: Bearer {{access_token}}*\n",
            "schema": {
              "type": "string",
              "example": "Bearer 2YotnFZFEjr1zCsicMWpAA"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Locations array",
            "headers": {
              "AI-ContinuationToken": {
                "schema": {
                  "type": "string",
                  "format": "base64",
                  "example": "eyJvZmZzZXQiOjEsInZlcnNpb24iOiIxNTE3MTY5NjM1NTI5IiwiaGFzaCI6IllxckxuaEhLdXRpb24vVm5PMnNCZHdKMTNOWVx1MDAzZCJ9"
                },
                "description": "The continuation token that should be used as query parameter `continuationToken` in the next request to retrieve the other set of records. When the continuation token is not provided, that means no more records are available.\n"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Location"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/oauthError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Locations"
        ],
        "summary": "Create or update existing locations",
        "operationId": "createOrUpdateLocations",
        "description": "Create or update existing locations",
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "The access_token is retrieved from /rest/v2/oauth/token. <br/>*Example: Bearer {{access_token}}*\n",
            "schema": {
              "type": "string",
              "example": "Bearer 2YotnFZFEjr1zCsicMWpAA"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Location(s) created or updated"
          },
          "400": {
            "description": "Invalid input, object invalid"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/oauthError"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Location"
                }
              }
            }
          },
          "description": "Locations with hierarchy to add"
        }
      }
    },
    "/rest/api/v2/locations/items": {
      "post": {
        "tags": [
          "Locations"
        ],
        "summary": "Create or update existing locations with their items",
        "operationId": "createOrUpdateLocationsWithItems",
        "description": "Create or update existing locations with their items",
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "The access_token is retrieved from /rest/v2/oauth/token. <br/>*Example: Bearer {{access_token}}*\n",
            "schema": {
              "type": "string",
              "example": "Bearer 2YotnFZFEjr1zCsicMWpAA"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Location(s) and items created or updated"
          },
          "400": {
            "description": "Invalid input, object invalid"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/oauthError"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/LocationItems"
                }
              }
            }
          },
          "description": "Locations with hierarchy to add"
        }
      }
    },
