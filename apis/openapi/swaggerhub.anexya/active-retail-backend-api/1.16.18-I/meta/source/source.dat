        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "barcode": {
            "type": "string",
            "example": "666666050010"
          },
          "description": {
            "type": "string",
            "example": "Simply Soft Towel"
          },
          "price": {
            "type": "number",
            "format": "float64",
            "example": 24.99
          },
          "manufacturerSRP": {
            "type": "number",
            "format": "float64",
            "example": 19.99,
            "description": "The manufacturer suggested retail price"
          },
          "size": {
            "type": "string",
            "example": "Large"
          },
          "style": {
            "$ref": "#/components/schemas/Style"
          },
          "color": {
            "$ref": "#/components/schemas/Color"
          },
          "brand": {
            "$ref": "#/components/schemas/Brand"
          },
          "category": {
            "$ref": "#/components/schemas/Category"
          },
          "skus": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemSKU"
            }
          }
        }
      },
      "ItemSKU": {
        "type": "object",
        "required": [
          "sku"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "sku": {
            "type": "string",
            "example": "KS944RUR"
          }
        }
      },
      "Style": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "name": {
            "type": "string",
            "example": "Bath Towel"
          }
        }
      },
      "Brand": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "name": {
            "type": "string",
            "example": "Simply Soft"
          },
          "description": {
            "type": "string",
            "example": "Simply Soft Brand"
          }
        }
      },
      "Category": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "name": {
            "type": "string",
            "example": "Simply Soft"
          },
          "description": {
            "type": "string",
            "example": "Simply Soft Brand"
          },
          "parent": {
            "$ref": "#/components/schemas/Category"
          }
        }
      },
      "Location": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "name": {
            "type": "string",
            "example": "Shipping Dock 01"
          },
          "barcode": {
            "type": "string",
            "example": "666666020037"
          },
          "epc": {
            "type": "string",
            "description": "The Electronic Product Code of a tagged location",
            "example": "3074257bf7194e4000001a85"
          },
          "type": {
            "type": "string",
            "example": "Site"
          },
          "parent": {
            "$ref": "#/components/schemas/Location"
          }
        }
      },
      "Container": {
        "type": "object",
        "required": [
          "sscc"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "sscc": {
            "type": "string",
            "example": "00006666660000000015",
            "description": "The package barcode, usually it's an SSCC but there are no restrictions on the standard used"
          },
          "weight": {
            "type": "number",
            "format": "float64",
            "example": 54.23,
            "description": "The weight of the package/container"
          },
          "type": {
            "type": "string",
            "example": "Carton Box",
            "description": "The type of the container/package that is being used"
          },
          "currentLocation": {
            "$ref": "#/components/schemas/Location"
          },
          "containerItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemQuantity"
            },
            "description": "A list of items with their quantities. It's considered as the packing list. In other words, it defines what this container/package holds and how much of it. The items should be unique, no record with the same item barcode should be repeated whithin this array, if there are duplicate items, then the last one will be taken. In addition, the item whithin within the ItemQuantity object, may only contain the barcode property, it will be used to link an already created item with this package. An item can be linked to multiple packages/containers. "
          }
        }
      },
      "LocationItems": {
        "type": "object",
        "required": [
          "location",
          "items"
        ],
        "properties": {
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemQuantity"
            }
          }
        }
      },
      "OrderItems": {
        "type": "object",
        "required": [
          "orderNumber",
          "items"
        ],
        "properties": {
          "orderNumber": {
            "type": "string",
            "example": "PO#0001",
            "description": "The order number"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemQuantity"
            },
            "description": "A list of items with their quantities.It defines what this order holds and how much of it. The items should be unique, no record with the same item barcode should be repeated whithin this array, if there are duplicate items, then the last one will be taken. In addition, the item whithin within the ItemQuantity object, may only contain the barcode property, it will be used to link an already created item with this order. An item can be linked to multiple orders. "
          }
        }
      },
      "ItemQuantity": {
        "type": "object",
        "required": [
          "item",
          "quantity"
        ],
        "properties": {
          "item": {
            "$ref": "#/components/schemas/Item"
          },
          "quantity": {
            "type": "integer",
            "format": "int64",
            "example": 12,
            "description": "It specifies how much is expected of that item, here the quantity 12 specifies that there are 12 pieces expected."
          }
        }
      },
      "Order": {
        "type": "object",
        "required": [
          "orderNumber"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "orderNumber": {
            "type": "string",
            "example": "PO#0001",
            "description": "The order number"
          },
          "containers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Container"
            }
          }
        }
      },
      "Color": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "name": {
            "type": "string",
            "example": "Blue"
          },
          "code": {
            "type": "string",
            "example": "0000FF"
          }
        }
      },
      "SerializedItem": {
        "type": "object",
        "required": [
          "epc"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "43380804-15f3-8fa7-0466-92cb2f44fcfa",
            "description": "This is not be sent by the third party system, it will only be accessed but never mutated"
          },
          "epc": {
            "type": "string",
            "description": "The Electronic Product Code that is unique and specific for one piece of an item",
            "example": "3074257bf7194e4000001a85"
          },
          "tid": {
            "type": "string",
            "description": "The unique tag ID",
            "example": "E2FFF0403C00123456789ABC1DD60000090400000904000400C0"
          },
          "coo": {
            "type": "string",
            "description": "The country of origin",
            "example": "USA"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "item": {
            "$ref": "#/components/schemas/Item"
          }
        }
      },
      "SerializedItemLocation": {
        "type": "object",
        "required": [
          "epc",
          "location",
          "date"
        ],
        "properties": {
          "epc": {
            "type": "string",
            "description": "The Electronic Product Code that is unique and specific for one piece of an item",
            "example": "3074257bf7194e4000001a85"
          },
          "location": {
            "type": "string",
            "description": "The location name",
            "example": "Shipping Location 1"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "The operation date",
            "example": "2018-05-23 18:25:43.511"
          },
          "tid": {
            "type": "string",
            "description": "The unique tag ID",
            "example": "E2FFF0403C00123456789ABC1DD60000090400000904000400C0"
          },
          "barcode": {
            "type": "string",
            "description": "The item barcode associated with the EPC",
            "example": "666666050010"
          }
        }
      },
      "CycleCountOperationResultFilter": {
        "type": "object",
        "properties": {
          "barcode": {
            "type": "string",
            "description": "The item barcode to filter on. This filter is used when the user wants to conduct a cycle count operation on a certain item",
            "example": "666666050010"
          },
          "style": {
            "type": "string",
            "description": "The style to filter on. This filter is used when the user wants to conduct a cycle count operation on a certain item style",
            "example": "Bath Towel"
          },
          "brand": {
            "type": "string",
            "description": "The brand to filter on. This filter is used when the user wants to conduct a cycle count operation on a certain item brand",
            "example": "Simply Soft"
          },
          "category": {
            "type": "string",
            "description": "The category to filter on. This filter is used when the user wants to conduct a cycle count operation on a certain item category",
            "example": "Towels"
          }
        }
      },
      "CycleCountOperationResult": {
        "type": "object",
        "required": [
          "name",
          "expected",
          "found",
          "added",
          "missing",
          "location",
          "filter",
          "user",
          "date",
          "results"
        ],
        "properties": {
          "filter": {
            "$ref": "#/components/schemas/CycleCountOperationResultFilter"
          },
          "name": {
            "type": "string",
            "description": "The operation name. This value is generated by the backend system to uniquely identify operations",
            "example": "2011318816_CCO_Shelf 1"
          },
          "expected": {
            "type": "integer",
            "description": "The expected items count",
            "example": "32"
          },
          "found": {
            "type": "integer",
            "description": "The found items count",
            "example": "26"
          },
          "added": {
            "type": "integer",
            "description": "The added items count",
            "example": "4"
          },
          "missing": {
            "type": "integer",
            "description": "The missing items count",
            "example": "2"
          },
          "location": {
            "type": "string",
            "description": "The location name in which the operation took place",
            "example": "Shelf 1"
          },
          "user": {
            "type": "string",
            "description": "The username of the user that conducted the operation",
            "example": "johndoe"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "The operation date",
            "example": "2018-05-23 18:25:43.511"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OperationItemResult"
            }
          }
        }
      },
      "OperationResult": {
        "type": "object",
        "required": [
          "type",
          "name",
          "expected",
          "found",
          "added",
          "missing",
          "location",
          "user",
          "date",
          "results"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "The operation type. The type can be one of the following: `RECEIVING`, `SHIPPING`, `PACKING`, or `CHECKLOAD`",
            "example": "SHIPPING"
          },
          "name": {
            "type": "string",
            "description": "The operation name. This value is generated by the backend system to uniquely identify operations",
            "example": "2011318816_SHIPPING_1534475192"
          },
          "expected": {
            "type": "integer",
            "description": "The expected items count",
            "example": "32"
          },
          "found": {
            "type": "integer",
            "description": "The found items count",
            "example": "26"
          },
          "added": {
            "type": "integer",
            "description": "The added items count",
            "example": "4"
          },
          "missing": {
            "type": "integer",
            "description": "The missing items count",
            "example": "2"
          },
          "location": {
            "type": "string",
            "description": "The location name in which the operation took place. When conducting a ship operation, this property will be used to hold the value of the 'From Location'",
            "example": "Shipping Location 1"
          },
          "destinationLocation": {
            "type": "string",
            "description": "The destination location name. This is only available when it's a ship operation",
            "example": "Shipping Destination 1"
          },
          "order": {
            "type": "string",
            "description": "The order number. This property is omitted if the operation was done on a new package",
            "example": "2011318816"
          },
          "container": {
            "type": "string",
            "description": "The package/container barcode (sscc). This property is omitted if the operation was done on the order level",
            "example": "00050456000581293549"
          },
          "user": {
            "type": "string",
            "description": "The username of the user that conducted the operation",
            "example": "johndoe"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "The operation date",
            "example": "2018-05-23 18:25:43.511"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OperationItemResult"
            }
          }
        }
      },
      "OperationItemResult": {
        "type": "object",
        "required": [
          "barcode",
          "expected",
          "found",
          "added",
          "missing",
          "known",
          "serials"
        ],
        "properties": {
          "barcode": {
            "type": "string",
            "description": "The item barcode",
            "example": "0605194"
          },
          "expected": {
            "type": "integer",
            "description": "The expected serials count",
            "example": "12"
          },
          "found": {
            "type": "integer",
            "description": "The found serials count",
            "example": "10"
          },
          "added": {
            "type": "integer",
            "description": "The added serials count",
            "example": "1"
          },
          "missing": {
            "type": "integer",
            "description": "The missing serials count",
            "example": "1"
          },
          "known": {
            "type": "boolean",
            "description": "Indicates whether this item is known or unknown in the system",
            "example": true
          },
          "serials": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OperationSerializedItemResult"
            }
          }
        }
      },
      "OperationSerializedItemResult": {
        "type": "object",
        "required": [
          "epc",
          "tid",
          "known",
          "status"
        ],
        "properties": {
          "epc": {
            "type": "string",
            "description": "The Electronic Product Code that is unique and specific for one piece of an item",
            "example": "3074257bf7194e4000001a85"
          },
          "tid": {
            "type": "string",
            "description": "The unique tag ID",
            "example": "E2FFF0403C00123456789ABC1DD60000090400000904000400C0"
          },
          "status": {
            "type": "string",
            "description": "The status of the serial item within the operation. The value may be one of the following: `FOUND`, `MISSING`, or `ADDED`",
            "example": "FOUND"
          }
        }
      },
      "LookupResult": {
        "type": "object",
        "required": [
          "barcode",
          "epc",
          "correctTid",
          "foundTid",
          "location",
          "user",
          "date",
          "status"
        ],
        "properties": {
          "barcode": {
            "type": "string",
            "description": "The item barcode associated with the EPC",
            "example": 666666050010
          },
          "epc": {
            "type": "string",
            "description": "The Electronic Product Code that is unique and specific for one piece of an item",
            "example": "3074257bf7194e4000001a85"
          },
          "correctTid": {
            "type": "string",
            "description": "The unique tag ID that was expected",
            "example": "E2FFF0403C00123456789ABC1DD60000090400000904000400C0"
          },
          "foundTid": {
            "type": "string",
            "description": "The unique tag ID that was read during the operation",
            "example": "C3FFF0403C00123456789ABC1DD61111190400000904000400C0"
          },
          "status": {
            "type": "string",
            "description": "The status of the lookup operation. If the correctTid and foundTid are equal and not empty then the status is `CORRECT`, otherwise the status is `INCORRECT`.",
            "example": "INCORRECT"
          },
          "location": {
            "type": "string",
            "description": "The location name in which the operation was conducted",
            "example": "Lookup Station"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "The operation date",
            "example": "2018-05-23 18:25:43.511"
          },
          "user": {
            "type": "string",
            "description": "The username of the user that conducted the operation",
            "example": "johndoe"
          }
        }
      },
      "ItemCount": {
        "type": "object",
        "required": [
          "barcode",
          "count"
        ],
        "properties": {
          "barcode": {
            "type": "string",
            "description": "The item barcode",
            "example": 666666050010
          },
          "count": {
            "type": "integer",
            "description": "The number of serialized items",
            "example": 23
          }
        }
      },
      "ItemsCountByLocationNameResponse": {
        "type": "object",
        "required": [
          "location",
          "itemsCount"
        ],
        "properties": {
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "itemsCount": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemCount"
            }
          }
        }
      },
      "oauthRequest": {
        "type": "object",
        "properties": {
          "grant_type": {
            "type": "string",
            "description": "OAuth grant type. Should be set to \"password\""
          },
          "username": {
            "type": "string",
            "description": "User login"
          },
          "password": {
            "type": "string",
            "description": "User password"
          }
        }
      },
      "oauthError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "error_description": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      },
      "token": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "example": "2YotnFZFEjr1zCsicMWpAA"
          },
          "token_type": {
            "type": "string",
            "example": "password"
          },
          "expires_in": {
            "type": "string",
            "example": "3600"
          },
          "scope": {
            "type": "string",
            "example": "rest-api"
          }
        }
      },
      "tokenRevokeRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Token value",
            "example": "2YotnFZFEjr1zCsicMWpAA"
          },
          "token_type": {
            "type": "string",
            "description": "Token type. Can be `access_token` or `refresh_token`",
            "example": "access_token"
          }
        },
        "required": [
          "token"
        ]
      }
    }
  }
}