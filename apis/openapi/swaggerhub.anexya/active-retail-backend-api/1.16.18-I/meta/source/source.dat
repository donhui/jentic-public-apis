    "/rest/api/v2/containers": {
      "get": {
        "tags": [
          "Containers"
        ],
        "summary": "Get all containers",
        "operationId": "getAllContainers",
        "description": "Retrieves the Containers array as Container objects\n",
        "parameters": [
          {
            "in": "query",
            "name": "continuationToken",
            "required": false,
            "description": "The continuation token is used for pagination. The first call that is made by the client doesn't send a token since there isn't any during the initial call. But later on, if the server returns a continuation token in the response header `AI-ContinuationToken`, that means that there are more records to be fetched and should be sent as query parameter in the next call.",
            "schema": {
              "type": "string",
              "example": "eyJvZmZzZXQiOjEsInZlcnNpb24iOiIxNTE3MTY5NjM1NTI5IiwiaGFzaCI6IllxckxuaEhLdXRpb24vVm5PMnNCZHdKMTNOWVx1MDAzZCJ9"
            }
          },
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "description": "The number of records to retrieve. If no limit value was provided it defaults to 350.",
            "schema": {
              "type": "integer",
              "example": 350,
              "minimum": 1
            }
          },
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "The access_token is retrieved from /rest/v2/oauth/token. <br/>*Example: Bearer {{access_token}}*\n",
            "schema": {
              "type": "string",
              "example": "Bearer 2YotnFZFEjr1zCsicMWpAA"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Containers array",
            "headers": {
              "AI-ContinuationToken": {
                "schema": {
                  "type": "string",
                  "format": "base64",
                  "example": "eyJvZmZzZXQiOjEsInZlcnNpb24iOiIxNTE3MTY5NjM1NTI5IiwiaGFzaCI6IllxckxuaEhLdXRpb24vVm5PMnNCZHdKMTNOWVx1MDAzZCJ9"
                },
                "description": "The continuation token that should be used as query parameter `continuationToken` in the next request to retrieve the other set of records. When the continuation token is not provided, that means no more records are available."
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Container"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/oauthError"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Containers"
        ],
        "summary": "Create or update existing containers",
        "operationId": "createOrUpdateContainers",
        "description": "Create or update existing containers",
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "description": "The access_token is retrieved from /rest/v2/oauth/token. <br/>*Example: Bearer {{access_token}}*\n",
            "schema": {
              "type": "string",
              "example": "Bearer 2YotnFZFEjr1zCsicMWpAA"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Container(s) created or updated"
          },
          "400": {
            "description": "Invalid input, object invalid"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/oauthError"
                }
              }
            }
          }
        },
        "requestBody": {
