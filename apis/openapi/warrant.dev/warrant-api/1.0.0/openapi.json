  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication using your WorkOS API secret key"
      }
    },
    "schemas": {
      "Resource": {
        "type": "object",
        "properties": {
          "object": {
            "type": "string",
            "example": "authorization_resource"
          },
          "id": {
            "type": "string",
            "description": "Internal resource ID"
          },
          "external_id": {
            "type": "string",
            "description": "External resource ID, unique within organization and type"
          },
          "name": {
            "type": "string",
            "description": "Human-readable resource name"
          },
          "description": {
            "type": "string",
            "description": "Resource description"
          },
          "resource_type_slug": {
            "type": "string",
            "description": "The resource type identifier"
          },
          "parent_resource_id": {
            "type": "string",
            "description": "ID of the parent resource"
          },
          "organization_id": {
            "type": "string",
            "description": "Organization the resource belongs to"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateResourceRequest": {
        "type": "object",
        "required": ["external_id", "name", "resource_type_slug", "organization_id"],
        "properties": {
          "external_id": {
            "type": "string",
            "description": "External ID, unique within organization and resource type"
          },
          "name": {
            "type": "string",
            "description": "Human-readable resource name"
          },
