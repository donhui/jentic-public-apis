{
  "openapi": "3.0.3",
  "info": {
    "title": "Warrant API",
    "description": "Warrant (now part of WorkOS) provides a Fine-Grained Authorization (FGA) API for managing resources, role assignments, and access checks. It supports hierarchical permission inheritance, sub-50ms p95 access checks, and strong consistency.",
    "version": "1.0.0",
    "contact": {
      "name": "Warrant / WorkOS",
      "url": "https://warrant.dev"
    }
  },
  "servers": [
    {
      "url": "https://api.workos.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/authorization/resources": {
      "get": {
        "operationId": "listResources",
        "summary": "List resources",
        "description": "List authorization resources with optional filtering by organization, resource type, or parent resource.",
        "tags": ["Resources"],
        "parameters": [
          {
            "name": "organization_id",
            "in": "query",
            "description": "Filter by organization ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "resource_type_slug",
            "in": "query",
            "description": "Filter by resource type slug",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "parent_resource_id",
            "in": "query",
            "description": "Filter by parent resource ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "parent_resource_type_slug",
            "in": "query",
            "description": "Filter by parent resource type slug",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "parent_external_id",
            "in": "query",
            "description": "Filter by parent external ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Search term to filter resources",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results (default 10, max 100)",
            "schema": {
              "type": "integer",
              "default": 10,
              "maximum": 100
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc", "normal"]
            }
          },
          {
            "name": "before",
            "in": "query",
            "description": "Pagination cursor for previous page",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "after",
            "in": "query",
            "description": "Pagination cursor for next page",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of resources",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourceList"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createResource",
        "summary": "Create a resource",
        "description": "Create a new authorization resource. Resources represent entities in your application such as workspaces, projects, or apps.",
        "tags": ["Resources"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateResourceRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Resource created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "409": {
            "description": "Resource already exists"
          }
        }
      }
    },
    "/authorization/resources/{resource_id}": {
      "get": {
        "operationId": "getResource",
        "summary": "Get a resource by ID",
        "description": "Retrieve a single authorization resource by its internal ID.",
        "tags": ["Resources"],
        "parameters": [
          {
            "name": "resource_id",
            "in": "path",
            "required": true,
            "description": "The internal resource ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resource details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Resource not found"
          }
        }
      },
      "patch": {
        "operationId": "updateResource",
        "summary": "Update a resource by ID",
        "description": "Update an existing authorization resource.",
        "tags": ["Resources"],
        "parameters": [
          {
            "name": "resource_id",
            "in": "path",
            "required": true,
            "description": "The internal resource ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateResourceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resource updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Resource"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Resource not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteResource",
        "summary": "Delete a resource by ID",
        "description": "Delete an authorization resource. Optionally cascade delete child resources.",
        "tags": ["Resources"],
        "parameters": [
          {
            "name": "resource_id",
            "in": "path",
            "required": true,
            "description": "The internal resource ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cascade_delete",
            "in": "query",
            "description": "If true, also delete child resources",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Resource deleted successfully"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Resource not found"
          }
        }
      }
    },
