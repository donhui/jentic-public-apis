              "type": "object",
              "properties": {
                "DefaultVal": { "type": "string" },
                "ID": { "type": "string" },
                "Label": { "type": "string" }
              }
            }
          },
          "Choices": {
            "type": "array",
            "description": "Available choices for dropdown, radio, or checkbox fields.",
            "items": {
              "type": "object",
              "properties": {
                "Label": { "type": "string" },
                "Score": { "type": "string" }
              }
            }
          },
          "HasOtherField": { "type": "boolean", "description": "Whether the field has an 'Other' option." }
        }
      },
      "Entry": {
        "type": "object",
        "description": "A form entry. Contains dynamic Field## properties based on the form structure.",
        "properties": {
          "EntryId": { "type": "string", "description": "The unique entry identifier." },
          "DateCreated": { "type": "string", "format": "date-time", "description": "When the entry was created." },
          "CreatedBy": { "type": "string", "description": "The user who created the entry." },
          "DateUpdated": { "type": "string", "format": "date-time", "description": "When the entry was last updated." },
          "UpdatedBy": { "type": "string", "description": "The user who last updated the entry." }
        },
        "additionalProperties": {
          "type": "string",
          "description": "Dynamic field values keyed by Field## identifiers."
        }
      },
      "EntryPostResponse": {
        "type": "object",
        "properties": {
          "Success": { "type": "integer", "description": "1 if submission succeeded, 0 if it failed.", "enum": [0, 1] },
          "EntryId": { "type": "integer", "description": "The ID of the newly created entry." },
          "EntryLink": { "type": "string", "description": "URL to view the entry in Wufoo." },
          "RedirectUrl": { "type": "string", "description": "URL to redirect the user to after submission." },
          "ErrorText": { "type": "string", "description": "Error message if submission failed." },
          "FieldErrors": {
            "type": "array",
