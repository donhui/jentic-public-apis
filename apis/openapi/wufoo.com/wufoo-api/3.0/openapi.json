{
  "openapi": "3.0.3",
  "info": {
    "title": "Wufoo API",
    "description": "The Wufoo REST API allows you to interact with Wufoo forms, entries, reports, users, webhooks, and more. Wufoo is an online form builder that helps users create forms, collect data, and manage submissions.",
    "version": "3.0",
    "contact": {
      "name": "Wufoo",
      "url": "https://www.wufoo.com"
    },
    "x-documentation-url": "https://wufoo.github.io/docs/"
  },
  "servers": [
    {
      "url": "https://{subdomain}.wufoo.com/api/v3",
      "description": "Wufoo API server",
      "variables": {
        "subdomain": {
          "default": "fishbowl",
          "description": "Your Wufoo account subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    { "name": "Forms", "description": "Operations related to Wufoo forms" },
    { "name": "Entries", "description": "Operations for managing form entries/submissions" },
    { "name": "Fields", "description": "Operations for retrieving form and report field structures" },
    { "name": "Comments", "description": "Operations for form entry comments" },
    { "name": "Reports", "description": "Operations related to Wufoo reports" },
    { "name": "Widgets", "description": "Operations for report widgets" },
    { "name": "Users", "description": "Operations for retrieving user information" },
    { "name": "Webhooks", "description": "Operations for managing webhook subscriptions" },
    { "name": "Login", "description": "User authentication" }
  ],
  "paths": {
    "/forms.json": {
      "get": {
        "operationId": "getForms",
        "summary": "List all forms",
        "description": "Returns all forms accessible to the authenticated user.",
        "tags": ["Forms"],
        "parameters": [
          {
            "name": "includeTodayCount",
            "in": "query",
            "description": "If true, includes the number of entries received today.",
            "schema": { "type": "boolean" }
          },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of forms.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Forms": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Form" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/forms/{identifier}.json": {
      "get": {
        "operationId": "getForm",
        "summary": "Get a specific form",
        "description": "Retrieves a single form by its hash or URL-encoded title.",
        "tags": ["Forms"],
        "parameters": [
          { "$ref": "#/components/parameters/FormIdentifier" },
          {
            "name": "includeTodayCount",
            "in": "query",
            "description": "If true, includes the number of entries received today.",
            "schema": { "type": "boolean" }
          },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A single form.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Forms": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Form" },
                      "maxItems": 1
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/forms/{identifier}/fields.json": {
      "get": {
        "operationId": "getFormFields",
        "summary": "Get form fields",
        "description": "Retrieves the field structure for a specific form.",
        "tags": ["Fields"],
        "parameters": [
          { "$ref": "#/components/parameters/FormIdentifier" },
          {
            "name": "system",
            "in": "query",
            "description": "If true, includes system fields such as IP, Status, etc.",
            "schema": { "type": "boolean" }
          },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of fields for the form.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Fields": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Field" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/forms/{identifier}/entries.json": {
      "get": {
        "operationId": "getFormEntries",
        "summary": "Get form entries",
        "description": "Retrieves entries (submissions) for a specific form. Supports filtering, sorting, and pagination.",
        "tags": ["Entries"],
        "parameters": [
          { "$ref": "#/components/parameters/FormIdentifier" },
          {
            "name": "system",
            "in": "query",
            "description": "If true, includes system fields in the response.",
            "schema": { "type": "boolean" }
          },
          {
            "name": "pageStart",
            "in": "query",
            "description": "The entry index to start from (0-based).",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "The number of entries to return per page (max 100).",
            "schema": { "type": "integer", "default": 25, "maximum": 100 }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "The field ID to sort results by (e.g., Field1, EntryId, DateCreated).",
            "schema": { "type": "string" }
          },
          {
            "name": "sortDirection",
            "in": "query",
            "description": "The direction to sort results.",
            "schema": { "type": "string", "enum": ["ASC", "DESC"], "default": "ASC" }
          },
          {
            "name": "Filter1",
            "in": "query",
            "description": "Filter expression in the format 'FieldID Operator Value'. Operators include Contains, Does_not_contain, Begins_with, Ends_with, Is_less_than, Is_greater_than, Is_on, Is_before, Is_after, Is_not_equal_to, Is_equal_to, Is_not_NULL.",
            "schema": { "type": "string" }
          },
          {
            "name": "Filter2",
            "in": "query",
            "description": "Additional filter expression (same format as Filter1).",
            "schema": { "type": "string" }
          },
          {
            "name": "match",
            "in": "query",
            "description": "Logic for combining multiple filters.",
            "schema": { "type": "string", "enum": ["AND", "OR"] }
          },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of entries for the form.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Entries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Entry" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "operationId": "createFormEntry",
        "summary": "Submit a new entry",
        "description": "Submits a new entry to the specified form. Fields are submitted as Field## key-value pairs. Rate limited to 50 submissions per user per 5-minute window.",
        "tags": ["Entries"],
        "parameters": [
          { "$ref": "#/components/parameters/FormIdentifier" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "description": "Form field values as Field##=value pairs. The exact field IDs depend on the form structure.",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Entry submission result.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EntryPostResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": {
            "description": "Rate limit exceeded. Maximum 50 submissions per user per 5-minute window."
          }
        }
      }
    },
    "/forms/{identifier}/entries/count.json": {
      "get": {
        "operationId": "getFormEntriesCount",
        "summary": "Get form entries count",
        "description": "Returns the total number of entries for a specific form. Supports the same filter parameters as the entries endpoint.",
        "tags": ["Entries"],
        "parameters": [
          { "$ref": "#/components/parameters/FormIdentifier" },
          {
            "name": "Filter1",
            "in": "query",
            "description": "Filter expression in the format 'FieldID Operator Value'.",
            "schema": { "type": "string" }
          },
          {
            "name": "Filter2",
            "in": "query",
            "description": "Additional filter expression.",
            "schema": { "type": "string" }
          },
          {
            "name": "match",
            "in": "query",
            "description": "Logic for combining multiple filters.",
            "schema": { "type": "string", "enum": ["AND", "OR"] }
          },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "The entry count.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "EntryCount": { "type": "string", "description": "The number of entries as a string." }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/forms/{identifier}/comments.json": {
      "get": {
        "operationId": "getFormComments",
        "summary": "Get form comments",
        "description": "Retrieves comments posted on entries for a specific form.",
        "tags": ["Comments"],
        "parameters": [
          { "$ref": "#/components/parameters/FormIdentifier" },
          {
            "name": "entryId",
            "in": "query",
            "description": "Filter comments to a specific entry by its ID.",
            "schema": { "type": "integer" }
          },
          {
            "name": "pageStart",
            "in": "query",
            "description": "The comment index to start from (0-based).",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of comments per page (max 100).",
            "schema": { "type": "integer", "default": 25, "maximum": 100 }
          },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of comments.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Comments": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Comment" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/forms/{identifier}/comments/count.json": {
      "get": {
        "operationId": "getFormCommentsCount",
        "summary": "Get form comments count",
        "description": "Returns the total number of comments for a specific form's entries.",
        "tags": ["Comments"],
        "parameters": [
          { "$ref": "#/components/parameters/FormIdentifier" },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "The comment count.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Count": { "type": "string", "description": "The number of comments as a string." }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/reports.json": {
      "get": {
        "operationId": "getReports",
        "summary": "List all reports",
        "description": "Returns all reports accessible to the authenticated user.",
        "tags": ["Reports"],
        "parameters": [
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of reports.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Reports": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Report" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/reports/{identifier}.json": {
      "get": {
        "operationId": "getReport",
        "summary": "Get a specific report",
        "description": "Retrieves a single report by its hash or URL-encoded title.",
        "tags": ["Reports"],
        "parameters": [
          { "$ref": "#/components/parameters/ReportIdentifier" },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A single report.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Reports": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Report" },
                      "maxItems": 1
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/reports/{identifier}/fields.json": {
      "get": {
        "operationId": "getReportFields",
        "summary": "Get report fields",
        "description": "Retrieves the field structure for the form associated with a specific report.",
        "tags": ["Fields"],
        "parameters": [
          { "$ref": "#/components/parameters/ReportIdentifier" },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of fields for the report's form.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Fields": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Field" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/reports/{identifier}/entries.json": {
      "get": {
        "operationId": "getReportEntries",
        "summary": "Get report entries",
        "description": "Retrieves entries matching the report's configured criteria and fields.",
        "tags": ["Reports", "Entries"],
        "parameters": [
          { "$ref": "#/components/parameters/ReportIdentifier" },
          {
            "name": "pageStart",
            "in": "query",
            "description": "The entry index to start from (0-based).",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "The number of entries to return per page (max 100).",
            "schema": { "type": "integer", "default": 25, "maximum": 100 }
          },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of entries matching the report criteria.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Entries": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Entry" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/reports/{identifier}/entries/count.json": {
      "get": {
        "operationId": "getReportEntriesCount",
        "summary": "Get report entries count",
        "description": "Returns the total number of entries matching the report criteria.",
        "tags": ["Reports", "Entries"],
        "parameters": [
          { "$ref": "#/components/parameters/ReportIdentifier" },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "The entry count.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "EntryCount": { "type": "string", "description": "The number of entries as a string." }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/reports/{identifier}/widgets.json": {
      "get": {
        "operationId": "getReportWidgets",
        "summary": "Get report widgets",
        "description": "Retrieves the widget definitions that compose a specific report.",
        "tags": ["Widgets"],
        "parameters": [
          { "$ref": "#/components/parameters/ReportIdentifier" },
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of widgets for the report.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Widgets": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Widget" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/users.json": {
      "get": {
        "operationId": "getUsers",
        "summary": "List users",
        "description": "Retrieves information about users associated with the account.",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "pretty",
            "in": "query",
            "description": "If true, returns pretty-printed JSON output.",
            "schema": { "type": "boolean" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of users.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "Users": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/User" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/forms/{identifier}/webhooks.json": {
      "put": {
        "operationId": "addWebhook",
        "summary": "Add a webhook",
        "description": "Creates or updates a webhook subscription for a specific form. When an entry is submitted, Wufoo will POST the data to the specified URL.",
        "tags": ["Webhooks"],
        "parameters": [
          { "$ref": "#/components/parameters/FormIdentifier" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["url", "handshakeKey"],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "The callback URL where Wufoo will POST entry data."
                  },
                  "handshakeKey": {
                    "type": "string",
                    "description": "A secret key used to authenticate the webhook callback. Wufoo sends this in the HandshakeKey field of the POST."
                  },
                  "metadata": {
                    "type": "boolean",
                    "description": "If true, Wufoo will include additional metadata (IP address, entry creation date, etc.) in the webhook POST."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "WebHookPutResult": {
                      "type": "object",
                      "properties": {
                        "Hash": {
                          "type": "string",
                          "description": "The hash identifier of the created webhook."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/forms/{identifier}/webhooks/{webhookHash}.json": {
      "delete": {
        "operationId": "deleteWebhook",
        "summary": "Delete a webhook",
        "description": "Removes a webhook subscription from a specific form.",
        "tags": ["Webhooks"],
        "parameters": [
          { "$ref": "#/components/parameters/FormIdentifier" },
          {
            "name": "webhookHash",
            "in": "path",
            "required": true,
            "description": "The hash identifier of the webhook to delete.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook deleted successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "WebHookDeleteResult": {
                      "type": "object",
                      "properties": {
                        "Hash": {
                          "type": "string",
                          "description": "The hash identifier of the deleted webhook."
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/login.json": {
      "post": {
        "operationId": "login",
        "summary": "Login",
        "description": "Authenticates a user with their integration key and subdomain and returns an API key that can be used for subsequent requests.",
        "tags": ["Login"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["integrationKey", "email", "password", "subdomain"],
                "properties": {
                  "integrationKey": {
                    "type": "string",
                    "description": "Your Wufoo integration key."
                  },
                  "email": {
                    "type": "string",
                    "description": "The user's email address."
                  },
                  "password": {
                    "type": "string",
                    "description": "The user's password."
                  },
                  "subdomain": {
                    "type": "string",
                    "description": "The Wufoo account subdomain."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful. Returns the user's API key and other details.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ApiKey": {
                      "type": "string",
                      "description": "The API key for the authenticated user."
                    },
                    "UserLink": {
                      "type": "string",
                      "description": "Link to the user's information."
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        },
        "security": []
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication. Use your API key as the username and any value (e.g., 'footastic') as the password."
      }
    },
    "parameters": {
      "FormIdentifier": {
        "name": "identifier",
        "in": "path",
        "required": true,
        "description": "The form hash or URL-encoded form title.",
