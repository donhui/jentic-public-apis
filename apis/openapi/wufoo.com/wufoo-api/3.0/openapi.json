          "LinkFields": { "type": "string", "format": "uri", "description": "API link to the form's fields." },
          "LinkEntries": { "type": "string", "format": "uri", "description": "API link to the form's entries." },
          "LinkEntriesCount": { "type": "string", "format": "uri", "description": "API link to the form's entry count." }
        }
      },
      "Field": {
        "type": "object",
