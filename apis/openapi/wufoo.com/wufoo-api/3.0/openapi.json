          "Description": { "type": "string", "description": "The form description." },
          "RedirectMessage": { "type": "string", "description": "The message shown after form submission." },
          "Url": { "type": "string", "description": "The public URL path of the form." },
          "Email": { "type": "string", "description": "Notification email address(es)." },
          "IsPublic": { "type": "string", "description": "Whether the form is public ('1') or private ('0')." },
          "Language": { "type": "string", "description": "The language of the form." },
          "StartDate": { "type": "string", "description": "The date when the form becomes active." },
          "EndDate": { "type": "string", "description": "The date when the form becomes inactive." },
          "EntryLimit": { "type": "string", "description": "Maximum number of entries the form accepts." },
          "DateCreated": { "type": "string", "format": "date-time", "description": "When the form was created." },
