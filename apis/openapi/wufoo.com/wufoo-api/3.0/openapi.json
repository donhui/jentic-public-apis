              "properties": {
                "ID": { "type": "string", "description": "The field ID that had an error." },
                "ErrorText": { "type": "string", "description": "The error message for the field." }
              }
            }
          }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "CommentId": { "type": "integer", "description": "Unique comment identifier." },
          "EntryId": { "type": "integer", "description": "The entry the comment belongs to." },
          "Text": { "type": "string", "description": "The comment text." },
          "CommentedBy": { "type": "string", "description": "The user who posted the comment." },
          "DateCreated": { "type": "string", "format": "date-time", "description": "When the comment was created." }
        }
      },
      "Report": {
        "type": "object",
        "properties": {
          "Name": { "type": "string", "description": "The name of the report." },
          "Description": { "type": "string", "description": "The report description." },
          "Url": { "type": "string", "description": "The public URL path of the report." },
          "IsPublic": { "type": "string", "description": "Whether the report is public ('1') or private ('0')." },
          "DateCreated": { "type": "string", "format": "date-time", "description": "When the report was created." },
