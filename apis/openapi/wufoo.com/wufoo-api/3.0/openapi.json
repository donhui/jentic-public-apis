          "ID": { "type": "string", "description": "The unique field identifier (e.g., Field1)." },
          "Instructions": { "type": "string", "description": "Help text or instructions for the field." },
          "IsRequired": { "type": "string", "description": "Whether the field is required ('1') or not ('0')." },
          "ClassNames": { "type": "string", "description": "CSS class names assigned to the field." },
          "DefaultVal": { "type": "string", "description": "The default value for the field." },
          "Page": { "type": "string", "description": "The page number the field is on." },
