          "Hash": { "type": "string", "description": "The unique hash identifier for the report." },
          "LinkFields": { "type": "string", "format": "uri", "description": "API link to the report's fields." },
          "LinkEntries": { "type": "string", "format": "uri", "description": "API link to the report's entries." },
          "LinkEntriesCount": { "type": "string", "format": "uri", "description": "API link to the report's entry count." },
          "LinkWidgets": { "type": "string", "format": "uri", "description": "API link to the report's widgets." }
        }
      },
      "Widget": {
        "type": "object",
        "properties": {
          "Name": { "type": "string", "description": "The widget name." },
          "Size": { "type": "string", "description": "The widget size." },
          "Type": { "type": "string", "description": "The widget type (e.g., chart, graph, table)." },
          "TypeDesc": { "type": "string", "description": "A human-readable description of the widget type." },
          "Hash": { "type": "string", "description": "The unique hash identifier for the widget." }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "User": { "type": "string", "description": "The username." },
          "Email": { "type": "string", "description": "The user's email address." },
          "TimeZone": { "type": "string", "description": "The user's timezone." },
          "Company": { "type": "string", "description": "The user's company name." },
          "IsAccountOwner": { "type": "string", "description": "Whether the user is the account owner ('1') or not ('0')." },
          "CreateForms": { "type": "string", "description": "Whether the user can create forms ('1') or not ('0')." },
          "CreateReports": { "type": "string", "description": "Whether the user can create reports ('1') or not ('0')." },
          "CreateThemes": { "type": "string", "description": "Whether the user can create themes ('1') or not ('0')." },
          "AdminAccess": { "type": "string", "description": "Whether the user has admin access ('1') or not ('0')." },
          "Hash": { "type": "string", "description": "The unique hash identifier for the user." },
          "ImageUrlSmall": { "type": "string", "format": "uri", "description": "URL to the user's small avatar." },
          "ImageUrlBig": { "type": "string", "format": "uri", "description": "URL to the user's large avatar." },
          "HttpsEnabled": { "type": "string", "description": "Whether HTTPS is enabled for the user." },
          "ApiKey": { "type": "string", "description": "The user's API key." },
          "LinkForms": { "type": "string", "format": "uri", "description": "API link to the user's forms." },
          "LinkReports": { "type": "string", "format": "uri", "description": "API link to the user's reports." }
        }
      }
    }
  }
