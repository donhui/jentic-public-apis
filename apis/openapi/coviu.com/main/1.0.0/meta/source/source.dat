{
  "openapi": "3.0.3",
  "info": {
    "title": "Coviu Telehealth Video API",
    "description": "REST API for the Coviu telehealth video platform. Manage video consultation sessions, participants, waiting areas, collections, and recordings.",
    "version": "1.0.0",
    "contact": {
      "name": "Coviu",
      "url": "https://coviu.readme.io/reference/the-coviu-rest-api"
    }
  },
  "externalDocs": {
    "description": "Coviu API Reference",
    "url": "https://coviu.readme.io/reference/the-coviu-rest-api"
  },
  "servers": [
    {
      "url": "https://api.coviu.com/v1",
      "description": "Production"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    { "name": "Auth", "description": "Authentication and token management" },
    { "name": "Sessions", "description": "Video consultation session management" },
    { "name": "Participants", "description": "Session participant management" },
    { "name": "WaitingArea", "description": "Waiting room and call queue operations" },
    { "name": "Collections", "description": "Team collections and form submissions" },
    { "name": "Recordings", "description": "Audio and video recording downloads" }
  ],
  "paths": {
    "/auth/token": {
      "post": {
        "operationId": "obtainAccessToken",
        "summary": "Obtain access token",
        "description": "Authenticate using HTTP Basic Auth (Client ID / Client Secret) and obtain an OAuth2 access token.",
        "tags": ["Auth"],
        "security": [
          {
            "basicAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "oneOf": [
                  { "$ref": "#/components/schemas/ClientCredentialsGrant" },
                  { "$ref": "#/components/schemas/AuthorizationCodeGrant" },
                  { "$ref": "#/components/schemas/RefreshTokenGrant" }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token issued successfully.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Token" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/sessions": {
      "post": {
        "operationId": "createSession",
        "summary": "Create a new video session",
        "description": "Create a new telehealth video session with optional participants and feature flags.",
        "tags": ["Sessions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateSession" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Session" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "get": {
        "operationId": "listSessions",
        "summary": "Retrieve all sessions",
        "description": "List sessions with optional filtering, pagination, and ordering.",
        "tags": ["Sessions"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Zero-based page index.",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "Number of entries to return per page.",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "start_time",
            "in": "query",
            "description": "Include sessions whose start time falls after this value (ISO 8601).",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "end_time",
            "in": "query",
            "description": "Include sessions whose end time falls before this value (ISO 8601).",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort order for returned sessions.",
            "schema": { "type": "string", "enum": ["forward", "reverse"] }
          },
          {
            "name": "include_canceled",
            "in": "query",
            "description": "When set, include cancelled sessions.",
            "schema": { "type": "string" }
          },
          {
            "name": "deleted_participants",
            "in": "query",
            "description": "When set, include removed participants.",
            "schema": { "type": "string" }
          },
          {
            "name": "state",
            "in": "query",
            "description": "Limit to sessions containing participants with this state value.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of sessions.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SessionList" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/sessions/{session_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/SessionId" }
      ],
      "get": {
        "operationId": "getSession",
        "summary": "Get a specific session",
        "description": "Retrieve full details of a single session including its participants.",
        "tags": ["Sessions"],
        "responses": {
          "200": {
            "description": "Session details.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Session" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "operationId": "updateSession",
        "summary": "Modify session settings",
        "description": "Update the name, times, or picture of an existing session.",
        "tags": ["Sessions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateSession" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Session" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "cancelSession",
        "summary": "Cancel an active session",
        "description": "Cancel (soft-delete) an active session.",
        "tags": ["Sessions"],
        "responses": {
          "200": {
            "description": "Session cancelled."
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/sessions/{session_id}/summary": {
      "parameters": [
        { "$ref": "#/components/parameters/SessionId" }
      ],
      "get": {
        "operationId": "getSessionSummary",
        "summary": "Retrieve session summary data",
        "description": "Get post-session summary including participant entry/exit times and bandwidth metrics.",
        "tags": ["Sessions"],
        "responses": {
          "200": {
            "description": "Session summary.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SessionSummary" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/sessions/{session_id}/participants": {
      "parameters": [
        { "$ref": "#/components/parameters/SessionId" }
      ],
      "get": {
        "operationId": "listParticipants",
        "summary": "List all participants",
        "description": "List participants belonging to a session.",
        "tags": ["Participants"],
        "parameters": [
          {
            "name": "deleted_participants",
            "in": "query",
            "description": "When set, include removed participants.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of participants.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Participant" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "operationId": "addParticipant",
        "summary": "Add a participant to a session",
        "description": "Add a new participant to an existing (not yet completed) session.",
        "tags": ["Participants"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateParticipant" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Participant added.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Participant" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/sessions/{session_id}/participants/{participant_id}": {
      "parameters": [
        { "$ref": "#/components/parameters/SessionId" },
        { "$ref": "#/components/parameters/ParticipantId" }
      ],
      "get": {
        "operationId": "getParticipant",
        "summary": "Get individual participant details",
        "tags": ["Participants"],
        "responses": {
          "200": {
            "description": "Participant details.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Participant" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "operationId": "updateParticipant",
        "summary": "Update participant information",
        "tags": ["Participants"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateParticipant" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Participant updated.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Participant" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "removeParticipant",
        "summary": "Remove a participant",
        "description": "Soft-delete a participant from a session.",
        "tags": ["Participants"],
        "responses": {
          "200": {
            "description": "Participant removed."
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/waiting/{teamId}": {
      "parameters": [
        { "$ref": "#/components/parameters/TeamId" }
      ],
      "get": {
        "operationId": "getCurrentlyWaitingCalls",
        "summary": "List currently waiting calls",
        "description": "Retrieve all calls currently in the waiting area for a team.",
        "tags": ["WaitingArea"],
        "responses": {
          "200": {
            "description": "Array of waiting calls.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Call" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/waiting/{teamId}/queue/{queueId}": {
      "parameters": [
        { "$ref": "#/components/parameters/TeamId" },
        {
          "name": "queueId",
          "in": "path",
          "required": true,
          "description": "Waiting queue identifier.",
          "schema": { "type": "string", "format": "uuid" }
        }
      ],
      "get": {
        "operationId": "getWaitingCallsForQueue",
        "summary": "Get waiting calls for a specific queue",
        "description": "Retrieve calls currently waiting in a particular queue.",
        "tags": ["WaitingArea"],
        "responses": {
          "200": {
            "description": "Array of waiting calls for the queue.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Call" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/waiting/{teamId}/calls/{callId}": {
      "parameters": [
        { "$ref": "#/components/parameters/TeamId" },
        {
          "name": "callId",
          "in": "path",
          "required": true,
          "description": "Unique call identifier.",
          "schema": { "type": "string", "format": "uuid" }
        }
      ],
      "get": {
        "operationId": "getCall",
        "summary": "Retrieve call details",
        "description": "Get details for a specific call.",
        "tags": ["WaitingArea"],
        "responses": {
          "200": {
            "description": "Call details.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Call" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/collections/{teamId}": {
      "parameters": [
        { "$ref": "#/components/parameters/TeamId" }
      ],
      "get": {
        "operationId": "getCollections",
        "summary": "List team collections",
        "description": "Retrieve all collections belonging to a team.",
        "tags": ["Collections"],
        "responses": {
          "200": {
            "description": "Array of collections.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Collection" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/collections/{teamId}/collection/{collectionId}": {
      "parameters": [
        { "$ref": "#/components/parameters/TeamId" },
        { "$ref": "#/components/parameters/CollectionId" }
      ],
      "get": {
        "operationId": "listSubmissions",
        "summary": "List collection submissions",
        "description": "Retrieve submissions for a given collection with pagination and filtering.",
        "tags": ["Collections"],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Start date filter (ISO 8601).",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "until",
            "in": "query",
            "description": "End date filter (ISO 8601).",
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "filter",
            "in": "query",
            "description": "Custom filter criteria.",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results to return.",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset.",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction.",
            "schema": { "type": "string", "enum": ["asc", "desc"], "default": "asc" }
          },
          {
            "name": "orderBy",
            "in": "query",
            "description": "Field to sort by.",
            "schema": { "type": "string", "default": "created_at" }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of submissions.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SubmissionList" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/collections/{teamId}/collection/{collectionId}/submission/{submissionId}": {
      "parameters": [
        { "$ref": "#/components/parameters/TeamId" },
        { "$ref": "#/components/parameters/CollectionId" },
        {
          "name": "submissionId",
          "in": "path",
          "required": true,
          "description": "Submission identifier.",
          "schema": { "type": "string", "format": "uuid" }
        }
      ],
      "get": {
        "operationId": "getSubmission",
        "summary": "Get submission details",
        "description": "Retrieve a single submission including its attached files.",
        "tags": ["Collections"],
        "responses": {
          "200": {
            "description": "Submission details with files.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SubmissionDetail" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/collections/{teamId}/collection/{collectionId}/submission/{submissionId}/file/{fileId}": {
      "parameters": [
        { "$ref": "#/components/parameters/TeamId" },
        { "$ref": "#/components/parameters/CollectionId" },
        {
          "name": "submissionId",
          "in": "path",
          "required": true,
          "description": "Submission identifier.",
          "schema": { "type": "string", "format": "uuid" }
        },
        {
          "name": "fileId",
          "in": "path",
          "required": true,
          "description": "File identifier within the submission.",
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "operationId": "getSubmissionFile",
        "summary": "Download submission file",
        "description": "Download a binary file attached to a submission.",
        "tags": ["Collections"],
        "responses": {
          "200": {
            "description": "Binary file content.",
            "content": {
              "application/octet-stream": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/collections/{teamId}/collection/{collectionId}/recording/{submissionId}": {
      "parameters": [
        { "$ref": "#/components/parameters/TeamId" },
        { "$ref": "#/components/parameters/CollectionId" },
        {
          "name": "submissionId",
          "in": "path",
          "required": true,
          "description": "Submission (recording) identifier.",
          "schema": { "type": "string", "format": "uuid" }
        }
      ],
      "get": {
        "operationId": "getAudioRecording",
        "summary": "Download audio recording",
        "description": "Download an audio recording in WebM format. Supports HTTP range requests (206 Partial Content).",
        "tags": ["Recordings"],
        "responses": {
          "200": {
            "description": "Full audio recording.",
            "content": {
              "audio/webm": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "206": {
            "description": "Partial content (range request).",
            "content": {
              "audio/webm": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 Client Credentials flow.",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://api.coviu.com/v1/auth/token",
            "scopes": {}
          }
        }
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Auth using Client ID as username and Client Secret as password."
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Bearer token obtained from the /auth/token endpoint."
      }
    },
    "parameters": {
      "SessionId": {
        "name": "session_id",
        "in": "path",
        "required": true,
        "description": "Unique session identifier.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "ParticipantId": {
        "name": "participant_id",
        "in": "path",
        "required": true,
        "description": "Unique participant identifier.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "TeamId": {
        "name": "teamId",
        "in": "path",
        "required": true,
        "description": "Team identifier.",
        "schema": { "type": "string", "format": "uuid" }
      },
      "CollectionId": {
        "name": "collectionId",
        "in": "path",
        "required": true,
        "description": "Collection identifier.",
        "schema": { "type": "string", "format": "uuid" }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request – invalid or missing parameters.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication credentials are missing or invalid.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Forbidden": {
        "description": "Insufficient permissions for this resource.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "The requested resource was not found.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error code."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message."
          }
        }
      },
      "ClientCredentialsGrant": {
        "type": "object",
        "required": ["grant_type"],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": ["client_credentials"]
          }
        }
      },
      "AuthorizationCodeGrant": {
        "type": "object",
        "required": ["grant_type", "code"],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": ["authorization_code"]
          },
          "code": {
            "type": "string",
            "description": "Authorization code."
          }
        }
      },
      "RefreshTokenGrant": {
        "type": "object",
        "required": ["grant_type", "refresh_token"],
        "properties": {
          "grant_type": {
            "type": "string",
            "enum": ["refresh_token"]
          },
          "refresh_token": {
            "type": "string",
            "description": "Refresh token value."
          }
        }
      },
      "Token": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "Bearer token for API requests."
          },
          "refresh_token": {
            "type": "string",
            "description": "Token for obtaining new access tokens."
          },
          "expires_in": {
            "type": "integer",
            "description": "Seconds until token expiration."
          },
          "token_type": {
            "type": "string",
            "description": "Token type (always \"Bearer\").",
            "example": "Bearer"
          },
          "scope": {
            "type": "string",
            "description": "Authorized permission scopes."
          }
        }
      },
      "CreateSession": {
        "type": "object",
        "required": ["session_name", "start_time", "end_time"],
        "properties": {
          "session_name": {
            "type": "string",
            "description": "Display name of the session."
          },
          "start_time": {
            "type": "string",
            "format": "date-time",
            "description": "Scheduled start time (ISO 8601)."
          },
          "end_time": {
            "type": "string",
            "format": "date-time",
            "description": "Scheduled end time (ISO 8601)."
          },
          "picture": {
            "type": "string",
            "description": "Session picture URL."
          },
          "participants": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CreateParticipant" },
            "description": "Initial participants to add to the session."
          },
          "feature_flags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Customisation flags (e.g. \"-plugin;coviu-waiting-room-plugin\", \"customisation;exit-url;https://example.com\")."
          }
        }
      },
      "UpdateSession": {
        "type": "object",
        "properties": {
          "session_name": {
            "type": "string",
            "description": "Updated session name."
          },
          "start_time": {
            "type": "string",
            "format": "date-time",
            "description": "Updated start time (ISO 8601)."
          },
          "end_time": {
            "type": "string",
            "format": "date-time",
            "description": "Updated end time (ISO 8601)."
          },
          "actual_end_time": {
            "type": "string",
            "format": "date-time",
            "description": "Actual completion time."
          },
          "picture": {
            "type": "string",
            "description": "Updated picture URL."
          }
        }
      },
      "Session": {
        "type": "object",
        "required": ["session_id"],
        "properties": {
          "session_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique session identifier."
          },
          "session_name": {
            "type": "string"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "actual_end_time": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "picture": {
            "type": "string",
            "nullable": true
          },
          "team_id": {
            "type": "string",
            "format": "uuid"
          },
          "client_id": {
            "type": "string",
            "format": "uuid"
          },
          "participants": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Participant" }
          }
        }
      },
      "SessionList": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Session" }
          },
          "page": {
            "type": "integer",
            "description": "Current page number."
          },
          "page_size": {
            "type": "integer",
            "description": "Items per page."
          },
          "more": {
            "type": "boolean",
            "description": "True if additional pages exist."
          }
        }
      },
      "SessionSummary": {
        "type": "object",
        "properties": {
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "actual_end_time": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "participants": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ParticipantSummary" }
          }
        }
      },
      "ParticipantSummary": {
        "type": "object",
        "properties": {
          "participant_id": {
            "type": "string",
            "format": "uuid"
          },
          "role": {
            "type": "string",
            "enum": ["GUEST", "HOST", "PARTICIPANT"]
          },
          "entry_time": {
            "type": "string",
            "format": "date-time",
            "description": "Earliest recorded entry time (excludes waiting room)."
          },
          "exit_time": {
            "$ref": "#/components/schemas/ExitTime"
          },
          "bandwidth": {
            "$ref": "#/components/schemas/BandwidthMetrics"
          }
        }
      },
      "ExitTime": {
        "type": "object",
        "properties": {
          "left_at": {
            "type": "string",
            "format": "date-time",
            "description": "Latest recorded exit time."
          },
          "left_reason": {
            "type": "string",
            "description": "Reason for departure."
          }
        }
      },
      "BandwidthMetrics": {
        "type": "object",
        "properties": {
          "min_sent_bandwidth": {
            "type": "number",
            "description": "Minimum upload bandwidth."
          },
          "max_sent_bandwidth": {
            "type": "number",
            "description": "Maximum upload bandwidth."
          },
          "avg_sent_bandwidth": {
            "type": "number",
            "description": "Average upload bandwidth."
          },
          "min_receive_bandwidth": {
            "type": "number",
            "description": "Minimum download bandwidth."
          },
          "max_receive_bandwidth": {
            "type": "number",
            "description": "Maximum download bandwidth."
          },
          "avg_receive_bandwidth": {
            "type": "number",
            "description": "Average download bandwidth."
          }
        }
      },
      "CreateParticipant": {
        "type": "object",
        "required": ["display_name", "role"],
        "properties": {
          "display_name": {
            "type": "string",
            "description": "Participant display name."
          },
          "role": {
            "type": "string",
            "enum": ["GUEST", "HOST", "PARTICIPANT"],
            "description": "Role assignment."
          },
          "picture": {
            "type": "string",
            "description": "Participant picture URL."
          },
          "state": {
            "type": "string",
            "description": "Custom state value."
          },
          "phone": {
            "type": "string",
            "description": "Phone number."
          }
        }
      },
      "UpdateParticipant": {
        "type": "object",
        "properties": {
          "display_name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["GUEST", "HOST", "PARTICIPANT"]
          },
          "picture": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        }
      },
      "Participant": {
        "type": "object",
        "required": ["participant_id", "session_id", "display_name", "role"],
        "properties": {
          "participant_id": {
            "type": "string",
            "format": "uuid"
          },
          "client_id": {
            "type": "string",
            "format": "uuid"
          },
          "session_id": {
            "type": "string",
            "format": "uuid"
          },
          "display_name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["GUEST", "HOST", "PARTICIPANT"]
          },
          "entry_url": {
            "type": "string",
            "description": "URL participants use to join the session."
          },
          "picture": {
            "type": "string",
            "nullable": true
          },
          "state": {
            "type": "string",
            "nullable": true
          },
          "user_hint": {
            "type": "string",
            "nullable": true
          },
          "deleted_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "coviu_user_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Call": {
        "type": "object",
        "properties": {
          "callId": {
            "type": "string",
            "format": "uuid"
          },
          "teamId": {
            "type": "string",
            "format": "uuid"
          },
          "peerId": {
            "type": "string"
          },
          "socketId": {
            "type": "string",
            "format": "uuid"
          },
          "sessionId": {
            "type": "string",
            "format": "uuid"
          },
          "details": {
            "type": "string",
            "description": "Additional call metadata (JSON string)."
          },
          "joinedAt": {
            "type": "string",
            "format": "date-time"
          },
          "leftQueueAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "answeredAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "finishedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "lastActivityAt": {
            "type": "string",
            "format": "date-time"
          },
          "cleanedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "transferredAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "transferredTo": {
            "type": "string",
            "nullable": true
          },
          "previousCallId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "onHoldAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "transferredToTeam": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "emptiedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "callType": {
            "type": "string",
            "enum": ["video", "phone"]
          },
          "waitingQueueId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "Collection": {
        "type": "object",
        "required": ["id", "team_id", "collection_id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "team_id": {
            "type": "string",
            "format": "uuid"
          },
          "collection_id": {
            "type": "string",
            "format": "uuid"
          },
          "collection_reference": {
            "type": "string",
            "description": "Human-readable collection reference."
          },
          "name": {
            "type": "string"
          },
          "read_setting": {
            "type": "string",
            "enum": ["restricted", "exclusive", "team"]
          },
          "delete_setting": {
            "type": "string",
            "enum": ["restricted", "exclusive", "team"]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "Submission": {
        "type": "object",
        "properties": {
          "secure_collection_id": {
            "type": "string",
            "format": "uuid"
          },
          "item_submission_id": {
            "type": "string",
            "format": "uuid"
          },
          "session_id": {
            "type": "string",
            "format": "uuid"
          },
          "collection_location": {
            "type": "string"
          },
          "submitting_user_id": {
            "type": "string",
            "format": "uuid"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "locked_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "action_status": {
            "type": "boolean"
          }
        }
      },
      "SubmissionList": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Submission" }
          },
          "total": {
            "type": "integer",
            "description": "Total count of matching submissions."
          }
        }
      },
      "SubmissionDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/Submission" },
          {
            "type": "object",
            "properties": {
              "files": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/SubmissionFile" }
              }
            }
          }
        ]
      },
      "SubmissionFile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "description": "File metadata key-value pairs."
          },
          "size": {
            "type": "number",
            "description": "File size in bytes."
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      }
    }
  }
}
