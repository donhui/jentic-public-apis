    "/api/v4/customer/students/registration/credit-card-action": {
      "get": {
        "summary": "Gets the credit card action that should be taken by the user on the credit card step of the wizard.  Possible\r\nreturn values are \"CanEnterDueToExpiredCard\" (a card is not required, and the user's is expired), \"CanEnterDueToNoCard\"\r\n(a card is not required, and the user doesn't have one), \"MustEnterDueToExpiredCard\" (a card is required, but the user's\r\nis expired), \"MustEnterDueToNoCard\" (a card is required, but the user doesn't have one), \"ReviewWhenCardIsRequired\" \r\n(a card is required, but the user's card is good; they just need to review the info), and \"ReviewWhenCardIsNotRequired\"\r\n(a card is not required, and the user's card is good; they just need to review the info).",
        "operationId": "CustomerStudentRegistration_GetCreditCardAction",
        "tags": [
