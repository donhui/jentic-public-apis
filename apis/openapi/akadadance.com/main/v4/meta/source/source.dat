    "/api/v4/customer/auth/create-account": {
      "post": {
        "summary": "Attempts to create a new account for a school.  This method is very similar to the method to\r\nlog an account in - the primary difference being that this method will create the account if\r\nit doesn't exist.  Check the isNewAccount property of the return object to see if the account\r\nis indeed a new account or if it already existed.  Either way, the token for the account will\r\nbe created on the server (i.e., the user will be logged in after this call completes).  All\r\nrules from the login method apply here as well; that is to say, you should treat this method\r\nas two methods in one: 1) we create the account, and 2) we log the account in and return the\r\nresults from the login method.",
        "operationId": "CustomerPublic_CreateAccount",
        "tags": [
          "api/v4/customer/auth/create-account?v3={v3}"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "v3",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
