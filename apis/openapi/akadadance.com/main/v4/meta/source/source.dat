    "/api/v4/customer/students/create": {
      "post": {
        "summary": "Creates a student along with dependent info (profile image, etc.) at the same time.\r\nThe incoming request must be encoded as \"multipart/form-data\" as follows:\r\nstudentInfo: An object containing the primary info for the student.\r\nstudentProfileImage: A file containing the student's profile photo.  Even if there\r\nis no image to be uploaded, always pass a zero-length file for this.\r\nstudentNotes: An object containing an array of notes for the student.  Only those\r\nnotes which the user has the ability to create will be added; others will be\r\nignored.\r\nstudentMaterialTitles: A string array of material titles (if materials are uploaded).\r\nIf the user doesn't have the ability to upload materials, this will be ignored.\r\nstudentMaterialFiles: If material titles are provided, the same number of files\r\nare expected to be uploaded in this array.",
        "operationId": "CustomerStudent_CreateStudentFull",
        "tags": [
          "api/v4/customer/students/create"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
