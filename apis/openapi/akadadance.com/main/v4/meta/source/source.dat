    "/api/v4/customer/account/card/stripe/attach": {
      "post": {
        "summary": "Attaches a Stripe payment method to the logged-in customer's account.  Note that it may take a\r\nfew moments for the payment method to appear on the customer's account, as Stripe will need\r\nto call us back via webhook to finalize the attachment.",
        "operationId": "CustomerCreditCard_AttachStripeCard",
        "tags": [
          "api/v4/customer/account/card/stripe/attach"
        ],
        "responses": {
          "200": {
