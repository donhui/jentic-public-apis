{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "API Tienda Bsale",
    "description": "Documentación de API Tienda Bsale JG",
    "contact": {
      "name": "Jorge Gutierrez",
      "url": "https://github.com/JGutierrez1457",
      "email": "jgutierrezch@uni.pe"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/JGutierrez1457/APIStoreBsale/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://tienda-bsale-jg.herokuapp.com/api",
      "description": "Aplicación desplegada en Heroku"
    }
  ],
  "paths": {
    "/products": {
      "get": {
        "description": "Obtiene los últimos **size** (default 20 si no se especifica el parametro size) productos registrados en la base de datos con los datos de su categoría respectiva, además de datos importantes para la paginación, como la página actual, número total de páginas y número total de registros encontrados.",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "required": false,
            "description": "Página de solicitud **(default 0)**",
            "schema": {
              "type": "number",
              "example": 0
            }
          },
          {
            "in": "query",
            "name": "size",
            "required": false,
            "description": "Tamaño de cada página **(default 20)**",
            "schema": {
              "type": "number",
              "example": 5
            }
          },
          {
            "in": "query",
            "name": "name",
            "required": false,
            "description": "Coincidencia en los nombres de los productos",
            "schema": {
              "type": "string",
              "example": "Bull"
            }
          },
          {
            "in": "query",
            "name": "order",
            "required": false,
            "description": "Tipo de ordenamiento por precio de los productos",
            "schema": {
              "type": "string",
              "enum": [
                "ASC",
                "DESC"
              ],
              "example": "DESC"
            }
          },
          {
            "in": "query",
            "name": "category",
            "required": false,
            "description": "Categorías para filtrar, para más de uno se puede recibir entre comas",
            "schema": {
              "type": "string",
              "example": "1,4"
            }
          },
          {
            "in": "query",
            "name": "deals",
            "required": false,
            "description": "Filtrar o no los productos con ofertas",
            "schema": {
              "type": "boolean",
              "example": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Respuesta exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {
                    "products": [
                      {
                        "id": 6,
                        "name": "ENERGETICA RED BULL",
                        "url_image": "https://dojiw2m9tvv09.cloudfront.net/11132/product/redbull8381.jpg",
                        "price": 1490,
                        "discount": 0,
                        "category": 3,
                        "categories": {
                          "id": 1,
                          "name": "ron"
                        }
                      }
                    ],
                    "totalPages": 1,
                    "count": 1,
                    "pageCurrent": 0
                  }
                }
              }
            }
          }
        },
        "operationId": "get-products"
      }
    },
    "/categories": {
      "get": {
        "description": "Obtiene todas las categorías registradas en la base de datos",
        "tags": [
          "Categories"
        ],
        "responses": {
          "200": {
            "description": "Respuesta exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {
                    "categories": [
                      {
                        "id": 1,
                        "name": "bebida energetica"
                      },
                      {
                        "id": 2,
                        "name": "pisco"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "operationId": "get-categories"
      }
    }
  },
  "tags": [
    {
      "name": "Categories"
    },
    {
      "name": "Products"
    }
  ]
}