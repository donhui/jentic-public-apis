{
  "openapi": "3.0.3",
  "info": {
    "title": "Time Door API",
    "description": "A scalable, resilient, and fully documented API for integrated time series analysis. Provides anomaly detection (point and collective), matrix profile computation, missing value imputation, data transformations, forecasting, changepoint detection, motif discovery, pattern chain analysis, serial dependency analysis, spectral analysis, and causal relation inference.",
    "version": "1.0.0",
    "contact": {
      "name": "Time Door",
      "url": "https://timedoor.io"
    },
    "x-jentic-source-url": "https://timedoor.io"
  },
  "servers": [
    {
      "url": "https://api.timedoor.io",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Anomaly Detection",
      "description": "Detect collective and point anomalies in time series data"
    },
    {
      "name": "Matrix Profile",
      "description": "Compute matrix profiles for time series similarity analysis"
    },
    {
      "name": "Imputation",
      "description": "Impute missing values in time series data"
    },
    {
      "name": "Transformation",
      "description": "Apply data transformations to time series"
    },
    {
      "name": "Forecasting",
      "description": "Generate forecasts for time series data"
    },
    {
      "name": "Changepoint Detection",
      "description": "Detect changepoints in time series data"
    },
    {
      "name": "Motif Discovery",
      "description": "Discover recurring motifs in time series data"
    },
    {
      "name": "Spectral Analysis",
      "description": "Perform spectral analysis on time series data"
    },
    {
      "name": "Causal Inference",
      "description": "Infer causal relations between time series"
    }
  ],
  "paths": {
    "/anomaly": {
      "post": {
        "operationId": "detectAnomalies",
        "summary": "Detect anomalies in time series data",
        "description": "Detects collective and point anomalies in the provided time series data.",
        "tags": ["Anomaly Detection"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TimeSeriesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Anomaly detection results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnomalyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable entity - invalid time series data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/matrix-profile": {
      "post": {
        "operationId": "computeMatrixProfile",
        "summary": "Compute matrix profile",
        "description": "Computes the matrix profile for the provided time series data, enabling similarity analysis and motif/discord detection.",
        "tags": ["Matrix Profile"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MatrixProfileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Matrix profile results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatrixProfileResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/impute": {
      "post": {
        "operationId": "imputeMissingValues",
        "summary": "Impute missing values",
        "description": "Fills in missing values in the time series using the specified imputation method (EWMA, LOCF, or linear interpolation).",
        "tags": ["Imputation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImputationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Imputed time series data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImputationResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/transform": {
      "post": {
        "operationId": "transformTimeSeries",
        "summary": "Apply data transformations",
        "description": "Applies transformations to the time series data including Box-Cox, log, seasonal differencing, and first differencing.",
        "tags": ["Transformation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransformRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transformed time series data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransformResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/forecast": {
      "post": {
        "operationId": "forecastTimeSeries",
        "summary": "Generate time series forecast",
        "description": "Generates a forecast for the provided time series data.",
        "tags": ["Forecasting"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForecastRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Forecast results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/changepoint": {
      "post": {
        "operationId": "detectChangepoints",
        "summary": "Detect changepoints",
        "description": "Detects changepoints in the provided time series data where statistical properties change.",
        "tags": ["Changepoint Detection"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TimeSeriesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Changepoint detection results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangepointResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/motif": {
      "post": {
        "operationId": "discoverMotifs",
        "summary": "Discover motifs in time series",
        "description": "Discovers recurring motifs (patterns) in the provided time series data.",
        "tags": ["Motif Discovery"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TimeSeriesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Motif discovery results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MotifResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/spectral": {
      "post": {
        "operationId": "spectralAnalysis",
        "summary": "Perform spectral analysis",
        "description": "Performs spectral analysis on the provided time series data to identify frequency components.",
        "tags": ["Spectral Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TimeSeriesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Spectral analysis results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SpectralResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/causal": {
      "post": {
        "operationId": "inferCausalRelations",
        "summary": "Infer causal relations",
        "description": "Infers causal relations between multiple time series.",
        "tags": ["Causal Inference"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CausalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Causal inference results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CausalResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication. Obtain from timedoor.io."
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication failed - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Unprocessable entity - invalid time series data",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "TimeSeriesData": {
        "type": "object",
        "description": "Time series data as a mapping of ISO 8601 timestamps to numeric values.",
        "additionalProperties": {
          "type": "number"
        },
        "example": {
          "2020-01-01T00:00:00Z": -0.1313,
          "2020-01-01T00:00:01Z": 0.2456,
          "2020-01-01T00:00:02Z": 0.7891
        }
      },
      "TimeSeriesRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TimeSeriesData"
          },
          "config": {
            "$ref": "#/components/schemas/AnalysisConfig"
          },
          "reproduce": {
            "type": "boolean",
            "description": "When true, include imputation details, transformation parameters, and precision settings in the response for reproducibility.",
            "default": false
          }
        }
      },
      "AnalysisConfig": {
        "type": "object",
        "properties": {
          "imputation": {
            "type": "string",
            "enum": ["ewma", "locf", "linear"],
            "description": "Method for imputing missing values. EWMA (exponentially weighted moving average), LOCF (last observation carried forward), or linear interpolation."
          },
          "transformations": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["box-cox", "log", "seasonal_differencing", "first_differencing"]
            },
            "description": "List of transformations to apply to the data before analysis."
          }
        }
      },
      "ImputationRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TimeSeriesData"
          },
          "method": {
            "type": "string",
            "enum": ["ewma", "locf", "linear"],
            "description": "Imputation method to use.",
            "default": "linear"
          },
          "reproduce": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "TransformRequest": {
        "type": "object",
        "required": ["data", "transformations"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TimeSeriesData"
          },
          "transformations": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["box-cox", "log", "seasonal_differencing", "first_differencing"]
            }
          },
          "reproduce": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "MatrixProfileRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TimeSeriesData"
          },
          "window_size": {
            "type": "integer",
            "description": "Subsequence window size for the matrix profile computation.",
            "minimum": 2
          },
          "config": {
            "$ref": "#/components/schemas/AnalysisConfig"
          }
        }
      },
      "ForecastRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TimeSeriesData"
          },
          "horizon": {
            "type": "integer",
            "description": "Number of time steps to forecast.",
            "minimum": 1
          },
          "config": {
            "$ref": "#/components/schemas/AnalysisConfig"
          },
          "reproduce": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "CausalRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "description": "Multiple named time series for causal analysis.",
            "additionalProperties": {
              "$ref": "#/components/schemas/TimeSeriesData"
            }
          },
          "config": {
            "$ref": "#/components/schemas/AnalysisConfig"
          }
        }
      },
      "AnomalyResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "collective_anomalies": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/CollectiveAnomaly"
                }
              },
              "point_anomalies": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PointAnomaly"
                }
              }
            }
          }
        }
      },
      "CollectiveAnomaly": {
        "type": "object",
        "properties": {
          "t": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the anomaly start."
          },
          "mean_change_strength": {
            "type": "number",
            "description": "Strength of the mean change."
          },
          "variance_change_strength": {
            "type": "number",
            "description": "Strength of the variance change."
          },
          "size": {
            "type": "integer",
            "description": "Number of data points in the anomalous segment."
          }
        }
      },
      "PointAnomaly": {
        "type": "object",
        "properties": {
          "t": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the point anomaly."
          },
          "value": {
            "type": "number",
            "description": "Value at the anomalous point."
          },
          "score": {
            "type": "number",
            "description": "Anomaly score."
          }
        }
      },
      "MatrixProfileResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "matrix_profile": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "description": "The computed matrix profile values."
              },
              "profile_index": {
                "type": "array",
                "items": {
                  "type": "integer"
                },
                "description": "Indices of the nearest neighbor for each subsequence."
              }
            }
          }
        }
      },
      "ImputationResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TimeSeriesData"
          },
          "imputed_indices": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Timestamps of the imputed values."
          },
          "method": {
            "type": "string",
            "description": "The imputation method that was applied."
          }
        }
      },
      "TransformResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TimeSeriesData"
          },
          "transformations_applied": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of transformations that were applied."
          },
          "parameters": {
            "type": "object",
            "description": "Parameters of the applied transformations for reproducibility.",
            "additionalProperties": true
          }
        }
      },
      "ForecastResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TimeSeriesData"
          },
          "confidence_interval": {
            "type": "object",
            "properties": {
              "upper": {
                "$ref": "#/components/schemas/TimeSeriesData"
              },
              "lower": {
                "$ref": "#/components/schemas/TimeSeriesData"
              }
            }
          }
        }
      },
      "ChangepointResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "changepoints": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "t": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "confidence": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "MotifResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "motifs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "start": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "end": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "pattern": {
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "SpectralResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "frequencies": {
                "type": "array",
                "items": {
                  "type": "number"
                }
              },
              "power_spectrum": {
                "type": "array",
                "items": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "CausalResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "relations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "cause": {
                      "type": "string"
                    },
                    "effect": {
                      "type": "string"
                    },
                    "strength": {
                      "type": "number"
                    },
                    "lag": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type or code."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message."
          },
          "detail": {
            "type": "string",
            "description": "Additional error details."
          }
        }
      }
    }
  }
}
