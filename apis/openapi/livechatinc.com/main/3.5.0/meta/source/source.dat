{
  "openapi": "3.0.3",
  "info": {
    "title": "LiveChat API",
    "description": "LiveChat is a customer service chat platform. This API covers messaging (Agent Chat, Customer Chat), management/configuration, and reporting. All endpoints use JSON request/response bodies unless otherwise noted.",
    "version": "3.5.0",
    "x-jentic-source-url": "https://developers.livechat.com/docs/",
    "contact": {
      "name": "LiveChat Developer Support",
      "url": "https://developers.livechat.com"
    }
  },
  "servers": [
    {
      "url": "https://api.livechatinc.com/v3.5",
      "description": "LiveChat API v3.5 production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Configuration",
      "description": "Management and configuration endpoints for agents, groups, webhooks, bots, and properties"
    },
    {
      "name": "AgentChat",
      "description": "Agent-side chat messaging endpoints for managing chats, threads, events, and routing"
    },
    {
      "name": "CustomerChat",
      "description": "Customer-side chat messaging endpoints"
    },
    {
      "name": "Reports",
      "description": "Reporting endpoints for chat statistics, ratings, response times, and agent availability"
    }
  ],
  "paths": {
    "/configuration/action/list_agents": {
      "get": {
        "operationId": "listAgents",
        "summary": "List agents",
        "description": "Returns a list of all agents in the license. Requires agents--all:ro scope.",
        "tags": ["Configuration"],
        "parameters": [
          {
            "name": "group_id",
            "in": "query",
            "description": "Filter agents by group ID",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of agents returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Agent"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/configuration/action/create_agent": {
      "post": {
        "operationId": "createAgent",
        "summary": "Create agent",
        "description": "Creates a new agent account. Requires accounts--all:rw scope.",
        "tags": ["Configuration"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAgentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/configuration/action/get_agent": {
      "get": {
        "operationId": "getAgent",
        "summary": "Get agent",
        "description": "Returns details of a specific agent. Requires agents--all:ro scope.",
        "tags": ["Configuration"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "Agent ID (email address)",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent details returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Agent"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/configuration/action/update_agent": {
      "post": {
        "operationId": "updateAgent",
        "summary": "Update agent",
        "description": "Updates an existing agent's properties. Requires agents--all:rw scope.",
