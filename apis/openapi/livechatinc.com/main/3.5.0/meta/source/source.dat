  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "OAuth2 Access Token or Personal Access Token",
        "description": "Use a Bearer token obtained via OAuth 2.0 or a Personal Access Token (PAT)"
      },
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authorization for LiveChat API. Supports Authorization Code and Implicit flows.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://accounts.livechat.com/authorize",
            "tokenUrl": "https://accounts.livechat.com/token",
            "scopes": {
              "chats--all:ro": "Read access to all chats",
              "chats--all:rw": "Read and write access to all chats",
              "chats--access:ro": "Read access to chats the agent has access to",
              "chats--access:rw": "Read and write access to chats the agent has access to",
              "agents--all:ro": "Read access to all agents",
              "agents--all:rw": "Read and write access to all agents",
              "agents-bot--all:ro": "Read access to all bot agents",
              "agents-bot--all:rw": "Read and write access to all bot agents",
              "agents-bot--my:rw": "Read and write access to own bot agents",
              "groups:ro": "Read access to groups",
              "groups:rw": "Read and write access to groups",
              "webhooks:ro": "Read access to webhooks",
              "webhooks:rw": "Read and write access to webhooks",
              "properties:ro": "Read access to properties",
              "properties:rw": "Read and write access to properties",
              "customers:ro": "Read access to customers",
              "customers:rw": "Read and write access to customers",
              "reports:ro": "Read access to reports"
            }
          },
          "implicit": {
            "authorizationUrl": "https://accounts.livechat.com/authorize",
            "scopes": {
              "chats--all:ro": "Read access to all chats",
              "chats--all:rw": "Read and write access to all chats",
              "agents--all:ro": "Read access to all agents",
              "groups:ro": "Read access to groups",
              "reports:ro": "Read access to reports"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "Standard error response returned by the LiveChat API",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Error type identifier (e.g., validation, authentication, not_found, internal)",
                "example": "validation"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error description",
                "example": "Invalid request parameters"
              },
              "data": {
                "type": "object",
                "description": "Additional error context and field-level details",
                "additionalProperties": true
              }
            },
            "required": ["type", "message"]
          }
        },
        "required": ["error"]
      },
      "EmptyResponse": {
        "type": "object",
        "description": "Empty success response",
        "properties": {}
      },
      "Agent": {
        "type": "object",
        "description": "LiveChat agent account",
        "properties": {
          "id": {
            "type": "string",
            "description": "Agent ID (email address)"
          },
          "name": {
            "type": "string",
            "description": "Agent display name"
          },
          "role": {
            "type": "string",
            "description": "Agent role",
            "enum": ["viceowner", "administrator", "normal"]
          },
          "login_status": {
            "type": "string",
            "description": "Current login status",
            "enum": ["accepting chats", "not accepting chats"]
          },
          "avatar": {
            "type": "string",
            "description": "URL of the agent's avatar image"
          },
          "job_title": {
            "type": "string",
            "description": "Agent job title"
          },
          "mobile": {
            "type": "string",
            "description": "Agent mobile phone number"
          },
          "max_chats_count": {
            "type": "integer",
            "description": "Maximum number of concurrent chats (max 20)",
            "maximum": 20
          },
          "groups": {
            "type": "array",
            "description": "Groups the agent belongs to with priority settings",
            "items": {
              "$ref": "#/components/schemas/AgentGroupAssignment"
            }
          },
          "notifications": {
            "type": "array",
            "description": "Enabled notification types",
            "items": {
              "type": "string"
            }
          },
          "email_subscriptions": {
            "type": "array",
            "description": "Email subscription preferences",
            "items": {
              "type": "string",
              "enum": ["daily_summary", "weekly_summary"]
            }
          },
          "work_scheduler": {
            "type": "object",
            "description": "Work schedule configuration",
            "properties": {
              "timezone": {
                "type": "string",
                "description": "Timezone for the schedule"
              }
            }
          }
        },
        "required": ["id", "name"]
      },
      "AgentGroupAssignment": {
        "type": "object",
        "description": "Agent assignment to a group with routing priority",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Group ID"
          },
          "priority": {
            "type": "string",
            "description": "Routing priority within the group",
            "enum": ["first", "normal", "last", "supervisor"]
          }
        },
        "required": ["id", "priority"]
      },
      "CreateAgentRequest": {
        "type": "object",
        "description": "Request body for creating an agent",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Agent ID (email address)"
          },
          "name": {
            "type": "string",
            "description": "Agent display name"
          },
          "role": {
            "type": "string",
            "description": "Agent role",
            "enum": ["viceowner", "administrator", "normal"],
            "default": "normal"
          },
          "avatar": {
            "type": "string",
            "description": "URL of the agent's avatar image"
          },
          "job_title": {
            "type": "string",
            "description": "Agent job title"
          },
          "mobile": {
            "type": "string",
            "description": "Agent mobile phone number"
          },
          "max_chats_count": {
            "type": "integer",
            "description": "Maximum number of concurrent chats",
            "maximum": 20
          },
          "groups": {
            "type": "array",
            "description": "Groups to assign the agent to",
            "items": {
              "$ref": "#/components/schemas/AgentGroupAssignment"
            }
          },
          "notifications": {
            "type": "array",
            "description": "Notification types to enable",
            "items": {
              "type": "string"
            }
          },
          "email_subscriptions": {
            "type": "array",
            "description": "Email subscriptions to enable",
            "items": {
              "type": "string",
              "enum": ["daily_summary", "weekly_summary"]
            }
          }
        }
      },
      "UpdateAgentRequest": {
        "type": "object",
        "description": "Request body for updating an agent",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Agent ID (email address) to update"
          },
          "name": {
            "type": "string",
            "description": "Updated display name"
          },
          "role": {
            "type": "string",
            "description": "Updated role",
            "enum": ["viceowner", "administrator", "normal"]
          },
          "avatar": {
            "type": "string",
            "description": "Updated avatar URL"
          },
          "job_title": {
            "type": "string",
            "description": "Updated job title"
          },
          "mobile": {
            "type": "string",
            "description": "Updated mobile number"
          },
          "max_chats_count": {
            "type": "integer",
            "description": "Updated max concurrent chats",
            "maximum": 20
          },
          "groups": {
            "type": "array",
            "description": "Updated group assignments",
            "items": {
              "$ref": "#/components/schemas/AgentGroupAssignment"
            }
          }
        }
      },
      "Group": {
        "type": "object",
        "description": "LiveChat group (department)",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Group ID"
          },
          "name": {
            "type": "string",
            "description": "Group name (max 180 characters)",
            "maxLength": 180
          },
          "language_code": {
            "type": "string",
            "description": "Language code for the group"
          },
          "agent_priorities": {
            "type": "object",
            "description": "Map of agent IDs to their routing priorities within this group",
            "additionalProperties": {
              "type": "string",
              "enum": ["first", "normal", "last", "supervisor"]
            }
          }
        },
        "required": ["id", "name"]
      },
      "CreateGroupRequest": {
        "type": "object",
        "description": "Request body for creating a group",
        "required": ["name", "agent_priorities"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Group name (max 180 characters)",
            "maxLength": 180
          },
          "language_code": {
            "type": "string",
            "description": "Language code for the group"
          },
          "agent_priorities": {
            "type": "object",
            "description": "Map of agent IDs to their routing priorities",
            "additionalProperties": {
              "type": "string",
              "enum": ["first", "normal", "last", "supervisor"]
            }
          }
        }
      },
      "UpdateGroupRequest": {
        "type": "object",
        "description": "Request body for updating a group",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Group ID to update"
          },
          "name": {
            "type": "string",
            "description": "Updated group name",
            "maxLength": 180
          },
          "language_code": {
            "type": "string",
            "description": "Updated language code"
          },
          "agent_priorities": {
            "type": "object",
            "description": "Updated agent priority assignments",
            "additionalProperties": {
              "type": "string",
              "enum": ["first", "normal", "last", "supervisor"]
            }
          }
        }
      },
      "Webhook": {
        "type": "object",
        "description": "Registered webhook configuration",
        "properties": {
          "id": {
            "type": "string",
            "description": "Webhook ID"
          },
          "url": {
            "type": "string",
            "description": "Webhook endpoint URL"
          },
          "action": {
            "type": "string",
            "description": "Event type that triggers this webhook"
          },
          "secret_key": {
            "type": "string",
            "description": "Secret key for HMAC webhook verification"
          },
          "filters": {
            "type": "object",
            "description": "Event filtering conditions",
            "additionalProperties": true
          },
          "owner_client_id": {
            "type": "string",
            "description": "Client ID of the webhook owner"
          }
        },
        "required": ["id", "url", "action"]
      },
      "RegisterWebhookRequest": {
        "type": "object",
        "description": "Request body for registering a webhook",
        "required": ["url", "action"],
        "properties": {
          "url": {
            "type": "string",
            "description": "Webhook endpoint URL",
            "format": "uri"
          },
          "action": {
            "type": "string",
            "description": "Event type to trigger the webhook (e.g., incoming_chat, chat_deactivated)"
          },
          "secret_key": {
            "type": "string",
            "description": "Secret key for HMAC verification of webhook payloads"
          },
          "filters": {
            "type": "object",
            "description": "Optional event filtering conditions",
            "additionalProperties": true
          }
        }
      },
      "Bot": {
        "type": "object",
        "description": "LiveChat bot agent",
        "properties": {
          "id": {
            "type": "string",
            "description": "Bot ID"
          },
          "name": {
            "type": "string",
            "description": "Bot display name"
          },
          "avatar": {
            "type": "string",
            "description": "Bot avatar URL"
          },
          "max_chats_count": {
            "type": "integer",
            "description": "Maximum number of concurrent chats (max 500, default 6)",
            "maximum": 500,
            "default": 6
          },
          "default_group_priority": {
            "type": "string",
            "description": "Default routing priority for the bot",
            "enum": ["first", "normal", "last", "supervisor"]
          },
          "groups": {
            "type": "array",
            "description": "Groups the bot belongs to",
            "items": {
              "$ref": "#/components/schemas/AgentGroupAssignment"
            }
          },
          "owner_client_id": {
            "type": "string",
            "description": "Application client ID that owns this bot"
          },
          "job_title": {
            "type": "string",
            "description": "Bot job title"
          }
        },
        "required": ["id", "name"]
      },
      "CreateBotRequest": {
        "type": "object",
        "description": "Request body for creating a bot agent",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Bot display name"
          },
          "avatar": {
            "type": "string",
            "description": "Bot avatar URL"
          },
          "max_chats_count": {
            "type": "integer",
            "description": "Maximum concurrent chats (max 500, default 6)",
            "maximum": 500,
            "default": 6
          },
          "default_group_priority": {
            "type": "string",
            "description": "Default routing priority",
            "enum": ["first", "normal", "last", "supervisor"]
          },
          "groups": {
            "type": "array",
            "description": "Groups to assign the bot to",
            "items": {
              "$ref": "#/components/schemas/AgentGroupAssignment"
            }
          },
          "job_title": {
            "type": "string",
            "description": "Bot job title"
          }
        }
      },
      "UpdateBotRequest": {
        "type": "object",
        "description": "Request body for updating a bot agent",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Bot ID to update"
          },
          "name": {
            "type": "string",
            "description": "Updated bot display name"
          },
          "avatar": {
            "type": "string",
            "description": "Updated avatar URL"
          },
          "max_chats_count": {
            "type": "integer",
            "description": "Updated max concurrent chats",
            "maximum": 500
          },
          "default_group_priority": {
            "type": "string",
            "description": "Updated default routing priority",
            "enum": ["first", "normal", "last", "supervisor"]
          },
          "groups": {
            "type": "array",
            "description": "Updated group assignments",
            "items": {
              "$ref": "#/components/schemas/AgentGroupAssignment"
            }
          }
        }
      },
      "PropertyConfig": {
        "type": "object",
        "description": "Custom property configuration",
        "properties": {
          "name": {
            "type": "string",
            "description": "Property name identifier"
          },
          "type": {
            "type": "string",
            "description": "Property value type",
            "enum": ["string", "int", "bool"]
          },
          "description": {
            "type": "string",
            "description": "Property description"
          },
          "domain": {
            "type": "array",
            "description": "Allowed values for the property (if restricted)",
            "items": {
              "type": "string"
            }
          },
          "access": {
            "type": "object",
            "description": "Access control for the property per location",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "agent": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["read", "write"]
                  }
                },
                "customer": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["read", "write"]
                  }
                }
              }
            }
          }
        },
        "required": ["name", "type"]
      },
      "RegisterPropertyRequest": {
        "type": "object",
        "description": "Request body for registering a custom property",
        "required": ["name", "type", "access"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Property name identifier"
          },
          "type": {
            "type": "string",
            "description": "Property value type",
            "enum": ["string", "int", "bool"]
          },
          "description": {
            "type": "string",
            "description": "Property description"
          },
          "domain": {
            "type": "array",
            "description": "Restrict allowed values",
            "items": {
              "type": "string"
            }
          },
          "access": {
            "type": "object",
            "description": "Access control settings per location (chat, thread, event)",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "agent": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["read", "write"]
                  }
                },
                "customer": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["read", "write"]
                  }
                }
              }
            }
          }
        }
      },
      "Chat": {
        "type": "object",
        "description": "Chat object containing thread, users, and properties",
        "properties": {
          "id": {
            "type": "string",
            "description": "Chat ID"
          },
          "users": {
            "type": "array",
            "description": "Users participating in the chat",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "thread": {
            "$ref": "#/components/schemas/Thread"
          },
          "properties": {
            "type": "object",
            "description": "Custom properties attached to the chat",
            "additionalProperties": true
          },
          "access": {
            "type": "object",
            "description": "Access control for the chat",
            "properties": {
              "group_ids": {
                "type": "array",
                "description": "Group IDs that have access to this chat",
                "items": {
                  "type": "integer"
                }
              }
            }
          },
          "is_followed": {
            "type": "boolean",
            "description": "Whether the requester follows this chat"
          }
        },
        "required": ["id"]
      },
      "Thread": {
        "type": "object",
        "description": "Thread within a chat containing events",
        "properties": {
          "id": {
            "type": "string",
            "description": "Thread ID"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Thread creation timestamp"
          },
          "active": {
            "type": "boolean",
            "description": "Whether the thread is currently active"
          },
          "user_ids": {
            "type": "array",
            "description": "IDs of users participating in the thread",
            "items": {
              "type": "string"
            }
          },
          "events": {
            "type": "array",
            "description": "Events (messages, system messages, etc.) in the thread",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "properties": {
            "type": "object",
            "description": "Custom properties attached to the thread",
            "additionalProperties": true
          },
          "tags": {
            "type": "array",
            "description": "Tags applied to the thread",
            "items": {
              "type": "string"
            }
          },
          "summary": {
            "type": "string",
            "description": "AI-generated summary of the thread"
          }
        },
        "required": ["id"]
      },
      "Event": {
        "type": "object",
        "description": "Event within a thread (message, file, system message, etc.)",
        "properties": {
          "id": {
            "type": "string",
            "description": "Event ID"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Event creation timestamp"
          },
          "type": {
            "type": "string",
            "description": "Event type",
            "enum": ["message", "system_message", "file", "filled_form", "rich_message", "custom"]
          },
          "visibility": {
            "type": "string",
            "description": "Who can see this event",
            "enum": ["all", "agents"]
          },
          "author_id": {
            "type": "string",
            "description": "ID of the user who created the event"
          },
          "text": {
            "type": "string",
            "description": "Message text content (for message type events)"
          },
          "properties": {
            "type": "object",
            "description": "Custom properties attached to the event",
            "additionalProperties": true
          }
        },
        "required": ["id", "type"]
      },
      "User": {
        "type": "object",
        "description": "User participating in a chat (agent or customer)",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "type": {
            "type": "string",
            "description": "User type",
            "enum": ["agent", "customer"]
          },
          "name": {
            "type": "string",
            "description": "User display name"
          },
          "email": {
            "type": "string",
            "description": "User email address"
          },
          "avatar": {
            "type": "string",
            "description": "User avatar URL"
          },
          "present": {
            "type": "boolean",
            "description": "Whether the user is currently present/online"
          }
        },
        "required": ["id", "type"]
      },
      "ChatSummary": {
        "type": "object",
        "description": "Summary of a chat for list endpoints",
        "properties": {
          "id": {
            "type": "string",
            "description": "Chat ID"
          },
          "last_event_per_type": {
            "type": "object",
            "description": "Most recent event of each type in the chat",
            "additionalProperties": {
              "$ref": "#/components/schemas/Event"
            }
          },
          "users": {
            "type": "array",
            "description": "Users participating in the chat",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "last_thread_summary": {
            "type": "object",
            "description": "Summary of the latest thread",
            "properties": {
              "id": {
                "type": "string"
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              },
              "active": {
                "type": "boolean"
              },
              "user_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "properties": {
            "type": "object",
            "additionalProperties": true
          },
          "access": {
            "type": "object",
            "properties": {
              "group_ids": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              }
            }
          },
          "is_followed": {
            "type": "boolean"
          }
        },
        "required": ["id"]
      },
      "ListChatsResponse": {
        "type": "object",
        "description": "Paginated response for listing chats",
        "properties": {
          "chats_summary": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatSummary"
            }
          },
          "found_chats": {
            "type": "integer",
            "description": "Total number of chats matching the query"
          },
          "next_page_id": {
            "type": "string",
            "description": "Cursor for the next page of results"
          },
          "previous_page_id": {
            "type": "string",
            "description": "Cursor for the previous page of results"
          }
        }
      },
      "ListThreadsResponse": {
        "type": "object",
        "description": "Paginated response for listing threads",
        "properties": {
          "threads": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Thread"
            }
          },
          "found_threads": {
            "type": "integer",
            "description": "Total number of threads matching the query"
          },
          "next_page_id": {
            "type": "string",
            "description": "Cursor for the next page of results"
          },
          "previous_page_id": {
            "type": "string",
            "description": "Cursor for the previous page of results"
          }
        }
      },
      "StartChatResponse": {
        "type": "object",
        "description": "Response when starting a new chat",
        "properties": {
          "chat_id": {
            "type": "string",
            "description": "ID of the newly created chat"
          },
          "thread_id": {
            "type": "string",
            "description": "ID of the initial thread in the chat"
          },
          "event_ids": {
            "type": "array",
            "description": "IDs of events created with the chat",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["chat_id", "thread_id"]
      },
      "ActivateChatRequest": {
        "type": "object",
        "description": "Request body for activating (resuming) an inactive chat",
        "required": ["chat"],
        "properties": {
          "chat": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Chat ID to activate"
              },
              "properties": {
                "type": "object",
                "description": "Properties to set on the chat",
                "additionalProperties": true
              },
              "access": {
                "type": "object",
                "description": "Access settings for the chat",
                "properties": {
                  "group_ids": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              },
              "thread": {
                "type": "object",
                "description": "Initial thread configuration",
                "properties": {
                  "events": {
                    "type": "array",
                    "description": "Initial events to include in the thread",
                    "items": {
                      "$ref": "#/components/schemas/Event"
                    }
                  },
                  "properties": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        }
      },
      "ActivateChatResponse": {
        "type": "object",
        "description": "Response when activating a chat",
        "properties": {
          "thread_id": {
            "type": "string",
            "description": "ID of the new thread created"
          },
          "event_ids": {
            "type": "array",
            "description": "IDs of events created with the thread",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["thread_id"]
      },
      "AgentStartChatRequest": {
        "type": "object",
        "description": "Request body for starting a new chat as an agent",
        "properties": {
          "chat": {
            "type": "object",
            "description": "Chat configuration",
            "properties": {
              "properties": {
                "type": "object",
                "description": "Custom properties for the chat",
                "additionalProperties": true
              },
              "access": {
                "type": "object",
                "properties": {
                  "group_ids": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              },
              "users": {
                "type": "array",
                "description": "Users to add to the chat",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": ["agent", "customer"]
                    }
                  },
                  "required": ["id", "type"]
                }
              },
              "thread": {
                "type": "object",
                "description": "Initial thread configuration",
                "properties": {
                  "events": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Event"
                    }
                  },
                  "properties": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        }
      },
      "CustomerStartChatRequest": {
        "type": "object",
        "description": "Request body for starting a new chat as a customer",
        "properties": {
          "chat": {
            "type": "object",
            "description": "Chat configuration",
            "properties": {
              "properties": {
                "type": "object",
                "description": "Custom properties for the chat",
                "additionalProperties": true
              },
              "access": {
                "type": "object",
                "properties": {
                  "group_ids": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              },
              "thread": {
                "type": "object",
                "description": "Initial thread configuration",
                "properties": {
                  "events": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/Event"
                    }
                  },
                  "properties": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              }
            }
          }
        }
