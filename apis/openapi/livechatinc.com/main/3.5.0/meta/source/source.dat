    "/agent/action/deactivate_chat": {
      "post": {
        "operationId": "deactivateChat",
        "summary": "Deactivate chat",
        "description": "Deactivates an active chat. The chat becomes inactive and its thread is closed.",
        "tags": ["AgentChat"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Chat ID to deactivate"
                  },
                  "ignore_requester_presence": {
                    "type": "boolean",
                    "description": "If true, allows deactivation even if the requester is not present in the chat",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat deactivated successfully",
            "content": {
              "application/json": {
                "schema": {
