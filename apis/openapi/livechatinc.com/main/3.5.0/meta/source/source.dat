            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/configuration/action/delete_agent": {
      "post": {
        "operationId": "deleteAgent",
        "summary": "Delete agent",
