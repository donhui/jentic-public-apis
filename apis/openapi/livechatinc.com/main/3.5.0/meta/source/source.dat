      "SendEventRequest": {
        "type": "object",
        "description": "Request body for sending an event to a chat",
        "required": ["chat_id", "event"],
        "properties": {
          "chat_id": {
            "type": "string",
            "description": "Chat ID to send the event to"
          },
          "event": {
            "type": "object",
            "description": "Event object to send",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "description": "Event type",
                "enum": ["message", "file", "rich_message", "custom"]
              },
              "text": {
                "type": "string",
                "description": "Message text (required for message type)"
              },
              "visibility": {
                "type": "string",
                "description": "Event visibility",
                "enum": ["all", "agents"],
                "default": "all"
              },
              "properties": {
                "type": "object",
                "description": "Custom properties for the event",
                "additionalProperties": true
              }
            }
          },
          "attach_to_last_thread": {
            "type": "boolean",
            "description": "If true, attaches the event to the last thread",
            "default": false
          }
        }
      },
      "SendEventResponse": {
        "type": "object",
        "description": "Response after sending an event",
        "properties": {
          "event_id": {
            "type": "string",
            "description": "ID of the created event"
          }
        },
        "required": ["event_id"]
      },
      "TransferChatRequest": {
        "type": "object",
        "description": "Request body for transferring a chat to another agent or group",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Chat ID to transfer"
          },
          "target": {
            "type": "object",
            "description": "Transfer target",
            "properties": {
              "type": {
                "type": "string",
                "description": "Target type",
                "enum": ["group", "agent"]
              },
              "ids": {
                "type": "array",
                "description": "Target group or agent IDs",
                "items": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    }
                  ]
                }
              }
            },
            "required": ["type", "ids"]
          },
          "ignore_agents_availability": {
            "type": "boolean",
            "description": "If true, transfers even if the target agent is not available",
            "default": false
          },
          "ignore_requester_presence": {
            "type": "boolean",
            "description": "If true, allows transfer even if the requester is not present",
            "default": false
          }
        }
      },
      "RoutingStatus": {
        "type": "object",
        "description": "Routing status of an agent",
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Agent ID"
          },
          "status": {
            "type": "string",
            "description": "Current routing status",
            "enum": ["accepting_chats", "not_accepting_chats", "offline"]
          }
        },
        "required": ["agent_id", "status"]
      },
      "TotalChatsReport": {
        "type": "object",
        "description": "Total chats report data",
        "properties": {
          "records": {
            "type": "array",
            "description": "Report records grouped by the specified interval",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string",
                  "format": "date",
                  "description": "Date of the record"
                },
                "total": {
                  "type": "integer",
                  "description": "Total number of chats"
                },
                "continuations": {
                  "type": "integer",
                  "description": "Number of continued chats"
                },
                "new_chats": {
                  "type": "integer",
                  "description": "Number of new chats"
                }
              }
            }
          },
          "total": {
            "type": "integer",
            "description": "Grand total of chats in the period"
          }
        }
      },
      "RatingsReport": {
        "type": "object",
        "description": "Chat ratings report data",
        "properties": {
          "records": {
            "type": "array",
            "description": "Rating records grouped by the specified interval",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string",
                  "format": "date",
                  "description": "Date of the record"
                },
                "good": {
                  "type": "integer",
                  "description": "Number of good ratings"
                },
                "bad": {
                  "type": "integer",
                  "description": "Number of bad ratings"
                },
                "rated": {
                  "type": "integer",
                  "description": "Total number of rated chats"
                },
                "not_rated": {
                  "type": "integer",
                  "description": "Number of unrated chats"
                }
              }
            }
          }
        }
      },
      "ResponseTimeReport": {
        "type": "object",
        "description": "Response time report data",
        "properties": {
          "records": {
            "type": "array",
            "description": "Response time records grouped by the specified interval",
            "items": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string",
                  "format": "date",
                  "description": "Date of the record"
                },
                "first_response_time": {
                  "type": "number",
                  "format": "float",
                  "description": "Average first response time in seconds"
                },
                "response_time": {
                  "type": "number",
                  "format": "float",
                  "description": "Average response time in seconds"
                },
                "count": {
                  "type": "integer",
