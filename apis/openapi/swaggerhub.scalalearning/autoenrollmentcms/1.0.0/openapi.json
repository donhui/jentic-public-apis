{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Autoenrollment_CMS",
    "description": "Documentacion para la implementacion del proceso de Autoenrollment al nuevo CMS .",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/SCALALEARNING/AutoenrollmentCMS/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "http://localhost/inscripcion",
      "description": "Esta url-base permite consumir los WebServices del nuevo Autoenrollment."
    }
  ],
  "tags": [
    {
      "name": "Get_career_info."
    }
  ],
  "paths": {
    "/get_paquetes_act/": {
      "post": {
        "tags": [
          "Get_career_info."
        ],
        "summary": "Obtencion de la informacion referente al id de la carrera.",
        "operationId": "Edicion de datos de facturacion.",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/career_req_model"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Respuesta del Web Service si la petici\u00f3n fue correcta.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/careers_resp_model"
                }
              }
            }
          },
          "400": {
            "description": "Respuesta del Web Service si la petici\u00f3n fue err\u00f3nea.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/fail_response"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "career_req_model": {
        "properties": {
          "id": {
            "description": "Campo de id asociado a la solicitud .",
            "type": "string",
            "example": "MDDRA123DQ12."
          },
          "country": {
            "description": "Campo de codigo de pais para solicitar la informacion de las carreras disponibles",
            "type": "string",
            "example": "MXN"
          }
        },
        "type": "object",
        "required": [
          "id",
          "country"
        ]
      },
      "exito_response": {
        "properties": {
          "message": {
            "type": "string",
            "example": "Exito."
          },
          "status": {
            "type": "string",
            "example": 200
          }
        },
        "type": "object"
      },
      "fail_response": {
        "properties": {
          "message": {
            "type": "string",
            "example": "Hubo un problema durante el proceso."
          },
          "exception": {
            "type": "string",
            "example": "Error durante el proceso"
          }
        },
        "type": "object"
      },
      "careers_resp_model": {
        "type": "object",
        "required": [
          "matricula"
        ],
        "properties": {
          "titulo": {
            "description": "Titulo.",
            "type": "string",
            "example": "Licenciatura en Administraci\u00f3n de Negocios Ejecutivo"
          },
          "fechas": {
            "description": "Fechas disponibles.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/fecha_model"
            }
          },
          "tipo": {
            "description": "Tipo.",
            "type": "string",
            "example": "REGULAR"
          },
          "modalidad": {
            "description": "Modalidad disponible.",
            "type": "string",
            "example": "Online"
          },
          "paquetes": {
            "description": "Paquetes disponibles.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/paquetes_model"
            }
          },
          "accesorios": {
            "description": "Accesorios disponibles.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/accesorios_model"
            }
          }
        }
      },
      "fecha_model": {
        "type": "object",
        "properties": {
          "to": {
            "description": "Intervalo de fecha hasta.",
            "type": "string",
            "example": "28-08-2022"
          },
          "from": {
            "description": "Intervalo de fecha de.",
            "type": "string",
            "example": "18-07-2022"
          },
          "value": {
            "description": "Codigo de la fecha de inicio.",
            "type": "string",
            "example": "L0B-7"
          }
        }
      },
      "jornada_model": {
        "type": "object",
        "properties": {
          "value": {
            "description": "Clave de la jornada.",
            "type": "string",
            "example": "1LC2 - JOR COMPLETA 2 MAT LICEN PRIM"
          },
          "descrip": {
            "description": "Descripcion de la jornada.",
            "type": "string",
            "example": "1LC2"
          }
        }
      },
      "escalonado_model": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Id de escalonado.",
            "type": "string",
            "example": 6
          },
          "nombre": {
            "description": "Nombre de escalonado.",
            "type": "string",
            "example": "BIMESTRAL1.COMEXE4M"
          },
          "escalonado": {
            "description": "Elemento de escalonado.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/escalon_item_model"
            }
          }
        }
      },
      "escalon_item_model": {
        "properties": {
          "mensualidad": {
            "description": "Mensualidad.",
            "type": "string",
            "example": 1
          },
          "moneda_pago": {
            "description": "Moneda pago.",
            "type": "string",
            "example": "MXN"
          },
          "precio": {
            "description": "Precio.",
            "type": "string",
            "example": 1299.0
          }
        }
      },
      "accesorios_model": {
        "type": "object",
        "properties": {
          "id": {
            "description": "Precio final asociado.",
            "type": "string"
          },
          "categoria": {
            "description": "Categoria del accesorio.",
            "type": "string"
          },
          "comision": {
            "description": "Comision del accesorio.",
            "type": "string"
          },
          "pagos": {
            "description": "Pagos del accesorio.",
            "type": "string"
          },
          "descuento": {
            "description": "Descuento del accesorio.",
            "type": "string"
          },
          "descripcion": {
            "description": "Descripci\u00f3n del accesorio.",
            "type": "string"
          },
          "codigo": {
            "description": "Codigo del accesorio.",
            "type": "string"
          },
          "precio_final": {
            "description": "Precio final asociado.",
            "type": "string"
          }
        }
      },
      "paquetes_model": {
        "type": "object",
        "properties": {
          "nombre": {
            "description": "Descripci\u00f3n del accesorio.",
            "type": "string",
            "example": "LI.AUTOENROLLMENT.DINAMICO.TEST"
          },
          "id_paquete": {
            "description": "Id del paquete.",
            "type": "string",
            "example": "Id del paquete"
          },
          "nivel": {
            "description": "Precio lista asociado.",
            "type": "string",
            "example": "LI"
          },
          "rate": {
            "description": "Rate asociado al paquete.",
            "type": "string",
            "example": "J02BP"
          },
          "descripcion": {
            "description": "Descripci\u00f3n.",
            "type": "string",
            "example": "LI.AUTOENROLLMENT.DINAMICO.TEST"
          },
          "moneda": {
            "description": "Moneda.",
            "type": "string",
            "example": "MXN"
          },
          "precio_lista": {
            "description": "Precio lista asociado.",
            "type": "string",
            "example": 14480.0
          },
          "precio_final": {
            "description": "Precio final.",
            "type": "string",
            "example": 5400.0
          },
          "excencion": {
            "description": "Excenci\u00f3n.",
            "type": "string",
            "example": 5
          },
          "condonacion": {
            "description": "Condonaci\u00f3n.",
            "type": "string",
            "example": 550.0
          },
          "jornada": {
            "description": "Jornadas disponibles.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/jornada_model"
            }
          },
          "escalonados_disp": {
            "description": "Elementos disponibles de escalonados",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/escalonado_model"
            }
          }
        }
      }
    }
  }
}