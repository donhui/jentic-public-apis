{
  "openapi": "3.0.3",
  "info": {
    "title": "Bancontact Payconiq Payments API",
    "version": "3.0.0",
    "description": "Payconiq online payments API for creating, retrieving, searching, and cancelling payments. Supports dynamic and static QR code payment flows.",
    "x-jentic-source-url": "https://developer.payconiq.com/online-payments-dock/"
  },
  "servers": [
    {
      "url": "https://api.payconiq.com/v3",
      "description": "Production"
    },
    {
      "url": "https://api.ext.payconiq.com/v3",
      "description": "External / Testing"
    }
  ],
  "paths": {
    "/payments": {
      "post": {
        "operationId": "createPayment",
        "summary": "Create a new payment",
        "description": "Initiates a new payment transaction.",
        "tags": ["Payments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payment created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/pos": {
      "post": {
        "operationId": "createPosPayment",
        "summary": "Create a POS / static QR payment",
        "description": "Creates a payment linked to a specific point-of-sale terminal.",
        "tags": ["Payments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePosPaymentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "POS payment created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/{paymentId}": {
      "get": {
        "operationId": "getPayment",
        "summary": "Get payment details",
        "description": "Retrieves the current status and details of a specific payment.",
        "tags": ["Payments"],
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "description": "24-character unique payment identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment details retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "cancelPayment",
        "summary": "Cancel a payment",
        "description": "Cancels a pending or identified payment.",
        "tags": ["Payments"],
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "description": "24-character unique payment identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Payment cancelled successfully"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Payment cannot be cancelled (not in PENDING or IDENTIFIED status)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/payments/search": {
      "post": {
        "operationId": "searchPayments",
        "summary": "Search payments",
        "description": "Searches and retrieves paginated payment history.",
        "tags": ["Payments"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Zero-based page index",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "Number of records per page",
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchPaymentsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Paginated payment results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchPaymentsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreatePaymentRequest": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": {
            "type": "integer",
            "minimum": 1,
            "maximum": 999999,
            "description": "Payment amount in Euro cents"
          },
          "currency": {
            "type": "string",
            "enum": ["EUR"],
            "description": "ISO 4217 currency code"
          },
          "description": {
            "type": "string",
            "maxLength": 140,
            "description": "Payment description"
          },
          "reference": {
            "type": "string",
            "maxLength": 35,
            "description": "Merchant reference"
          },
          "callbackUrl": {
            "type": "string",
            "format": "uri",
            "description": "HTTPS endpoint for payment status notifications"
          },
          "bulkId": {
            "type": "string",
            "maxLength": 35,
            "description": "Batch reference identifier"
          }
        }
      },
      "CreatePosPaymentRequest": {
        "type": "object",
        "required": ["amount", "posId"],
        "properties": {
          "amount": {
            "type": "integer",
            "minimum": 1,
            "maximum": 999999,
            "description": "Payment amount in Euro cents"
          },
          "currency": {
            "type": "string",
            "enum": ["EUR"],
            "description": "ISO 4217 currency code"
          },
          "description": {
            "type": "string",
            "maxLength": 140,
            "description": "Payment description"
          },
          "reference": {
            "type": "string",
            "maxLength": 35,
            "description": "Merchant reference"
          },
          "callbackUrl": {
            "type": "string",
            "format": "uri",
            "description": "HTTPS endpoint for payment status notifications"
          },
          "posId": {
            "type": "string",
            "maxLength": 36,
            "description": "Point-of-sale identifier"
          },
          "shopId": {
            "type": "string",
            "maxLength": 36,
            "description": "Shop identifier"
          },
          "shopName": {
            "type": "string",
            "maxLength": 36,
            "description": "Displayed shop name"
          }
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "paymentId": {
            "type": "string",
            "description": "24-character unique payment identifier"
          },
          "status": {
            "type": "string",
            "enum": ["PENDING", "IDENTIFIED", "AUTHORIZED", "AUTHORIZATION_EXPIRED", "SUCCEEDED", "FAILED", "CANCELLED", "EXPIRED"],
            "description": "Current payment status"
          },
          "amount": {
            "type": "integer",
            "description": "Payment amount in Euro cents"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "description": {
            "type": "string",
            "description": "Payment description"
          },
          "reference": {
            "type": "string",
            "description": "Merchant reference"
          },
          "bulkId": {
            "type": "string",
            "description": "Batch reference"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Payment creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "Payment expiration timestamp"
          },
          "debtor": {
            "$ref": "#/components/schemas/Debtor"
          },
          "creditor": {
            "$ref": "#/components/schemas/Creditor"
          },
          "_links": {
            "type": "object",
            "description": "Hypermedia links for payment actions",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Debtor": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Debtor name"
          },
          "iban": {
            "type": "string",
            "description": "Debtor IBAN"
          }
        }
      },
      "Creditor": {
        "type": "object",
        "properties": {
          "merchantId": {
            "type": "string",
            "description": "Merchant identifier"
          },
          "name": {
            "type": "string",
            "description": "Creditor name"
          },
          "iban": {
            "type": "string",
            "description": "Creditor IBAN"
          }
        }
      },
      "SearchPaymentsRequest": {
        "type": "object",
        "required": ["from"],
        "properties": {
          "from": {
            "type": "string",
            "format": "date-time",
            "description": "Start date in ISO format"
          },
          "to": {
            "type": "string",
            "format": "date-time",
            "description": "End date in ISO format"
          },
          "paymentStatuses": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["PENDING", "IDENTIFIED", "AUTHORIZED", "AUTHORIZATION_EXPIRED", "SUCCEEDED", "FAILED", "CANCELLED", "EXPIRED"]
            },
            "description": "Filter by payment statuses"
          },
          "reference": {
            "type": "string",
            "description": "Filter by merchant reference"
          }
        }
      },
      "SearchPaymentsResponse": {
        "type": "object",
        "properties": {
          "size": {
            "type": "integer",
            "description": "Page size"
          },
          "totalPages": {
            "type": "integer",
            "description": "Total number of pages"
          },
          "totalElements": {
            "type": "integer",
            "description": "Total number of matching payments"
          },
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Payment"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code (e.g. UNAUTHORIZED, PAYMENT_NOT_FOUND, FIELD_IS_REQUIRED)"
          },
          "message": {
            "type": "string",
            "description": "Error description"
          },
          "traceId": {
            "type": "string",
            "description": "Request trace identifier"
          },
          "spanId": {
            "type": "string",
            "description": "Work unit identifier"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key as Bearer token"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}