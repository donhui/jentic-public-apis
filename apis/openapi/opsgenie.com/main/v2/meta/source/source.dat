{
  "openapi": "3.0.3",
  "info": {
    "title": "Opsgenie Alert API",
    "version": "v2",
    "description": "Opsgenie Alert API provides endpoints to create, manage, and take actions on alerts. Alerts can be created, deleted, acknowledged, closed, snoozed, and more. Supports async processing with request status tracking.",
    "x-jentic-source-url": "https://docs.opsgenie.com/docs/alert-api"
  },
  "servers": [
    {
      "url": "https://api.opsgenie.com/v2"
    },
    {
      "url": "https://api.eu.opsgenie.com/v2",
      "description": "EU instance"
    }
  ],
  "paths": {
    "/alerts/requests/{requestId}": {
      "get": {
        "operationId": "getRequestStatus",
        "summary": "Get Request Status",
        "description": "Track the status and alert details of an asynchronous request.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "requestId",
            "in": "path",
            "required": true,
            "description": "Universally unique identifier of the request.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Request status retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RequestStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/alerts": {
      "post": {
        "operationId": "createAlert",
        "summary": "Create Alert",
        "description": "Creates an alert. Processed asynchronously; returns HTTP 202.",
        "tags": ["Alerts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAlertRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Request accepted for processing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listAlerts",
        "summary": "List Alerts",
        "description": "List alerts with filtering, sorting and pagination. Max 20000 alerts retrievable.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search query to filter alerts.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchIdentifier",
            "in": "query",
            "description": "Identifier of the saved search query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchIdentifierType",
            "in": "query",
            "description": "Type of saved search identifier.",
            "schema": {
              "type": "string",
              "enum": ["id", "name"],
              "default": "id"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Start index of the result set. Default and minimum is 0.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of items to return. Default 20, max 100.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Field to sort results by.",
            "schema": {
              "type": "string",
              "default": "createdAt",
              "enum": ["createdAt", "updatedAt", "tinyId", "alias", "message", "status", "acknowledged", "isSeen", "snoozed", "snoozedUntil", "count", "lastOccurredAt", "source", "owner", "integration.name", "integration.type", "report.ackTime", "report.closeTime", "report.acknowledgedBy", "report.closedBy"]
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sorting order.",
            "schema": {
              "type": "string",
              "enum": ["desc", "asc"],
              "default": "desc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alerts listed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListAlertsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/alerts/count": {
      "get": {
        "operationId": "countAlerts",
        "summary": "Count Alerts",
        "description": "Count alerts matching filter criteria.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Search query to filter alerts.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchIdentifier",
            "in": "query",
            "description": "Identifier of the saved search query.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchIdentifierType",
            "in": "query",
            "description": "Type of saved search identifier.",
            "schema": {
              "type": "string",
              "enum": ["id", "name"],
              "default": "id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alert count returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CountAlertsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/alerts/{identifier}": {
      "get": {
        "operationId": "getAlert",
        "summary": "Get Alert",
        "description": "Retrieve a single alert by identifier.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "identifier",
            "in": "path",
            "required": true,
            "description": "Identifier of the alert.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "identifierType",
            "in": "query",
            "description": "Type of the identifier.",
            "schema": {
              "type": "string",
              "enum": ["id", "tiny", "alias"],
              "default": "id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alert retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetAlertResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteAlert",
        "summary": "Delete Alert",
        "description": "Delete an alert. Processed asynchronously; returns HTTP 202.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "identifier",
            "in": "path",
            "required": true,
            "description": "Identifier of the alert.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "identifierType",
            "in": "query",
            "description": "Type of the identifier.",
            "schema": {
              "type": "string",
              "enum": ["AlertID", "tinyID"],
              "default": "AlertID"
            }
          },
          {
            "name": "user",
            "in": "query",
            "description": "Display name of the request owner.",
            "schema": {
              "type": "string",
              "maxLength": 100
            }
          },
          {
            "name": "source",
            "in": "query",
            "description": "Display name of the request source.",
            "schema": {
              "type": "string",
              "maxLength": 100
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Request accepted for processing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AsyncResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
