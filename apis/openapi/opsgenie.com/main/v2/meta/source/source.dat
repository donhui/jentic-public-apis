  "components": {
    "schemas": {
      "CreateAlertRequest": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string",
            "maxLength": 130,
            "description": "Message of the alert."
          },
          "alias": {
            "type": "string",
            "maxLength": 512,
            "description": "Client-defined identifier of the alert, key element of Alert De-Duplication."
          },
          "description": {
            "type": "string",
            "maxLength": 15000,
            "description": "Description field of the alert."
          },
          "responders": {
            "type": "array",
            "maxItems": 50,
            "items": {
              "$ref": "#/components/schemas/Responder"
            },
            "description": "Teams, users, escalations and schedules the alert will be routed to."
          },
          "visibleTo": {
            "type": "array",
            "maxItems": 50,
            "items": {
              "$ref": "#/components/schemas/VisibleTo"
            },
            "description": "Teams and users that the alert will become visible to."
          },
          "actions": {
            "type": "array",
            "maxItems": 10,
            "items": {
              "type": "string",
              "maxLength": 50
            },
            "description": "Custom actions available for the alert."
          },
          "tags": {
            "type": "array",
            "maxItems": 20,
            "items": {
              "type": "string",
              "maxLength": 50
            },
            "description": "Tags of the alert."
          },
          "details": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Map of key-value pairs for custom properties."
          },
          "entity": {
            "type": "string",
            "maxLength": 512,
            "description": "Entity field of the alert."
          },
          "source": {
            "type": "string",
            "maxLength": 100,
            "description": "Source field of the alert."
          },
          "priority": {
            "type": "string",
            "enum": ["P1", "P2", "P3", "P4", "P5"],
            "default": "P3",
            "description": "Priority level of the alert."
          },
          "user": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "note": {
            "type": "string",
            "maxLength": 25000,
            "description": "Additional note to add while creating."
          }
        }
      },
      "Responder": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "ID of the responder."
          },
          "name": {
            "type": "string",
            "description": "Name of the responder (for team, escalation, schedule)."
          },
          "username": {
            "type": "string",
            "description": "Username of the responder (for user type)."
          },
          "type": {
            "type": "string",
            "enum": ["team", "user", "escalation", "schedule"],
            "description": "Type of the responder."
          }
        }
      },
      "VisibleTo": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["team", "user"]
          }
        }
      },
      "AlertActionRequest": {
        "type": "object",
        "properties": {
          "user": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "source": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request source."
          },
          "note": {
            "type": "string",
            "maxLength": 25000,
            "description": "Additional alert note to add."
          }
        }
      },
      "AddNoteRequest": {
        "type": "object",
        "required": ["note"],
        "properties": {
          "user": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "source": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request source."
          },
          "note": {
            "type": "string",
            "maxLength": 25000,
            "description": "Alert note to add."
          }
        }
      },
      "SnoozeAlertRequest": {
        "type": "object",
        "required": ["endTime"],
        "properties": {
          "endTime": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time that snooze will lose effect (ISO 8601)."
          },
          "user": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "source": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request source."
          },
          "note": {
            "type": "string",
            "maxLength": 25000,
            "description": "Additional alert note to add."
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "tinyId": {
            "type": "string"
          },
          "alias": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["open", "closed"]
          },
          "acknowledged": {
            "type": "boolean"
          },
          "isSeen": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "snoozed": {
            "type": "boolean"
          },
          "snoozedUntil": {
            "type": "string",
            "format": "date-time"
          },
          "count": {
            "type": "integer"
          },
          "lastOccurredAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "source": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": ["P1", "P2", "P3", "P4", "P5"]
          },
          "responders": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Responder"
            }
          },
          "integration": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          },
          "report": {
            "type": "object",
            "properties": {
              "ackTime": {
                "type": "integer"
              },
              "closeTime": {
                "type": "integer"
              },
              "acknowledgedBy": {
                "type": "string"
              },
              "closedBy": {
                "type": "string"
              }
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "entity": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "details": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "RequestStatusResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "success": {
                "type": "boolean"
              },
              "action": {
                "type": "string"
              },
              "processedAt": {
                "type": "string",
                "format": "date-time"
              },
              "integrationId": {
                "type": "string"
              },
              "isSuccess": {
                "type": "boolean"
              },
              "status": {
                "type": "string"
              },
              "alertId": {
                "type": "string"
              },
              "alias": {
                "type": "string"
              }
            }
          },
          "took": {
            "type": "number"
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "AsyncResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "string"
          },
          "took": {
            "type": "number"
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "GetAlertResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Alert"
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "ListAlertsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Alert"
            }
          },
          "paging": {
            "type": "object",
            "properties": {
              "next": {
                "type": "string"
              },
              "first": {
                "type": "string"
              },
              "last": {
                "type": "string"
              }
            }
          },
          "took": {
            "type": "number"
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "CountAlertsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "count": {
                "type": "integer"
              }
            }
          },
          "took": {
            "type": "number"
          },
          "requestId": {
            "type": "string"
          }
        }
      },
      "AddTagsRequest": {
        "type": "object",
        "required": ["tags"],
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of tags to add to the alert."
          },
          "user": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "source": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request source."
          },
          "note": {
            "type": "string",
            "maxLength": 25000,
            "description": "Additional alert note to add."
          }
        }
      },
      "AssignAlertRequest": {
        "type": "object",
        "required": ["owner"],
        "properties": {
          "owner": {
            "$ref": "#/components/schemas/Responder"
          },
          "user": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "source": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request source."
          },
          "note": {
            "type": "string",
            "maxLength": 25000,
            "description": "Additional alert note to add."
          }
        }
      },
      "AddResponderRequest": {
        "type": "object",
        "required": ["responder"],
        "properties": {
          "responder": {
            "$ref": "#/components/schemas/Responder"
          },
          "user": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "source": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request source."
          },
          "note": {
            "type": "string",
            "maxLength": 25000,
            "description": "Additional alert note to add."
          }
        }
      },
      "AddTeamRequest": {
        "type": "object",
        "required": ["team"],
        "properties": {
          "team": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Team ID."
              },
              "name": {
                "type": "string",
                "description": "Team name."
              }
            }
          },
          "user": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "source": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request source."
          },
          "note": {
            "type": "string",
            "maxLength": 25000,
            "description": "Additional alert note to add."
          }
        }
      },
      "EscalateAlertRequest": {
        "type": "object",
        "required": ["escalation"],
        "properties": {
          "escalation": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Escalation ID."
              },
              "name": {
                "type": "string",
                "description": "Escalation name."
              }
            }
          },
          "user": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request owner."
          },
          "source": {
            "type": "string",
            "maxLength": 100,
            "description": "Display name of the request source."
          },
          "note": {
            "type": "string",
            "maxLength": 25000,
            "description": "Additional alert note to add."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "took": {
            "type": "number"
          },
          "requestId": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "GenieKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key authentication. Use 'GenieKey {apiKey}' format."
      }
    }
  },
