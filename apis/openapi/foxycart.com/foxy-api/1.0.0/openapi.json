  "info": {
    "title": "Foxy API",
    "version": "1.0.0",
    "description": "Foxy.io e-commerce API (hAPI). Uses HATEOAS architecture with hypermedia links for navigation between resources. Supports stores, customers, transactions, subscriptions, and more.",
    "x-jentic-source-url": "https://api.foxycart.com"
  },
