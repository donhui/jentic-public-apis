{
  "openapi": "3.0.1",
  "info": {
    "title": "Biometric API Documentation",
    "description": "REST API de biometr\u00eda",
    "contact": {
      "name": "Billy Larru",
      "email": "billy.larru@insolutions.pe"
    },
    "version": "1.0.0",
