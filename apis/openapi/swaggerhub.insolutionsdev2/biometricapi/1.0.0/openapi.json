  },
  "paths": {
    "/api/fingerprint/verification": {
      "post": {
        "tags": [
          "Fingerprint"
        ],
        "summary": "Validaci\u00f3n biom\u00e9trica",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n 0000000000 - OK\r\n \r\n 1111111111 - Error en el servidor\r\n \r\n 2222222222 - Operaci\u00f3n Fallida\r\n \r\n 0040400000 - Token no encontrado\r\n \r\n 0044000000 - Token expirado\r\n \r\n 0040100000 - Token inv\u00e1lido\r\n \r\n 2040001001 - La petici\u00f3n es inv\u00e1lida.\r\n \r\n 2040001002 - La huella recibida no coincide con la huella del dni ingresado.\r\n \r\n 2040001003 - Error de validaci\u00f3n de datos de entrada.\r\n \r\n 2050001001 - Error interno.\r\n \r\n 2050001002 - Error en la base de datos.\r\n \r\n 2050001003 - Error de configuraci\u00f3n del servidor\r\n \r\n 2050001004 - Error de servicio del RENIEC\r\n \r\n 2050001006 - El dni ingresado no existe en la base de datos del RENIEC.\r\n \r\n 2050001007 - El dni corresponde a un menor de edad.\r\n \r\n 2050001008 - El dni ingresado corresponde a una persona fallecida.\r\n \r\n 2050001009 - El servicio del RENIEC no est\u00e1 disponible.",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FingerprintVerifcationBodyRequest"
              },
              "examples": {
                "request OK": {
                  "value": {
                    "dni": "12341234",
                    "fingerprintHeight": "594",
                    "fingerprintWidth": "645",
                    "fingerprintEncripted": "RkdGWjBkUHkwK0pqUlExTkJFMW95a1V5WkFpWGtHYzFVOVZVazNzcS9jRmlJMUFrRHNsREtsMDJZb1p5QkhPNWRybStvVDU2a1VDU25DT295MFdnSWdtZE1BOW1XRS9EK2w3QUp3TXJablE9"
                  }
                },
                "request Validation Error": {
                  "value": {
                    "dni": "aa111",
                    "fingerprintHeight": null,
                    "fingerprintWidth": null,
                    "fingerprintEncripted": null
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FingerprintVerifcationBodyResponse"
                },
                "examples": {
                  "response OK": {
                    "value": {
                      "message": "Operaci\u00f3n exitosa.",
                      "code": "0000000000",
                      "status": 0,
                      "data": {
                        "resultCode": "70006",
                        "paternalLastName": "Mendoza",
                        "maternalLastName": "Trujillo",
                        "dni": "12341234",
                        "dniExpirationDate": "2020-07-13",
                        "restriction": "",
                        "errorDescription": ""
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tokens": {
      "post": {
        "tags": [
          "Token"
        ],
        "summary": "Obtenci\u00f3n de token",
        "description": " Al enviar credenciales v\u00e1lidas obtendr\u00e1 un token con un tiempo de vida de 1 hora,\r\n \r\n este debe ser usado de manera obligatoria para consumir el servicio de validaci\u00f3n biom\u00e9trica.\r\n \r\n**Posibles c\u00f3digos de respuesta:**\r\n\r\n 0000000000 - OK\r\n \r\n 1111111111 - Error en el servidor\r\n \r\n 2222222222 - Operaci\u00f3n Fallida\r\n \r\n 1040001001 - La petici\u00f3n es inv\u00e1lida.\r\n \r\n 1040001002 - Error de validaci\u00f3n de datos de entrada.\r\n \r\n 1040401003 - Credenciales inv\u00e1lidas.\r\n \r\n 1050001001 - Error interno\r\n \r\n 1050001002 - Error en la BD",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTokenBodyRequest"
              },
              "examples": {
                "request OK": {
                  "value": {
                    "username": "pepito",
                    "password": "123456"
                  }
                },
                "request Validation Error": {
                  "value": {
                    "username": null,
                    "password": "123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTokenResponse"
                },
                "examples": {
                  "response OK": {
                    "value": {
                      "message": "Operaci\u00f3n exitosa.",
                      "code": "0000000000",
                      "status": 0,
                      "data": {
                        "token": "+065y9dJMm3w0TkpFOKLK1DpcPdiuCR9"
                      }
                    }
                  },
                  "response invalid credentials": {
                    "value": {
                      "message": "Credenciales inv\u00e1lidas.",
                      "code": "1040401003",
                      "status": 2,
                      "data": null
                    }
                  },
                  "response Validation Error": {
                    "value": {
                      "message": "Error de validaci\u00f3n de datos de entrada.",
                      "code": "1040001002",
                      "status": 2,
                      "data": {
                        "userName": [
                          "El userName es requerido"
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FingerprintVerifcationBodyRequest": {
        "type": "object",
        "properties": {
          "dni": {
            "type": "string",
            "nullable": true
          },
          "fingerprintHeight": {
            "type": "string",
            "nullable": true
          },
          "fingerprintWidth": {
            "type": "string",
            "nullable": true
          },
          "fingerprintEncripted": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "FingerprintVerifcationBodyResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo de respuesta",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "Estado del proceso\r\n\r\n0 - Proceso exitoso\r\n\r\n1 - Error\r\n\r\n2 - Fall\u00f3",
            "format": "int32"
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "description": "Informaci\u00f3n que el servicio retornar\u00e1 en el caso que sea necesario",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateTokenBodyRequest": {
        "required": [
          "password",
          "username"
        ],
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CreateTokenResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo de respuesta",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "Estado del proceso\r\n\r\n0 - Proceso exitoso\r\n\r\n1 - Error\r\n\r\n2 - Fall\u00f3",
            "format": "int32"
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "description": "Informaci\u00f3n que el servicio retornar\u00e1 en el caso que sea necesario",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}