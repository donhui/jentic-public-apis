  "paths": {
    "/api/v1/biometrics/best": {
      "post": {
        "tags": [
          "Biometric"
        ],
        "summary": "Mejores huellas",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n 0000000000 - OK (successful HTTP Status 200)\r\n \r\n 1111111111 - Error en el servidor\r\n \r\n 2222222222 - Operaci\u00f3n Fallida\r\n \r\n 0040400000 - Token no encontrado\r\n \r\n 0044000000 - Token expirado\r\n \r\n 0040100000 - Token inv\u00e1lido\r\n \r\n 1020001001 - Es probable que se detecte la huella de los dedos indices.\r\n \r\n 1040001001 - La petici\u00f3n es inv\u00e1lida.\r\n \r\n 1040001002 - Sin registro de huellas de mejor calidad.\r\n \r\n 1040001003 - Error de validaci\u00f3n de datos de entrada.\r\n \r\n 1050001001 - Error interno\r\n \r\n 1050001002 - Error en la BD\r\n \r\n 1050001003 - Error de configuraci\u00f3n del servidor.\r\n \r\n 1050001004 - Error del servicio de RENIEC",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BiometricBestRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BiometricBestResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/biometrics/validation": {
      "post": {
        "tags": [
          "Biometric"
        ],
        "summary": "Validaci\u00f3n biom\u00e9trica",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n 0000000000 - OK (successful HTTP Status 200)\r\n \r\n 1111111111 - Error en el servidor (error del servidor HTTP estado 500)\r\n \r\n 2222222222 - Operaci\u00f3n Fallida ( error del cliente y/o servidor estado 500)\r\n \r\n 0040400000 - Token no encontrado ( error del cliente HTTP estado 400)\r\n \r\n 0044000000 - Token expirado ( error del cliente HTTP estado 400)\r\n \r\n 0040100000 - Token inv\u00e1lido ( error del cliente HTTP estado 400)\r\n \r\n 1040002001 - La petici\u00f3n es inv\u00e1lida. ( error del cliente HTTP estado 400)\r\n \r\n 1040002002 - La huella recibida no coincide con la huella del dni ingresado. ( error del cliente HTTP estado 400)\r\n \r\n 1040002003 - Error de validaci\u00f3n de datos de entrada. ( error del cliente)\r\n \r\n 1050002001 - Error interno. ( error del servidor HTTP estado 500)\r\n \r\n 1050002002 - Error en la BD( error del servidor HTTP estado 500)\r\n \r\n 1050002003 - Error de configuraci\u00f3n del servidor. (error del servidor HTTP estado 500)\r\n \r\n 1050002004 - Error del servicio de RENIEC (error del servidor HTTP estado 500)\r\n \r\n 1050002006 - El dni ingresado no existe en la base de datos del RENIEC.",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BiometricValidationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BiometricValidationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/documents/signed": {
      "get": {
        "tags": [
          "Document"
        ],
        "summary": "Obtener documentos firmados",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n 0000000000 - OK (successful HTTP Status 200)\r\n \r\n 1111111111 - Error en el servidor\r\n \r\n 2222222222 - Operaci\u00f3n Fallida\r\n \r\n 0040400000 - Token no encontrado\r\n \r\n 0044000000 - Token expirado\r\n \r\n 0040100000 - Token inv\u00e1lido\r\n \r\n 2040001001 - La petici\u00f3n es inv\u00e1lida.\r\n \r\n 2040001002 - Error de validaci\u00f3n de datos de entrada.\r\n \r\n 2050001001 - Error interno\r\n \r\n 2050001002 - Error en la BD",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentSignedResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/documents/pending/{documentId}": {
      "get": {
        "tags": [
          "Document"
        ],
        "summary": "Obtener documentos pendientes de firma por su id",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n 0000000000 - OK (successful HTTP Status 200)\r\n \r\n 1111111111 - Error en el servidor\r\n \r\n 2222222222 - Operaci\u00f3n Fallida\r\n \r\n 0040400000 - Token no encontrado\r\n \r\n 0044000000 - Token expirado\r\n \r\n 0040100000 - Token inv\u00e1lido\r\n \r\n 2040002001 - La petici\u00f3n es inv\u00e1lida.\r\n \r\n 2040002002 - Error de validaci\u00f3n de datos de entrada.\r\n \r\n 2050002001 - Error interno\r\n \r\n 2050002002 - Error en la BD",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "documentId",
            "in": "path",
            "description": "",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentPendingResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/documents/generation": {
      "post": {
        "tags": [
          "Document"
        ],
        "summary": "Generacion de documento",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n 0000000000 - OK (successful HTTP Status 200)\r\n \r\n 1111111111 - Error en el servidor\r\n \r\n 2222222222 - Operaci\u00f3n Fallida\r\n \r\n 0040400000 - Token no encontrado\r\n \r\n 0044000000 - Token expirado\r\n \r\n 0040100000 - Token inv\u00e1lido\r\n \r\n 2040003001 - La petici\u00f3n es inv\u00e1lida.\r\n \r\n 2040003002 - Error de validaci\u00f3n de datos de entrada.\r\n \r\n 2040003003 - No pas\u00f3 la validaci\u00f3n de datos del api de Acres\r\n \r\n 2050003001 - Error interno\r\n \r\n 2050003002 - Error en la BD\r\n \r\n 2050003003 - Ocurri\u00f3 un error en la generaci\u00f3n del documento en el api de acres",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerationDocumentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenerationDocumentResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users": {
      "post": {
        "tags": [
          "User"
        ],
        "summary": "Creaci\u00f3n de usuario",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n0000000000 - OK (successful HTTP Status 200)\r\n\r\n1111111111 - Error en el servidor\r\n\r\n2222222222 - Operaci\u00f3n Fallida\r\n\r\n0040400000 - Token no encontrado\r\n\r\n0044000000 - Token expirado\r\n\r\n0040100000 - Token inv\u00e1lido\r\n\r\n4040001001 - La petici\u00f3n es inv\u00e1lida. ( error del cliente)\r\n\r\n4040001002 - Error de validaci\u00f3n de datos de entrada ( los datos enviados por el cliente no tienen el formato esperado)\r\n\r\n4040001003 - El dni ya se encuentra en uso, no es posible registrarlo nuevamente.\r\n\r\n4050001001 - Error interno del endpoint\r\n\r\n4050001002 - Error en la BD",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewAccountRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewAccountResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "User"
        ],
        "summary": "Cambiar contrase\u00f1a",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n0000000000 - OK (successful HTTP Status 200)\r\n\r\n1111111111 - Error en el servidor\r\n\r\n2222222222 - Operaci\u00f3n Fallida\r\n\r\n0040400000 - Token no encontrado\r\n\r\n0044000000 - Token expirado\r\n\r\n0040100000 - Token inv\u00e1lido\r\n\r\n4040004001 - La petici\u00f3n es inv\u00e1lida. ( error del cliente)\r\n\r\n4040004002 - Error de validaci\u00f3n de datos de entrada ( los datos enviados por el cliente no tienen el formato esperado)\r\n            \r\n4040004003 - El usuario no existe en la base de datos.\r\n\r\n4050004001 - Error interno en el endpoint\r\n\r\n4050004002 - Error en la BD",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangePasswordResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/{dni}": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Comprobaci\u00f3n de DNI",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n0000000000 - OK (successful HTTP Status 200)\r\n\r\n1111111111 - Error en el servidor\r\n\r\n2222222222 - Operaci\u00f3n Fallida\r\n\r\n0040400000 - Token no encontrado\r\n\r\n0044000000 - Token expirado\r\n\r\n0040100000 - Token inv\u00e1lido\r\n\r\n4040002001 - La petici\u00f3n es inv\u00e1lida. ( error del cliente)\r\n\r\n4040002002 - Error de validaci\u00f3n de datos de entrada ( los datos enviados por el cliente no tienen el formato esperado)\r\n\r\n4040402001 - El DNI no existe en la base de datos.\r\n\r\n4050002001 - Error interno en el endpoint\r\n\r\n4050002002 - Error en la BD\r\n\r\n    Data response con status = 0\r\n    data:  {\r\n            \"found\": true, --> es true si se encuentra en nuestra bd, false si no esta en nuestra bd y se consulta al servicio acres\r\n            \"enabled\": true --> es true si el dni esta habilitado, false si no esta habilitado\r\n           }",
        "parameters": [
          {
            "name": "dni",
            "in": "path",
            "description": "",
            "required": true,
            "schema": {
              "maxLength": 8,
              "minLength": 8,
              "pattern": "^[0-9-]*$",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyDniResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/login": {
      "post": {
        "tags": [
          "User"
        ],
        "summary": "Validar credenciales",
        "description": "**Posibles c\u00f3digos de respuesta:**\r\n\r\n0000000000 - OK (successful HTTP Status 200)\r\n\r\n1111111111 - Error en el servidor\r\n\r\n2222222222 - Operaci\u00f3n Fallida\r\n\r\n0040400000 - Token no encontrado\r\n\r\n0044000000 - Token expirado\r\n\r\n0040100000 - Token inv\u00e1lido\r\n\r\n4040003001 - La petici\u00f3n es inv\u00e1lida. ( error del cliente)\r\n\r\n4040003002 - Error de validaci\u00f3n de datos de entrada ( los datos enviados por el cliente no tienen el formato esperado)\r\n\r\n4040003003 - Credenciales inv\u00e1lidas\r\n\r\n4050003001 - Error interno en el endpoint\r\n\r\n4050003002 - Error en la BD",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u00c9xito",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BiometricBestRequest": {
        "type": "object",
        "properties": {
          "dni": {
            "maxLength": 8,
            "minLength": 8,
            "pattern": "^[0-9-]*$",
            "type": "string",
            "nullable": true
          },
          "transactionalId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "BiometricBestResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo de respuesta",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "Estado del proceso\r\n\r\n0 - Proceso exitoso\r\n\r\n1 - Error\r\n\r\n2 - Fall\u00f3",
            "format": "int32"
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "description": "Informaci\u00f3n que el servicio retornar\u00e1 en el caso que sea necesario",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "BiometricValidationRequest": {
        "required": [
          "dniCliente",
          "rawBase64",
          "rawHeight",
          "rawWidth"
        ],
        "type": "object",
        "properties": {
          "dniCliente": {
            "maxLength": 8,
            "minLength": 8,
            "pattern": "^[0-9-]*$",
            "type": "string"
          },
          "rawBase64": {
            "type": "string"
          },
          "rawHeight": {
            "type": "string"
          },
          "rawWidth": {
            "type": "string"
          },
          "transactionalId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "BiometricValidationResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo de respuesta",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "Estado del proceso\r\n\r\n0 - Proceso exitoso\r\n\r\n1 - Error\r\n\r\n2 - Fall\u00f3",
            "format": "int32"
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "description": "Informaci\u00f3n que el servicio retornar\u00e1 en el caso que sea necesario",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "DocumentSignedResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo de respuesta",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "Estado del proceso\r\n\r\n0 - Proceso exitoso\r\n\r\n1 - Error\r\n\r\n2 - Fall\u00f3",
            "format": "int32"
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "description": "Informaci\u00f3n que el servicio retornar\u00e1 en el caso que sea necesario",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "DocumentPendingResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo de respuesta",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "Estado del proceso\r\n\r\n0 - Proceso exitoso\r\n\r\n1 - Error\r\n\r\n2 - Fall\u00f3",
            "format": "int32"
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "description": "Informaci\u00f3n que el servicio retornar\u00e1 en el caso que sea necesario",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GenerationDocumentRequest": {
        "required": [
          "documentId",
          "rawBase64",
          "rawHeight",
          "rawWidth"
        ],
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string",
            "description": "C\u00f3digo del documento a firmar"
          },
          "rawBase64": {
            "type": "string",
            "description": "Raw de la huella dactilar en base64"
          },
          "rawWidth": {
            "type": "integer",
            "description": "width del raw de la huella dactilar",
            "format": "int32"
          },
          "rawHeight": {
            "type": "integer",
            "description": "height del raw de la huella dactilar",
            "format": "int32"
          },
          "transactionalId": {
            "type": "integer",
            "description": "Id de la transacci\u00f3n",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GenerationDocumentResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo de respuesta",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "Estado del proceso\r\n\r\n0 - Proceso exitoso\r\n\r\n1 - Error\r\n\r\n2 - Fall\u00f3",
            "format": "int32"
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "description": "Informaci\u00f3n que el servicio retornar\u00e1 en el caso que sea necesario",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "NewAccountRequest": {
        "required": [
          "birthDate",
          "dni",
          "lastName",
          "name",
          "password"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "birthDate": {
            "pattern": "^([0-9]{4})-([0-9]{2})-([0-9]{2})$",
            "type": "string"
          },
          "dni": {
            "maxLength": 8,
            "minLength": 8,
            "pattern": "^[0-9-]*$",
            "type": "string"
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "NewAccountResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo de respuesta",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "Estado del proceso\r\n\r\n0 - Proceso exitoso\r\n\r\n1 - Error\r\n\r\n2 - Fall\u00f3",
            "format": "int32"
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "description": "Informaci\u00f3n que el servicio retornar\u00e1 en el caso que sea necesario",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ChangePasswordRequest": {
        "required": [
          "dni",
          "password"
        ],
        "type": "object",
        "properties": {
          "dni": {
            "maxLength": 8,
            "minLength": 8,
            "pattern": "^[0-9-]*$",
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ChangePasswordResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "C\u00f3digo de respuesta",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "description": "Estado del proceso\r\n\r\n0 - Proceso exitoso\r\n\r\n1 - Error\r\n\r\n2 - Fall\u00f3",
            "format": "int32"
          },
          "data": {
            "type": "object",
            "additionalProperties": false,
            "description": "Informaci\u00f3n que el servicio retornar\u00e1 en el caso que sea necesario",
