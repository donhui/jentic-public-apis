{
  "openapi": "3.0.1",
  "info": {
    "title": "Acres API Documentation",
    "description": "REST API para la aplicaci\u00f3n de Acres",
    "contact": {
      "name": "Billy Larru",
      "email": "billy.larru@insolutions.pe"
