{
  "openapi": "3.0.3",
  "info": {
    "title": "Polly Web API",
    "description": "The Polly Web API for creating polls, surveys, and triggering workflows in Slack.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.polly.ai/api"
  },
  "servers": [
    {
      "url": "https://api.polly.ai/v1",
      "description": "Production API server"
    }
  ],
  "paths": {
    "/polls.create": {
      "post": {
        "operationId": "createPoll",
        "summary": "Create a new single-question poll",
        "tags": [
          "Polls"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PollRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Poll created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PollResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/polls.info": {
      "post": {
        "operationId": "getPollInfo",
        "summary": "Get information about a specific poll",
        "tags": [
          "Polls"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string",
                    "description": "The poll ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Poll information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PollResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/polls.list": {
      "post": {
        "operationId": "listPolls",
        "summary": "List all polls",
        "tags": [
          "Polls"
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of polls",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "polls": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/PollResponse"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/polls.delete": {
      "post": {
        "operationId": "deletePoll",
        "summary": "Delete a poll",
        "tags": [
          "Polls"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string",
                    "description": "The poll ID to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Poll deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/surveys.create": {
      "post": {
        "operationId": "createSurvey",
        "summary": "Create a new multi-question survey",
        "tags": [
          "Surveys"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SurveyRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Survey created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SurveyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/surveys.info": {
      "post": {
        "operationId": "getSurveyInfo",
        "summary": "Get information about a specific survey",
        "tags": [
          "Surveys"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string",
                    "description": "The survey ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Survey information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SurveyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/surveys.list": {
      "post": {
        "operationId": "listSurveys",
        "summary": "List all surveys",
        "tags": [
          "Surveys"
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of surveys",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "surveys": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/SurveyResponse"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/surveys.delete": {
      "post": {
        "operationId": "deleteSurvey",
        "summary": "Delete a survey",
        "tags": [
          "Surveys"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string",
                    "description": "The survey ID to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Survey deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/workflows.trigger": {
      "post": {
        "operationId": "triggerWorkflow",
        "summary": "Trigger a workflow",
        "tags": [
          "Workflows"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "workflow_id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "workflow_id": {
                    "type": "string",
                    "description": "The workflow ID to trigger"
                  },
                  "audience": {
                    "$ref": "#/components/schemas/Audience"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow triggered",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    },
    "/workflows.results": {
      "post": {
        "operationId": "getWorkflowResults",
        "summary": "Get results of a workflow",
        "tags": [
          "Workflows"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "workflow_id"
                ],
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "workflow_id": {
                    "type": "string",
                    "description": "The workflow ID"
                  },
                  "cursor": {
                    "type": "string",
                    "description": "Pagination cursor"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Number of results to return"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowResultsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "name": "X-API-TOKEN",
        "in": "header",
        "description": "API token managed at https://app.polly.ai/api"
      }
    },
    "schemas": {
      "Audience": {
        "type": "object",
        "properties": {
          "user_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Slack user IDs"
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Email addresses"
          },
          "channel_names": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Slack channel names"
          },
          "channel_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Slack channel IDs"
          }
        }
      },
      "Reminders": {
        "type": "object",
        "properties": {
          "total_reminders": {
            "type": "integer"
          },
          "reminder_interval": {
            "type": "integer"
          },
          "reminder_interval_unit": {
            "type": "string",
            "enum": [
              "hours",
              "days"
            ]
          }
        }
      },
      "QuestionRequest": {
        "type": "object",
        "required": [
          "type",
          "title"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "multiple_choice",
              "agree_disagree",
              "open_ended",
              "nps",
              "rating"
            ]
          },
          "title": {
            "type": "string"
          },
          "allow_adding_choices": {
            "type": "boolean"
          },
          "allow_multiple_answers": {
            "type": "boolean"
          },
          "required": {
            "type": "boolean"
          },
          "allow_comments": {
            "type": "boolean"
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rank_count": {
            "type": "integer"
          },
          "points": {
            "type": "integer"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        }
      },
      "PollRequest": {
        "type": "object",
        "required": [
          "audience",
          "question"
        ],
        "properties": {
          "token": {
            "type": "string"
          },
          "audience": {
            "$ref": "#/components/schemas/Audience"
          },
          "alternate_alias": {
            "type": "string"
          },
          "appeal": {
            "type": "string"
          },
          "anonymity_level": {
            "type": "string",
            "enum": [
              "anonymous",
              "confidential",
              "transparent"
            ]
          },
          "results_visibility": {
            "type": "string",
            "enum": [
              "real_time",
              "after_close",
              "author_only"
            ]
          },
          "comments_visibility": {
            "type": "string",
            "enum": [
              "public",
              "private"
            ]
          },
          "send_via_direct_message": {
            "type": "boolean"
          },
          "send_at": {
            "type": "string",
            "format": "date-time"
          },
          "close_at": {
            "type": "string",
            "format": "date-time"
          },
          "question": {
            "$ref": "#/components/schemas/QuestionRequest"
          },
          "reminders": {
            "$ref": "#/components/schemas/Reminders"
          }
        }
      },
      "PollResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "id": {
            "type": "string"
          },
          "team_id": {
            "type": "string"
          },
          "question": {
            "$ref": "#/components/schemas/QuestionResponse"
          },
          "audience_response_info": {
            "$ref": "#/components/schemas/AudienceResponseInfo"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "QuestionResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "choices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Choice"
            }
          },
          "votes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Vote"
            }
          },
          "comments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Comment"
            }
          }
        }
      },
      "SurveyRequest": {
        "type": "object",
        "required": [
          "audience",
          "questions"
        ],
        "properties": {
          "token": {
            "type": "string"
          },
          "audience": {
            "$ref": "#/components/schemas/Audience"
          },
          "title": {
            "type": "string"
          },
          "anonymity_level": {
            "type": "string",
            "enum": [
              "anonymous",
              "confidential",
              "transparent"
            ]
          },
          "results_visibility": {
            "type": "string",
            "enum": [
              "real_time",
              "after_close",
              "author_only"
            ]
          },
          "send_at": {
            "type": "string",
            "format": "date-time"
          },
          "close_at": {
            "type": "string",
            "format": "date-time"
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionRequest"
            }
          },
          "reminders": {
            "$ref": "#/components/schemas/Reminders"
          }
        }
      },
      "SurveyResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "id": {
            "type": "string"
          },
          "team_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QuestionResponse"
            }
          },
          "audience_response_info": {
            "$ref": "#/components/schemas/AudienceResponseInfo"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "WorkflowResultsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "cursor": {
            "type": "string"
          },
          "has_more": {
            "type": "boolean"
          }
        }
      },
      "ListRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "cursor": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "AudienceResponseInfo": {
        "type": "object",
        "properties": {
          "total_audience": {
            "type": "integer"
          },
          "total_responses": {
            "type": "integer"
          }
        }
      },
      "Metadata": {
        "type": "object",
        "additionalProperties": true
      },
      "Choice": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        }
      },
      "Vote": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string"
          },
          "choice": {
            "type": "string"
          }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AuthenticationError": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "example": "not_authed"
          }
        }
      },
      "InvalidRequestError": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [
    {
      "apiToken": []
    }
  ],
  "tags": [
    {
      "name": "Polls",
      "description": "Create and manage polls"
    },
    {
      "name": "Surveys",
      "description": "Create and manage surveys"
    },
    {
      "name": "Workflows",
      "description": "Trigger and query workflow results"
    }
  ]
}