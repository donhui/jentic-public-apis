{
  "openapi": "3.0.3",
  "info": {
    "title": "Polly Web API",
    "version": "1.0.0",
    "description": "Polly API for creating and managing polls, surveys, and workflows.",
    "x-jentic-source-url": "https://docs.polly.ai/api"
  },
  "servers": [
    {
      "url": "https://api.polly.ai/v1",
      "description": "Polly API v1"
    }
  ],
  "paths": {
    "/polls.create": {
      "post": {
        "operationId": "createpoll",
        "summary": "Create a poll",
        "description": "Creates a new single-question poll. Requires polls:write scope.",
        "tags": [
          "Polls"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PollRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Poll created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PollResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/polls.info": {
      "post": {
        "operationId": "getpollinfo",
        "summary": "Get poll information",
        "description": "Retrieves information about an existing poll. Requires polls:read scope.",
        "tags": [
          "Polls"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "token"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Poll ID"
                  },
                  "token": {
                    "type": "string",
                    "description": "Authentication token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Poll information returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PollResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/polls.list": {
      "post": {
        "operationId": "listpolls",
        "summary": "List polls",
        "description": "Returns a filtered list of available polls. Requires polls:read scope.",
        "tags": [
          "Polls"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of polls returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PollResponse"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/polls.delete": {
      "post": {
        "operationId": "deletepoll",
        "summary": "Delete a poll",
        "description": "Deletes a poll and associated messages. Requires polls:write scope.",
        "tags": [
          "Polls"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "token"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Poll ID to delete"
                  },
                  "token": {
                    "type": "string",
                    "description": "Authentication token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Poll deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PollResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/surveys.create": {
      "post": {
        "operationId": "createsurvey",
        "summary": "Create a survey",
        "description": "Creates a new multi-question survey. Requires surveys:write scope.",
        "tags": [
          "Surveys"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SurveyRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Survey created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SurveyResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/surveys.info": {
      "post": {
        "operationId": "getsurveyinfo",
        "summary": "Get survey information",
        "description": "Queries and returns a single survey by ID. Requires surveys:read scope.",
        "tags": [
          "Surveys"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "token"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Survey ID"
                  },
                  "token": {
                    "type": "string",
                    "description": "Authentication token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Survey information returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SurveyResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/surveys.list": {
      "post": {
        "operationId": "listsurveys",
        "summary": "List surveys",
        "description": "Returns a filtered list of available surveys. Requires surveys:read scope.",
        "tags": [
          "Surveys"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of surveys returned",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SurveyResponse"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/surveys.delete": {
      "post": {
        "operationId": "deletesurvey",
        "summary": "Delete a survey",
        "description": "Deletes a survey and associated messages. Requires surveys:write scope.",
        "tags": [
          "Surveys"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "token"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Survey ID to delete"
                  },
                  "token": {
                    "type": "string",
                    "description": "Authentication token"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Survey deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SurveyResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/workflows.trigger": {
      "post": {
        "operationId": "triggerworkflow",
        "summary": "Trigger a workflow",
        "description": "Initiates a workflow with optional metadata attachment. Requires workflows:write scope.",
        "tags": [
          "Workflows"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Workflow ID"
                  },
                  "metadata": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    },
                    "description": "Custom key-value metadata pairs"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow triggered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowTriggerResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/workflows.results": {
      "post": {
        "operationId": "getworkflowresults",
        "summary": "Get workflow results",
        "description": "Retrieves results associated with a workflow. Requires workflows:read scope.",
        "tags": [
          "Workflows"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "id",
                  "token"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Workflow ID"
                  },
                  "token": {
                    "type": "string",
                    "description": "Authentication token"
                  },
                  "created_at_from": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Lower bound filter for creation date"
                  },
                  "created_at_to": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Upper bound filter for creation date"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workflow results returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowResultsResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-TOKEN",
        "description": "API token for authentication. Can also be passed as 'token' in request body."
      }
    },
    "schemas": {
      "PollRequest": {
        "type": "object",
        "description": "Request body for creating a poll",
        "properties": {
          "question": {
            "type": "string",
            "description": "The poll question"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of answer options"
          },
          "audience": {
            "type": "string",
            "description": "Target audience identifier"
          },
          "token": {
            "type": "string",
            "description": "Authentication token"
          }
        }
      },
      "PollResponse": {
        "type": "object",
        "description": "Poll response object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Poll ID"
          },
          "question": {
            "type": "string",
            "description": "The poll question"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Answer options"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "status": {
            "type": "string",
            "description": "Poll status"
          }
        }
      },
      "SurveyRequest": {
        "type": "object",
        "description": "Request body for creating a survey",
        "properties": {
          "title": {
            "type": "string",
            "description": "Survey title"
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SurveyQuestion"
            },
            "description": "List of survey questions"
          },
          "audience": {
            "type": "string",
            "description": "Target audience identifier"
          },
          "token": {
            "type": "string",
            "description": "Authentication token"
          }
        }
      },
      "SurveyQuestion": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "description": "Question text"
          },
          "type": {
            "type": "string",
            "description": "Question type (e.g., multiple_choice, open_ended)"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Answer options (for multiple choice)"
          }
        }
      },
      "SurveyResponse": {
        "type": "object",
        "description": "Survey response object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Survey ID"
          },
          "title": {
            "type": "string",
            "description": "Survey title"
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SurveyQuestion"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "status": {
            "type": "string",
            "description": "Survey status"
          }
        }
      },
      "ListRequest": {
        "type": "object",
        "description": "Request body for list operations",
        "properties": {
          "token": {
            "type": "string",
            "description": "Authentication token"
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of results"
          },
          "offset": {
            "type": "integer",
            "description": "Offset for pagination"
          },
          "status": {
            "type": "string",
            "description": "Filter by status"
          }
        }
      },
      "WorkflowTriggerResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Whether the workflow was triggered successfully"
          },
          "workflow_id": {
            "type": "string",
            "description": "Workflow ID"
          }
        }
      },
      "WorkflowResultsResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "data": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "description": "Error type"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication error - invalid or missing token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Invalid parameter error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Rate limit exceeded",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "apiToken": []
    }
  ],
  "tags": [
    {
      "name": "Polls",
      "description": "Operations related to Polls"
    },
    {
      "name": "Surveys",
      "description": "Operations related to Surveys"
    },
    {
      "name": "Workflows",
      "description": "Operations related to Workflows"
    }
  ]
}