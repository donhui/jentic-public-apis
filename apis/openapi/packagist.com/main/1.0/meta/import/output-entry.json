{
  "openapi": "3.0.3",
  "info": {
    "title": "Private Packagist API",
    "version": "1.0",
    "description": "Private Packagist REST API for managing packages, teams, customers, and credentials in your organization's private Composer repository.",
    "x-jentic-source-url": "https://packagist.com/docs/api"
  },
  "servers": [
    {
      "url": "https://packagist.com/api"
    }
  ],
  "paths": {
    "/packages/": {
      "get": {
        "operationId": "listPackages",
        "summary": "List all packages",
        "tags": [
          "Packages"
        ],
        "parameters": [
          {
            "name": "origin",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "public-mirror",
                "private-mirror",
                "private"
              ]
            },
            "description": "Filter by package origin"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page number"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Items per page"
          }
        ],
        "responses": {
          "200": {
            "description": "List of packages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Package"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createPackage",
        "summary": "Create a new package",
        "tags": [
          "Packages"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PackageInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Package created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Package"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
