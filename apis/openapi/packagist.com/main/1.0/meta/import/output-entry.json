  "components": {
    "securitySchemes": {
      "hmacAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "PACKAGIST-HMAC-SHA256 signature-based authentication: Authorization: PACKAGIST-HMAC-SHA256 Key=..., Timestamp=..., Cnonce=..., Signature=..."
      },
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "PACKAGIST-TOKEN for GET requests only: Authorization: PACKAGIST-TOKEN [api-key]"
