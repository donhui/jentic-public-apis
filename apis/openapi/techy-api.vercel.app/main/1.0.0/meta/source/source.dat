{
  "openapi": "3.0.3",
  "info": {
    "title": "Techy API",
    "version": "1.0.0",
    "description": "A simple API that generates cool tech-savvy sounding phrases. Returns random techy phrases in either plaintext or JSON format.",
    "x-jentic-source-url": "https://techy-api.vercel.app/"
  },
  "servers": [
    {
      "url": "https://techy-api.vercel.app"
    }
  ],
  "paths": {
    "/api/text": {
      "get": {
        "operationId": "getRandomPhraseAsText",
        "summary": "Get a random techy phrase in plaintext",
        "tags": ["Phrases"],
        "responses": {
          "200": {
            "description": "A random techy phrase in plaintext",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "example": "Mass-parallel bandwidth is down, reboot the virtual.js sensor"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/json": {
      "get": {
        "operationId": "getRandomPhraseAsJson",
        "summary": "Get a random techy phrase in JSON format",
        "tags": ["Phrases"],
        "responses": {
          "200": {
            "description": "A random techy phrase in JSON",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TechyPhrase"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TechyPhrase": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "A randomly generated techy phrase",
            "example": "Mass-parallel bandwidth is down, reboot the virtual.js sensor"
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}