  "components": {
    "securitySchemes": {
      "PATAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Personal Access Token (PAT). Format: 'Key YOUR_PAT_HERE'. Obtain from https://clarifai.com/settings/security"
      }
    },
    "schemas": {
      "PostModelOutputsRequest": {
        "type": "object",
        "required": [
          "inputs"
        ],
        "properties": {
          "user_app_id": {
            "$ref": "#/components/schemas/UserAppId"
          },
          "inputs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Input"
            },
            "description": "List of inputs to process (max 128)"
          }
        }
      },
      "PostInputsRequest": {
        "type": "object",
        "required": [
          "inputs"
        ],
        "properties": {
          "inputs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Input"
            }
          }
        }
      },
      "DeleteInputsRequest": {
        "type": "object",
        "properties": {
          "ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of input IDs to delete"
          }
        }
      },
      "PostSearchesRequest": {
        "type": "object",
        "properties": {
          "query": {
            "type": "object",
            "properties": {
              "ands": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "output": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Data"
                        }
                      }
                    },
                    "input": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Data"
                        }
                      }
