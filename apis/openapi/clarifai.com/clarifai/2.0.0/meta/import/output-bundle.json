{
  "openapi": "3.0.3",
  "info": {
    "title": "Clarifai API",
    "description": "Clarifai is a computer vision and natural language processing platform that provides pre-trained and custom AI models for image recognition, object detection, face detection, text classification, and more. The API allows you to make predictions using models, manage inputs, search visual content, and build custom workflows.",
    "version": "2.0.0",
    "contact": {
      "name": "Clarifai Support",
      "url": "https://docs.clarifai.com",
      "email": "support@clarifai.com"
    },
    "x-jentic-source-url": "https://docs.clarifai.com/api-guide/api-overview"
  },
  "servers": [
    {
      "url": "https://api.clarifai.com/v2",
      "description": "Clarifai Production API"
    }
  ],
  "paths": {
    "/users/{user_id}/apps/{app_id}/models/{model_id}/outputs": {
      "post": {
        "operationId": "postModelOutputs",
        "summary": "Predict using a model",
        "description": "Makes predictions on inputs using a specified model. Supports image classification, object detection, face detection, text analysis, and more.",
        "tags": [
          "Predict"
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The user ID that owns the model"
          },
          {
            "name": "app_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The application ID that contains the model"
          },
          {
            "name": "model_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The model ID to use for prediction"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostModelOutputsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful prediction",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MultiOutputResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "PATAuth": []
          }
        ]
      }
    },
