{
  "openapi": "3.0.1",
  "info": {
    "title": "Add Offer Order",
    "description": "This is Swagger specification for the Open API to add offer order. There are some assumptions that needs to be considered while using this API, \n 1) This API does not support adding of multiple offers in one API request. \n 2) It is assumed that channel calling the API would create payload for this API based on the deep filtering responses from the TMF620 List Product Offering API and will not include unavailable offer in the payload. This API does not perform any offer eligibility or offer availability check. \n  3) This API replaces an existing purchased offer with the new offer if the cardinality rule in the ancestor offer tree allows 1 optional child offer only and another optional child offer has already been purchased. \n 4) The channel shall pass in the OrderUpfrontPrice in the API request. \n 5) The channel shall continue to use the existing get ProductOrder API to retrieve the product order information and the existing get Product API to retrieve the product inventory information. ",
    "version": "1.6",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/CSGSystems/AddOfferOrder/1.6/swagger.json"
