{
  "openapi": "3.0.3",
  "info": {
    "title": "KanbanTool API",
    "description": "KanbanTool API v3 for managing boards, tasks, subtasks, comments, attachments, and time trackers.",
    "version": "3.0.0",
    "x-jentic-source-url": "https://kanbantool.com/developer/api-v3"
  },
  "servers": [
    {
      "url": "https://{domain}.kanbantool.com/api/v3",
      "variables": {
        "domain": {
          "default": "your-domain",
          "description": "Your KanbanTool domain"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {"name": "Users", "description": "User operations"},
    {"name": "Boards", "description": "Board operations"},
    {"name": "Tasks", "description": "Task operations"},
    {"name": "Subtasks", "description": "Subtask operations"},
    {"name": "Comments", "description": "Comment operations"},
    {"name": "Attachments", "description": "Attachment operations"},
    {"name": "TimeTrackers", "description": "Time tracker operations"}
  ],
  "paths": {
    "/users/{userId}.json": {
      "get": {
        "operationId": "getUser",
        "tags": ["Users"],
        "summary": "Get a specific user",
        "parameters": [{"name": "userId", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "200": {"description": "User details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/User"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/users/current.json": {
      "get": {
        "operationId": "getCurrentUser",
        "tags": ["Users"],
        "summary": "Get authenticated user info and accessible boards",
        "responses": {
          "200": {"description": "Current user", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/User"}}}},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/boards/{boardId}/preload.json": {
      "get": {
        "operationId": "preloadBoard",
        "tags": ["Boards"],
        "summary": "Get board overview without tasks",
        "parameters": [{"$ref": "#/components/parameters/BoardIdParam"}],
        "responses": {
          "200": {"description": "Board overview", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Board"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/boards/{boardId}.json": {
      "get": {
        "operationId": "getBoard",
        "tags": ["Boards"],
        "summary": "Get complete board data including all tasks",
        "parameters": [{"$ref": "#/components/parameters/BoardIdParam"}],
        "responses": {
          "200": {"description": "Board with tasks", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Board"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/boards/{boardId}/changelog.json": {
      "get": {
        "operationId": "getBoardChangelog",
        "tags": ["Boards"],
        "summary": "List board changelogs",
        "parameters": [
          {"$ref": "#/components/parameters/BoardIdParam"},
          {"name": "before", "in": "query", "schema": {"type": "integer"}},
          {"name": "after", "in": "query", "schema": {"type": "integer"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Changelog entries", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Changelog"}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/tasks/search.json": {
      "get": {
        "operationId": "searchTasks",
        "tags": ["Tasks"],
        "summary": "Search tasks across boards",
        "parameters": [
          {"name": "q", "in": "query", "required": true, "schema": {"type": "string"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer"}},
          {"name": "page", "in": "query", "schema": {"type": "integer"}},
          {"name": "board_id", "in": "query", "schema": {"type": "string"}},
          {"name": "archived", "in": "query", "schema": {"type": "integer", "enum": [0, 1]}}
        ],
        "responses": {
          "200": {"description": "Search results", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Task"}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/tasks/{taskId}/preload.json": {
      "get": {
        "operationId": "preloadTask",
        "tags": ["Tasks"],
        "summary": "Get task overview without details",
        "parameters": [{"$ref": "#/components/parameters/TaskIdParam"}],
        "responses": {
          "200": {"description": "Task overview", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Task"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/tasks/{taskId}.json": {
      "get": {
        "operationId": "getTask",
        "tags": ["Tasks"],
        "summary": "Get complete task with subtasks, comments, attachments",
        "parameters": [{"$ref": "#/components/parameters/TaskIdParam"}],
        "responses": {
          "200": {"description": "Task details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Task"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateTask",
        "tags": ["Tasks"],
        "summary": "Update a task (also used for archive, unarchive, delete, restore)",
        "parameters": [{"$ref": "#/components/parameters/TaskIdParam"}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TaskUpdate"}}}
        },
        "responses": {
          "200": {"description": "Updated task", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Task"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/tasks.json": {
      "post": {
        "operationId": "createTask",
        "tags": ["Tasks"],
        "summary": "Create a new task",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TaskCreate"}}}
        },
        "responses": {
          "200": {"description": "Task created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Task"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/subtasks.json": {
      "post": {
        "operationId": "createSubtask",
        "tags": ["Subtasks"],
        "summary": "Create a subtask",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SubtaskCreate"}}}
        },
        "responses": {
          "200": {"description": "Subtask created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Subtask"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/subtasks/{subtaskId}.json": {
      "patch": {
        "operationId": "updateSubtask",
        "tags": ["Subtasks"],
        "summary": "Update a subtask",
        "parameters": [{"name": "subtaskId", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SubtaskCreate"}}}},
        "responses": {
          "200": {"description": "Subtask updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Subtask"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteSubtask",
        "tags": ["Subtasks"],
        "summary": "Delete a subtask",
        "parameters": [{"name": "subtaskId", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "200": {"description": "Subtask deleted"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/subtasks/reorder.json": {
      "put": {
        "operationId": "reorderSubtasks",
        "tags": ["Subtasks"],
        "summary": "Reorder subtasks",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "properties": {"task_id": {"type": "integer"}, "ids": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "Subtasks reordered", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Subtask"}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/tasks/{taskId}/comments.json": {
      "post": {
        "operationId": "createComment",
        "tags": ["Comments"],
        "summary": "Create a comment on a task",
        "parameters": [{"$ref": "#/components/parameters/TaskIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "required": ["content"], "properties": {"content": {"type": "string"}}}}}},
        "responses": {
          "200": {"description": "Comment created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Comment"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/tasks/{taskId}/comments/{commentId}.json": {
      "delete": {
        "operationId": "deleteComment",
        "tags": ["Comments"],
        "summary": "Delete a comment",
        "parameters": [
          {"$ref": "#/components/parameters/TaskIdParam"},
          {"name": "commentId", "in": "path", "required": true, "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Comment deleted"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/attachments.json": {
      "post": {
        "operationId": "uploadAttachment",
        "tags": ["Attachments"],
        "summary": "Upload an attachment",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "files[]": {"type": "string", "format": "binary"},
                  "attachable": {"type": "string", "description": "Resource identifier like Board#100 or Task#200"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Attachment uploaded"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/attachments/{attachmentId}/detach.json": {
      "delete": {
        "operationId": "detachAttachment",
        "tags": ["Attachments"],
        "summary": "Detach an attachment",
        "parameters": [
          {"name": "attachmentId", "in": "path", "required": true, "schema": {"type": "integer"}},
          {"name": "attachable", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "204": {"description": "Attachment detached"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/attachments/{attachmentId}/set_mode.json": {
      "patch": {
        "operationId": "setAttachmentMode",
        "tags": ["Attachments"],
        "summary": "Set attachment display mode",
        "parameters": [{"name": "attachmentId", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["attachable", "mode"], "properties": {"attachable": {"type": "string"}, "mode": {"type": "integer", "enum": [0, 1, 2, 3], "description": "0=none, 1=pinned, 2=cover, 3=pinned+cover"}}}}}
        },
        "responses": {
          "204": {"description": "Mode set"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/time_trackers.json": {
      "post": {
        "operationId": "createTimeTracker",
        "tags": ["TimeTrackers"],
        "summary": "Create a time tracker entry",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TimeTrackerCreate"}}}
        },
        "responses": {
          "200": {"description": "Time tracker created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TimeTracker"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/time_trackers/{timeTrackerId}.json": {
      "put": {
        "operationId": "updateTimeTracker",
        "tags": ["TimeTrackers"],
        "summary": "Update a time tracker",
        "parameters": [{"name": "timeTrackerId", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TimeTrackerCreate"}}}},
        "responses": {
          "200": {"description": "Time tracker updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TimeTracker"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteTimeTracker",
        "tags": ["TimeTrackers"],
        "summary": "Delete a time tracker",
        "parameters": [{"name": "timeTrackerId", "in": "path", "required": true, "schema": {"type": "integer"}}],
        "responses": {
          "200": {"description": "Time tracker deleted"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "BoardIdParam": {
        "name": "boardId",
        "in": "path",
        "required": true,
        "schema": {"type": "integer"}
      },
      "TaskIdParam": {
        "name": "taskId",
        "in": "path",
        "required": true,
        "schema": {"type": "integer"}
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "email": {"type": "string"},
          "boards": {"type": "array", "items": {"$ref": "#/components/schemas/Board"}}
        }
      },
      "Board": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "tasks": {"type": "array", "items": {"$ref": "#/components/schemas/Task"}},
          "workflow_stages": {"type": "array", "items": {"$ref": "#/components/schemas/WorkflowStage"}},
          "swimlanes": {"type": "array", "items": {"$ref": "#/components/schemas/Swimlane"}}
        }
      },
      "WorkflowStage": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "position": {"type": "integer"}
        }
      },
      "Swimlane": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "position": {"type": "integer"}
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "board_id": {"type": "integer"},
          "workflow_stage_id": {"type": "integer"},
          "swimlane_id": {"type": "integer"},
          "card_type_id": {"type": "integer"},
          "priority": {"type": "integer"},
          "tags": {"type": "string"},
          "due_date": {"type": "string", "format": "date"},
          "deleted_at": {"type": "string", "format": "date-time", "nullable": true},
          "subtasks": {"type": "array", "items": {"$ref": "#/components/schemas/Subtask"}},
          "comments": {"type": "array", "items": {"$ref": "#/components/schemas/Comment"}}
        }
      },
      "TaskCreate": {
        "type": "object",
        "required": ["task"],
        "properties": {
          "task": {
            "type": "object",
            "required": ["name", "board_id"],
            "properties": {
              "name": {"type": "string"},
              "board_id": {"type": "integer"},
              "workflow_stage_id": {"type": "integer"},
              "swimlane_id": {"type": "integer"},
              "card_type_id": {"type": "integer"},
              "description": {"type": "string"},
              "priority": {"type": "integer"},
              "tags": {"type": "string"},
              "due_date": {"type": "string", "format": "date"}
            }
          }
        }
      },
      "TaskUpdate": {
        "type": "object",
        "properties": {
          "task": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "description": {"type": "string"},
              "workflow_stage_id": {"type": "integer"},
              "swimlane_id": {"type": "integer"},
              "priority": {"type": "integer"},
              "tags": {"type": "string"},
              "due_date": {"type": "string", "format": "date"}
            }
          },
          "_action": {"type": "string", "enum": ["archive", "unarchive", "delete", "undelete"]}
        }
      },
      "Subtask": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "task_id": {"type": "integer"},
          "assigned_user_id": {"type": "integer"},
          "is_completed": {"type": "boolean"},
          "position": {"type": "integer"},
          "deleted_at": {"type": "string", "format": "date-time", "nullable": true}
        }
      },
      "SubtaskCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "task_id": {"type": "integer"},
          "assigned_user_id": {"type": "integer"},
          "is_completed": {"type": "boolean"}
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "content": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"},
          "deleted_at": {"type": "string", "format": "date-time", "nullable": true}
        }
      },
      "Changelog": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "action": {"type": "string"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "TimeTracker": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "board_id": {"type": "integer"},
          "task_id": {"type": "integer"},
          "position": {"type": "integer"},
          "listed": {"type": "boolean"},
          "started_at": {"type": "string", "format": "date-time"},
          "ended_at": {"type": "string", "format": "date-time", "nullable": true},
          "highlighted_at": {"type": "string", "format": "date-time", "nullable": true}
        }
      },
      "TimeTrackerCreate": {
        "type": "object",
        "required": ["board_id", "task_id"],
        "properties": {
          "board_id": {"type": "integer"},
          "task_id": {"type": "integer"},
          "position": {"type": "integer"},
          "listed": {"type": "boolean"},
          "started_at": {"type": "string", "format": "date-time"},
          "ended_at": {"type": "string", "format": "date-time"},
          "highlighted_at": {"type": "string", "format": "date-time"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing Bearer token"
      }
    }
  }
}
