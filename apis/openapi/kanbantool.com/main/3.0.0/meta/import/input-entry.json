{
  "openapi": "3.0.3",
  "info": {
    "title": "Kanban Tool API",
    "description": "Kanban Tool is a smart visual project management application with real-time collaboration that allows teams to get work done faster.",
    "version": "3.0.0",
    "x-jentic-source-url": "http://kanbantool.com/about/api#introduction"
  },
  "servers": [
    {
      "url": "https://{domain}.kanbantool.com/api/v3",
      "variables": {
        "domain": {
          "default": "YOUR_DOMAIN",
          "description": "Your Kanban Tool workspace subdomain"
        }
      }
    }
  ],
  "paths": {
    "/users/{user_id}.json": {
      "get": {
        "operationId": "getUser",
        "summary": "Fetch a user",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "responses": {
          "200": {
            "description": "User object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      }
    },
    "/users/current.json": {
      "get": {
        "operationId": "getCurrentUser",
        "summary": "Fetch current authenticated user",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Current user object with boards and time trackers",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/User"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "boards": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Board"
                          }
                        },
                        "time_trackers": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/TimeTracker"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/boards/{board_id}/preload.json": {
      "get": {
        "operationId": "preloadBoard",
        "summary": "Fetch board without tasks",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/BoardId"
          }
        ],
        "responses": {
          "200": {
            "description": "Board object without tasks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Board"
                }
              }
            }
          }
        }
      }
    },
    "/boards/{board_id}.json": {
      "get": {
        "operationId": "getBoard",
        "summary": "Fetch board with tasks",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/BoardId"
          }
        ],
        "responses": {
          "200": {
            "description": "Board object with tasks",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Board"
                }
              }
            }
          }
        }
      }
    },
    "/boards/{board_id}/changelog.json": {
      "get": {
        "operationId": "listBoardChangelogs",
        "summary": "List board changelogs",
        "tags": [
          "Boards"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/BoardId"
          },
          {
            "name": "before",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Return changelogs where id < value"
          },
          {
            "name": "after",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Return changelogs where id > value"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Maximum number of results"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of changelog objects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Changelog"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/search.json": {
      "get": {
        "operationId": "searchTasks",
        "summary": "Search tasks",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query with filters"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "board_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated board IDs"
          },
          {
            "name": "archived",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "Set to 1 for archived tasks"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of matching tasks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task_id}/preload.json": {
      "get": {
        "operationId": "preloadTask",
        "summary": "Fetch task basic data",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskId"
          }
        ],
        "responses": {
          "200": {
            "description": "Task object with basic data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task_id}.json": {
      "get": {
        "operationId": "getTask",
        "summary": "Fetch task with full details",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskId"
          }
        ],
        "responses": {
          "200": {
            "description": "Task with comments, subtasks, attachments, changelogs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateTask",
        "summary": "Update a task",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated task object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/tasks.json": {
      "post": {
        "operationId": "createTask",
        "summary": "Create a task",
        "tags": [
          "Tasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created task object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/subtasks.json": {
      "post": {
        "operationId": "createSubtask",
        "summary": "Create a subtask",
        "tags": [
          "Subtasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubtaskCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created subtask object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subtask"
                }
              }
            }
          }
        }
      }
    },
    "/subtasks/{subtask_id}.json": {
      "patch": {
        "operationId": "updateSubtask",
        "summary": "Update a subtask",
        "tags": [
          "Subtasks"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/SubtaskId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubtaskCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated subtask object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subtask"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteSubtask",
        "summary": "Delete a subtask",
        "tags": [
          "Subtasks"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/SubtaskId"
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted subtask with deleted_at timestamp",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subtask"
                }
              }
            }
          }
        }
      }
    },
    "/subtasks/reorder.json": {
      "put": {
        "operationId": "reorderSubtasks",
        "summary": "Reorder subtasks",
        "tags": [
          "Subtasks"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "task_id",
                  "ids"
                ],
                "properties": {
                  "task_id": {
                    "type": "integer"
                  },
                  "ids": {
                    "type": "string",
                    "description": "Comma-separated subtask IDs in new order"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reordered subtask objects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Subtask"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task_id}/comments.json": {
      "post": {
        "operationId": "createComment",
        "summary": "Create a comment on a task",
        "tags": [
          "Comments"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "content"
                ],
                "properties": {
                  "content": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created comment object",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comment"
                }
              }
            }
          }
        }
      }
    },
    "/tasks/{task_id}/comments/{comment_id}.json": {
      "delete": {
        "operationId": "deleteComment",
        "summary": "Delete a comment",
        "tags": [
          "Comments"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskId"
          },
          {
            "name": "comment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted comment with deleted_at timestamp",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Comment"
                }
              }
            }
          }
        }
      }
    },
    "/attachments.json": {
      "post": {
        "operationId": "createAttachment",
        "summary": "Upload an attachment",
        "tags": [
          "Attachments"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "files[]"
                ],
                "properties": {
                  "files[]": {
                    "type": "string",
                    "format": "binary",
                    "description": "File to upload"
                  },
                  "attachable": {
                    "type": "string",
                    "description": "Target entity, e.g. Board#123 or Task#456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload result array",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {}
                }
              }
            }
          }
        }
      }
    },
    "/attachments/{attachment_id}/detach.json": {
      "delete": {
        "operationId": "detachAttachment",
        "summary": "Detach an attachment",
        "tags": [
          "Attachments"
        ],
        "parameters": [
          {
            "name": "attachment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "attachable",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Target entity, e.g. Board#123 or Task#456"
          }
        ],
        "responses": {
          "200": {
            "description": "Empty response"
          }
        }
      }
    },
    "/attachments/{attachment_id}/set_mode.json": {
      "patch": {
        "operationId": "setAttachmentMode",
        "summary": "Set attachment display mode",
        "tags": [
          "Attachments"
        ],
        "parameters": [
          {
            "name": "attachment_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "attachable",
                  "mode"
                ],
                "properties": {
                  "attachable": {
                    "type": "string",
                    "description": "Target entity"
                  },
                  "mode": {
                    "type": "integer",
                    "enum": [
                      0,
                      1,
                      2,
                      3
                    ],
                    "description": "0=none, 1=pinned, 2=cover, 3=pinned+cover"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Empty response"
          }
        }
      }
    },
    "/time_trackers.json": {
      "post": {
        "operationId": "createTimeTracker",
        "summary": "Create a time tracker",
        "tags": [
          "Time Trackers"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TimeTrackerCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created time tracker",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimeTracker"
                }
              }
            }
          }
        }
      }
    },
    "/time_trackers/{time_tracker_id}.json": {
      "put": {
        "operationId": "updateTimeTracker",
        "summary": "Update a time tracker",
        "tags": [
          "Time Trackers"
        ],
        "parameters": [
          {
            "name": "time_tracker_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TimeTrackerUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated time tracker",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimeTracker"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteTimeTracker",
        "summary": "Delete a time tracker",
        "tags": [
          "Time Trackers"
        ],
        "parameters": [
          {
            "name": "time_tracker_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted time tracker",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimeTracker"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "parameters": {
      "UserId": {
        "name": "user_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      },
      "BoardId": {
        "name": "board_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      },
      "TaskId": {
        "name": "task_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      },
      "SubtaskId": {
        "name": "subtask_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "initials": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          }
        }
      },
      "Board": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "swimlanes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Swimlane"
            }
          },
          "workflow_stages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WorkflowStage"
            }
          },
          "card_types": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CardType"
            }
          },
          "tasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Task"
            }
          },
          "collaborators": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/User"
            }
          },
          "settings": {
            "type": "object"
          }
        }
      },
      "Swimlane": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "WorkflowStage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "CardType": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "tags": {
            "type": "string"
          },
          "due_date": {
            "type": "string",
            "format": "date"
          },
          "assigned_user_id": {
            "type": "integer"
          },
          "board_id": {
            "type": "integer"
          },
          "workflow_stage_id": {
            "type": "integer"
          },
          "swimlane_id": {
            "type": "integer"
          },
          "card_type_id": {
            "type": "integer"
          },
          "subtasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Subtask"
            }
          },
          "comments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Comment"
            }
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            }
          },
          "time_trackers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TimeTracker"
            }
          }
        }
      },
      "TaskCreate": {
        "type": "object",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "object",
            "required": [
              "name",
              "board_id"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "board_id": {
                "type": "integer"
              },
              "workflow_stage_id": {
                "type": "integer"
              },
              "swimlane_id": {
                "type": "integer"
              },
              "card_type_id": {
                "type": "integer"
              },
              "description": {
                "type": "string"
              },
              "priority": {
                "type": "integer"
              },
              "tags": {
                "type": "string"
              },
              "due_date": {
                "type": "string",
                "format": "date"
              },
              "assigned_user_id": {
                "type": "integer"
              }
            }
          }
        }
      },
      "TaskUpdate": {
        "type": "object",
        "properties": {
          "task": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "priority": {
                "type": "integer"
              },
              "tags": {
                "type": "string"
              },
              "due_date": {
                "type": "string",
                "format": "date"
              },
              "assigned_user_id": {
                "type": "integer"
              },
              "workflow_stage_id": {
                "type": "integer"
              },
              "swimlane_id": {
                "type": "integer"
              },
