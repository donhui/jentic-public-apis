{
  "openapi": "3.0.3",
  "info": {
    "title": "Dolibarr ERP CRM API",
    "version": "19.0",
    "description": "REST API for Dolibarr ERP/CRM. Provides access to products, orders, invoices, third parties, and other ERP resources.",
    "x-jentic-source-url": "https://wiki.dolibarr.org"
  },
  "servers": [
    {
      "url": "https://{server}/api/index.php",
      "description": "Dolibarr API server",
      "variables": {
        "server": {
          "default": "example.com",
          "description": "Your Dolibarr server hostname"
        }
      }
    }
  ],
  "paths": {
    "/login": {
      "get": {
        "operationId": "getLoginToken",
        "summary": "Obtain API token for a user",
        "tags": [
          "Authentication"
        ],
        "parameters": [
          {
            "name": "login",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Username"
          },
          {
            "name": "password",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "User password"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": []
      }
    },
