{
  "openapi": "3.0.3",
  "info": {
    "title": "Dolibarr ERP REST API",
    "description": "REST API for the Dolibarr ERP/CRM platform. Provides access to products, orders, third parties (customers/suppliers), and other business resources.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://wiki.dolibarr.org"
  },
  "servers": [
    {
      "url": "https://{host}/api/index.php",
      "description": "Dolibarr instance API base URL",
      "variables": {
        "host": {
          "default": "your-dolibarr-instance.com",
          "description": "Your Dolibarr server hostname"
        }
      }
    }
  ],
  "paths": {
    "/login": {
      "get": {
        "operationId": "getApiToken",
        "summary": "Obtain API token",
        "description": "Authenticate and obtain a DOLAPIKEY token for subsequent API requests.",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "login",
            "in": "query",
            "required": true,
            "description": "User login name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "password",
            "in": "query",
            "required": true,
            "description": "User password",
            "schema": {
              "type": "string",
              "format": "password"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "List products",
        "description": "Retrieve a list of products with optional filtering, sorting, and pagination.",
        "tags": ["Products"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/SortField"
          },
          {
            "$ref": "#/components/parameters/SortOrder"
          },
          {
            "$ref": "#/components/parameters/SqlFilters"
          }
        ],
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing DOLAPIKEY"
          }
        }
      },
      "post": {
        "operationId": "createProduct",
        "summary": "Create a product",
        "description": "Create a new product in Dolibarr.",
        "tags": ["Products"],
        "security": [{"apiKeyAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "description": "ID of the created product"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "operationId": "getProduct",
        "summary": "Get a product",
        "description": "Retrieve a single product by ID.",
        "tags": ["Products"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Product ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Product not found"
          }
        }
      },
      "put": {
        "operationId": "updateProduct",
        "summary": "Update a product",
        "description": "Update an existing product.",
        "tags": ["Products"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product updated"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Product not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteProduct",
        "summary": "Delete a product",
        "description": "Delete a product by ID.",
        "tags": ["Products"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Product not found"
          }
        }
      }
    },
    "/thirdparties": {
      "get": {
        "operationId": "listThirdParties",
        "summary": "List third parties",
        "description": "Retrieve a list of third parties (customers, suppliers, prospects).",
        "tags": ["Third Parties"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/SortField"
          },
          {
            "$ref": "#/components/parameters/SortOrder"
          },
          {
            "$ref": "#/components/parameters/SqlFilters"
          },
          {
            "name": "mode",
            "in": "query",
            "description": "Filter by type: 1=customer, 2=prospect, 3=supplier, 4=customer+prospect",
            "schema": {
              "type": "integer",
              "enum": [1, 2, 3, 4]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of third parties",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ThirdParty"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createThirdParty",
        "summary": "Create a third party",
        "description": "Create a new third party (customer, supplier, or prospect).",
        "tags": ["Third Parties"],
        "security": [{"apiKeyAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ThirdPartyCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Third party created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "description": "ID of the created third party"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/thirdparties/{id}": {
      "get": {
        "operationId": "getThirdParty",
        "summary": "Get a third party",
        "description": "Retrieve a single third party by ID.",
        "tags": ["Third Parties"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Third party details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThirdParty"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "operationId": "updateThirdParty",
        "summary": "Update a third party",
        "tags": ["Third Parties"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ThirdPartyCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Third party updated"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteThirdParty",
        "summary": "Delete a third party",
        "tags": ["Third Parties"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "List orders",
        "description": "Retrieve a list of orders.",
        "tags": ["Orders"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "$ref": "#/components/parameters/SortField"
          },
          {
            "$ref": "#/components/parameters/SortOrder"
          },
          {
            "$ref": "#/components/parameters/SqlFilters"
          }
        ],
        "responses": {
          "200": {
            "description": "List of orders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Order"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "operationId": "createOrder",
        "summary": "Create an order",
        "description": "Create a new sales order.",
        "tags": ["Orders"],
        "security": [{"apiKeyAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "description": "Order ID"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/orders/{id}": {
      "get": {
        "operationId": "getOrder",
        "summary": "Get an order",
        "tags": ["Orders"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "operationId": "updateOrder",
        "summary": "Update an order",
        "tags": ["Orders"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order updated"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "operationId": "deleteOrder",
        "summary": "Delete an order",
        "tags": ["Orders"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order deleted"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/orders/{id}/validate": {
      "post": {
        "operationId": "validateOrder",
        "summary": "Validate an order",
        "description": "Validate a draft order to change its status.",
        "tags": ["Orders"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "idwarehouse": {
                    "type": "string",
                    "description": "Warehouse ID",
                    "default": "0"
                  },
                  "notrigger": {
                    "type": "string",
                    "description": "Disable triggers",
                    "default": "0"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order validated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/orders/{id}/lines": {
      "post": {
        "operationId": "addOrderLine",
        "summary": "Add a line to an order",
        "description": "Add a new line item to an existing order.",
        "tags": ["Orders"],
        "security": [{"apiKeyAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderLine"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Line added"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Order not found"
          }
        }
      }
    },
    "/dictionnarycountries": {
      "get": {
        "operationId": "listCountries",
        "summary": "List countries",
        "description": "Retrieve the list of available countries from the dictionary.",
        "tags": ["Dictionaries"],
        "security": [{"apiKeyAuth": []}],
        "responses": {
          "200": {
            "description": "List of countries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Country"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Limit": {
        "name": "limit",
        "in": "query",
        "description": "Maximum number of records to return",
        "schema": {
          "type": "integer",
          "default": 100
        }
      },
      "SortField": {
        "name": "sortfield",
        "in": "query",
        "description": "Field to sort by",
        "schema": {
          "type": "string"
        }
      },
      "SortOrder": {
        "name": "sortorder",
        "in": "query",
        "description": "Sort direction: ASC or DESC",
        "schema": {
          "type": "string",
          "enum": ["ASC", "DESC"]
        }
      },
      "SqlFilters": {
        "name": "sqlfilters",
        "in": "query",
        "description": "SQL-style filter string (e.g., '(t.ref:like:%ABC%)')",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "LoginResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer",
                "example": 200
              },
              "token": {
                "type": "string",
                "description": "API key token (DOLAPIKEY)"
              }
            }
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Product ID"
          },
          "ref": {
            "type": "string",
            "description": "Product reference"
          },
          "label": {
            "type": "string",
            "description": "Product label/name"
          },
          "description": {
            "type": "string",
            "description": "Product description"
          },
          "type": {
            "type": "string",
            "description": "0=product, 1=service"
          },
          "price": {
            "type": "number",
            "description": "Selling price"
          },
          "price_ttc": {
            "type": "number",
            "description": "Selling price including tax"
          },
          "tva_tx": {
            "type": "number",
            "description": "VAT rate"
          },
          "status": {
            "type": "integer",
            "description": "Product status (0=draft, 1=active)"
          },
          "barcode": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          },
          "stock_reel": {
            "type": "number",
            "description": "Real stock quantity"
          }
        }
      },
      "ProductCreate": {
        "type": "object",
        "required": ["ref", "label"],
        "properties": {
          "ref": {
            "type": "string",
            "description": "Product reference"
          },
          "label": {
            "type": "string",
            "description": "Product label/name"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "description": "0=product, 1=service",
            "default": "0"
          },
          "price": {
            "type": "number"
          },
          "tva_tx": {
            "type": "number",
            "description": "VAT rate"
          },
          "status": {
            "type": "integer",
            "default": 1
          },
          "barcode": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          }
        }
      },
      "ThirdParty": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "description": "Company or individual name"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          },
          "town": {
            "type": "string"
          },
          "country_id": {
            "type": "integer"
          },
          "client": {
            "type": "string",
            "description": "0=not customer, 1=customer, 2=prospect, 3=customer+prospect"
          },
          "fournisseur": {
            "type": "string",
            "description": "0=not supplier, 1=supplier"
          },
          "code_client": {
            "type": "string"
          },
          "code_fournisseur": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          }
        }
      },
      "ThirdPartyCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          },
          "town": {
            "type": "string"
          },
          "country_id": {
            "type": "integer"
          },
          "client": {
            "type": "string",
            "default": "1"
          },
          "fournisseur": {
            "type": "string",
            "default": "0"
          },
          "code_client": {
            "type": "string",
            "default": "auto"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "ref": {
            "type": "string",
            "description": "Order reference"
          },
          "socid": {
            "type": "string",
            "description": "Third party ID"
          },
          "type": {
            "type": "string",
            "description": "Order type: 0=standard"
          },
          "date": {
            "type": "string",
            "description": "Order date (Unix timestamp)"
          },
          "statut": {
            "type": "integer",
            "description": "Order status"
          },
          "total_ht": {
            "type": "number",
            "description": "Total excluding tax"
          },
          "total_tva": {
            "type": "number",
            "description": "Total tax"
          },
          "total_ttc": {
            "type": "number",
            "description": "Total including tax"
          },
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderLine"
            }
          }
        }
      },
      "OrderCreate": {
        "type": "object",
        "required": ["socid"],
        "properties": {
          "socid": {
            "type": "string",
            "description": "Third party ID"
          },
          "type": {
            "type": "string",
            "default": "0"
          },
          "date": {
            "type": "string",
            "description": "Order date (Unix timestamp)"
          },
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderLine"
            }
          }
        }
      },
      "OrderLine": {
        "type": "object",
        "properties": {
          "fk_product": {
            "type": "integer",
            "description": "Product ID"
          },
          "desc": {
            "type": "string",
            "description": "Line description"
          },
          "qty": {
            "type": "number",
            "description": "Quantity"
