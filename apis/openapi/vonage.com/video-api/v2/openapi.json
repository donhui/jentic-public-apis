{
  "openapi": "3.0.3",
  "info": {
    "title": "Vonage Video API (OpenTok)",
    "description": "The Vonage Video API (formerly OpenTok) provides a REST API for managing video sessions, archives, broadcasts, signals, streams, and connections. Authentication uses JWT tokens passed via the X-OPENTOK-AUTH header.",
    "version": "2.0.0",
    "contact": {
      "name": "Vonage Developer",
      "url": "https://developer.vonage.com"
    },
    "x-jentic-source-url": "https://developer.vonage.com/en/video/overview"
  },
  "servers": [
    {
      "url": "https://api.opentok.com/v2/project/{apiKey}",
      "description": "Vonage Video API (OpenTok)",
      "variables": {
        "apiKey": {
          "description": "Your OpenTok API key",
          "default": "YOUR_API_KEY"
        }
      }
    }
  ],
  "security": [
    {
      "opentokAuth": []
    }
  ],
  "tags": [
    {
      "name": "Sessions",
      "description": "Create and manage video sessions"
    },
    {
      "name": "Archives",
      "description": "Record and manage session archives"
    },
    {
      "name": "Streams",
      "description": "Get stream information and mute streams"
    },
    {
      "name": "Signals",
      "description": "Send signals to clients in a session"
    },
    {
      "name": "Connections",
      "description": "List and force-disconnect connections"
    },
    {
      "name": "Broadcasts",
      "description": "Start and manage live streaming broadcasts"
    }
  ],
  "paths": {
    "/session/create": {
      "post": {
        "operationId": "createSession",
        "summary": "Create a session",
        "description": "Create a new OpenTok session. Returns a session ID that you use to connect clients.",
        "tags": ["Sessions"],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Session"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/session/{sessionId}/signal": {
      "post": {
        "operationId": "signalAllClients",
        "summary": "Signal all clients in a session",
        "description": "Send a signal to all clients connected to a session.",
        "tags": ["Signals"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The session ID."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignalRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Signal sent successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/session/{sessionId}/connection/{connectionId}/signal": {
      "post": {
        "operationId": "signalSpecificClient",
        "summary": "Signal a specific client",
        "description": "Send a signal to a specific client connected to a session.",
        "tags": ["Signals"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "connectionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignalRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Signal sent successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "Connection not found"
          }
        }
      }
    },
    "/session/{sessionId}/connection/{connectionId}": {
      "delete": {
        "operationId": "forceDisconnect",
        "summary": "Force disconnect a client",
        "description": "Force a client endpoint to disconnect from a session.",
        "tags": ["Connections"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "connectionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Client disconnected"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "Connection not found"
          }
        }
      }
    },
    "/session/{sessionId}/connection": {
      "get": {
        "operationId": "listConnections",
        "summary": "List connections in a session",
        "description": "List the connections from an OpenTok session.",
        "tags": ["Connections"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50,
              "maximum": 1000
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of connections",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/session/{sessionId}/stream": {
      "get": {
        "operationId": "listStreams",
        "summary": "Get all streams in a session",
        "description": "Get information about all streams in a session.",
        "tags": ["Streams"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stream information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StreamListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/session/{sessionId}/stream/{streamId}": {
      "get": {
        "operationId": "getStream",
        "summary": "Get stream information",
        "description": "Get information about a specific stream in a session.",
        "tags": ["Streams"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stream information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Stream"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/session/{sessionId}/stream/{streamId}/mute": {
      "post": {
        "operationId": "muteStream",
        "summary": "Mute a stream",
        "description": "Force a specific stream to mute its published audio.",
        "tags": ["Streams"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "streamId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stream muted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/session/{sessionId}/mute": {
      "post": {
        "operationId": "muteSession",
        "summary": "Mute or unmute all streams in a session",
        "description": "Force all streams (except excluded ones) in a session to mute published audio, or disable the mute state.",
        "tags": ["Streams"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MuteSessionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session mute state updated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/archive": {
      "post": {
        "operationId": "startArchive",
        "summary": "Start recording an archive",
        "description": "Start recording an archive of an OpenTok session. At least one client must be connected to the session.",
        "tags": ["Archives"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartArchiveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Archive started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Archive"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "get": {
        "operationId": "listArchives",
        "summary": "List archives",
        "description": "List archives for the project.",
        "tags": ["Archives"],
        "parameters": [
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "sessionId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of archives",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArchiveListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/archive/{archiveId}": {
      "get": {
        "operationId": "getArchive",
        "summary": "Get archive info",
        "description": "Get information about an archive.",
        "tags": ["Archives"],
        "parameters": [
          {
            "name": "archiveId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Archive information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Archive"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      },
      "delete": {
        "operationId": "deleteArchive",
        "summary": "Delete an archive",
        "description": "Delete an archive.",
        "tags": ["Archives"],
        "parameters": [
          {
            "name": "archiveId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Archive deleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/archive/{archiveId}/stop": {
      "post": {
        "operationId": "stopArchive",
        "summary": "Stop an archive",
        "description": "Stop recording an archive.",
        "tags": ["Archives"],
        "parameters": [
          {
            "name": "archiveId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Archive stopped",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Archive"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/session/{sessionId}/migrate": {
      "post": {
        "operationId": "migrateSession",
        "summary": "Migrate a session",
        "description": "Migrate a session to a different server. Only possible if no migration is in progress and the session was not created/migrated recently.",
        "tags": ["Sessions"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Migration accepted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "409": {
            "description": "Conflict - migration already in progress or session created/migrated too recently"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "opentokAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-OPENTOK-AUTH",
        "description": "JWT token for authentication. See the OpenTok REST API documentation for JWT generation details."
      }
    },
    "schemas": {
      "CreateSessionRequest": {
        "type": "object",
        "properties": {
          "archiveMode": {
            "type": "string",
            "enum": ["manual", "always"],
            "default": "manual",
            "description": "Whether the session is automatically archived."
          },
          "p2p.preference": {
            "type": "string",
            "enum": ["disabled", "enabled"],
            "description": "Set to 'enabled' for relayed sessions."
          },
          "location": {
            "type": "string",
            "description": "An IP address that the OpenTok servers will use to situate the session in its global network."
          }
        }
      },
      "Session": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "create_dt": {
            "type": "string"
          },
          "media_server_url": {
            "type": "string"
          }
        }
      },
      "SignalRequest": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "The signal type (max 128 bytes)."
          },
          "data": {
            "type": "string",
            "description": "The signal data (max 8 kB)."
          }
        }
      },
      "MuteSessionRequest": {
        "type": "object",
        "required": ["active"],
        "properties": {
          "active": {
            "type": "boolean",
            "description": "Whether to mute streams (true) or disable mute state (false)."
          },
          "excludedStreamIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Stream IDs that should not be muted."
          }
        }
      },
      "StartArchiveRequest": {
        "type": "object",
        "required": ["sessionId"],
        "properties": {
          "sessionId": {
            "type": "string",
            "description": "The session ID to archive."
          },
          "hasAudio": {
            "type": "boolean",
            "default": true
          },
          "hasVideo": {
            "type": "boolean",
            "default": true
          },
          "name": {
            "type": "string",
            "description": "Archive name (max 255 chars)."
          },
          "outputMode": {
            "type": "string",
            "enum": ["composed", "individual"],
            "default": "composed"
          },
          "resolution": {
            "type": "string",
            "enum": ["640x480", "1280x720", "1920x1080", "480x640", "720x1280", "1080x1920"],
            "default": "640x480"
          },
          "streamMode": {
            "type": "string",
            "enum": ["auto", "manual"],
            "default": "auto"
          },
          "layout": {
            "$ref": "#/components/schemas/Layout"
          }
        }
      },
      "Layout": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["bestFit", "custom", "horizontalPresentation", "pip", "verticalPresentation"]
          },
          "stylesheet": {
            "type": "string"
          },
          "screenshareType": {
            "type": "string"
          }
        }
      },
      "Archive": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["started", "paused", "stopped", "uploaded", "available", "deleted", "expired"]
          },
          "name": {
            "type": "string"
          },
          "sessionId": {
            "type": "string"
          },
          "projectId": {
            "type": "integer"
          },
          "createdAt": {
            "type": "integer",
            "description": "Timestamp in milliseconds since Unix epoch."
          },
          "duration": {
            "type": "integer"
          },
          "size": {
            "type": "integer"
          },
          "hasAudio": {
            "type": "boolean"
          },
          "hasVideo": {
            "type": "boolean"
          },
          "outputMode": {
            "type": "string"
          },
          "resolution": {
            "type": "string"
          },
          "streamMode": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ArchiveListResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Archive"
            }
          }
        }
      },
      "Stream": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "videoType": {
            "type": "string",
            "enum": ["camera", "screen", "custom"]
          },
          "name": {
            "type": "string"
          },
          "layoutClassList": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "StreamListResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Stream"
            }
          }
        }
      },
      "ConnectionListResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "projectId": {
            "type": "string"
          },
          "sessionId": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Connection"
            }
          }
        }
      },
      "Connection": {
        "type": "object",
        "properties": {
          "connectionId": {
            "type": "string"
          },
          "createdAt": {
            "type": "integer"
          },
          "connectionState": {
            "type": "string",
            "enum": ["Connecting", "Connected"]
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid credentials",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}
