{
  "openapi": "3.0.3",
  "info": {
    "title": "phpIPAM",
    "version": "v1",
    "description": "phpIPAM REST API for IP address management including sections, subnets, addresses, VLANs, VRFs, devices, and tools.",
    "x-jentic-source-url": "https://phpipam.net/api/api_documentation/"
  },
  "servers": [
    {
      "url": "https://{host}/api/{appName}",
      "variables": {
        "host": {
          "default": "phpipam.example.com",
          "description": "phpIPAM server hostname"
        },
        "appName": {
          "default": "myapp",
          "description": "API application name"
        }
      }
    }
  ],
  "security": [
    { "tokenAuth": [] }
  ],
  "tags": [
    { "name": "Authentication", "description": "User authentication" },
    { "name": "Sections", "description": "Section management" },
    { "name": "Subnets", "description": "Subnet management" },
    { "name": "Addresses", "description": "IP address management" },
    { "name": "VLANs", "description": "VLAN management" },
    { "name": "L2Domains", "description": "L2 domain management" },
    { "name": "VRFs", "description": "VRF management" },
    { "name": "Devices", "description": "Device management" },
    { "name": "Tools", "description": "Tools and utilities" },
    { "name": "Search", "description": "Search operations" },
    { "name": "Prefixes", "description": "Prefix/provisioning" }
  ],
  "paths": {
    "/user/": {
      "post": {
        "operationId": "authenticate",
        "summary": "Authenticate and get token",
        "tags": ["Authentication"],
        "security": [
          { "basicAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer", "example": 200 },
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": { "type": "string" },
                        "expires": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/sections/": {
      "get": {
        "operationId": "listSections",
        "summary": "List all sections",
        "tags": ["Sections"],
        "responses": {
          "200": {
            "description": "List of sections",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createSection",
        "summary": "Create a new section",
        "tags": ["Sections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SectionInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "Section created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "operationId": "updateSection",
        "summary": "Update a section",
        "tags": ["Sections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  { "$ref": "#/components/schemas/SectionInput" },
                  { "type": "object", "required": ["id"], "properties": { "id": { "type": "integer" } } }
                ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Section updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteSection",
        "summary": "Delete a section",
        "tags": ["Sections"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": { "id": { "type": "integer" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Section deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/sections/{id}/": {
      "get": {
        "operationId": "getSection",
        "summary": "Get section by ID",
        "tags": ["Sections"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Section details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/subnets/": {
      "get": {
        "operationId": "listSubnets",
        "summary": "List all subnets",
        "tags": ["Subnets"],
        "responses": {
          "200": { "description": "List of subnets", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createSubnet",
        "summary": "Create a subnet",
        "tags": ["Subnets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SubnetInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "Subnet created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "operationId": "updateSubnet",
        "summary": "Update a subnet",
        "tags": ["Subnets"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  { "$ref": "#/components/schemas/SubnetInput" },
                  { "type": "object", "required": ["id"], "properties": { "id": { "type": "integer" } } }
                ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Subnet updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/subnets/{id}/": {
      "get": {
        "operationId": "getSubnet",
        "summary": "Get subnet by ID",
        "tags": ["Subnets"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Subnet details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteSubnet",
        "summary": "Delete a subnet",
        "tags": ["Subnets"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Subnet deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/subnets/{id}/usage/": {
      "get": {
        "operationId": "getSubnetUsage",
        "summary": "Get subnet usage statistics",
        "tags": ["Subnets"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Subnet usage data", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/subnets/{id}/addresses/": {
      "get": {
        "operationId": "listSubnetAddresses",
        "summary": "List addresses in subnet",
        "tags": ["Subnets"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Addresses in subnet", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/subnets/{id}/first_free/": {
      "get": {
        "operationId": "getFirstFreeSubnetAddress",
        "summary": "Get first available IP in subnet",
        "tags": ["Subnets"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "First free IP", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/subnets/cidr/{subnet}/": {
      "get": {
        "operationId": "searchSubnetByCidr",
        "summary": "Search subnet by CIDR notation",
        "tags": ["Subnets"],
        "parameters": [
          {
            "name": "subnet",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "CIDR notation (e.g., 10.0.0.0/24)"
          }
        ],
        "responses": {
          "200": { "description": "Matching subnets", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/addresses/{id}/": {
      "get": {
        "operationId": "getAddress",
        "summary": "Get address by ID",
        "tags": ["Addresses"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Address details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "operationId": "updateAddress",
        "summary": "Update an address",
        "tags": ["Addresses"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddressInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Address updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteAddress",
        "summary": "Delete an address",
        "tags": ["Addresses"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" },
          {
            "name": "remove_dns",
            "in": "query",
            "schema": { "type": "boolean" },
            "description": "Also remove DNS record"
          }
        ],
        "responses": {
          "200": { "description": "Address deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/addresses/": {
      "post": {
        "operationId": "createAddress",
        "summary": "Create an IP address",
        "tags": ["Addresses"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddressInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "Address created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/addresses/all/": {
      "get": {
        "operationId": "listAllAddresses",
        "summary": "Get all addresses",
        "tags": ["Addresses"],
        "responses": {
          "200": { "description": "All addresses", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/addresses/search/{ip}/": {
      "get": {
        "operationId": "searchAddress",
        "summary": "Search for address by IP",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "ip",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/addresses/search_hostname/{hostname}/": {
      "get": {
        "operationId": "searchAddressByHostname",
        "summary": "Search address by hostname",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "hostname",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/addresses/search_mac/{mac}/": {
      "get": {
        "operationId": "searchAddressByMac",
        "summary": "Search address by MAC address",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "mac",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/addresses/first_free/{subnetId}/": {
      "get": {
        "operationId": "getFirstFreeAddress",
        "summary": "Get first available IP in subnet",
        "tags": ["Addresses"],
        "parameters": [
          {
            "name": "subnetId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "First free IP", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/vlan/": {
      "get": {
        "operationId": "listVlans",
        "summary": "List all VLANs",
        "tags": ["VLANs"],
        "responses": {
          "200": { "description": "List of VLANs", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createVlan",
        "summary": "Create a VLAN",
        "tags": ["VLANs"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/VlanInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "VLAN created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "operationId": "updateVlan",
        "summary": "Update a VLAN",
        "tags": ["VLANs"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "allOf": [
                  { "$ref": "#/components/schemas/VlanInput" },
                  { "type": "object", "required": ["id"], "properties": { "id": { "type": "integer" } } }
                ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "VLAN updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "operationId": "deleteVlan",
        "summary": "Delete a VLAN",
        "tags": ["VLANs"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": { "id": { "type": "integer" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "VLAN deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/vlan/{id}/": {
      "get": {
        "operationId": "getVlan",
        "summary": "Get VLAN by ID",
        "tags": ["VLANs"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "VLAN details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/vlan/{id}/subnets/": {
      "get": {
        "operationId": "listVlanSubnets",
        "summary": "List subnets in VLAN",
        "tags": ["VLANs"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "VLAN subnets", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/l2domains/": {
      "get": {
        "operationId": "listL2Domains",
        "summary": "List all L2 domains",
        "tags": ["L2Domains"],
        "responses": {
          "200": { "description": "List of L2 domains", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createL2Domain",
        "summary": "Create an L2 domain",
        "tags": ["L2Domains"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "L2 domain created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/l2domains/{id}/": {
      "get": {
        "operationId": "getL2Domain",
        "summary": "Get L2 domain by ID",
        "tags": ["L2Domains"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "L2 domain details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/vrf/": {
      "get": {
        "operationId": "listVrfs",
        "summary": "List all VRFs",
        "tags": ["VRFs"],
        "responses": {
          "200": { "description": "List of VRFs", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createVrf",
        "summary": "Create a VRF",
        "tags": ["VRFs"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/VrfInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "VRF created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/vrf/{id}/": {
      "get": {
        "operationId": "getVrf",
        "summary": "Get VRF by ID",
        "tags": ["VRFs"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "VRF details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/vrf/{id}/subnets/": {
      "get": {
        "operationId": "listVrfSubnets",
        "summary": "List subnets in VRF",
        "tags": ["VRFs"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "VRF subnets", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/devices/": {
      "get": {
        "operationId": "listDevices",
        "summary": "List all devices",
        "tags": ["Devices"],
        "responses": {
          "200": { "description": "List of devices", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createDevice",
        "summary": "Create a device",
        "tags": ["Devices"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeviceInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "Device created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/devices/{id}/": {
      "get": {
        "operationId": "getDevice",
        "summary": "Get device by ID",
        "tags": ["Devices"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Device details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/devices/{id}/subnets/": {
      "get": {
        "operationId": "listDeviceSubnets",
        "summary": "List subnets for device",
        "tags": ["Devices"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Device subnets", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/devices/{id}/addresses/": {
      "get": {
        "operationId": "listDeviceAddresses",
        "summary": "List addresses for device",
        "tags": ["Devices"],
        "parameters": [
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Device addresses", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tools/{subcontroller}/": {
      "get": {
        "operationId": "listToolObjects",
        "summary": "List all objects of a tool type",
        "tags": ["Tools"],
        "parameters": [
          {
            "name": "subcontroller",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["tags", "devices", "device_types", "vlans", "vrfs", "nameservers", "scanagents", "locations", "nat", "racks"]
            }
          }
        ],
        "responses": {
          "200": { "description": "List of objects", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createToolObject",
        "summary": "Create a tool object",
        "tags": ["Tools"],
        "parameters": [
          {
            "name": "subcontroller",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["tags", "devices", "device_types", "vlans", "vrfs", "nameservers", "scanagents", "locations", "nat", "racks"]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object" }
            }
          }
        },
        "responses": {
          "201": { "description": "Object created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tools/{subcontroller}/{id}/": {
      "get": {
        "operationId": "getToolObject",
        "summary": "Get tool object by ID",
        "tags": ["Tools"],
        "parameters": [
          {
            "name": "subcontroller",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/ResourceId" }
        ],
        "responses": {
          "200": { "description": "Object details", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/search/{searchString}/": {
      "get": {
        "operationId": "search",
        "summary": "Search across database",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "searchString",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Search results", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/prefix/{customerType}/": {
      "get": {
        "operationId": "listPrefixes",
        "summary": "Get provisioning subnets",
        "tags": ["Prefixes"],
        "parameters": [
          {
            "name": "customerType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Provisioning subnets", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/prefix/{customerType}/{addressType}/{mask}/": {
      "get": {
        "operationId": "getFirstAvailablePrefix",
        "summary": "Get first available subnet with mask",
        "tags": ["Prefixes"],
        "parameters": [
          {
            "name": "customerType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "addressType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "mask",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "First available subnet", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createFirstAvailablePrefix",
        "summary": "Create first available subnet with mask",
        "tags": ["Prefixes"],
        "parameters": [
          {
            "name": "customerType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "addressType",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "mask",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "201": { "description": "Subnet created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ApiResponse" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "phpipam-token",
        "description": "Token obtained from POST /user/ authentication"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    },
    "parameters": {
      "ResourceId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" }
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "success": { "type": "boolean" },
          "data": {},
          "message": { "type": "string" }
        }
      },
      "SectionInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "masterSection": { "type": "integer" },
          "permissions": { "type": "string", "description": "JSON-encoded permissions" },
          "strictMode": { "type": "boolean" },
          "subnetOrdering": { "type": "string" },
          "showVLAN": { "type": "boolean" },
          "showVRF": { "type": "boolean" },
          "DNS": { "type": "string" }
        }
      },
      "SubnetInput": {
        "type": "object",
        "required": ["subnet", "mask", "sectionId"],
        "properties": {
          "subnet": { "type": "string" },
          "mask": { "type": "integer" },
          "sectionId": { "type": "integer" },
          "description": { "type": "string" },
          "vlanId": { "type": "integer" },
          "vrfId": { "type": "integer" },
          "masterSubnetId": { "type": "integer" },
          "linked_subnet": { "type": "integer" },
          "permissions": { "type": "string" },
          "DNSrecursive": { "type": "boolean" },
          "allowRequests": { "type": "boolean" },
          "state": { "type": "integer" },
          "threshold": { "type": "integer" }
        }
      },
      "AddressInput": {
        "type": "object",
        "required": ["subnetId", "ip"],
        "properties": {
          "subnetId": { "type": "integer" },
          "ip": { "type": "string" },
          "is_gateway": { "type": "boolean" },
          "hostname": { "type": "string" },
          "mac": { "type": "string" },
          "owner": { "type": "string" },
          "tag": { "type": "integer" },
          "PTRignore": { "type": "boolean" },
          "deviceId": { "type": "integer" },
          "description": { "type": "string" },
          "note": { "type": "string" },
          "excludePing": { "type": "boolean" }
        }
      },
      "VlanInput": {
        "type": "object",
        "required": ["name", "number"],
        "properties": {
          "domainId": { "type": "integer" },
          "name": { "type": "string" },
          "number": { "type": "integer" },
          "description": { "type": "string" }
        }
      },
      "VrfInput": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "rd": { "type": "string", "description": "Route distinguisher" },
          "description": { "type": "string" },
          "sections": { "type": "string" }
        }
      },
      "DeviceInput": {
        "type": "object",
        "required": ["hostname"],
        "properties": {
          "hostname": { "type": "string" },
          "ip_addr": { "type": "string" },
          "description": { "type": "string" },
          "sections": { "type": "string" },
          "rack": { "type": "integer" },
          "location": { "type": "integer" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiResponse" }
          }
        }
      }
    }
  }
}