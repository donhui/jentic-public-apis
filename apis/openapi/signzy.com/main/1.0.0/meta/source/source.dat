{
  "openapi": "3.0.3",
  "info": {
    "title": "Signzy API",
    "version": "1.0.0",
    "description": "Signzy API provides digital identity verification and video KYC (Know Your Customer) services. It supports user authentication, video KYC session management, identity document verification, and real-time verification workflows.",
    "x-jentic-source-url": "https://docs.signzy.com/vkyc/login-api"
  },
  "servers": [
    {
      "url": "https://api.signzy.com/api/v3"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate user",
        "description": "Authenticates a user and returns an access token for subsequent API calls.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid credentials format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/vkyc/session": {
      "post": {
        "operationId": "createVkycSession",
        "summary": "Create a video KYC session",
        "description": "Creates a new video KYC session for identity verification of a customer.",
        "tags": ["Video KYC"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateVkycSessionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "VKYC session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VkycSession"
                }
              }
            }
          },
          "400": {
            "description": "Invalid session parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/vkyc/session/{sessionId}": {
      "get": {
        "operationId": "getVkycSession",
        "summary": "Get VKYC session status",
        "description": "Retrieves the current status and details of a video KYC session.",
        "tags": ["Video KYC"],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "description": "Unique VKYC session identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VkycSession"
                }
              }
            }
          },
          "400": {
            "description": "Invalid session ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/identity/verify": {
      "post": {
        "operationId": "verifyIdentity",
        "summary": "Verify identity document",
        "description": "Verifies an identity document such as Aadhaar, PAN card, or passport.",
        "tags": ["Identity Verification"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IdentityVerifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationResult"
                }
              }
            }
          },
          "400": {
            "description": "Invalid document data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/esign/init": {
      "post": {
        "operationId": "initEsign",
        "summary": "Initialize e-signature",
        "description": "Initializes an electronic signature workflow for document signing.",
        "tags": ["E-Signature"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EsignInitRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "E-sign session initialized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EsignSession"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Account username or email"
          },
          "password": {
            "type": "string",
            "description": "Account password"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "accessToken": {
            "type": "string",
            "description": "JWT access token for API authentication"
          },
          "userId": {
            "type": "string",
            "description": "Unique user identifier"
          }
        }
      },
      "CreateVkycSessionRequest": {
        "type": "object",
        "required": ["customerName", "customerPhone"],
        "properties": {
          "customerName": {
            "type": "string",
            "description": "Full name of the customer"
          },
          "customerPhone": {
            "type": "string",
            "description": "Customer phone number"
          },
          "customerEmail": {
            "type": "string",
            "format": "email",
            "description": "Customer email address"
          },
          "callbackUrl": {
            "type": "string",
            "format": "uri",
            "description": "Webhook URL for session status updates"
          }
        }
      },
      "VkycSession": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "description": "Unique session identifier"
          },
          "status": {
            "type": "string",
            "enum": ["created", "in_progress", "completed", "failed", "expired"],
            "description": "Current session status"
          },
          "sessionUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL for the customer to join the VKYC session"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "result": {
            "$ref": "#/components/schemas/VerificationResult"
          }
        }
      },
      "IdentityVerifyRequest": {
        "type": "object",
        "required": ["documentType", "documentNumber"],
        "properties": {
          "documentType": {
            "type": "string",
            "enum": ["aadhaar", "pan", "passport", "voter_id", "driving_license"],
            "description": "Type of identity document"
          },
          "documentNumber": {
            "type": "string",
            "description": "Document number to verify"
          },
          "name": {
            "type": "string",
            "description": "Name on the document for matching"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "Date of birth for matching"
          }
        }
      },
      "VerificationResult": {
        "type": "object",
        "properties": {
          "verified": {
            "type": "boolean",
            "description": "Whether the verification was successful"
          },
          "score": {
            "type": "number",
            "description": "Confidence score of the verification"
          },
          "details": {
            "type": "object",
            "additionalProperties": true,
            "description": "Additional verification details"
          }
        }
      },
      "EsignInitRequest": {
        "type": "object",
        "required": ["documentUrl", "signerName", "signerEmail"],
        "properties": {
          "documentUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL of the document to be signed"
          },
          "signerName": {
            "type": "string"
          },
          "signerEmail": {
            "type": "string",
            "format": "email"
          },
          "callbackUrl": {
            "type": "string",
            "format": "uri",
            "description": "Webhook URL for signing status updates"
          }
        }
      },
      "EsignSession": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "signingUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL for the signer to sign the document"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "signed", "expired"]
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "statusCode": {
            "type": "integer"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token obtained from the login endpoint"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}