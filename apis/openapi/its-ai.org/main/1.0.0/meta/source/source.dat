{
  "openapi": "3.0.3",
  "info": {
    "title": "It's AI - AI Text Detection API",
    "description": "API for detecting AI-generated text. Provides single text analysis and batch analysis endpoints with optional deep scan for word-level segmentation scores.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.its-ai.org/"
  },
  "servers": [
    {
      "url": "https://api.its-ai.org",
      "description": "It's AI Production API"
    }
  ],
  "tags": [
    {
      "name": "Text Analysis",
      "description": "Analyze text for AI-generated content detection"
    }
  ],
  "paths": {
    "/api/text": {
      "post": {
        "operationId": "analyzeText",
        "summary": "Analyze a single text",
        "description": "Analyze a single piece of text and estimate the likelihood that it was generated by AI. Optionally enable deep_scan for word-level segmentation scores.",
        "tags": ["Text Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyzeTextRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful analysis",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyzeTextResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid or missing parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/batch/": {
      "post": {
        "operationId": "analyzeBatch",
        "summary": "Analyze a batch of texts",
        "description": "Analyze multiple texts in a single request. Each text is evaluated individually with the same length limits as the single-scan endpoint. Returns results preserving the order of input texts.",
        "tags": ["Text Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyzeBatchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful batch analysis",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyzeBatchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid or missing parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyBody": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key passed in the request body. Obtain from https://app.its-ai.org/main/api/table"
      }
    },
    "schemas": {
      "AnalyzeTextRequest": {
        "type": "object",
        "required": ["text", "api_key"],
        "properties": {
          "text": {
            "type": "string",
            "description": "The text to analyze for AI-generated content"
          },
          "api_key": {
            "type": "string",
            "description": "Your personal API key from https://app.its-ai.org/main/api/table"
          },
          "deep_scan": {
            "type": "boolean",
            "default": false,
            "description": "When false (default), returns only the overall AI-generation score. When true, also returns per-word segmentation scores."
          }
        }
      },
      "AnalyzeTextResponse": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 1,
            "description": "Probability that the text was generated by AI. 0 = highly likely human, 1 = highly likely AI."
          },
          "segmentation_tokens": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "float",
              "minimum": 0,
              "maximum": 1
            },
            "nullable": true,
            "description": "Per-word scores showing AI influence. Only returned when deep_scan is true. 0 = no influence (human-like), 1 = strong influence (AI-like)."
          }
        }
      },
      "AnalyzeBatchRequest": {
        "type": "object",
        "required": ["texts", "api_key"],
        "properties": {
          "texts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of texts to analyze. Each element must be a UTF-8 string."
          },
          "api_key": {
            "type": "string",
            "description": "Your personal API key from https://app.its-ai.org/main/api/table"
          },
          "deep_scan": {
            "type": "boolean",
            "default": false,
            "description": "When false (default), each result contains only the overall score. When true, includes word-level segmentation scores."
          }
        }
      },
      "AnalyzeBatchResponse": {
        "type": "object",
        "properties": {
          "answer": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BatchResultItem"
            },
            "description": "One element per input text, preserving order."
          }
        }
      },
      "BatchResultItem": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "The original text as received"
          },
          "answer": {
            "type": "number",
            "format": "float",
            "minimum": 0,
            "maximum": 1,
            "description": "Probability that the text was generated by AI"
          },
          "segmentation_tokens": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "float"
            },
            "nullable": true,
            "description": "Word-level scores (0-1), returned only when deep_scan is true"
          },
          "deep_scan": {
            "type": "boolean",
            "description": "Echoes the deep_scan flag that was applied"
          },
          "error": {
            "type": "string",
            "nullable": true,
            "description": "Null on success, or an error message"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    }
  }
}