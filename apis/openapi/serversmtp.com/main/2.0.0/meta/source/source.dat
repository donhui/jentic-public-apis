{
  "openapi": "3.0.3",
  "info": {
    "title": "TurboSMTP Public APIs",
    "version": "2.0.0",
    "description": "TurboSMTP is a professional SMTP service for reliable, secure email and newsletter delivery. This API provides endpoints for sending emails, managing suppressions, email validation, sub-account management, and more.",
    "contact": {
      "email": "api@turbo-smtp.com"
    },
    "x-jentic-source-url": "https://serversmtp.com/turbo-api/"
  },
  "servers": [
    { "url": "https://pro.api.serversmtp.com/api/v2", "description": "Production" },
    { "url": "https://api.turbo-smtp.com/api/v2", "description": "Send Production" },
    { "url": "https://api.eu.turbo-smtp.com/api/v2", "description": "Send EU Production" }
  ],
  "security": [
    { "ApiKeyAuth": [] }
  ],
  "tags": [
    { "name": "Authentication", "description": "Login, logout, password management" },
    { "name": "Mail", "description": "Email sending operations" },
    { "name": "Suppressions", "description": "Managing suppressed email addresses" },
    { "name": "Meta", "description": "Metadata endpoints (countries, states)" },
    { "name": "Billing", "description": "Credit and subscription management" },
    { "name": "EmailValidator", "description": "Email validation features" },
    { "name": "Subaccounts", "description": "Sub-account management" }
  ],
  "paths": {
    "/authorize": {
      "post": {
        "operationId": "authorize",
        "summary": "Login and get authorization token",
        "description": "Authenticate with email and password to receive an authorization token for subsequent API calls.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthorizeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthorizeResponse" }
              }
            }
          },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Invalid credentials.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/deauthorize": {
      "post": {
        "operationId": "deauthorize",
        "summary": "Logout and invalidate token",
        "description": "Invalidate the current authorization token.",
        "tags": ["Authentication"],
        "responses": {
          "200": { "description": "Token invalidated successfully.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/change-password": {
      "put": {
        "operationId": "changePassword",
        "summary": "Change account password",
        "description": "Change the password for the authenticated account.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "old_password": { "type": "string" },
                  "new_password": { "type": "string" }
                },
                "required": ["old_password", "new_password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password changed.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/forgot-password": {
      "get": {
        "operationId": "checkForgotPasswordToken",
        "summary": "Check forgot password token",
        "description": "Verify a forgot password token.",
        "tags": ["Authentication"],
        "parameters": [
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Token valid.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Invalid token.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "requestForgotPassword",
        "summary": "Request forgot password email",
        "description": "Send a forgot password email with reset token.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Reset email sent.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "resetPassword",
        "summary": "Reset password with token",
        "description": "Reset password using the token received via email.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": { "type": "string" },
                  "new_password": { "type": "string" }
                },
                "required": ["token", "new_password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/mail/send": {
      "post": {
        "operationId": "sendEmail",
        "summary": "Send an email",
        "description": "Send an email message through turboSMTP.",
        "tags": ["Mail"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SendEmailRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Email sent successfully.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SendEmailResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/suppressions": {
      "get": {
        "operationId": "listSuppressions",
        "summary": "List suppressed email addresses",
        "description": "Retrieve a list of suppressed email addresses.",
        "tags": ["Suppressions"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Suppressions retrieved.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuppressionsListResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "addSuppression",
        "summary": "Add a suppressed email address",
        "description": "Add an email address to the suppression list.",
        "tags": ["Suppressions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "reason": { "type": "string" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Suppression added.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/suppressions/import": {
      "post": {
        "operationId": "importSuppressions",
        "summary": "Import suppressions from JSON",
        "description": "Bulk import suppressed email addresses.",
        "tags": ["Suppressions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "emails": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Suppressions imported.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/suppressions/csv": {
      "get": {
        "operationId": "exportSuppressionsAsCsv",
        "summary": "Export suppressions as CSV",
        "description": "Download suppressed email addresses as a CSV file.",
        "tags": ["Suppressions"],
        "responses": {
          "200": { "description": "CSV file.", "content": { "text/csv": { "schema": { "type": "string" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "importSuppressionsFromCsv",
        "summary": "Import suppressions from CSV",
        "description": "Upload a CSV file of email addresses to suppress.",
        "tags": ["Suppressions"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Suppressions imported.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/suppressions/bulk_delete": {
      "post": {
        "operationId": "bulkDeleteSuppressions",
        "summary": "Bulk delete suppressions",
        "description": "Delete multiple email addresses from the suppression list.",
        "tags": ["Suppressions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "emails": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Suppressions deleted.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/suppressions/delete": {
      "post": {
        "operationId": "deleteSuppression",
        "summary": "Delete a suppression",
        "description": "Remove a single email address from the suppression list.",
        "tags": ["Suppressions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Suppression deleted.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/meta/countries": {
      "get": {
        "operationId": "listCountries",
        "summary": "List countries",
        "description": "Retrieve a list of available countries.",
        "tags": ["Meta"],
        "responses": {
          "200": { "description": "Countries list.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CountryListResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/meta/state/{isoCode}": {
      "get": {
        "operationId": "listStatesByCountry",
        "summary": "List states by country",
        "description": "Retrieve a list of states for a given country ISO code.",
        "tags": ["Meta"],
        "parameters": [
          { "name": "isoCode", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Country ISO code." }
        ],
        "responses": {
          "200": { "description": "States list.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StateListResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/billing/buy_emailvalidation_credits": {
      "post": {
        "operationId": "buyEmailValidationCredits",
        "summary": "Buy email validation credits",
        "description": "Purchase email validation credits for the account.",
        "tags": ["Billing"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "quantity": { "type": "integer" }
                },
                "required": ["quantity"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Credits purchased.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/emailvalidation/subscription": {
      "get": {
        "operationId": "getEmailValidationSubscription",
        "summary": "Get email validation subscription",
        "description": "Retrieve the current email validation subscription details.",
        "tags": ["EmailValidator"],
        "responses": {
          "200": { "description": "Subscription details.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailValidationSubscriptionResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/emailvalidation/upload": {
      "post": {
        "operationId": "uploadEmailValidationList",
        "summary": "Upload email validation list",
        "description": "Upload a file containing email addresses for validation.",
        "tags": ["EmailValidator"],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "List uploaded.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailValidationUploadResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/emailvalidation/lists": {
      "get": {
        "operationId": "listEmailValidationLists",
        "summary": "List email validation lists",
        "description": "Retrieve all uploaded email validation lists.",
        "tags": ["EmailValidator"],
        "responses": {
          "200": { "description": "Lists retrieved.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailValidationListsResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/emailvalidation/lists/{Id}": {
      "get": {
        "operationId": "getEmailValidationList",
        "summary": "Get email validation list details",
        "description": "Retrieve details of a specific email validation list.",
        "tags": ["EmailValidator"],
        "parameters": [
          { "name": "Id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List details.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailValidationListDetailResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteEmailValidationList",
        "summary": "Delete email validation list",
        "description": "Delete a specific email validation list.",
        "tags": ["EmailValidator"],
        "parameters": [
          { "name": "Id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List deleted.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/emailvalidation/lists/{Id}/validate": {
      "post": {
        "operationId": "validateEmailList",
        "summary": "Validate email list",
        "description": "Start validation of a previously uploaded email list.",
        "tags": ["EmailValidator"],
        "parameters": [
          { "name": "Id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Validation started.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MessageResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/emailvalidation/lists/{Id}/emails": {
      "get": {
        "operationId": "listEmailsInValidationList",
        "summary": "List emails in validation list",
        "description": "Retrieve all emails in a specific validation list.",
        "tags": ["EmailValidator"],
        "parameters": [
          { "name": "Id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Emails retrieved.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailValidationEmailsResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/emailvalidation/lists/{Id}/emails/{emailId}": {
      "get": {
        "operationId": "getEmailValidationResult",
        "summary": "Get single email validation result",
        "description": "Retrieve the validation result for a specific email.",
        "tags": ["EmailValidator"],
        "parameters": [
          { "name": "Id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "emailId", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Validation result.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailValidationResultResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/emailvalidation/lists/{Id}/csv": {
      "get": {
        "operationId": "downloadEmailValidationCsv",
        "summary": "Download validation results as CSV",
        "description": "Download the validation results of a list as a CSV file.",
        "tags": ["EmailValidator"],
        "parameters": [
          { "name": "Id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "CSV file.", "content": { "text/csv": { "schema": { "type": "string" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/emailvalidation/validateEmail": {
      "post": {
        "operationId": "validateSingleEmail",
        "summary": "Validate a single email address",
        "description": "Validate a single email address in real-time.",
        "tags": ["EmailValidator"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Validation result.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EmailValidationResultResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/subaccounts/list": {
      "get": {
        "operationId": "listSubaccounts",
        "summary": "List sub-accounts",
        "description": "Retrieve a list of all sub-accounts.",
        "tags": ["Subaccounts"],
        "responses": {
          "200": { "description": "Sub-accounts retrieved.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SubaccountListResponse" } } } },
          "400": { "description": "Bad request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/subaccounts/email-exists": {
      "get": {
        "operationId": "checkSubaccountEmailExists",
        "summary": "Check if sub-account email exists",
