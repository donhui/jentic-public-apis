{
  "openapi": "3.0.0",
  "info": {
    "title": "Aero Paquetes",
    "description": "Aero-Packs es la aplicacion donde Aero S.R.L ofrece todos sus servicios en un único servicio integral.\n\nEste documento debe utilizarse como referencia para utilizar la API de AeroPaquetes.\nSe necesitan credenciales de acceso para el uso de la misma.\n",
    "version": "1.7.2",
    "contact": {
      "email": "jonatan.sivori@aerolaplata.com.ar"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/jsivori/Aero-Packs/1.7.2/swagger.json"
  },
  "servers": [
    {
      "description": "Staging Instance",
      "url": "https://paquetes.staging.aero.tur.ar"
    }
  ],
  "paths": {
    "/api/packages/find_with_params": {
      "post": {
        "tags": [
          "Find with parameters"
        ],
        "summary": "Búqueda de salidas con parámetros puntuales opcionales.",
        "description": "Obtiene la información de las salidas que se corresponden con los parámetros enviados, algunos de estos son opcionales y otros no. En caso de no querer enviar un parametro, obviarlo en el cuerpo. 'visible' es un ejemplo de este tipo de parametro opcional.\n\nEste suele ser el endpoint de entrada para la opcion de volcado de datos o consumo de la API, para obtener posteriormente el identificador único de la salida.          \n",
        "operationId": "find_with_parameters",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindWithParamsData"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardPackageItems"
          },
          "400": {
            "$ref": "#/components/responses/StandardError"
          }
        }
      }
    },
    "/api/packages/{id}": {
      "get": {
        "tags": [
          "Find"
        ],
        "summary": "Búqueda puntual de una salida por identificador único.",
        "description": "Obtiene información de una salida puntual, indistintamente si esta disponible, visible o vencida.\n",
        "operationId": "searchPackage",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardPackageItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardError"
          },
          "404": {
            "$ref": "#/components/responses/StandardNotFoundError"
          }
        }
      }
    },
    "/api/packages/{id}/availability": {
      "get": {
        "tags": [
          "Availability"
        ],
        "summary": "Consulta de disponibilidad de una salida.",
        "description": "Este endpoint consulta por la disponibilidad de una salida. \n\nInternamente previo a dar una respuesta actualiza claves internas, precios y disponibilidad de la salida y sus servicios para asegurar la fiabilidad de la misma.\n",
        "operationId": "availability",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardAvailableResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundError"
          }
        }
      }
    },
    "/api/packages/{id}/other_bases": {
      "get": {
        "tags": [
          "Other Bases"
        ],
        "summary": "Alternativas a una salida puntual.",
        "description": "Basándose en una salida puntual por medio de su identificador único, este endpoint nos devuelve otra salidas que esten relacionadas a la misma de acuerdo a la base en la que la salida esta creada, entiéndase por SGL, DBL, TPL, etc.\n",
        "operationId": "other_bases",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardOtherResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundError"
          }
        }
      }
    },
    "/api/packages/{id}/other_options": {
      "get": {
        "tags": [
          "Other options"
        ],
        "summary": "Alternativas a una salida puntual.",
        "description": "Basándose en una salida puntual por medio de su identificador único, este endpoint nos devuelve otra salidas que esten relacionadas a la misma de acuerdo a los destinos o lugares y cupos aéreos.\n",
        "operationId": "other_options_id",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardOtherResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundError"
          }
        }
      }
    },
    "/api/packages/{id}/get_price_info": {
      "get": {
        "tags": [
          "Get Price Info"
        ],
        "summary": "Preliquidacion de la salida puntual.",
        "description": "Obtiene los valores puntuales de liquidacion y costo de una salida con un formato solicitado detallado.\n\nEs importante mencionar que con este endpoint se puede cotizar para adultos y niños y con ello validar la distribucion valida de la salida.\n",
        "operationId": "getPriceInfo",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          },
          {
            "$ref": "#/components/parameters/requestChildParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/PricePackageItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardError"
          }
        }
      }
    },
    "/api/packages/{id}/reserve": {
      "post": {
        "tags": [
          "Reserve"
        ],
        "summary": "Genera una reserva.",
        "description": "Este endpoint crea la reserva con los servicios en el sistema backend. \n\nEntre los parameteros que recibe controla que la salida este disponible para la venta y hace un chequeo simple de DNI de pasajeros y/o existencia de cupo tomado para el mismo.\n",
        "operationId": "reserve",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "booking_params"
                ],
                "properties": {
                  "booking_params": {
                    "$ref": "#/components/schemas/BookingDataParam"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/ReserveResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundReserveError"
          }
        }
      }
    },
    "/api/packages/reserve_to_cancel": {
      "get": {
        "tags": [
          "Cancel reserve"
        ],
        "summary": "Cancelar una reserva.",
        "description": "Este endpoint envía un mail al vendedor u operativo asociado a la reserva para solicitar la cancelación de la misma asociada a una salida. El id_reserve debe corresponderse con el ID de reserva del MO.\n\nEs en este punto donde se automatiza el sistema enviando la cancelación de cupos aereos al sistema de cupos, restando la cancelacion de demas servicios con la notificacion pertinente.\n",
        "operationId": "other_options",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestReserveIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/CancelReserveResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundReserveError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "Authorization": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    },
    "schemas": {
      "Date": {
        "type": "string",
        "pattern": "^[0-9]{4}\\-((0[1-9]|1[0-2])){1}-([012][0-9]|3[01])$",
        "example": "2017-10-12"
      },
      "Time": {
        "type": "string",
        "description": "String que representa la clase Time.",
        "pattern": "(?:[01][0-9]|2[0-3]):([0-5][0-9])",
        "example": "20:31"
      },
      "Base": {
        "type": "string",
        "description": "Enumerativo string que representa la base de la salida.",
        "enum": [
          "SGL",
          "DBL",
          "TPL"
        ],
        "example": "DBL"
      },
      "CategoryItem": {
        "description": "Categorización a la que pertenece una salida.",
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre de la categoría.",
            "example": "Sol y Playa"
          }
        }
      },
      "ServiceItem": {
        "description": "Representa a un servicio de Productos Terrestres que forman parte de la salida.",
        "type": "object",
        "required": [
          "detail",
          "service_kind"
        ],
        "properties": {
          "detail": {
            "type": "string",
            "description": "Nombre del servicio",
            "example": "Excursión FD - Día completo  Regular - Chichén Itzá"
          },
          "service_kind": {
            "type": "string",
            "description": "Tipo del servicio.",
            "enum": [
              "admission",
              "excursion",
              "generic",
              "internal aereal",
              "transfer",
              "travel_assistance",
              "visa"
            ],
            "default": "excursion"
          }
        }
      },
      "TransferItem": {
        "description": "Representa a un traslado de Productos Terrestres que forman parte de la salida.",
        "type": "object",
        "required": [
          "detail",
          "service_kind",
          "type",
          "category",
          "from",
          "to"
        ],
        "properties": {
          "detail": {
            "type": "string",
            "description": "Nombre del servicio",
            "example": "Traslado IN Privado (Desde:Aeropuerto Cancún  Hasta:Hotel Cancún)"
          },
          "service_kind": {
            "type": "string",
            "description": "Tipo del servicio.",
            "enum": [
              "admission",
              "excursion",
              "generic",
              "internal aereal",
              "transfer",
              "travel_assistance",
              "visa"
            ],
            "example": "transfer"
          },
          "type": {
            "type": "string",
            "example": "in_out"
          },
          "category": {
            "type": "string",
            "example": "regular"
          },
          "from": {
            "type": "string",
            "example": "Aeropuerto Cancún"
          },
          "to": {
            "type": "string",
            "example": "Hotel Cancún"
          }
        }
      },
      "IATACode": {
        "description": "Codigo de 3 letras que representa univocamente un lugar o aeropuerto.",
        "type": "string",
        "pattern": "^[A-Z]{3}$",
        "example": "CUN"
      },
      "Segment_Leg_Info": {
        "type": "object",
        "required": [
          "origin",
          "destination",
          "departure_date",
          "departure_time",
          "arrival_date",
          "arrival_time",
          "company",
          "flight_number",
          "flight_duration"
        ],
        "properties": {
          "origin": {
            "$ref": "#/components/schemas/IATACode"
          },
          "destination": {
            "$ref": "#/components/schemas/IATACode"
          },
          "departure_date": {
            "$ref": "#/components/schemas/Date"
          },
          "departure_time": {
            "$ref": "#/components/schemas/Time"
          },
          "arrival_date": {
            "$ref": "#/components/schemas/Date"
          },
          "arrival_time": {
            "$ref": "#/components/schemas/Time"
          },
          "company": {
            "type": "string",
            "description": "Compañia.",
            "example": "Aerolineas Argentinas"
          },
          "flight_number": {
            "type": "integer",
            "description": "Numero del vuelo.",
            "example": 8010
          },
          "flight_duration": {
            "$ref": "#/components/schemas/Time"
          }
        }
      },
      "DepartureItem": {
        "description": "Representa una ruta de los cupos aéreos que forman parte de la salida.",
        "type": "object",
        "required": [
          "origin",
          "destination",
          "departure_date",
          "arrival_date",
          "departure_time",
          "arrival_time",
          "fligh_duration",
          "time_between_legs",
          "legs",
          "baggage",
          "baggage_allowed"
        ],
        "properties": {
          "origin": {
            "type": "string",
            "example": "EZE"
          },
          "destination": {
            "type": "string",
            "example": "CUN"
          },
          "departure_date": {
            "$ref": "#/components/schemas/Date"
          },
          "arrival_date": {
            "$ref": "#/components/schemas/Date"
          },
          "departure_time": {
            "$ref": "#/components/schemas/Time"
          },
          "arrival_time": {
            "$ref": "#/components/schemas/Time"
          },
          "fligh_duration": {
            "$ref": "#/components/schemas/Time"
          },
          "time_between_legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Time"
            }
          },
          "legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Segment_Leg_Info"
            }
          },
          "baggage": {
            "type": "number",
            "example": 1
          },
          "baggage_allowed": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "AccomodationItem": {
        "type": "object",
        "description": "Representa datos de la habitacion de hotel de la salida.",
        "required": [
          "name",
          "category_name",
          "service_kind",
          "room_type",
          "stars",
          "regime",
          "check_in",
          "check_out",
          "nights",
          "city_iata"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre del hotel al que pertenece la habitación.",
            "example": "RIU Cancún"
          },
          "category_name": {
            "type": "string",
            "description": "Nombre de la categoría de la habitación dentro del hotel.",
            "example": "Doble Estándar Vista Mar (DBMB)"
          },
          "service_kind": {
            "type": "string",
            "description": "Representa al tipo de servicio, siempre es hotel.",
            "example": "hotel"
          },
          "room_type": {
            "type": "string",
            "description": "Tipo de habitacion de acuerdo a la base de personas.",
            "enum": [
              "single",
              "double",
              "triple",
              "quadruple",
              "apartment"
            ],
            "example": "double"
          },
          "stars": {
            "type": "integer",
            "description": "Cantidad de estrellas del hotel.",
            "enum": [
              1,
              2,
              3,
              4,
              5
            ],
            "example": 4
          },
          "regime": {
            "description": "Regimen de la tarifa del hotel.",
            "type": "string",
            "enum": [
              "Sólo alojamiento",
              "Sólo desayuno",
              "Media pensión",
              "Pensión completa",
              "Todo incluido"
            ],
            "example": "Todo incluido"
          },
          "check_in": {
            "$ref": "#/components/schemas/Date"
          },
          "check_out": {
            "$ref": "#/components/schemas/Date"
          },
          "nights": {
            "type": "integer",
            "description": "Cantidad de noches que se contrata la habitación.",
            "example": 8
          },
          "city_iata": {
            "$ref": "#/components/schemas/IATACode"
          }
        }
      },
      "PlaceItem": {
        "type": "object",
        "description": "Lugar asociado a la salida.",
        "required": [
          "name",
          "country",
          "iata_code"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre del lugar completo.",
            "example": "México, Cancún"
          },
          "country": {
            "type": "string",
            "description": "Nombre del país.",
            "example": "México"
          },
          "iata_code": {
            "$ref": "#/components/schemas/IATACode"
          }
        }
      },
      "ImageItem": {
        "type": "string",
        "description": "URL de donde se obtiene la imagen.",
        "example": "https://aero-tur-dev.s3-sa-east-1.amazonaws.com/cotizador/galleries_packages/58/temp2100720181033.jpg?X-Amz-Expires=600&X-Amz-Date=20180720T152436Z&X-Amz-Algorithm=AWS4-HMAC-SHA256&X-Amz-Credential=AKIAJDOYXBY4JJXICGEA/20180720/sa-east-1/s3/aws4_request&X-Amz-SignedHeaders=host&X-Amz-Signature=ffac7c390ebfd4bcf46006fd1c8bdd3e7b3dbe6c908da41767b3e823609f5cab"
      },
      "RateItem": {
        "type": "object",
        "description": "Precio de la salida en distintas monedas.",
        "required": [
          "ars_value",
          "usd_value",
          "eur_value",
          "gbp_value"
        ],
        "properties": {
          "ars_value": {
            "type": "number",
            "description": "Precio en pesos.",
            "format": "float",
            "example": 90369.46
          },
          "usd_value": {
            "type": "number",
            "description": "Precio en dolares.",
            "format": "float",
            "example": 3250.7
          },
          "eur_value": {
            "type": "number",
            "description": "Precio en libras.",
            "format": "float",
            "example": 2712.17
          },
          "gbp_value": {
            "type": "number",
            "format": "float",
            "example": 2338.63
          }
        }
      },
      "SearchItem": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "available",
          "admit_child",
          "observations",
          "start_date",
          "end_date",
          "base",
          "categories",
          "places",
          "duration",
          "services",
          "departures",
          "accomodation",
          "images",
          "prices",
          "prices_with_markup",
          "related_packages",
          "base_related_packages",
          "other_related_packages"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Salida a Cancún"
          },
          "description": {
            "type": "string",
            "example": "Paquete Masivo N°1 - Cupo LA 19Jul18 8 nts - RIU Cancún - Doble Estándar Vista Mar (DBMB)."
          },
          "available": {
            "type": "boolean",
            "example": true
          },
          "admit_child": {
            "type": "boolean",
            "example": true
          },
          "observations": {
            "type": "string",
            "example": "Salida promocional para Cancun y alrededores."
          },
          "start_date": {
            "$ref": "#/components/schemas/Date"
          },
          "end_date": {
            "$ref": "#/components/schemas/Date"
          },
          "base": {
            "$ref": "#/components/schemas/Base"
          },
          "categories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CategoryItem"
            }
          },
          "places": {
            "type": "object",
            "required": [
              "origin",
              "middle_destinations",
              "destination"
            ],
            "properties": {
              "origin": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PlaceItem"
                }
              },
              "middle_destinations": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PlaceItem"
                }
              },
              "destination": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PlaceItem"
                }
              }
            }
          },
          "duration": {
            "type": "number",
            "format": "integer",
            "example": 8
          },
          "services": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/ServiceItem"
                },
                {
                  "$ref": "#/components/schemas/TransferItem"
                }
              ]
            }
          },
          "departures": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "arrival_flights",
                "departure_flights"
              ],
              "properties": {
                "arrival_flights": {
                  "$ref": "#/components/schemas/DepartureItem"
                },
                "departure_flights": {
                  "$ref": "#/components/schemas/DepartureItem"
                }
              }
            }
          },
          "accomodation": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AccomodationItem"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageItem"
            }
          },
          "prices": {
            "$ref": "#/components/schemas/RateItem"
          },
          "prices_with_markup": {
            "$ref": "#/components/schemas/RateItem"
          },
          "related_packages": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              2,
              3,
              4,
              5,
              6,
              7,
              8
            ]
          },
          "base_related_packages": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              2
            ]
          },
          "other_related_packages": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              3
            ]
          }
        }
      },
      "SearchRelatedItem": {
        "type": "object",
        "required": [
          "id",
          "can_sell",
          "accomodation",
          "images",
          "prices",
          "prices_with_markup"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "can_sell": {
            "type": "boolean",
            "description": "Booleano que determina si la salida puede venderse o no en base a la visibilidad y disponibilidad de la misma.",
            "example": true
          },
          "accomodation": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AccomodationItem"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageItem"
            }
          },
          "prices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RateItem"
            }
          },
          "prices_with_markup": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RateItem"
            }
          }
        }
      },
      "ReserveDataParam": {
        "type": "object",
        "required": [
          "seller_email",
          "agency_id"
        ],
        "properties": {
          "seller_email": {
            "type": "string",
            "description": "Email del vendedor.",
            "example": "jonatan.sivori@aerolaplata.com.ar"
          },
          "agency_id": {
            "type": "integer",
