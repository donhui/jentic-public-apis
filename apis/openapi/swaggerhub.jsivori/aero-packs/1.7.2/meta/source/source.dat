    "parameters": {
      "Token": {
        "in": "header",
        "name": "token",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Token para uso de API.",
        "example": "teste653b1344d0db791ba3a8f3bb725"
      },
      "requestIdParam": {
        "in": "path",
        "name": "id",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Identificador un\u00edvoco del elemento que se busca.",
        "example": 1
      },
      "requestChildParam": {
        "in": "query",
        "required": false,
        "name": "children_ages[]",
        "schema": {
          "type": "array",
          "items": {
            "type": "number",
            "example": 3
          }
        },
        "description": "Edades de los ni\u00f1os."
      },
      "requestReserveIdParam": {
        "in": "path",
        "name": "reserve_id",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Identificador un\u00edvoco de una reserva.",
        "example": 35048
      }
    }
  },
  "paths": {
    "/api/packages/find_with_params": {
      "post": {
        "tags": [
          "Find with parameters"
        ],
        "summary": "B\u00faqueda de salidas con par\u00e1metros puntuales opcionales.",
        "description": "Obtiene la informaci\u00f3n de las salidas que se corresponden con los par\u00e1metros enviados, algunos de estos son opcionales y otros no. En caso de no querer enviar un parametro, obviarlo en el cuerpo. 'visible' es un ejemplo de este tipo de parametro opcional.\n\nEste suele ser el endpoint de entrada para la opcion de volcado de datos o consumo de la API, para obtener posteriormente el identificador \u00fanico de la salida.          \n",
        "operationId": "find_with_parameters",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FindWithParamsData"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardPackageItems"
          },
          "400": {
            "$ref": "#/components/responses/StandardError"
          }
        }
      }
    },
    "/api/packages/{id}": {
      "get": {
        "tags": [
          "Find"
        ],
        "summary": "B\u00faqueda puntual de una salida por identificador \u00fanico.",
        "description": "Obtiene informaci\u00f3n de una salida puntual, indistintamente si esta disponible, visible o vencida.\n",
        "operationId": "searchPackage",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardPackageItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardError"
          },
          "404": {
            "$ref": "#/components/responses/StandardNotFoundError"
          }
        }
      }
    },
    "/api/packages/{id}/availability": {
      "get": {
        "tags": [
          "Availability"
        ],
        "summary": "Consulta de disponibilidad de una salida.",
        "description": "Este endpoint consulta por la disponibilidad de una salida. \n\nInternamente previo a dar una respuesta actualiza claves internas, precios y disponibilidad de la salida y sus servicios para asegurar la fiabilidad de la misma.\n",
        "operationId": "availability",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardAvailableResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundError"
          }
        }
      }
    },
    "/api/packages/{id}/other_bases": {
      "get": {
        "tags": [
          "Other Bases"
        ],
        "summary": "Alternativas a una salida puntual.",
        "description": "Bas\u00e1ndose en una salida puntual por medio de su identificador \u00fanico, este endpoint nos devuelve otra salidas que esten relacionadas a la misma de acuerdo a la base en la que la salida esta creada, enti\u00e9ndase por SGL, DBL, TPL, etc.\n",
        "operationId": "other_bases",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardOtherResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundError"
          }
        }
      }
    },
    "/api/packages/{id}/other_options": {
      "get": {
        "tags": [
          "Other options"
        ],
        "summary": "Alternativas a una salida puntual.",
        "description": "Bas\u00e1ndose en una salida puntual por medio de su identificador \u00fanico, este endpoint nos devuelve otra salidas que esten relacionadas a la misma de acuerdo a los destinos o lugares y cupos a\u00e9reos.\n",
        "operationId": "other_options_id",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/StandardOtherResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundError"
          }
        }
      }
    },
    "/api/packages/{id}/get_price_info": {
      "get": {
        "tags": [
          "Get Price Info"
        ],
        "summary": "Preliquidacion de la salida puntual.",
        "description": "Obtiene los valores puntuales de liquidacion y costo de una salida con un formato solicitado detallado.\n\nEs importante mencionar que con este endpoint se puede cotizar para adultos y ni\u00f1os y con ello validar la distribucion valida de la salida.\n",
        "operationId": "getPriceInfo",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          },
          {
            "$ref": "#/components/parameters/requestChildParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/PricePackageItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardError"
          }
        }
      }
    },
    "/api/packages/{id}/reserve": {
      "post": {
        "tags": [
          "Reserve"
        ],
        "summary": "Genera una reserva.",
        "description": "Este endpoint crea la reserva con los servicios en el sistema backend. \n\nEntre los parameteros que recibe controla que la salida este disponible para la venta y hace un chequeo simple de DNI de pasajeros y/o existencia de cupo tomado para el mismo.\n",
        "operationId": "reserve",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "booking_params"
                ],
                "properties": {
                  "booking_params": {
                    "$ref": "#/components/schemas/BookingDataParam"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/ReserveResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundReserveError"
          }
        }
      }
    },
    "/api/packages/reserve_to_cancel": {
      "get": {
        "tags": [
          "Cancel reserve"
        ],
        "summary": "Cancelar una reserva.",
        "description": "Este endpoint env\u00eda un mail al vendedor u operativo asociado a la reserva para solicitar la cancelaci\u00f3n de la misma asociada a una salida. El id_reserve debe corresponderse con el ID de reserva del MO.\n\nEs en este punto donde se automatiza el sistema enviando la cancelaci\u00f3n de cupos aereos al sistema de cupos, restando la cancelacion de demas servicios con la notificacion pertinente.\n",
        "operationId": "other_options",
        "parameters": [
          {
            "$ref": "#/components/parameters/requestReserveIdParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/CancelReserveResponseItem"
          },
          "400": {
            "$ref": "#/components/responses/StandardNotFoundReserveError"
          }
        }
      }
    }
  },
  "servers": [
    {
      "description": "Staging Instance",
      "url": "https://paquetes.staging.aero.tur.ar"
    }
  ]
}