{
  "openapi": "3.0.0",
  "externalDocs": {
    "description": "Encuentre mas informaci\u00f3n aqu\u00ed",
    "url": "https://git.aero.tur.ar/jsivori/aero-packs/wikis/swaggerdocs"
  },
  "info": {
    "title": "Aero Paquetes",
    "description": "Aero-Packs es la aplicacion donde Aero S.R.L ofrece todos sus servicios en un \u00fanico servicio integral.\n\nEste documento debe utilizarse como referencia para utilizar la API de AeroPaquetes.\nSe necesitan credenciales de acceso para el uso de la misma.\n",
    "version": "1.7.2",
    "contact": {
      "email": "jonatan.sivori@aerolaplata.com.ar"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/jsivori/Aero-Packs/1.7.2/swagger.json"
  },
  "security": [
    {
      "Authorization": []
    }
  ],
  "components": {
    "securitySchemes": {
      "Authorization": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    },
    "schemas": {
      "Date": {
        "type": "string",
        "pattern": "^[0-9]{4}\\-((0[1-9]|1[0-2])){1}-([012][0-9]|3[01])$",
        "example": "2017-10-12"
      },
      "Time": {
        "type": "string",
        "description": "String que representa la clase Time.",
        "pattern": "(?:[01][0-9]|2[0-3]):([0-5][0-9])",
        "example": "20:31"
      },
      "Base": {
        "type": "string",
        "description": "Enumerativo string que representa la base de la salida.",
        "enum": [
          "SGL",
          "DBL",
          "TPL"
        ],
        "example": "DBL"
      },
      "CategoryItem": {
        "description": "Categorizaci\u00f3n a la que pertenece una salida.",
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre de la categor\u00eda.",
            "example": "Sol y Playa"
          }
        }
      },
      "ServiceItem": {
        "description": "Representa a un servicio de Productos Terrestres que forman parte de la salida.",
        "type": "object",
        "required": [
          "detail",
          "service_kind"
        ],
        "properties": {
          "detail": {
            "type": "string",
            "description": "Nombre del servicio",
            "example": "Excursi\u00f3n FD - D\u00eda completo  Regular - Chich\u00e9n Itz\u00e1"
          },
          "service_kind": {
            "type": "string",
            "description": "Tipo del servicio.",
            "enum": [
              "admission",
              "excursion",
              "generic",
              "internal aereal",
              "transfer",
              "travel_assistance",
              "visa"
            ],
            "default": "excursion"
          }
        }
      },
      "TransferItem": {
        "description": "Representa a un traslado de Productos Terrestres que forman parte de la salida.",
        "type": "object",
        "required": [
          "detail",
          "service_kind",
          "type",
          "category",
          "from",
          "to"
        ],
        "properties": {
          "detail": {
            "type": "string",
            "description": "Nombre del servicio",
            "example": "Traslado IN Privado (Desde:Aeropuerto Canc\u00fan  Hasta:Hotel Canc\u00fan)"
          },
          "service_kind": {
            "type": "string",
            "description": "Tipo del servicio.",
            "enum": [
              "admission",
              "excursion",
              "generic",
              "internal aereal",
              "transfer",
              "travel_assistance",
              "visa"
            ],
            "example": "transfer"
          },
          "type": {
            "type": "string",
            "example": "in_out"
          },
          "category": {
            "type": "string",
            "example": "regular"
          },
          "from": {
            "type": "string",
            "example": "Aeropuerto Canc\u00fan"
          },
          "to": {
            "type": "string",
            "example": "Hotel Canc\u00fan"
          }
        }
      },
      "IATACode": {
        "description": "Codigo de 3 letras que representa univocamente un lugar o aeropuerto.",
        "type": "string",
        "pattern": "^[A-Z]{3}$",
        "example": "CUN"
      },
      "Segment_Leg_Info": {
        "type": "object",
        "required": [
          "origin",
          "destination",
          "departure_date",
          "departure_time",
          "arrival_date",
          "arrival_time",
          "company",
          "flight_number",
          "flight_duration"
        ],
        "properties": {
          "origin": {
            "$ref": "#/components/schemas/IATACode"
          },
          "destination": {
            "$ref": "#/components/schemas/IATACode"
          },
          "departure_date": {
            "$ref": "#/components/schemas/Date"
          },
          "departure_time": {
            "$ref": "#/components/schemas/Time"
          },
          "arrival_date": {
            "$ref": "#/components/schemas/Date"
          },
          "arrival_time": {
            "$ref": "#/components/schemas/Time"
          },
          "company": {
            "type": "string",
            "description": "Compa\u00f1ia.",
            "example": "Aerolineas Argentinas"
          },
          "flight_number": {
            "type": "integer",
            "description": "Numero del vuelo.",
            "example": 8010
          },
          "flight_duration": {
            "$ref": "#/components/schemas/Time"
          }
        }
      },
      "DepartureItem": {
        "description": "Representa una ruta de los cupos a\u00e9reos que forman parte de la salida.",
        "type": "object",
        "required": [
          "origin",
          "destination",
          "departure_date",
          "arrival_date",
          "departure_time",
          "arrival_time",
          "fligh_duration",
          "time_between_legs",
          "legs",
          "baggage",
          "baggage_allowed"
        ],
        "properties": {
          "origin": {
            "type": "string",
            "example": "EZE"
          },
          "destination": {
            "type": "string",
            "example": "CUN"
          },
          "departure_date": {
            "$ref": "#/components/schemas/Date"
          },
          "arrival_date": {
            "$ref": "#/components/schemas/Date"
          },
          "departure_time": {
            "$ref": "#/components/schemas/Time"
          },
          "arrival_time": {
            "$ref": "#/components/schemas/Time"
          },
          "fligh_duration": {
            "$ref": "#/components/schemas/Time"
          },
          "time_between_legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Time"
            }
          },
          "legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Segment_Leg_Info"
            }
          },
          "baggage": {
            "type": "number",
            "example": 1
          },
          "baggage_allowed": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "AccomodationItem": {
        "type": "object",
        "description": "Representa datos de la habitacion de hotel de la salida.",
        "required": [
          "name",
          "category_name",
          "service_kind",
          "room_type",
          "stars",
          "regime",
          "check_in",
          "check_out",
          "nights",
          "city_iata"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre del hotel al que pertenece la habitaci\u00f3n.",
            "example": "RIU Canc\u00fan"
          },
          "category_name": {
            "type": "string",
            "description": "Nombre de la categor\u00eda de la habitaci\u00f3n dentro del hotel.",
            "example": "Doble Est\u00e1ndar Vista Mar (DBMB)"
          },
          "service_kind": {
            "type": "string",
            "description": "Representa al tipo de servicio, siempre es hotel.",
            "example": "hotel"
          },
          "room_type": {
            "type": "string",
            "description": "Tipo de habitacion de acuerdo a la base de personas.",
            "enum": [
              "single",
              "double",
              "triple",
              "quadruple",
              "apartment"
            ],
            "example": "double"
          },
          "stars": {
            "type": "integer",
            "description": "Cantidad de estrellas del hotel.",
            "enum": [
              1,
              2,
              3,
              4,
              5
            ],
            "example": 4
          },
          "regime": {
            "description": "Regimen de la tarifa del hotel.",
            "type": "string",
            "enum": [
              "S\u00f3lo alojamiento",
              "S\u00f3lo desayuno",
              "Media pensi\u00f3n",
              "Pensi\u00f3n completa",
              "Todo incluido"
            ],
            "example": "Todo incluido"
          },
          "check_in": {
            "$ref": "#/components/schemas/Date"
          },
          "check_out": {
            "$ref": "#/components/schemas/Date"
          },
          "nights": {
            "type": "integer",
            "description": "Cantidad de noches que se contrata la habitaci\u00f3n.",
            "example": 8
          },
          "city_iata": {
            "$ref": "#/components/schemas/IATACode"
          }
        }
      },
      "PlaceItem": {
        "type": "object",
        "description": "Lugar asociado a la salida.",
        "required": [
          "name",
          "country",
          "iata_code"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre del lugar completo.",
            "example": "M\u00e9xico, Canc\u00fan"
          },
          "country": {
            "type": "string",
            "description": "Nombre del pa\u00eds.",
            "example": "M\u00e9xico"
          },
          "iata_code": {
            "$ref": "#/components/schemas/IATACode"
          }
        }
      },
      "ImageItem": {
        "type": "string",
        "description": "URL de donde se obtiene la imagen.",
        "example": "https://aero-tur-dev.s3-sa-east-1.amazonaws.com/cotizador/galleries_packages/58/temp2100720181033.jpg?X-Amz-Expires=600&X-Amz-Date=20180720T152436Z&X-Amz-Algorithm=AWS4-HMAC-SHA256&X-Amz-Credential=AKIAJDOYXBY4JJXICGEA/20180720/sa-east-1/s3/aws4_request&X-Amz-SignedHeaders=host&X-Amz-Signature=ffac7c390ebfd4bcf46006fd1c8bdd3e7b3dbe6c908da41767b3e823609f5cab"
      },
      "RateItem": {
        "type": "object",
        "description": "Precio de la salida en distintas monedas.",
        "required": [
          "ars_value",
          "usd_value",
          "eur_value",
          "gbp_value"
        ],
        "properties": {
          "ars_value": {
            "type": "number",
            "description": "Precio en pesos.",
            "format": "float",
            "example": 90369.46
          },
          "usd_value": {
            "type": "number",
            "description": "Precio en dolares.",
            "format": "float",
            "example": 3250.7
          },
          "eur_value": {
            "type": "number",
            "description": "Precio en libras.",
            "format": "float",
            "example": 2712.17
          },
          "gbp_value": {
            "type": "number",
            "format": "float",
            "example": 2338.63
          }
        }
      },
      "SearchItem": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "available",
          "admit_child",
          "observations",
          "start_date",
          "end_date",
          "base",
          "categories",
          "places",
          "duration",
          "services",
          "departures",
          "accomodation",
          "images",
          "prices",
          "prices_with_markup",
          "related_packages",
          "base_related_packages",
          "other_related_packages"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "Salida a Canc\u00fan"
          },
          "description": {
            "type": "string",
            "example": "Paquete Masivo N\u00b01 - Cupo LA 19Jul18 8 nts - RIU Canc\u00fan - Doble Est\u00e1ndar Vista Mar (DBMB)."
          },
          "available": {
            "type": "boolean",
            "example": true
          },
          "admit_child": {
            "type": "boolean",
            "example": true
          },
          "observations": {
            "type": "string",
            "example": "Salida promocional para Cancun y alrededores."
          },
          "start_date": {
            "$ref": "#/components/schemas/Date"
          },
          "end_date": {
            "$ref": "#/components/schemas/Date"
          },
          "base": {
            "$ref": "#/components/schemas/Base"
          },
          "categories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CategoryItem"
            }
          },
          "places": {
            "type": "object",
            "required": [
              "origin",
              "middle_destinations",
              "destination"
            ],
            "properties": {
              "origin": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PlaceItem"
                }
              },
              "middle_destinations": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PlaceItem"
                }
              },
              "destination": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PlaceItem"
                }
              }
            }
          },
          "duration": {
            "type": "number",
            "format": "integer",
            "example": 8
          },
          "services": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/ServiceItem"
                },
                {
                  "$ref": "#/components/schemas/TransferItem"
                }
              ]
            }
          },
          "departures": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "arrival_flights",
                "departure_flights"
              ],
              "properties": {
                "arrival_flights": {
                  "$ref": "#/components/schemas/DepartureItem"
                },
                "departure_flights": {
                  "$ref": "#/components/schemas/DepartureItem"
                }
              }
            }
          },
          "accomodation": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AccomodationItem"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageItem"
            }
          },
          "prices": {
            "$ref": "#/components/schemas/RateItem"
          },
          "prices_with_markup": {
            "$ref": "#/components/schemas/RateItem"
          },
          "related_packages": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              2,
              3,
              4,
              5,
              6,
              7,
              8
            ]
          },
          "base_related_packages": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              2
            ]
          },
          "other_related_packages": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": [
              3
            ]
          }
        }
      },
      "SearchRelatedItem": {
        "type": "object",
        "required": [
          "id",
          "can_sell",
          "accomodation",
          "images",
          "prices",
          "prices_with_markup"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "can_sell": {
            "type": "boolean",
            "description": "Booleano que determina si la salida puede venderse o no en base a la visibilidad y disponibilidad de la misma.",
            "example": true
          },
          "accomodation": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AccomodationItem"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageItem"
            }
          },
          "prices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RateItem"
            }
          },
          "prices_with_markup": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RateItem"
            }
          }
        }
      },
      "ReserveDataParam": {
        "type": "object",
        "required": [
          "seller_email",
          "agency_id"
        ],
        "properties": {
          "seller_email": {
            "type": "string",
            "description": "Email del vendedor.",
            "example": "jonatan.sivori@aerolaplata.com.ar"
          },
          "agency_id": {
            "type": "integer",
            "description": "Identificador \u00fanico de una agencia.",
            "example": 180
          }
        }
      },
      "PassengerDataParam": {
        "type": "object",
        "required": [
          "first_name",
          "last_name",
          "document_type",
          "document_number",
          "birthdate"
        ],
        "properties": {
          "first_name": {
            "type": "string",
            "description": "Nombre del pasajero.",
            "example": "Nombre"
          },
          "last_name": {
            "type": "string",
            "description": "Apellido del pasajero.",
            "example": "Apellido"
          },
          "document_type": {
            "type": "string",
            "description": "Tipo de documento del pasajero.",
            "enum": [
              "DNI",
              "VISA",
              "PASAPORTE"
            ],
            "example": "DNI"
          },
          "document_number": {
            "type": "string",
            "description": "Numero de documento del pasajero.",
            "example": "34343434"
          },
          "birthdate": {
            "$ref": "#/components/schemas/Date"
          }
        }
      },
      "locationIds": {
        "description": "Arreglo de identificadores \u00fanicos de destinos para la b\u00fasqueda. En mismo formato, acepta un \u00fanico identificador.",
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^(\\d{1,5})((,\\s*\\d{1,5})*)?"
        },
        "example": [
          "3453, 1234"
        ]
      },
      "locationNames": {
        "description": "Arreglo de nombres de destinos para la b\u00fasqueda. En mismo formato, acepta un \u00fanico identificador.",
        "type": "array",
        "items": {
          "type": "string",
          "example": "Cancun"
        },
        "example": [
          "Cancun",
          "Lima"
        ]
      },
      "visible": {
        "type": "string",
        "description": "Determina si las salidas a buscar tienen que estar o no visibles, la omisi\u00f3n de este para\u00e1metro se toma como `true`.",
        "example": false
      },
      "FindWithParamsData": {
        "type": "object",
        "description": "Informacion necesaria para la busqueda con parametros opcionales.",
        "required": [
          "start_date",
          "end_date",
          "adults_count",
          "location_ids",
          "location_names",
          "visible"
        ],
        "properties": {
          "start_date": {
            "$ref": "#/components/schemas/Date"
          },
          "end_date": {
            "$ref": "#/components/schemas/Date"
          },
          "adults_count": {
            "type": "integer",
            "example": 1
          },
          "location_ids": {
            "$ref": "#/components/schemas/locationIds"
          },
          "location_names": {
            "$ref": "#/components/schemas/locationNames"
          },
          "visible": {
            "$ref": "#/components/schemas/visible"
          }
        }
      },
      "BookingDataParam": {
        "type": "object",
        "description": "Informacion necesaria para el booking de una reserva.",
        "required": [
          "adults_number",
          "reserve_data",
          "passengers"
        ],
        "properties": {
          "adults_number": {
            "type": "integer",
            "example": 1
          },
          "reserve_data": {
            "$ref": "#/components/schemas/ReserveDataParam"
          },
          "passengers": {
            "$ref": "#/components/schemas/PassengerDataParam"
          }
        }
      },
      "RateDescriptionItem": {
        "type": "object",
        "description": "Detalle de importe para endpoints de TravelPack.",
        "required": [
          "rate",
          "amount",
          "base",
          "description"
        ],
        "properties": {
          "rate": {
            "type": "number",
            "format": "float",
            "example": 21
          },
          "amount": {
            "type": "number",
            "format": "float",
            "example": 15.15
          },
          "base": {
            "type": "number",
            "format": "float",
            "example": 72.13
          },
          "description": {
            "type": "string",
            "example": "Gastos administrativos"
          }
        }
      },
      "RateDescriptionMinItem": {
        "type": "object",
        "description": "Detalle de importe para endpoints de TravelPack.",
        "required": [
          "amount",
          "description"
        ],
        "properties": {
          "amount": {
            "type": "number",
            "format": "float",
            "example": 15.15
          },
          "description": {
            "type": "string",
            "example": "Gastos administrativos"
          }
        }
      },
      "PreliquidationItem": {
        "type": "object",
        "required": [
          "total",
          "TourismTaxes",
          "FiscalTaxes",
          "NonCommissionableService",
          "commission_amount",
          "commissionable_price"
        ],
        "properties": {
          "total": {
            "type": "integer",
            "format": "float",
            "example": 1101.48
          },
          "TourismTaxes": {
            "$ref": "#/components/schemas/RateDescriptionItem"
          },
          "FiscalTaxes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RateDescriptionItem"
            }
          },
          "NonCommissionableService": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RateDescriptionMinItem"
            }
          },
          "commission_amount": {
            "type": "integer",
            "format": "float",
            "example": 0.0
          },
          "commissionable_price": {
            "type": "integer",
            "format": "float",
            "example": 857.0
          }
        }
      }
    },
    "responses": {
      "StandardError": {
        "description": "Respuesta de error estandar.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "string",
                  "description": "Estado del request",
                  "example": "error"
                },
                "notifications": {
                  "type": "array",
                  "description": "Detalle del/los error/s.",
                  "example": [
                    "Mensaje de error apropiado"
                  ],
                  "items": {
                    "type": "string"
                  }
                },
                "results": {
                  "type": "array",
                  "description": "Arreglo vac\u00edo.",
                  "example": [],
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "StandardNotFoundError": {
