{
  "openapi": "3.0.0",
  "externalDocs": {
    "description": "Encuentre mas informaci\u00f3n aqu\u00ed",
    "url": "http://git.aero.tur.ar/jsivori/aero-packs/wikis/integracion-al-mundo"
  },
  "info": {
    "title": "Aero Paquetes Adaptador AlMundo",
    "description": "Aero-Packs es la aplicacion donde Aero S.R.L ofrece todos sus servicios en un \u00fanico servicio integral.\n\nEste documento debe utilizarse como referencia para utilizar la API de AeroPacks integrada con AlMundo para la venta de paquetes desde un consumo externo con modalidad consulta y venta \"on the fly\".\n\n<b>Tener en cuenta:</b> La disponibilidad de una salida depende de que la misma haya podido mapear el destino con el proveedor y ademas requiere la carga de al menos una imagen para la misma.\n\n<b>Recordar que</b> el workflow de trabajo del proveedor respeta el orden del listado de endpoints presentados.\n\nSe necesitan credenciales de acceso para el uso de esta API. (HTTP_X_TOKEN)\n",
    "version": "1.7.2",
    "contact": {
      "email": "jonatan.sivori@aerolaplata.com.ar"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/jsivori/aero-paquetes_adaptador_al_mundo/1.7.2/swagger.json"
  },
  "components": {
    "schemas": {
      "Date": {
        "type": "string",
        "description": "String que representa la clase Date.",
        "pattern": "^[0-9]{4}\\-((0[1-9]|1[0-2])){1}-([012][0-9]|3[01])$",
        "example": "2017-10-12"
      },
      "Time": {
        "type": "string",
        "description": "String que representa la clase Time.",
        "pattern": "(?:[01][0-9]|2[0-3]):([0-5][0-9])",
        "example": "20:31"
      },
      "IATACode": {
        "description": "Codigo de 3 letras que representa univocamente un lugar o aeropuerto.",
        "type": "string",
        "pattern": "^[A-Z]{3}$",
        "example": "CUN"
      },
      "ImageItem": {
        "type": "object",
        "description": "Representa una imagen de la salida.",
        "required": [
          "thumbnail",
          "picture"
        ],
        "properties": {
          "thumbnail": {
            "type": "string",
            "description": "Imagen en version peque\u00f1a.",
            "example": "9ad2f0ee-2cf6-42a4-8f95-1135a3f2947d"
          },
          "picture": {
            "type": "string",
            "description": "Imagen en version normal.",
            "example": "9ad2f0ee-2cf6-42a4-8f95-1135a3f2947d"
          }
        }
      },
      "OriginResponse": {
        "type": "array",
        "description": "Arreglo con destinos.",
        "example": [
          123412,
          234524
        ]
      },
      "ErrorResponse": {
        "type": "array",
        "description": "Arreglo con detalles de error.",
        "items": {
          "type": "string",
          "enum": [
            "Ha ocurrido un error.",
            "Falta el ID del destino."
          ]
        }
      },
      "NotFoundResponse": {
        "type": "array",
        "description": "Arreglo con detalles de error.",
        "example": [
          "Recurso desconocido...",
          "No existe el servicio solicitado."
        ]
      },
      "ServerErrorResponse": {
        "type": "array",
        "description": "Arreglo con detalles de error.",
        "example": [
          "Error de conexion interna, intente en unos minutos nuevamente",
          "Ha ocurrido un error inesperado, por favor vuelva a intentar en unos segundos o comuniquese con los programadores"
        ]
      },
      "Product_Types": {
        "type": "array",
        "description": "Listado de servicios de una salida.",
        "example": [
          "INSURANCE",
          "FLIGHT",
          "HOTEL",
          "TRANSFER",
          "ACTIVITY"
        ]
      },
      "BasicData_Template": {
        "type": "object",
        "description": "Informacion basica de un Template.",
        "required": [
          "notes",
          "images",
          "recommended",
          "tags",
          "important_information",
          "departure_dates"
        ],
        "properties": {
          "notes": {
            "type": "string",
            "description": "Notas de la salida."
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageItem"
            }
          },
          "recommended": {
            "type": "boolean",
            "description": "Booleano que detemrina si la salida esta recomendada o no. De momento siempre es verdadero.",
            "example": true
          },
          "tags": {
            "type": "string",
            "description": "Tags de la salida puntual. De momento es un valor que se envia nulo."
          },
          "important_information": {
            "type": "string",
            "description": "Informacion importante de la salida.",
            "example": "No se permiten Ni\u00f1os"
          },
          "departure_dates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Date"
            }
          }
        }
      },
      "TravelDetails_Template": {
        "type": "object",
        "description": "Informacion basica en detalle de un con lugares de origen y destino y servicios del Template.",
        "required": [
          "duration",
          "origin",
          "destinations",
          "product_types"
        ],
        "properties": {
          "duration": {
            "type": "integer",
            "description": "Cantidad de dias que dura la salida.",
            "example": 8
          },
          "origin": {
            "type": "integer",
            "description": "Lugar de origen de la salida. Destino de AlMundo.",
            "example": 1282466
          },
          "destinations": {
            "$ref": "#/components/schemas/OriginResponse"
          },
          "product_types": {
            "$ref": "#/components/schemas/Product_Types"
          }
        }
      },
      "Template": {
        "type": "object",
        "description": "Template basico de respuesta de una salida.",
        "required": [
          "id",
          "provider",
          "name",
          "description",
          "basic_data",
          "travel_details"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Id del conjunto de salidas que responden a la busqueda. Clave Md5.",
            "example": "a3d4d8612e2fcbba4a963cc149e50615"
          },
          "provider": {
            "type": "string",
            "description": "Campo nulo, que luego se completa con el nombre del proveedor.",
            "example": "AEROLP"
          },
          "name": {
            "type": "string",
            "description": "Nombre del conjunto de salidas que responden a la busqueda.",
            "example": null
          },
          "description": {
            "type": "string",
            "description": "Descripci\u00f3n de la salida.",
            "example": null
          },
          "basic_data": {
            "$ref": "#/components/schemas/BasicData_Template"
          },
          "travel_details": {
            "$ref": "#/components/schemas/TravelDetails_Template"
          }
        }
      },
      "Taxes_Detail": {
        "type": "object",
        "description": "Informacion detallada de precio acorde al modelo pedido.",
        "required": [
          "name",
          "amount"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre que detalla el tipo de impuesto que se aplica a la tarifa.",
            "example": "IVA21"
          },
          "amount": {
            "type": "number",
            "description": "Precio del impuesto.",
            "example": 452.25
          }
        }
      },
      "Price_Info": {
        "type": "object",
        "description": "Informacion detallada de precio acorde al modelo pedido.",
        "required": [
          "currency",
          "total",
          "taxes"
        ],
        "properties": {
          "currency": {
            "type": "string",
            "description": "Moneda en la cual se devuelve la tarifa.",
            "example": "USD"
          },
          "total": {
            "type": "number",
            "description": "Precio de la salida. Incluye el valor del IVA e impuestos.",
            "example": 2153.56
          },
          "taxes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Taxes_Detail"
            }
          }
        }
      },
      "Geo_Position": {
        "type": "object",
        "description": "Informacion de geolocalizacion.",
        "required": [
          "latitude",
          "longitude"
        ],
        "properties": {
          "latitude": {
            "type": "number",
            "example": 12.453
          },
          "longitude": {
            "type": "number",
            "example": -12.453
          }
        }
      },
      "Room_Information": {
        "type": "object",
        "required": [
          "images",
          "adults",
          "children",
          "description"
        ],
        "properties": {
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageItem"
            }
          },
          "description": {
            "type": "string",
            "description": "Descripcion anexa de habitacion.",
            "example": "Info util"
          },
          "adults": {
            "type": "integer",
            "example": 1
          },
          "children": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "example": []
          }
        }
      },
      "Rooms_Cluster_Information": {
        "type": "object",
        "required": [
          "rooms",
          "price",
          "images",
          "description",
          "rate_id"
        ],
        "properties": {
          "rooms": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Room_Information"
            }
          },
          "price": {
            "$ref": "#/components/schemas/Price_Info"
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageItem"
            }
          },
          "description": {
            "type": "string",
            "description": "Descripcion anexa de habitacion.",
            "example": "Se debe pedir al encargado las llaves de los servicios"
          },
          "rate_id": {
            "type": "string",
            "description": "Identificador de la tarifa de habitacion. Como eso no aplica se envia el id del hotel.",
            "example": "545"
          }
        }
      },
      "Hotel_Availability_Info": {
        "type": "object",
        "description": "Informacion del hotel para el endpoint de disponibilidad y chequeo.",
        "required": [
          "id",
          "name",
          "check_in",
          "check_out",
          "check_in_time",
          "check_out_time",
          "geo_position",
          "address",
          "rooms",
          "stars",
          "amenities",
          "meal_plan",
          "images",
          "description",
          "room_cluster"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "543"
          },
          "name": {
            "type": "string",
            "description": "Nombre del hotel",
            "example": "Occidental Punta Cana (Ex Gran Punta Cana)"
          },
          "check_in": {
            "$ref": "#/components/schemas/Date"
          },
          "check_out": {
            "$ref": "#/components/schemas/Date"
          },
          "check_in_time": {
            "$ref": "#/components/schemas/Time"
          },
          "check_out_time": {
            "$ref": "#/components/schemas/Time"
          },
          "geo_position": {
            "$ref": "#/components/schemas/Geo_Position"
          },
          "address": {
            "type": "string",
            "description": "Direccion fisica del hotel.",
            "example": "345 Street Rd"
          },
          "rooms": {
            "$ref": "#/components/parameters/rooms"
          },
          "stars": {
            "type": "integer",
            "description": "Cantidad de estrellas del hotel.",
            "example": 3
          },
          "amenities": {
            "type": "array",
            "description": "Amenities del hotel.",
            "items": {
              "type": "string"
            },
            "example": []
          },
          "meal_plan": {
            "type": "string",
            "description": "Regimen del hotel. Esta mapeado de acuerdo a lo requerido por el cosumidor.",
            "example": "ALL_INCLUSIVE"
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageItem"
            }
          },
          "description": {
            "type": "string",
            "description": "Descripcion anexa del servicio.",
            "example": "Puede almacenarse el equipaje hasta el check_in"
          },
          "room_cluster": {
            "type": "object",
            "description": "Informacion de la habitacion/es.",
            "required": [
              "selected",
              "options"
            ],
            "properties": {
              "selected": {
                "$ref": "#/components/schemas/Rooms_Cluster_Information"
              },
              "options": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": []
              }
            }
          }
        }
      },
      "Hotel_Keys_Availability_Info": {
        "type": "object",
        "required": [
          "selected",
          "options"
        ],
        "properties": {
          "selected": {
            "$ref": "#/components/schemas/Hotel_Availability_Info"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          }
        }
      },
      "Transfer_Keys_Availability_Info": {
        "type": "object",
        "required": [
          "selected",
          "options"
        ],
        "properties": {
          "selected": {
            "$ref": "#/components/schemas/Transfer_Availability_Info"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          }
        }
      },
      "Insurance_Keys_Availability_Info": {
        "type": "object",
        "required": [
          "selected",
          "options"
        ],
        "properties": {
          "selected": {
            "$ref": "#/components/schemas/Insurance_Availability_Info"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          }
        }
      },
      "Flight_Keys_Availability_Info": {
        "type": "object",
        "required": [
          "selected",
          "options"
        ],
        "properties": {
          "selected": {
            "$ref": "#/components/schemas/Flight_Availability_Info"
          },
          "options": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          }
        }
      },
      "Segment_Leg_Info": {
        "type": "object",
        "required": [
          "origin",
          "destination",
          "departure_date",
          "departure_time",
          "arrival_date",
          "arrival_time",
          "marketing_carrier",
          "operating_carrier",
          "number",
          "flight_duration",
          "flight_class",
          "cabin_type",
          "cabin_description"
        ],
        "properties": {
          "origin": {
            "$ref": "#/components/schemas/IATACode"
          },
          "destination": {
            "$ref": "#/components/schemas/IATACode"
          },
          "departure_date": {
            "$ref": "#/components/schemas/Date"
          },
          "departure_time": {
            "$ref": "#/components/schemas/Time"
          },
          "arrival_date": {
            "$ref": "#/components/schemas/Date"
          },
          "arrival_time": {
            "$ref": "#/components/schemas/Time"
          },
          "marketing_carrier": {
            "type": "string",
            "description": "Iata de la compa\u00f1ia.",
            "example": "LA"
          },
          "operating_carrier": {
            "type": "string",
            "description": "Iata de compa\u00f1ia.",
            "example": "LA"
          },
          "number": {
            "type": "integer",
            "description": "Numero del vuelo.",
            "example": 8010
          },
          "flight_duration": {
            "$ref": "#/components/schemas/Time"
          },
          "flight_class": {
            "type": "string",
            "description": "Clase del vuelo.",
            "example": "Q"
          },
          "cabin_type": {
            "type": "string",
            "description": "Tipo de cabina.",
            "example": ""
          },
          "cabin_description": {
            "type": "string",
            "description": "Descripcion de cabina.",
            "example": ""
          }
        }
      },
      "Baggage_Info": {
        "type": "object",
        "required": [
          "quantity",
          "weight",
          "weight_unit",
          "dimension",
          "dimension_unit"
        ],
        "properties": {
          "quantity": {
            "type": "integer",
            "example": 1
          },
          "weight": {
            "example": null
          },
          "weight_unit": {
            "example": null
          },
          "dimension": {
            "example": null
          },
          "dimension_unit": {
            "example": null
          }
        }
      },
      "Segment_Info": {
        "type": "object",
        "required": [
          "id",
          "origin",
          "destination",
          "departure_date",
          "arrival_date",
          "departure_time",
          "arrival_time",
          "fligh_duration",
          "time_between_legs",
          "legs",
          "baggage",
          "baggage_allowed"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "2934"
          },
          "origin": {
            "type": "string",
            "example": "EZE"
          },
          "destination": {
            "type": "string",
            "example": "CUN"
          },
          "departure_date": {
            "$ref": "#/components/schemas/Date"
          },
          "arrival_date": {
            "$ref": "#/components/schemas/Date"
          },
          "departure_time": {
            "$ref": "#/components/schemas/Time"
          },
          "arrival_time": {
            "$ref": "#/components/schemas/Time"
          },
          "fligh_duration": {
            "$ref": "#/components/schemas/Time"
          },
          "time_between_legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Time"
            }
          },
          "legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Segment_Leg_Info"
            }
          },
          "baggage": {
            "$ref": "#/components/schemas/Baggage_Info"
          },
          "baggage_allowed": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "Flight_Availability_Info": {
        "type": "object",
        "required": [
          "id",
          "price",
          "carrier",
          "domestic",
          "segments"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "2934"
          },
          "price": {
            "$ref": "#/components/schemas/Price_Info"
          },
          "carrier": {
            "type": "string",
            "description": "Compa\u00f1ia a la cual el cupo pertenece. Iata de la misma.",
            "example": "LA"
          },
          "domestic": {
            "type": "boolean",
            "description": "Determina si el vuelo es interno o no.",
            "example": false
          },
          "segments": {
            "type": "array",
            "description": "Rutas del cupo.",
            "items": {
              "$ref": "#/components/schemas/Segment_Info"
            }
          }
        }
      },
      "Transfer_Leg_info": {
        "type": "object",
        "required": [
          "from",
          "to",
          "departure_datetime",
          "arrival_datetime"
        ],
        "properties": {
          "from": {
            "type": "string",
            "example": "Puerto La Romana"
          },
          "to": {
            "type": "string",
            "example": "Hotel Punta Cana"
          },
          "departure_datetime": {
            "type": "string",
            "example": ""
          },
          "arrival_datetime": {
            "type": "string",
            "example": ""
          }
        }
      },
      "Transfer_Availability_Info": {
        "type": "object",
        "required": [
          "id",
          "category",
          "legs",
          "price"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "60"
          },
          "category": {
            "type": "string",
            "description": "Categoria del servicio mapeado con las categorias del consumidor.",
            "example": "PRIVATE"
          },
          "legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transfer_Leg_info"
            }
          },
          "price": {
            "$ref": "#/components/schemas/Price_Info"
          }
        }
      },
      "Insurance_Availability_Info": {
        "type": "object",
        "required": [
          "id",
          "price",
          "validity_start_date",
          "validity_end_date",
          "coverage_type",
          "name",
          "insurance_coverage",
          "amount_coverage",
          "conditions"
        ],
        "properties": {
          "id": {
            "type": "string",
            "example": "345"
          },
          "price": {
            "$ref": "#/components/schemas/Price_Info"
          },
          "validity_start_date": {
            "$ref": "#/components/schemas/Date"
          },
          "validity_end_date": {
            "$ref": "#/components/schemas/Date"
          },
          "coverage_type": {
            "type": "string",
            "example": null
          },
          "name": {
            "type": "string",
            "example": "Asistencia Mayores"
          },
          "insurance_coverage": {
            "type": "string",
            "example": "Cubre un adulto y ni\u00f1o hasta 8 a\u00f1os"
          },
          "amount_coverage": {
            "type": "string",
            "example": "Cubre hasta 5000 dolares"
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "Cubre hasta 5000 dolares"
            }
          }
        }
      },
      "Service_Availability_Info": {
        "type": "object",
        "required": [
          "name",
          "description",
          "image"
        ],
        "properties": {
          "name": {
            "type": "string",
            "example": "Excursi\u00f3n FD - D\u00eda completo  Regular - Santo Domingo desde Punta Cana"
          },
          "description": {
            "type": "string",
            "example": "Conocer la capital, Santo Domingo, es esencial para conocer el pa\u00eds. Aqu\u00ed empez\u00f3 la historia de Am\u00e9rica. Es una ciudad cosmopolita, pujante, cargada de un profundo pasado hist\u00f3rico asociado a la conquista del continente americano. Localizada al sur de la isla, la ciudad es ba\u00f1ada por las olas y las brisas del Mar Caribe.\\r\\nLa Zona Colonial, declarada Patrimonio Com\u00fan de la Humanidad por la UNESCO, incluye las construcciones m\u00e1s antiguas creadas por los espa\u00f1oles; como las primeras oficinas administrativas o la primera catedral del nuevo mundo.\\r\\n\\r\\nTiming:\\r\\n10:30 Visita al Alc\u00e1zar de Col\u00f3n. Caminata por la calle de Las Damas.\\r\\nVisita a La Primera Catedral de Am\u00e9rica.\\r\\n12:30 Almuerzo en Meli\u00e1 SDQ con una bebida inclu\u00edda. \\r\\n14:00 Tiempo Libre para shopping.\\r\\n15:00 Visita al monumento Faro a Col\u00f3n.\\r\\n15:30 Visita a La Cueva Los Tres Ojos."
          },
          "image": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageItem"
            }
          }
        }
      },
      "Availability_Products": {
        "type": "object",
        "required": [
          "cities",
          "flights",
          "insurance",
          "services",
          "transfers"
        ],
        "properties": {
          "cities": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "city_id",
                "hotel",
                "activities"
              ],
              "properties": {
                "city_id": {
                  "type": "string",
                  "description": "Id de la ciudad donde se encuentra el hotel.",
                  "example": "1330536"
                },
                "hotel": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Hotel_Keys_Availability_Info"
                  }
                },
                "activities": {
                  "type": "array",
                  "description": "Actividades extra para el servicio",
                  "items": {
                    "type": "string"
                  },
                  "example": []
                }
              }
            }
          },
          "flights": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Flight_Keys_Availability_Info"
            }
          },
          "insurance": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Insurance_Keys_Availability_Info"
            }
          },
          "services": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Service_Availability_Info"
            }
          },
          "transfers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Transfer_Keys_Availability_Info"
            }
          }
        }
      },
      "Availability": {
        "type": "object",
        "description": "Informacion de disponibilidad.",
        "required": [
          "id",
          "provider",
          "name",
          "description",
          "basic_data",
          "travel_details",
          "rate_id",
          "start_date",
          "status",
          "price",
          "products"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Id del conjunto de salidas que responden a la busqueda. Clave Md5.",
            "example": "a3d4d8612e2fcbba4a963cc149e50615"
          },
          "provider": {
            "type": "string",
            "description": "Campo nulo, que luego se completa con el nombre del proveedor.",
            "example": "AEROLP"
          },
          "name": {
            "type": "string",
            "description": "Nombre del conjunto de salidas que responden a la busqueda.",
            "example": null
          },
          "description": {
            "type": "string",
            "description": "Descripci\u00f3n de la salida.",
            "example": null
          },
          "basic_data": {
            "$ref": "#/components/schemas/BasicData_Template"
          },
          "travel_details": {
            "$ref": "#/components/schemas/TravelDetails_Template"
          },
          "rate_id": {
            "type": "string",
            "description": "Referencia al id del paquete de aero puntual que se va a reservar dentro del conjunto de salidas que se busco.",
            "example": "3"
          },
          "start_date": {
            "$ref": "#/components/schemas/Date"
          },
          "status": {
            "type": "string",
            "example": "CHECKED_NO_CHANGE"
          },
          "price": {
            "$ref": "#/components/schemas/Price_Info"
          },
          "products": {
            "$ref": "#/components/schemas/Availability_Products"
          }
        }
      },
      "ContactInformationParam": {
        "type": "object",
        "description": "Informacion de contacto para la reserva de alMundo, es requerido aunque no se tiene en cuenta actualmente en la reserva de Aero.",
        "required": [
          "email",
          "phone_type",
          "phone_country_code",
          "phone_area_code",
          "phone_number"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "nicolas.mejias@almundo.com"
          },
          "phone_type": {
            "type": "string",
            "example": "CELULAR"
          },
          "phone_country_code": {
            "type": "string",
            "example": "54"
          },
          "phone_area_code": {
            "type": "string",
            "example": "11"
          },
          "phone_number": {
            "type": "string",
            "example": "12345678"
          }
        }
      },
      "DocumentPassengerData": {
        "type": "object",
        "description": "Data del documento del pasajero para Api de AlMundo.",
        "required": [
          "type",
          "number",
          "issuer",
          "expiration"
        ],
        "properties": {
          "type": {
            "type": "string",
            "example": "Pasaporte"
          },
          "number": {
            "type": "string",
            "example": 12345678
          },
          "issuer": {
            "type": "string",
            "example": "ARG"
          },
          "expiration": {
            "type": "string",
            "example": "2020-01-01"
          }
        }
      },
      "PassengerAlMundoData": {
        "type": "object",
        "description": "Informacion del pasajero de Api de AlMundo para crear reservas.",
        "required": [
          "first_name",
          "last_name",
          "birthday",
          "nationality",
          "gender",
          "document"
        ],
        "properties": {
          "first_name": {
            "type": "string",
            "example": "Nicolas"
          },
          "last_name": {
            "type": "string",
            "example": "Mejias"
          },
          "birthday": {
            "type": "string",
            "example": "1988-03-23"
          },
          "nationality": {
            "type": "string",
            "example": "ARG"
          },
          "gender": {
            "type": "string",
            "example": "MALE"
          },
          "document": {
            "$ref": "#/components/schemas/DocumentPassengerData"
          }
        }
      },
      "BookingDataParam": {
        "type": "object",
        "description": "Parametros para el booking de parte de Api de AlMundo contra Api Aero.",
        "required": [
          "cart_id",
          "contact_information",
          "passengers"
        ],
        "properties": {
          "cart_id": {
            "type": "string",
            "example": "CartIdNico2"
          },
          "contact_information": {
            "$ref": "#/components/schemas/ContactInformationParam"
          },
          "passengers": {
            "$ref": "#/components/schemas/PassengerAlMundoData"
          }
        }
      },
      "ResponseReserveCreateAlMundo": {
        "type": "object",
        "description": "Respuesta de AlMundo para la creacion de una reserva.",
        "required": [
          "reservation_code"
        ],
        "properties": {
          "reservation_code": {
            "type": "string",
            "example": 67708
          }
        }
      },
      "ResponseDeleteCreateAlMundo": {
        "type": "object",
        "description": "Respuesta de AlMundo para la baja de una reserva.",
        "required": [
          "cancellation_code"
        ],
        "properties": {
          "cancellation_code": {
            "type": "string",
            "example": 6
          }
        }
      },
      "ResponseReserveConfirmAlMundo": {
        "type": "object",
        "description": "Respuesta de AlMundo para la obtencion de una o mas reservas.",
        "required": [
          "reservation_code",
          "price"
        ],
        "properties": {
          "reservation_code": {
            "type": "string",
            "example": 67708
          },
          "price": {
            "$ref": "#/components/schemas/Price_Info"
          }
        }
      },
      "ResponseReserveRetrieveAlMundo": {
        "type": "object",
        "description": "Respuesta de AlMundo para la confirmacion de una reserva.",
        "required": [
          "code",
          "cart_id",
          "price",
          "status",
          "cancellation_code"
        ],
        "properties": {
          "reservation_code": {
            "type": "string",
            "example": 67780
          },
          "cart_id": {
            "type": "string",
            "example": "CartIdNico2"
          },
          "price": {
            "$ref": "#/components/schemas/Price_Info"
          },
          "status": {
            "type": "string",
            "enum": [
              "CREATED",
              "COFIRMED",
              "CANCELLED",
              "EXPIRED"
            ]
          },
          "cancellation_code": {
            "type": "string",
            "example": 5
          }
        }
      }
    },
    "parameters": {
      "originParam": {
        "in": "path",
        "name": "originId",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Destino de AlMundo.",
        "example": 123412
      },
      "destinationParam": {
        "in": "path",
        "name": "destinationId",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Destino de AlMundo.",
        "example": 234524
      },
      "startDate": {
        "in": "path",
        "name": "startDate",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Fecha de inicio de busqueda. (<a target=\"_blank\" href=\"https://docs.oracle.com/javase/8/docs/api/java/time/format/DateTimeFormatter.html#ISO_LOCAL_DATE\">Documentaci\u00f3n</a>). Esta fecha es la fecha de inicio de la salida puntual la cual concuerda con la fecha de salida del cupo aereo o inicio del viaje.",
        "example": "2018-11-11"
      },
      "endDate": {
        "in": "path",
        "name": "endDate",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Fecha de fin de busqueda. (<a target=\"_blank\" href=\"https://docs.oracle.com/javase/8/docs/api/java/time/format/DateTimeFormatter.html#ISO_LOCAL_DATE\">Documentaci\u00f3n</a>)",
        "example": "2018-12-12"
      },
      "rooms": {
        "in": "path",
        "name": "rooms",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Este par\u00e1metro es un string que contiene la distribuci\u00f3n de los pasajeros por habitaci\u00f3n, y las edades de los menores. Dentro de rooms, las habitaciones se separan por coma. Cada habitaci\u00f3n tiene la cantidad de adultos y, separado por pipe, las edades de cada menor (separadas por gui\u00f3n).",
        "example": "2|1-2"
      },
      "package_id": {
        "in": "path",
        "name": "packageId",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Clave Md5 con la cual se indentifica al conjunto de salidas.",
        "example": "a3d4d8612e2fcbba4a963cc149e50615"
      },
      "rateId": {
        "in": "path",
        "name": "rateId",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Id puntual de una salida de AERO.",
        "example": 3
      },
      "language": {
        "in": "path",
        "name": "language",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Lenguaje de idioma de la busqueda. (<a target=\"_blank\" href=\"https://en.wikipedia.org/wiki/List_of_ISO_639-1_codes\">Documentaci\u00f3n</a>)",
        "example": "es"
      },
      "site": {
        "in": "path",
        "name": "site",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Lugar donde se realiza la busqueda.  (<a target=\"_blank\" href=\"https://en.wikipedia.org/wiki/ISO_3166-1_alpha-3\">Documentaci\u00f3n</a>)",
        "example": "ARG"
      },
      "reservation_code": {
        "in": "path",
        "name": "reservation_code",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Codigo de reserva efectuada.",
        "example": 667980
      }
    },
    "responses": {
      "OriginResponse": {
        "description": "Respuesta con destinos de AlMundo.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/OriginResponse"
            }
          }
        }
      },
      "DeparturesResponse": {
        "description": "Respuesta con fechas de salida de paquetes.",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Date"
              }
            }
          }
        }
      },
      "TemplateResponse": {
        "description": "Respuesta del template basico de una salida.",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/Template"
              }
            }
          }
        }
      },
      "AvailabilityResponse": {
        "description": "Respuesta de disponibilidad de un conjunto de salidas agrupada por clave de bases diferentes.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Availability"
            }
          }
        }
      },
      "CheckResponse": {
        "description": "Respuesta de chequeo de una salida puntual.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Availability"
            }
          }
        }
      },
      "ConfirmReserveResponse": {
        "description": "Respuesta de confirmacion de una salida.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ResponseReserveConfirmAlMundo"
            }
          }
        }
      },
      "CreateReserveResponse": {
        "description": "Respuesta de una reserva creada por AlMundo.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ResponseReserveCreateAlMundo"
            }
          }
        }
      },
      "DeleteReserveResponse": {
        "description": "Respuesta de cancelacion de reserva.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ResponseDeleteCreateAlMundo"
            }
          }
        }
      },
      "RetrieveReserveResponse": {
        "description": "Respuesta de recuperacion de una reserva.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ResponseReserveRetrieveAlMundo"
            }
          }
        }
      },
      "SearchReserveResponse": {
        "description": "Respuesta de obtencion de una reserva o varias de un carrito.",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/ResponseReserveRetrieveAlMundo"
              }
            }
          }
        }
      },
      "NotFoundResponse": {
        "description": "Respuesta est\u00e1ndar con errores por inexistencia de recurso.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/NotFoundResponse"
            }
          }
        }
      },
      "ServerErrorResponse": {
        "description": "Respuestas est\u00e1ndar problemas con servidor.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ServerErrorResponse"
            }
          }
        }
      },
      "ErrorResponse": {
        "description": "Respuesta est\u00e1ndar con errores de API.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/search/origins": {
      "get": {
        "tags": [
          "Listado de lugares origen de salidas."
        ],
        "summary": "Origenes.",
        "description": "Obtiene un listado de lugares (origen) mapeados a lugares de AlMundo con salidas disponibles con fecha mayor o igual a la actual.\n",
        "operationId": "origins",
        "parameters": [
          {
            "$ref": "#/components/parameters/language"
          },
          {
            "$ref": "#/components/parameters/site"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/OriginResponse"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ServerErrorResponse"
          }
        }
      }
    },
    "/search/destinations": {
      "get": {
        "tags": [
          "Listado de lugares destino de salidas."
        ],
        "summary": "Destinos.",
        "description": "Obtiene un listado de lugares (destino) mapeados a lugares de AlMundo con salidas disponibles con fecha mayor o igual a la actual basados en origen.\n",
        "operationId": "destinations",
        "parameters": [
          {
            "$ref": "#/components/parameters/originParam"
          },
          {
            "$ref": "#/components/parameters/language"
          },
          {
            "$ref": "#/components/parameters/site"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/OriginResponse"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ServerErrorResponse"
          }
        }
      }
    },
    "/search/departures": {
      "get": {
        "tags": [
          "Listado de fechas de salidas."
        ],
        "summary": "Fechas de Salidas.",
        "description": "Obtiene un listado de fechas para salidas disponibles basandose en origen y destino.\n",
        "operationId": "departures",
        "parameters": [
          {
            "$ref": "#/components/parameters/originParam"
          },
          {
            "$ref": "#/components/parameters/destinationParam"
          },
          {
            "$ref": "#/components/parameters/language"
          },
          {
            "$ref": "#/components/parameters/site"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/DeparturesResponse"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ServerErrorResponse"
          }
        }
      }
    },
    "/templates": {
      "get": {
        "tags": [
          "Listado de templates de salidas disponibles."
        ],
        "summary": "Templates.",
        "description": "Obtiene un listado de templates de salidas para las cuales la busqueda aplica. \n\nEl template es una plantilla que describe a un conjunto de paquetes (cada uno con su propia fecha de salida), pero todos deben coincidir con las caracter\u00edsticas que el template presenta (por ejemplo, la duraci\u00f3n).\n\nLos templates obtenidos son para mostrar en el cortizador y luego usar para controlar disponibilidad y generar reservas. \n\nEs por ello que luego de aqu\u00ed los endpoints posteriores utilizan para las salidas un identificador univoco y alfanum\u00e9rico que le otorga proveedor y ademas mantienen el identificador unico de Aero como <i>\"rate_id\"</i>.\n\nA partir de aqu\u00ed el par\u00e1metro <i>rooms</i> sirve como control de cotizaci\u00f3n disponible para CHDs.\n",
        "operationId": "templates",
        "parameters": [
          {
            "$ref": "#/components/parameters/originParam"
          },
          {
            "$ref": "#/components/parameters/destinationParam"
          },
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/endDate"
          },
          {
            "$ref": "#/components/parameters/language"
          },
          {
            "$ref": "#/components/parameters/site"
          },
          {
            "$ref": "#/components/parameters/rooms"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/TemplateResponse"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ServerErrorResponse"
          }
        }
      }
    },
    "/availability": {
      "get": {
        "tags": [
          "Listado de disponibilidades"
        ],
        "summary": "Availability.",
        "description": "Este endpoint devuelve disponibilidad de un paquete espec\u00edfico. \n\nEntre esta informacion, esta la disponibilidad de la salida junto con el identificador del paquete puntual de Aero para poder hacer el chequeo final y la reserva. <i>(\"rate_id\")</i>.\n",
        "operationId": "availability",
        "parameters": [
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/rooms"
          },
          {
            "$ref": "#/components/parameters/package_id"
          },
          {
            "$ref": "#/components/parameters/language"
          },
          {
            "$ref": "#/components/parameters/site"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/AvailabilityResponse"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ServerErrorResponse"
          }
        }
      }
    },
    "/check": {
      "get": {
        "tags": [
          "Chequeo"
        ],
        "summary": "Check.",
        "description": "Manteniendo informacion ya presentada, controla disponibilidad de una salida en particular para la posterior generacion de la reserva.\n",
        "operationId": "check",
        "parameters": [
          {
            "$ref": "#/components/parameters/rateId"
          },
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/rooms"
          },
          {
            "$ref": "#/components/parameters/package_id"
          },
          {
            "$ref": "#/components/parameters/language"
          },
          {
            "$ref": "#/components/parameters/site"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/CheckResponse"
          },
          "202": {
            "$ref": "#/components/responses/NotFoundResponse"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ServerErrorResponse"
          }
        }
      }
    },
    "/book": {
      "post": {
        "tags": [
          "Crear reserva"
        ],
        "summary": "Create Reserve.",
        "description": "Crea una reserva puntual en el sistema de reservas de Aero (MO).\n",
        "operationId": "create_reserve",
        "parameters": [
          {
            "$ref": "#/components/parameters/rateId"
          },
          {
            "$ref": "#/components/parameters/startDate"
          },
          {
            "$ref": "#/components/parameters/rooms"
          },
          {
            "$ref": "#/components/parameters/package_id"
          },
          {
            "$ref": "#/components/parameters/language"
          },
          {
            "$ref": "#/components/parameters/site"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "booking_params"
                ],
                "properties": {
                  "booking_params": {
                    "$ref": "#/components/schemas/BookingDataParam"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/CreateReserveResponse"
          },
          "202": {
            "$ref": "#/components/responses/NotFoundResponse"
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "500": {
            "$ref": "#/components/responses/ServerErrorResponse"
          }
        }
      },
      "get": {
        "tags": [
          "Recuperar reserva"
        ],
        "summary": "Search.",
        "description": "Recupera los datos de una o varias reservas con el identificador del carrito de AlMundo.\n",
        "operationId": "search",
        "parameters": [
          {
            "in": "query",
            "name": "CartId",
            "schema": {
              "type": "integer"
            },
            "required": true,
            "description": "Identificador del carrito de AlMundo",
            "example": "CartIdNico2"
          }
