  "paths": {
    "/ProductsPriceEntries/{shop_id}": {
      "get": {
        "summary": "Abrufen der Preise eines Shops",
        "description": "Ruft die Produktpreis-Zeilen eines Shops ab",
        "parameters": [
          {
            "in": "path",
            "name": "shop_id",
            "schema": {
              "$ref": "#/components/schemas/SHOP-ID"
            },
            "required": true,
            "description": "Shop-ID"
          }
        ],
        "responses": {
          "200": {
            "description": "R\u00fcckgabewerte (Produktpreis-Zeilen) eines Shops",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "result": {
                      "$ref": "#/components/schemas/SuccessResultType"
                    },
                    "entries": {
                      "description": "Array mit einem Eintrag",
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ResponseProductsPriceEntry"
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/ProductsPriceEntry/{shop_id}": {
      "put": {
        "summary": "\u00dcberschreibt Produkt Brutto Preise und deren Attribute im PIT",
        "description": "\u00dcberschreibt Shop spezifisch Produkte in den Produkt-Attributen",
        "parameters": [
          {
            "in": "path",
            "name": "shop_id",
            "schema": {
              "$ref": "#/components/schemas/SHOP-ID"
            },
            "required": true,
            "description": "Shop-ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/RequestProductsPriceEntry"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/ResponseProductsPriceEntries"
          },
          "409": {
            "$ref": "#/components/responses/EntityConflict"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/ProductsPriceEntry/{shop_id}/{ntin}": {
      "get": {
        "summary": "Abrufen einer Shop spezifischen Preiszeile",
        "description": "Ruft einen Shop spezifischen Eintrag einer Produktpreis-Zeile ab",
        "parameters": [
          {
            "in": "path",
            "name": "shop_id",
            "schema": {
              "$ref": "#/components/schemas/SHOP-ID"
            },
            "required": true,
            "description": "Shop-ID"
          },
          {
            "in": "path",
            "name": "ntin",
            "schema": {
              "$ref": "#/components/schemas/NTIN-FORMAT"
            },
            "required": true,
            "description": "Produkt-NTIN"
          }
        ],
        "responses": {
          "200": {
            "description": "R\u00fcckgabewerte eines Produkt-Preis Eintrags",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "result": {
                      "$ref": "#/components/schemas/SuccessResultType"
                    },
                    "entries": {
                      "description": "Array mit einem Eintrag",
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ResponseProductsPriceEntry"
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    },
    "/ProductsAttributes/{shop_id}": {
      "put": {
        "summary": "\u00dcberschreibt diverse Produkt Attribute im PIT",
        "description": "\u00dcberschreibt diverse Produkt Attribute im PIT. ACHTUNG: Maximale Anzahl an Produkt\u00e4nderungen in einem Request: 5000",
        "parameters": [
          {
            "in": "path",
            "name": "shop_id",
            "schema": {
              "$ref": "#/components/schemas/SHOP-ID"
            },
            "required": true,
            "description": "Shop-ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "products": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/RequestProductsAttributesEntry"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/ResponseProductsAttributesEntries"
          },
          "409": {
            "$ref": "#/components/responses/EntityConflict"
          },
          "422": {
            "$ref": "#/components/responses/UnprocessableEntity"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SHOP-ID": {
        "type": "integer",
        "format": "int32",
        "maxLength": 2
      },
      "PZN-FORMAT": {
        "type": "string",
        "pattern": "^[0-9]{8,8}$",
        "maxLength": 8,
        "minLength": 8,
        "example": "08123223"
      },
      "INT-FORMAT": {
        "type": "integer",
        "format": "int32",
        "example": 7
      },
      "NUMBER-FORMAT": {
        "type": "number",
        "format": "float",
        "example": 13.2
      },
      "NTIN-FORMAT": {
        "type": "string",
        "pattern": "^[0-9]{14,14}$",
        "maxLength": 14,
        "minLength": 14,
        "example": "04150072337767"
      },
      "SuccessResultType": {
        "description": "Resultat Typ",
        "type": "string",
        "example": "success"
      },
      "FailureResultType": {
        "description": "Resultat Typ",
        "type": "string",
        "example": "failure"
      },
      "RequestProductsPriceEntry": {
        "description": "Array mit Daten zum \u00dcberschreiben eines Produkt-Preislisten Eintrages (Brutto Preise!)",
        "type": "object",
        "properties": {
          "ntin": {
            "$ref": "#/components/schemas/NTIN-FORMAT"
          },
          "price_gross": {
            "type": "number",
            "format": "float",
            "example": 8.99,
            "description": "Brutto-Preis des Produkts"
          },
          "price_extra_charge_gross": {
            "type": "number",
            "format": "float",
            "example": -3.01,
            "description": "erster Ab/Aufschag (als Brutto-Wert) des Produkts f\u00fcr die Verwendung bei Preisvergleichen, kann positiver und negativer Wert sein"
          },
          "price_extra_charge_second_gross": {
            "type": "number",
            "format": "float",
            "example": 3.01,
            "description": "zweiter Ab/Aufschag (als Brutto-Wert) des Produkts f\u00fcr die Verwendung bei Preisvergleichen, kann positiver und negativer Wert sein"
          },
          "price_extra_charge_third_gross": {
            "type": "number",
            "format": "float",
            "example": 3.01,
            "description": "dritter Ab/Aufschag (als Brutto-Wert) des Produkts f\u00fcr die Verwendung bei Preisvergleichen, kann positiver und negativer Wert sein"
          },
          "price_ebay_gross": {
            "type": "number",
            "format": "float",
            "example": 9.15,
            "description": "Brutto-Preis des Produkts bei Ebay"
          },
          "price_amazon_gross": {
            "type": "number",
            "format": "float",
            "example": 9.15,
            "description": "Brutto-Preis des Produkts bei Amazon"
          },
          "tax_id": {
            "$ref": "#/components/schemas/INT-FORMAT"
          }
        },
        "required": [
          "ntin",
          "price_gross",
          "price_extra_charge_gross",
          "price_extra_charge_second_gross",
          "price_extra_charge_third_gross",
          "price_ebay_gross",
          "price_amazon_gross",
          "tax_id"
        ]
      },
      "RequestProductsAttributesEntry": {
        "description": "Array mit Daten zum \u00dcberschreiben von Produktattributen (Identifier NTIN)",
        "type": "object",
        "properties": {
          "ntin": {
            "$ref": "#/components/schemas/NTIN-FORMAT"
          },
          "maxstueckzahl": {
            "type": "number",
            "format": "integer",
            "example": 8,
            "description": "Maximalst\u00fcckzahl f\u00fcr das Produkt"
          },
          "uvp": {
            "type": "number",
            "format": "float",
            "example": 16.9999,
            "description": "UVP/AVP Preis des Produktes (Bruttowert)"
          },
          "apothekenpflichtig": {
            "type": "number",
            "format": "integer",
            "example": 1,
            "description": "Produkt apothekenpflichtig? (1 == ja, 0 == nein)"
          },
          "rezeptpflichtig": {
            "type": "number",
            "format": "integer",
            "example": 1,
            "description": "Produkt rezeptpflichtig? (1 == ja, 0 == nein)"
          }
        },
        "required": [
          "ntin"
        ]
      },
      "ResponseProductsPriceEntry": {
        "description": "Ein Shop spezifischer Produkt-Preislisten Eintrag",
        "type": "object",
        "properties": {
          "products_id": {
            "$ref": "#/components/schemas/INT-FORMAT"
          },
          "pzn": {
            "$ref": "#/components/schemas/PZN-FORMAT"
          },
          "ntin": {
            "$ref": "#/components/schemas/NTIN-FORMAT"
          },
          "price_gross": {
            "type": "number",
            "format": "float",
            "example": 8.99,
            "description": "Brutto-Preis des Produkts"
          },
          "price_extra_charge_gross": {
            "type": "number",
            "format": "float",
            "example": -3.01,
            "description": "erster Ab/Aufschag (als Brutto-Wert) des Produkts f\u00fcr die Verwendung bei Preisvergleichen, kann positiver und negativer Wert sein"
          },
          "price_extra_charge_second_gross": {
            "type": "number",
            "format": "float",
            "example": 3.01,
            "description": "zweiter Ab/Aufschag (als Brutto-Wert) des Produkts f\u00fcr die Verwendung bei Preisvergleichen, kann positiver und negativer Wert sein"
          },
          "price_extra_charge_third_gross": {
            "type": "number",
            "format": "float",
            "example": 3.01,
            "description": "dritter Ab/Aufschag (als Brutto-Wert) des Produkts f\u00fcr die Verwendung bei Preisvergleichen, kann positiver und negativer Wert sein"
          },
          "price_ebay_gross": {
            "type": "number",
            "format": "float",
            "example": 9.15,
            "description": "Brutto-Preis des Produkts bei Ebay"
          },
          "price_amazon_gross": {
            "type": "number",
            "format": "float",
            "example": 9.15,
            "description": "Brutto-Preis des Produkts bei Amazon"
          },
          "msrp": {
            "$ref": "#/components/schemas/NUMBER-FORMAT"
          },
          "tax_id": {
            "$ref": "#/components/schemas/INT-FORMAT"
          },
          "tax_value_percent": {
            "$ref": "#/components/schemas/INT-FORMAT"
          }
        }
      }
    },
    "responses": {
      "InternalError": {
        "description": "Interner Server Fehler",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/components/schemas/FailureResultType"
                },
                "error_status": {
                  "type": "string",
                  "example": "INTERNAL_SERVER_ERROR"
                },
                "error_code": {
                  "type": "string",
                  "example": "500"
                },
                "errors": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "result",
                "error_status",
                "error_code",
                "errors"
              ]
            }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "Falsche oder fehlende Parameter \u00fcbergeben",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/components/schemas/FailureResultType"
                },
                "error_status": {
                  "type": "string",
                  "example": "UNPROCESSABLE_ENTITY"
                },
                "error_code": {
                  "type": "string",
                  "example": "422"
                },
                "errors": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "result",
                "error_status",
                "error_code",
                "errors"
              ]
            }
          }
        }
      },
      "EntityConflict": {
        "description": "Entit\u00e4tskonflikt",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/components/schemas/FailureResultType"
                },
                "error_status": {
                  "type": "string",
                  "example": "ENTITY_CONFLICT"
                },
                "error_code": {
                  "type": "string",
                  "example": "409"
                },
                "errors": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "result",
                "error_status",
                "error_code",
                "errors"
              ]
            }
          }
        }
      },
      "ResponseProductsPriceEntries": {
        "description": "Ergebnis eines ProductsPriceEntries Request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "type": "string",
                  "enum": [
                    "success",
                    "failure"
                  ],
                  "example": "success"
                },
                "affected_ntins": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NTIN-FORMAT"
                  }
                },
                "error_ntins": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NTIN-FORMAT"
                  }
                },
                "errors": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "ResponseProductsAttributesEntries": {
        "description": "Ergebnis eines ProductsAttributesEntries Request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "type": "string",
                  "enum": [
                    "success",
                    "failure"
                  ],
                  "example": "success"
                },
                "affected_ntins": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NTIN-FORMAT"
                  }
                },
                "error_ntins": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NTIN-FORMAT"
                  }
                },
                "errors": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic"
      }
    }
  }
}