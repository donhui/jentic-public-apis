{
  "openapi": "3.0.3",
  "info": {
    "title": "Postal API",
    "version": "1.0.0",
    "description": "Postal is an open source mail delivery platform. The HTTP API allows you to send messages using JSON over HTTP, retrieve message information, and manage deliveries. All requests are POST requests with JSON bodies.",
    "x-jentic-source-url": "https://docs.postalserver.io/developer/api"
  },
  "servers": [
    {
      "url": "https://{postal_domain}/api/v1",
      "variables": {
        "postal_domain": {
          "default": "postal.example.com",
          "description": "Your Postal server domain"
        }
      }
    }
  ],
  "paths": {
    "/send/message": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send an email message",
        "description": "Sends an email by providing individual attributes (to, from, subject, body, etc.).",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          }
        }
      }
    },
    "/send/raw": {
      "post": {
        "operationId": "sendRawMessage",
        "summary": "Send a raw RFC 2822 email message",
        "description": "Sends an email by providing a pre-crafted RFC 2822 formatted message.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendRawMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          }
        }
      }
    },
    "/messages/message": {
      "post": {
        "operationId": "getMessage",
        "summary": "Get message details",
        "description": "Retrieves a message and its contents using the message ID. Optionally include expansions for additional detail.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          }
        }
      }
    },
    "/messages/deliveries": {
      "post": {
        "operationId": "getMessageDeliveries",
        "summary": "Get message deliveries",
        "description": "Retrieves delivery information for a specific message.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "The message ID"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Delivery information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SendMessageRequest": {
        "type": "object",
        "required": ["to", "from"],
        "properties": {
          "to": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Recipient email addresses"
          },
          "cc": {
            "type": "array",
            "items": { "type": "string" },
            "description": "CC email addresses"
          },
          "bcc": {
            "type": "array",
            "items": { "type": "string" },
            "description": "BCC email addresses"
          },
          "from": {
            "type": "string",
            "description": "Sender email address"
          },
          "sender": {
            "type": "string",
            "description": "Sender header (if different from from)"
          },
          "subject": {
            "type": "string",
            "description": "Email subject"
          },
          "tag": {
            "type": "string",
            "description": "Tag for the message"
          },
          "reply_to": {
            "type": "string",
            "description": "Reply-To address"
          },
          "plain_body": {
            "type": "string",
            "description": "Plain text body"
          },
          "html_body": {
            "type": "string",
            "description": "HTML body"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Attachment"
            }
          },
          "headers": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Custom email headers"
          },
          "bounce": {
            "type": "boolean",
            "description": "Whether this is a bounce message"
          }
        }
      },
      "SendRawMessageRequest": {
        "type": "object",
        "required": ["mail_from", "rcpt_to", "data"],
        "properties": {
          "mail_from": {
            "type": "string",
            "description": "MAIL FROM address"
          },
          "rcpt_to": {
            "type": "array",
            "items": { "type": "string" },
            "description": "RCPT TO addresses"
          },
          "data": {
            "type": "string",
            "description": "Base64-encoded RFC 2822 message"
          },
          "bounce": {
            "type": "boolean",
            "description": "Whether this is a bounce message"
          }
        }
      },
      "SendMessageResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "error"]
          },
          "time": {
            "type": "number",
            "description": "Time taken in seconds"
          },
          "flags": {
            "type": "object"
          },
          "data": {
            "type": "object",
            "properties": {
              "message_id": {
                "type": "string",
                "description": "UUID message ID"
              },
              "messages": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer" },
                    "token": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "GetMessageRequest": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "The message ID"
          },
          "_expansions": {
            "type": "boolean",
            "description": "Include expanded information"
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "error"]
          },
          "time": { "type": "number" },
          "flags": { "type": "object" },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "token": { "type": "string" },
              "message_id": { "type": "string" },
              "tag": { "type": "string" },
              "rcpt_to": { "type": "string" },
              "mail_from": { "type": "string" },
              "subject": { "type": "string" },
              "status": { "type": "string" },
              "timestamp": { "type": "number" }
            }
          }
        }
      },
      "Attachment": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "content_type": { "type": "string" },
          "data": { "type": "string", "description": "Base64-encoded attachment data" }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "error"]
          },
          "time": { "type": "number" },
          "flags": { "type": "object" },
          "data": { "type": "object" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["error"]
          },
          "time": { "type": "number" },
          "data": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "serverApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Server-API-Key",
        "description": "API key created for your mail server through the Postal web interface"
      }
    }
  },
  "security": [
    {
      "serverApiKey": []
    }
  ]
}