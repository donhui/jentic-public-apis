{
  "openapi": "3.0.3",
  "info": {
    "title": "Prismic Content API",
    "version": "v2",
    "description": "Prismic's Content Delivery API for querying and retrieving structured content from a Prismic repository.",
    "x-jentic-source-url": "https://prismic.io/docs/api"
  },
  "servers": [
    {
      "url": "https://{repository}.cdn.prismic.io",
      "variables": {
        "repository": {
          "description": "Your Prismic repository name",
          "default": "your-repo-name"
        }
      }
    }
  ],
  "security": [
    {},
    {
      "accessTokenQuery": []
    },
    {
      "accessTokenHeader": []
    }
  ],
  "tags": [
    {
      "name": "API",
      "description": "API entry point and metadata"
    },
    {
      "name": "Documents",
      "description": "Document search and retrieval"
    }
  ],
  "paths": {
    "/api/v2": {
      "get": {
        "operationId": "getApiEntryPoint",
        "summary": "Get API Entry Point",
        "description": "Returns the API entry point for the repository, including available refs, bookmarks, languages, content types, tags, search forms, and OAuth endpoints. This is the starting point for all API interactions — use the master ref from the response to query documents.",
        "tags": ["API"],
        "security": [
          {},
          {
            "accessTokenQuery": []
          },
          {
            "accessTokenHeader": []
          }
        ],
        "responses": {
          "200": {
            "description": "API entry point metadata for the repository.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiEntryPoint"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    },
    "/api/v2/documents/search": {
      "get": {
        "operationId": "searchDocuments",
        "summary": "Search Documents",
        "description": "Search and retrieve documents from the Prismic repository. Use Prismic query predicates in the `q` parameter to filter results. Common use cases include fetching documents by type, ID, UID, tags, or fulltext search.\n\n**Examples:**\n- All blog posts: `q=[[at(document.type,\"blog_post\")]]`\n- Document by ID: `q=[[at(document.id,\"XjZbKBIAACQAM5Gg\")]]`\n- Document by UID: `q=[[at(my.blog_post.uid,\"hello-world\")]]`\n- Fulltext search: `q=[[fulltext(document,\"prismic\")]]`\n- Multiple predicates: `q=[[at(document.type,\"blog_post\")][at(document.tags,[\"featured\"])]]`\n\n**Available predicates:**\n- `at(path, value)` — Exact match\n- `not(path, value)` — Exclude match\n- `any(path, values)` — Match any value in a list\n- `in(path, values)` — Match if field value is in array\n- `fulltext(path, value)` — Fulltext search\n- `has(path)` — Field exists\n- `missing(path)` — Field is missing\n- `similar(id, value)` — Find similar documents\n- `geopoint.near(path, lat, lng, radius)` — Geographic proximity\n- `number.lt(path, value)` / `number.gt(path, value)` / `number.inRange(path, lower, upper)` — Numeric comparisons\n- `date.before(path, value)` / `date.after(path, value)` / `date.between(path, lower, upper)` — Date comparisons",
        "tags": ["Documents"],
        "security": [
          {},
          {
            "accessTokenQuery": []
          },
          {
            "accessTokenHeader": []
          }
        ],
        "parameters": [
          {
            "name": "ref",
            "in": "query",
            "required": true,
            "description": "The ref to query against. Typically the master ref obtained from the API entry point (`GET /api/v2`). Use a release ref to query content from a specific release.",
            "schema": {
              "type": "string"
            },
            "example": "YxZbKBIAAC0AM5Gg"
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Prismic query predicates enclosed in double square brackets. Multiple predicates can be combined. If omitted, returns all published documents.\n\nExamples:\n- `[[at(document.type,\"blog_post\")]]` — all documents of type blog_post\n- `[[at(document.id,\"XjZbKBIAACQAM5Gg\")]]` — document by ID\n- `[[at(my.blog_post.uid,\"hello-world\")]]` — document by UID\n- `[[fulltext(document,\"search term\")]]` — fulltext search\n- `[[at(document.tags,[\"featured\"])]]` — documents with a specific tag\n- `[[any(document.type,[\"blog_post\",\"article\"])]]` — documents matching any listed type",
            "schema": {
              "type": "string"
            },
            "example": "[[at(document.type,\"blog_post\")]]"
          },
          {
            "name": "lang",
            "in": "query",
            "required": false,
            "description": "Language code to filter results. Use `*` to return documents in all languages. Defaults to `*` (all languages). Use ISO language codes such as `en-us`, `fr-fr`, etc.",
            "schema": {
              "type": "string",
              "default": "*"
            },
            "example": "en-us"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "The page number for paginated results. Starts at 1.",
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "The number of results per page. Maximum is 100.",
            "schema": {
              "type": "integer",
              "default": 20,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "after",
            "in": "query",
            "required": false,
            "description": "Document ID to use as a cursor for pagination. Returns results after the specified document. Useful for deep pagination beyond offset-based paging.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fetch",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of fields to include in the response. Limits the fields returned in each document's `data` object, reducing payload size. Format: `{type}.{field}`.",
            "schema": {
              "type": "string"
            },
            "example": "blog_post.title,blog_post.body"
          },
          {
            "name": "fetchLinks",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of fields to resolve from linked documents. When a document contains a link to another document, this parameter specifies which fields from the linked document to include inline. Format: `{type}.{field}`.",
            "schema": {
              "type": "string"
            },
            "example": "author.name,author.avatar"
          },
          {
            "name": "graphQuery",
            "in": "query",
            "required": false,
            "description": "A GraphQuery string for precise control over which fields to return and how deeply to resolve linked content. More powerful than `fetch` and `fetchLinks`. See Prismic GraphQuery documentation for syntax.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orderings",
            "in": "query",
            "required": false,
            "description": "Sort order for results. Specify fields with optional `desc` keyword inside square brackets. Multiple orderings are comma-separated.\n\nExamples:\n- `[my.blog_post.date desc]` — sort by date descending\n- `[document.first_publication_date]` — sort by publication date ascending\n- `[my.blog_post.date desc, document.last_publication_date]` — multiple sort fields",
            "schema": {
              "type": "string"
            },
            "example": "[my.blog_post.date desc]"
          },
          {
            "name": "access_token",
            "in": "query",
            "required": false,
            "description": "API access token for private repositories. Not required for public repositories. Can also be provided via the Authorization header.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of documents matching the query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "accessTokenQuery": {
        "type": "apiKey",
        "name": "access_token",
        "in": "query",
        "description": "API access token passed as a query parameter. Required for private repositories."
      },
      "accessTokenHeader": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "API access token passed in the Authorization header using the format: `Token your-access-token`. Required for private repositories."
      }
    },
    "schemas": {
      "ApiEntryPoint": {
        "type": "object",
        "description": "The API entry point response containing repository metadata, refs, and search form definitions.",
        "properties": {
          "refs": {
            "type": "array",
            "description": "Available refs (releases) for the repository. The master ref represents the current published content.",
            "items": {
              "$ref": "#/components/schemas/Ref"
            }
          },
          "bookmarks": {
            "type": "object",
            "description": "Named bookmarks mapping bookmark names to document IDs. Configured in the Prismic dashboard.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "languages": {
            "type": "array",
            "description": "Languages configured for the repository.",
            "items": {
              "$ref": "#/components/schemas/Language"
            }
          },
          "types": {
            "type": "object",
            "description": "Custom types defined in the repository. Maps type API ID to human-readable name.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "description": "All tags used across documents in the repository.",
            "items": {
              "type": "string"
            }
          },
          "forms": {
            "type": "object",
            "description": "Search form definitions describing available query endpoints and their parameters.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SearchForm"
            }
          },
          "oauth_initiate": {
            "type": "string",
            "description": "URL to initiate the OAuth authentication flow."
          },
          "oauth_token": {
            "type": "string",
            "description": "URL to exchange an OAuth code for an access token."
          },
          "experiments": {
            "type": "object",
            "description": "Active and draft A/B experiments for the repository.",
            "properties": {
              "draft": {
                "type": "array",
                "description": "Draft experiments not yet running.",
                "items": {
                  "$ref": "#/components/schemas/Experiment"
                }
              },
              "running": {
                "type": "array",
                "description": "Currently active experiments.",
                "items": {
                  "$ref": "#/components/schemas/Experiment"
                }
              }
            }
          }
        }
      },
      "Ref": {
        "type": "object",
        "description": "A ref represents a version of the repository content. The master ref is the current live content.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the ref."
          },
          "ref": {
            "type": "string",
            "description": "The ref value to use in API queries."
          },
          "label": {
            "type": "string",
            "description": "Human-readable label for the ref (e.g., \"Master\")."
          },
          "isMasterRef": {
            "type": "boolean",
            "description": "Whether this is the master (live published) ref."
          }
        },
        "required": ["id", "ref", "label", "isMasterRef"]
      },
      "Language": {
        "type": "object",
        "description": "A language configured in the Prismic repository.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Language code (e.g., \"en-us\", \"fr-fr\")."
          },
          "name": {
            "type": "string",
            "description": "Human-readable language name (e.g., \"English - United States\")."
          },
          "is_master": {
            "type": "boolean",
            "description": "Whether this is the default (master) language for the repository."
          }
        },
        "required": ["id", "name", "is_master"]
      },
      "SearchForm": {
        "type": "object",
        "description": "Definition of a search form describing an available query endpoint.",
        "properties": {
          "action": {
            "type": "string",
            "description": "The URL to submit the search form to."
          },
          "method": {
            "type": "string",
            "description": "HTTP method for the form (typically GET)."
          },
          "fields": {
            "type": "object",
            "description": "Field definitions for the search form parameters.",
            "additionalProperties": {
              "$ref": "#/components/schemas/SearchFormField"
            }
          }
        }
      },
      "SearchFormField": {
        "type": "object",
        "description": "A field definition within a search form.",
        "properties": {
          "type": {
            "type": "string",
            "description": "The data type of the field (e.g., \"String\", \"Integer\")."
          },
          "multiple": {
            "type": "boolean",
            "description": "Whether the field accepts multiple values."
          },
          "default": {
            "type": "string",
            "description": "Default value for the field, if any."
          }
        }
      },
      "Experiment": {
        "type": "object",
        "description": "An A/B experiment defined in the repository.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the experiment."
          },
          "name": {
            "type": "string",
            "description": "Human-readable name of the experiment."
          },
          "variations": {
            "type": "array",
            "description": "Variations within the experiment.",
            "items": {
              "$ref": "#/components/schemas/ExperimentVariation"
            }
          }
        }
      },
      "ExperimentVariation": {
        "type": "object",
        "description": "A variation within an experiment.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the variation."
          },
          "ref": {
            "type": "string",
            "description": "The ref associated with this variation."
          },
          "label": {
            "type": "string",
            "description": "Human-readable label for the variation."
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "description": "Paginated response from a document search query.",
        "properties": {
          "page": {
            "type": "integer",
            "description": "Current page number."
          },
          "results_per_page": {
            "type": "integer",
            "description": "Number of results per page."
          },
          "results_size": {
            "type": "integer",
            "description": "Number of results on the current page."
          },
          "total_results_size": {
            "type": "integer",
            "description": "Total number of results across all pages."
          },
          "total_pages": {
            "type": "integer",
            "description": "Total number of pages."
          },
          "next_page": {
            "type": "string",
            "nullable": true,
            "description": "URL for the next page of results. Null if on the last page."
          },
          "prev_page": {
            "type": "string",
            "nullable": true,
            "description": "URL for the previous page of results. Null if on the first page."
          },
          "results": {
            "type": "array",
            "description": "Array of documents matching the query.",
            "items": {
              "$ref": "#/components/schemas/Document"
            }
          }
        },
        "required": ["page", "results_per_page", "results_size", "total_results_size", "total_pages", "next_page", "prev_page", "results"]
      },
      "Document": {
        "type": "object",
        "description": "A Prismic document containing structured content.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique document identifier."
          },
          "uid": {
            "type": "string",
            "nullable": true,
            "description": "User-friendly unique identifier (slug). Null if the content type does not have a UID field."
          },
          "url": {
            "type": "string",
            "nullable": true,
            "description": "Resolved URL for the document if a link resolver is configured."
          },
          "type": {
            "type": "string",
            "description": "The API ID of the document's custom type."
          },
          "href": {
            "type": "string",
            "description": "Direct API URL to retrieve this document."
          },
          "tags": {
            "type": "array",
            "description": "Tags assigned to the document.",
            "items": {
              "type": "string"
            }
          },
          "first_publication_date": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the document was first published."
          },
          "last_publication_date": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the document was last published."
          },
          "slugs": {
            "type": "array",
            "description": "Historical slugs for the document, with the current slug first.",
            "items": {
              "type": "string"
            }
          },
          "linked_documents": {
            "type": "array",
            "description": "Documents linked from this document.",
            "items": {
              "$ref": "#/components/schemas/LinkedDocument"
            }
          },
          "lang": {
            "type": "string",
            "description": "Language code of the document (e.g., \"en-us\")."
          },
          "alternate_languages": {
            "type": "array",
            "description": "Translations of this document in other languages.",
            "items": {
              "$ref": "#/components/schemas/AlternateLanguage"
            }
          },
          "data": {
            "type": "object",
            "description": "The document's content fields. Structure varies depending on the custom type definition.",
            "additionalProperties": true
          }
        },
        "required": ["id", "type", "href", "tags", "first_publication_date", "last_publication_date", "slugs", "linked_documents", "lang", "alternate_languages", "data"]
      },
      "LinkedDocument": {
        "type": "object",
        "description": "A reference to a linked document.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the linked document."
          },
          "type": {
            "type": "string",
            "description": "Custom type of the linked document."
          },
          "tags": {
            "type": "array",
            "description": "Tags on the linked document.",
            "items": {
              "type": "string"
            }
          },
          "lang": {
            "type": "string",
            "description": "Language of the linked document."
          },
          "slug": {
            "type": "string",
            "description": "Current slug of the linked document."
          },
          "uid": {
            "type": "string",
            "nullable": true,
            "description": "UID of the linked document, if available."
          }
        }
      },
      "AlternateLanguage": {
        "type": "object",
        "description": "A reference to a translation of the document in another language.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Document ID of the alternate language version."
          },
          "type": {
            "type": "string",
            "description": "Custom type of the alternate language version."
          },
          "lang": {
            "type": "string",
            "description": "Language code of the alternate version."
          }
        },
        "required": ["id", "type", "lang"]
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Error response returned by the API.",
        "properties": {
          "type": {
            "type": "string",
            "description": "Error type identifier."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message describing what went wrong."
          },
          "oauth_initiate": {
            "type": "string",
            "description": "OAuth initiate URL, included in 401 responses."
          },
          "oauth_token": {
            "type": "string",
            "description": "OAuth token URL, included in 401 responses."
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad Request. The query syntax is invalid or a required parameter is missing.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized. The repository is private and no valid access token was provided.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Not Found. The repository does not exist or the URL is invalid.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Too Many Requests. The API rate limit has been exceeded. Retry after a delay.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}