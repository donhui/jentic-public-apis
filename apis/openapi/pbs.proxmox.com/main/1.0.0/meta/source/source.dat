{
  "openapi": "3.0.3",
  "info": {
    "title": "Proxmox Backup Server API",
    "version": "1.0.0",
    "description": "Proxmox Backup Server REST API for managing backups, datastores, access control, and system configuration.",
    "x-jentic-source-url": "https://pbs.proxmox.com/docs/api-viewer/index.html"
  },
  "servers": [
    {
      "url": "https://{host}:8007/api2/json",
      "variables": {
        "host": {
          "default": "localhost",
          "description": "Proxmox Backup Server hostname"
        }
      }
    }
  ],
  "paths": {
    "/access/ticket": {
      "post": {
        "operationId": "createTicket",
        "summary": "Create authentication ticket",
        "tags": ["Access"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "path": { "type": "string" },
                  "port": { "type": "integer" },
                  "privs": { "type": "string" },
                  "tfa-challenge": { "type": "string" }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication ticket",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TicketResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Authentication failed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "logout",
        "summary": "Invalidate authentication ticket",
        "tags": ["Access"],
        "responses": {
          "200": { "description": "Logged out" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/acl": {
      "get": {
        "operationId": "getAcl",
        "summary": "Read Access Control Lists",
        "tags": ["Access"],
        "parameters": [
          { "name": "exact", "in": "query", "schema": { "type": "boolean" } },
          { "name": "path", "in": "query", "schema": { "type": "string", "maxLength": 128 } }
        ],
        "responses": {
          "200": { "description": "ACL entries", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/AclEntry" } } } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateAcl",
        "summary": "Update Access Control Lists",
        "tags": ["Access"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "auth-id": { "type": "string" },
                  "delete": { "type": "boolean" },
                  "digest": { "type": "string" },
                  "group": { "type": "boolean" },
                  "path": { "type": "string" },
                  "propagate": { "type": "boolean" },
                  "role": { "type": "string" }
                },
                "required": ["path", "role"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "ACL updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/domains": {
      "get": {
        "operationId": "listDomains",
        "summary": "List authentication realms",
        "tags": ["Access"],
        "responses": {
          "200": { "description": "Authentication domains", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } } } } }
        }
      }
    },
    "/access/domains/{realm}/sync": {
      "post": {
        "operationId": "syncDomain",
        "summary": "Synchronize users from authentication realm",
        "tags": ["Access"],
        "parameters": [
          { "name": "realm", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "dry-run": { "type": "boolean" },
                  "enable-new": { "type": "boolean" },
                  "remove-vanished": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Sync completed" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/openid/auth-url": {
      "post": {
        "operationId": "getOpenIdAuthUrl",
        "summary": "Generate OpenID Connect redirect URL",
        "tags": ["Access"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "realm": { "type": "string" },
                  "redirect-url": { "type": "string" }
                },
                "required": ["realm", "redirect-url"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Auth URL", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "string" } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/openid/login": {
      "post": {
        "operationId": "openIdLogin",
        "summary": "Complete OpenID Connect authentication",
        "tags": ["Access"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "code": { "type": "string" },
                  "redirect-url": { "type": "string" },
                  "state": { "type": "string" }
                },
                "required": ["code", "redirect-url", "state"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/TicketResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Authentication failed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/password": {
      "put": {
        "operationId": "changePassword",
        "summary": "Change user password",
        "tags": ["Access"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userid": { "type": "string" },
                  "password": { "type": "string" },
                  "confirmation-password": { "type": "string" }
                },
                "required": ["userid", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password changed" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/permissions": {
      "get": {
        "operationId": "getPermissions",
        "summary": "List user permissions",
        "tags": ["Access"],
        "parameters": [
          { "name": "auth-id", "in": "query", "schema": { "type": "string" } },
          { "name": "path", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Permissions", "content": { "application/json": { "schema": { "type": "object" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/roles": {
      "get": {
        "operationId": "listRoles",
        "summary": "List available roles",
        "tags": ["Access"],
        "responses": {
          "200": { "description": "Roles list", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List users",
        "tags": ["Users"],
        "parameters": [
          { "name": "include_tokens", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": { "description": "User list", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createUser",
        "summary": "Create a new user",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateUserRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "User created" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/users/{userid}": {
      "get": {
        "operationId": "getUser",
        "summary": "Get user details",
        "tags": ["Users"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "User details", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/User" } } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateUser",
        "summary": "Update user",
        "tags": ["Users"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "firstname": { "type": "string" },
                  "lastname": { "type": "string" },
                  "enable": { "type": "boolean" },
                  "expire": { "type": "integer" },
                  "comment": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "User updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteUser",
        "summary": "Delete user",
        "tags": ["Users"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "User deleted" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/users/{userid}/token": {
      "get": {
        "operationId": "listUserTokens",
        "summary": "List API tokens for a user",
        "tags": ["Users"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Token list", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object" } } } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/users/{userid}/token/{token-name}": {
      "get": {
        "operationId": "getToken",
        "summary": "Get API token info",
        "tags": ["Users"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "token-name", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Token details", "content": { "application/json": { "schema": { "type": "object" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createToken",
        "summary": "Generate a new API token",
        "tags": ["Users"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "token-name", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "comment": { "type": "string" },
                  "enable": { "type": "boolean" },
                  "expire": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token created", "content": { "application/json": { "schema": { "type": "object", "properties": { "data": { "type": "object", "properties": { "tokenid": { "type": "string" }, "value": { "type": "string" } } } } } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateToken",
        "summary": "Update API token",
        "tags": ["Users"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "token-name", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "comment": { "type": "string" },
                  "enable": { "type": "boolean" },
                  "expire": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteToken",
        "summary": "Delete API token",
        "tags": ["Users"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "token-name", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Token deleted" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/users/{userid}/unlock-tfa": {
      "put": {
        "operationId": "unlockTfa",
        "summary": "Unlock user TFA",
        "tags": ["Users"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "TFA unlocked" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/tfa": {
      "get": {
        "operationId": "listTfa",
        "summary": "List all TFA configurations",
        "tags": ["Access"],
        "responses": {
          "200": { "description": "TFA configurations", "content": { "application/json": { "schema": { "type": "object" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/access/tfa/{userid}/{id}": {
      "get": {
        "operationId": "getTfaEntry",
        "summary": "Get TFA entry",
        "tags": ["Access"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "TFA entry", "content": { "application/json": { "schema": { "type": "object" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "operationId": "updateTfaEntry",
        "summary": "Update TFA entry",
        "tags": ["Access"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": { "description": "TFA entry updated" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteTfaEntry",
        "summary": "Delete TFA entry",
        "tags": ["Access"],
        "parameters": [
          { "name": "userid", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "TFA entry deleted" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/admin/datastore/{store}/active-operations": {
      "get": {
        "operationId": "getActiveOperations",
        "summary": "Get active datastore operations",
        "tags": ["Datastore"],
        "parameters": [
          { "name": "store", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Active operations", "content": { "application/json": { "schema": { "type": "object" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "errors": { "type": "object" },
          "data": { "type": "object" }
        }
      },
      "TicketResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "ticket": { "type": "string" },
              "CSRFPreventionToken": { "type": "string" },
              "username": { "type": "string" }
            }
          }
        }
      },
      "AclEntry": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "roleid": { "type": "string" },
          "ugid": { "type": "string" },
          "ugid_type": { "type": "string" },
          "propagate": { "type": "boolean" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "userid": { "type": "string" },
          "email": { "type": "string" },
          "firstname": { "type": "string" },
          "lastname": { "type": "string" },
          "enable": { "type": "boolean" },
          "expire": { "type": "integer" },
          "comment": { "type": "string" },
          "tokens": { "type": "array", "items": { "type": "object" } }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "properties": {
          "userid": { "type": "string" },
          "email": { "type": "string" },
          "firstname": { "type": "string" },
          "lastname": { "type": "string" },
          "password": { "type": "string" },
          "enable": { "type": "boolean" },
          "expire": { "type": "integer" },
          "comment": { "type": "string" }
        },
        "required": ["userid"]
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "PBSAuthCookie",
        "description": "Authentication ticket cookie"
      },
      "csrfToken": {
        "type": "apiKey",
        "in": "header",
        "name": "CSRFPreventionToken",
        "description": "CSRF prevention token for state-changing requests"
      }
    }
  },
  "security": [
    {
      "cookieAuth": [],
      "csrfToken": []
    }
  ]
}