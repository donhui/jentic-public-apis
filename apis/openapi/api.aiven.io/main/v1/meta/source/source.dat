    "/account": {
      "post": {
        "summary": "Create a new account",
        "tags": [
          "Account"
        ],
        "operationId": "AccountCreate",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountCreateRequestBody"
              },
              "example": {
                "account_name": "Aiven Ltd",
                "parent_account_id": "a22ba494e096",
                "primary_billing_group_id": "ffb3f0cd-5532-4eb9-8867-f2cac5823492"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response",
            "content": {
