                ],
                "billing_extra_text": "Purchase order: PO100018",
                "billing_group_id": "ffb3f0cd-5532-4eb9-8867-f2cac5823492",
                "card_id": "9330c086-8781-11e5-89ff-5404a64abfef",
                "city": "Helsinki",
                "cloud": "aws-eu-central-1",
                "company": "My Company",
                "copy_from_project": "myexistingproject",
                "copy_tags": true,
                "country_code": "FI",
                "project": "myproject",
                "state": "",
                "tags": {},
                "tech_emails": [
                  {
                    "email": "jane@example.com"
                  }
                ],
                "use_source_project_billing_group": false,
                "vat_id": "FI27957435",
                "zip_code": "01234"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectCreateResponse"
