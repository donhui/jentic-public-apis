              },
              "required": [
                "email"
              ]
            }
          },
          "billing_extra_text": {
            "type": "string",
            "maxLength": 1000,
            "description": "[DEPRECATED] Extra text to be included in all project invoices"
          },
          "billing_group_id": {
            "type": "string",
            "minLength": 36,
            "maxLength": 36,
            "description": "Billing group ID"
          },
          "card_id": {
            "type": "string",
            "maxLength": 64,
            "description": "[DEPRECATED] Credit card ID"
          },
          "city": {
            "type": "string",
            "maxLength": 512,
            "description": "[DEPRECATED] Address city"
          },
          "cloud": {
            "type": "string",
            "maxLength": 256,
            "description": "Target cloud"
          },
