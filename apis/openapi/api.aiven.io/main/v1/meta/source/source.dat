                        "maxLength": 256,
                        "description": "the host or * for all hosts"
                      },
                      "id": {
                        "type": "string",
                        "maxLength": 40,
                        "description": "ID"
                      },
                      "operation": {
                        "type": "string",
                        "description": "Kafka ACL operation represents an operation which an ACL grants or denies permission to perform",
                        "enum": [
                          "All",
                          "Alter",
                          "AlterConfigs",
                          "ClusterAction",
                          "Create",
                          "CreateTokens",
