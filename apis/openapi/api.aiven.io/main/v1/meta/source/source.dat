            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountAttachPaymentMethodResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "tokenAuth": [],
            "oauth2": [
              "accounts:write",
              "payments:write"
            ]
          }
