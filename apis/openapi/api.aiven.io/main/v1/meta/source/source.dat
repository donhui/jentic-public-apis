                        "monday",
                        "tuesday",
                        "wednesday",
                        "thursday",
                        "friday",
                        "saturday",
                        "sunday",
                        "never"
                      ]
                    },
                    "enabled": {
                      "type": "boolean",
                      "description": "Service maintenance enabled"
                    },
                    "time": {
                      "type": "string",
                      "minLength": 8,
                      "maxLength": 8,
                      "description": "Time for installing updates, UTC"
                    },
                    "updates": {
                      "type": "array",
                      "description": "List of updates waiting to be installed",
                      "items": {
                        "type": "object",
                        "properties": {
                          "deadline": {
                            "type": "string",
