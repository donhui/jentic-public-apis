                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "This feature is not enabled in your context, please contact support to enable it.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "title": "Human readable error message"
                    },
                    "errors": {
                      "type": "array",
                      "title": "List of error details. Typically there is only one element",
                      "items": {
                        "type": "object",
                        "properties": {
                          "message": {
                            "type": "string",
                            "title": "Human readable error message"
                          },
                          "error_code": {
                            "type": "string",
                            "enum": [
                              "feature_not_enabled"
                            ],
                            "title": "Machine processable error code. Clients must be prepared to handle new codes.",
                            "description": "feature_not_enabled: This feature is not enabled in your context, please contact support to enable it"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "tokenAuth": [],
            "oauth2": [
              "projects:write"
            ]
          }
        ]
      }
    },
