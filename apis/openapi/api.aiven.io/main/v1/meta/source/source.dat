                    "title": "Permitted pub/sub channel patterns",
                    "items": {
                      "type": "string"
                    }
                  },
                  "valkey_acl_commands": {
                    "type": "array",
                    "maxItems": 256,
                    "description": "Rules for individual commands",
                    "items": {
                      "type": "string"
                    }
                  },
