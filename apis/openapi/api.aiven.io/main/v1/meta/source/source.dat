                    },
                    "country": {
                      "type": "string",
                      "maxLength": 128,
                      "description": "Country"
                    },
                    "country_code": {
                      "type": "string",
                      "maxLength": 2,
                      "description": "Two letter ISO country code"
                    },
                    "exp_month": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 12,
                      "description": "Expiration month"
                    },
                    "exp_year": {
                      "type": "integer",
                      "minimum": 2015,
                      "maximum": 2100,
                      "description": "Expiration year"
                    },
                    "last4": {
                      "type": "string",
                      "description": "Credit card last four digits"
                    },
                    "name": {
                      "type": "string",
                      "maxLength": 256,
                      "description": "Name on the credit card"
                    },
