              ]
            }
          },
          "create_time": {
            "type": "string",
            "maxLength": 36,
            "description": "VPC creation timestamp"
          },
          "display_name": {
            "type": "string",
            "maxLength": 64,
            "description": "User defined display name for this VPC"
          },
          "errors": {
            "type": "array",
            "description": "List of errors occurred during request processing",
            "items": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
