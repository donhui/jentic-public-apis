                      "type": "string",
                      "description": "Role of this node. Only returned for a subset of service types",
                      "enum": [
                        "master",
                        "standby",
                        "read-replica"
                      ]
                    },
                    "roles": {
                      "type": "string",
                      "description": "A role string indicating the node's roles in the OpenSearch cluster. Only populated for OpenSearch services using cluster plans. Format: first character is '*' (elected cluster manager) or '-' (not elected), followed by role letters: 'd' (data), 'i' (ingest), 'm' (cluster_manager eligible), 'c' (coordinating), 'L' (ML), 'D' (Dashboards). Example: '*mc' means elected cluster manager with cluster_manager and coordinating roles.",
                      "title": "Roles of this node. Only returned for OpenSearch services with cluster plans"
                    },
                    "shard": {
                      "type": "object",
                      "description": "Shard of this node. Only returned for a subset of service types",
