                },
                "source_service": {
                  "type": "string",
                  "maxLength": 64,
                  "description": "Source service name"
                },
                "user_config": {
                  "type": "object",
                  "description": "Service type-specific settings",
                  "properties": {}
                }
              },
              "required": [
