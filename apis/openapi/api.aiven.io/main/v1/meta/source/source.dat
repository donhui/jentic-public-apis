            }
          }
        },
        "responses": {
          "200": {
            "description": "Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountAuthenticationMethodCreateResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "tokenAuth": [],
            "oauth2": [
              "accounts:write",
              "authentication:write"
            ]
          }
        ]
      },
