              },
              "service_notifications": {
                "type": "array",
                "description": "Service notifications",
                "items": {
                  "type": "object",
                  "properties": {
                    "level": {
                      "type": "string",
                      "description": "Notification level",
                      "enum": [
                        "notice",
                        "warning"
                      ]
                    },
                    "message": {
                      "type": "string",
                      "maxLength": 1024,
                      "description": "Human notification message"
                    },
                    "metadata": {
                      "type": "object",
                      "description": "Notification metadata",
                      "properties": {
                        "end_of_life_help_article_url": {
                          "type": "string",
