                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "maxLength": 40,
                      "description": "ID"
                    },
                    "permission": {
                      "type": "string",
                      "description": "Kafka permission",
                      "enum": [
                        "admin",
                        "read",
                        "readwrite",
                        "write"
                      ]
                    },
                    "topic": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 249,
