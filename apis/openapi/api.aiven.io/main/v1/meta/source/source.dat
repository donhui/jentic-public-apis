                      "tuesday",
                      "wednesday",
                      "thursday",
                      "friday",
                      "saturday",
                      "sunday",
                      "never"
                    ]
                  },
                  "enabled": {
                    "type": "boolean",
                    "description": "Service maintenance enabled"
                  },
                  "time": {
                    "type": "string",
                    "minLength": 8,
                    "maxLength": 8,
                    "description": "Time for installing updates, UTC"
                  },
                  "updates": {
                    "type": "array",
