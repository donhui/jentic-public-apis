                    },
                    "username": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 64,
                      "description": "Username"
                    }
                  },
                  "required": [
                    "permission",
                    "topic",
                    "username"
                  ]
                }
              },
              "backups": {
                "type": "array",
                "description": "List of backups for the service",
                "items": {
                  "type": "object",
                  "properties": {
                    "additional_regions": {
                      "type": "array",
                      "description": "Additional backup regions, if available",
                      "items": {
                        "type": "object",
                        "properties": {
                          "cloud": {
                            "type": "string",
                            "maxLength": 256,
                            "description": "Target cloud"
                          },
                          "pause_reason": {
                            "type": "string",
                            "description": "Reason for pausing the backup synchronization"
                          },
                          "paused": {
                            "type": "boolean",
