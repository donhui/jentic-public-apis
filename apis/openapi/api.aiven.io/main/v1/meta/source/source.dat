                          "items": {
                            "type": "string"
                          }
                        },
                        "valkey_acl_keys": {
                          "type": "array",
                          "maxItems": 256,
                          "description": "Key access rules",
                          "items": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "access_key": {
                      "type": "string",
                      "description": "Access key for TLS client authentication"
                    },
                    "authentication": {
                      "type": "string",
                      "description": "Service specific authentication details. Currently only used for MySQL where accepted options are 'mysql_native_password' and 'caching_sha2_password', latter being default when this is not explicitly set.",
                      "title": "Authentication details",
                      "enum": [
                        "null",
