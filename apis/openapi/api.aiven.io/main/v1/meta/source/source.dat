                          "DENY"
                        ]
                      },
                      "principal": {
                        "type": "string",
                        "minLength": 0,
                        "maxLength": 256,
                        "description": "principal is in 'principalType:name' format"
                      },
                      "resource_name": {
                        "type": "string",
                        "minLength": 0,
                        "maxLength": 256,
                        "description": "Resource pattern used to match specified resources"
                      },
                      "resource_type": {
                        "type": "string",
