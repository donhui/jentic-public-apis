                "linked_domains": [
                  {
                    "domain_id": "domain-a9s7d6f98as7d6"
                  }
                ],
                "saml_assertion_signed_enabled": true,
                "saml_authn_requests_signed_enabled": true,
                "saml_certificate": "-----BEGIN CERTIFICATE...",
                "saml_digest_algorithm": "sha256",
                "saml_entity_id": "https://example.com/saml2/entity",
                "saml_field_mapping": {
                  "email": "email",
                  "first_name": "first_name",
                  "groups": "groups",
                  "identity": "email",
                  "last_name": "last_name",
                  "real_name": "full_name"
