{
  "openapi": "3.0.3",
  "info": {
    "title": "Barchart OnDemand Market Data API",
    "version": "1.0.0",
    "description": "Barchart OnDemand provides real-time and historical market data through a RESTful API. Endpoints cover quotes, historical prices, company profiles, equity options, and more.",
    "x-jentic-source-url": "https://www.barchart.com/ondemand/api"
  },
  "servers": [
    {
      "url": "https://ondemand.websol.barchart.com",
      "description": "Barchart OnDemand Production"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Quotes",
      "description": "Real-time and delayed price data"
    },
    {
      "name": "History",
      "description": "Historical time series data"
    },
    {
      "name": "Profiles",
      "description": "Company and instrument profile data"
    },
    {
      "name": "Options",
      "description": "Equity options data"
    },
    {
      "name": "Crypto",
      "description": "Cryptocurrency data"
    },
    {
      "name": "Fundamentals",
      "description": "Financial statements and fundamental data"
    },
    {
      "name": "Market",
      "description": "Market leaders and index data"
    },
    {
      "name": "News",
      "description": "Financial news and articles"
    },
    {
      "name": "Analytics",
      "description": "Technical analysis and signals"
    },
    {
      "name": "ETFs",
      "description": "ETF profiles and holdings"
    },
    {
      "name": "Corporate Actions",
      "description": "Dividends, earnings, and corporate events"
    }
  ],
  "paths": {
    "/getQuote.json": {
      "get": {
        "operationId": "getquote",
        "summary": "Get real-time or delayed quote data",
        "description": "Returns real-time or delayed price data for one or more financial instruments.",
        "tags": [
          "Quotes"
        ],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API authentication key"
          },
          {
            "name": "symbols",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma or semicolon-delimited list of financial instrument symbols"
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-delimited list of specific data fields to retrieve"
          },
          {
            "name": "only",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Return only specified fields"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getHistory.json": {
      "get": {
        "operationId": "gethistory",
        "summary": "Get historical time series data",
        "description": "Returns historical price data for a financial instrument with configurable granularity.",
        "tags": [
          "History"
        ],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API authentication key"
          },
          {
            "name": "symbol",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "A symbol or code that identifies a financial instrument"
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "ticks",
                "minutes",
                "daily",
                "weekly",
                "monthly",
                "quarterly",
                "yearly",
                "nearbyMinutes",
                "formTMinutes",
                "dailyNearest",
                "dailyContinue"
              ]
            },
            "description": "Data granularity type"
          },
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Start date in format yyyymmdd[hhmm[ss]]"
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "End date in format yyyymmdd[hhmm[ss]]"
          },
          {
            "name": "maxRecords",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Maximum number of records to return"
          },
          {
            "name": "interval",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            },
            "description": "Minutes per bar for minute queries"
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "asc"
            },
            "description": "Chronological ordering"
          },
          {
            "name": "splits",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "Adjust for stock splits"
          },
          {
            "name": "dividends",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "Adjust for dividends"
          },
          {
            "name": "volume",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "total",
                "sum",
                "contract",
                "sumcontract",
                "sumtotal"
              ]
            },
            "description": "Volume calculation type"
          },
          {
            "name": "backAdjust",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Back-adjust futures contracts"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HistoryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getProfile.json": {
      "get": {
        "operationId": "getprofile",
        "summary": "Get company or instrument profile",
        "description": "Returns profile information for one or more financial instruments including company details, financial metrics, and identifiers.",
        "tags": [
          "Profiles"
        ],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API authentication key"
          },
          {
            "name": "symbols",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma or semicolon-delimited list of financial instrument symbols"
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-delimited list of specific fields to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/getEquityOptions.json": {
      "get": {
        "operationId": "getequityoptions",
        "summary": "Get equity options data",
        "description": "Returns intraday or end-of-day options data for equity symbols.",
        "tags": [
          "Options"
        ],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API authentication key"
          },
          {
            "name": "underlying_symbols",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Valid equity symbol(s), maximum 5 tickers per request"
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Call",
                "Put"
              ]
            },
            "description": "Option type filter"
          },
          {
            "name": "strikePrice",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "description": "Strike price of the option"
          },
          {
            "name": "expirationMonth",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Numeric month representation (e.g., 05)"
          },
          {
            "name": "expirationDate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Expiration date in YYYY-MM-DD format"
          },
          {
            "name": "optionType",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "Monthly",
                "Weekly"
              ]
            },
            "description": "Monthly or Weekly options; both returned by default"
          },
          {
            "name": "fields",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Additional fields requested (comma/semicolon-delimited)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EquityOptionsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
