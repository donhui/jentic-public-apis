{
  "openapi": "3.0.3",
  "info": {
    "title": "Acute API",
    "version": "1.0.0",
    "description": "Acute is a customer feedback management tool. This API provides access to feedback cards, conversations, and integrations with Intercom and GitHub.",
    "x-jentic-source-url": "https://docs.getacute.io"
  },
  "servers": [
    {
      "url": "https://admin.api.getacute.io"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Cards", "description": "Feedback cards" },
    { "name": "Conversations", "description": "Feedback conversations" },
    { "name": "Integrations", "description": "Third-party integrations" }
  ],
  "paths": {
    "/zapier/cards": {
      "get": {
        "operationId": "listCards",
        "summary": "Retrieve all feedback cards",
        "tags": ["Cards"],
        "responses": {
          "200": {
            "description": "List of feedback cards",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Card"
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/zapier/conversations": {
      "get": {
        "operationId": "listConversations",
        "summary": "Retrieve all feedback conversations",
        "tags": ["Conversations"],
        "responses": {
          "200": {
            "description": "List of conversations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Conversation"
                  }
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/intercom/cards/create-tag": {
      "post": {
        "operationId": "createIntercomTag",
        "summary": "Generate an Intercom tag for a feedback card",
        "tags": ["Integrations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Feedback card identifier"
                  }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tag created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IntercomTag"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/zapier/cards/add-github-issue": {
      "post": {
        "operationId": "addGithubIssue",
        "summary": "Link a GitHub issue to a feedback card",
        "tags": ["Integrations"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cardId": {
                    "type": "string",
                    "description": "Feedback card identifier"
                  },
                  "issueNumber": {
                    "type": "string",
                    "description": "GitHub issue number"
                  }
                },
                "required": ["cardId", "issueNumber"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "GitHub issue linked to card",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Card"
                }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "Card": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "state": { "type": "string" },
          "voteCount": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "author": {
            "$ref": "#/components/schemas/Author"
          },
          "url": { "type": "string", "format": "uri" },
          "githubIssueNumber": { "type": "string", "nullable": true }
        }
      },
      "Conversation": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "body": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "author": {
            "$ref": "#/components/schemas/Author"
          },
          "feedbackId": { "type": "string" },
          "feedbackTitle": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      },
      "Author": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      },
      "IntercomTag": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "string" },
          "name": { "type": "string", "description": "Generated name with 'acute' prefix and feedback title" }
        }
      }
    }
  }
}