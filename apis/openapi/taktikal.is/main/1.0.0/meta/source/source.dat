    "/signing/process/{ProcessKey}/signee/{SigneeKey}/remind": {
      "delete": {
        "operationId": "cancelProcessReminder",
        "summary": "Cancel signing reminders for signee in process",
        "tags": ["Signing Process"],
        "parameters": [
