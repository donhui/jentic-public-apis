          { "name": "EndDate", "in": "query", "required": true, "schema": { "type": "string", "format": "date-time" } },
          { "name": "MinDistance", "in": "query", "schema": { "type": "number" } },
          { "name": "MaxDistance", "in": "query", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": {
            "description": "Company distance and time results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatsDistanceAndTimeResult" }
              }
            }
          }
        }
      }
    },
    "/watchlist/person": {
      "post": {
        "operationId": "watchlistPersonLookup",
        "summary": "PEP and sanction lookup for person",
        "tags": ["Watchlist"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WatchListRequestPublic" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Watchlist results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WatchListResponse" }
              }
            }
          }
        }
      }
    },
    "/watchlist/company": {
      "post": {
        "operationId": "watchlistCompanyLookup",
        "summary": "PEP and sanction lookup for company",
        "tags": ["Watchlist"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WatchListCompanyRequestPublic" }
