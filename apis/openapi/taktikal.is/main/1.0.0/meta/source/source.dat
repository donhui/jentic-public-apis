          }
        },
        "responses": {
          "200": {
            "description": "Signee updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Signee" }
              }
            }
          }
        },
        "security": []
      },
      "delete": {
        "operationId": "removeSignee",
        "summary": "Remove a signee",
        "tags": ["Signing Process"],
        "parameters": [
          { "name": "ProcessKey", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "SigneeKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Signee removed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Signee" }
              }
            }
          }
        },
        "security": []
      }
    },
