            }
          }
        },
        "security": []
      }
    },
    "/signing/{ProcessKey}/signee/{SigneeKey}/passcode": {
      "post": {
        "operationId": "authenticateSigneeWithPasscode",
        "summary": "Authenticate signee into signing process via passcode",
