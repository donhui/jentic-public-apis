{
  "openapi": "3.0.3",
  "info": {
    "title": "Taktikal Core API",
    "description": "Taktikal is a digital signing and onboarding platform providing e-signing, sequential signing, authentication, compliance, document management, and webhook capabilities.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://onboardingdev.taktikal.is/api/swagger-ui"
  },
  "servers": [
    {
      "url": "https://onboardingdev.taktikal.is/api",
      "description": "Taktikal Development Server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    { "name": "Activity", "description": "Signing activity logs" },
    { "name": "Sequential Signing", "description": "Sequential (bulk) signing operations" },
    { "name": "Signing Process", "description": "Individual signing process management" },
    { "name": "Management", "description": "Administrative signing operations" },
    { "name": "Authentication", "description": "E-ID authentication flows" },
    { "name": "Documents", "description": "PDF and document management" },
    { "name": "Flows", "description": "Flow configuration" },
    { "name": "SmartFlows", "description": "SmartFlow schema management" },
    { "name": "Webhooks", "description": "Webhook management" },
    { "name": "Compliance", "description": "Compliance and watchlist checks" },
    { "name": "Statistics", "description": "Distance and time statistics" },
    { "name": "Watchlist", "description": "PEP and sanction lookups" },
    { "name": "API Keys", "description": "API key validation" }
  ],
  "paths": {
    "/signing/activity/total": {
      "get": {
        "operationId": "getActivityLogTotal",
        "summary": "Get activity log total for paging support",
        "tags": ["Activity"],
        "parameters": [
          { "name": "StartDate", "in": "query", "required": true, "schema": { "type": "string", "format": "date-time" } },
          { "name": "EndDate", "in": "query", "required": true, "schema": { "type": "string", "format": "date-time" } },
          { "name": "User", "in": "query", "schema": { "type": "string" } },
          { "name": "ProcessKey", "in": "query", "schema": { "type": "string" } },
          { "name": "FlowType", "in": "query", "schema": { "type": "string" } },
          { "name": "FlowKey", "in": "query", "schema": { "type": "string" } },
          { "name": "Search", "in": "query", "schema": { "type": "string" } },
          { "name": "StatusFilter", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Activity log total",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ActivityLogTotal" }
              }
            }
          }
        }
      }
    },
    "/signing/activity": {
      "get": {
        "operationId": "getActivityLog",
        "summary": "Get activity log",
        "tags": ["Activity"],
        "parameters": [
          { "name": "StartDate", "in": "query", "required": true, "schema": { "type": "string", "format": "date-time" } },
          { "name": "EndDate", "in": "query", "required": true, "schema": { "type": "string", "format": "date-time" } },
          { "name": "Take", "in": "query", "schema": { "type": "integer" } },
          { "name": "Skip", "in": "query", "schema": { "type": "integer" } },
          { "name": "User", "in": "query", "schema": { "type": "string" } },
          { "name": "ProcessKey", "in": "query", "schema": { "type": "string" } },
          { "name": "FlowType", "in": "query", "schema": { "type": "string" } },
          { "name": "FlowKey", "in": "query", "schema": { "type": "string" } },
          { "name": "Search", "in": "query", "schema": { "type": "string" } },
          { "name": "StatusFilter", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Activity log entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/SigningProcessActivityLogWrapper" }
                }
              }
            }
          }
        }
      }
    },
    "/signing/sequential/{SequenceKey}": {
      "post": {
        "operationId": "authenticateIntoSequence",
        "summary": "Authenticate a signee into a signing sequence",
        "tags": ["Sequential Signing"],
        "parameters": [
          { "name": "SequenceKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RequestToViewSequence" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sequential signing details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SequentialSigning" }
              }
            }
          }
        },
        "security": []
      }
    },
    "/signing/sequential/{SequenceKey}/auth": {
      "post": {
        "operationId": "startSequenceAuth",
        "summary": "Start authentication with e-ID for sequence",
        "tags": ["Sequential Signing"],
        "parameters": [
          { "name": "SequenceKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RequestToViewSequenceStart" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Auth started",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StartAuthResponse" }
              }
            }
          }
        },
        "security": []
      }
    },
    "/signing/sequential/{SequenceKey}/auth/poll": {
      "post": {
        "operationId": "pollSequenceAuth",
        "summary": "Poll authentication completion for sequence",
        "tags": ["Sequential Signing"],
        "parameters": [
          { "name": "SequenceKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RequestToViewSequencePoll" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Poll result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RequestToViewSequencePollResult" }
              }
            }
          }
        },
        "security": []
      }
    },
    "/signing/sequential/{SequenceKey}/signee": {
      "post": {
        "operationId": "addSequentialSignee",
        "summary": "Add a sequential signee",
        "tags": ["Sequential Signing"],
        "parameters": [
          { "name": "SequenceKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddSequentialSignee" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signee added",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SequentialSigningSignee" }
              }
            }
          }
        },
        "security": []
      }
    },
    "/signing/sequential/{SequenceKey}/signee/{SequentialSigneeKey}": {
      "get": {
        "operationId": "getSequentialSigning",
        "summary": "Get sequential signing by signee key",
        "tags": ["Sequential Signing"],
        "parameters": [
          { "name": "SequenceKey", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "SequentialSigneeKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Sequential signing details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SequentialSigning" }
              }
            }
          }
        },
        "security": []
      },
      "put": {
        "operationId": "updateSequentialSignee",
        "summary": "Update a sequential signee",
        "tags": ["Sequential Signing"],
        "parameters": [
          { "name": "SequenceKey", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "SequentialSigneeKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateSequentialSignee" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signee updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SequentialSigningSignee" }
              }
            }
          }
        },
        "security": []
      },
      "delete": {
        "operationId": "removeSequentialSignee",
        "summary": "Remove a sequential signee",
        "tags": ["Sequential Signing"],
        "parameters": [
          { "name": "SequenceKey", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "SequentialSigneeKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Signee removed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SequentialSigningSignee" }
              }
            }
          }
        },
        "security": []
      }
    },
    "/signing/sequential/{SequenceKey}/signee/{SequentialSigneeKey}/passcode": {
      "post": {
        "operationId": "authenticateSequentialSigneeWithPasscode",
        "summary": "Authenticate signee into signing sequence via passcode",
        "tags": ["Sequential Signing"],
        "parameters": [
          { "name": "SequenceKey", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "SequentialSigneeKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RequestToViewPasscodeSequence" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SequentialSigning" }
              }
            }
          }
        },
        "security": []
      }
    },
    "/signing/sequential/{SequenceKey}/signee/{SequentialSigneeKey}/Token": {
      "post": {
        "operationId": "createSequenceAccessToken",
        "summary": "Create access token for signing process in sequence",
        "tags": ["Sequential Signing"],
        "parameters": [
          { "name": "SequenceKey", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "SequentialSigneeKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateSequenceAccessToken" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TaktikalAccessToken" }
              }
            }
          }
        }
      }
    },
    "/signing/{ProcessKey}/signee": {
      "post": {
        "operationId": "addSignee",
        "summary": "Add a signee to existing process",
        "tags": ["Signing Process"],
        "parameters": [
          { "name": "ProcessKey", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
