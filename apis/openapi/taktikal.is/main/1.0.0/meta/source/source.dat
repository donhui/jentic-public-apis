        },
        "security": []
      },
      "delete": {
        "operationId": "deleteAttachmentReference",
        "summary": "Delete attachment from signing process",
        "tags": ["Documents"],
        "parameters": [
          { "name": "ProcessKey", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "Id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "FileName", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "Attachment deleted" }
        },
        "security": []
      }
    },
    "/signing/sign/{ProcessKey}/signee/{SigneeKey}": {
      "post": {
        "operationId": "requestToSign",
        "summary": "Start signing process for signee",
