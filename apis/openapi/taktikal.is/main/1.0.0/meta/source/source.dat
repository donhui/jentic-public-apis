            "description": "Authenticated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SigningProcess" }
              }
            }
          }
        },
        "security": []
      }
    },
    "/signing/{ProcessKey}/signee/{SigneeKey}/meta": {
      "put": {
        "operationId": "updateSigningProcessMeta",
        "summary": "Update signing process meta object",
        "tags": ["Signing Process"],
        "parameters": [
          { "name": "ProcessKey", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "SigneeKey", "in": "path", "required": true, "schema": { "type": "string" } }
