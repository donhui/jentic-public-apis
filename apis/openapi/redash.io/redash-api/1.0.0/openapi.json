{
  "openapi": "3.0.3",
  "info": {
    "title": "Redash API",
    "description": "Redash is a data visualization and dashboarding platform. The API allows you to programmatically create queries, refresh data, manage dashboards, and access query results.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://redash.io/help/user-guide/integrations-and-api/api",
    "contact": {
      "name": "Redash Support",
      "url": "https://redash.io/help"
    }
  },
  "servers": [
    {
      "url": "https://{instance}.redash.io/api",
      "description": "Redash instance server",
      "variables": {
        "instance": {
          "default": "app",
          "description": "Your Redash instance subdomain"
        }
      }
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Queries",
      "description": "Query management operations"
    },
    {
      "name": "Dashboards",
      "description": "Dashboard management operations"
    },
    {
      "name": "Data Sources",
      "description": "Data source operations"
    },
    {
      "name": "Users",
      "description": "User management operations"
    }
  ],
  "paths": {
    "/queries": {
      "get": {
        "operationId": "listQueries",
        "summary": "List all queries",
        "description": "Returns a list of all queries accessible to the user",
        "tags": ["Queries"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 250
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueriesListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createQuery",
        "summary": "Create a new query",
        "description": "Creates a new query in Redash",
        "tags": ["Queries"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryCreate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Query"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/queries/{query_id}": {
      "get": {
        "operationId": "getQuery",
        "summary": "Get query by ID",
        "description": "Returns details of a specific query",
        "tags": ["Queries"],
        "parameters": [
          {
            "name": "query_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Query"
                }
              }
            }
          },
          "404": {
            "description": "Query not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "updateQuery",
        "summary": "Update query",
        "description": "Updates an existing query",
        "tags": ["Queries"],
        "parameters": [
          {
            "name": "query_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Query"
                }
              }
            }
          },
          "404": {
            "description": "Query not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteQuery",
        "summary": "Delete query",
        "description": "Deletes a query",
        "tags": ["Queries"],
        "parameters": [
          {
            "name": "query_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Query deleted successfully"
          },
          "404": {
            "description": "Query not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/queries/{query_id}/results": {
      "post": {
        "operationId": "refreshQuery",
        "summary": "Refresh query results",
        "description": "Executes a query and returns the results",
        "tags": ["Queries"],
        "parameters": [
          {
            "name": "query_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "max_age",
            "in": "query",
            "required": false,
            "description": "Maximum age in seconds for cached results",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "parameters": {
                    "type": "object",
                    "description": "Query parameters"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResults"
                }
              }
            }
          },
          "404": {
            "description": "Query not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/dashboards": {
      "get": {
        "operationId": "listDashboards",
        "summary": "List all dashboards",
        "description": "Returns a list of all dashboards",
        "tags": ["Dashboards"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DashboardsListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/dashboards/{dashboard_slug}": {
      "get": {
        "operationId": "getDashboard",
        "summary": "Get dashboard by slug",
        "description": "Returns details of a specific dashboard",
        "tags": ["Dashboards"],
        "parameters": [
          {
            "name": "dashboard_slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Dashboard"
                }
              }
            }
          },
          "404": {
            "description": "Dashboard not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/data_sources": {
      "get": {
        "operationId": "listDataSources",
        "summary": "List all data sources",
        "description": "Returns a list of all configured data sources",
        "tags": ["Data Sources"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataSource"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "operationId": "listUsers",
        "summary": "List all users",
        "description": "Returns a list of all users",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key",
        "description": "API key for authentication"
      }
    },
    "schemas": {
      "QueriesListResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Query"
            }
          }
        }
      },
      "Query": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "data_source_id": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "is_archived": {
            "type": "boolean"
          },
          "is_draft": {
            "type": "boolean"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "QueryCreate": {
        "type": "object",
        "required": ["name", "query", "data_source_id"],
        "properties": {
          "name": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "data_source_id": {
            "type": "integer"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "QueryUpdate": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "is_archived": {
            "type": "boolean"
          }
        }
      },
      "QueryResults": {
        "type": "object",
        "properties": {
          "query_result": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "query_hash": {
                "type": "string"
              },
              "query": {
                "type": "string"
              },
              "data": {
                "type": "object",
                "properties": {
                  "columns": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "type": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "rows": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                }
              },
              "data_source_id": {
                "type": "integer"
              },
              "runtime": {
                "type": "number"
              },
              "retrieved_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "DashboardsListResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Dashboard"
            }
          }
        }
      },
      "Dashboard": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "is_archived": {
            "type": "boolean"
          },
          "is_draft": {
            "type": "boolean"
          },
          "widgets": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "DataSource": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "syntax": {
            "type": "string"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "error": {
            "type": "string",
            "description": "Error details"
          }
        }
      }
    }
  }
}