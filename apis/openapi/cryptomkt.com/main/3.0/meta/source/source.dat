                "payin_enabled": true,
                "payout_enabled": true,
                "precision_payout": "0.01",
                "payout_fee": "50.000000000000",
                "payout_is_payment_id": false,
                "payin_payment_id": false,
                "payin_confirmations": 2,
                "low_processing_time": "11.443",
                "high_processing_time": "54.165",
