      }
    },
    "/wallet/crypto/withdraw": {
      "post": {
        "tags": [
          "Withdrawals"
        ],
        "summary": "Create a withdrawal",
        "description": "Creates a withdrawal transaction, and, depending on the operation scheme:\n  * **one-phase**\u2014the transaction is committed automatically;\n  * **two-phase**\u2014the transaction remains in `\"PENDING\"` state until the user commits or rolls it back.\n\n\u26a0\ufe0f Depending on the `use_offchain` parameter, a withdrawal may be processed off chain.\n\n\u26a0\ufe0f Depending on the `use_offchain` parameter, a withdrawal may be processed off chain.\n\n\u26a0\ufe0f The platform charges fees for execution of a withdrawal unless it is processed off chain. Fees amount is displayed in the transaction history.\n\n\u26a0\ufe0f Apart from available balance, the amount of a withdrawal must exceed the sum of:\n  * fees;\n  * the total amount reserved on all wallets;\n  * the total amount reserved on all exchange accounts.\n\n\u26a0\ufe0f An operation may fail due to the following reasons:\n  * the user cannot perform this type of operation based on:\n    * temporary account limitations;\n    * no active 2FA.\n  * it does not pass pre-AML checks.\n\n\u26a0\ufe0f Created but not committed withdrawal will reserve pending amount on the sender wallet affecting the balance remaining for other withdrawals.\n\n\u2139\ufe0f Call `GET /public/currency/{currency}` and check `payout_enabled` to determine if withdrawals are allowed for the currency.\n\n\u2139\ufe0f Call `GET /wallet/crypto/fee/estimate` to check whether off-chain transaction are allowed for the given target address.\n\n\u2139\ufe0f Call `GET /wallet/transactions/{id}` to check out the resulting transaction details.\n\n\u2139\ufe0f Call `PUT /wallet/crypto/withdraw/{id}` to commit the transaction.\n\n\u2139\ufe0f Call `DELETE /wallet/crypto/withdraw/{id}` to roll back the transaction.\n\n**Permission**: Withdraw cryptocurrencies\n\n**IP limit**: 10/10\n\n**Account limit**: 20/30\n",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/wallet_WithdrawalRequest"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/wallet_WithdrawalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "id"
                  ],
                  "properties": {
                    "id": {
                      "$ref": "#/components/schemas/wallet_TransactionID"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/wallet_Validation"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_LowAmount"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_CurrencyNotFound"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_NotAllowed"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_PayoutInvalidAddress"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_PayoutInvalidPaymentID"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_PayoutBlacklisted"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_PayoutOffchainUnavailable"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_PayoutAmountLocked"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_TransactionNotFound"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_PayoutDisabled"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/wallet_401"
          },
          "403": {
            "$ref": "#/components/responses/wallet_403"
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/wallet_UserNotFound"
                }
              }
            }
          },
          "408": {
            "$ref": "#/components/responses/wallet_408"
          },
          "429": {
            "$ref": "#/components/responses/wallet_429"
          },
          "500": {
            "$ref": "#/components/responses/wallet_500"
          },
          "502": {
            "$ref": "#/components/responses/wallet_502"
          },
          "503": {
            "$ref": "#/components/responses/wallet_503"
          },
          "504": {
            "$ref": "#/components/responses/wallet_504"
          },
          "default": {
            "$ref": "#/components/responses/wallet_Error"
          }
        },
        "security": [
          {
            "wallet_BearerAuth": []
          },
          {
            "wallet_BasicAuth": []
          }
        ]
      }
    },
