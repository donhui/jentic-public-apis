    "securitySchemes": {
      "wallet_BasicAuth": {
        "type": "http",
        "description": "Provide a public key as the username and a secret key as the password.",
        "scheme": "basic"
      },
      "wallet_BearerAuth": {
        "type": "http",
        "description": "Provide a bearer token obtained from the authentication service.",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "trading_BasicAuth": {
        "type": "http",
        "description": "Provide a public key as the username and a secret key as the password.",
        "scheme": "basic"
      },
      "trading_BearerAuth": {
        "type": "http",
        "description": "Provide a bearer token obtained from the authentication service.",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}