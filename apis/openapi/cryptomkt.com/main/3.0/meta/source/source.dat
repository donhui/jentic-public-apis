    "/wallet/transactions": {
      "get": {
        "tags": [
          "Transactions"
        ],
        "summary": "Get transactions",
        "description": "\u26a0\ufe0f `from`/`till` and `from_id`/`till_id` are mutually exclusive.\n\n**Permission**: Payment information\n\n**IP limit**: 10/10\n\n**Account limit**: 20/30\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/wallet_IdFrom"
          },
          {
            "$ref": "#/components/parameters/wallet_IdTill"
          },
          {
            "$ref": "#/components/parameters/wallet_From"
          },
          {
            "$ref": "#/components/parameters/wallet_Till"
          },
          {
            "$ref": "#/components/parameters/wallet_Sort"
          },
          {
            "$ref": "#/components/parameters/wallet_Limit"
          },
          {
            "$ref": "#/components/parameters/wallet_Offset"
          },
          {
            "name": "tx_ids",
            "in": "query",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/wallet_TransactionID"
              }
            },
            "description": "Comma-separated list of transaction identifiers."
          },
          {
            "name": "currencies",
            "in": "query",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/wallet_CurrencyCommon"
              }
            },
            "description": "Comma-separated list of currency codes."
          },
          {
            "name": "networks",
            "in": "query",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/wallet_NetworkCommon"
              }
            },
            "description": "Comma-separated list of network codes."
          },
          {
            "name": "statuses",
            "in": "query",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/wallet_TransactionStatuses"
              }
            },
            "description": "Comma-separated list of transaction statuses."
          },
          {
            "name": "types",
            "in": "query",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/wallet_TransactionTypes"
              }
            },
            "description": "Comma-separated list of transaction types."
          },
          {
            "name": "subtypes",
            "in": "query",
            "style": "form",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/wallet_TransactionSubtypes"
              }
            },
            "description": "Comma-separated list of transaction subtypes."
          },
          {
            "name": "order_by",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "created_at",
              "enum": [
                "id",
                "created_at",
                "updated_at",
                "last_activity_at",
                "ID",
                "CREATED_AT",
                "UPDATED_AT",
                "LAST_ACTIVITY_AT"
              ]
            },
            "description": "The field the entries sorted by.\n\n\u26a0\ufe0f Cannot be `id` or `ID` if `from` and (or) `till` are provided.\n"
          },
          {
            "name": "group_transactions",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Flag indicating whether the returned transactions will be parts of a single operation."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/wallet_Transaction"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/wallet_TransactionNotFound"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/wallet_401"
          },
          "403": {
            "$ref": "#/components/responses/wallet_403"
          },
          "429": {
            "description": "Too Many Requests",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/wallet_TooManyRequests"
                }
              }
            }
          },
          "504": {
            "description": "Gateway Timeout",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/wallet_GatewayTimeout"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/wallet_Error"
          }
        },
        "security": [
          {
            "wallet_BearerAuth": []
          },
          {
            "wallet_BasicAuth": []
          }
        ]
      }
    },
    "/wallet/transactions/{id}": {
      "get": {
        "tags": [
          "Transactions"
