        "security": []
      }
    },
    "/public/converted/candles": {
      "get": {
        "tags": [
          "Candles"
        ],
        "summary": "Get a rate candle",
        "description": "Returns OHLCV data regarding the last price converted to the target currency for all symbols.\n\n\u26a0\ufe0f This call produces the same output as `GET /public/converted/candles` except all values in quote currency are converted to the target currency.\n\n\u2139\ufe0f Conversion from the symbol quote currency to the target currency is the mean of \"best\" bid price and \"best\" ask price in the order book. If there is no \"best\" bid of ask price, the last price is returned.\n\n**Permission**: None\n\n**IP limit**: 30/50\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_TargetCurrency"
          },
          {
            "$ref": "#/components/parameters/marketData_Symbols"
          },
          {
            "$ref": "#/components/parameters/marketData_SortDesc"
          },
          {
            "$ref": "#/components/parameters/marketData_Period"
          },
          {
            "$ref": "#/components/parameters/marketData_From"
          },
          {
            "$ref": "#/components/parameters/marketData_Till"
          },
          {
            "$ref": "#/components/parameters/marketData_Limit10"
          },
          {
            "$ref": "#/components/parameters/marketData_Pool"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_ConvertedCandles"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                    },
                    {
                      "$ref": "#/components/schemas/marketData_Validation"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": []
      }
    },
    "/public/converted/candles/{symbol}": {
      "get": {
        "tags": [
          "Candles"
        ],
        "summary": "Get rate candles",
        "description": "Returns OHLCV data regarding the last price converted to the target currency for a symbol.\n\n\u26a0\ufe0f This call produces the same output as `GET /public/converted/candles` except all values in quote currency are converted to the target currency.\n\n\u2139\ufe0f Conversion from the symbol quote currency to the target currency is the mean of \"best\" bid price and \"best\" ask price in the order book. If there is no \"best\" bid of ask price, the last price is returned.\n\n**Permission**: None\n\n**IP limit**: 30/50\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_TargetCurrency"
          },
          {
            "$ref": "#/components/parameters/marketData_SymbolPath"
          },
          {
            "$ref": "#/components/parameters/marketData_SortDesc"
          },
          {
            "$ref": "#/components/parameters/marketData_Period"
          },
          {
            "$ref": "#/components/parameters/marketData_From"
          },
          {
            "$ref": "#/components/parameters/marketData_Till"
          },
          {
            "$ref": "#/components/parameters/marketData_Limit100"
          },
          {
            "$ref": "#/components/parameters/marketData_Offset"
          },
          {
            "$ref": "#/components/parameters/marketData_Pool"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/marketData_ConvertedCandle"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
