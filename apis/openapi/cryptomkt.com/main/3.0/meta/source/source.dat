      "trading_BadFormat": {
        "title": "Bad format",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Provided parameters do not meet any supported authentication scheme.\n",
        "example": {
          "error": {
            "code": 1004,
            "message": "Unsupported authorization method"
          }
        }
      },
      "trading_BadFormatHS256": {
        "title": "Bad format (HS256)",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Any of:\n* missing required parameters;\n* the maximum time window is exceeded.\n",
        "example": {
          "error": {
            "code": 1004,
            "message": "Unsupported authorization method"
          }
        }
      },
      "trading_Forbidden": {
        "title": "Forbidden",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Any of:\n* insufficient API key permissions;\n* provided IP address is not in the white list;\n* the user is not eligible for the given liquidity pool due to the\n  configuration.\n",
        "example": {
          "error": {
            "code": 1003,
            "message": "Action is forbidden for this API key"
          }
        }
      },
      "trading_UnauthorizedHS256": {
        "title": "Unauthorized (HS256)",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Any of:\n* invalid API key;\n* user is not allowed to perform the requested operation;\n* invalid time window value;\n* invalid HMAC signature format;\n* invalid HMAC signature value.\n",
        "example": {
          "error": {
            "code": 1002,
            "message": "Authorization is required or has been failed"
          }
        }
      },
      "trading_UnauthorizedJWT": {
        "title": "Unauthorized (Bearer)",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Invalid JWT.\n",
        "example": {
          "error": {
            "code": 1002,
            "message": "Authorization is required or has been failed"
          }
        }
      },
      "trading_TradingForbidden": {
        "title": "Trading forbidden",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Placing new order is forbidden for this liquidity pool.\n",
        "example": {
          "error": {
            "code": 1006,
            "message": "Action is forbidden"
          }
        }
      },
      "trading_CurrencyNotFound": {
        "title": "Currency not found",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Provided currency has not been found.\n\nAny of:\n* the currency is disabled;\n* the currency is unavailable for a given market.\n",
        "example": {
          "error": {
            "code": 2002,
            "message": "Currency not found"
          }
        }
      },
      "trading_QuantityNotNumber": {
        "title": "Quantity not number",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Invalid quantity value.\n\nAny of:\n* quantity is not a decimal with a dot as the separator;\n* maximum bit depth is exceeded.\n",
        "example": {
          "error": {
            "code": 2010,
            "message": "Quantity not a valid number"
          }
        }
      },
      "trading_QuantityTooLow": {
        "title": "Quantity too low",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Quantity is less or equal to zero or the quantity increment.\n",
        "example": {
          "error": {
            "code": 2011,
            "message": "Quantity too low"
          }
        }
      },
      "trading_InvalidPrice": {
        "title": "Invalid price",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Invalid price value.\n\nAny of:\n* price is not a decimal with a dot as the separator;\n* maximum bit depth is exceeded;\n* price is less or equal to zero.\n",
        "example": {
          "error": {
            "code": 2020,
            "message": "Price is not a valid decimal"
          }
        }
      },
      "trading_Validation": {
        "title": "Validation",
        "schema": {
          "$ref": "#/components/schemas/trading_Error"
        },
        "type": "object",
        "description": "Any of:\n* invalid JSON payload;\n* invalid form payload;\n* specified parameters are mutually exclusive;\n* a required parameter is missing;\n* the value of a parameter is invalid;\n* pair parameters have different formats;\n* provided value does not match the currency precision while the\n  strict-validate mode is enabled.\n",
        "example": {
          "error": {
            "code": 10001,
            "message": "Validation error"
          }
        }
      }
    },
    "responses": {
      "marketData_404": {
        "description": "Not Found",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "timestamp",
                "path",
                "status",
                "error",
                "message",
                "requestId"
              ],
              "properties": {
                "timestamp": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Request timestamp.",
                  "example": "2024-03-22T15:04:05.590Z"
                },
                "path": {
                  "type": "string",
                  "description": "Request path.",
                  "example": "/api/3/public/PATH"
                },
                "status": {
                  "type": "integer",
                  "description": "Error status.",
                  "example": 404
                },
                "error": {
                  "type": "string",
                  "description": "Error description.",
                  "example": "Not Found"
                },
                "message": {
                  "type": "string",
                  "nullable": true,
                  "enum": [
                    null
                  ],
                  "description": "Error message."
                },
                "requestId": {
                  "type": "string",
                  "description": "Request identifier.",
                  "example": "0cdf39b4-28499640"
                }
              }
            }
          }
        }
      },
      "wallet_401": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/wallet_UnauthorizedHS256"
                },
                {
                  "$ref": "#/components/schemas/wallet_BadFormatHS256"
                },
                {
                  "$ref": "#/components/schemas/wallet_AuthInvalid"
                },
                {
                  "$ref": "#/components/schemas/wallet_BadFormat"
                }
              ]
            }
          }
        }
      },
      "wallet_403": {
        "description": "Forbidden",
        "content": {
          "application/json": {
            "schema": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/wallet_Forbidden"
                },
                {
