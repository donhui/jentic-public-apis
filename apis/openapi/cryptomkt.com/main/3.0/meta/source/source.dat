    "/wallet/crypto/address/check-mine": {
      "get": {
        "tags": [
          "Addresses"
        ],
        "summary": "Check address ownership",
        "description": "Determines whether the provided deposit address belongs to the user.\n\n**Permission**: Payment information\n\n**IP limit**: 10/10\n\n**Account limit**: 20/30\n",
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^([\\w@\\-.:<>]+|[0-9A-Z]{4}( ?[0-9A-Z]{4}){8}|(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?)$"
            },
            "description": "Deposit crypto address.",
            "example": "3A3MR43kUvahSAJtTsxzE8mcTz3VfL9upi"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
