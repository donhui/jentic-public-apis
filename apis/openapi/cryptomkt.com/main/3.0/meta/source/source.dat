      "trading_OrderRequest": {
        "allOf": [
          {
            "type": "object"
          },
          {
            "title": "Order request",
            "discriminator": {
              "propertyName": "type",
              "mapping": {
                "limit": "#/components/schemas/trading_LimitOrderRequest",
                "market": "#/components/schemas/trading_MarketOrderRequest",
