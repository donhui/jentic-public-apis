                "schema": {
                  "$ref": "#/components/schemas/marketData_Ticker"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                }
              }
