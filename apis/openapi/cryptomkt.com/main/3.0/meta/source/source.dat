              },
              {
                "$ref": "#/components/schemas/trading_StopMarketOrderRequest"
              }
            ]
          }
        ]
      },
      "trading_NewOrderClientId": {
        "title": "Order client ID",
        "type": "object",
        "properties": {
          "new_client_order_id": {
            "type": "string",
            "minLength": 8,
            "maxLength": 32,
            "pattern": "^[a-zA-Z0-9_\\-]{8,32}$",
            "description": "Client-provided identifier of a new order placed or parked instead of the canceled one.\n\n\u26a0\ufe0f Uniqueness must be guaranteed until the last order with the same `client_order_id` becomes inactive (canceled, expired, or fully executed) and some time after that.\n\n\u2139\ufe0f If omitted, will be generated by the system.\n",
            "example": "d8574207d9e3b16a4a5511753eeef175"
          }
        }
      },
