      "marketData_InternalCurrency": {
        "title": "Internal currency",
        "allOf": [
          {
            "$ref": "#/components/schemas/marketData_CurrencyBase"
          },
          {
            "$ref": "#/components/schemas/marketData_NetworkBase"
          },
          {
            "type": "object",
            "required": [
              "full_name",
              "crypto",
              "payin_enabled",
              "payin_payment_id",
              "payin_confirmations",
              "payout_enabled",
              "payout_is_payment_id",
              "transfer_enabled",
              "delisted",
              "precision_payout",
              "precision_transfer"
            ],
            "properties": {
              "payout_minimal_amount": {
                "type": "string",
                "description": "The size of minimal available withdrawal."
              },
              "token_family": {
                "type": "string",
                "description": "Token group.",
                "example": "eth"
              },
              "crypto_type": {
                "type": "string",
                "enum": [
                  "",
                  "btc",
                  "nxt",
                  "cryptonote",
                  "crypto_address",
                  "payment_id",
                  "ICO",
                  "TOKEN"
                ],
                "description": "Type of crypto platform.\n\nValues:\n  * `btc`\u2014BTC-like currencies;\n  * `nxt`\u2014NXT only;\n  * `cryptonote`\u2014currencies that use the cryptonote algorithm (e.g., BCN, XMR);\n  * `payment_id`\u2014currencies that allow to specify a transaction identifier;\n  * `ICO`\u2014futures (currency which has not been released on the market yet);\n  * `TOKEN`\u2014tokens;\n  * `crypto_address`\u2014Ethereum contract address;\n  * empty string\u2014any other currency types.\n"
              },
              "category": {
                "type": "string",
                "description": "Currency category.",
                "example": "LMC"
              },
              "is_instruments_stable": {
                "type": "boolean",
                "description": "If `true`, the pairs of this currency are displayed on the **Stable** tab."
              }
            }
          }
        ]
