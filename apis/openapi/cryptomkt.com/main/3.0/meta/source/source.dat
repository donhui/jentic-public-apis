      "wallet_PublicComment": {
        "title": "Public comment",
        "type": "object",
        "properties": {
          "public_comment": {
            "type": "string",
            "maxLength": 255,
            "pattern": "^[\\w@\\-\\.:<>]+( [\\w@\\-\\.:<>]+)*$",
            "description": "Custom text comment for external use.\n\n\u2139\ufe0f The specified value will be displayed in the transaction history and may help in identification of the transaction.\n\n\u2139\ufe0f Avoid the following characters: `&`, `'`, `<`, `>`, `\"`.\n",
            "example": "Lorem ipsum dolor sit amet consectetur adipiscing elit..."
          }
        }
      },
      "wallet_AddressCommon": {
        "title": "Deposit address",
        "type": "string",
        "pattern": "^([\\w@\\-.:<>]+|[0-9A-Z]{4}( ?[0-9A-Z]{4}){8}|(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?)$",
        "description": "Deposit crypto address.",
        "example": "3A3MR43kUvahSAJtTsxzE8mcTz3VfL9upi"
      },
      "wallet_Address": {
        "title": "Deposit address",
        "type": "object",
        "properties": {
          "address": {
            "$ref": "#/components/schemas/wallet_AddressCommon"
          }
        }
      },
      "wallet_PaymentID": {
        "title": "Payment ID",
        "type": "object",
        "properties": {
          "payment_id": {
            "type": "string",
            "pattern": "^[\\w@\\-.:<>]+$",
            "description": "An additional recipient identifier (for example, \"Memo\") required for specific currencies."
          }
        }
      },
      "wallet_Fee": {
        "title": "Withdrawal fee",
        "type": "object",
        "properties": {
          "fee": {
            "type": "string",
            "description": "Fee amount.\n\nFormat: currency precision\n",
            "example": "0"
          }
        }
      },
      "wallet_HashCommon": {
        "title": "Transaction hash",
        "type": "string",
        "nullable": true,
        "description": "Transaction blockchain hash.",
        "example": "0xfb0ba568213d11230cd34d62fddd1cc1fe11fdc173l4f2007b0e47a06ad73d20\n"
      },
      "wallet_Hash": {
        "title": "Transaction hash",
        "type": "object",
        "required": [
          "tx_hash"
        ],
        "properties": {
          "tx_hash": {
            "$ref": "#/components/schemas/wallet_HashCommon"
          }
        }
      },
      "wallet_CreatedAt": {
        "title": "Created at",
        "type": "object",
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time of the creation.",
            "example": "2024-03-22 15:04:05Z07:00"
          }
        }
      },
      "wallet_UpdatedAt": {
        "title": "Updated at",
        "type": "object",
        "properties": {
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Date and time of the last update.",
            "example": "2024-03-22 15:04:05Z07:00"
          }
        }
      },
      "wallet_DeletedAt": {
        "title": "Deleted at",
        "type": "object",
        "properties": {
          "deleted_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-03-22 15:04:05Z07:00",
            "description": "Date and time of the deletion."
          }
        }
      },
      "wallet_OperationID": {
        "title": "Operation ID",
        "type": "object",
        "properties": {
          "operation_id": {
            "type": "string",
            "format": "uuid",
            "description": "Operation UUID.",
            "example": "7388421c-06af-11ee-be56-0242ac120002"
          }
        }
      },
      "wallet_IPAddressCommon": {
        "title": "IP address",
        "oneOf": [
          {
            "type": "string",
            "format": "ipv4"
          },
          {
            "type": "string",
            "format": "ipv6"
          }
        ],
        "description": "IP address of the request sender provided by the client or detected automatically.",
        "example": "127.0.0.1"
      },
      "wallet_Balance": {
        "title": "Wallet balance",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "type": "object",
            "required": [
              "available",
              "currency",
              "reserved"
            ],
            "properties": {
              "available": {
                "type": "string",
                "description": "Amount available for withdrawals and transfers to the exchange account.",
                "example": "14.08"
              },
              "reserved": {
                "type": "string",
                "description": "Total amount reserved for withdrawals, withdrawal fees, and transfers to the exchange account.",
                "example": "2.37"
              }
            }
          }
        ]
      },
      "wallet_DepositAddressBase": {
        "title": "Deposit address",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Address"
          },
          {
            "$ref": "#/components/schemas/wallet_PaymentID"
          },
          {
            "type": "object",
            "required": [
              "currency",
              "address"
            ],
            "properties": {
              "public_key": {
                "type": "string",
                "description": "Public key."
              }
            },
            "example": {
              "address": "3A3MR43kUvahSAJtTsxzE8mcTz3VfL9upi"
            }
          }
        ]
      },
      "wallet_DepositAddress": {
        "title": "Deposit address",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Network"
          },
          {
            "$ref": "#/components/schemas/wallet_DepositAddressBase"
          },
          {
            "example": {
              "currency": "USDT",
              "network_code": "ETH",
              "address": "3A3MR43kUvahSAJtTsxzE8mcTz3VfL9upi"
            }
          }
        ]
      },
      "wallet_RecentDepositAddress": {
        "title": "Deposit address",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "type": "object",
            "properties": {
              "network_name": {
                "type": "string",
                "description": "Network full name."
              }
            },
            "example": {
              "currency": "USDT",
              "network_code": "ETH",
              "network_name": "Ethereum",
              "address": "3A3MR43kUvahSAJtTsxzE8mcTz3VfL9upi"
            }
          }
        ]
      },
      "wallet_DepositAddressRequest": {
        "title": "Deposit address request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Network"
          },
          {
            "type": "object",
            "required": [
              "currency"
            ]
          }
        ]
      },
      "wallet_TransferEnum": {
        "title": "Transfer types",
        "type": "string",
        "enum": [
          "wallet"
        ]
      },
      "wallet_SpotTransferEnum": {
        "title": "Transfer types",
        "type": "string",
        "enum": [
          "spot"
        ]
      },
      "wallet_TransferRequest": {
        "title": "Transfer request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Amount"
          },
          {
            "type": "object",
            "required": [
              "amount",
              "currency",
              "destination",
              "source"
            ],
            "properties": {
              "source": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/wallet_SpotTransferEnum"
                  },
                  {
                    "$ref": "#/components/schemas/wallet_TransferEnum"
                  },
                  {
                    "description": "Transfer source account type."
                  }
                ]
              },
              "destination": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/wallet_TransferEnum"
                  },
                  {
                    "$ref": "#/components/schemas/wallet_SpotTransferEnum"
                  },
                  {
                    "description": "Transfer destination account type."
                  }
                ]
              }
            }
          }
        ]
      },
      "wallet_WhitelistedAddress": {
        "title": "Whitelisted address",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Address"
          },
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "required": [
              "name",
              "address",
              "currency",
              "network"
            ]
          },
          {
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the whitelist item.\n",
                "example": "ETH withdrawal"
              },
              "network": {
                "$ref": "#/components/schemas/wallet_NetworkCommon"
              }
            }
          }
        ]
      },
      "wallet_TransactionID": {
        "title": "Transaction ID",
        "type": "string",
        "format": "uuid",
        "description": "Transaction UUID.",
        "example": "27fa7f14-ca49-42fd-834a-4ce630d069d2"
      },
      "wallet_SingleTransfer": {
        "title": "Wallet \u2194 Exchange",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/wallet_TransactionID"
        },
        "minItems": 1,
        "maxItems": 1,
        "description": "Transfer between a wallet and an exchange account.",
        "example": [
          "27fa7f14-ca49-42fd-834a-4ce630d069d2"
        ]
      },
      "wallet_DoubleTransfer": {
        "title": "Exchange \u2194 Exchange",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/wallet_TransactionID"
        },
        "minItems": 2,
        "maxItems": 2,
        "description": "Operation made by 2 transactions: via an intermediate account.\n",
        "example": [
          "b79ecc5d-0081-47e9-bdc0-69a7e941e7c6",
          "7a04e62c-563c-4797-8eeb-ea8e3fa354d3"
        ]
      },
      "wallet_ConvertConfig": {
        "title": "Conversion config",
        "type": "object",
        "required": [
          "currencyFrom",
          "currencyTo",
          "customTypeTo",
          "customTypeFrom",
          "comment"
        ],
        "properties": {
          "currencyFrom": {
            "$ref": "#/components/schemas/wallet_CurrencyCommon",
            "description": "Source currency code."
          },
          "currencyTo": {
            "type": "string",
            "description": "Target currency code.",
            "example": "USDT20"
          },
          "customTypeTo": {
            "type": "string",
            "enum": [
              "conversion_output"
            ],
            "description": "Transfer custom type for source."
          },
          "customTypeFrom": {
            "type": "string",
            "enum": [
              "conversion_input"
            ],
            "description": "Transfer custom type for target."
          },
          "comment": {
            "type": "string",
            "description": "Text description of conversion source and target currencies.",
            "example": "USDT to USDT20"
          }
        }
      },
      "wallet_ConvertRequest": {
        "title": "Conversion request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Amount"
          },
          {
            "type": "object",
            "required": [
              "amount",
              "from_currency",
              "to_currency"
            ],
            "properties": {
              "from_currency": {
                "$ref": "#/components/schemas/wallet_CurrencyCommon",
                "description": "Source currency code."
              },
              "to_currency": {
                "type": "string",
                "description": "Target currency code.",
                "example": "USDT20"
              }
            }
          }
        ]
      },
      "wallet_InternalWithdrawalRequestByEnum": {
        "title": "Withdrawal targets",
        "type": "string",
        "enum": [
          "email",
          "username",
          "external_id"
        ]
      },
      "wallet_InternalWithdrawalRequestBase": {
        "title": "Withdrawal request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Amount"
          },
          {
            "$ref": "#/components/schemas/wallet_PublicComment"
          },
          {
            "type": "object",
            "required": [
              "currency",
              "by",
              "amount"
            ],
            "properties": {
              "by": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/wallet_InternalWithdrawalRequestByEnum"
                  }
                ],
                "description": "Type of the target user identifier."
              }
            }
          }
        ]
      },
      "wallet_InternalWithdrawalRequestEmail": {
        "title": "Email",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_InternalWithdrawalRequestBase"
          },
          {
            "type": "object",
            "required": [
              "identifier"
            ],
            "properties": {
              "identifier": {
                "type": "string",
                "format": "email",
                "description": "Target user email.",
                "example": "johndoe@example.com"
              }
            }
          }
        ]
      },
      "wallet_InternalWithdrawalRequestUsername": {
        "title": "Username",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_InternalWithdrawalRequestBase"
          },
          {
            "type": "object",
            "required": [
              "identifier"
            ],
            "properties": {
              "identifier": {
                "type": "string",
                "minLength": 3,
                "maxLength": 16,
                "pattern": "^[a-zA-Z0-9@_+.-]+$",
                "description": "Target user username.",
                "example": "john.doe"
              }
            }
          }
        ]
      },
      "wallet_InternalWithdrawalRequestExternalID": {
        "title": "External ID",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_InternalWithdrawalRequestBase"
          },
          {
            "type": "object",
            "required": [
              "identifier"
            ],
            "properties": {
              "identifier": {
                "type": "string",
                "description": "Target user external identifier.",
                "example": "C1408A"
              }
            }
          }
        ]
      },
      "wallet_InternalWithdrawalRequestWalletID": {
        "title": "Wallet ID",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_InternalWithdrawalRequestBase"
          },
          {
            "type": "object",
            "required": [
              "identifier"
            ],
            "properties": {
              "identifier": {
                "type": "string",
                "minLength": 5,
                "maxLength": 60,
                "pattern": "^[a-z0-9].$",
                "description": "Target user wallet ID (without a domain).",
                "example": "johndoe"
              }
            }
          }
        ]
      },
      "wallet_InternalWithdrawalRequest": {
        "allOf": [
          {
            "type": "object"
          },
          {
            "title": "Internal withdrawal request",
            "discriminator": {
              "propertyName": "by",
              "mapping": {
                "email": "#/components/schemas/wallet_InternalWithdrawalRequestEmail",
                "username": "#/components/schemas/wallet_InternalWithdrawalRequestUsername",
                "external_id": "#/components/schemas/wallet_InternalWithdrawalRequestExternalID",
                "wallet_id": "#/components/schemas/wallet_InternalWithdrawalRequestWalletID"
              }
            },
            "oneOf": [
              {
                "$ref": "#/components/schemas/wallet_InternalWithdrawalRequestEmail"
              },
              {
                "$ref": "#/components/schemas/wallet_InternalWithdrawalRequestUsername"
              },
              {
                "$ref": "#/components/schemas/wallet_InternalWithdrawalRequestExternalID"
              },
              {
                "$ref": "#/components/schemas/wallet_InternalWithdrawalRequestWalletID"
              }
            ]
          }
        ]
      },
      "wallet_WithdrawalRequest": {
        "title": "Withdrawal request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Amount"
          },
          {
            "$ref": "#/components/schemas/wallet_PublicComment"
          },
          {
            "$ref": "#/components/schemas/wallet_Address"
          },
          {
            "type": "object",
            "required": [
              "currency",
              "amount",
              "address"
            ],
            "properties": {
              "network_code": {
                "type": "string",
                "description": "Network code.\n\nConditions: if omitted, the currency default network will be\nused\n",
                "example": "ETH"
              },
              "payment_id": {
                "type": "string",
                "pattern": "^[\\w@\\-.:<>]+$",
                "description": "An additional recipient identifier (for example, \"Memo\") required for specific currencies.\n\n\u2139\ufe0f Call `GET /public/currency/{currency}` and check `payout_is_payment_id` value to determine if a payment ID is needed.\n",
                "example": ""
              },
              "include_fee": {
                "type": "boolean",
                "nullable": true,
                "default": false,
                "description": "Flag indicating whether fees will be included in the final amount of the resulting transaction.\n\nValues:\n  * `true`\u2014fees will reduce the amount sent to the receiver. The amount written-off from the sender will be exactly equal to `amount`;\n  * `false`\u2014fees will increase the amount written-off from the sender. The amount sent to the receiver will be exactly equal to `amount`.\n\n\u26a0\ufe0f If set to `true`, make sure that the amount exceeds fees.\n\n\u2139\ufe0f Call `GET /wallet/crypto/fee/estimate` to get an estimated fee amount before creating a transaction.\n"
              },
              "auto_commit": {
                "type": "boolean",
                "nullable": true,
                "default": false,
                "description": "Flag indicating whether the sender should commit the transaction within 1 hour after it is created\u2014the transaction will be rolled back otherwise.\n\nValues:\n  * `true`\u2014one-phase scheme, the transaction will be committed automatically shortly after its creation;\n  * `false`\u2014two-phase scheme, the transaction must be committed or rolled back.\n"
              },
              "use_offchain": {
                "type": "string",
                "enum": [
                  "never",
                  "optionally",
                  "required"
                ],
                "default": "never",
                "description": "The instruction specifying whether it is allowed, needed, or forbidden to process the transaction off chain.\n\nValues:\n  * `never`\u2014a transaction must be committed to the blockchain;\n  * `optionally`\u2014the resulting transaction will be processed off chain if it is a viable option for the given address and the current configuration state;\n  * `required`\u2014the request will be rejected if a withdrawal cannot be processed off chain.\n\n\u2139\ufe0f Call `GET /wallet/crypto/check-offchain-available` to check if the given operation may be processed off chain.\n"
              },
              "wallet_id": {
                "type": "string",
                "pattern": "^*\\..*$",
                "description": "Wallet ID in an external network.",
                "example": "johndoe.dba.id"
              }
            },
            "example": {
              "currency": "USDT",
              "amount": 2.37,
              "public_comment": "Lorem ipsum dolor sit amet consectetur adipiscing elit...",
              "address": "3A3MR43kUvahSAJtTsxzE8mcTz3VfL9upi",
              "network_code": "ETH"
            }
          }
        ]
      },
      "wallet_OffChainRequest": {
        "title": "Off-chain request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_PaymentID"
          },
          {
            "$ref": "#/components/schemas/wallet_Address"
          },
          {
            "type": "object",
            "required": [
              "currency",
              "address"
            ]
          }
        ]
      },
      "wallet_FeesEstimateRequest": {
        "title": "Fee estimate request",
        "type": "array",
        "items": {
          "allOf": [
            {
              "$ref": "#/components/schemas/wallet_Amount"
            },
            {
              "$ref": "#/components/schemas/wallet_Currency"
            },
            {
              "$ref": "#/components/schemas/wallet_Network"
            },
            {
              "type": "object",
              "required": [
                "amount",
                "currency"
              ]
            }
          ]
        }
      },
      "wallet_EstimatedFee": {
        "title": "Estimated fee",
        "type": "array",
        "items": {
          "allOf": [
            {
              "$ref": "#/components/schemas/wallet_Fee"
            },
            {
              "$ref": "#/components/schemas/wallet_Amount"
            },
            {
              "$ref": "#/components/schemas/wallet_Currency"
            },
            {
              "type": "object",
              "required": [
                "fee",
                "networkFee",
                "amount",
                "currency"
              ],
              "properties": {
                "networkFee": {
                  "type": "string",
                  "description": "Network fee."
                },
                "networkCode": {
                  "$ref": "#/components/schemas/wallet_NetworkCommon"
                }
              },
              "example": {
                "fee": "0.02",
                "networkFee": "0",
                "networkCode": "ETH"
              }
            }
          ]
        }
      },
      "wallet_EstimatedFeeBulk": {
        "title": "Estimated fee",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Network"
          },
          {
            "$ref": "#/components/schemas/wallet_Amount"
          },
          {
            "$ref": "#/components/schemas/wallet_Fee"
          },
          {
            "required": [
              "currency",
              "amount",
              "fee"
            ]
          }
        ]
      },
      "wallet_reqBulkEstimateFeeByLabel": {
        "title": "Bulk estimate fee by label",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Network"
          },
          {
            "$ref": "#/components/schemas/wallet_Amount"
          },
          {
            "required": [
              "currency",
              "amount"
            ]
          }
        ]
      },
      "wallet_schFees": {
        "title": "Fees",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Network"
          },
          {
            "properties": {
              "levels": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/wallet_schLevels"
                }
              }
            }
          }
        ]
      },
      "wallet_ptyHash-Fees": {
        "title": "Hash",
        "properties": {
          "hash": {
            "type": "string",
            "description": "Fee hash.\n",
            "example": "3982183395978"
          }
        }
      },
      "wallet_ptyDefaultLevelId": {
        "title": "Default level ID",
        "type": "object",
        "properties": {
          "default_level_id": {
            "$ref": "#/components/schemas/wallet_FeeLevelIDCommon",
            "description": "Default fee level.\n"
          }
        }
      },
      "wallet_ptyFees": {
        "title": "Fees",
        "type": "object",
        "properties": {
          "fees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/wallet_schFees"
            }
          }
        }
      },
      "wallet_resGetFeeList": {
        "title": "Get fee list response",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_ptyHash-Fees"
          },
          {
            "$ref": "#/components/schemas/wallet_ptyDefaultLevelId"
          },
          {
            "$ref": "#/components/schemas/wallet_ptyFees"
          },
          {
            "required": [
              "hash",
              "default_level_id",
              "fees"
            ]
          }
        ]
      },
      "wallet_resGetFeeHash": {
        "title": "Get fee hash response",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_ptyHash-Fees"
          },
          {
            "required": [
              "hash"
            ]
          }
        ]
      },
      "wallet_TransactionStatuses": {
        "title": "Transaction statuses",
        "type": "string",
        "enum": [
          "CREATED",
          "PENDING",
          "FAILED",
          "SUCCESS",
          "ROLLED_BACK"
        ],
        "description": "Transaction status.\n\nValues:\n  * `CREATED`\u2014the transaction has been created and needs to be approved. For withdrawals, the status means that the transaction has been created but not committed. It remains in this status until manually validated or moved to a blockchain;\n  * `PENDING`\u2014the transaction has been created and is queued until the fees are paid, and it can be processed further. Also, for withdrawals and deposits, the status means that blockchain confirmations have not yet been gathered;\n  * `FAILED`\u2014the transaction could not be committed;\n  * `ROLLED_BACK`\u2014the transaction has been canceled;\n  * `SUCCESS`\u2014the transaction has been approved and fully processed.\n"
      },
      "wallet_TransactionTypes": {
        "title": "Transaction types",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_OTCTransactionTypes"
          },
          {
            "$ref": "#/components/schemas/wallet_TransactionTypesBase"
          },
          {
            "description": "Transaction type."
          }
        ]
      },
      "wallet_TransactionTypesBase": {
        "title": "Native transaction types",
        "type": "string",
        "enum": [
          "DEPOSIT",
          "WITHDRAW",
          "TRANSFER"
        ]
      },
      "wallet_OTCTransactionTypes": {
        "title": "OTC transaction types",
        "type": "string",
        "enum": [
          "OTC"
        ]
      },
      "wallet_TransactionSubtypes": {
        "title": "Transaction subtypes",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_TransactionSubtypesBase"
          },
          {
            "$ref": "#/components/schemas/wallet_SubaccountsTransactionSubtypes"
          },
          {
            "description": "Transaction subtype."
          }
        ]
      },
      "wallet_TransactionSubtypesBase": {
        "title": "Native transaction subtypes",
        "type": "string",
        "enum": [
          "UNCLASSIFIED",
          "BLOCKCHAIN",
          "OFFCHAIN",
          "FIAT",
          "WALLET_TO_SPOT",
          "SPOT_TO_WALLET",
          "CHAIN_SWITCH_FROM",
          "CHAIN_SWITCH_TO"
        ]
      },
      "wallet_SubaccountsTransactionSubtypes": {
        "title": "Subaccounts transaction subtypes",
        "type": "string",
        "enum": [
          "SUB_ACCOUNT"
        ]
      },
      "wallet_SwapOperationType": {
        "title": "Swap operation types",
        "type": "string",
        "enum": [
          "SWAP"
        ]
      },
      "wallet_OTCOperationType": {
        "title": "OTC operation types",
        "type": "string",
        "enum": [
          "OTC"
        ]
      },
      "wallet_TransactionBase": {
        "title": "Transaction",
        "allOf": [
          {
            "type": "object",
            "required": [
              "id",
              "type",
              "status",
              "created_at",
              "updated_at",
              "last_activity_at"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64",
                "description": "Transaction identifier.",
                "example": 221163
              },
              "created_at": {
                "type": "string",
                "format": "date-time",
                "description": "Date and time of the creation.",
                "example": "2024-03-22 15:04:05Z07:00"
              },
              "updated_at": {
                "type": "string",
                "format": "date-time",
                "description": "Transaction updated.\n",
                "example": "2024-03-22 15:04:05Z07:00"
              },
              "last_activity_at": {
                "type": "string",
                "format": "date-time",
                "description": "Transaction info updated.\n\n\u26a0\ufe0f `last_activity_at` indicates the timestamp of a history\n record, whereas `updated_at` is the time of the latest actual\n change of transaction info. So `updated_at` may precede\n `last_activity_at` but never updates prior to entire record.\n",
                "example": "2024-03-22 15:04:05Z07:00"
              },
              "status": {
                "$ref": "#/components/schemas/wallet_TransactionStatuses"
              },
              "type": {
                "$ref": "#/components/schemas/wallet_TransactionTypes"
              },
              "subtype": {
                "$ref": "#/components/schemas/wallet_TransactionSubtypes"
              },
              "operation_id": {
                "type": "string",
                "format": "uuid",
                "description": "UUID of the operation embracing the transaction.",
                "example": "99e78bf4-a708-43a3-ab18-e8e7618cd891"
              }
            }
          }
        ]
      },
      "wallet_NativeBase": {
        "title": "Native",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Network"
          },
          {
            "type": "object",
            "required": [
              "tx_id",
              "index",
              "currency",
              "amount"
            ],
            "properties": {
              "amount": {
                "type": "string",
                "description": "Transaction amount.",
                "example": "2.37"
              },
              "tx_id": {
                "$ref": "#/components/schemas/wallet_TransactionID"
              },
              "index": {
                "type": "integer",
                "format": "uint64",
                "description": "Last update sequence number.",
                "example": 1408237221
              },
              "protocol_code": {
                "type": "string",
                "description": "The protocol or the standard powering the network.",
                "example": "ETH"
              }
            }
          }
        ]
      },
      "wallet_AttemptHashes": {
        "title": "Attempt hashes",
        "type": "string",
        "description": "Hash of the attempt to send a transaction to the blockchain.\n",
        "example": "0xfb0ba568213d11230cd34d62fddd1cc1fe11fdc173l4f2007b0e47a06ad73d20"
      },
      "wallet_NativeWithdrawalFields": {
        "title": "Native withdrawal",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Fee"
          },
          {
            "$ref": "#/components/schemas/wallet_PublicComment"
          },
          {
            "$ref": "#/components/schemas/wallet_PaymentID"
          },
          {
            "type": "object",
            "required": [
              "fee"
            ],
            "properties": {
              "wallet_id": {
                "type": "string",
                "pattern": "^*\\..*$",
                "description": "Wallet ID.",
                "example": "johndoe.dba.id"
              },
              "offchain_id": {
                "type": "string",
                "nullable": true,
                "description": "Identifier of an off-chain withdrawal."
              },
              "error_code": {
                "type": "string",
                "nullable": true,
                "enum": [
                  "INVALID_ADDRESS",
                  "INVALID_PAYMENT_ID",
                  "BAD_PRECISION"
                ],
                "description": "Withdrawal rejection reason."
              },
              "attempt_hashes": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/wallet_AttemptHashes"
                }
              }
            }
          }
        ]
      },
      "wallet_NativeBlockchainFields": {
        "title": "Native blockchain",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Address"
          },
          {
            "type": "object",
            "required": [
              "hash",
              "confirmations"
            ],
            "properties": {
              "hash": {
                "$ref": "#/components/schemas/wallet_HashCommon"
              },
              "confirmations": {
                "type": "integer",
                "format": "uint64",
                "minimum": 1,
                "nullable": true,
                "description": "Current count of transaction confirmations.",
                "example": 2
              },
              "senders": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/wallet_AddressCommon"
                },
                "description": "Crypto addresses of the transaction senders."
              }
            }
          }
        ]
      },
      "wallet_CommitRisk": {
        "title": "Commit risk",
        "type": "object",
        "required": [
          "score",
          "rbf",
          "low_fee"
        ],
        "properties": {
          "score": {
            "type": "integer",
            "format": "uint64",
            "nullable": true,
            "minimum": 0,
            "maximum": 100,
            "description": "Risk score that decreases non-linearly when the transaction gains confirmations.\n\n\u2139\ufe0f Scores from 0 to 50 imply the transaction may be considered committed (but it is not guaranteed) or it may take at least half an hour otherwise.\n"
          },
          "rbf": {
            "type": "boolean",
            "nullable": true,
            "description": "Flag indicating whether the transaction did not gain a sufficient number of confirmations and may be replaced by another one for different fees.\n\n\u26a0\ufe0f This value indicates the transaction is complete and do not affect the score.\n\n\u2139\ufe0f `false` value along with a score above 50 gives a good chance that the transaction is irreversible.\n"
          },
          "low_fee": {
            "type": "boolean",
            "nullable": true,
            "description": "Flag indicating whether the actual network fee is lower than the estimated one.\n\n\u26a0\ufe0f This value indicates the difference between the estimated fee and the actual paid fee and does not affect the score.\n"
          }
        }
      },
      "wallet_Deposit": {
        "title": "Deposit",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_TransactionBase"
          },
          {
            "type": "object",
            "required": [
              "native"
            ],
            "properties": {
              "native": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/wallet_NativeBase"
                  },
                  {
                    "$ref": "#/components/schemas/wallet_NativeBlockchainFields"
                  }
                ]
              }
            }
          },
          {
            "type": "object",
            "properties": {
              "commit_risk": {
                "$ref": "#/components/schemas/wallet_CommitRisk"
              }
            }
          }
        ]
      },
      "wallet_Withdrawal": {
        "title": "Withdrawal",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_TransactionBase"
          },
          {
            "type": "object",
            "required": [
              "native"
            ],
            "properties": {
              "native": {
                "allOf": [
                  {
                    "$ref": "#/components/schemas/wallet_NativeBase"
                  },
                  {
                    "$ref": "#/components/schemas/wallet_NativeWithdrawalFields"
                  },
                  {
                    "$ref": "#/components/schemas/wallet_NativeBlockchainFields"
                  }
                ]
              }
            }
          }
        ]
      },
      "wallet_Transfer": {
        "title": "Transfer",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_TransactionBase"
          },
          {
            "type": "object",
            "required": [
              "native"
            ],
            "properties": {
              "native": {
                "$ref": "#/components/schemas/wallet_NativeBase"
              }
            }
          }
        ]
      },
      "wallet_Transaction": {
        "allOf": [
          {
            "type": "object"
          },
          {
            "title": "Transaction",
            "discriminator": {
              "propertyName": "type",
              "mapping": {
                "DEPOSIT": "#/components/schemas/wallet_Deposit",
                "WITHDRAW": "#/components/schemas/wallet_Withdrawal",
                "TRANSFER": "#/components/schemas/wallet_Transfer"
              }
            },
            "oneOf": [
              {
                "$ref": "#/components/schemas/wallet_Deposit"
              },
              {
                "$ref": "#/components/schemas/wallet_Withdrawal"
              },
              {
                "$ref": "#/components/schemas/wallet_Transfer"
              }
            ]
          }
        ]
      },
      "wallet_SubaccountIdCommon": {
        "title": "Subaccount ID",
        "type": "string",
        "description": "Subaccount external identifier.",
        "example": "A1408C"
      },
      "wallet_SubaccountID": {
        "title": "Subaccount ID",
        "type": "object",
        "properties": {
          "sub_account_id": {
            "type": "string",
            "description": "Subaccount external identifier.",
            "example": "A1408C"
          }
        }
      },
      "wallet_Subaccount": {
        "title": "Subaccount",
        "type": "object",
        "required": [
          "email",
          "sub_account_id",
          "status"
        ],
        "properties": {
          "sub_account_id": {
            "type": "string",
            "description": "Subaccount external identifier.",
            "example": "A1408C"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address.",
            "example": "johndoe@example.com"
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "active",
              "disable"
            ],
            "description": "Account status.\n\nValues:\n  * `new`\u2014account is created, but not confirmed by email;\n  * `active`\u2014account is fully functioning (it is normally accomplished after email confirmation);\n  * `disable`\u2014account is disabled (the user cannot initiate account deactivation \u2014 it can only be done by the CRM operator).\n"
          }
        }
      },
      "wallet_SubaccountsIds": {
        "title": "Subaccount IDs",
        "type": "object",
        "required": [
          "sub_account_ids"
        ],
        "properties": {
          "sub_account_ids": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/wallet_SubaccountIdCommon"
            },
            "description": "A list of subaccounts external identifiers."
          }
        }
      },
      "wallet_SubaccountTransferRequest": {
        "title": "Subaccount transfer request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_SubaccountID"
          },
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Amount"
          },
          {
            "type": "object",
            "required": [
              "sub_account_id",
              "currency",
              "amount",
              "type"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "to_sub_account",
                  "from_sub_account"
                ],
                "description": "Transfer type.\n\nValues:\n  * `to_sub_account`\u2014from the user wallet to a subaccount wallet;\n  * `from_sub_account`\u2014from a subaccount wallet to the user wallet.\n\n\u26a0\ufe0f Only a subaccount with `active` status may receive funds from the user (super account).\n"
              }
            }
          }
        ]
      },
      "wallet_SubToSubTransferRequest": {
        "title": "Subaccount to subaccount transfer request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_SubaccountID"
          },
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Amount"
          },
          {
            "required": [
              "sub_account_id",
              "currency",
              "amount"
            ]
          }
        ]
      },
      "wallet_SubToSuperTransferRequest": {
        "title": "Subaccount to super account transfer request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_Amount"
          },
          {
            "required": [
              "currency",
              "amount"
            ]
          }
        ]
      },
      "wallet_SubaccountACLBase": {
        "title": "Subaccount ACL",
        "type": "object",
        "required": [
          "sub_account_id",
          "deposit_address_generation_enabled",
          "withdraw_enabled"
        ],
        "properties": {
          "deposit_address_generation_enabled": {
            "type": "boolean",
            "description": "Flag indicating whether deposits are enabled."
          },
          "withdraw_enabled": {
            "type": "boolean",
            "description": "Flag indicating whether withdrawals are enabled."
          },
          "description": {
            "type": "string",
            "description": "Text description."
          }
        }
      },
      "wallet_SubaccountACL": {
        "title": "Subaccount ACL",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_SubaccountID"
          },
          {
            "$ref": "#/components/schemas/wallet_SubaccountACLBase"
          },
          {
            "$ref": "#/components/schemas/wallet_CreatedAt"
          },
          {
            "$ref": "#/components/schemas/wallet_UpdatedAt"
          }
        ]
      },
      "wallet_SubaccountACLRequest": {
        "title": "Subaccount ACL request",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_SubaccountsIds"
          },
          {
            "$ref": "#/components/schemas/wallet_SubaccountACLBase"
          }
        ]
      },
      "wallet_ExchangeBalance": {
        "title": "Exchange balance",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_SpotBalance"
          }
        ]
      },
      "wallet_SpotBalance": {
        "title": "Spot balance",
        "required": [
          "available",
          "reserved"
        ],
        "type": "object",
        "properties": {
          "available": {
            "type": "string",
            "description": "Amount available for trading or transferring to a wallet.",
            "example": "2.27"
          },
          "reserved": {
            "type": "string",
            "description": "Total amount reserved for active orders and incomplete transfers to a wallet.",
            "example": "0.237"
          }
        }
      },
      "wallet_SubaccountBalance": {
        "title": "Subaccount balance",
        "allOf": [
          {
            "type": "object",
            "required": [
              "wallet"
            ],
            "properties": {
              "wallet": {
                "$ref": "#/components/schemas/wallet_Balance"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "spot"
            ],
            "properties": {
              "spot": {
                "$ref": "#/components/schemas/wallet_ExchangeBalance"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "derivatives"
            ],
            "properties": {
              "derivatives": {
                "$ref": "#/components/schemas/wallet_ExchangeBalance"
              }
            }
          }
        ]
      },
      "wallet_IdempotencyKey": {
        "title": "Idempotency key",
        "type": "object",
        "properties": {
          "idempotency_key": {
            "type": "string",
            "format": "uuid",
            "description": "Idempotency key.\n\n\u26a0\ufe0f Expires after 48 hours.\n",
            "example": "232e855b-cc72-4204-85c1-c9b6e3bb7e8b"
          }
        }
      },
      "wallet_AmountLock": {
        "title": "Amount lock",
        "allOf": [
          {
            "$ref": "#/components/schemas/wallet_Currency"
          },
          {
            "$ref": "#/components/schemas/wallet_CreatedAt"
          },
          {
            "type": "object",
            "required": [
              "id",
              "currency",
              "amount",
              "date_end",
              "description",
              "canceled",
              "canceled_at",
              "cancel_description",
              "created_at"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "format": "uint64",
                "description": "Amount lock identifier.",
                "example": 1
              },
              "amount": {
                "type": "string",
                "description": "Locked amount in USD.",
                "example": "2.37"
              },
              "date_end": {
                "type": "string",
                "description": "The date and time of the lock expiration.",
                "example": ""
              },
              "description": {
                "type": "string",
                "description": "Text description.",
                "example": "Lorem ipsum dolor sit amet consectetur adipiscing elit..."
              },
              "canceled": {
                "type": "boolean",
                "description": "Flag indicating whether the amount lock was canceled.",
                "example": false
              },
              "canceled_at": {
                "type": "string",
                "nullable": true,
                "format": "date-time",
                "description": "Date and time of the lock cancellation.",
                "example": null
              },
              "cancel_description": {
                "type": "string",
                "nullable": true,
                "description": "Text description on cancellation.",
                "example": null
              }
            }
          }
        ]
      },
      "wallet_PrimeTrustMethod": {
        "allOf": [
          {
            "type": "object"
          }
        ]
      },
      "wallet_Error": {
        "title": "Error",
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "integer",
                "format": "int",
                "description": "Custom error code."
              },
              "message": {
                "type": "string",
                "description": "Error message."
              },
              "description": {
                "type": "string",
                "description": "Error description."
              }
            }
          }
        }
      },
      "wallet_NotFound": {
        "title": "Not Found",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Any of:\n  * a subaccount is not found;\n  * the user is not a super account.\n",
        "example": {
          "error": {
            "code": 404,
            "message": "Not Found"
          }
        }
      },
      "wallet_RequestTimeout": {
        "title": "Request Timeout",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "The request has been canceled.",
        "example": {
          "error": {
            "code": 408,
            "message": "Request timeout"
          }
        }
      },
      "wallet_TooManyRequests": {
        "title": "Too Many Requests",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Rate limits are exceeded.",
        "example": {
          "error": {
            "code": 429,
            "message": "Too many requests"
          }
        }
      },
      "wallet_Internal": {
        "title": "Internal Server Error",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Internal error.\n\nAny of:\n  * unclassified internal error;\n  * user bank account is blocked;\n  * transaction(s) for the requested operation have not been created;\n  * transaction(s) for the requested operation have been rolled back.\n",
        "example": {
          "error": {
            "code": 500,
            "message": "Internal Server Error"
          }
        }
      },
      "wallet_AmountLocked": {
        "title": "Amount locked",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Funds needed for execution of the operation are locked.",
        "example": {
          "error": {
            "code": 500,
            "message": "Internal Server Error"
          }
        }
      },
      "wallet_BadGateway": {
        "title": "Bad Gateway",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Unclassified error while connecting the authentication service.",
        "example": {
          "error": {
            "code": 502,
            "message": "Bad gateway"
          }
        }
      },
      "wallet_ServiceUnavailable": {
        "title": "Service Unavailable",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Any of:\n  * withdrawals are disabled;\n  * unclassified internal error.\n",
        "example": {
          "error": {
            "code": 503,
            "message": "Service unavailable"
          }
        }
      },
      "wallet_NotAllowed": {
        "title": "Not allowed",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Operations on the requested currency are not allowed.\n\nAny of:\n  * currency is disabled;\n  * operations of the given type are disabled for the currency;\n  * operations on the needed account types are disabled for the currency;\n  * conversion is not allowed for the provided currencies.\n",
        "example": {
          "error": {
            "code": 600,
            "message": "Action not allowed"
          }
        }
      },
      "wallet_PayoutBlacklisted": {
        "title": "Payouts blacklisted",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "User is in the blacklist and can no longer make withdrawals.",
        "example": {
          "error": {
            "code": 602,
            "message": "Payout blacklisted"
          }
        }
      },
      "wallet_PayoutAmountLocked": {
        "title": "Payout amount locked",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Operation amount in total with locked amount exceeds available balance.",
        "example": {
          "error": {
            "code": 604,
            "message": "Payout amount bigger than locked amount"
          }
        }
      },
      "wallet_ResourceNotFound": {
        "title": "Resource not found",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Resource not found due to an internal error.\n",
        "example": {
          "error": {
            "code": 800,
            "message": "Resource Not Found"
          }
        }
      },
      "wallet_UnauthorizedHS256": {
        "title": "Unauthorized (HS256)",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Any of:\n  * invalid API key;\n  * invalid time window value;\n  * invalid HMAC signature format.\n",
        "example": {
          "error": {
            "code": 1002,
            "message": "Authorization is required or has been failed"
          }
        }
      },
      "wallet_Forbidden": {
        "title": "Forbidden",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Any of:\n  * currency settings forbid the requested operation;\n  * the user has insufficient permissions for the operation;\n  * requested operation is forbidden for the user;\n  * insufficient API key permissions;\n  * provided IP address is not in the white list;\n  * the user is not eligible for the given currency by the configuration;\n  * provided operation parameters are forbidden by the configuration;\n  * a withdrawal operation failed to pass pre-AML checks.\n",
        "example": {
          "error": {
            "code": 1003,
            "message": "Action is forbidden for this API key"
          }
        }
      },
      "wallet_BadFormat": {
        "title": "Bad Format",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Provided parameters do not meet any supported authentication scheme.",
        "example": {
          "error": {
            "code": 1004,
            "message": "Unsupported authorization method"
          }
        }
      },
      "wallet_BadFormatHS256": {
        "title": "Bad format (HS256)",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Any of:\n  * missing required parameters;\n  * the maximum of the time window is exceeded.\n",
        "example": {
          "error": {
            "code": 1004,
            "message": "Unsupported authorization method"
          }
        }
      },
      "wallet_AuthInvalid": {
        "title": "Invalid authorization",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Invalid JWT.",
        "example": {
          "error": {
            "code": 1005,
            "message": "Invalid authorization"
          }
        }
      },
      "wallet_ShouldUpgradePermission": {
        "title": "Should upgrade permission",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Current permission scope in the authentication service is insufficient.",
        "example": {
          "error": {
            "code": 1006,
            "message": "Action unavailable, please upgrade scopes"
          }
        }
      },
      "wallet_NotEnoughPermissions": {
        "title": "Not enough permissions",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Current permission scope in the authentication service is insufficient.",
        "example": {
          "error": {
            "code": 1007,
            "message": "Not enough permissions"
          }
        }
      },
      "wallet_CurrencyNotFound": {
        "title": "Currency not found",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Currency is not found.\n\nAny of:\n  * requested network is not found;\n  * requested currency is not found;\n  * no currency provided while the network is specified;\n  * requested network is disabled;\n  * operations relating to the request are disabled for the currency;\n  * currencies featured in an operation are not found.\n",
        "example": {
          "error": {
            "code": 2002,
            "message": "Currency not found"
          }
        }
      },
      "wallet_Validation": {
        "title": "Validation",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Any of:\n  * invalid JSON payload;\n  * invalid form payload;\n  * invalid payload format;\n  * invalid parameter value;\n  * invalid parameter format;\n  * specified parameters are mutually exclusive;\n  * a required parameter is missing;\n  * the value of a parameter is invalid;\n  * provided value is not unique;\n  * in an update request, no parameters provided.\n",
        "example": {
          "error": {
            "code": 10001,
            "message": "Validation error"
          }
        }
      },
      "wallet_LowAmount": {
        "title": "Low amount",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Operation amount is too low.\n\nAny of:\n  * provided amount is lesser than the currency precision (bit depth);\n  * fees are included in the final amount, and the amount is lesser than fees.\n",
        "example": {
          "error": {
            "code": 10001,
            "message": "Validation error",
            "description": "Amount too low"
          }
        }
      },
      "wallet_OTCHighVolatility": {
        "title": "High volatility",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "OTC trade will be unlikely executed due to high market volatility.",
        "example": {
          "error": {
            "code": 10001,
            "message": "Validation error",
            "description": "Exchange high volatility"
          }
        }
      },
      "wallet_UserDisabled": {
        "title": "User disabled",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "A subaccount has not confirmed the registration or is disabled which is required for execution of the operation.",
        "example": {
          "error": {
            "code": 10021,
            "message": "User disabled"
          }
        }
      },
      "wallet_InsufficientFunds": {
        "title": "Insufficient funds",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Available balance is insufficient for execution of the operation.",
        "example": {
          "error": {
            "code": 20001,
            "message": "Insufficient funds",
            "description": "Check that the funds are sufficient, given commissions"
          }
        }
      },
      "wallet_TransactionNotFound": {
        "title": "Transaction not found",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Any of:\n  * a transaction has failed to create;\n  * the requested transaction is not found.\n",
        "example": {
          "error": {
            "code": 20004,
            "message": "Transaction not found",
            "description": ""
          }
        }
      },
      "wallet_PayoutNotFound": {
        "title": "Payout not found",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "The requested withdrawal is not found.",
        "example": {
          "error": {
            "code": 20005,
            "message": "Payout not found"
          }
        }
      },
      "wallet_PayoutCommitted": {
        "title": "Payout committed",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Transaction associated with the operation was complete before being committed or rolled back.",
        "example": {
          "error": {
            "code": 20006,
            "message": "Payout already committed"
          }
        }
      },
      "wallet_PayoutInvalidAddress": {
        "title": "Invalid payout address",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Receiver deposit address has an invalid format.",
        "example": {
          "error": {
            "code": 20011,
            "message": "Payout address is invalid"
          }
        }
      },
      "wallet_PayoutInvalidPaymentID": {
        "title": "Invalid payment ID",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Any of:\n  * an internal transfer recipient did not complete the registration;\n  * recipient payment identifier is of an invalid format.\n",
        "example": {
          "error": {
            "code": 20012,
            "message": "Payout payment address is invalid"
          }
        }
      },
      "wallet_PayoutOffchainUnavailable": {
        "title": "Offchain unavailable",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "The internal transfer is directed to the sender of the request.\n\nAny of:\n  * off-chain operations are disabled;\n  * the receiver is not a valid target for an off-chain operation.\n",
        "example": {
          "error": {
            "code": 20014,
            "message": "Payout offchain unavailable"
          }
        }
      },
      "wallet_PayoutDisabled": {
        "title": "Offchain unavailable",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Withdrawals are unavailable due to the current configuration.\n\nAny of:\n  * internal withdrawals are disabled;\n  * in-chain withdrawals are disabled.\n",
        "example": {
          "error": {
            "code": 20018,
            "message": "Payout disabled"
          }
        }
      },
      "wallet_SubAccountNotFound": {
        "title": "Subaccount not found",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Any of:\n  * a subaccount does not exist;\n  * a subaccount does not belong to the super account.\n",
        "example": {
          "error": {
            "code": 21001,
            "message": "Subaccount not found"
          }
        }
      },
      "wallet_SubAccountAlreadyFrozenOrDisabled": {
        "title": "Subaccount already frozen or disabled",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "A subaccount has already been frozen or disabled regardless of super account actions.",
        "example": {
          "error": {
            "code": 21003,
            "message": "Subaccount already frozen"
          }
        }
      },
      "wallet_UserNotFound": {
        "title": "User not found",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "User not found.",
        "example": {
          "error": {
            "code": 22004,
            "message": "User not found"
          }
        }
      },
      "wallet_GatewayTimeout": {
        "title": "Gateway Timeout",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Gateway timeout.",
        "example": {
          "error": {
            "code": 22008,
            "message": "Gateway timeout. Please, try again later."
          }
        }
      },
      "wallet_VerificationRequired": {
        "title": "Verification required",
        "schema": {
          "$ref": "#/components/schemas/wallet_Error"
        },
        "type": "object",
        "description": "Verification level is insufficient for the given operation.",
        "example": {
          "error": {
            "code": 20090,
            "message": "KYC required"
          }
        }
      },
      "trading_CurrencyCommon": {
        "title": "Currency",
        "type": "string",
        "description": "Currency code.",
        "example": "USDT"
      },
      "trading_SymbolCommon": {
        "title": "Symbol",
        "type": "string",
        "description": "Symbol code."
      },
      "trading_StrictValidateCommon": {
        "title": "Strict validate",
        "type": "boolean",
        "default": false,
        "description": "Price and quantity will be checked for incrementation within the symbol tick size and quantity step (see the symbol `tick_size` and `quantity_increment`)."
      },
      "trading_Currency": {
        "title": "Currency",
        "type": "object",
        "required": [
          "currency"
        ],
        "properties": {
          "currency": {
            "$ref": "#/components/schemas/trading_CurrencyCommon"
          }
        }
      },
      "trading_Symbol": {
        "title": "Symbol",
        "type": "object",
        "required": [
          "symbol"
        ],
        "properties": {
          "symbol": {
            "type": "string",
            "description": "Symbol code.",
            "example": "BTCUSDT"
          }
        }
      },
      "trading_ExchangeBalance": {
        "title": "Exchange balance",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_SpotBalance"
          }
        ]
      },
      "trading_SpotBalance": {
        "title": "Spot Balance",
        "required": [
          "available",
          "reserved"
        ],
        "type": "object",
        "properties": {
          "available": {
            "type": "string",
            "description": "Amount available for trading or transferring to a wallet.",
            "example": "23.7"
          },
          "reserved": {
            "type": "string",
            "description": "Total amount reserved for active orders and incomplete transfers to a wallet.",
            "example": "2.37"
          }
        }
      },
      "trading_Fee": {
        "title": "Trading fees",
        "type": "object",
        "required": [
          "make_rate",
          "take_rate"
        ],
        "properties": {
          "take_rate": {
            "type": "string",
            "description": "Liquidity taker fee rate applied to the order value.",
            "example": "0.001"
          },
          "make_rate": {
            "type": "string",
            "description": "Liquidity provider fee rate applied to the order value.",
            "example": "-0.0001"
          }
        }
      },
      "trading_OrderCommon": {
        "title": "Order",
        "type": "object",
        "required": [
          "id",
          "client_order_id",
          "symbol",
          "quantity",
          "quantity_cumulative",
          "time_in_force",
          "side",
          "status",
          "type",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64",
            "example": 828680665,
            "description": "Unique order identifier as assigned by the exchange."
          },
          "client_order_id": {
            "type": "string",
            "description": "Client-provided or system-generated identifier of an order.",
            "example": "d8574207d9e3b16a4a5511753eeef175"
          },
          "symbol": {
            "type": "string",
            "description": "Symbol code.",
            "example": "BTCUSDT"
          },
          "side": {
            "type": "string",
            "enum": [
              "sell",
              "buy"
            ],
            "description": "Order side."
          },
          "status": {
            "type": "string",
            "enum": [
              "new",
              "suspended",
              "partiallyFilled",
              "filled",
              "canceled",
              "expired",
              "rejected"
            ],
            "description": "Order status.\n\nValues:\n* `new`\u2014an order is placed in the order book;\n* `suspended`\u2014a `stopLimit`, `stopMarket`, `takeProfitLimit` or `takeProfitMarket` order is parked until it meets the conditions for placement in the order book;\n* `partiallyFilled`\u2014an order is executed, but a part of its quantity is not filled yet;\n* `filled`\u2014order quantity filled completely;\n* `canceled`\u2014an order is canceled. It can either be done by a user through a cancel/replace request or by the system under specific circumstances;\n* `expired`\u2014an order is deactivated after it no longer satisfies Time in Force (IOC, FOK) or Post Only requirements;\n* `rejected`\u2014an order has been rejected.\n"
          },
          "type": {
            "type": "string",
            "enum": [
              "limit",
              "market",
              "stopLimit",
              "stopMarket",
              "takeProfitLimit",
              "takeProfitMarket"
            ],
            "description": "Order type.\n\nValues:\n* `limit`\u2014an order that will be executed at or better than the specified price. The remainder, if any, is added to the order book or expired by terms of its Time-In-Force instruction;\n* `market`\u2014an order that will be executed at the \"best\" available market price. If the order depletes its price level, then leaves quantity is placed to the order book at this limit price;\n* `stopLimit`\u2014a limit order that remains inactive until the market crosses a specified stop price (for sell orders\u2014falls below, for buy orders\u2014rises above);\n* `stopMarket`\u2014a market order that remains inactive until the market crosses a specified stop price (for sell orders\u2014falls below, for buy orders\u2014rises above);\n* `takeProfitLimit`\u2014a limit order that remains inactive until the market crosses a specified stop price (for sell orders\u2014rises above, for buy orders\u2014falls below);\n* `takeProfitMarket`\u2014a market order that remains inactive until the market crosses a specified stop price (for sell orders\u2014rises above, for buy orders\u2014falls below).\n"
          },
          "time_in_force": {
            "type": "string",
            "enum": [
              "GTC",
              "IOC",
              "FOK",
              "Day",
              "GTD"
            ],
            "description": "Order expiration mode.\n\nValues:\n* `GTC` (\"Good-Till-Canceled\")\u2014order will not be closed until it is filled;\n* `IOC` (\"Immediate-Or-Cancel\")\u2014order must be executed immediately. Any part of an IOC order that cannot be filled immediately will be canceled;\n* `FOK` (\"Fill-Or-Kill\")\u2014order must be executed immediately and completely or not executed at all;\n* `Day`\u2014keeps the order active until the end of the trading day (23:59 UTC+0);\n* `GTD` (\"Good-Till-Date\")\u2014order will be canceled on the specified date.\n"
          },
          "quantity": {
            "type": "string",
            "description": "Order quantity.",
            "example": "13.942"
          },
          "quantity_cumulative": {
            "type": "string",
            "description": "Executed order quantity.",
            "example": "5.240"
          },
          "expire_time": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "description": "Date of order expiration.\n\nConditions: `time_in_force` is `\"GTD\"`\n",
            "example": null
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Date of order creation.",
            "example": "2024-03-22T14:18:47.321Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Date of order last update.",
            "example": "2024-03-22T15:23:56.876Z"
          },
          "price_average": {
            "type": "string",
            "description": "Average price of executed order quantity.\n",
            "example": "27001.99"
          }
        }
      },
      "trading_OrderTrades": {
        "title": "Order trades",
        "type": "object",
        "properties": {
          "trades": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/trading_OrderTradesBase"
            }
          }
        }
      },
      "trading_OrderBase": {
        "title": "Order",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_OrderCommon"
          },
          {
            "type": "object",
            "required": [
              "post_only"
            ],
            "properties": {
              "post_only": {
                "type": "boolean",
                "description": "A post-only order is an order that does not remove liquidity.\n\n\u26a0\ufe0f If the post-only order would cause a match with a\npre-existing order as a taker, then the order will be canceled.\n"
              }
            }
          }
        ]
      },
      "trading_OrderTradesBase": {
        "title": "Order trades",
        "type": "object",
        "required": [
          "id",
          "quantity",
          "price",
          "fee",
          "timestamp",
          "taker"
        ],
        "description": "The list of trades the order participated in.",
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64",
            "description": "Trade identifier.",
            "example": 112263
          },
          "quantity": {
            "type": "string",
            "description": "Quantity of the trade.",
            "example": "5.457"
          },
          "price": {
            "type": "string",
            "description": "Trade price.",
            "example": "27001.99"
          },
          "fee": {
            "type": "string",
            "description": "Fee paid for trade.",
            "example": "0.000097776600"
          },
          "timestamp": {
            "type": "string",
            "description": "Date and time of the trade.",
            "example": "2024-03-22T17:01:05.092Z"
          },
          "taker": {
            "type": "boolean",
            "description": "Liquidity indicator."
          }
        }
      },
      "trading_Price": {
        "title": "Price",
        "type": "object",
        "required": [
          "price"
        ],
        "properties": {
          "price": {
            "type": "string",
            "pattern": "^\\d+\\.?\\d*$",
            "description": "Order price.",
            "example": "27001.99"
          }
        }
      },
      "trading_StopPrice": {
        "title": "Stop price",
        "type": "object",
        "properties": {
          "stop_price": {
            "type": "string",
            "description": "The price level that triggers order activation.",
            "example": "27003.99"
          }
        }
      },
      "trading_MarketOrder": {
        "title": "Market order",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_OrderBase"
          },
          {
            "$ref": "#/components/schemas/trading_OrderTrades"
          },
          {
            "$ref": "#/components/schemas/trading_OrderListFields"
          }
        ]
      },
      "trading_LimitOrder": {
        "title": "Limit order",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_MarketOrder"
          },
          {
            "$ref": "#/components/schemas/trading_Price"
          }
        ]
      },
      "trading_StopLimitOrder": {
        "title": "Stop limit order",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_LimitOrder"
          },
          {
            "$ref": "#/components/schemas/trading_StopPrice"
          },
          {
            "required": [
              "stop_price"
            ]
          }
        ]
      },
      "trading_StopMarketOrder": {
        "title": "Stop market order",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_MarketOrder"
          },
          {
            "$ref": "#/components/schemas/trading_StopPrice"
          },
          {
            "required": [
              "stop_price"
            ]
          }
        ]
      },
      "trading_Order": {
        "allOf": [
          {
            "type": "object"
          },
          {
            "title": "Order",
            "discriminator": {
              "propertyName": "type",
              "mapping": {
                "limit": "#/components/schemas/trading_LimitOrder",
                "market": "#/components/schemas/trading_MarketOrder",
                "stopLimit": "#/components/schemas/trading_StopLimitOrder",
                "stopMarket": "#/components/schemas/trading_StopMarketOrder",
                "takeProfitLimit": "#/components/schemas/trading_StopLimitOrder",
                "takeProfitMarket": "#/components/schemas/trading_StopMarketOrder"
              }
            },
            "oneOf": [
              {
                "$ref": "#/components/schemas/trading_LimitOrder"
              },
              {
                "$ref": "#/components/schemas/trading_MarketOrder"
              },
              {
                "$ref": "#/components/schemas/trading_StopLimitOrder"
              },
              {
                "$ref": "#/components/schemas/trading_StopMarketOrder"
              },
              {
                "$ref": "#/components/schemas/trading_StopLimitOrder"
              },
              {
                "$ref": "#/components/schemas/trading_StopMarketOrder"
              }
            ]
          }
        ]
      },
      "trading_OrderListFields": {
        "title": "Order list",
        "type": "object",
        "properties": {
          "order_list_id": {
            "type": "string",
            "description": "Order list identifier.\n\nConditions: order list\n",
            "example": "d8574207d9e3b16a4a5511753eeef175"
          },
          "contingency_type": {
            "type": "string",
            "enum": [
              "allOrNone",
              "oneCancelOther",
              "oneTriggerOther",
              "oneTriggerOneCancelOther"
            ],
            "description": "Order list type.\n\nConditions: order list\n\nValues:\n  * `allOrNone` (AON)\u2014all orders in the set should be executed within a single transaction or become expired otherwise;\n  * `oneCancelOther` (OCO)\u2014all orders in the set should be canceled if one of them was executed;\n  * `oneTriggerOther` (OTO)\u2014execution of the first (primary) order on the list activates other (secondary) orders as independent of each other;\n  * `oneTriggerOneCancelOther` (OTOCO)\u2014the execution of the first (primary) order on the list activates the other (secondary) orders as an OCO order list.\n"
          }
        }
      },
      "trading_NewMarketOrder": {
        "title": "Market order",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_OrderBase"
          },
          {
            "$ref": "#/components/schemas/trading_OrderTrades"
          }
        ]
      },
