            "$ref": "#/components/responses/wallet_408"
          },
          "429": {
            "$ref": "#/components/responses/wallet_429"
          },
          "500": {
            "$ref": "#/components/responses/wallet_500"
          },
          "502": {
            "$ref": "#/components/responses/wallet_502"
          },
          "503": {
            "$ref": "#/components/responses/wallet_503"
          },
          "default": {
