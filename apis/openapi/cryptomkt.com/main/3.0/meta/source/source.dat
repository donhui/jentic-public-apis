    "/public/candles/{symbol}": {
      "get": {
        "tags": [
          "Candles"
        ],
        "summary": "Get a last price candle",
        "description": "Returns OHLCV data regarding last price for a symbol.\n\n**Permission**: None\n\n**IP limit**: 30/50\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_SymbolPath"
          },
          {
            "$ref": "#/components/parameters/marketData_SortDesc"
