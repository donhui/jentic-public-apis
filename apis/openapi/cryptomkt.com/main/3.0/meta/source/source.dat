        "description": "Returns trades that filled user spot orders.\n\n**Permission**: Orderbook, History, Trading balance\n\n**IP limit**: 20/30\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/trading_OrderId"
          },
          {
            "$ref": "#/components/parameters/trading_Symbols"
          },
          {
            "$ref": "#/components/parameters/trading_Sort"
          },
          {
            "$ref": "#/components/parameters/trading_By"
          },
          {
            "$ref": "#/components/parameters/trading_From"
          },
          {
            "$ref": "#/components/parameters/trading_Till"
          },
          {
            "$ref": "#/components/parameters/trading_Limit"
          },
          {
            "$ref": "#/components/parameters/trading_Offset"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/trading_Trade"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/trading_NotAvailable"
                    },
                    {
                      "$ref": "#/components/schemas/trading_Validation"
                    },
                    {
                      "$ref": "#/components/schemas/trading_SymbolNotFound"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/trading_401"
          },
          "403": {
            "$ref": "#/components/responses/trading_403"
          },
          "500": {
            "$ref": "#/components/responses/trading_500"
          },
          "504": {
            "$ref": "#/components/responses/trading_504"
          },
          "default": {
            "$ref": "#/components/responses/trading_Error"
          }
        },
        "security": [
          {
            "trading_BasicAuth": []
          },
          {
            "trading_BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "parameters": {
      "marketData_CurrencyPath": {
        "name": "currency",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/marketData_CurrencyCommon"
        }
      },
      "marketData_Currencies": {
        "name": "currencies",
        "in": "query",
        "style": "form",
        "explode": false,
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/marketData_CurrencyCommon"
          }
        },
        "description": "A comma-separated list of currency codes."
      },
      "marketData_SymbolPath": {
        "name": "symbol",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/marketData_SymbolCommon"
        }
      },
      "marketData_Symbols": {
        "name": "symbols",
        "in": "query",
        "style": "form",
        "explode": false,
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/marketData_SymbolCommon"
          }
        },
        "description": "A comma-separated list of symbol codes."
      },
      "marketData_SortDesc": {
        "name": "sort",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "DESC",
            "ASC"
          ],
          "default": "DESC"
        },
        "description": "Sort order.\n\nValues:\n  * `ASC`\u2014ascending;\n  * `DESC`\u2014descending.\n"
      },
      "marketData_From": {
        "name": "from",
        "in": "query",
        "schema": {
          "allOf": [
            {
              "$ref": "#/components/schemas/marketData_TimestampCommon"
            },
            {
              "default": 1
            }
          ]
        },
        "description": "Interval start value."
      },
      "marketData_Till": {
        "name": "till",
        "in": "query",
        "schema": {
          "allOf": [
            {
              "$ref": "#/components/schemas/marketData_TimestampCommon"
            },
            {
              "default": 1000
            }
          ]
        },
        "description": "Interval end value."
      },
      "marketData_Period": {
        "name": "period",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "M1",
            "M3",
            "M5",
            "M15",
            "M30",
            "H1",
            "H4",
            "D1",
            "D7",
            "1M"
          ],
          "default": "M30"
        },
        "description": "History time period.\n\nValues:\n  * `M*`\u2014minutes;\n  * `H*`\u2014hours;\n  * `D*`\u2014days;\n  * `1M`\u2014one month.\n"
      },
      "marketData_Limit10": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 10
        },
        "description": "The number of items to return."
      },
      "marketData_Limit100": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 100
        },
        "description": "The number of items to return."
      },
      "marketData_Offset": {
        "name": "offset",
        "in": "query",
        "schema": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100000,
          "default": 0
        },
        "description": "The number of items to skip before starting to collect the result set."
      },
      "marketData_ByTimestamp": {
        "name": "by",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "timestamp",
            "id"
          ],
          "default": "timestamp"
        },
        "description": "The name of the field to order the results by."
      },
      "marketData_Pool": {
        "name": "exclude_pool",
        "in": "query",
        "schema": {
          "type": "boolean"
        },
        "description": "Flag indicating whether to return trades for a single broker."
      },
      "marketData_TargetCurrency": {
        "name": "target_currency",
        "in": "query",
        "required": true,
        "schema": {
          "allOf": [
            {
              "$ref": "#/components/schemas/marketData_CurrencyCommon"
            },
            {
              "description": "Target currency for conversion."
            }
          ]
        }
      },
      "wallet_CurrencyPath": {
        "name": "currency",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/wallet_CurrencyCommon"
        }
      },
      "wallet_SubaccountIdPath": {
        "name": "sub_account_id",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/wallet_SubaccountIdCommon"
        }
      },
      "wallet_CurrencyReq": {
        "name": "currency",
        "in": "query",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/wallet_CurrencyCommon"
        }
      },
      "wallet_Currency": {
        "name": "currency",
        "in": "query",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/wallet_CurrencyCommon"
        }
      },
      "wallet_AmountReq": {
        "name": "amount",
        "in": "query",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/wallet_AmountCommon"
        }
      },
      "wallet_LabelIdReq": {
        "name": "label_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        },
        "description": "Fee label UUID.\n",
        "example": "81cee4a1-0eb4-433b-b205-888e232c9f40"
      },
      "wallet_TransactionIdPathReq": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/wallet_TransactionID"
        }
      },
      "wallet_Network": {
        "name": "network_code",
        "in": "query",
        "schema": {
          "$ref": "#/components/schemas/wallet_NetworkCommon"
        }
      },
      "wallet_Sort": {
        "name": "sort",
        "in": "query",
        "schema": {
          "type": "string",
          "default": "desc",
          "enum": [
            "desc",
            "asc",
            "DESC",
            "ASC"
          ]
        },
        "description": "Sort order.\n\nValues:\n  * `asc`\u2014ascending (from A to Z);\n  * `desc`\u2014descending (from Z to A).\n"
      },
      "wallet_Limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "maximum": 1000,
          "minimum": 1,
          "type": "integer",
          "format": "int",
          "default": 100
        },
        "description": "The number of items to return."
      },
      "wallet_Offset": {
        "name": "offset",
        "in": "query",
        "schema": {
          "maximum": 100000,
          "minimum": 0,
          "type": "integer",
          "format": "int",
          "default": 0
        },
        "description": "The number of items to skip before starting to collect the result set."
      },
      "wallet_IdFrom": {
        "name": "id_from",
        "in": "query",
        "schema": {
          "type": "integer",
          "format": "uint64",
          "example": 221163
        },
        "description": "Transaction `id` start value (inclusive).\n"
      },
      "wallet_IdTill": {
        "name": "id_till",
        "in": "query",
        "schema": {
          "type": "integer",
          "format": "uint64",
          "example": 332274
        },
        "description": "Transaction `id` end value (inclusive).\n"
      },
      "wallet_From": {
        "name": "from",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date-time",
          "description": "Interval start value.\n\nFormat: RFC 3339 in nanoseconds\n",
          "example": "2024-03-22 15:04:05Z07:00"
        },
        "description": "Interval start value (inclusive).\n\n\u2139\ufe0f `order_by` defines the value type.\n"
      },
      "wallet_Till": {
        "name": "till",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date-time",
          "description": "Interval end value.\n\nFormat: RFC 3339 in nanoseconds\n",
          "example": "2024-03-22 15:04:05Z07:00"
        },
        "description": "Interval end value (inclusive).\n\n\u2139\ufe0f `order_by` defines the value type.\n"
      },
      "wallet_qryLabels": {
        "name": "labels",
        "in": "query",
        "required": true,
        "style": "form",
        "explode": false,
        "schema": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/wallet_schLabels"
          }
        }
      },
      "trading_ClOrderIdPath": {
        "name": "client_order_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 8,
          "maxLength": 32,
          "pattern": "^[a-zA-Z0-9_\\-]{8,32}$"
        },
        "description": "Client-provided or system-generated identifier of the order.",
        "example": "d8574207d9e3b16a4a5511753eeef175"
      },
      "trading_CurrencyPath": {
        "name": "currency",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/trading_CurrencyCommon"
        }
      },
      "trading_Currency": {
        "name": "currency",
        "in": "query",
        "schema": {
          "$ref": "#/components/schemas/trading_CurrencyCommon"
        }
      },
      "trading_SymbolPath": {
        "name": "symbol",
        "in": "path",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/trading_SymbolCommon"
        }
      },
      "trading_Symbol": {
        "name": "symbol",
        "in": "query",
        "schema": {
          "$ref": "#/components/schemas/trading_SymbolCommon"
        }
      },
      "trading_Symbols": {
        "name": "symbol",
        "in": "query",
        "schema": {
          "type": "array",
          "nullable": true,
          "items": {
            "$ref": "#/components/schemas/trading_SymbolCommon"
          },
          "minItems": 1
        },
        "style": "form",
        "explode": false,
        "description": "Comma-separated symbol codes."
      },
      "trading_ClOrderId": {
        "name": "client_order_id",
        "in": "query",
        "schema": {
          "type": "string",
          "minLength": 8,
          "maxLength": 32,
          "pattern": "^[a-zA-Z0-9_\\-]{8,32}$"
        },
        "description": "Client-provided or system-generated identifier of the order."
      },
      "trading_OrderId": {
        "name": "order_id",
        "in": "query",
        "schema": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "description": "Order identifier as assigned by the exchange.",
        "example": 816088377
      },
      "trading_By": {
        "name": "by",
        "in": "query",
        "schema": {
          "type": "string",
          "default": "id",
          "enum": [
            "timestamp",
            "ts",
            "id"
          ]
        },
        "description": "The type of field the entries sorted by.\n\nValues:\n  * `timestamp`, `ts`\u2014date and time of entry creation;\n  * `id`\u2014identifier of the entry.\n"
      },
      "trading_ByTs": {
        "name": "by",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string",
          "enum": [
            "timestamp",
            "ts"
          ]
        },
        "description": "The type of field entries sorted by.\n\nValues:\n  * `timestamp`, `ts`\u2014date and time of entry creation.\n"
      },
      "trading_From": {
        "name": "from",
        "in": "query",
        "schema": {
          "oneOf": [
            {
              "type": "integer",
              "format": "uint64",
              "description": "Interval start value."
            },
            {
              "type": "string",
              "format": "date-time",
              "description": "Interval start value.\n\nFormat: RFC 3339 in nanoseconds\n",
              "example": "2024-03-22T15:04:05.999999999"
            }
          ]
        }
      },
      "trading_Till": {
        "name": "till",
        "in": "query",
        "schema": {
          "oneOf": [
            {
              "type": "integer",
              "format": "uint64",
              "description": "Interval end value."
            },
            {
              "type": "string",
              "format": "date-time",
              "description": "Interval end value.\n\nFormat: RFC 3339 in nanoseconds\n",
              "example": "2024-03-22T15:04:05.999999999"
            }
          ]
        }
      },
      "trading_TsFrom": {
        "name": "from",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date-time",
          "description": "Interval start value.\n\nFormat: RFC 3339 in nanoseconds\n",
          "example": "2024-03-22T15:04:05.999999999"
        },
        "description": "Entry identifier or timestamp."
      },
      "trading_TsTill": {
        "name": "till",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date-time",
          "description": "Interval end value.\n\nFormat: RFC 3339 in nanoseconds\n",
          "example": "2024-03-22T15:04:05.999999999"
        },
        "description": "Entry identifier or timestamp."
      },
      "trading_Sort": {
        "name": "sort",
        "in": "query",
        "schema": {
          "type": "string",
          "default": "desc",
          "enum": [
            "desc",
            "asc"
          ]
        },
        "description": "Sort order.\n\nValues:\n  * `asc`\u2014ascending (from A to Z);\n  * `desc`\u2014descending (from Z to A).\n"
      },
      "trading_Limit": {
        "name": "limit",
        "in": "query",
        "description": "The number of items to return.",
        "schema": {
          "maximum": 1000,
          "minimum": 1,
          "type": "integer",
          "format": "int",
          "default": 100
        }
      },
      "trading_Offset": {
        "name": "offset",
        "in": "query",
        "schema": {
          "maximum": 100000,
          "minimum": 0,
          "type": "integer",
          "format": "int",
          "default": 0
        },
        "description": "The number of items to skip before starting to collect the result set."
      }
    },
    "schemas": {
      "marketData_TimestampCommon": {
        "title": "Timestamp",
        "oneOf": [
          {
            "title": "ISO 8601",
            "type": "string",
            "format": "date-time",
            "description": "Format: ISO 8601\n",
            "example": "2024-03-22T15:04:05.590Z"
          },
          {
            "title": "UNIX seconds",
            "type": "integer",
            "description": "Format: UNIX timestamp in seconds\n",
            "example": 1687778487
          },
          {
            "title": "UNIX milliseconds",
            "type": "integer",
            "description": "Format: UNIX timestamp in milliseconds\n",
            "example": 1687778556151
          }
        ]
      },
      "marketData_CurrencyCommon": {
        "title": "Currency",
        "type": "string",
        "description": "Currency code.",
        "example": "USDT"
      },
      "marketData_CurrencyNetworkBase": {
        "title": "Network",
        "type": "object",
        "properties": {
          "payin_enabled": {
            "type": "boolean",
            "description": "Flag indicating whether generating deposit addresses is allowed for the currency."
          },
          "payout_enabled": {
            "type": "boolean",
            "description": "Flag indicating whether withdrawals are allowed for the currency."
          },
          "crypto_payment_id_name": {
            "type": "string",
            "description": "The name of an additional account identifier for the protocol used.",
            "example": ""
          },
          "crypto_explorer": {
            "type": "string",
            "description": "The link to the currency explorer with `{tx}` placeholder instead of a hash.",
            "example": "https://blockchair.com/bitcoin/transaction/{tx}"
          }
        }
      },
      "marketData_CurrencyBase": {
        "title": "Currency",
        "allOf": [
          {
            "$ref": "#/components/schemas/marketData_CurrencyNetworkBase"
          },
          {
            "type": "object",
            "properties": {
              "full_name": {
                "type": "string",
                "description": "Currency full name.",
                "example": "Tether Omni"
              },
              "crypto": {
                "type": "boolean",
                "description": "Flag indicating whether the currency is a cryptocurrency."
              },
              "transfer_enabled": {
                "type": "boolean",
                "description": "Flag indicating whether transfers between the bank and the exchange accounts are allowed for the currency (may be disabled on maintenance)."
              },
              "sign": {
                "type": "string",
                "description": "Currency sign.",
                "example": "\u20ae"
              },
              "account_top_order": {
                "type": "integer",
                "minimum": 1,
                "description": "The absolute position of the currency in the currency list.",
                "example": 3
              },
              "qr_prefix": {
                "type": "string",
                "description": "The QR prefix used for indication of the currency in a deposit address."
              },
              "precision_transfer": {
                "type": "string",
                "description": "The minimum amount of a transfer.",
                "example": "0.00000001"
              },
              "delisted": {
                "type": "boolean",
                "description": "Flag indicating whether the currency has been delisted."
              }
            }
          }
        ]
      },
      "marketData_NetworkBase": {
        "title": "Network",
        "type": "object",
        "properties": {
          "payout_fee": {
            "type": "string",
            "description": "The minimal possible fee value constituted of the network fee charged by a blockchain and the maintenance fee charged by the exchange.\n\n\u26a0\ufe0f This fee is valid only if both network and maintenance fees fell below its minimal absolute values given the withdrawal amount.\n\n\u2139\ufe0f Call `GET /wallet/crypto/fee/estimate` to see the exact value of fees based on the amount.\n\nFormat: decimal\n",
            "example": "0.001050000000"
          },
          "precision_payout": {
            "type": "string",
            "description": "The minimum amount of a withdrawal.",
            "example": "0.00000001"
          },
          "payout_is_payment_id": {
            "type": "boolean",
            "description": "Flag indicating whether providing additional information for withdrawals is needed."
          },
          "payin_payment_id": {
            "type": "boolean",
            "description": "Flag indicating whether providing additional information for deposits is needed."
          },
          "payin_confirmations": {
            "type": "integer",
            "description": "The number of confirmation required for a transaction to be accepted in the network.",
            "example": 1
          },
          "low_processing_time": {
            "type": "string",
            "description": "The lowest processing time in seconds for a withdrawal.",
            "example": "11.443"
          },
          "high_processing_time": {
            "type": "string",
            "description": "The highest processing time in seconds for a withdrawal.",
            "example": "54.165"
          },
          "avg_processing_time": {
            "type": "string",
            "description": "The average processing time in seconds for a withdrawal.",
            "example": "30.355375"
          }
        }
      },
      "marketData_Currency": {
        "allOf": [
          {
            "$ref": "#/components/schemas/marketData_CurrencyBase"
          },
          {
            "type": "object",
            "required": [
              "full_name",
              "crypto",
              "payin_enabled",
              "payout_enabled",
              "transfer_enabled",
              "transfer_to_wallet_enabled",
              "transfer_to_exchange_enabled",
              "precision_transfer",
              "delisted",
              "networks"
            ],
            "properties": {
              "networks": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/marketData_Network"
                },
                "description": "Networks that may host operations on the currency."
              },
              "transfer_to_wallet_enabled": {
                "type": "boolean",
                "description": "Flag indicating whether transfers to the bank account are\nallowed for the currency (may be disabled on maintenance).\n"
              },
              "transfer_to_exchange_enabled": {
                "type": "boolean",
                "description": "Flag indicating whether transfers to the exchange account are\nallowed for the currency (may be disabled on maintenance).\n"
              }
            }
          }
        ]
      },
      "marketData_Network": {
        "allOf": [
          {
            "$ref": "#/components/schemas/marketData_CurrencyNetworkBase"
          },
          {
            "$ref": "#/components/schemas/marketData_NetworkBase"
          },
          {
            "type": "object",
            "required": [
              "code",
              "network_name",
              "network",
              "is_ens_available",
              "default",
              "payin_enabled",
              "payout_enabled",
              "precision_payout",
              "payout_is_payment_id",
              "payin_payment_id",
              "payin_confirmations",
              "is_multichain"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Currency code.",
                "example": "BTC"
              },
              "network_name": {
                "type": "string",
                "description": "Network full name.",
                "example": "BTC"
              },
              "network": {
                "type": "string",
                "description": "Code of the currency of the hosting network.",
                "example": "BTC"
              },
              "protocol": {
                "type": "string",
                "description": "The standard or protocol underlying network operations or smart\n contracts.\n\n\u2139\ufe0f If equals `code`, the currency is the network native\n currency.\n\n\u2139\ufe0f If `TOKEN`, the currency is a token build on top of this\n layer-2 network.\n",
                "example": "BTC"
              },
              "default": {
                "type": "boolean",
                "description": "Flag indicating whether the network is the default for the\n currency.\n"
              },
              "is_ens_available": {
                "type": "boolean",
                "description": "Flag indicating whether the network supports ENS (Ethereum Name\n Service).\n"
              },
              "address_regex": {
                "type": "string",
                "description": "Regular expression for a deposit address."
              },
              "payment_id_regex": {
                "type": "string",
                "description": "Regular expression for the payment identifier string."
              },
              "contract_address": {
                "type": "string",
                "description": "Token contract address.",
                "example": "0xdac17f958d2ee523a2206206994597c13d831ec7"
              },
              "is_multichain": {
                "type": "boolean",
                "description": "Flag indicating whether multichain is active for the network.\n"
              },
              "asset_id": {
                "type": "object",
                "nullable": true,
                "description": "A unique arbitrary object that identifies a coin.\n\n\u2139\ufe0f Each network has own set of properties returned inside an\n object.\n"
              }
            }
          }
        ]
      },
