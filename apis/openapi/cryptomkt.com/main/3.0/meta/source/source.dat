    "/wallet/convert": {
      "post": {
        "tags": [
          "Conversions"
        ],
        "summary": "Commit a conversion",
        "description": "Creates and commits a transfer between wallets of different currencies at 1:1 rate. Units of the currencies must be of an equal value and the conversion pair and the direction must be allowed by the configuration.\n\n\u26a0\ufe0f Successful response to the request does not necessarily mean the resulting transaction got executed immediately. It has to be processed first and may eventually be rolled back or fail.\n\n\u2139\ufe0f Call `GET /transfer-convert/config` to get available conversion pairs.\n\n\u2139\ufe0f A successful request results in 2 transactions: an outgoing transfer from the source wallet and an incoming transfer to the destination wallet.\n\n\u2139\ufe0f Call `GET /wallet/transactions/{id}` to check out statuses of resulting transactions.\n\n**Permission**: Payment information\n\n**IP limit**: 10/10\n\n**Account limit**: 20/30\n",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/wallet_ConvertRequest"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/wallet_ConvertRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/wallet_DoubleTransfer"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/wallet_CurrencyNotFound"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_NotAllowed"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_Validation"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_LowAmount"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/wallet_401"
