          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": [],
        "description": "\n**IP limit**: 30/50\n"
      }
    },
    "/public/candles": {
      "get": {
        "tags": [
          "Candles"
        ],
        "summary": "Get last price candles",
        "description": "Returns OHLCV data regarding last price for all symbols.\n\n**Permission**: None\n\n**IP limit**: 30/50\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_Symbols"
          },
          {
            "$ref": "#/components/parameters/marketData_SortDesc"
          },
          {
            "$ref": "#/components/parameters/marketData_Period"
          },
          {
            "$ref": "#/components/parameters/marketData_From"
          },
          {
            "$ref": "#/components/parameters/marketData_Till"
          },
          {
            "$ref": "#/components/parameters/marketData_Limit10"
          },
          {
            "$ref": "#/components/parameters/marketData_Pool"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_CandleMap"
                }
              }
            }
