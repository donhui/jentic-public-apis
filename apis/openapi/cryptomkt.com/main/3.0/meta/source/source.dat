{
  "openapi": "3.0.3",
  "info": {
    "title": "CryptoMarket API",
    "description": "CryptoMarket (CryptoMKT) cryptocurrency exchange REST API for trading, market data, and wallet management.",
    "version": "3.0"
  },
  "servers": [
    {
      "url": "https://api.exchange.cryptomkt.com/api/3"
    }
  ],
  "paths": {
    "/public/currency": {
      "get": {
        "tags": [
          "Currencies"
        ],
        "summary": "Get currencies",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_Currencies"
          },
          {
            "name": "preferred_network",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Default network.",
            "example": "ETH"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_CurrencyMap"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": [],
        "description": "\n**Permission**: None\n\n**IP limit**: 30/50\n"
      }
    },
    "/public/currency/{currency}": {
      "get": {
        "tags": [
          "Currencies"
        ],
        "summary": "Get a currency",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_CurrencyPath"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_Currency"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": [],
        "description": "\n**Permission**: None\n\n**IP limit**: 30/50\n"
      }
    },
    "/public/symbol": {
      "get": {
        "tags": [
          "Symbols"
        ],
        "summary": "Get symbols",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_Symbols"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/marketData_SpotSymbolMap"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": [],
        "description": "\n**Permission**: None\n\n**IP limit**: 30/50\n"
      }
    },
    "/public/symbol/{symbol}": {
      "get": {
        "tags": [
          "Symbols"
        ],
        "summary": "Get a symbol",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_SymbolPath"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/marketData_SpotSymbol"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": [],
        "description": "\n**Permission**: None\n\n**IP limit**: 30/50\n"
      }
    },
    "/public/price/rate": {
      "get": {
        "tags": [
          "Quotes"
        ],
        "summary": "Get a quote",
        "description": "Returns the mean of \"best\" bid price and \"best\" ask price in the order book.\n\n\u2139\ufe0f If there is no \"best\" bid of ask price, the last price is returned.\n\n\u2139\ufe0f If provided currencies do not match any existing symbol, the rate for intermediate pairs are multiplied of inverted depending on the direction of exchange in these pairs.\n\n\u2139\ufe0f If there is no rate, an empty object is returned.\n\n**Permission**: None\n\n**IP limit**: 30/50\n",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "required": true,
            "description": "Base currency code.",
            "schema": {
              "$ref": "#/components/schemas/marketData_CurrencyCommon"
            },
            "example": "BTC"
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "description": "Quote currency code.",
            "schema": {
              "$ref": "#/components/schemas/marketData_CurrencyCommon"
            },
            "example": "USDT"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_Quote"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                    },
                    {
                      "$ref": "#/components/schemas/marketData_Validation"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": []
      }
    },
    "/public/price/ticker": {
      "get": {
        "tags": [
          "Quote Tickers"
        ],
        "summary": "Get quote tickers",
        "description": "Returns last prices on symbols.\n\n**Permission**: None\n\n**IP limit**: 30/50\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_Symbols"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_LastPriceMap"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": []
      }
    },
    "/public/price/ticker/{symbol}": {
      "get": {
        "tags": [
          "Quote Tickers"
        ],
        "summary": "Get a quote ticker",
        "description": "Returns the last price on a symbol.\n\n**Permission**: None\n\n**IP limit**: 30/50\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_SymbolPath"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_LastPrice"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": []
      }
    },
    "/public/price/history": {
      "get": {
        "tags": [
          "Quote History"
        ],
        "summary": "Get quote history",
        "description": "Returns the last trade price history.\n\n**Permission**: None\n\n**IP limit**: 30/50\n",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Base currency code.",
            "schema": {
              "$ref": "#/components/schemas/marketData_CurrencyCommon"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "description": "Quote currency code.",
            "schema": {
              "$ref": "#/components/schemas/marketData_CurrencyCommon"
            }
          },
          {
            "name": "since",
            "in": "query",
            "description": "Interval start value.",
            "schema": {
              "$ref": "#/components/schemas/marketData_TimestampCommon"
            }
          },
          {
            "name": "until",
            "in": "query",
            "description": "Interval end value.",
            "schema": {
              "$ref": "#/components/schemas/marketData_TimestampCommon"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000,
              "default": 1
            },
            "description": "The number of items to return."
          },
          {
            "$ref": "#/components/parameters/marketData_Period"
          },
          {
            "$ref": "#/components/parameters/marketData_SortDesc"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_LastPriceHistoryMap"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/marketData_InstrumentNotFound"
                    },
                    {
                      "$ref": "#/components/schemas/marketData_Validation"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": []
      }
    },
    "/public/ticker": {
      "get": {
        "tags": [
          "Tickers"
        ],
