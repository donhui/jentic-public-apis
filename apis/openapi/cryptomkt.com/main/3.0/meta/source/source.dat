              "type": "boolean"
            },
            "description": "Flag indicating whether returned locks are active."
          },
          {
            "name": "limit",
            "in": "query",
            "required": true,
            "schema": {
              "maximum": 1000,
              "minimum": 1,
              "type": "integer",
              "format": "int",
              "default": 100
            },
            "description": "The number of items to return."
