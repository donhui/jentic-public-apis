      "trading_Trade": {
        "title": "Trade",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_OrderTradesBase"
          },
          {
            "type": "object",
            "required": [
              "order_id",
              "client_order_id",
              "side",
              "symbol"
            ],
            "properties": {
              "order_id": {
                "type": "integer",
                "format": "uint64",
                "description": "Unique identifier of the aggressor order as assigned by the exchange.",
                "example": 816088377
              },
              "client_order_id": {
                "type": "string",
                "description": "Unique identifier of the aggressor order as assigned by the trader.",
                "example": "d8574207d9e3b16a4a5511753eeef175"
              },
              "symbol": {
                "type": "string",
                "description": "Symbol code.",
                "example": "BTCUSDT"
              },
              "side": {
                "type": "string",
                "enum": [
                  "sell",
                  "buy"
                ],
                "description": "Aggressor order side."
              }
            }
          }
        ]
      },
      "trading_PriceRequest": {
        "title": "Price",
        "type": "object",
        "required": [
          "price"
        ],
        "properties": {
          "price": {
            "type": "number",
            "exclusiveMinimum": true,
            "description": "Order price.",
            "example": 27001.99,
            "minimum": 0
          }
        }
      },
      "trading_StrictValidateRequest": {
        "title": "Strict validate",
        "type": "object",
        "properties": {
          "strict_validate": {
            "type": "boolean",
            "description": "Price and quantity will be checked for incrementation within the symbol tick size and quantity step (see the symbol `tick_size` and `quantity_increment`).",
            "default": false
          }
        }
      },
      "trading_QuantityRequest": {
        "title": "Quantity",
        "type": "object",
        "required": [
          "quantity"
        ],
        "properties": {
          "quantity": {
            "type": "string",
            "exclusiveMinimum": true,
            "description": "Order quantity.",
            "example": 2.37,
            "minimum": 0
          }
        }
      },
      "trading_OrderRequestBase": {
        "title": "Order request",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_StrictValidateRequest"
          },
          {
            "$ref": "#/components/schemas/trading_QuantityRequest"
          },
          {
            "type": "object",
            "required": [
              "side",
              "symbol"
            ],
            "properties": {
              "client_order_id": {
                "type": "string",
                "minLength": 8,
                "maxLength": 32,
                "pattern": "^[a-zA-Z0-9_\\-]{8,32}$",
                "description": "Client-provided identifier of an order.\n\n\u26a0\ufe0f Uniqueness must be guaranteed until the last order with the same `client_order_id` becomes inactive (canceled, expired, or fully executed) and some time after that.\n\n\u2139\ufe0f If omitted, will be generated by the system.\n"
              },
              "symbol": {
                "type": "string",
                "description": "Symbol code.",
                "example": "BTCUSDT"
              },
              "side": {
                "type": "string",
                "enum": [
                  "sell",
                  "buy"
                ],
                "description": "Order side."
              },
              "type": {
                "type": "string",
                "default": "limit",
                "enum": [
                  "limit",
                  "market",
                  "stopLimit",
                  "stopMarket",
                  "takeProfitLimit",
                  "takeProfitMarket"
                ],
                "description": "Order type.\n\nConditions: required if `market`, `stopMarket`, `takeProfitMarket`\n\nValues:\n  * `limit`\u2014an order that will be executed at or better than the specified price. The remainder, if any, is added to the order book or expired by terms of its Time-In-Force instruction;\n  * `market`\u2014an order that will be executed at the \"best\" available market price. If the order depletes its price level, then leaves quantity is placed to the order book at this limit price;\n  * `stopLimit`\u2014a limit order that remains inactive until the market crosses a specified stop price (for sell orders\u2014falls below, for buy orders\u2014rises above);\n  * `stopMarket`\u2014a market order that remains inactive until the market crosses a specified stop price (for sell orders\u2014falls below, for buy orders\u2014rises above);\n  * `takeProfitLimit`\u2014a limit order that remains inactive until the market crosses a specified stop price (for sell orders\u2014rises above, for buy orders\u2014falls below);\n  * `takeProfitMarket`\u2014a market order that remains inactive until the market crosses a specified stop price (for sell orders\u2014rises above, for buy orders\u2014falls below).\n"
              },
              "time_in_force": {
                "type": "string",
                "enum": [
                  "GTC",
                  "IOC",
                  "FOK",
                  "Day",
                  "GTD"
                ],
                "default": "FOK",
                "description": "Order expiration mode.\n\nConditions: `post_only` omitted\n\nValues:\n  * `GTC` (\"Good-Till-Canceled\")\u2014order will not be closed until it is filled;\n  * `IOC` (\"Immediate-Or-Cancel\")\u2014order must be executed immediately. Any part of an IOC order that cannot be filled immediately will be canceled;\n  * `FOK` (\"Fill-Or-Kill\")\u2014order must be executed immediately and completely or not executed at all;\n  * `Day`\u2014keeps the order active until the end of the trading day (23:59 UTC+0);\n  * `GTD` (\"Good-Till-Date\")\u2014order will be canceled on the specified date.\n"
              },
              "expire_time": {
                "type": "string",
                "format": "date-time",
                "description": "Date and time of order expiration.\n\nConditions: `time_in_force` is `\"GTD\"`\n"
              },
              "post_only": {
                "type": "boolean",
                "description": "A post-only order is an order that does not remove liquidity.\n\nConditions: `time_in_force` omitted\n\n\u26a0\ufe0f If the post-only order would cause a match with a pre-existing order as a taker, then the order will be canceled.\n",
                "default": false
              }
            }
          }
        ]
      },
      "trading_StopPriceRequest": {
        "title": "Stop price",
        "type": "object",
        "properties": {
          "stop_price": {
            "type": "number",
            "exclusiveMinimum": true,
            "description": "The price level that triggers order activation.",
            "example": 27003.99,
            "minimum": 0
          }
        }
      },
      "trading_MarkupRateRequest": {
        "title": "Markup rate",
        "type": "object",
        "properties": {
          "take_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 0.1,
            "multipleOf": 1e-06,
            "description": "Markup taker fee rate applied to the order volume.",
            "example": 0.001
          },
          "make_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 0.1,
            "multipleOf": 1e-06,
            "description": "Markup maker fee rate applied to the order volume.",
            "example": 0.001
          }
        }
      },
      "trading_LimitDefaultTIF": {
        "title": "Time-in-Force",
        "type": "object",
        "properties": {
          "time_in_force": {
            "default": "GTC"
          }
        }
      },
      "trading_MarketOrderRequest": {
        "title": "Market order",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_OrderRequestBase"
          },
