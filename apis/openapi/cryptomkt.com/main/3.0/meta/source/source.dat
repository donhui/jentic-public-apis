      "trading_AccountCrossReport": {
        "title": "Cross-margin account report",
        "description": "\u26a0\ufe0f Values of `required_margin`, `margin_call_margin`,\n`liquidation_margin` do not carry information that would be valuable for\npredicting the condition of a position, since those change after an\nadjusted price (mark price) changes.\n",
        "allOf": [
          {
            "required": [
              "account_margin",
              "currency",
              "margin_mode",
              "exec_type",
              "margin",
              "required_margin",
              "debt_sum",
              "margin_call"
            ],
            "properties": {
              "exec_type": {
                "type": "string",
                "enum": [
                  "created",
                  "marginChanged"
                ],
                "description": "Margin account report execution type.\n\nValues:\n* `created`\u2014new position has been created as a result of the\n  first set margin request;\n* `marginChanged`\u2014position margin has been added or withdrawn as\n  a result of any subsequent set margin request.\n"
              },
              "currency": {
                "type": "string",
                "description": "Currency code.\n",
                "example": "USDT"
              },
              "account_margin": {
                "type": "string",
                "description": "Amount of margin in natural units of currency.\n",
                "example": "100.00"
              },
              "margin": {
                "type": "string",
                "description": "Total amount of margin in natural units of currency involved in\npositions, meaning that it is equal to the sum of orders margin\nand account margin.\n",
                "example": "100.00"
              },
              "required_margin": {
                "type": "string",
                "description": "The lower boundary to `margin` minus debt. If margin is lower\nthan this value, placing new orders and margin retrieving are\nnot allowed.\n",
                "example": "0"
              },
              "margin_call_margin": {
                "type": "string",
                "description": "Minimum amount of margin that must be in the account to avoid\nsending a margin call.\n\n\u2139\ufe0f If the `account_margin` minus `debt_sum` not exceeds\n`margin_call_margin`, a margin call will send.\n",
                "example": "0"
              },
              "liquidation_margin": {
                "type": "string",
                "description": "Minimum amount of margin that must be in the account to avoid\nliquidation.\n\n\u2139\ufe0f If the `account_margin` minus `debt_sum` not exceeds\n`liquidation_margin`, all active orders will be canceled and\nthen, if condition still true, account will be liquidated.\n",
                "example": "0"
              },
              "debt_sum": {
                "type": "string",
                "description": "Account debt for interests (fundings), fees, and loss.\n",
                "example": "0"
              },
              "margin_call": {
                "type": "boolean",
                "description": "Flag indicating whether additional margin is required to\nmaintain the position.\n"
              }
            }
          }
        ]
      },
      "trading_AccountReport": {
        "title": "Margin account report",
        "oneOf": []
      },
      "trading_FuturesAccountReport": {
        "title": "Margin account report",
        "oneOf": []
      },
      "trading_IsolatedAccountBalance": {
        "title": "Margin account balance",
        "type": "object",
        "required": [
          "code",
          "margin_balance",
          "reserved_orders",
          "reserved_positions"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Currency code.",
            "example": "USDT"
          },
          "margin_balance": {
            "type": "string",
            "description": "The total value of funds reserved for the position.",
            "example": "23.7"
          },
          "reserved_orders": {
            "type": "string",
            "description": "The value reserved for active orders in the position.",
            "example": "0"
          },
          "reserved_positions": {
            "type": "string",
            "description": "The minimum value reserved for position's executed quantity that cannot be reduced.",
            "example": "2.37"
          }
        }
      },
      "trading_CrossAccountBalance": {
        "title": "Cross account balance",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_IsolatedAccountBalance"
          },
          {
            "required": [
              "margin_call_margin",
              "liquidation_margin",
              "debt_sum"
            ]
          },
          {
            "properties": {
              "margin_call_margin": {
                "type": "string",
                "description": "The lower boundary to `margin_balance` minus debt.\n\n\u2139\ufe0f If the margin is equal to this value, a margin call is sent.\n\n\u2139\ufe0f This do not carry information that would be valuable for\npredicting the condition of a position, since those change after an\nadjusted price (mark price) changes.\n",
                "example": "0.37"
              },
              "liquidation_margin": {
                "type": "string",
                "description": "The lower boundary to `margin_balance` minus debt.\n\n\u2139\ufe0f If the margin is equal to this value, it is liquidated.\n\n\u2139\ufe0f This do not carry information that would be valuable for\npredicting the condition of a position, since those change after an\nadjusted price (mark price) changes.\n",
                "example": "0.23"
              },
              "debt_sum": {
                "type": "string",
                "description": "Account debt for interests (fundings), fees, and loss.\n",
                "example": "0"
              }
            }
          }
        ]
      },
      "trading_FuturesPositionBase": {
        "title": "Margin position",
        "allOf": [
          {
            "properties": {
              "sum_fundings": {
                "type": "string",
                "description": "Sum of all settled funding to a position.\n",
                "example": "0"
              },
              "adl_ranking": {
                "type": "string",
                "description": "Rank of a position which defines how appropriate a position is\nto be used for closing bankrupt positions avoided liquidation.\n\nThe rank represents the probability of a position becoming\ndeleveraged: a high rank value signifies a high probability,\nand vice versa.\n\nValues: 0 \u2013 4\n",
                "example": "0"
              }
            }
          }
        ]
      },
      "trading_ReportReason": {
        "title": "Report reason",
        "required": [
          "report_reason"
        ],
        "properties": {
          "report_reason": {
            "type": "string",
            "enum": [
              "created",
              "openTrade",
              "closeTrade",
              "flipTrade",
              "updated",
              "marginChanged",
              "closed",
              "status",
              "liquidated",
              "interestTaken",
              "liquidationTrade",
              "fundingTaken",
              "deleveraged",
              "deleverageTrade",
              "leverageChanged"
            ],
            "description": "Position report reason.\n\nValues:\n* `created`\u2014new position has been created as a result of the first\n  set margin request;\n* `openTrade`\u2014opening trade has been executed;\n* `closeTrade`\u2014closing trade has been executed;\n* `flipTrade`\u2014position has been flipped as a result of an opposite\n  order execution with quantity exceeding the position quantity;\n* `updated`\u2014position has been changed as a result of either order\n  placing, canceling, position status changing, or a \"margin call\";\n* `marginChanged`\u2014position margin has been added or withdrawn as a\n  result of any subsequent set margin request (refer to `created`);\n* `closed`\u2014position quantity has zeroed as a result of a close\n  trade;\n* `status`\u2014response to a position request;\n* `liquidated`\u2014position has been closed as a result of a liquidation\n  trade (including one during auto-deleveraging);\n* `interestTaken`\u2014interest rate has been paid;\n* `liquidationTrade`\u2014liquidation order has been placed;\n* `fundingTaken`\u2014funding has been paid/taken;\n* `deleveraged`\u2014position has been deleveraged;\n* `deleverageTrade`\u2014a part of position quantity has been\n  deleveraged;\n* `leverageChanged`\u2014leverage of a futures position has been changed.\n"
          }
        }
      },
      "trading_FuturesPosition": {
        "title": "Margin position",
        "allOf": [
          {
            "$ref": "#/components/schemas/trading_FuturesPositionBase"
          }
        ]
      },
      "trading_PositionHistory": {
        "title": "Positions history",
        "type": "object",
        "required": [
          "id",
          "entry_value",
          "entry_price",
          "avg_buy_price",
          "avg_sell_price",
          "quantity",
          "buy_quantity",
          "sell_quantity",
          "margin_call_price",
          "liquidation_price",
          "bankruptcy_price",
          "margin",
          "required_margin",
          "orders_margin",
          "pnl",
          "leverage",
          "margin_mode",
          "state",
          "symbol",
          "margin_call",
          "create_timestamp",
          "update_timestamp"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "uint64",
            "description": "Position identifier.",
            "example": 1408
          },
          "entry_value": {
            "type": "string",
            "description": "Position value in currency.",
            "example": "0"
          },
          "entry_price": {
            "type": "string",
            "description": "Weighted average open price.",
            "example": "0.000"
          },
          "avg_buy_price": {
            "type": "string",
            "description": "Weighted average buy price.",
            "example": "1978.057"
          },
          "avg_sell_price": {
            "type": "string",
            "description": "Weighted average sell price.",
            "example": "3851.001"
          },
          "quantity": {
            "type": "string",
            "description": "Position quantity.",
            "example": "0"
          },
          "buy_quantity": {
            "type": "string",
            "description": "Total quantity of buy trades in the position.",
            "example": "0"
          },
          "sell_quantity": {
            "type": "string",
            "description": "Total quantity of sell trades in the position.",
            "example": "0"
          },
          "margin_call_price": {
            "type": "string",
            "description": "If the market is equal to or worse than this price a margin call will be issued.",
            "example": "0.000"
          },
          "liquidation_price": {
            "type": "string",
            "description": "The price at which the platform begins to close the position.",
            "example": "0.000"
          },
          "bankruptcy_price": {
            "type": "string",
            "description": "The price at which the position can no longer be closed with any non-negative PnL.",
            "example": "0.000"
          },
          "margin": {
            "type": "string",
            "description": "Amount of margin expressed in the quote currency.",
            "example": "100.169018395350"
          },
          "required_margin": {
            "type": "string",
            "description": "Margin reserved for close orders.",
            "example": "0"
          },
          "orders_margin": {
            "type": "string",
            "description": "Margin reserved for open orders.",
            "example": "0.000006557500"
          },
          "pnl": {
            "type": "string",
            "description": "Unrealized Profit and Loss.",
            "example": "0.187294400000"
          },
          "leverage": {
            "type": "string",
            "description": "Position leverage.",
            "example": "10.00"
          },
          "margin_mode": {
            "$ref": "#/components/schemas/trading_MarginModeCommon"
          },
          "state": {
            "type": "string",
            "description": "Position state.",
            "enum": [
              "closed",
              "active",
              "liquidated"
            ]
          },
          "fee_cumulative": {
            "type": "string",
            "description": "Total amount of fees paid throughout the position lifetime until it\n is closed.\n\nFormat: Decimal\n\nValues: `0` if a new position created\n\n\u26a0\ufe0f This value does zero out after the position closes  and does not\n when it flips.\n",
            "example": 0.14
          },
          "symbol": {
            "type": "string",
            "description": "Symbol code.",
            "example": "BTCUSDT"
          },
          "margin_call": {
            "type": "boolean",
            "description": "Flag indicating the position is close to the liquidation, and increased margin may prevent it from happening."
          },
          "create_timestamp": {
            "type": "integer",
            "format": "uint64",
            "description": "Timestamp of the position creation in nanoseconds.",
            "example": 1626881592397
          },
          "update_timestamp": {
            "type": "integer",
            "format": "uint64",
            "description": "Timestamp of the position last update in nanoseconds.",
            "example": 1639570624225
          }
        }
      },
