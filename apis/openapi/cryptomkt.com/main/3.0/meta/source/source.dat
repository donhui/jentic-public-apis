    "/sub-account/transfer": {
      "post": {
        "tags": [
          "Subaccounts"
        ],
        "summary": "Commit a transfer to a subaccount",
        "description": "Creates and commits a transfer between the user (super account) and a subaccount.\n\n\u26a0\ufe0f Call is being sent by a super account.\n\n\u26a0\ufe0f Created but not committed transfer will reserve pending amount on the sender wallet affecting their ability to withdraw or transfer crypto to a subaccount. Incomplete withdrawals affect subaccount transfers the same way.\n\n**Permission**: Withdraw cryptocurrencies\n\n**Account limit**: 20/30\n",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/wallet_SubaccountTransferRequest"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/wallet_SubaccountTransferRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "result"
                  ],
                  "properties": {
                    "result": {
                      "$ref": "#/components/schemas/wallet_TransactionID"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/wallet_Validation"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_LowAmount"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_CurrencyNotFound"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_InsufficientFunds"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_TransactionNotFound"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_PayoutCommitted"
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/wallet_401"
          },
          "403": {
            "$ref": "#/components/responses/wallet_403"
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/wallet_NotFound"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_UserDisabled"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_UserNotFound"
                    }
                  ]
                }
              }
            }
