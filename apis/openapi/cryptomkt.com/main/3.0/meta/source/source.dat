                },
                {
                  "$ref": "#/components/schemas/wallet_NotEnoughPermissions"
                }
              ]
            }
          }
        }
      },
      "wallet_408": {
        "description": "Request Timeout",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/wallet_RequestTimeout"
            }
          }
