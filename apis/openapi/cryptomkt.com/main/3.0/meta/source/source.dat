          }
        },
        "security": []
      }
    },
    "/public/orderbook": {
      "get": {
        "tags": [
          "Order Books"
        ],
        "summary": "Get order books",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_Symbols"
          },
          {
            "name": "depth",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "The number of price levels.\n\n\u2139\ufe0f Set to `0` to view the full order book.\n"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_OrderBookMap"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
