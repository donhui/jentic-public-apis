    "/wallet/crypto/address": {
      "get": {
        "tags": [
          "Addresses"
        ],
        "summary": "Get addresses",
        "description": "Returns the list of latest generated deposit addresses per currency.\n\n\u26a0\ufe0f Generation of a deposit address and deposits may be rejected due to an insufficient verification level.\n\n\u2139\ufe0f If no addresses have ever been generated for a currency, nothing will be returned in the list.\n\n\u2139\ufe0f If no an address have ever been generated for a currency and `currency` parameter is specified, a new address will be generated and returned in a response.\n\n**Permission**: Payment information\n\n**IP limit**: 10/10\n\n**Account limit**: 20/30\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/wallet_CurrencyReq"
          },
          {
            "$ref": "#/components/parameters/wallet_Network"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/wallet_DepositAddress"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/wallet_CurrencyNotFound"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/wallet_401"
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/wallet_Forbidden"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_ShouldUpgradePermission"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_NotEnoughPermissions"
                    },
                    {
                      "$ref": "#/components/schemas/wallet_VerificationRequired"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/wallet_UserNotFound"
                }
              }
            }
          },
          "408": {
            "$ref": "#/components/responses/wallet_408"
          },
          "429": {
            "$ref": "#/components/responses/wallet_429"
          },
          "500": {
            "$ref": "#/components/responses/wallet_500"
          },
          "502": {
            "$ref": "#/components/responses/wallet_502"
          },
          "503": {
            "$ref": "#/components/responses/wallet_503"
          },
          "default": {
            "$ref": "#/components/responses/wallet_Error"
          }
        },
        "security": [
          {
            "wallet_BearerAuth": []
          },
          {
            "wallet_BasicAuth": []
          }
        ]
      },
      "post": {
        "tags": [
