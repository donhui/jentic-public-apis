                    {
                      "$ref": "#/components/schemas/marketData_Validation"
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/marketData_404"
          }
        },
        "security": [],
        "description": "\n**Permission**: None\n\n**IP limit**: 30/50\n"
      }
    },
    "/public/orderbook/{symbol}": {
      "get": {
        "tags": [
          "Order Books"
        ],
        "summary": "Get an order book",
        "parameters": [
          {
            "$ref": "#/components/parameters/marketData_SymbolPath"
          },
          {
            "name": "depth",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100
            },
            "description": "The number of price levels.\n\n\u2139\ufe0f Set to `0` to view the full order book.\n"
          },
          {
            "name": "volume",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "The minimum total volume among the levels.\n\nFormat: decimal\n"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/marketData_OrderBook"
                }
              }
            }
