    "/v1/projects/{projectOrProductUID}/usage/data": {
      "get": {
        "operationId": "getDataUsage",
        "summary": "Get data usage",
        "description": "Get data usage in bytes for a project, aggregated by device, fleet, or project.",
        "tags": ["Usage"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectOrProductUID" },
          { "name": "period", "in": "query", "required": true, "schema": { "type": "string", "enum": ["day", "week", "month"] }, "description": "Period type for aggregation." },
          { "name": "startDate", "in": "query", "schema": { "type": "integer" }, "description": "Start date as Unix timestamp." },
          { "name": "endDate", "in": "query", "schema": { "type": "integer" }, "description": "End date as Unix timestamp." },
          { "name": "deviceUID", "in": "query", "schema": { "type": "array", "items": { "type": "string" } }, "description": "Array of DeviceUIDs to filter by." },
          { "name": "fleetUID", "in": "query", "schema": { "type": "array", "items": { "type": "string" } }, "description": "Array of FleetUIDs to filter by." },
          { "name": "aggregate", "in": "query", "schema": { "type": "string", "enum": ["device", "fleet", "project"] }, "description": "Aggregation type (default: device)." },
          { "name": "limit", "in": "query", "schema": { "type": "integer" }, "description": "Maximum number of data points to return." }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved data usage",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UsageResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
