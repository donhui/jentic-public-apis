          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/v1/projects/{projectOrProductUID}/devices": {
      "get": {
        "operationId": "getProjectDevices",
        "summary": "Get project devices",
        "description": "Get an array of devices associated with a Notehub project.",
        "tags": ["Device"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectOrProductUID" },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Number of devices to return per page."
          },
          {
            "name": "pageNum",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1 },
            "description": "Page number of results to return."
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved devices",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DevicesResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
