      "delete": {
        "operationId": "deleteDevice",
        "summary": "Delete a device",
        "description": "Delete a device from a Notehub project.",
        "tags": ["Device"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectOrProductUID" },
          { "$ref": "#/components/parameters/DeviceUID" }
        ],
        "responses": {
