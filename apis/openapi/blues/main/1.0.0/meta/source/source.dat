    "/v1/projects/{projectOrProductUID}/events": {
      "get": {
        "operationId": "getProjectEvents",
        "summary": "Get project events",
        "description": "Get an array of Notehub events by ProjectUID.",
        "tags": ["Event"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectOrProductUID" },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer" }, "description": "Number of events per page (default 50)." },
          { "name": "pageNum", "in": "query", "schema": { "type": "integer", "minimum": 1 }, "description": "Page number of results." },
          { "name": "deviceUID", "in": "query", "schema": { "type": "array", "items": { "type": "string" } }, "description": "Array of DeviceUIDs to filter by." },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "enum": ["best_id", "device_serial", "device_uid", "captured", "modified", "device_location", "tower_location", "triangulated_location", "best_location"] }, "description": "Field to sort by." },
          { "name": "sortOrder", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] }, "description": "Sort order (default: asc)." },
          { "name": "startDate", "in": "query", "schema": { "type": "integer" }, "description": "Start date as Unix timestamp." },
          { "name": "endDate", "in": "query", "schema": { "type": "integer" }, "description": "End date as Unix timestamp." },
          { "name": "dateType", "in": "query", "schema": { "type": "string", "enum": ["captured", "uploaded"] }, "description": "Which date to filter on." },
          { "name": "systemFilesOnly", "in": "query", "schema": { "type": "boolean" }, "description": "If true, return only System Notefiles." },
          { "name": "files", "in": "query", "schema": { "type": "string" }, "description": "Comma-delimited list of Notefile names." },
          { "name": "format", "in": "query", "schema": { "type": "string", "enum": ["json", "csv"] }, "description": "Response format." },
          { "name": "fleetUID", "in": "query", "schema": { "type": "array", "items": { "type": "string" } }, "description": "Array of FleetUIDs to filter by." },
          { "name": "selectFields", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated list of fields to include." }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved events",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/EventsResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
