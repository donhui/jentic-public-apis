        "tags": ["Project"],
        "parameters": [
          { "$ref": "#/components/parameters/ProjectOrProductUID" },
          { "$ref": "#/components/parameters/FleetUID" }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved fleet",
            "content": {
