  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Use a Personal Access Token or OAuth bearer token obtained from POST /oauth2/token."
      }
    },
    "parameters": {
      "ProjectUID": {
        "name": "projectUID",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "The ProjectUID of a Notehub project."
      },
      "ProjectOrProductUID": {
        "name": "projectOrProductUID",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "The ProjectUID or ProductUID of a Notehub project."
      },
      "DeviceUID": {
        "name": "deviceUID",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "The DeviceUID of a Notehub device."
      },
      "FleetUID": {
        "name": "fleetUID",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "The FleetUID of a Notehub fleet."
      },
      "RouteUID": {
        "name": "routeUID",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "The RouteUID of a Notehub route."
      },
      "MonitorUID": {
        "name": "monitorUID",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "The MonitorUID of a Notehub monitor."
      },
      "NotefileID": {
        "name": "notefileID",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "The Notefile ID."
      },
      "NoteID": {
        "name": "noteID",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "The Note ID."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "err": {
            "type": "string",
            "description": "Error message."
          }
        }
      },
      "OAuthTokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The OAuth bearer token."
          },
          "expires_in": {
            "type": "integer",
            "description": "Number of seconds until token expires."
          },
          "token_type": {
            "type": "string",
            "description": "Token type (always 'bearer')."
          }
        }
      },
      "BillingAccountsResponse": {
        "type": "object",
        "properties": {
          "billing_accounts": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BillingAccount" }
          }
        }
      },
      "BillingAccount": {
        "type": "object",
        "properties": {
          "uid": { "type": "string", "description": "Billing account UID." },
          "name": { "type": "string", "description": "Billing account name." },
