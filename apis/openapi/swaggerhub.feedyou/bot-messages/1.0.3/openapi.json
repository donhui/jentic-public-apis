{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.3",
    "title": "Feedyou Bot Messaging API",
    "description": "This API allows to use Feedyou bot with omnichannel solution which allows sending and receiving text messages to the user using various channeks.\n\n - When user starts conversation and routing rule tells that bot should handle this conversation, `beginIntroDialog` event is sent to the bot\n - Bot loads set of intro messages and sends them one by one to the endpoind specified by `serviceUrl` in incoming event\n - Omnichannel should show this messages to the user, optionally with set of suggested reply buttons, carousel attachment or disabled/enabled text input based on `inputHint` setting\n - When user clicks on the button or sends text message, `message` event is being sent to the bot\n - Bot can decide that user should be transferred to the operator and `handoff` event is send back to omnichannel (optionally with any key-value metadata gathered during conversation or preferred operator group/skill)\n - When it is needed to route user back to the bot from operator, `cancelHandoff` event can be used\n\nSee the following sequence diagram to understand basic principles.\n<br /><br /> <img alt=\"Sequence diagram\" src=\"https://feedyou.blob.core.windows.net/docs/chat-bot-custom-channel.png\" />\n",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/feedyou/bot-messages/1.0.3/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/feedyou/bot-messages/1.0.3"
    },
    {
      "url": "https://{botId}.azurewebsites.net/api/messages",
      "variables": {
        "botId": {
          "default": "feedbot-example",
          "description": "Customer ID assigned by the service provider"
        }
      }
    }
  ],
  "paths": {
    "/custom": {
      "post": {
        "summary": "Send message from user to the bot's custom channel",
        "description": "",
        "tags": [
          "Omnichannel solution \u2192 Bot"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/UserEvent"
                  },
                  {
                    "$ref": "#/components/schemas/UserMessage"
                  }
                ]
              },
              "examples": {
                "beginIntroDialog": {
                  "summary": "Start conversation using default intro dialog flow",
                  "value": {
                    "type": "event",
                    "name": "beginIntroDialog",
                    "address": {
                      "user": {
                        "id": "1244",
                        "name": "Jan Dvo\u0159\u00e1k"
                      },
                      "conversation": {
                        "id": "abcd"
                      },
                      "serviceUrl": "https://xyz.com/api/message"
                    },
                    "channelData": {
                      "userData": {
                        "email": "some@email.com"
                      }
                    }
                  }
                },
                "message": {
                  "summary": "Send message from user to the bot",
                  "value": {
                    "type": "message",
                    "text": "Hi!",
                    "address": {
                      "user": {
                        "id": "1244",
                        "name": "Jan Dvo\u0159\u00e1k"
                      },
                      "conversation": {
                        "id": "abcd"
                      },
                      "serviceUrl": "https://xyz.com/api/message"
                    }
                  }
                },
                "cancelHandoff": {
                  "summary": "Return conversation from operator the user",
                  "value": {
                    "type": "event",
                    "name": "cancelHandoff",
                    "address": {
                      "user": {
                        "id": "1244",
                        "name": "Jan Dvo\u0159\u00e1k"
                      },
                      "conversation": {
                        "id": "abcd"
                      },
                      "serviceUrl": "https://xyz.com/api/message"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfull response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "OK",
                  "message": "Command successfull"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "post": {
        "summary": "Send message or event from the bot to user",
        "description": "",
        "tags": [
          "Bot \u2192 Omnichannel solution"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/BotMessage"
                  },
                  {
                    "$ref": "#/components/schemas/BotTyping"
                  },
                  {
                    "$ref": "#/components/schemas/BotHandoff"
                  }
                ]
              },
              "examples": {
                "messageWithReplies": {
                  "summary": "Send message with suggested actions",
                  "value": {
                    "type": "message",
                    "address": {
                      "user": {
                        "id": "1244",
                        "name": "Jan Dvo\u0159\u00e1k"
                      },
                      "conversation": {
                        "id": "abcd"
                      },
                      "serviceUrl": "https://xyz.com/api/message"
                    },
                    "text": "Co chcete d\u011blat d\u00e1le?",
                    "suggestedActions": {
                      "actions": [
                        {
                          "type": "imBack",
                          "value": "Pokra\u010dovat",
                          "title": "Pokra\u010dovat"
                        },
                        {
                          "type": "imBack",
                          "value": "Oper\u00e1tor",
                          "title": "P\u0159epojit"
                        }
                      ]
                    }
                  }
                },
                "messageWithCarousel": {
                  "summary": "Send message with carousel",
                  "value": {
                    "type": "message",
                    "address": {
                      "user": {
                        "id": "1244",
                        "name": "Jan Dvo\u0159\u00e1k"
                      },
                      "conversation": {
                        "id": "abcd"
                      },
                      "serviceUrl": "https://xyz.com/api/message"
                    },
                    "text": "Co chcete d\u011blat d\u00e1le?",
                    "attachmentLayout": "carousel",
                    "attachments": [
                      {
                        "contentType": "application/vnd.microsoft.card.hero",
                        "content": {
                          "text": "Text 1",
                          "buttons": [
                            {
                              "type": "imBack",
                              "value": "Prvn\u00ed",
                              "title": "Vybrat"
                            }
                          ],
                          "title": "Titulek 1",
                          "subtitle": "Podtitulek 1"
                        }
                      },
                      {
                        "contentType": "application/vnd.microsoft.card.hero",
                        "content": {
                          "text": "Text 2",
                          "images": [
                            {
                              "url": "https://example.com/image2.jpg"
                            }
                          ],
                          "buttons": [
                            {
                              "type": "openUrl",
                              "value": "https://seznam.cz",
                              "title": "Seznam.cz"
                            }
                          ],
                          "title": "Titulek 2",
                          "subtitle": "Podtitulek 2"
                        }
                      }
                    ]
                  }
                },
                "handoff": {
                  "summary": "Handoff chat to the operator",
                  "value": {
                    "type": "handoff",
                    "address": {
                      "user": {
                        "id": "1244",
                        "name": "Jan Dvo\u0159\u00e1k"
                      },
                      "conversation": {
                        "id": "abcd"
                      },
                      "serviceUrl": "https://xyz.com/api/message"
                    },
                    "channelData": {
                      "operatorSkill": "loans",
                      "userEmail": "some@example.com"
                    }
                  }
                },
                "typing": {
                  "summary": "Send typing indicator",
                  "value": {
                    "type": "typing",
                    "address": {
                      "user": {
                        "id": "1244",
                        "name": "Jan Dvo\u0159\u00e1k"
                      },
                      "conversation": {
                        "id": "abcd"
                      },
                      "serviceUrl": "https://xyz.com/api/message"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfull response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "status": "OK",
                  "message": "Command successfull"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserEvent": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "event"
            ]
          },
          "name": {
            "type": "string"
          },
          "address": {
            "$ref": "#/components/schemas/UserAddress"
          },
          "channelData": {
            "type": "object",
            "properties": {
              "userData": {
                "type": "object",
                "properties": {
                  "referrerUrl": {
                    "type": "string"
                  },
                  "userAgent": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "required": [
          "type",
          "name",
          "address"
        ]
      },
      "UserMessage": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "message"
            ]
          },
          "text": {
            "type": "string",
            "enum": [
              "beginIntroDialog",
              "cancelHandoff"
            ]
          },
          "address": {
            "$ref": "#/components/schemas/UserAddress"
          },
          "channelData": {
            "type": "object",
            "properties": {
              "availableOperatorsCount": {
                "type": "integer"
              }
            }
          }
        },
        "required": [
          "type",
          "text",
          "address"
        ]
      },
      "UserAddress": {
        "type": "object",
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name"
            ]
          },
          "conversation": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              }
            }
          },
          "serviceUrl": {
            "type": "string"
          },
          "serviceOauthServer": {
            "type": "string"
          },
          "serviceOauthTokenEndpoint": {
            "type": "string"
          }
        }
      },
      "BotMessage": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "message"
            ]
          },
          "address": {
            "$ref": "#/components/schemas/UserAddress"
          },
          "text": {
            "type": "string"
          },
          "suggestedActions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "actions": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "imBack",
                        "postBack"
                      ]
                    },
                    "value": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type",
                    "value"
                  ]
                }
              },
              "required": [
                "type"
              ]
            }
          },
          "attachment": {
            "type": "object",
            "properties": {
              "attachmentLayout": {
                "type": "string",
                "example": "carousel"
              },
              "attachments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "contentType": {
                      "type": "string",
                      "example": "application/vnd.microsoft.card.hero"
                    },
                    "content": {
                      "$ref": "#/components/schemas/AttachmentHeroCard"
                    }
                  }
                }
              }
            }
          },
          "channelData": {
            "additionalProperties": true
          },
          "inputHint": {
            "type": "string",
            "enum": [
              "ignoringInput",
              "expectingInput",
              "acceptingInput"
            ]
          }
        },
        "required": [
          "type",
          "text",
          "address"
        ]
      },
      "BotTyping": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "typing"
            ]
          },
          "address": {
            "$ref": "#/components/schemas/UserAddress"
          }
        },
        "required": [
          "type"
        ]
      },
      "BotHandoff": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "handoff"
            ]
          },
          "address": {
            "$ref": "#/components/schemas/UserAddress"
          },
          "channelData": {
            "additionalProperties": true
          }
        },
        "required": [
          "type",
          "text"
        ]
      },
      "AttachmentHeroCard": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "buttons": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "imBack",
                    "postBack"
                  ]
                },
                "value": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                }
              }
            }
          },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}