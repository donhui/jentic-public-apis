                    },
                    {
                      "site_ts_timestamp": [
                        1679672905,
                        1679759305,
                        1679842105,
                        1679928505,
                        1679992692
                      ],
                      "site_ts_metadata_name": "Lluvia",
                      "site_ts_metadata_measurement": "l/m2",
                      "site_ts_value": [
                        5.5,
                        23.0,
                        11.7,
                        14.5,
                        20.1
                      ]
                    },
                    {
                      "site_ts_timestamp": [
                        1679672905,
                        1679759305,
                        1679842105,
                        1679928505,
                        1679992692
                      ],
                      "site_ts_metadata_name": "Presi\u00f3n",
                      "site_ts_metadata_measurement": "hPa",
                      "site_ts_value": [
                        4.5,
                        5.0,
                        4.6,
                        3.8,
                        8.3
                      ]
                    },
                    {
                      "site_ts_timestamp": [
                        1679672905,
