{
  "openapi": "3.0.0",
  "servers": [
    {
      "description": "Aquasost Algae bloom API",
      "url": "https://virtserver.swaggerhub.com/Cetaqua/aquasost/1.0.0"
    }
  ],
  "info": {
    "description": "REST API for Aquasost Algae bloom service",
    "version": "1.0.0",
    "title": "Aquasost Algae bloom API",
    "contact": {
      "email": "info@cetaqua.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Cetaqua/aquasost/1.0.0/swagger.json"
  },
  "paths": {
    "/sites": {
      "get": {
        "summary": "retrieves list of sites",
        "operationId": "retrieve_all_sites",
        "description": "Returns the list of all sites. \n",
        "responses": {
          "200": {
            "description": "list of sites",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/site_item"
                  }
                },
                "example": [
                  {
                    "site_id": "as_001",
                    "site_name": "As_Forcadas",
                    "site_current_risk": "Alerta",
                    "site_coordinates": {
                      "site_lon": -8.078323,
                      "site_lat": 43.603492
                    }
                  },
                  {
                    "site_id": "as_002",
                    "site_name": "Beche",
                    "site_current_risk": "Prealerta",
                    "site_coordinates": {
                      "site_lon": -8.306916,
                      "site_lat": 43.181712
                    }
                  },
                  {
                    "site_id": "as_003",
                    "site_name": "Caldas",
                    "site_current_risk": "Alerta",
                    "site_coordinates": {
                      "site_lon": -8.606824,
                      "site_lat": 42.605043
                    }
                  },
                  {
                    "site_id": "as_004",
                    "site_name": "Cecebre",
                    "site_current_risk": "Normal",
                    "site_coordinates": {
                      "site_lon": -8.280654,
                      "site_lat": 43.272678
                    }
                  },
                  {
                    "site_id": "as_005",
                    "site_name": "Eiras",
                    "site_current_risk": "Normal",
                    "site_coordinates": {
                      "site_lon": -8.480838,
                      "site_lat": 42.4433
                    }
                  }
                ]
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authorization information is missing or invalid"
          }
        }
      }
    },
    "/sites/{id}": {
      "get": {
        "summary": "retrieves a specific site identified by id",
        "operationId": "retrieve_site",
        "description": "Returns information about a site \n",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "pass an id to retrieve a specific site",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "site matching provided id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/site_item"
                },
                "example": {
                  "site_id": "as_001",
                  "site_name": "As_Forcadas",
                  "site_current_risk": "Alerta",
                  "site_coordinates": {
                    "site_lon": -8.078323,
                    "site_lat": 43.603492
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authorization information is missing or invalid"
          },
          "404": {
            "description": "Site not found"
          }
        }
      }
    },
    "/sites/{id}/parameters/history": {
      "get": {
        "summary": "retrieves the historic series of quality parameters for a given site",
        "operationId": "retrieve_site_parameters_history",
        "description": "Returns a series of quality parameters by sourcetype for a given site in a given period. In case no from or to values are provided the entire time series is retrieved\n",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "pass an id to retrieve a specific site",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "from",
            "description": "beginning of the time window of the query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "to",
            "description": "end of the time window of the query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "series of parameters for the given site",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "site_id": {
                      "type": "string"
                    },
                    "site_source_type": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/site_source_type_time_series"
                      }
                    }
                  }
                },
