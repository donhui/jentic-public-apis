  "components": {
    "schemas": {
      "site_item": {
        "type": "object",
        "required": [
          "site_id",
          "site_name",
          "site_coordinates",
          "site_current_risk"
        ],
        "properties": {
          "site_id": {
            "type": "string",
            "example": "as_001"
          },
          "site_name": {
            "type": "string",
            "example": "Eir\u00e1s"
          },
          "site_coordinates": {
            "type": "object",
            "required": [
              "site_lat",
              "site_lon"
            ],
            "properties": {
              "site_lat": {
                "type": "string"
              },
              "site_lon": {
                "type": "string"
              }
            },
            "example": {
              "site_lon": 42.4544,
              "site_lat": 2.4544
            }
          },
          "site_current_risk": {
            "type": "string",
            "example": "Alerta"
          }
        }
      },
      "site_source_type_time_series": {
        "type": "object",
        "required": [
          "site_time_series"
        ],
        "properties": {
          "site_source_types": {
            "type": "array",
            "items": {
              "properties": {
                "site_source_type": {
                  "type": "string",
                  "example": "Boya"
                },
                "site_time_series": {
                  "type": "array",
                  "items": {
                    "properties": {
                      "site_ts_timestamp": {
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      },
                      "site_ts_metadata_name": {
                        "type": "string",
                        "example": "Pressure"
                      },
                      "site_ts_metadata_measurement": {
                        "type": "string",
                        "example": "dbar"
                      },
                      "site_ts_value": {
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "site_risk_series": {
        "type": "object",
        "required": [
          "rs_timestamp",
          "rs_value"
        ],
        "properties": {
          "rs_timestamp": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "rs_risk_value": {
            "type": "array",
            "items": {
              "type": "number"
            }
          },
          "rs_toxin_value": {
            "type": "array",
            "items": {
              "type": "number"
            }
          }
        }
      },
      "site_sampling_points": {
        "type": "object",
        "required": [
          "sp_id",
          "sp_source_type",
          "sp_coordinates",
          "sp_latest_measures",
          "sp_latest_measures_timestamp"
        ],
        "properties": {
          "sp_id": {
            "type": "string",
            "example": "as_004_sp_001"
          },
          "sp_source_type": {
            "type": "string",
            "example": "boya"
          },
          "sp_coordinates": {
            "type": "object",
            "required": [
              "sp_lat",
              "sp_lon"
            ],
            "properties": {
              "sp_lat": {
                "type": "string"
              },
              "sp_lon": {
                "type": "string"
              }
            },
            "example": {
              "sp_lat": 42.4544,
              "sp_lon": 2.4544
            }
          },
          "sp_latest_measures": {
            "type": "array",
            "items": {
              "properties": {
                "sp_latest_measures_metadata_name": {
                  "type": "string",
                  "example": "Pressure"
                },
                "sp_latest_measures_metadatameasurement": {
                  "type": "string",
                  "example": "dbar"
                },
                "sp_latest_measures_value": {
                  "type": "number",
                  "example": 34.23
                }
              }
            }
          }
        }
      },
      "site_tree_with_image": {
        "type": "object",
        "required": [
          "tr_timestamp",
          "tr_image"
        ],
        "properties": {
          "tr_timestamp": {
            "type": "integer",
            "example": 1677002661
          },
          "tr_path": {
            "type": "string",
            "example": "/resources/img/as004/important/116633222.jpg"
          }
        }
      }
    }
  }
}