    "/sites/{id}/parameters/forecast": {
      "get": {
        "summary": "retrieves the forecast of the quality parameters for a given site",
        "operationId": "retrieve_site_parameters_forecast",
        "description": "Returns the forecast of quality parameters as provided by MeteoGalicia for a given site. \n",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "pass an id to retrieve a specific site",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "forecast of quality parameters for the given site as provided by MeteoGalicia",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "site_id": {
                      "type": "string"
                    },
                    "site_source_type": {
                      "type": "string",
                      "example": "sensor"
                    },
                    "site_parameters_forecast_time_series": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "site_parameters_forecast_ts_timestamp": {
                            "type": "array",
                            "items": {
                              "type": "number"
                            }
                          },
                          "site_parameters_forecast_ts_name": {
                            "type": "string",
                            "example": "Temp_med"
                          },
                          "site_parameters_forecast_ts_measurement": {
                            "type": "string",
                            "example": "\u00b0C"
                          },
                          "site_parameters_forecast_ts_value": {
                            "type": "array",
                            "items": {
                              "type": "number"
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "example": {
                  "site_id": "as_005",
                  "site_source_type": "MeteoGalicia",
                  "site_parameters_forecast_time_series": [
                    {
                      "site_ts_timestamp": [
                        1679672905,
