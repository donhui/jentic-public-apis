{
  "openapi": "3.0.3",
  "info": {
    "title": "Clip Payments API",
    "description": "Clip payment processing API for Mexico. Supports payment links, transparent checkout with card tokenization, transactions, refunds, deposits, and PinPad device integration.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://developer.clip.mx/"
  },
  "servers": [
    {
      "url": "https://api.clip.mx",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "tags": [
    { "name": "PaymentLinks", "description": "Checkout payment link operations" },
    { "name": "Checkout", "description": "Transparent checkout with card tokenization" },
    { "name": "Transactions", "description": "Transaction retrieval" },
    { "name": "Refunds", "description": "Refund operations" },
    { "name": "Deposits", "description": "Settlement and deposit reports" },
    { "name": "PinPad", "description": "PinPad device payment operations" }
  ],
  "paths": {
    "/payment-links": {
      "post": {
        "operationId": "createPaymentLink",
        "summary": "Create a new payment link",
        "tags": ["PaymentLinks"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePaymentLinkRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment link created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaymentLink" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/payment-links/{id}": {
      "get": {
        "operationId": "getPaymentLink",
        "summary": "Get payment link status",
        "tags": ["PaymentLinks"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Payment link identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment link details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaymentLink" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tokens": {
      "post": {
        "operationId": "createCardToken",
        "summary": "Generate a card token for secure transactions",
        "tags": ["Checkout"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTokenRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Card token created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TokenResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/charges": {
      "post": {
        "operationId": "createCharge",
        "summary": "Process a payment using a card token",
        "tags": ["Checkout"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateChargeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment processed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChargeResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions": {
      "get": {
        "operationId": "listTransactions",
        "summary": "List transactions with optional filters",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Start date filter",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "to",
            "in": "query",
            "description": "End date filter",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results",
            "schema": { "type": "integer" }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Pagination offset",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Transactions retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TransactionsListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/transactions/{transactionId}": {
      "get": {
        "operationId": "getTransaction",
        "summary": "Get transaction details",
        "tags": ["Transactions"],
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "description": "Transaction identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/refunds": {
      "post": {
        "operationId": "createRefund",
        "summary": "Create a refund for a transaction",
        "tags": ["Refunds"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRefundRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Refund request created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Refund" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/refunds/{refundId}": {
      "get": {
        "operationId": "getRefund",
        "summary": "Get refund details and status",
        "tags": ["Refunds"],
        "parameters": [
          {
            "name": "refundId",
            "in": "path",
            "required": true,
            "description": "Refund identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Refund details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Refund" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/settlements": {
      "get": {
        "operationId": "getSettlements",
        "summary": "Get settlement summary",
        "tags": ["Deposits"],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Start date filter",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "to",
            "in": "query",
            "description": "End date filter",
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": {
            "description": "Settlement summary retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SettlementsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/deposits": {
      "get": {
        "operationId": "getDeposits",
        "summary": "Get detailed deposit breakdown",
        "tags": ["Deposits"],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "description": "Start date filter",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "to",
            "in": "query",
            "description": "End date filter",
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": {
            "description": "Deposit details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DepositsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/f2f/pinpad/v1/payment": {
      "post": {
        "operationId": "createPinPadPayment",
        "summary": "Create a PinPad payment intent",
        "tags": ["PinPad"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePinPadPaymentRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment intent created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PinPadPaymentResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/f2f/pinpad/v1/payment/{paymentId}": {
      "get": {
        "operationId": "getPinPadPayment",
        "summary": "Get PinPad payment details",
        "tags": ["PinPad"],
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "description": "Payment identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PinPadPaymentResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/f2f/pinpad/v1/payment/{pinpadRequestId}": {
      "delete": {
        "operationId": "cancelPinPadPaymentById",
        "summary": "Cancel a PinPad payment by request ID",
        "tags": ["PinPad"],
        "parameters": [
          {
            "name": "pinpadRequestId",
            "in": "path",
            "required": true,
            "description": "PinPad request identifier",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CancellationResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/f2f/pinpad/v1/payment/serial-number/{serialNumber}": {
      "delete": {
        "operationId": "cancelPinPadPaymentBySerial",
        "summary": "Cancel a PinPad payment by device serial number",
        "tags": ["PinPad"],
        "parameters": [
          {
            "name": "serialNumber",
            "in": "path",
            "required": true,
            "description": "PinPad device serial number",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CancellationResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/f2f/pinpad/v1/devices/status": {
      "get": {
        "operationId": "getPinPadDeviceStatus",
        "summary": "Get PinPad device status",
        "tags": ["PinPad"],
        "responses": {
          "200": {
            "description": "Device status retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeviceStatusResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication using base64(api_key:api_secret)"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing credentials",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "CreatePaymentLinkRequest": {
        "type": "object",
        "required": ["amount", "currency"],
        "properties": {
          "amount": { "type": "number", "description": "Payment amount" },
          "currency": { "type": "string", "description": "Currency code (MXN or USD)", "enum": ["MXN", "USD"] },
          "description": { "type": "string", "description": "Payment description" },
          "expiration_date": { "type": "string", "format": "date-time", "description": "Link expiration date" },
          "reference": { "type": "string", "description": "Merchant reference" }
        }
      },
      "PaymentLink": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "status": { "type": "string" },
          "description": { "type": "string" },
          "expiration_date": { "type": "string", "format": "date-time" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateTokenRequest": {
        "type": "object",
        "required": ["card_number", "card_name", "exp_month", "exp_year", "cvv"],
        "properties": {
          "card_number": { "type": "string", "description": "Card number" },
          "card_name": { "type": "string", "description": "Cardholder name" },
          "exp_month": { "type": "string", "description": "Expiration month (MM)" },
          "exp_year": { "type": "string", "description": "Expiration year (YY or YYYY)" },
          "cvv": { "type": "string", "description": "Card verification value" }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Card token" },
          "last_four": { "type": "string" },
          "card_brand": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateChargeRequest": {
        "type": "object",
        "required": ["amount", "currency", "token"],
        "properties": {
          "amount": { "type": "number", "description": "Charge amount" },
          "currency": { "type": "string", "enum": ["MXN", "USD"] },
          "token": { "type": "string", "description": "Card token from /tokens endpoint" },
          "installments": {
            "type": "integer",
            "description": "Monthly installments (MSI)",
            "enum": [3, 6, 9, 12, 18, 24]
          },
          "description": { "type": "string" },
          "reference": { "type": "string" }
        }
      },
      "ChargeResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "status": { "type": "string" },
          "reference": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "TransactionsListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Transaction" }
          },
          "total": { "type": "integer" }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "status": { "type": "string" },
          "type": { "type": "string" },
          "reference": { "type": "string" },
          "description": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CreateRefundRequest": {
        "type": "object",
        "required": ["transaction_id"],
        "properties": {
          "transaction_id": { "type": "string", "description": "Original transaction ID" },
          "amount": { "type": "number", "description": "Refund amount (full or partial)" }
        }
      },
      "Refund": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "transaction_id": { "type": "string" },
          "amount": { "type": "number" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "SettlementsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "period_start": { "type": "string", "format": "date" },
                "period_end": { "type": "string", "format": "date" },
                "total_amount": { "type": "number" },
                "currency": { "type": "string" },
                "status": { "type": "string" }
              }
            }
          }
        }
      },
      "DepositsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "amount": { "type": "number" },
                "currency": { "type": "string" },
                "date": { "type": "string", "format": "date" },
                "status": { "type": "string" }
              }
            }
          }
        }
      },
      "CreatePinPadPaymentRequest": {
        "type": "object",
        "required": ["amount", "serial_number"],
        "properties": {
          "amount": { "type": "number", "description": "Payment amount" },
          "serial_number": { "type": "string", "description": "PinPad device serial number" },
          "reference": { "type": "string", "description": "Merchant reference" }
        }
      },
      "PinPadPaymentResponse": {
        "type": "object",
        "properties": {
          "pinpad_request_id": { "type": "string" },
          "amount": { "type": "number" },
          "reference": { "type": "string" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CancellationResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "DeviceStatusResponse": {
        "type": "object",
        "properties": {
          "serial_number": { "type": "string" },
          "status": { "type": "string" },
          "last_seen": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}