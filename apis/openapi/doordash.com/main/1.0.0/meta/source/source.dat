              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Businesses"],
        "summary": "Update a business",
        "description": "Updates an existing business entity.",
        "operationId": "updateBusiness",
        "parameters": [
          {
            "name": "external_business_id",
            "in": "path",
            "description": "The unique external business identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBusinessRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Business updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Business"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Business not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/drive/v2/businesses/{external_business_id}/stores": {
      "post": {
        "tags": ["Stores"],
        "summary": "Create a store",
        "description": "Creates a new store under a business. A store represents an individual pickup location such as a restaurant or storefront.",
        "operationId": "createStore",
        "parameters": [
          {
            "name": "external_business_id",
            "in": "path",
            "description": "The external business ID that owns this store",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateStoreRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Store created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Store"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Business not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Store with this external_store_id already exists under this business",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Stores"],
        "summary": "List stores",
        "description": "Retrieves a list of stores under a business.",
        "operationId": "listStores",
        "parameters": [
          {
            "name": "external_business_id",
            "in": "path",
            "description": "The external business ID that owns the stores",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of stores to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "continuation_token",
            "in": "query",
            "description": "Token for paginating through results",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of stores retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoreListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Business not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/drive/v2/businesses/{external_business_id}/stores/{external_store_id}": {
      "get": {
        "tags": ["Stores"],
        "summary": "Get a store",
        "description": "Retrieves the details of an existing store by its external store ID under a given business.",
        "operationId": "getStore",
        "parameters": [
          {
            "name": "external_business_id",
            "in": "path",
            "description": "The external business ID that owns this store",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_store_id",
            "in": "path",
            "description": "The unique external store identifier within the business",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Store details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Store"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Business or store not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Stores"],
        "summary": "Update a store",
        "description": "Updates an existing store under a business.",
        "operationId": "updateStore",
        "parameters": [
          {
            "name": "external_business_id",
            "in": "path",
            "description": "The external business ID that owns this store",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "external_store_id",
            "in": "path",
            "description": "The unique external store identifier within the business",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateStoreRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Store updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Store"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Business or store not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token signed with HS256 using your signing_secret. The JWT must include claims: aud (doordash), iss (developer_id), kid (key_id), exp (expiration timestamp), iat (issued-at timestamp), and header dd-ver: DD-JWT-V1. Tokens typically expire after 5 minutes."
      }
    },
    "schemas": {
      "CreateDeliveryRequest": {
        "type": "object",
        "required": [
          "external_delivery_id",
          "pickup_address",
          "pickup_phone_number",
          "dropoff_address",
          "dropoff_phone_number",
          "order_value"
        ],
        "properties": {
          "external_delivery_id": {
            "type": "string",
            "description": "A unique identifier for this delivery in your system"
          },
          "pickup_address": {
            "type": "string",
            "description": "Full street address of the pickup location"
          },
          "pickup_business_name": {
            "type": "string",
            "description": "Business name at the pickup location"
          },
          "pickup_phone_number": {
            "type": "string",
            "description": "Phone number at the pickup location in E.164 format (e.g. +16505555555)"
          },
          "pickup_instructions": {
            "type": "string",
            "description": "Instructions for the Dasher at the pickup location"
          },
          "pickup_reference_tag": {
            "type": "string",
            "description": "Reference tag for the pickup (e.g. order number for the Dasher to give at pickup)"
          },
          "pickup_external_business_id": {
            "type": "string",
            "description": "External business ID for the pickup location. Omit to use default business."
          },
          "pickup_external_store_id": {
            "type": "string",
            "description": "External store ID for the pickup location. Omit to use default store."
          },
          "dropoff_address": {
            "type": "string",
            "description": "Full street address of the dropoff location"
          },
          "dropoff_business_name": {
            "type": "string",
            "description": "Business name at the dropoff location"
          },
          "dropoff_phone_number": {
            "type": "string",
            "description": "Phone number at the dropoff location in E.164 format"
          },
          "dropoff_instructions": {
            "type": "string",
            "description": "Instructions for the Dasher at the dropoff location"
          },
          "dropoff_contact_given_name": {
            "type": "string",
            "description": "First name of the recipient at the dropoff location"
          },
          "dropoff_contact_family_name": {
            "type": "string",
            "description": "Last name of the recipient at the dropoff location"
          },
          "dropoff_contact_send_notifications": {
            "type": "boolean",
            "description": "Whether DoorDash should send SMS notifications to the dropoff contact"
          },
          "order_value": {
            "type": "integer",
            "description": "Value of the order in cents (e.g. 1999 for $19.99)"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code (e.g. USD)",
            "default": "USD"
          },
          "tip": {
            "type": "integer",
            "description": "Tip amount for the Dasher in cents"
          },
          "order_contains": {
            "type": "object",
            "description": "Flags indicating what the order contains",
            "properties": {
              "alcohol": {
                "type": "boolean",
                "description": "Whether the order contains alcohol"
              },
              "pharmacy_items": {
                "type": "boolean",
                "description": "Whether the order contains pharmacy items"
              },
              "age_restricted_pharmacy_items": {
                "type": "boolean",
                "description": "Whether the order contains age-restricted pharmacy items"
              }
            }
          },
          "pickup_time": {
            "type": "string",
            "format": "date-time",
            "description": "Requested pickup time in ISO-8601 UTC format. If not specified, delivery is ASAP."
          },
          "dropoff_time": {
            "type": "string",
            "format": "date-time",
            "description": "Requested dropoff time in ISO-8601 UTC format"
          },
          "pickup_window": {
            "type": "object",
            "description": "Time window for pickup",
            "properties": {
              "start_time": {
                "type": "string",
                "format": "date-time",
                "description": "Start of the pickup window in ISO-8601 UTC format"
              },
              "end_time": {
                "type": "string",
                "format": "date-time",
                "description": "End of the pickup window in ISO-8601 UTC format"
              }
            }
          },
          "dropoff_window": {
            "type": "object",
            "description": "Time window for dropoff",
            "properties": {
              "start_time": {
                "type": "string",
                "format": "date-time",
                "description": "Start of the dropoff window in ISO-8601 UTC format"
              },
              "end_time": {
                "type": "string",
                "format": "date-time",
                "description": "End of the dropoff window in ISO-8601 UTC format"
              }
            }
          },
          "contactless_dropoff": {
            "type": "boolean",
            "description": "Whether the delivery should be contactless"
          },
          "action_if_undeliverable": {
            "type": "string",
            "description": "Action to take if the delivery cannot be completed",
            "enum": ["return_to_pickup", "dispose"]
          },
          "dropoff_requires_signature": {
            "type": "boolean",
            "description": "Whether the dropoff requires a recipient signature. Cannot be true if contactless_dropoff is true."
          },
          "promotion_id": {
            "type": "string",
            "description": "Promotion ID for any applicable promotional pricing"
          },
          "dropoff_cash_on_delivery": {
            "type": "integer",
            "description": "Cash on delivery amount to collect in cents"
          },
          "items": {
            "type": "array",
            "description": "List of items in the delivery",
            "items": {
              "$ref": "#/components/schemas/DeliveryItem"
            }
          },
          "team_lift_required": {
            "type": "boolean",
            "description": "Whether the delivery requires team lift (heavy items)"
          },
          "barcode_scanning_required": {
            "type": "boolean",
            "description": "Whether barcode scanning is required at pickup/dropoff"
          },
          "force_batch_id": {
            "type": "string",
            "description": "ID to batch multiple deliveries together for the same Dasher"
          }
        }
      },
      "UpdateDeliveryRequest": {
        "type": "object",
        "properties": {
          "pickup_address": {
            "type": "string",
            "description": "Updated pickup address"
          },
          "pickup_business_name": {
            "type": "string",
            "description": "Updated business name at pickup"
          },
          "pickup_phone_number": {
            "type": "string",
            "description": "Updated phone number at pickup"
          },
          "pickup_instructions": {
            "type": "string",
            "description": "Updated pickup instructions"
          },
          "dropoff_address": {
            "type": "string",
            "description": "Updated dropoff address"
          },
          "dropoff_business_name": {
            "type": "string",
            "description": "Updated business name at dropoff"
          },
          "dropoff_phone_number": {
            "type": "string",
            "description": "Updated phone number at dropoff"
          },
          "dropoff_instructions": {
            "type": "string",
            "description": "Updated dropoff instructions"
          },
          "dropoff_contact_given_name": {
            "type": "string",
            "description": "Updated first name of the recipient"
          },
          "dropoff_contact_family_name": {
            "type": "string",
            "description": "Updated last name of the recipient"
          },
          "dropoff_contact_send_notifications": {
            "type": "boolean",
            "description": "Whether to send SMS notifications to the dropoff contact"
          },
          "tip": {
            "type": "integer",
            "description": "Updated tip amount in cents"
          },
          "pickup_time": {
            "type": "string",
            "format": "date-time",
            "description": "Updated pickup time"
          },
          "dropoff_time": {
            "type": "string",
            "format": "date-time",
            "description": "Updated dropoff time"
          }
        }
      },
      "CancelDeliveryRequest": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "description": "Reason for cancelling the delivery"
          }
        }
      },
      "Delivery": {
        "type": "object",
        "properties": {
          "external_delivery_id": {
            "type": "string",
            "description": "The unique external delivery identifier"
          },
          "delivery_status": {
            "type": "string",
            "description": "Current status of the delivery",
            "enum": [
              "created",
              "confirmed",
              "enroute_to_pickup",
              "arrived_at_pickup",
              "picked_up",
              "enroute_to_dropoff",
              "arrived_at_dropoff",
              "delivered",
              "cancelled"
            ]
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "fee": {
            "type": "integer",
            "description": "Delivery fee in cents"
          },
          "tip": {
            "type": "integer",
            "description": "Tip amount in cents"
          },
          "order_value": {
            "type": "integer",
            "description": "Order value in cents"
          },
          "pickup_address": {
            "type": "string",
            "description": "Pickup street address"
          },
          "pickup_business_name": {
            "type": "string",
            "description": "Business name at pickup"
          },
          "pickup_phone_number": {
            "type": "string",
            "description": "Phone number at pickup"
          },
          "pickup_instructions": {
            "type": "string",
            "description": "Pickup instructions"
          },
          "pickup_reference_tag": {
            "type": "string",
            "description": "Pickup reference tag"
          },
          "pickup_external_business_id": {
            "type": "string",
            "description": "External business ID for pickup"
          },
          "pickup_external_store_id": {
            "type": "string",
            "description": "External store ID for pickup"
          },
          "dropoff_address": {
            "type": "string",
            "description": "Dropoff street address"
          },
          "dropoff_business_name": {
            "type": "string",
            "description": "Business name at dropoff"
          },
          "dropoff_phone_number": {
            "type": "string",
            "description": "Phone number at dropoff"
          },
          "dropoff_instructions": {
            "type": "string",
            "description": "Dropoff instructions"
          },
          "dropoff_contact_given_name": {
            "type": "string",
            "description": "First name of the recipient"
          },
          "dropoff_contact_family_name": {
            "type": "string",
            "description": "Last name of the recipient"
          },
          "dropoff_contact_send_notifications": {
            "type": "boolean",
            "description": "Whether SMS notifications are sent to the dropoff contact"
          },
          "contactless_dropoff": {
            "type": "boolean",
            "description": "Whether the delivery is contactless"
          },
          "action_if_undeliverable": {
            "type": "string",
            "description": "Action taken if undeliverable",
            "enum": ["return_to_pickup", "dispose"]
          },
          "dropoff_requires_signature": {
            "type": "boolean",
            "description": "Whether dropoff requires a signature"
          },
          "tracking_url": {
            "type": "string",
            "description": "URL for tracking the delivery status in real time"
          },
          "support_reference": {
            "type": "string",
            "description": "Reference ID for DoorDash support inquiries"
          },
          "dasher_id": {
            "type": "integer",
            "description": "Unique identifier of the assigned Dasher",
            "nullable": true
          },
          "dasher_name": {
            "type": "string",
            "description": "Name of the assigned Dasher",
            "nullable": true
          },
          "dasher_dropoff_phone_number": {
            "type": "string",
            "description": "Dasher phone number for dropoff contact",
            "nullable": true
          },
          "dasher_pickup_phone_number": {
            "type": "string",
            "description": "Dasher phone number for pickup contact",
            "nullable": true
          },
          "dasher_location": {
            "type": "object",
            "nullable": true,
            "description": "Current location of the Dasher",
            "properties": {
              "lat": {
                "type": "number",
                "format": "double",
                "description": "Latitude"
              },
              "lng": {
                "type": "number",
                "format": "double",
                "description": "Longitude"
              }
            }
          },
          "dasher_vehicle_make": {
            "type": "string",
            "description": "Vehicle make of the Dasher",
            "nullable": true
          },
          "dasher_vehicle_model": {
            "type": "string",
            "description": "Vehicle model of the Dasher",
            "nullable": true
          },
          "dasher_vehicle_year": {
            "type": "string",
            "description": "Vehicle year of the Dasher",
            "nullable": true
          },
          "pickup_time_estimated": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated pickup time in ISO-8601 UTC format",
            "nullable": true
          },
          "pickup_time_actual": {
            "type": "string",
            "format": "date-time",
            "description": "Actual pickup time in ISO-8601 UTC format",
            "nullable": true
          },
          "dropoff_time_estimated": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated dropoff time in ISO-8601 UTC format",
            "nullable": true
          },
          "dropoff_time_actual": {
            "type": "string",
            "format": "date-time",
            "description": "Actual dropoff time in ISO-8601 UTC format",
            "nullable": true
          },
          "return_time_estimated": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated return time if applicable",
            "nullable": true
          },
          "return_time_actual": {
            "type": "string",
            "format": "date-time",
            "description": "Actual return time if applicable",
            "nullable": true
          },
          "return_address": {
            "type": "string",
            "description": "Return address if delivery is undeliverable",
            "nullable": true
          },
          "dropoff_verification_image_url": {
            "type": "string",
            "description": "URL of the dropoff verification photo taken by the Dasher",
            "nullable": true
          },
          "pickup_verification_image_url": {
            "type": "string",
            "description": "URL of the pickup verification photo",
            "nullable": true
          },
          "dropoff_signature_image_url": {
            "type": "string",
            "description": "URL of the recipient signature image",
            "nullable": true
          },
          "promotion_id": {
            "type": "string",
            "description": "Applied promotion ID",
            "nullable": true
          },
          "dropoff_cash_on_delivery": {
            "type": "integer",
            "description": "Cash on delivery amount in cents",
            "nullable": true
          },
          "cancellation_reason": {
            "type": "string",
            "description": "Reason for cancellation if the delivery was cancelled",
            "nullable": true
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the delivery was last updated in ISO-8601 UTC format"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the delivery was created in ISO-8601 UTC format"
          },
          "items": {
            "type": "array",
            "description": "List of items in the delivery",
            "items": {
              "$ref": "#/components/schemas/DeliveryItem"
            }
          },
          "force_batch_id": {
            "type": "string",
            "description": "Batch ID if the delivery is part of a batch",
            "nullable": true
          },
          "team_lift_required": {
            "type": "boolean",
            "description": "Whether team lift is required"
          },
          "barcode_scanning_required": {
            "type": "boolean",
            "description": "Whether barcode scanning is required"
          }
        }
      },
      "DeliveryItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the item"
          },
          "description": {
            "type": "string",
            "description": "Description of the item"
          },
          "quantity": {
            "type": "integer",
            "description": "Quantity of the item"
          },
          "external_id": {
            "type": "string",
            "description": "External identifier for the item"
          },
          "price": {
            "type": "integer",
            "description": "Price of the item in cents"
          },
          "weight": {
            "type": "number",
            "format": "double",
            "description": "Weight of the item in pounds"
          },
          "length": {
            "type": "number",
            "format": "double",
            "description": "Length of the item in inches"
          },
          "width": {
            "type": "number",
            "format": "double",
            "description": "Width of the item in inches"
          },
          "height": {
            "type": "number",
            "format": "double",
            "description": "Height of the item in inches"
          },
          "barcode": {
            "type": "string",
            "description": "Barcode value for the item"
          },
          "substitution_preference": {
            "type": "string",
            "description": "Substitution preference for the item",
            "enum": ["no_substitution", "contact", "best_available"]
          }
        }
      },
      "DeliveryListResponse": {
        "type": "object",
        "properties": {
          "deliveries": {
            "type": "array",
            "description": "List of deliveries",
            "items": {
              "$ref": "#/components/schemas/Delivery"
            }
          },
          "continuation_token": {
            "type": "string",
            "description": "Token to retrieve the next page of results",
            "nullable": true
          }
        }
      },
      "CreateQuoteRequest": {
        "type": "object",
        "required": [
          "external_delivery_id",
          "pickup_address",
          "dropoff_address",
          "order_value"
        ],
        "properties": {
          "external_delivery_id": {
            "type": "string",
            "description": "A unique identifier for this delivery quote in your system"
          },
          "pickup_address": {
            "type": "string",
            "description": "Full street address of the pickup location"
          },
          "pickup_business_name": {
            "type": "string",
            "description": "Business name at the pickup location"
          },
          "pickup_phone_number": {
            "type": "string",
            "description": "Phone number at the pickup location"
          },
          "pickup_external_business_id": {
            "type": "string",
            "description": "External business ID for the pickup location"
          },
          "pickup_external_store_id": {
            "type": "string",
            "description": "External store ID for the pickup location"
          },
          "dropoff_address": {
            "type": "string",
            "description": "Full street address of the dropoff location"
          },
          "dropoff_phone_number": {
            "type": "string",
            "description": "Phone number at the dropoff location"
          },
          "order_value": {
            "type": "integer",
            "description": "Value of the order in cents"
          },
          "pickup_time": {
            "type": "string",
            "format": "date-time",
            "description": "Requested pickup time in ISO-8601 UTC format"
          },
          "dropoff_time": {
            "type": "string",
            "format": "date-time",
            "description": "Requested dropoff time in ISO-8601 UTC format"
          },
          "pickup_window": {
            "type": "object",
            "description": "Time window for pickup",
            "properties": {
              "start_time": {
                "type": "string",
                "format": "date-time"
              },
              "end_time": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "dropoff_window": {
            "type": "object",
            "description": "Time window for dropoff",
            "properties": {
              "start_time": {
                "type": "string",
                "format": "date-time"
              },
              "end_time": {
                "type": "string",
                "format": "date-time"
              }
            }
          },
          "order_contains": {
            "type": "object",
            "description": "Flags for order content types",
            "properties": {
              "alcohol": {
                "type": "boolean"
              },
              "pharmacy_items": {
                "type": "boolean"
              },
              "age_restricted_pharmacy_items": {
                "type": "boolean"
              }
            }
          },
          "items": {
            "type": "array",
            "description": "List of items for accurate quoting",
            "items": {
              "$ref": "#/components/schemas/DeliveryItem"
            }
          }
        }
      },
      "Quote": {
        "type": "object",
        "properties": {
          "external_delivery_id": {
            "type": "string",
            "description": "The external delivery identifier from the request"
          },
          "quote_id": {
            "type": "string",
            "description": "Unique identifier for this quote, used to accept the quote"
          },
          "fee": {
            "type": "integer",
            "description": "Estimated delivery fee in cents"
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code"
          },
          "pickup_time_estimated": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated pickup time in ISO-8601 UTC format"
          },
          "dropoff_time_estimated": {
            "type": "string",
            "format": "date-time",
            "description": "Estimated dropoff time in ISO-8601 UTC format"
          },
          "delivery_distance": {
            "type": "number",
            "format": "double",
            "description": "Estimated delivery distance in miles"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this quote expires in ISO-8601 UTC format"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the quote was created"
          }
        }
      },
      "AcceptQuoteRequest": {
        "type": "object",
        "required": [
          "dropoff_phone_number"
        ],
        "properties": {
          "dropoff_phone_number": {
            "type": "string",
            "description": "Phone number at the dropoff location in E.164 format"
          },
          "dropoff_instructions": {
            "type": "string",
            "description": "Instructions for the Dasher at the dropoff"
          },
          "dropoff_business_name": {
            "type": "string",
            "description": "Business name at the dropoff"
          },
          "dropoff_contact_given_name": {
            "type": "string",
            "description": "First name of the recipient"
          },
          "dropoff_contact_family_name": {
            "type": "string",
            "description": "Last name of the recipient"
          },
          "dropoff_contact_send_notifications": {
            "type": "boolean",
            "description": "Whether to send SMS notifications to the dropoff contact"
          },
          "pickup_instructions": {
            "type": "string",
            "description": "Instructions for the Dasher at pickup"
          },
          "pickup_phone_number": {
            "type": "string",
            "description": "Phone number at the pickup location"
          },
          "tip": {
            "type": "integer",
            "description": "Tip amount for the Dasher in cents"
          },
          "order_value": {
            "type": "integer",
            "description": "Updated order value in cents"
          },
          "items": {
            "type": "array",
            "description": "List of items in the delivery",
            "items": {
              "$ref": "#/components/schemas/DeliveryItem"
            }
          },
          "contactless_dropoff": {
            "type": "boolean",
            "description": "Whether the delivery should be contactless"
          },
          "action_if_undeliverable": {
            "type": "string",
            "enum": ["return_to_pickup", "dispose"],
            "description": "Action to take if the delivery cannot be completed"
          },
          "dropoff_requires_signature": {
            "type": "boolean",
            "description": "Whether the dropoff requires a recipient signature"
          }
        }
      },
      "CreateBusinessRequest": {
        "type": "object",
        "required": [
          "external_business_id",
          "name"
        ],
        "properties": {
          "external_business_id": {
            "type": "string",
            "description": "Unique external identifier for the business. Must match pattern: /^[A-Za-z0-9_-]{3,64}$/",
            "pattern": "^[A-Za-z0-9_-]{3,64}$"
          },
          "name": {
            "type": "string",
            "description": "Display name of the business"
          },
          "description": {
            "type": "string",
            "description": "Description of the business"
          },
          "activation_status": {
            "type": "string",
            "description": "Activation status of the business",
            "enum": ["active", "inactive"]
          }
        }
      },
      "UpdateBusinessRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
