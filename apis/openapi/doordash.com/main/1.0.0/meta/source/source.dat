            "type": "string",
            "description": "Full street address of the store"
          },
          "phone_number": {
            "type": "string",
            "description": "Phone number of the store in E.164 format"
          },
          "pickup_instructions": {
            "type": "string",
            "description": "Default pickup instructions for deliveries from this store"
          },
          "status": {
            "type": "string",
            "description": "Status of the store",
            "enum": ["active", "inactive"]
          },
          "location": {
            "type": "object",
            "description": "Precise geographic coordinates for the store",
            "properties": {
