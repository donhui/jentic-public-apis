{
  "openapi": "3.0.3",
  "info": {
    "title": "DoorDash Drive API",
    "description": "DoorDash Drive is a delivery-as-a-service platform that allows businesses to request on-demand deliveries powered by DoorDash's Dasher network. The API enables creating deliveries, obtaining delivery quotes, managing businesses and stores, and receiving real-time delivery status updates via webhooks.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.doordash.com/",
    "contact": {
      "name": "DoorDash Developer Support",
      "url": "https://developer.doordash.com/en-US/docs/drive/support"
    }
  },
  "servers": [
    {
      "url": "https://openapi.doordash.com",
      "description": "DoorDash Drive API production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Deliveries",
      "description": "Create, retrieve, update, and cancel deliveries"
    },
    {
      "name": "Quotes",
      "description": "Validate delivery coverage and get pricing quotes before creating a delivery"
    },
    {
      "name": "Businesses",
      "description": "Manage business entities that own stores"
    },
    {
      "name": "Stores",
      "description": "Manage store locations under a business"
    }
  ],
  "paths": {
    "/drive/v2/deliveries": {
      "post": {
        "tags": ["Deliveries"],
        "summary": "Create a delivery",
        "description": "Creates a new delivery request. A Dasher will be assigned to pick up items from the pickup address and deliver them to the dropoff address. The external_delivery_id must be unique across all your deliveries.",
        "operationId": "createDelivery",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDeliveryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Delivery created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed - bad or expired JWT token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Authorization failed - identity verified but operation not permitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict - system state does not allow operation to proceed (e.g. duplicate external_delivery_id)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error - request is properly formatted but cannot be executed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Deliveries"],
        "summary": "List deliveries",
        "description": "Retrieves a list of deliveries. Results can be filtered by various query parameters.",
        "operationId": "listDeliveries",
        "parameters": [
          {
            "name": "pickup_external_business_id",
            "in": "query",
            "description": "Filter deliveries by the external business ID of the pickup location",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pickup_external_store_id",
            "in": "query",
            "description": "Filter deliveries by the external store ID of the pickup location",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "created_after",
            "in": "query",
            "description": "Filter deliveries created after this ISO-8601 UTC timestamp",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "created_before",
            "in": "query",
            "description": "Filter deliveries created before this ISO-8601 UTC timestamp",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of deliveries to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "continuation_token",
            "in": "query",
            "description": "Token for paginating through results",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of deliveries retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeliveryListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/drive/v2/deliveries/{external_delivery_id}": {
      "get": {
        "tags": ["Deliveries"],
        "summary": "Get a delivery",
        "description": "Retrieves the current status and details of an existing delivery by its external delivery ID.",
        "operationId": "getDelivery",
        "parameters": [
          {
            "name": "external_delivery_id",
            "in": "path",
            "description": "The unique external delivery identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Delivery details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Delivery not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Deliveries"],
        "summary": "Update a delivery",
        "description": "Updates an existing delivery. Only certain fields can be updated depending on the current delivery status. For example, you can update tip amount or dropoff details before the Dasher picks up.",
        "operationId": "updateDelivery",
        "parameters": [
          {
            "name": "external_delivery_id",
            "in": "path",
            "description": "The unique external delivery identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDeliveryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Delivery updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Delivery not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict - delivery is in a state that does not allow this update",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/drive/v2/deliveries/{external_delivery_id}/cancel": {
      "put": {
        "tags": ["Deliveries"],
        "summary": "Cancel a delivery",
        "description": "Cancels an existing delivery. A delivery can only be cancelled if it has not yet been picked up by the Dasher. Cancellation fees may apply depending on the delivery status at the time of cancellation.",
        "operationId": "cancelDelivery",
        "parameters": [
          {
            "name": "external_delivery_id",
            "in": "path",
            "description": "The unique external delivery identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelDeliveryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Delivery cancelled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Delivery not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict - delivery cannot be cancelled in its current state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/drive/v2/quotes": {
      "post": {
        "tags": ["Quotes"],
        "summary": "Create a delivery quote",
        "description": "Creates a delivery quote to validate coverage and get estimated pricing before creating a delivery. The quote provides fee estimates and estimated pickup/dropoff times.",
        "operationId": "createQuote",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQuoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quote created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Quote"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error - e.g. delivery outside coverage area",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/drive/v2/quotes/{quote_id}/accept": {
      "post": {
        "tags": ["Quotes"],
        "summary": "Accept a delivery quote",
        "description": "Accepts a previously created delivery quote, which creates a delivery at the quoted price. The quote must not be expired.",
        "operationId": "acceptQuote",
        "parameters": [
          {
            "name": "quote_id",
            "in": "path",
            "description": "The unique identifier of the quote to accept",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptQuoteRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Quote accepted and delivery created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Delivery"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Quote not found or expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Quote has already been accepted or is expired",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/drive/v2/businesses": {
      "post": {
        "tags": ["Businesses"],
        "summary": "Create a business",
        "description": "Creates a new business entity. A business groups multiple stores and is used for invoice organization and portal access.",
        "operationId": "createBusiness",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBusinessRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Business created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Business"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Business with this external_business_id already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Businesses"],
        "summary": "List businesses",
        "description": "Retrieves a list of businesses associated with your developer account.",
        "operationId": "listBusinesses",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of businesses to return",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "continuation_token",
            "in": "query",
            "description": "Token for paginating through results",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of businesses retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BusinessListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/drive/v2/businesses/{external_business_id}": {
      "get": {
        "tags": ["Businesses"],
        "summary": "Get a business",
        "description": "Retrieves the details of an existing business by its external business ID.",
        "operationId": "getBusiness",
        "parameters": [
          {
            "name": "external_business_id",
            "in": "path",
