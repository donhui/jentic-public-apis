{
  "openapi": "3.0.3",
  "info": {
    "title": "Dua Dhikr",
    "description": "A REST API providing Islamic dua (supplications) and dhikr (remembrance) data organized by categories. Supports multiple languages via the Accept-Language header.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://github.com/Fitrahive/dua-dhikr"
  },
  "servers": [
    {
      "url": "https://dua-dhikr.vercel.app",
      "description": "Primary production server (Vercel)"
    },
    {
      "url": "https://dua-dhikr.onrender.com",
      "description": "Secondary production server (Render)"
    }
  ],
  "paths": {
    "/languages": {
      "get": {
        "operationId": "getlanguages",
        "summary": "List supported languages",
        "description": "Returns the list of supported languages for dua and dhikr content.",
        "tags": [
          "Languages"
        ],
        "responses": {
          "200": {
            "description": "List of supported languages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Language"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/categories": {
      "get": {
        "operationId": "getcategories",
        "summary": "Get dua and dhikr categories",
        "description": "Returns a list of all dua and dhikr categories.",
        "tags": [
          "Categories"
        ],
        "parameters": [
          {
            "name": "Accept-Language",
            "in": "header",
            "required": false,
            "description": "Language code for content. Defaults to 'id' (Indonesian).",
            "schema": {
              "type": "string",
              "default": "id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of categories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Category"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/categories/{slug}": {
      "get": {
        "operationId": "getcategoryduas",
        "summary": "Get duas/dhikrs in a category",
        "description": "Returns the list of duas and dhikrs within a specific category.",
        "tags": [
          "Categories"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "Category slug identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "required": false,
            "description": "Language code for content. Defaults to 'id' (Indonesian).",
            "schema": {
              "type": "string",
              "default": "id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of duas/dhikrs in the category",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DuaDhikr"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/categories/{slug}/{id}": {
      "get": {
        "operationId": "getduadhikrbyid",
        "summary": "Get a specific dua/dhikr entry",
        "description": "Returns details of a single dua or dhikr entry by its ID within a category.",
        "tags": [
          "Categories"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "Category slug identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Dua/dhikr entry ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "required": false,
            "description": "Language code for content. Defaults to 'id' (Indonesian).",
            "schema": {
              "type": "string",
              "default": "id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Dua/dhikr entry details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DuaDhikr"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Language": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Language code (e.g. id, en, ar)"
          },
          "name": {
            "type": "string",
            "description": "Language name"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "description": "Category slug identifier"
          },
          "title": {
            "type": "string",
            "description": "Category title"
          },
          "description": {
            "type": "string",
            "description": "Category description"
          }
        }
      },
      "DuaDhikr": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Entry ID"
          },
          "title": {
            "type": "string",
            "description": "Title of the dua/dhikr"
          },
          "arabic": {
            "type": "string",
            "description": "Arabic text"
          },
          "transliteration": {
            "type": "string",
            "description": "Transliteration of the Arabic text"
          },
          "translation": {
            "type": "string",
            "description": "Translation in the requested language"
          },
          "notes": {
            "type": "string",
            "description": "Additional notes"
          },
          "fawaid": {
            "type": "string",
            "description": "Benefits/virtues"
          },
          "source": {
            "type": "string",
            "description": "Hadith source reference"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          }
        },
        "required": [
          "message"
        ]
      }
    },
    "securitySchemes": {}
  },
  "security": [],
  "tags": [
    {
      "name": "Categories",
      "description": "Operations related to Categories"
    },
    {
      "name": "Languages",
      "description": "Operations related to Languages"
    }
  ]
}