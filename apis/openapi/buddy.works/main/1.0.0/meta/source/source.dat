  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth2 access token"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "message": { "type": "string" },
                "status": { "type": "integer" }
              }
            }
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "html_url": { "type": "string" },
          "name": { "type": "string" },
          "display_name": { "type": "string" },
          "status": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ProjectInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "display_name": { "type": "string" }
        }
      },
      "ProjectList": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "html_url": { "type": "string" },
          "projects": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Project" }
          }
        }
      },
      "Pipeline": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "html_url": { "type": "string" },
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "on": { "type": "string" },
          "refs": { "type": "array", "items": { "type": "string" } },
          "last_execution_status": { "type": "string" },
          "last_execution_revision": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "PipelineInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "on": { "type": "string", "enum": ["CLICK", "EVENT", "SCHEDULE"] },
          "refs": { "type": "array", "items": { "type": "string" } },
          "always_from_scratch": { "type": "boolean" },
          "auto_clear_cache": { "type": "boolean" }
        }
      },
      "PipelineList": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "html_url": { "type": "string" },
          "pipelines": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Pipeline" }
          }
        }
      },
      "Action": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "html_url": { "type": "string" },
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "ActionInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "trigger_time": { "type": "string", "enum": ["ON_EVERY_EXECUTION", "ON_FAILURE", "ON_BACK_TO_SUCCESS"] }
        }
      },
      "ActionList": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "actions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Action" }
          }
        }
      },
      "Environment": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "html_url": { "type": "string" },
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "identifier": { "type": "string" }
        }
      },
      "EnvironmentInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "identifier": { "type": "string" }
        }
      },
      "EnvironmentList": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "environments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Environment" }
          }
        }
      },
      "Commit": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "html_url": { "type": "string" },
          "revision": { "type": "string" },
          "author_date": { "type": "string", "format": "date-time" },
          "commit_date": { "type": "string", "format": "date-time" },
          "message": { "type": "string" },
          "author": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string" }
            }
          }
        }
      },
      "CommitList": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "commits": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Commit" }
          }
        }
      }
    }
  }
}