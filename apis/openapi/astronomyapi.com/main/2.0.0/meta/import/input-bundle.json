{
  "openapi": "3.0.3",
  "info": {
    "title": "Astronomy API",
    "version": "2.0.0",
    "description": "Free astronomy API providing celestial body positions, events, star charts, moon phases, and search for stars and deep space objects.",
    "x-jentic-source-url": "https://docs.astronomyapi.com"
  },
  "servers": [
    {
      "url": "https://api.astronomyapi.com/api/v2",
      "description": "Astronomy API v2 server"
    }
  ],
  "paths": {
    "/bodies": {
      "get": {
        "operationId": "listBodies",
        "summary": "List all celestial bodies",
        "description": "Get a list of available celestial bodies.",
        "tags": [
          "Bodies"
        ],
        "responses": {
          "200": {
            "description": "List of celestial bodies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Forbidden - authentication failure"
          }
        }
      }
    },
    "/bodies/positions": {
      "get": {
        "operationId": "getBodyPositions",
        "summary": "Get celestial body positions",
        "description": "Get positions of celestial bodies for given observer location and time.",
        "tags": [
          "Bodies"
        ],
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Observer latitude"
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Observer longitude"
          },
          {
            "name": "elevation",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Observer elevation in meters"
          },
          {
            "name": "from_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date"
          },
          {
            "name": "to_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date"
          },
          {
            "name": "time",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Time in HH:MM:SS format"
          }
        ],
        "responses": {
          "200": {
            "description": "Position data for celestial bodies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/bodies/positions/{body}": {
      "get": {
        "operationId": "getBodyPosition",
        "summary": "Get position of a specific celestial body",
        "tags": [
          "Bodies"
        ],
        "parameters": [
          {
            "name": "body",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Body identifier (e.g., sun, moon, mars)"
          },
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "elevation",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "from_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "time",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Position data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/bodies/events/{body}": {
      "get": {
        "operationId": "getBodyEvents",
        "summary": "Get events for a celestial body",
        "description": "Get celestial events for a given body within a date range.",
        "tags": [
          "Events"
        ],
        "parameters": [
          {
            "name": "body",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "elevation",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "from_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "time",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Events data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/studio/star-chart": {
      "post": {
        "operationId": "generateStarChart",
        "summary": "Generate a star chart image",
        "description": "Generates a star chart image with the given parameters and returns the URL.",
        "tags": [
          "Studio"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StarChartInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Star chart generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/studio/moon-phase": {
      "post": {
        "operationId": "generateMoonPhase",
        "summary": "Generate a moon phase image",
        "description": "Generate an image of the Moon based on the given parameters.",
        "tags": [
          "Studio"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MoonPhaseInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Moon phase image generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "searchObjects",
        "summary": "Search for stars and deep space objects",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search term"
          },
          {
            "name": "match_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "fuzzy",
                "exact"
              ],
              "default": "fuzzy"
            }
          },
          {
            "name": "ra",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Right ascension decimal value"
          },
          {
            "name": "dec",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Declination decimal value"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Number of records to return"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Pagination offset"
          },
          {
            "name": "order_by",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Sort field"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Authentication required"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Base64 encoded applicationId:applicationSecret"
      }
    },
    "schemas": {
      "StarChartInput": {
        "type": "object",
        "properties": {
          "style": {
            "type": "string"
          },
          "observer": {
            "$ref": "#/components/schemas/Observer"
          },
          "view": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "parameters": {
                "type": "object"
              }
            }
          }
        }
      },
      "MoonPhaseInput": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string"
          },
          "style": {
            "type": "object"
          },
          "observer": {
            "$ref": "#/components/schemas/Observer"
          },
          "view": {
            "type": "object"
          }
        }
      },
      "Observer": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "date": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "ImageResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "imageUrl": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "meta": {
            "type": "object",
            "properties": {
              "limit": {
                "type": "integer"
              },
              "offset": {
                "type": "integer"
              }
            }
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CelestialObject"
            }
          }
        }
      },
      "CelestialObject": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            }
          },
          "subType": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              }
            }
          },
          "crossIdentification": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "position": {
            "type": "object",
            "properties": {
              "equatorial": {
                "type": "object",
                "properties": {
                  "rightAscension": {
                    "type": "object"
                  },
                  "declination": {
                    "type": "object"
                  }
                }
              },
              "constellation": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "short": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ]
}