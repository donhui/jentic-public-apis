{
  "openapi": "3.0.3",
  "info": {
    "title": "Checkr Trust API",
    "description": "Checkr Trust is a modern, RESTful API-driven service designed to enhance trust and safety for platforms. Provides access to criminal records, traffic infractions, registry checks, driver checks, and identity verifications.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.checkrtrust.com/"
  },
  "servers": [
    {
      "url": "https://api.checkrtrust.com/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/accounts/token": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Obtain an access token",
        "description": "Exchange client_id and client_secret for an OAuth 2.0 access token. Tokens expire in 24 hours.",
        "operationId": "getAccessToken",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token successfully generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid client credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
