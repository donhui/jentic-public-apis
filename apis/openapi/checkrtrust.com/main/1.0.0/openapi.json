  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "OAuth 2.0 Bearer token obtained from /accounts/token endpoint"
      }
    },
    "schemas": {
      "TokenRequest": {
        "type": "object",
        "required": [
          "client_id",
          "client_secret"
        ],
        "properties": {
          "client_id": {
            "type": "string",
            "description": "Your Client Key"
          },
          "client_secret": {
            "type": "string",
            "description": "Your Secret Key"
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The OAuth access token"
          },
          "scope": {
            "type": "string",
            "description": "Scopes granted"
          },
          "expires_in": {
            "type": "integer",
            "description": "Token expiry time in seconds (86400 = 24 hours)"
          },
          "token_type": {
            "type": "string",
            "description": "Token type, always Bearer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type"
          },
          "error_description": {
            "type": "string",
            "description": "Human-readable error description"
          }
        }
      },
      "ProfileRequest": {
        "type": "object",
        "required": [
          "first_name",
          "last_name"
        ],
        "properties": {
          "first_name": {
            "type": "string",
            "description": "First name of the person"
          },
          "last_name": {
            "type": "string",
            "description": "Last name of the person"
          },
          "dob": {
            "type": "string",
            "description": "Date of birth in YYYYMMDD format"
          },
          "email": {
            "type": "string",
            "description": "Email address"
          },
          "phone": {
            "type": "string",
            "description": "Phone number"
          },
          "address": {
            "type": "string",
            "description": "Street address"
          }
        }
      },
      "Profile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Profile ID"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "dob": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CheckRequest": {
        "type": "object",
        "properties": {
          "first_name": {
            "type": "string",
            "description": "First name (required if no profile_id)"
          },
          "last_name": {
            "type": "string",
            "description": "Last name (required if no profile_id)"
          },
          "dob": {
            "type": "string",
            "description": "Date of birth in YYYYMMDD format (encouraged but not required)"
          },
          "profile_id": {
            "type": "string",
            "description": "Reference to existing profile PII"
          }
        }
      },
      "CheckResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Check ID"
          },
          "check_type": {
            "type": "string",
            "description": "Type of check performed"
          },
          "status": {
            "type": "string",
            "description": "Check status"
          },
          "results": {
            "type": "array",
            "description": "Check results. Empty results indicates no items on record.",
            "items": {
              "type": "object",
              "properties": {
                "record": {
                  "type": "object",
                  "description": "Criminal record data"
                }
              }
            }
          },
