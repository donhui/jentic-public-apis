        "required": ["type", "adAccountType", "ads"],
        "properties": {
          "type": {"type": "string", "enum": ["single", "multi", "carousel", "flexible"]},
          "adAccountType": {"type": "string", "enum": ["facebook", "tiktok", "snapchat", "pinterest", "axon", "taboola"]},
          "ads": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "adName": {"type": "string"},
                "adAccountId": {"type": "string"},
                "title": {"type": "string"},
                "description": {"type": "string"},
                "cta": {"type": "string"},
                "link": {"type": "string"},
                "page": {"type": "string"},
                "insta": {"type": "string"},
                "adSets": {"type": "array", "items": {"type": "string"}},
                "media": {"type": "array", "items": {"type": "object"}}
              }
            }
          }
        }
      },
      "LaunchResponse": {
        "type": "object",
        "properties": {
          "adBatchId": {"type": "string"},
          "slug": {"type": "string"},
          "isAsync": {"type": "boolean"}
        }
      },
      "BatchStatus": {
        "type": "object",
        "properties": {
          "status": {"type": "string", "enum": ["in_progress", "success", "error"]},
          "progress": {"type": "number"},
          "totalAds": {"type": "integer"},
          "successfulAds": {"type": "integer"}
        }
      },
      "GoogleCampaign": {
        "type": "object",
        "properties": {
          "campaignId": {"type": "string"},
          "name": {"type": "string"},
          "status": {"type": "string"},
          "spend": {"type": "number"},
          "impressions": {"type": "integer"},
          "clicks": {"type": "integer"},
          "adGroups": {"type": "array", "items": {"type": "object"}}
        }
      },
      "MediaFile": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "url": {"type": "string"},
          "filename": {"type": "string"},
          "adid": {"type": "string"},
          "dimensions": {"type": "string"},
          "thumbnail": {"type": "string"},
          "mimeType": {"type": "string"},
          "duration": {"type": "number"}
        }
      },
      "AdAccount": {
        "type": "object",
        "properties": {
          "accountId": {"type": "string"},
          "accountName": {"type": "string"},
          "businessId": {"type": "string"},
          "workspaceId": {"type": "string"},
          "type": {"type": "string"}
        }
      },
      "Draft": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "status": {"type": "string"},
          "state": {"type": "object"},
          "businessId": {"type": "string"},
          "workspaceId": {"type": "string"},
          "createdAt": {"type": "string", "format": "date-time"}
        }
      },
      "CreateDraftRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {"type": "string"},
          "businessId": {"type": "string"},
          "workspaceId": {"type": "string"},
          "state": {"type": "object"}
        }
      },
      "UpdateDraftRequest": {
        "type": "object",
        "properties": {
          "title": {"type": "string"},
          "state": {"type": "object"},
          "status": {"type": "string"},
          "businessId": {"type": "string"},
          "workspaceId": {"type": "string"}
        }
      },
      "AutomationRule": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "trigger": {"type": "object"},
          "condition": {"type": "object"},
          "action": {"type": "object"}
        }
      },
      "CreateAutomationRuleRequest": {
        "type": "object",
        "required": ["name", "trigger", "condition", "action"],
        "properties": {
          "name": {"type": "string"},
          "trigger": {"type": "object"},
          "condition": {"type": "object"},
          "action": {"type": "object"}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {"type": "string"},
          "message": {"type": "string"},
          "statusCode": {"type": "integer"}
        }
      }
    }
  }
}