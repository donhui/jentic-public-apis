{
  "openapi": "3.0.3",
  "info": {
    "title": "Admanage AI Ad Management API",
    "version": "1.0.0",
    "description": "Admanage AI API for launching, managing, and reporting on ads across Facebook, TikTok, Snapchat, Pinterest, Google Ads, Axon/AppLovin, and Taboola. Includes media management, library, drafts, automation rules, and performance reporting.",
    "x-jentic-source-url": "https://admanage.ai/api-docs"
  },
  "servers": [
    {
      "url": "https://api.admanage.ai/v1",
      "description": "Admanage AI API v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/launch": {
      "post": {
        "operationId": "launchAds",
        "summary": "Launch ads across platforms",
        "description": "Create an ad batch and dispatch to launcher service. Supports single, multi, carousel, and flexible ad types across Facebook, TikTok, Snapchat, Pinterest, Axon, and Taboola.",
        "tags": ["Launch"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/LaunchRequest"}
            }
          }
        },
        "responses": {
          "202": {"description": "Ad batch created and dispatched", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/LaunchResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/launch/from-draft": {
      "post": {
        "operationId": "launchFromDraft",
        "summary": "Launch ads from existing draft",
        "description": "Re-launch an existing batch by ID.",
        "tags": ["Launch"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["batchId"], "properties": {"batchId": {"type": "string"}}}}}
        },
        "responses": {
          "202": {"description": "Batch re-launched", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/LaunchResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/batch-status/{id}": {
      "get": {
        "operationId": "getBatchStatus",
        "summary": "Check batch launch status",
        "description": "Poll launch progress. Returns summary status, progress percentage, and ad counts.",
        "tags": ["Launch"],
        "parameters": [
          {"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Batch status", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BatchStatus"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/campaigns": {
      "get": {
        "operationId": "listGoogleAdsCampaigns",
        "summary": "List Google Ads campaigns",
        "tags": ["Google Ads"],
        "parameters": [
          {"name": "accountId", "in": "query", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Campaign list with spend, impressions, clicks", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/GoogleCampaign"}}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/campaigns/toggle-status": {
      "post": {
        "operationId": "toggleGoogleCampaignStatus",
        "summary": "Toggle Google Ads campaign status",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["accountId", "campaignId", "status"], "properties": {"accountId": {"type": "string"}, "campaignId": {"type": "string"}, "status": {"type": "string", "enum": ["ENABLED", "PAUSED"]}}}}}
        },
        "responses": {
          "200": {"description": "Status toggled", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/campaigns/rename": {
      "post": {
        "operationId": "renameGoogleCampaign",
        "summary": "Rename a Google Ads campaign",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["accountId", "campaignId", "newName"], "properties": {"accountId": {"type": "string"}, "campaignId": {"type": "string"}, "newName": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "Campaign renamed", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/duplicate-campaign": {
      "post": {
        "operationId": "duplicateGoogleCampaign",
        "summary": "Duplicate a Google Ads campaign",
        "description": "Copy campaign with all ad groups, ads, and keywords.",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["campaignId", "accountId", "newName"], "properties": {"campaignId": {"type": "string"}, "accountId": {"type": "string"}, "newName": {"type": "string"}, "status": {"type": "string", "enum": ["ENABLED", "PAUSED"]}}}}}
        },
        "responses": {
          "200": {"description": "Campaign duplicated", "content": {"application/json": {"schema": {"type": "object", "properties": {"newCampaignId": {"type": "string"}, "adGroupsCopied": {"type": "integer"}, "totalAdsCopied": {"type": "integer"}, "totalKeywordsCopied": {"type": "integer"}}}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/duplicate-ad-group": {
      "post": {
        "operationId": "duplicateGoogleAdGroup",
        "summary": "Duplicate a Google Ads ad group",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["campaignId", "adGroupId", "accountId", "newName"], "properties": {"campaignId": {"type": "string"}, "adGroupId": {"type": "string"}, "accountId": {"type": "string"}, "newName": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "Ad group duplicated", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/duplicate-ad": {
      "post": {
        "operationId": "duplicateGoogleAd",
        "summary": "Duplicate a Google Ads ad",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["adGroupId", "adId", "accountId"], "properties": {"adGroupId": {"type": "string"}, "adId": {"type": "string"}, "accountId": {"type": "string"}, "status": {"type": "string", "enum": ["ENABLED", "PAUSED"]}}}}}
        },
        "responses": {
          "200": {"description": "Ad duplicated", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/ad-details": {
      "post": {
        "operationId": "getGoogleAdDetails",
        "summary": "Get Google Ads ad details",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["accountId", "adGroupId", "adId"], "properties": {"accountId": {"type": "string"}, "adGroupId": {"type": "string"}, "adId": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "Ad details", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/add-text-assets": {
      "post": {
        "operationId": "addGoogleTextAssets",
        "summary": "Add text assets to Google Ads asset groups",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["accountId", "assetGroupIds"], "properties": {"accountId": {"type": "string"}, "assetGroupIds": {"type": "array", "items": {"type": "string"}}, "headlines": {"type": "array", "items": {"type": "string"}}, "longHeadlines": {"type": "array", "items": {"type": "string"}}, "descriptions": {"type": "array", "items": {"type": "string"}}}}}}
        },
        "responses": {
          "200": {"description": "Text assets added", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/add-assets": {
      "post": {
        "operationId": "addGoogleMediaAssets",
        "summary": "Add media assets to Google Ads asset groups",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["accountId", "assetGroupIds"], "properties": {"accountId": {"type": "string"}, "assetGroupIds": {"type": "array", "items": {"type": "string"}}, "videos": {"type": "array", "items": {"type": "object"}}, "images": {"type": "array", "items": {"type": "object"}}}}}}
        },
        "responses": {
          "200": {"description": "Media assets added", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/remove-assets": {
      "post": {
        "operationId": "removeGoogleAssets",
        "summary": "Remove assets from Google Ads asset group",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["accountId", "assetId", "assetGroupId"], "properties": {"accountId": {"type": "string"}, "assetId": {"type": "string"}, "assetGroupId": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "Assets removed", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/update-assets": {
      "post": {
        "operationId": "updateGoogleAssets",
        "summary": "Update Google Ads assets",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["accountId", "editedAssets"], "properties": {"accountId": {"type": "string"}, "editedAssets": {"type": "array", "items": {"type": "object"}}}}}}
        },
        "responses": {
          "200": {"description": "Assets updated", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/google-ads/launch": {
      "post": {
        "operationId": "launchGoogleAds",
        "summary": "Launch Google Ads batch",
        "description": "Orchestrated batch with asset operations. Rate limit: 3 requests/minute.",
        "tags": ["Google Ads"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object"}}}
        },
        "responses": {
          "202": {"description": "Batch launched", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/LaunchResponse"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/youtube/upload-from-url": {
      "post": {
        "operationId": "uploadVideoToYouTube",
        "summary": "Upload video to YouTube from URL",
        "tags": ["YouTube"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["videoUrl", "title"], "properties": {"videoUrl": {"type": "string", "format": "uri"}, "title": {"type": "string"}, "description": {"type": "string"}, "privacy": {"type": "string", "enum": ["private", "public", "unlisted"]}}}}}
        },
        "responses": {
          "200": {"description": "Video uploaded", "content": {"application/json": {"schema": {"type": "object", "properties": {"videoId": {"type": "string"}, "url": {"type": "string"}}}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/media/upload": {
      "post": {
        "operationId": "uploadMedia",
        "summary": "Upload media file",
        "tags": ["Media"],
        "requestBody": {
          "required": true,
          "content": {"multipart/form-data": {"schema": {"type": "object", "properties": {"file": {"type": "string", "format": "binary"}}}}}
        },
        "responses": {
          "200": {"description": "Media uploaded", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MediaFile"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/media/upload/url": {
      "post": {
        "operationId": "uploadMediaFromUrl",
        "summary": "Upload media from URL",
        "tags": ["Media"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["url"], "properties": {"url": {"type": "string", "format": "uri"}}}}}
        },
        "responses": {
          "200": {"description": "Media uploaded", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MediaFile"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/media/upload/check": {
      "post": {
        "operationId": "checkMediaUpload",
        "summary": "Check if media file exists",
        "tags": ["Media"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["fileName"], "properties": {"fileName": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "Check result", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/media/get-upload-url": {
      "post": {
        "operationId": "getMediaUploadUrl",
        "summary": "Get a presigned upload URL",
        "tags": ["Media"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["fileName"], "properties": {"fileName": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "Presigned URL for upload", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/media/confirm-upload": {
      "post": {
        "operationId": "confirmMediaUpload",
        "summary": "Confirm a completed upload",
        "tags": ["Media"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["url", "fileName"], "properties": {"url": {"type": "string", "format": "uri"}, "fileName": {"type": "string"}}}}}
        },
        "responses": {
          "200": {"description": "Upload confirmed", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MediaFile"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/media/generate-thumbnail": {
      "post": {
        "operationId": "generateThumbnail",
        "summary": "Generate a media thumbnail",
        "tags": ["Media"],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["url"], "properties": {"url": {"type": "string", "format": "uri"}}}}}
        },
        "responses": {
          "200": {"description": "Thumbnail generated", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/media/search": {
      "get": {
        "operationId": "searchMedia",
        "summary": "Search stored media",
        "tags": ["Media"],
        "parameters": [
          {"name": "q", "in": "query", "schema": {"type": "string"}},
          {"name": "tags", "in": "query", "schema": {"type": "string"}},
          {"name": "status", "in": "query", "schema": {"type": "string"}},
          {"name": "type", "in": "query", "schema": {"type": "string", "enum": ["image", "video"]}},
          {"name": "dimension", "in": "query", "schema": {"type": "string"}},
          {"name": "page", "in": "query", "schema": {"type": "integer"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Paginated media list", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/media/{id}": {
      "get": {
        "operationId": "getMediaById",
        "summary": "Get stored media by ID",
        "tags": ["Media"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Media details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MediaFile"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/drive/browse": {
      "get": {
        "operationId": "browseGoogleDrive",
        "summary": "Browse Google Drive files",
        "tags": ["Media"],
        "parameters": [
          {"name": "folderId", "in": "query", "schema": {"type": "string"}},
          {"name": "scope", "in": "query", "schema": {"type": "string"}},
          {"name": "search", "in": "query", "schema": {"type": "string"}},
          {"name": "pageSize", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Drive file listing", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/dropbox/browse": {
      "get": {
        "operationId": "browseDropbox",
        "summary": "Browse Dropbox files",
        "tags": ["Media"],
        "parameters": [
          {"name": "path", "in": "query", "schema": {"type": "string"}},
          {"name": "sharedLink", "in": "query", "schema": {"type": "string"}},
          {"name": "search", "in": "query", "schema": {"type": "string"}},
          {"name": "limit", "in": "query", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Dropbox file listing", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/adbatches/{id}/ad-delivery-statuses": {
      "get": {
        "operationId": "getAdDeliveryStatuses",
        "summary": "Get Meta ad delivery statuses for a batch",
        "tags": ["Batches"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {"description": "Ad delivery status details", "content": {"application/json": {"schema": {"type": "object"}}}},
          "400": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/comments": {
      "get": {
        "operationId": "listComments",
        "summary": "Retrieve ad comments",
        "tags": ["Comments"],
        "responses": {
          "200": {"description": "List of comments", "content": {"application/json": {"schema": {"type": "object"}}}},
          "401": {"description": "Unauthorized", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}}
        }
      }
    },
    "/comments/{id}/reply": {
      "post": {
        "operationId": "replyToComment",
        "summary": "Reply to an ad comment",
        "tags": ["Comments"],
        "parameters": [{"name": "id", "in": "path", "required": true, "schema": {"type": "string"}}],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"type": "object", "required": ["message"], "properties": {"message": {"type": "string"}}}}}
        },
        "responses": {
