            },
            "description": "Collection of transaction details."
          }
        }
      },
      "transaction-id-common.json": {
        "title": "TransactionIdCommon",
        "type": "string",
        "example": "TR5IDS4",
        "description": "Authors use transaction IDs to collect feedback after a customer transaction: invoice numbers or order IDs are common transaction IDs. Respondents can take a survey by entering their transaction ID, and each transaction ID uniquely identifies a response for that transaction."
      },
      "transaction-item-create.json": {
