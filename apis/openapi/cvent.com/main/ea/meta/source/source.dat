              },
              "homeAddress": {
                "properties": {
                  "address3": {},
                  "countryCode": {}
                }
              },
              "dateOfBirth": {},
              "gender": {},
              "homePhone": {},
              "socialSecurityNumber": {}
            }
          }
        ]
      },
      "contact-transaction": {
        "title": "Contact Transaction",
        "description": "A changeset of contact fields.",
        "required": [
          "transactionId"
        ],
        "type": "object",
        "allOf": [
          {
            "title": "Contact Fields",
            "description": "An array of standard contact fields supported by Cvent.",
            "required": [
              "data"
            ],
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/contact-field.json"
                },
                "description": "Collection of standard contact fields."
              }
            }
          }
        ],
        "properties": {
          "transactionId": {
            "title": "Readonly UUID Property",
            "description": "A unique id corresponding to the contact transaction callback made to fetch contact information.",
            "type": "string",
            "format": "uuid",
            "readOnly": true,
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          }
        }
      },
      "contact-type-paginated-response": {
        "title": "ContactTypePaginatedResponse",
        "description": "The response from a request to get the list of contact types. This includes the paging object as well as the collection of contact-types.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/contact-type.json"
            },
            "description": "Collection of contact types."
          }
        }
      },
      "contact-type.json": {
        "title": "ContactType",
        "description": "This entity represents a contact type at contact level.",
        "required": [
          "id",
          "code",
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The ID of the contact type.",
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "The contact type code. Must be unique in the account.",
            "readOnly": true,
            "maxLength": 30,
            "example": "VIP"
          },
          "name": {
            "type": "string",
            "description": "Name of the contact type.",
            "maxLength": 50,
            "example": "VIP Attendee"
          },
          "description": {
            "type": "string",
            "description": "Description of the contact type.",
            "maxLength": 2500,
            "example": "Very important attendee."
          }
        }
      },
      "contact-type.json1": {
        "type": "string",
        "title": "ContactType",
        "description": "The contact types used for the proposal.",
        "enum": [
          "PRIMARY",
          "SECONDARY"
        ],
        "default": "PRIMARY"
      },
      "contact-update": {
        "title": "ContactUpdate",
        "description": "This entity is used to represent a single item that is requested for a contact update",
        "required": [
          "id"
        ],
        "allOf": [
          {
            "title": "ExistingContact",
            "description": "Represents a contact that has been created and has an id.",
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/contact/allOf/0"
              }
            ],
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The ID of the contact."
              },
              "parentId": {
                "type": "string",
                "format": "uuid",
                "description": "ID of the parent contact, applicable with contact snapshot.",
                "readOnly": true
              },
              "event": {
                "description": "Event ID",
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "ID of the event where the contact was created, applicable when contact snapshot is enabled for an event."
                  }
                },
                "readOnly": true
              }
            }
          }
        ]
      },
      "contact.json1": {
        "title": "Contact",
        "description": "The contact details.",
        "type": "object",
        "properties": {
          "contactType": {
            "$ref": "#/components/schemas/contact-type.json1"
          },
          "firstName": {
            "type": "string",
            "maxLength": 50,
            "description": "The first name of the contact.",
            "example": "Saurabh"
          },
          "lastName": {
            "type": "string",
            "maxLength": 50,
            "description": "The last name of the contact.",
            "example": "Sachdeva"
          },
          "organizationWebsite": {
            "type": "string",
            "format": "uri",
            "description": "The URL of the organization's website.",
            "maxLength": 100,
            "example": "www.cvent.com"
          },
          "organization": {
            "type": "string",
            "maxLength": 100,
            "description": "The name of the organization.",
            "example": "Cvent"
          },
          "title": {
            "type": "string",
            "description": "Designation of the contact.",
            "maxLength": 50,
            "example": "Co-founder"
          },
          "email": {
            "type": "string",
            "maxLength": 300,
            "format": "email",
            "description": "The email address of the contact.",
            "example": "saurabhsachdeva@xyz.com"
          },
          "countryCode": {
            "type": "string",
            "maxLength": 25,
            "description": "The country code for the contact's phone number.",
            "example": "1"
          },
          "phone": {
            "type": "string",
            "description": "The phone number of the organization.",
            "maxLength": 50,
            "example": "198752236"
          },
          "fax": {
            "type": "string",
            "description": "The organization's fax number.",
            "maxLength": 50,
            "example": "2487234567"
          },
          "mobile": {
            "type": "string",
            "description": "The mobile number of the contact.",
            "maxLength": 50,
            "example": "2487649053"
          },
          "streetAddress1": {
            "type": "string",
            "description": "Address line 1 of contact's street address.",
            "maxLength": 255,
            "example": "299 ABC Street"
          },
          "streetAddress2": {
            "type": "string",
            "description": "Address line 2 of contact's street address.",
            "maxLength": 255,
            "example": "Unit 1A"
          },
          "streetAddress3": {
            "type": "string",
            "description": "Address line 3 of contact's street address.",
            "maxLength": 255,
            "example": "Seattle, Washington"
          },
          "city": {
            "type": "string",
            "maxLength": 100,
            "description": "The city of the contact.",
            "example": "Seattle"
          },
          "stateProvince": {
            "$ref": "#/components/schemas/state-province.json"
          },
          "postalCode": {
            "type": "string",
            "maxLength": 30,
            "description": "The postal code of the contact.",
            "example": "110079"
          },
          "country": {
            "$ref": "#/components/schemas/country.json"
          },
          "notes": {
            "type": "string",
            "maxLength": 255,
            "description": "Additional notes of the contact.",
            "example": "Available between 8am - 5pm."
          }
        }
      },
      "contact.json2": {
        "title": "Contact",
        "type": "object",
        "description": "The contact details who watched a video",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The unique ID of the contact who watched a video.",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          }
        }
      },
      "copy-mapping-entity-type.json": {
        "title": "Copy Mapping Entity Type",
        "type": "string",
        "description": "The entity type for the mapping.",
        "enum": [
          "BOOTH_TYPE",
          "BOOTH",
          "EVENT",
          "SPONSORSHIP_LEVEL",
          "EXHIBITOR",
          "EXHIBITOR_CATEGORY",
          "EXHIBITOR_CUSTOM_QUESTION",
          "EXHIBITOR_CUSTOM_ANSWER"
        ],
        "example": "BOOTH"
      },
      "copy-mappings-response": {
        "title": "Copy Mappings Response",
        "type": "object",
        "description": "Response model for saved copy mappings.",
        "required": [
          "id",
          "event",
          "type",
          "mappingIds"
        ],
        "allOf": [
          {
            "title": "Audit",
            "description": "Audit information",
            "type": "object",
            "properties": {
              "created": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was created.",
                "readOnly": true,
                "example": "2017-01-02T02:00:00Z"
              },
              "createdBy": {
                "type": "string",
                "description": "The identifier of the user that created this record.",
                "readOnly": true,
                "example": "hporter"
              },
              "lastModified": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was updated.",
                "readOnly": true,
                "example": "2019-02-12T03:00:00Z"
              },
              "lastModifiedBy": {
                "type": "string",
                "description": "The identifier of the user that last updated this record.",
                "readOnly": true,
                "example": "hporter"
              }
            }
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the mapping record.",
            "example": "6b92a82d-4374-40bc-a24f-6dee46d68737"
          },
          "event": {
            "$ref": "#/components/schemas/event.json6"
          },
          "type": {
            "$ref": "#/components/schemas/copy-mapping-entity-type.json"
          },
          "mappingIds": {
            "$ref": "#/components/schemas/mapping-ids.json"
          }
        }
      },
