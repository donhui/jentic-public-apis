      "session1": {
        "title": "Session",
        "description": "Represents an event session.",
        "type": "object",
        "allOf": [
          {
            "title": "Audit",
            "description": "Audit information",
            "type": "object",
            "properties": {
              "created": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was created.",
                "readOnly": true,
                "example": "2017-01-02T02:00:00Z"
              },
              "createdBy": {
                "type": "string",
                "description": "The identifier of the user that created this record.",
                "readOnly": true,
                "example": "hporter"
              },
              "lastModified": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was updated.",
                "readOnly": true,
                "example": "2019-02-12T03:00:00Z"
              },
              "lastModifiedBy": {
                "type": "string",
                "description": "The identifier of the user that last updated this record.",
                "readOnly": true,
                "example": "hporter"
              }
            }
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier of the session.",
            "readOnly": true
          },
          "virtual": {
            "type": "boolean",
            "description": "Indicates whether the session is virtual or not. DEPRECATED - This indicator has been removed from the product.",
            "example": true,
            "deprecated": true
          },
          "event": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "title": {
            "type": "string",
            "description": "Title of the session.",
            "maxLength": 100,
            "example": "Day 1 Keynote Session"
          },
          "code": {
            "type": "string",
            "description": "A system-generated code for this session.",
            "maxLength": 20,
            "readOnly": true,
            "example": "R5NP4NJYB3D"
          },
          "category": {
            "$ref": "#/components/schemas/id-name.json"
          },
          "type": {
            "type": "object",
            "deprecated": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/event/properties/category/allOf/0"
              }
            ]
          },
          "location": {
            "$ref": "#/components/schemas/event/properties/category/allOf/0"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the session.",
            "maxLength": 2500,
            "example": "Keynote session to kick off the event. The dynamic and energetic Dr. Smith will be speaking about the industry."
          },
          "includedSession": {
            "type": "boolean",
            "description": "True indicates this session was automatically included with registration.",
            "example": true
          },
          "start": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted date and time when the session starts.",
            "example": "2020-02-03T13:00:00.000Z"
          },
          "end": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted date and time when the session ends.",
            "example": "2020-02-07T17:00:00.000Z"
          },
          "status": {
            "$ref": "#/components/schemas/session-status.json1"
          },
          "enableWaitlist": {
            "type": "boolean",
            "description": "True indicates a waitlist is enabled on the session.",
            "example": false
          },
          "capacity": {
            "type": "integer",
            "description": "The maximum number of attendees who can enroll in the session.",
            "example": 150
          },
          "timezone": {
            "type": "string",
            "description": "The session timezone (as determined in the IANA time zone database, also known as the Olson specification).",
            "maxLength": 29,
            "example": "America/New_York"
          },
          "featured": {
            "deprecated": true,
            "type": "boolean",
            "description": "True indicates the session is set to be featured. This will cause the session to be highlighted in Attendee Hub.",
            "example": true
          },
          "group": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The ID of the session group, if the session belongs to one."
              }
            },
            "description": "The session group, if the session belongs to one."
          },
          "openForRegistration": {
            "type": "boolean",
            "description": "True indicates the session is open for registration.",
            "example": false
          },
          "openForAttendeeHub": {
            "type": "boolean",
            "description": "True indicates the session is open in Attendee Hub.",
            "example": true
          },
          "registrationTypes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/uuid-property"
            },
            "description": "Unique identifiers for registration types associated with this session."
          },
          "customFields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/custom-field.json5"
            },
            "description": "Collection of custom fields."
          }
        }
      },
