            "maxLength": 36,
            "example": "VNNDLJ6DKVK"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when this record was created.",
            "readOnly": true,
            "example": "2017-01-02T02:00:00Z"
          }
        }
      },
      "badge-print-job-error-code.json": {
        "title": "BadgePrintJobErrorCode",
