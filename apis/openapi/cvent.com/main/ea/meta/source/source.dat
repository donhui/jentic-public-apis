          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/filter"
              },
              "example": {
                "filter": "id in ('1b01ae34-6970-41f2-a4e8-b4f39185dc15', '1b01ae34-6970-41f2-a4e8-b4f39185dc16')"
              }
            }
          }
        },
        "responses": {
