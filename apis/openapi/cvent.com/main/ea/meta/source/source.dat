          },
          "created": {
            "type": "string",
            "description": "The ISO 8601 zoned date time when this record was created.",
            "example": "2024-01-05T03:00:00Z",
            "format": "date-time"
          },
          "lastModified": {
            "type": "string",
            "description": "The ISO 8601 zoned date time when this record was last modified.",
            "example": "2024-01-07T02:00:00Z",
            "format": "date-time"
          }
        }
