                    "description": "The last name of the booth staff that captured the lead.",
                    "example": "Doe"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "The email address of the booth staff that captured the lead.",
                    "minLength": 6,
                    "maxLength": 80,
                    "example": "h.potterfield@test.com"
                  }
                }
              }
