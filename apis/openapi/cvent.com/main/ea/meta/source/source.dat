            "example": "Device 1"
          },
          "boothStaff": {
            "type": "object",
            "description": "Booth staff for the lead.",
            "allOf": [
              {
                "type": "object",
                "title": "ActivityBoothStaff",
                "description": "Booth staff for an activity.",
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
