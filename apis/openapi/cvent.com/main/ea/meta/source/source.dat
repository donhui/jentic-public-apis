          "images": {
            "type": "array",
            "description": "List of room images.",
            "items": {
              "$ref": "#/components/schemas/image-link.json"
            }
          },
          "customOrder": {
            "description": "Specifies a custom sort order defined by the user. This property is applicable only when the default price-based sorting is not active.",
            "type": "integer",
            "minimum": 1,
            "example": 1
          }
        }
      },
      "room-type-id.json": {
        "type": "object",
        "title": "roomTypeId",
        "description": "Contains unique ID of the room type.",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "description": "The unique ID of the room type.",
            "type": "integer",
            "example": 11549984
          }
        }
      },
      "rooms-sort-type.json": {
        "description": "Rooms sort type. CustomOrder: A user-defined sort order. PriceAscending: Data sorted with lowest price first. PriceDescending: Data sorted by highest price first.",
        "type": "string",
        "enum": [
          "CustomOrder",
          "PriceAscending",
          "PriceDescending"
        ]
      },
