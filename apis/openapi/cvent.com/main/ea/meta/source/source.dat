      "answer.json2": {
        "title": "Answer",
        "description": "A question answer.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/question.json3/allOf/0"
          }
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Data type of an answer. DEPRECATED: This field is deprecated and not applicable to this activity.",
            "example": "simple",
            "deprecated": true
          }
        }
      },
      "appointment-attendee": {
        "title": "AppointmentAttendee",
        "description": "Attendee for an event appointment.",
        "type": "object",
        "required": [
          "id",
          "contact",
          "appointmentEvent"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique ID representing the attendee.",
            "readOnly": true,
            "example": "0cdfa3f7-05da-4121-857b-d7732891e01a::52a68001-70ce-4ec4-a6fe-d0888123c715"
          },
          "code": {
            "type": "string",
            "description": "System generated code for this attendee appointment.",
            "maxLength": 11,
            "readOnly": true,
            "example": "GKNNHYW9GFV"
          },
          "appointmentEvent": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "contact": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "registration": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted date/time when the appointment attendee was created.",
            "example": "2019-04-01T17:00:00.000Z"
          },
          "modified": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted date/time when the appointment attendee was last modified.",
            "example": "2019-04-01T17:00:00.000Z"
          },
          "deleted": {
            "type": "boolean",
            "description": "True indicates the appointment attendee has been logically deleted.",
            "example": false
          }
        }
      },
      "appointment-attendee-paginated-response": {
        "title": "AppointmentAttendeePaginatedResponse",
        "description": "The response from a request to get the list of appointment attendees, including paging information.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/appointment-attendee"
            },
            "description": "Collection of appointment attendees and their related details."
          }
        }
      },
      "appointment-availability": {
        "title": "AppointmentAvailability",
        "description": "Appointment availability details.",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique ID representing the attendee's availability in an appointment event.",
            "example": "da8b035b-428b-4069-b25b-92afbcf514b3::2d8234f1-55df-483c-abe3-7e2cb98f8275"
          },
          "attendee": {
            "title": "attendee",
            "type": "object",
            "description": "The appointment attendee the availability is associated with.",
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique ID representing the appointment attendee.",
                "example": "0cdfa3f7-05da-4121-857b-d7732891e01a::52a68001-70ce-4ec4-a6fe-d0888123c715"
              }
            }
          },
          "appointmentEvent": {
            "$ref": "#/components/schemas/appointment-event-id.json"
          },
          "timeRanges": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/appointment-availability-time-range.json"
            },
            "description": "A list of time ranges when the attendee is available for appointments. Times are in the appointment event's time zone."
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted datetime when the attendee availability was created.",
            "example": "2019-04-01T17:00:00.000Z"
          },
          "lastModified": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted date/time when the attendee availability was last modified.",
            "example": "2019-04-01T17:00:00.000Z"
          },
          "deleted": {
            "type": "boolean",
            "description": "True indicates the record is deleted.",
            "example": false
          }
        }
      },
      "appointment-availability-paginated-response": {
        "title": "AppointmentAvailabilityPaginatedResponse",
        "type": "object",
        "description": "The response for a request for appointment availability times, including paging information.",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/appointment-availability"
            },
            "description": "The collection of appointment availability times and their related details."
          }
        }
      },
      "appointment-availability-time-range.json": {
        "title": "AppointmentAvailabilityTimeRange",
        "description": "Time range for an appointment availability.",
        "type": "object",
        "properties": {
          "start": {
            "type": "string",
            "description": "The ISO 8601 formatted start datetime of the time range, in the event's timezone.",
            "example": "2020-04-01T19:00:00.000"
          },
          "end": {
            "type": "string",
            "description": "The ISO 8601 formatted end datetime of the time range, in the event's timezone.",
            "example": "2020-04-01T20:00:00.000"
          },
          "type": {
            "$ref": "#/components/schemas/appointment-availability-type.json"
          }
        }
      },
      "appointment-availability-type.json": {
        "title": "AppointmentAvailabilityType",
        "type": "string",
        "enum": [
          "AVAILABLE",
          "UNAVAILABLE"
        ],
        "description": "Denotes whether an availability time range represents when an attendee is available or unavailable.",
        "example": "AVAILABLE"
      },
      "appointment-event": {
        "title": "AppointmentEvent",
        "description": "An event appointment.",
        "type": "object",
        "required": [
          "id",
          "code",
          "apptEventType",
          "status",
          "title",
          "start",
          "end"
        ],
        "x-extends": {
          "$ref": "#/components/schemas/audit.json"
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/audit.json"
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The unique ID representing the appointment event.",
            "readOnly": true,
            "example": "2d8234f1-55df-483c-abe3-7e2cb98f8275"
          },
          "code": {
            "type": "string",
            "description": "The system generated code for this appointment event.",
            "maxLength": 11,
            "readOnly": true,
            "example": "GKNNHYW9GFV"
          },
          "event": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "apptEventType": {
            "$ref": "#/components/schemas/appointment-event-type.json"
          },
          "status": {
            "$ref": "#/components/schemas/appointment-event-status.json"
          },
          "deleted": {
            "type": "boolean",
            "description": "True indicates the appointment event has been logically deleted.",
            "example": false
          },
          "archived": {
            "type": "boolean",
            "description": "True indicates the appointment event has been archived.",
            "example": true
          },
          "defaultLocale": {
            "type": "string",
            "description": "The appointment event default local using the IETF Language Tag format.",
            "maxLength": 35,
            "example": "en-US"
          },
          "title": {
            "type": "string",
            "description": "The title of the appointment event.",
            "maxLength": 300,
            "example": "Cvent Connect 2020"
          },
          "description": {
            "type": "string",
            "description": "The description of the appointment event.",
            "maxLength": 300,
            "example": "The Cvent yearly user conference."
          },
          "start": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted start date/time of the appointment.",
            "example": "2019-06-29T17:00:00.000Z"
          },
          "end": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted end date/time of the appointment.",
            "example": "2019-06-29T21:00:00.000Z"
          },
          "timezone": {
            "type": "string",
            "description": "The event timezone from the IANA specification.",
            "maxLength": 29,
            "example": "America/New_York"
          },
          "venues": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/venue.json"
            },
            "description": "Collection of venues and their associated details."
          },
          "phone": {
            "type": "string",
            "description": "The phone number for the event.",
            "maxLength": 13,
            "example": "555-555-5555"
          },
          "planners": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/planner.json"
            },
            "description": "Collection of information about planners."
          }
        }
      },
      "appointment-event-id.json": {
        "type": "object",
        "description": "Represents an appointment event ID.",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The unique ID of an appointment event.",
            "readOnly": true,
            "example": "2d8234f1-55df-483c-abe3-7e2cb98f8275"
          }
        }
      },
      "appointment-event-paginated-response": {
        "title": "AppointmentEventPaginatedResponse",
        "description": "The response from a request to get the list of appointment events, includes the paging object.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/appointment-event"
            },
            "description": "Collection of appointment events and their related details."
          }
        }
      },
      "appointment-event-status.json": {
        "title": "AppointmentEventStatus",
        "enum": [
          "ACTIVE",
          "CLOSED",
          "COMPLETED",
          "PENDING"
        ],
        "type": "string",
        "description": "Denotes the status of appointment event.",
        "example": "ACTIVE"
      },
      "appointment-event-type.json": {
        "title": "AppointmentEventType",
        "enum": [
          "STANDARD",
          "UNIVERSAL",
          "PLANNER_COORDINATED",
          "SIMPLE"
        ],
        "type": "string",
        "description": "Denotes the type of appointment event.<br/>STANDARD: You or attendees can manage schedules based on the permissions and settings you choose.<br/>UNIVERSAL: Your staff manages their schedules with attendees, at an event your staff is attending.<br/>PLANNER_COORDINATED: You manage attendee schedules for your event based on their preferences.<br/>SIMPLE: Import appointments or let attendees schedule them without any restrictions or prior setup.",
        "example": "STANDARD"
      },
      "appointment-group.json": {
        "title": "AppointmentGroup",
        "description": "An appointment group.",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The ID of the appointment group.",
            "format": "uuid",
            "example": "bf183d50-56ad-454b-8b9f-06d8e923e1fd"
          }
        }
      },
      "appointment-meeting-interest.json": {
        "title": "AppointmentMeetingInterest",
        "type": "object",
        "description": "An individual meeting interest.",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the exhibitor in which interest is expressed.",
            "example": "Cvent"
          },
          "exhibitor": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "ranking": {
            "type": "string",
            "description": "The strength of the interest.",
            "example": "5"
          },
          "meetingType": {
            "type": "string",
            "description": "The meeting type of interest.",
            "example": "Group Meeting"
          },
          "comment": {
            "type": "string",
            "description": "A comment about this interest.",
            "example": "A 1:1 or group meeting works."
          }
        }
      },
      "appointment-paginated-response": {
        "title": "AppointmentPaginatedResponse",
        "description": "The response for a request of appointments, including the paging object.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
