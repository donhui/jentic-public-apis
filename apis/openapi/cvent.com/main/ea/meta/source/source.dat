      "room-inventory.json": {
        "description": "Room inventory details for single night.",
        "type": "object",
        "required": [
          "housingEvent",
          "hotel",
          "roomType",
          "date"
        ],
        "allOf": [
          {
            "description": "Inventory details for single night.",
            "type": "object",
            "required": [
              "rate",
              "currentBlock",
              "pickup",
              "available"
            ],
            "properties": {
              "hideRates": {
                "description": "Indicates if rates are hidden on booking site for this night.",
                "type": "boolean",
                "example": false
              },
              "rate": {
                "$ref": "#/components/schemas/night-rate.json"
              },
              "originalBlock": {
                "description": "Number of inventory blocked on event creation.",
                "type": "integer",
                "example": 100,
                "minimum": 0
              },
              "currentBlock": {
                "description": "Current inventory number.",
                "type": "integer",
                "example": 150,
                "minimum": 0
              },
              "pickup": {
                "description": "Number of rooms sold.",
                "type": "integer",
                "example": 50,
                "minimum": 0
              },
              "finalPickup": {
                "description": "Reported number of sold rooms.",
                "type": "integer",
                "example": 45,
                "minimum": 0
              },
              "maxGuests": {
                "$ref": "#/components/schemas/max-guests.json"
              },
              "minLengthOfStay": {
                "description": "Minimum number nights of stay when starting from this night.",
                "type": "integer",
                "example": 1,
                "minimum": 1,
                "maximum": 10
              },
              "waitListRequests": {
                "description": "Number of reservations in wait list.",
                "type": "integer",
                "example": 1,
                "minimum": 0
              },
              "available": {
                "description": "Number of unsold rooms.",
                "type": "integer",
                "example": 30
              }
            }
          }
        ],
        "properties": {
          "housingEvent": {
            "$ref": "#/components/schemas/housing-event-id.json"
          },
          "hotel": {
            "$ref": "#/components/schemas/hotel-id.json"
          },
          "roomType": {
            "$ref": "#/components/schemas/room-id.json"
          },
          "date": {
            "description": "Inventory date.",
            "type": "string",
            "format": "date",
            "example": "2024-12-01"
          },
          "freeSell": {
            "description": "Number of inventory that can be sold to any attendee type.",
            "type": "integer",
            "example": 80
          },
          "unassigned": {
            "description": "Number of unassigned inventory. Inventory left in unassigned will not be sold until allocated to an attendee type or marked for free-sell to any attendee type.",
            "type": "integer",
            "example": 20
          },
          "allocation": {
            "description": "Inventory allocation by attendee type.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/attendee-inventory.json"
            },
            "minItems": 1
          }
        }
      },
      "room-type-details": {
        "type": "object",
        "title": "RoomTypeDetails",
        "description": "Room type details.",
        "required": [
          "id",
          "housingEvent",
          "hotel",
          "housingAttendees",
          "name",
          "description"
