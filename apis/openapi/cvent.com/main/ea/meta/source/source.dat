          },
          "housingEvent": {
            "$ref": "#/components/schemas/housing-event-id.json"
          },
          "name": {
            "description": "The hotel's name.",
            "type": "string",
            "example": "Hotel New York"
          },
          "description": {
            "description": "The hotel's description.",
            "type": "string",
            "example": "Since first opening its doors in 1936, the Hotel New York has welcomed countless guests."
          },
          "childPolicy": {
            "description": "The hotel's child policy.",
            "type": "string",
            "example": "Children 17 years or younger will stay free of charge in adult\u2019s room with existing bedding."
          },
          "images": {
            "type": "array",
            "description": "List of hotel images.",
            "items": {
              "$ref": "#/components/schemas/image-link.json"
            }
          },
          "proximity": {
            "$ref": "#/components/schemas/proximity.json"
          },
          "amenities": {
            "type": "array",
            "description": "List of available amenities at the hotel.",
            "items": {
              "description": "Amenity name.",
              "type": "string",
              "example": "Room Service"
            },
            "maxItems": 70
          },
          "rating": {
            "$ref": "#/components/schemas/hotel-rating.json"
          },
          "address": {
            "$ref": "#/components/schemas/address.json3"
          }
        }
      },
      "housing-event-hotels-list": {
        "type": "object",
        "title": "HotelsList",
        "description": "List of hotels associated with a particular housing event.",
        "required": [
          "paging",
          "data"
        ],
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/housing-event-hotel"
            },
            "description": "List of hotels associated with a particular housing event."
          }
        }
      },
      "housing-event-id.json": {
        "type": "object",
        "title": "HousingEventId",
