            "$ref": "#/components/schemas/device.json"
          },
          "video": {
            "$ref": "#/components/schemas/video.json1"
          },
          "type": {
            "$ref": "#/components/schemas/view-type.json1"
          },
          "totalDuration": {
            "type": "integer",
            "format": "int64",
            "description": "The total duration of the video (in milliseconds).",
            "example": 233000
          },
          "watchDuration": {
            "type": "integer",
            "format": "int64",
            "description": "The total duration of the video watched by the viewer (in milliseconds).",
            "example": 153600
          },
          "watchPercentage": {
            "type": "number",
            "description": "The percentage of the video watched by the viewer.",
            "example": 52
          }
        }
      },
