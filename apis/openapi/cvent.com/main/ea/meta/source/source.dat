          },
          {
            "name": "filter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "example": "type eq 'email'"
            },
            "description": "A filter query string narrows search results results and supports the combination of logical and comparison operators.\nThe filter adheres to the pattern filter='field' comparisonType 'value'.\n\nThere is one comparison type that can be used in filter expressions:\n* equal: eq\n\nThe following fields are filterable:\n* type (eq)\n"
          }
        ],
        "tags": [
          "Compliance"
        ],
        "security": [
          {
            "OAuth2.clientCredentials": [
              "compliance/communications:read"
            ]
          },
          {
            "OAuth2.authorizationCode": [
              "compliance/communications:read"
            ]
          }
