            "maxLength": 4000,
            "example": "No."
          }
        }
      },
      "Customer": {
        "title": "Customer",
        "description": "The definition of a Cvent Customer. This is an independent contractual business unit underneath an Organization. The contractual agreements between different Customers underneath the same Organization can differ. A Customer may associate to 0 to many Cvent Core Accounts.",
        "required": [
          "organization",
          "id",
          "number",
          "stub",
          "name",
          "salesforceId",
          "status"
        ],
        "type": "object",
        "properties": {
          "organization": {
            "$ref": "#/components/schemas/Account/properties/organization/allOf/0"
          },
          "id": {
            "$ref": "#/components/schemas/customer-id.json"
          },
          "stub": {
            "type": "string",
            "format": "uuid",
            "allOf": [
              {
                "title": "Customer Stub",
                "type": "string",
                "format": "uuid",
                "description": "The globally unique identifier which represents this customer for a specific region."
              },
              {
                "readOnly": true
              }
            ]
          },
          "number": {
            "$ref": "#/components/schemas/customer-number.json"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "The name of this customer",
            "example": "Cvent"
          },
          "salesforceId": {
            "$ref": "#/components/schemas/salesforce-account-id.json"
          },
          "status": {
            "$ref": "#/components/schemas/customer-status.json"
          },
          "creditCardDetails": {
            "$ref": "#/components/schemas/customer-credit-card-details.json"
          },
          "autoSendInvoice": {
            "type": "boolean",
            "default": true,
            "description": "True means that the billing invoice will automatically be sent."
          },
          "convertedTrial": {
            "type": "boolean",
            "readOnly": true,
            "description": "True means that this customer has been converted from a trial using Cvent's product."
          },
          "salesTaxExempt": {
            "type": "boolean",
            "default": false,
            "description": "True means that sales tax for this Customer will be exempt."
          },
          "note": {
            "type": "string",
            "maxLength": 1000,
            "description": "Additional details about this customer.",
            "example": "Additional details about this customer.",
            "default": ""
          }
        }
      },
      "customer-address.json": {
        "title": "Customer Address",
        "description": "The Customer's address details.",
        "required": [
          "address1",
          "city",
          "countryCode",
