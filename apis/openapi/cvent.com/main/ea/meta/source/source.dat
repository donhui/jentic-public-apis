      "attendee-paginated-response": {
        "title": "AttendeePaginatedResponse",
        "description": "The response from a request to get the list of attendees. This includes the paging object as well as the collection of attendees.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
