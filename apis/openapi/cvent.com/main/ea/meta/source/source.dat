      "processFormExpand": {
        "name": "expand",
        "in": "query",
        "explode": false,
        "required": false,
        "description": "This endpoint enables users to request the process form name in an extended response by utilizing the expand query parameter. The expanded process form including the name is fetched and presented inline for each specified expand value.\n\nA process form submission includes the ID of a corresponding process form in its response properties. By employing the expand query parameter, users can access the process form name within the process form submission.\n\nThe following fields are expandable:\n  * process-form\n",
        "example": [
          "process-form"
        ],
        "schema": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "process-form"
            ]
          }
        }
      },
      "programId": {
        "name": "programId",
        "description": "A uuid used to uniquely identify the program.",
        "required": true,
        "in": "path",
