      "alternate-answer.json": {
        "title": "AlternateAnswer",
        "description": "Represents the answer(s) to an alternate travel question submitted by an attendee.",
        "type": "object",
        "properties": {
          "value": {
            "type": "array",
            "description": "The set of answers to a single alternate travel question.",
            "maxItems": 50,
            "items": {
              "type": "string",
              "description": "A single answer to the alternate travel question.",
              "example": "1234"
            },
            "example": [
              "1234"
            ]
          }
        }
      },
      "alternate-question.json": {
        "title": "AlternateQuestion",
        "description": "Represents a reference to an alternate travel question entity, containing only the question ID and text.",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the question entity.",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          },
          "text": {
            "type": "string",
            "description": "Text of the alternate travel question.",
            "example": "Why are you not booking a hotel with us?"
          }
        }
      },
      "alternate-travel-detail.json": {
        "title": "AlternateTravelDetail",
        "description": "Details of an alternate travel answer submitted by an attendee who opted out of air or hotel bookings.",
        "type": "object",
        "allOf": [
          {
            "title": "Audit",
            "description": "Audit information",
            "type": "object",
            "properties": {
              "created": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was created.",
                "readOnly": true,
                "example": "2017-01-02T02:00:00Z"
              },
              "createdBy": {
                "type": "string",
                "description": "The identifier of the user that created this record.",
                "readOnly": true,
                "example": "hporter"
              },
              "lastModified": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was updated.",
                "readOnly": true,
                "example": "2019-02-12T03:00:00Z"
              },
              "lastModifiedBy": {
                "type": "string",
                "description": "The identifier of the user that last updated this record.",
                "readOnly": true,
                "example": "hporter"
              }
            }
          }
        ],
        "properties": {
          "attendee": {
            "$ref": "#/components/schemas/attendee.json4"
          },
          "requesterId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the entity this alternate travel belongs to. For an event attendee, this field is contact ID. For guest, this field is guest ID.",
            "example": "3b2359a7-4583-40ed-8afd-67e5f15373d3"
          },
          "requesterType": {
            "type": "string",
            "description": "Attendee type of the entity this alternate travel belongs to. Contact means the requester is an independent attendee. Guest means the attendee is accompanying another attendee.",
            "enum": [
              "Contact",
              "Guest"
            ],
            "example": "Contact"
          },
          "travelType": {
            "type": "string",
            "description": "Type of travel alternate question",
            "enum": [
              "AirRequest",
              "HotelRequest",
              "AirActual",
              "GroupFlight"
            ],
            "example": "AirRequest"
          },
          "question": {
            "$ref": "#/components/schemas/alternate-question.json"
          },
          "answer": {
            "$ref": "#/components/schemas/alternate-answer.json"
          }
        }
      },
      "alternate-travel-paginated-response": {
        "title": "AlternateTravelPaginatedResponse",
        "description": "Paginated response containing alternate travel answers submitted by attendees who opt out of air or hotel bookings.",
        "type": "object",
        "required": [
          "paging",
          "data"
        ],
        "properties": {
          "paging": {
            "type": "object",
            "description": "Represents pagination information for the list of results.",
            "allOf": [
              {
                "$ref": "#/components/schemas/paging.json"
              }
            ]
          },
          "data": {
            "type": "array",
            "maxItems": 200,
            "description": "Collection of alternate travel answers for attendees.",
            "items": {
              "$ref": "#/components/schemas/alternate-travel-detail.json"
            }
          }
        }
      },
      "amenity-type.json": {
        "title": "Amenity Type",
        "enum": [
          "included_amenity",
          "amenity",
          "bundled_supplement"
        ],
        "type": "string",
        "description": "Amenity type",
        "example": "amenity"
      },
      "anniversary-membership-item.json": {
        "title": "Anniversary",
        "description": "Represents an anniversary-based membership item that renews on the anniversary date of the original purchase.",
        "required": [
          "renewalType"
        ],
        "allOf": [
          {
            "title": "Membership Item",
            "description": "Represents a membership item. Membership items are products that can be purchased during registration or on contact websites.",
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/quantity-item/allOf/0"
              }
            ],
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "A unique identifier for the membership item.",
                "example": "976d53c7-e7d6-43b0-9b6e-5422d59c54b1",
                "readOnly": true
              },
              "type": {
                "type": "string",
                "maxLength": 50,
                "description": "Planner specified type or category of membership being offered.",
                "example": "Gold Membership"
              },
              "item": {
                "type": "string",
                "maxLength": 50,
                "description": "The specific membership item or product name within the membership type.",
                "example": "Annual Gold Membership Package"
              },
              "contactType": {
                "description": "The contact type associated with this membership item.",
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The contact type id associated with this membership item.",
                    "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d4"
                  }
                }
              },
              "price": {
                "type": "number",
                "example": 100,
                "description": "The price charged when an invitee purchases a membership."
              },
              "renewalPrice": {
                "type": "number",
                "example": 100,
                "description": "The price charged when an invitee renews their membership."
              },
              "description": {
                "type": "string",
                "description": "Description of the membership item.",
                "maxLength": 2500,
                "example": "Access to exclusive webinars and networking events for Gold members."
              },
              "code": {
                "type": "string",
                "maxLength": 8,
                "description": "A planner-specified code for the membership item.",
                "example": "R5NP4NJYB3D"
              },
              "registrationTypes": {
                "maxItems": 200,
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/registration-type-id.json"
                },
                "description": "Contains unique identifiers for registration types associated with this membership item."
              },
              "openForRegistration": {
                "type": "boolean",
                "description": "True indicates the membership item is selectable during registration.",
                "example": false
              },
              "automaticClosureDate": {
                "type": "string",
                "format": "date",
                "description": "The ISO 8601 formatted date when the membership item registration automatically closes. The item closes at the start (12:00 AM) of the chosen date, according to the UTC timezone.",
                "example": "2026-08-12"
              },
              "generalLedger": {
                "$ref": "#/components/schemas/general-ledger.json2"
              },
              "currency": {
                "type": "string",
                "description": "The ISO 4217 currency code for this membership item.",
                "example": "EUR",
                "readOnly": true,
                "maxLength": 3
              }
            }
          }
        ],
        "type": "object",
        "properties": {
          "renewalType": {
            "type": "string",
            "description": "The renewal type of the membership item.",
            "example": "Anniversary"
          },
          "duration": {
            "type": "string",
            "enum": [
              "OneYear",
              "ThreeMonths",
              "SixMonths",
              "Custom",
              "NoExpiration"
            ],
            "description": "The duration of the membership item with anniversary renewal type.",
            "example": "OneYear"
          },
          "customDuration": {
            "type": "object",
            "description": "Represents a custom membership duration. Required when the duration property is set to 'Custom'.",
            "properties": {
              "days": {
                "type": "integer",
                "minimum": 1,
                "maximum": 9999,
                "description": "The custom duration in days for the membership.",
                "example": 120
              }
            }
          }
        }
      },
