          },
          "serviceChargeAmount": {
            "type": "number",
            "minimum": 0,
            "maximum": 9999999999.99,
            "description": "Service charge amount.",
            "example": 1
          },
          "serviceChargePercent": {
            "type": "boolean",
            "description": "True indicates the service charge amount represents a percentage, instead of a monetary value"
          },
          "serviceChargeIncluded": {
            "type": "boolean",
            "description": "True indicates the service charge is included."
          }
        }
      },
      "update-appointment-request": {
