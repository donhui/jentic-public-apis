            "$ref": "#/components/responses/Unauthorized1"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden1"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests1"
          }
        },
        "callbacks": {
          "contactTransaction": {
            "{$request.body#/callback}": {
              "post": {
                "summary": "Contact Transaction Callback",
                "description": "This callback will be invoked on the URI you registered via <a href=\"#operation/contactHook\">Create Contact Hook</a>.\nCvent will send a message requesting details on the contact that triggered the callback. All the non-blank\nfields in your response will overwrite the related fields in Cvent.\n",
                "operationId": "contactTransactionCallback",
                "security": [
                  {
                    "CallbackApiKeyAuth": []
                  },
                  {
                    "CallbackBasicAuth": []
                  }
                ],
                "requestBody": {
                  "content": {
                    "application/json": {
                      "schema": {
                        "$ref": "#/components/schemas/contact-transaction"
                      }
                    }
                  }
                },
                "responses": {
                  "200": {
                    "$ref": "#/components/responses/ContactFieldsResponse"
                  },
                  "400": {
                    "description": "Your server rejected the callback because of some issue with the data. We will not retry on this response."
                  },
                  "404": {
                    "description": "Your server rejects the callback because the contact doesn't exist in your system. Our system will not retry on this response."
                  },
                  "429": {
                    "$ref": "#/components/responses/TooManyRequests1"
                  }
                }
              }
            }
          }
        },
        "externalDocs": {
          "description": "More about OAuth2 authorization code support for administrators",
          "url": "#oauth2-auth-code-planner-admin"
        }
      }
    },
