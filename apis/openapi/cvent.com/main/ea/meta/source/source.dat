            },
            "description": "Collection of attendees."
          }
        }
      },
      "attendee-response-method.json": {
        "title": "AttendeeResponseMethod",
        "enum": [
          "Administrator Responded",
          "Administrator Responded Widget",
          "API-Responded",
          "Appointments Event Website",
          "Cvent Salesforce App",
          "Cvent Salesforce App - Campaign Page",
          "Cvent Salesforce App - Contact Page",
          "Cvent Salesforce App - Event Page",
          "Cvent Salesforce App - Lead Page",
          "Cvent Salesforce App - Person Account Page",
          "Cvent Salesforce App - Recommendation Widget",
          "External Registration",
          "Group Leader Responded",
          "Group Leader Responded Widget",
          "Historical Import",
          "Imported",
          "No Response",
          "On-site Responded",
          "Planner-Imported",
          "Planner-Responded",
          "Post Event",
          "Self-Responded",
          "Self-Responded Mobile",
          "Self-Responded Widget"
        ],
        "type": "string",
        "description": "Represents the method by which an attendee registered for the event.\n\n- Administrator Responded: The invitee was registered by another contact acting as their administrator.\n- API-Responded: The invitee was registered through a custom process configured via an API integration.\n- Appointments Event Website: The invitee registered via an appointments event website.\n- Cvent Salesforce App: The invitee registered through an action in the Cvent Salesforce App.\n- External Registration: The attendee was registered through an external integration, such as Marketo.\n- Group Leader Responded: The invitee was registered by a group leader and added to a group.\n- Historical Import: The invitee's registration was imported into the event as historical data.\n- Imported: The invitee's registration was imported into the event.\n- No Response: The invitee has not registered.\n- On-site Responded: The invitee registered onsite using OnArrival's Kiosk Mode.\n- Planner-Imported: An account user imported the invitee's registration into the event.\n- Planner-Responded: An account user registered the invitee from the Cvent back-end or the planner-side of the OnArrival app.\n- Post Event: The invitee was registered by an account user after the event's end date or while the event was in Completed status.\n- Self-Responded: The invitee registered themselves through a weblink or invitation.\n\nNote: The responseMethod can only be set if the invitee's status is No Response.",
        "example": "Self-Responded"
      },
      "attendee-response.json": {
        "title": "Attendee Response",
        "description": "Response object indicating the status of send email request for a particular attendee.",
        "required": [
          "id",
          "status"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The ID of the attendee you're emailing.",
            "example": "9A641E55-3367-4C50-B21B-B6A7613DFB23"
          },
          "status": {
            "$ref": "#/components/schemas/send-email-status.json"
          },
          "errorMessage": {
            "type": "string",
            "description": "The error message contains reason of a failed email.",
            "example": "attendee does not exist."
          }
        }
      },
      "attendee-segment": {
        "title": "AttendeeSegment",
        "required": [
          "eventId",
          "name"
        ],
        "description": "Represents an attendee segment. Attendee segments are assigned to events and provide the ability for planners to segment their attendees into groups and better manage the attendee experience based on their defined segments.",
        "allOf": [
          {
            "title": "Audit",
            "description": "Audit information",
            "type": "object",
            "properties": {
              "created": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was created.",
                "readOnly": true,
                "example": "2017-01-02T02:00:00Z"
              },
              "createdBy": {
                "type": "string",
                "description": "The identifier of the user that created this record.",
                "readOnly": true,
                "example": "hporter"
              },
              "lastModified": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was updated.",
                "readOnly": true,
                "example": "2019-02-12T03:00:00Z"
              },
              "lastModifiedBy": {
                "type": "string",
                "description": "The identifier of the user that last updated this record.",
                "readOnly": true,
                "example": "hporter"
              }
            }
          }
        ],
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the event where the attendee segment exists.",
            "example": "103097a4-143d-11e5-9f99-d0a637ee0032"
          },
          "name": {
            "type": "string",
            "description": "Name of the attendee segment. Must be unique in the event where the segment exists.",
            "maxLength": 100,
            "example": "VIP Attendees"
          },
          "description": {
            "type": "string",
            "description": "Description of the attendee segment.",
            "maxLength": 2500,
            "example": "A group of VIP attendees."
          },
          "status": {
            "type": "string",
            "description": "Status of the attendee segment. ACTIVE: This attendee segment is active and in use. INACTIVE: This attendee segment is marked as inactive.",
            "example": "ACTIVE",
            "enum": [
              "ACTIVE",
              "INACTIVE"
            ],
            "default": "ACTIVE"
          }
        }
      },
      "attendee-signature-response.json": {
        "title": "AttendeeSignatureResponse",
        "description": "Attendee's Signature Response.",
        "type": "object",
        "required": [
          "id",
          "event",
          "attendee",
          "type",
          "checkinSignatureUrl"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/check-in-message-request/allOf/0"
          }
        ],
        "properties": {
          "id": {
            "description": "Internal ID generated by the system.",
            "type": "string",
            "format": "uuid",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          },
          "event": {
            "description": "Event information associated with the signature.",
            "type": "object",
            "properties": {
              "id": {
                "description": "ID of the event.",
                "type": "string",
                "format": "uuid",
                "example": "b62809dd-7556-49d2-884a-591bbf96cf1a"
              }
            }
          },
          "session": {
            "description": "Session information associated with the signature.",
            "type": "object",
            "properties": {
              "id": {
                "description": "ID of the session.",
                "type": "string",
                "format": "uuid",
                "example": "4d44b9e4-8c1a-403d-a20a-0b981f539935"
              }
            }
          },
          "attendee": {
            "description": "Attendee information associated with the signature.",
            "type": "object",
            "properties": {
              "id": {
                "description": "ID of the attendee.",
                "type": "string",
                "format": "uuid",
                "example": "ce359543-61f5-492d-b8de-875c3473e8ae"
              }
            }
          },
          "type": {
            "description": "Type of entity this signature is associated with. Possible values are: `EVENT`, `SESSION`.",
            "type": "string",
            "enum": [
              "EVENT",
              "SESSION"
            ]
          },
          "checkinSignatureUrl": {
            "description": "Check-in signature image S3 url",
            "type": "string",
            "example": "https://custom.t2.cvent.com/files/contact/signatures/checkinSignature.jpg"
          },
          "checkoutSignatureUrl": {
            "description": "Check-out signature image S3 url",
            "type": "string",
            "example": "https://custom.t2.cvent.com/files/contact/signatures/checkoutSignature.jpg"
          }
        }
      },
      "attendee-status.json": {
        "title": "AttendeeStatus",
        "enum": [
          "No Response",
          "Accepted",
          "Declined",
          "Visited",
          "Waitlisted",
          "Cancelled",
          "Pending Approval",
          "Denied Approval"
        ],
        "type": "string",
        "description": "This is used to denote the status of an attendee.",
        "example": "Accepted"
      },
      "attendee-subscription-request": {
        "description": "Request body for updating an attendee's email subscription status.",
        "type": "object",
        "required": [
          "unsubscribed"
        ],
        "properties": {
          "unsubscribed": {
            "type": "boolean",
            "description": "The subscription status to set. True means the attendee will be unsubscribed from email communications, false means they will be subscribed.",
            "example": true
          }
        }
      },
      "attendee-subscription-response": {
        "title": "Attendee Subscription Response",
        "description": "Response body for successful attendee subscription status update.",
        "type": "object",
        "required": [
          "attendee",
          "unsubscribed"
        ],
        "properties": {
          "attendee": {
            "type": "object",
            "description": "The attendee whose subscription status is being updated.",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The unique identifier of the attendee.",
                "example": "123e4567-e89b-12d3-a456-426614174000"
              }
            }
          },
          "unsubscribed": {
            "type": "boolean",
            "description": "The updated subscription status. True means the attendee is unsubscribed from email communications, false means they are subscribed.",
            "example": true
          }
        }
      },
      "attendee-type-id.json": {
        "type": "object",
        "title": "AttendeeTypeId",
        "description": "Contains the unique ID of the attendee type.",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "description": "The unique ID of the attendee type.",
            "type": "integer",
            "example": 34549966
          }
        }
      },
      "attendee-type.json": {
        "title": "AttendeeType",
        "description": "Attendee type details.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/attendee-type-id.json"
          }
        ],
        "required": [
          "id",
          "name",
          "codes"
        ],
        "properties": {
          "name": {
            "description": "The name of the attendee type.",
            "type": "string",
            "example": "Staff"
          },
          "codes": {
            "description": "A list of attendee type codes.",
            "type": "array",
            "minItems": 1,
            "maxItems": 6,
            "items": {
              "description": "An attendee type code.",
              "type": "string",
              "example": "PEWATT0524317"
            }
          }
        }
      },
      "attendee-update": {
        "title": "AttendeeUpdate",
        "description": "Model representing an attendee to be updated in an event.",
        "required": [
          "event",
          "contact",
          "status"
        ],
        "type": "object",
        "allOf": [
          {
            "title": "AttendeeBase",
            "description": "Model representing an attendee to be added or updated to an event. The status determines if this is an registration or an invite.",
            "type": "object",
            "required": [
              "event"
            ],
            "properties": {
              "event": {
                "type": "object",
                "properties": {
                  "id": {
                    "description": "The event ID.",
                    "type": "string",
                    "format": "uuid",
                    "example": "0a955598-376e-43d4-a796-91d6d5f41e3f"
                  }
                },
                "description": "The ID of the event associated with the attendee."
              },
              "contact": {
                "type": "object",
                "properties": {
                  "id": {
                    "description": "The contact ID.",
                    "type": "string",
                    "format": "uuid",
                    "example": "ea66a709-2a93-4fa0-8b83-cf4f62df9dc3"
                  }
                },
                "description": "The ID of the address book contact associated with the attendee."
              },
              "invitationList": {
                "type": "object",
                "properties": {
                  "id": {
                    "description": "The invitation list ID.",
                    "type": "string",
                    "format": "uuid",
                    "example": "06da38f9-12da-4cb6-a581-7a5954f8e0e2"
                  }
                },
                "description": "The ID of the invitation list associated with the attendee."
              },
              "referenceId": {
                "type": "string",
                "description": "The reference ID of an attendee. A planner determined string used to track which link attendee's used to reach the event registration.",
                "maxLength": 100,
                "example": "refid-marketingwebsite"
              },
              "note": {
                "type": "string",
                "description": "A planner created note for an attendee, used to track details about the attendee.",
                "maxLength": 300,
                "example": "Would like to sit near the front of the room for sessions."
              },
              "administrator": {
                "type": "object",
                "properties": {
                  "id": {
                    "description": "The administrator contact ID.",
                    "type": "string",
                    "format": "uuid",
                    "example": "7949c335-b5b2-46cf-8f5d-f6b21795df51"
                  }
                },
                "description": "The ID of the administrator contact whom registered this attendee."
              },
              "unsubscribed": {
                "type": "boolean",
                "description": "True indicates this attendee is unsubscribed from this event's emails. They'll still recieve emails triggered by their own actions (like registration modification).",
                "example": false,
                "readOnly": true
              },
              "admissionItem": {
                "type": "object",
                "properties": {
                  "id": {
                    "description": "The admission item ID.",
                    "type": "string",
                    "format": "uuid",
                    "example": "7949c335-b5b2-46cf-8f5d-f6b21795df51"
                  }
                },
                "description": "The ID of the attendee's admission item. Required when registering, updating a registered attendee, or cancelling an attendee."
              },
              "visibility": {
                "$ref": "#/components/schemas/attendee-visibility.json"
              },
              "answers": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/attendee-answer.json"
                },
                "description": "The list of answers to the attendee's registration questions."
              },
              "sendEmail": {
                "type": "boolean",
                "description": "True indicates a confirmation email should be sent to the attendee. Cancelled attendees will not receive emails as a result of this field. If this field is left blank, the event settings for confirmation emails will apply.",
                "example": false
              }
            }
          }
        ],
        "properties": {
          "status": {
            "$ref": "#/components/schemas/attendee-update-status.json"
          },
          "registrationType": {
            "type": "object",
            "description": "The attendee's registration type.",
            "properties": {
              "id": {
                "description": "The ID of the registration type.",
                "type": "string",
                "format": "uuid"
              }
            }
          },
          "invitedBy": {
            "$ref": "#/components/schemas/deprecated-attendee-invited-by.json"
          },
          "responseMethod": {
            "$ref": "#/components/schemas/deprecated-attendee-response-method.json"
          }
        }
      },
      "attendee-update-status.json": {
        "title": "AttendeeUpdateStatus",
        "enum": [
          "No Response",
          "Accepted",
          "Cancelled",
          "Visited",
          "Declined",
          "Pending Approval",
          "Denied Approval"
        ],
        "type": "string",
        "default": "No Response",
        "description": "Denotes the status of an attendee to be updated. No Response: The attendee was added to an invitation list but hasn't taken any action. Accepted: The attendee is registered for the event. Cancelled: The attendee's registration for the event is cancelled. Visited: The attendee visited the event's webpage but didn't finish registration. Declined: The attendee declined to attend the event. Pending Approval: When registration approval is enabled, this status indicates the attendee is still waiting to be approved by the planner. Denied Approval: When registration approval is enabled, this status indicates the attendee has been denied approval by the planner. <br>The following status transitions are supported by this API:<br> * No Response -> Visited <br> * No Response -> Accepted <br> * No Response -> Declined <br> * No Response -> Pending Approval <br> * Cancelled -> Accepted <br> * Cancelled -> Pending Approval <br> * Visited -> Accepted <br> * Visited -> Pending Approval <br> * Declined -> Accepted <br> * Declined -> Pending Approval <br> * Accepted -> Cancelled <br> * Pending Approval -> Accepted <br> * Pending Approval -> Denied Approval <br> * Denied Approval -> Pending Approval",
        "example": "Accepted"
      },
      "attendee-visibility.json": {
        "title": "AttendeeVisibility",
        "enum": [
          "Private",
          "Public"
        ],
        "type": "string",
        "description": "Denotes the visibility of the attendee profile to other attendees. Private: Their profile is not visible. Public: Their profile is visible.",
        "example": "Private"
      },
      "attendee-web-links.json": {
        "title": "AttendeeWebLinks",
        "description": "Web links for an attendee.",
        "type": "object",
        "properties": {
          "acceptRegistration": {
            "type": "string",
            "format": "uri",
            "description": "This shortened URL, when used, allows you to accept the registration.",
            "example": "https://example.com/123ABC?i=abcdefghijklmnopqrstuv"
          },
          "declineRegistration": {
            "type": "string",
            "format": "uri",
            "description": "This shortened URL, when used, allows you to decline the registration.",
            "example": "https://example.com/123ABC?i=abcdefghijklmnopqrstuv"
          }
        }
      },
      "attendee.json": {
        "type": "object",
        "description": "The reference to the attendee. Contains only the ID of the attendee.",
        "title": "Attendee",
        "required": [
          "id"
