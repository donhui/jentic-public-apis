      "existing-admission-item": {
        "title": "ExistingAdmissionItem",
        "description": "Represents an existing event admission item.",
        "type": "object",
        "allOf": [
          {
            "title": "AdmissionItem",
            "description": "Represents an admission item.",
            "type": "object",
