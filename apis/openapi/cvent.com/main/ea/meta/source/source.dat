      "segments-error-response": {
        "title": "SegmentsErrorResponse",
        "description": "Segments error response details.",
        "allOf": [
          {
            "title": "ErrorResponse",
            "description": "Represents an error response with additional details of cascading error messages.",
            "allOf": [
              {
                "title": "ErrorResponseBase",
                "type": "object",
                "description": "Represents an error response with no additional details.",
                "required": [
                  "code",
                  "message"
                ],
                "properties": {
                  "code": {
                    "type": "integer",
                    "description": "The HTTP status code representing the error.",
                    "example": 400
                  },
                  "message": {
                    "type": "string",
                    "description": "A brief description of the error.",
                    "example": "Bad Request"
                  },
                  "target": {
                    "type": "string",
                    "description": "The target resource of the error.",
                    "example": "example target"
                  }
                }
              }
            ],
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "details": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/segments-error-response/allOf/0/allOf/0"
                },
                "description": "Additional details of cascading error messages."
              }
            }
          }
        ],
        "type": "object",
        "properties": {
          "validationCode": {
            "type": "string",
            "description": "Business validation code for bad requests.",
            "example": "SEGMENTS_PER_EVENT_LIMIT_REACHED",
            "enum": [
              "ATTENDEES_PER_SEGMENT_LIMIT_REACHED",
              "DUPLICATE_SEGMENT_NAME",
              "ERROR_CHECKING_CONNECTION_TO_LINKEDIN",
              "SEGMENT_CONNECTED_TO_LINKEDIN",
              "SEGMENTS_PER_ATTENDEE_LIMIT_REACHED",
              "SEGMENTS_PER_EVENT_LIMIT_REACHED"
            ]
          }
        }
      },
      "send-email-emarketing-response": {
        "title": "Send Emarketing Email Response",
        "description": "Response object containing a request ID and a list of all email responses sent to recipients.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/send-email-event-response/allOf/0"
          }
        ],
        "required": [
          "templateId",
          "recipientResponse"
        ],
        "properties": {
          "templateId": {
            "type": "string",
            "description": "The template ID of the eMarketing email.",
            "example": "12345::2023-09-22T08:34:21.593Z"
          },
          "recipientResponse": {
            "type": "array",
            "minItems": 1,
            "maxItems": 200,
            "items": {
              "$ref": "#/components/schemas/recipients-response.json"
            },
            "description": "List of responses specifying the status of email request for each recipient."
          }
        }
      },
      "send-email-event-request": {
        "title": "Send Event Email Request",
        "description": "Request object to send an email to one or more event attendees.",
        "required": [
          "event",
          "email",
          "resendToPreviousRecipients",
          "attendees"
        ],
        "type": "object",
        "properties": {
          "event": {
            "$ref": "#/components/schemas/event.json11"
          },
          "email": {
            "$ref": "#/components/schemas/email.json2"
          },
          "resendToPreviousRecipients": {
            "type": "boolean",
            "description": "True indicates this email should be resent to attendees who had already received this email previously.",
            "example": true
          },
          "attendees": {
            "type": "array",
            "minItems": 1,
            "maxItems": 200,
            "items": {
              "type": "string",
              "format": "uuid",
              "description": "The ID of an attendee to whom you'd like to send an email.",
              "example": "9A641E55-3367-4C50-B21B-B6A7613DFB23"
            },
            "description": "Array of attendee identifiers to whom email is to be sent."
          }
        }
      },
      "send-email-event-response": {
        "title": "Send Event Email Response",
        "description": "Response object containing a request ID and a list of all email responses sent to attendees.",
        "type": "object",
        "allOf": [
          {
            "title": "Send Email Response",
            "description": "Response object containing details of email send.",
            "type": "object",
            "allOf": [
              {
                "title": "Audit",
                "description": "Audit information",
                "type": "object",
                "properties": {
                  "created": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The ISO 8601 zoned date time when this record was created.",
                    "readOnly": true,
                    "example": "2017-01-02T02:00:00Z"
                  },
                  "createdBy": {
                    "type": "string",
                    "description": "The identifier of the user that created this record.",
                    "readOnly": true,
                    "example": "hporter"
                  },
                  "lastModified": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The ISO 8601 zoned date time when this record was updated.",
                    "readOnly": true,
                    "example": "2019-02-12T03:00:00Z"
                  },
                  "lastModifiedBy": {
                    "type": "string",
                    "description": "The identifier of the user that last updated this record.",
                    "readOnly": true,
                    "example": "hporter"
                  }
                }
              }
            ],
            "required": [
              "requestId"
            ],
            "properties": {
              "requestId": {
                "type": "string",
                "format": "uuid",
                "description": "The request ID for the email send request.",
                "example": "3A541E55-3367-4C50-B21B-B6A7613DFB23"
              },
              "status": {
                "$ref": "#/components/schemas/send-email-request-status.json"
              },
              "description": {
                "type": "string",
                "description": "The description of the response. If the `status` is `ERROR`, this field contains the reason for the failure.",
                "example": "Cannot send an email from deleted event."
              }
            }
          }
        ],
        "required": [
          "event",
          "email",
          "resendToPreviousRecipients",
          "attendeeResponse"
        ],
        "properties": {
          "event": {
            "$ref": "#/components/schemas/event.json11"
          },
          "email": {
            "$ref": "#/components/schemas/email.json2"
          },
          "resendToPreviousRecipients": {
            "type": "boolean",
            "description": "True indicates this email should be resent to attendees who had already received this email previously.",
            "example": true
          },
          "attendeeResponses": {
            "type": "array",
            "minItems": 1,
            "maxItems": 200,
            "items": {
              "$ref": "#/components/schemas/attendee-response.json"
            },
            "description": "List of responses specifying the status of email request for each attendee."
          }
        }
      },
      "send-email-request": {
        "title": "Send EMarketing Email Request",
        "description": "Request object to send an email to one or more eMarketing campaign recipients.",
        "required": [
          "templateId",
          "recipients"
        ],
        "type": "object",
        "properties": {
          "templateId": {
            "type": "string",
            "description": "The template ID of the eMarketing email to be sent.",
            "example": "12345"
          },
          "recipients": {
            "type": "array",
            "minItems": 1,
            "maxItems": 200,
            "items": {
              "$ref": "#/components/schemas/recipients-request.json"
            },
            "description": "Array of one or more recipients whom emails need to be sent."
          }
        }
      },
      "send-email-request-status.json": {
        "title": "Send Email Request Status",
        "enum": [
          "ERROR",
          "IN-PROGRESS",
          "SUCCESSFUL"
        ],
        "type": "string",
        "description": "Denotes the status of the send email request.",
        "example": "ERROR"
      },
      "send-email-response": {
        "title": "Send EMarketing Email Response",
        "description": "Response object containing a request ID and a list of all email responses sent to recipients.",
        "type": "object",
        "required": [
          "requestId",
          "templateId",
          "recipientResponse"
        ],
        "properties": {
          "requestId": {
            "type": "string",
            "format": "uuid",
            "description": "The request ID for the eMarketing email send request.",
            "example": "3A541E55-3367-4C50-B21B-B6A7613DFB23"
          },
          "templateId": {
            "type": "string",
            "description": "The template ID of the eMarketing email.",
            "example": "12345"
          },
          "recipientResponse": {
            "type": "array",
            "minItems": 1,
            "maxItems": 200,
            "items": {
              "$ref": "#/components/schemas/recipients-response.json"
            },
            "description": "List of responses specifying the status of email request for each recipient."
          },
          "status": {
            "$ref": "#/components/schemas/send-email-request-status.json"
          },
          "description": {
            "type": "string",
            "description": "The description of the request status. If the `status` is `ERROR`, this field contains the reason for the failure.",
            "example": "Cannot send an email to inactive campaign(s)."
          }
        }
      },
      "send-email-status.json": {
        "title": "Send Email Status",
        "enum": [
          "Sent",
          "In-Progress",
          "Error",
          "Opted-Out"
        ],
        "type": "string",
        "description": "It is used to denote the status of the sent email.",
        "example": "Accepted"
      },
      "ServiceProviderConfig": {
        "title": "ServiceProviderConfigs",
        "description": "Service Provider Configs",
        "type": "object",
        "properties": {
          "schemas": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "urn:ietf:params:scim:api:messages:2.0:ListResponse"
            },
            "description": "The list of schemas using this resource."
          },
          "documentationUri": {
            "type": "string",
            "format": "uri",
            "description": "The location of the API documentation.",
            "example": "https://developers.cvent.com/documentation#section/Introduction"
          },
          "patch": {
            "description": "Config details for patch operations.",
            "type": "object",
            "properties": {
              "supported": {
                "type": "boolean",
                "description": "Indicates if the patch operation is supported.",
                "example": false
              }
            }
          },
          "bulk": {
            "description": "Config details for bulk operations.",
            "type": "object",
            "properties": {
              "supported": {
                "type": "boolean",
                "description": "Indicates if the bulk operation is supported.",
                "example": false
              },
              "maxOperations": {
                "type": "integer",
                "description": "An integer value specifying the maximum number of operations.",
                "example": 1
              },
              "maxPayloadSize": {
                "type": "integer",
                "description": "An integer value specifying the maximum payload size in bytes.",
                "example": 1048576
              }
            }
          },
          "filter": {
            "description": "Config details for filter operations.",
            "type": "object",
            "properties": {
              "supported": {
                "type": "boolean",
                "description": "Indicates if the filteration is supported.",
                "example": false
              },
              "maxResults": {
                "type": "integer",
                "description": "The maximum number of results in the response.",
                "example": 100
              }
            }
          },
          "changePassword": {
            "description": "Config details for change password operations.",
            "type": "object",
            "properties": {
              "supported": {
                "type": "boolean",
                "description": "Indicates if the password change is supported.",
                "example": false
              }
            }
          },
          "sort": {
            "description": "Config details for sort operations.",
            "type": "object",
            "properties": {
              "supported": {
                "type": "boolean",
                "description": "Indicates if the sort operation is supported.",
                "example": false
              }
            }
          },
          "etag": {
            "description": "Config details for change e-tag operations.",
            "type": "object",
            "properties": {
              "supported": {
                "type": "boolean",
                "description": "Indicates if the entity tag operation is supported.",
                "example": false
              }
            }
          },
          "authenticationSchemes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/authentication-schema.json"
            },
            "description": "The collection of authentication schemas."
          },
          "meta": {
            "$ref": "#/components/schemas/meta.json"
          }
        }
      },
      "session": {
        "title": "Session",
        "type": "object",
        "description": "Used to denote a session and its attributes.",
        "required": [
          "title",
          "start",
          "end",
          "event",
          "event.id",
          "status"
        ],
        "allOf": [
          {
            "title": "SessionBase",
            "type": "object",
            "description": "Used to denote a session and all of its attributes.",
            "required": [
              "title",
              "start",
              "end",
              "event",
              "event.id",
              "status"
            ],
            "allOf": [
              {
                "$ref": "#/components/schemas/session-segment/allOf/0"
              }
            ],
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3",
                "description": "A unique identifier of the session",
                "readOnly": true
              },
              "virtual": {
                "type": "boolean",
                "description": "Indicates whether the session is virtual or not.",
                "example": true,
                "readOnly": true
              },
              "event": {
                "$ref": "#/components/schemas/uuid.json"
              },
              "title": {
                "type": "string",
                "description": "Title of the session. For example, Keynote Session.",
                "maxLength": 500,
                "example": "Day 1 Keynote Session"
              },
              "code": {
                "type": "string",
                "description": "A unique code for this session.",
                "maxLength": 30,
                "example": "R5NP4NJYB3D"
              },
              "category": {
                "$ref": "#/components/schemas/id-name.json"
              },
              "type": {
                "type": "object",
                "allOf": [
                  {
                    "deprecated": true,
                    "description": "Whether a session is in-person, virtual or hybrid. Use virtual field instead."
                  },
                  {
                    "title": "Lookup",
                    "description": "Lookup response object",
                    "type": "object",
                    "properties": {
                      "id": {
                        "$ref": "#/components/schemas/uuid-property"
                      },
                      "code": {
                        "type": "string",
                        "description": "Code / Abbreviation of the lookup item.",
                        "maxLength": 30,
                        "example": "MU"
                      },
                      "name": {
                        "type": "string",
                        "description": "Name of the lookup item.",
                        "maxLength": 30,
                        "example": "Meet up"
                      }
                    }
                  }
                ]
              },
              "location": {
                "$ref": "#/components/schemas/location.json2"
              },
              "description": {
                "type": "string",
                "description": "Detailed description of the session. HTML is supported, but only a limited set of elements and attributes are allowed. Use of HTML will count towards the character limit. Planners are responsible for confirming the visual output of HTML content.\n\nAllowed elements: b, strong, i, em, u, a, strike, del, s, sup, sub, ul, ol, li, p, font, mark, span\n\nAllowed attributes:\n- color on font\n- style on p, font, li, ul, ol, span\n- href, target, rel on a",
                "maxLength": 5000,
                "example": "Keynote session to kick off the event. The dynamic and energetic Dr. Smith will be speaking about the industry."
              },
              "start": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 formatted date and time when the session starts.",
                "example": "2020-02-03T13:00:00.000Z"
              },
              "end": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 formatted date and time when the session ends.",
                "example": "2020-02-07T17:00:00.000Z"
              },
              "status": {
                "$ref": "#/components/schemas/session-status.json"
              },
              "automaticallyOpensOn": {
                "type": "string",
                "format": "date",
                "description": "The ISO 8601 formatted date when the session registration automatically opens.",
                "example": "2022-08-01"
              },
              "automaticallyClosesOn": {
                "type": "string",
                "format": "date",
                "description": "The ISO 8601 formatted date when the session registration automatically closes.",
                "example": "2022-08-12"
              },
              "enableWaitlist": {
                "type": "boolean",
                "description": "Indicates if the waitlist is supported for the session.",
                "example": false
              },
              "waitlistCapacity": {
                "type": "integer",
                "description": "The maximum number of attendees who can waitlist for the in-person portion of the session.",
                "example": 100
              },
              "enableWaitlistVirtual": {
                "type": "boolean",
                "description": "Indicates if the virtual waitlist for the session is open.",
                "example": true
              },
              "capacity": {
                "type": "integer",
                "description": "The maximum number of attendees who can enroll in the in-person portion of the session.",
                "example": 150
              },
              "capacityUnlimited": {
                "type": "boolean",
                "description": "Indicates whether a given session has unlimited in-person capacity.",
                "example": false
              },
              "capacityVirtual": {
                "type": "integer",
                "description": "The maximum number of attendees who can enroll in the virtual portion of the session.",
                "example": 150
              },
              "virtualCapacityUnlimited": {
                "type": "boolean",
                "description": "Indicates whether a given session has unlimited virtual capacity.",
                "example": false
              },
              "waitlistCapacityVirtual": {
                "type": "integer",
                "description": "The maximum number of attendees who can waitlist the virtual portion of the session.",
                "example": 150
              },
              "timezone": {
                "type": "string",
                "deprecated": true,
                "description": "The timezone of the event that the session is associated with",
                "maxLength": 29,
                "example": "America/New_York",
                "readOnly": true
              },
              "displayOnAgenda": {
                "type": "boolean",
                "description": "Indicates whether to display the session on Agenda.",
                "example": true,
                "default": true
              },
              "featured": {
                "type": "boolean",
                "description": "Indicates if the session is featured",
                "example": true
              },
              "group": {
                "type": "string",
                "example": "b0cd3bac-0565-4593-be6e-5333753a6c25",
                "properties": {
                  "id": {
                    "$ref": "#/components/schemas/uuid-property"
                  }
                },
                "description": "The id of the session group, if the session belongs to one"
              },
              "admissionItems": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/uuid-property"
                },
                "description": "The ids of the admission items, if the session is included with any."
              },
              "openForRegistration": {
                "type": "boolean",
                "description": "Indicates if the session is open for registration.",
                "example": false
              },
              "openForAttendeeHub": {
                "type": "boolean",
                "description": "Indicates if the session is open for AttendeeHub.",
                "example": true
              },
              "registrationTypes": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/uuid-property"
                },
                "description": "Contains unique identifiers for registration types associated with this session"
              },
              "presentationType": {
                "type": "string",
                "description": "The presentation type of the session.",
                "maxLength": 100,
                "example": "Power Point"
              },
              "dataTagCode": {
                "type": "string",
                "description": "A tag associated with the session.",
                "maxLength": 30,
                "example": "Optional Session"
              },
              "customFields": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/custom-field.json2"
                },
                "description": "Collection of custom fields.",
                "readOnly": true
              },
              "segments": {
                "type": "array",
                "maxItems": 25,
                "items": {
                  "$ref": "#/components/schemas/segment-id.json"
                },
                "description": "Contains unique identifiers for segments associated with this session.",
                "readOnly": true
              },
              "order": {
                "type": "integer",
                "description": "The display order of session, set by planner for concurrent sessions",
                "example": 1
              }
            }
          }
        ],
        "properties": {
          "includedSession": {
            "type": "boolean",
            "description": "Indicator to specify if this session was automatically included with the event.",
            "example": true,
            "default": false
          },
          "relevance": {
            "$ref": "#/components/schemas/relevance.json"
          }
        }
      },
      "session-bulk-checkin": {
        "title": "SessionBulkCheckin",
        "description": "Represents a list of session check-ins.",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/session-checkin-create.json"
        }
      },
      "session-category": {
        "title": "SessionCategory",
        "description": "This is used to denote the category of a session.",
        "required": [
          "name"
        ],
        "type": "object",
        "properties": {
          "id": {
            "title": "Session Category Id",
            "description": "A string that represents a specified session category.",
            "type": "string",
            "format": "uuid",
            "example": "38db6ae2-0dc3-487b-953e-86d6abbdf7d3",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "description": "The name of the session category.",
            "maxLength": 100,
            "example": "Networking"
          },
          "description": {
            "type": "string",
            "description": "A description for the session category.",
            "maxLength": 2500,
            "example": "During networking sessions, come meet fellow workers in your field."
          }
        }
      },
      "session-category-paginated-response": {
        "title": "SessionCategoryPaginatedResponse",
        "description": "The response from a request to get the list of session categories.  This includes the paging object as well as the collection of session categories.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/session-category"
            },
            "description": "Collection of session categories."
          }
        }
      },
      "session-checkin-base.json": {
        "title": "SessionCheckinBase",
        "description": "Base model for a session check-in.",
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "ID of an attendee to be checked in to a session.",
            "example": "9463c74e-18c6-401a-a710-ae0f485bf059"
          },
          "checkOut": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date and time when the attendee checked out of a session.",
            "example": "2018-01-13T02:00:00Z"
          },
          "device": {
            "type": "string",
            "description": "Name of the device used for check-in.",
            "example": "Mobile App"
          },
          "duration": {
            "type": "integer",
            "description": "Duration (in milliseconds) of attendance in the session.",
            "minimum": 0,
            "example": 4000
          }
        }
      },
      "session-checkin-bulk-update": {
        "title": "SessionCheckinBulkUpdate",
        "description": "A list of session check-ins to be updated in bulk.",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/session-checkin-base.json"
        }
      },
      "session-checkin-create.json": {
        "title": "SessionCheckin",
        "description": "Represents an attendee to be checked into a session.",
        "required": [
          "checkIn"
        ],
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/session-checkin-base.json"
          }
        ],
        "properties": {
          "checkIn": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date and time when the attendee was checked into a session.",
            "example": "2018-01-13T02:00:00Z"
          }
        }
      },
      "session-document-lite.json": {
        "type": "object",
        "title": "SessionDocumentLite",
        "description": "The related document object.",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/document-id.json"
          }
        }
      },
      "session-document-paginated-response": {
        "title": "SessionDocumentPaginatedResponse",
        "description": "The response from a request to get the list of documents for a single session.  This includes the paging object as well as the collection of documents.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/session-file"
            },
            "description": "Collection of a session's documents."
          }
        }
      },
      "session-enrollment-status.json": {
        "title": "SessionEnrollmentStatus",
        "type": "string",
        "enum": [
          "Registered",
          "Waitlisted",
          "Cancelled"
        ],
        "description": "Denotes the attendee's status in the session. Registered: The attendee is registered for the session. Waitlisted: The attendee is on a waitlist to register for the session. Cancelled: The attendee's registration for the session has been cancelled.",
        "example": "Waitlisted"
      },
      "session-file": {
        "title": "SessionFile",
        "required": [
          "file",
          "href"
        ],
        "description": "Used to denote a session files attributes.",
        "properties": {
          "file": {
            "properties": {
              "id": {
                "$ref": "#/components/schemas/uuid-property"
              }
            }
          },
          "href": {
            "format": "uri",
            "type": "string",
            "description": "URL of a session's document",
            "readOnly": true,
            "example": "https://custom.cvent.com/a5154f85f71a4cf2464e037feb75b308/00000000000000000000000000000000/files/e209d73d845746b7a6deda4da9d91b2c.png"
          },
          "friendlyName": {
            "type": "string",
            "description": "Friendly name of the file",
            "example": "Important Document",
