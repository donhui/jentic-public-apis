            },
            "maxItems": 4
          },
          "displayRate": {
            "$ref": "#/components/schemas/display-rate.json"
          }
        }
      },
      "reservation-night.json": {
        "description": "Reservation night details.",
        "title": "ReservationNight",
        "type": "object",
        "required": [
          "stayDate",
          "status",
          "rate"
        ],
        "properties": {
          "stayDate": {
            "description": "Night date.",
            "type": "string",
            "format": "date",
            "example": "2024-12-01"
          },
          "status": {
            "description": "Indicator of night's status.",
            "type": "string",
            "enum": [
              "confirmed",
              "waitlisted"
            ]
          },
          "hideRates": {
            "description": "True indicates the rates are hidden for this night.",
            "type": "boolean",
            "example": false
          },
          "rate": {
            "$ref": "#/components/schemas/reservation-night-rate.json"
          }
        }
      },
      "reservation-payment-info.json": {
        "description": "Payment information.",
        "title": "Reservation Payment Info",
        "allOf": [
