      "discountAgendaItemFilter": {
        "name": "filter",
        "in": "query",
        "required": false,
        "description": "A filter query string narrows search results and supports the combination of logical and comparison operators.\nThe filter adheres to the pattern filter='field' comparisonType 'value'.\n\nThere are two comparison types that can be used in filter expressions:\n   * equal: eq\n   * includes value(s): in\n\nThe following fields are filterable:\n   * discount.id (eq|in)\n   * type (eq|in)\n\nThe following operators are available:\n   * and\n   * or\n",
        "schema": {
          "type": "string",
          "example": "type eq 'AdmissionItem' and discount.id in ('1b01ae34-6970-41f2-a4e8-b4f39185dc15', '1b01ae34-6970-41f2-a4e8-b4f39185dc16')"
        }
      },
      "discountCode": {
        "in": "path",
        "name": "discountCode",
        "description": "Unique Code for a Discount.",
        "required": true,
        "schema": {
          "type": "string",
          "maxLength": 30,
          "example": "HALF_OFF"
        }
      },
      "discountFilter": {
        "name": "filter",
        "in": "query",
        "required": false,
        "description": "A filter query string narrows search results and supports the combination of logical and comparison operators.\nThe filter adheres to the pattern filter='field' comparisonType 'value'.\n\nThere are two comparison types that can be used in filter expressions:\n   * equal: eq\n   * includes value(s): in\n\nThe following fields are filterable:\n   * id (in)\n   * method.type (eq)\n   * type (eq)\n   * level (eq)\n\nThe following operators are available:\n   * and\n   * or\n",
        "schema": {
          "type": "string",
          "example": "id in ('1b01ae34-6970-41f2-a4e8-b4f39185dc15', '1b01ae34-6970-41f2-a4e8-b4f39185dc16') and method.type eq 'PERCENTAGE'"
        }
      },
