          },
          "type": {
            "$ref": "#/components/schemas/thumbnail-type.json"
          },
          "status": {
            "$ref": "#/components/schemas/thumbnail-status.json"
          }
        }
      },
      "video-type.json": {
        "title": "VideoType",
        "enum": [
          "mpg2",
