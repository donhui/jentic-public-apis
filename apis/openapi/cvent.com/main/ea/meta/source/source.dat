          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/filter"
              },
              "example": {
                "filter": "status eq 'Accepted' or status eq 'Pending' and (id eq 'abc' or id eq 'def')"
              }
            }
          }
        },
        "parameters": [
          {
            "$ref": "#/components/parameters/after"
          },
          {
            "$ref": "#/components/parameters/before"
          },
          {
            "$ref": "#/components/parameters/limit"
          },
