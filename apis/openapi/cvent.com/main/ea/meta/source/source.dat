      "travel-request-status.json": {
        "title": "TravelRequestStatus",
        "enum": [
          "SUBMITTED",
          "PROCESSING",
          "APPROVED",
          "RESERVED",
          "DENIED",
          "NOT_AVAILABLE",
          "CANCELLED",
          "PENDING",
          "TICKETED",
          "WAITLISTED"
        ],
        "type": "string",
