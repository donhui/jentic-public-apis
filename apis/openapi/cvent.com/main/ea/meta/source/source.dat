      "refund-policy.json": {
        "title": "RefundPolicy",
        "description": "Refund policy associated to a fee.",
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "example": 50,
            "description": "The total refund amount when the related item is canceled from the attendee's agenda."
          },
          "percentage": {
            "type": "number",
            "example": 50,
            "description": "The total refund percentage when the related item is canceled from the attendee's agenda. Percentage is returned only if the refund policy is `RefundByPercentage`."
          },
          "type": {
            "$ref": "#/components/schemas/refund-type.json"
          },
          "cancelByDate": {
            "type": "string",
            "format": "date",
            "description": "Attendees must cancel by this ISO 8601 formatted date to receive the type of refund. Otherwise, nothing is refunded.",
            "readOnly": true,
            "example": "2020-02-09"
          }
        }
      },
      "refund-type.json": {
        "description": "The type of refund policy for the fee. `RefundByFixedAmount`: Returns a fixed amount to the attendee as chosen by the planner. `RefundByCancellationAmount`: Refunds everything to the attendee minus an cancellation fee chosen by the planner. `RefundByPercentage`: Refunds a percentage of the amount as chosen by the planner.",
        "title": "RefundType",
        "type": "string",
        "enum": [
          "RefundByFixedAmount",
          "RefundByCancellationAmount",
          "RefundByPercentage"
        ],
        "example": "RefundByPercentage"
      },
