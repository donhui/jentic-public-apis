          },
          "refundPolicy": {
            "type": "array",
            "maxItems": 5,
            "description": "Refund policy for the fee.",
            "items": {
              "$ref": "#/components/schemas/refund-policy.json"
            }
          },
          "active": {
            "type": "boolean",
            "description": "True indicates that the fee is active.",
            "default": false
          },
          "display": {
            "type": "boolean",
            "description": "True indicates that the fee displays in the fee widget.",
            "example": true
          },
          "default": {
            "type": "boolean",
            "example": true,
            "description": "True indicates this is the default fee. Default fees apply to attendees without a registration type. Each agenda item can only have one default fee."
          },
          "generalLedgerCodes": {
            "type": "array",
            "maxItems": 2,
            "description": "General ledger codes for the fee.",
            "items": {
              "$ref": "#/components/schemas/general-ledger-code.json"
            }
          },
          "registrationTypes": {
            "type": "array",
            "maxItems": 100,
            "description": "The registration types this fee is applies to, represented by their IDs.",
            "items": {
              "type": "string",
              "format": "uuid",
              "description": "A unique identifier representing the planner-defined registration type this fee applies to. These IDs can be matched to registration type details by comparing IDs returned in [List Registration Types](#operation/listRegistrationTypes)."
            },
            "example": [
              "a64b648e-b7b0-4031-8f8a-8d5e0919b936",
              "f590f1ee-6c54-4b01-90e6-d701748f0851"
            ]
          }
        }
      },
