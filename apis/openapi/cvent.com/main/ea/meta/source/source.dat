        "operationId": "listMembershipItems",
        "tags": [
          "Events"
        ],
        "security": [
          {
            "OAuth2.clientCredentials": [
              "event/membership-items:read"
            ]
          },
          {
            "OAuth2.authorizationCode": [
              "event/membership-items:read"
            ]
          }
        ],
        "description": "Gets a paginated list of membership items. [Membership items](https://support.cvent.com/s/communityarticle/Setting-Up-Memberships) are a type of [optional item](https://support.cvent.com/s/communityarticle/Understanding-Agenda-Items) that can be purchased during registration.\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/eventId2"
          },
