            "example": "2021-01-13"
          },
          "quantity": {
            "type": "integer",
            "description": "The total number of rooms for this room block.",
            "example": 20,
            "minimum": 0
          },
          "rate": {
            "type": "number",
            "description": "The nightly cost of rooms in this room block.",
            "example": 150,
            "minimum": 0
          }
        }
      },
      "sleeping-room-requirement.json": {
        "title": "SleepingRoomRequirement",
        "description": "The requirements of a sleeping room on the specified date.",
        "required": [
          "date"
        ],
        "properties": {
          "date": {
            "type": "string",
            "description": "The date for the sleeping room, in format of YYYY-MM-DD.",
            "example": "2099-12-11"
          },
          "any": {
            "type": "integer",
            "description": "The number of any sleeping rooms.",
            "example": 10
          },
          "single": {
            "type": "integer",
            "description": "The number of 1 bed sleeping rooms.",
            "example": 10
          },
          "double": {
            "type": "integer",
            "description": "The number of 2 beds sleeping rooms.",
            "example": 10
          },
          "suite": {
            "type": "integer",
            "description": "The number of suite sleeping rooms.",
            "example": 10
          },
          "staff": {
            "type": "integer",
            "description": "The number of sleeping rooms for staff.",
            "example": 10
          }
        }
      },
      "sleeping-room-type.json": {
        "type": "string",
        "title": "SleepingRoomType",
        "description": "Sleeping room type",
        "enum": [
          "ANY",
          "SINGLE",
          "DOUBLE",
          "SUITE",
          "STAFF"
        ]
      },
      "sleeping-room.json": {
        "type": "object",
        "title": "SleepingRoom",
        "description": "The sleeping room.",
        "properties": {
          "proposalDateType": {
            "$ref": "#/components/schemas/date-type.json1"
          },
          "checkInDate": {
            "type": "string",
            "format": "date",
            "description": "The check in date for attendees.",
            "example": "2021-01-13"
          },
          "checkOutDate": {
            "type": "string",
            "format": "date",
            "description": "The check out date for attendees.",
            "example": "2021-01-13"
          },
          "peakRoomNights": {
            "type": "integer",
            "minimum": 0,
            "description": "The night during an event when the most sleeping rooms are occupied.",
            "example": 2
          },
          "totalRoomNights": {
            "type": "integer",
            "description": "The total number of room nights available over the entire event.",
            "minimum": 0,
            "example": 200
          },
          "lowestRate": {
            "type": "number",
            "description": "The lowest room rate offered by the venue.",
            "example": 140
          },
          "maximumRate": {
            "type": "number",
            "description": "The highest room rate offered by the venue.",
            "example": 200
          },
          "lowestAverageDailyRate": {
            "type": "number",
            "description": "The lowest average daily rate.",
            "example": 140
          },
          "highestAverageDailyRate": {
            "type": "number",
            "description": "The highest average daily rate.",
            "example": 200
          },
          "totalRoomCost": {
            "type": "number",
            "description": "The total room cost to attendees.",
            "example": 300
          },
          "budgetedRoomRate": {
            "type": "number",
            "description": "The planner's budgeted room rate.",
            "example": 135
          },
          "lowestAvailableRoomCount": {
            "type": "integer",
            "description": "Minimum number of available rooms.",
            "example": 10
          },
          "highestAvailableRoomCount": {
            "type": "integer",
            "description": "Maximum number of available rooms.",
            "example": 10
          },
          "notes": {
            "type": "string",
            "maxLength": 2500,
            "description": "Additional notes of the sleeping room.",
            "example": "Premier Suite not available for the selected dates."
          },
          "sleepingRoomBlocks": {
            "type": "array",
            "description": "List of sleeping room blocks for this sleeping room type.",
            "items": {
              "$ref": "#/components/schemas/sleeping-room-block.json"
            }
          }
        }
      },
