        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "description": "The unique ID of the housing event.",
            "type": "integer",
            "example": 69121314
          }
        }
      },
      "housing-event-room-types-list": {
        "type": "object",
        "title": "RoomTypesList",
        "description": "List of room types.",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/room-type-details"
            },
