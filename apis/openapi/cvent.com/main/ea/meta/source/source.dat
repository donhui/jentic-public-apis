        "tags": [
          "Events"
        ],
        "security": [
          {
            "OAuth2.clientCredentials": [
              "event/fee-items:read"
            ]
          },
          {
            "OAuth2.authorizationCode": [
              "event/fee-items:read"
            ]
          }
        ],
        "description": "Gets a paginated list of fee items associated with the event.\n",
