          }
        }
      },
      "housing-event-statuses.json": {
        "description": "Housing event status.",
        "title": "HousingEventStatus",
        "type": "string",
        "enum": [
          "Open",
          "PreOpen",
          "Closed",
          "Cancelled",
          "New"
        ]
      },
      "housing-event-summary-list": {
        "type": "object",
        "title": "HousingEventSummaryList",
        "description": "List of housing events with key information, providing a summarized view of each event.",
        "required": [
          "paging",
          "data"
        ],
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/housing-event/allOf/0"
            },
            "description": "List of housing events with key information, providing a summarized view of each event."
          }
        }
      },
      "hub-background.json": {
        "title": "HubBackground",
        "type": "object",
        "description": "The background image of the Events+ hub.",
        "properties": {
          "url": {
            "description": "The optimized URL of the Events+ hub's background image. The background image appears on the Events+ hub registration page.",
            "type": "string",
            "format": "uri",
            "example": "https://images.cvent.com/ab5d5f790f6b4a90b29a3711d4ec381f/video-center/4833fde2-eedf-4751-92a5-f788cfa70674/43c5b520abf9635f4168a2ce37a89d89!_!6fbef1a131b81d4bed2b16c175ef57cd.jpeg"
          },
          "originalUrl": {
            "description": "The original URL of the Events+ hub background image. The background appears on the Events+ hub Registration page.",
            "type": "string",
            "format": "uri",
            "example": "https://custom.cvent.com/ab5d5f790f6b4a90b29a3711d4ec381f/video-center/4833fde2-eedf-4751-92a5-f788cfa70674/43c5b520abf9635f4168a2ce37a89d89.jpeg"
          },
          "altText": {
            "type": "string",
            "description": "Alternate text for the background image.",
            "example": "A mostly empty conference room.",
            "minLength": 1,
            "maxLength": 100
          }
        }
      },
      "hub-calendar.json": {
        "title": "HubCalendar",
        "type": "object",
        "description": "The event calendar associated with this Events+ hub. The event calendar allows you to share multiple events and sessions in a list or calendar format.",
        "properties": {
          "id": {
            "description": "The ID of the calendar associated to an Events+ hub.",
            "type": "string",
            "format": "uuid",
            "example": "1e7e0f38-d73c-4326-9f93-422086b91304",
            "maxLength": 255
          },
          "layout": {
            "description": "The initial layout style used by front-ends to render the associated calendar.",
            "type": "string",
            "enum": [
              "List",
              "Grid"
            ],
            "example": "List"
          }
        }
      },
      "hub-colors.json": {
        "title": "HubColors",
        "type": "object",
        "description": "All the colors associated with the Events+ hub.",
        "properties": {
          "action": {
            "title": "Action Color",
            "description": "The secondary color of an Events+ hub.",
            "type": "string",
            "example": "#0F0F0F",
            "pattern": "^#?([0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})$",
            "maxLength": 7
          },
          "background": {
            "title": "Background Color",
            "description": "The background color of an Events+ hub.",
            "type": "string",
            "example": "#0F0F0F",
            "pattern": "^#?([0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})$",
            "maxLength": 7
          },
          "main": {
            "title": "Main Color",
            "description": "The primary color of an Events+ hub.",
            "type": "string",
            "example": "#0F0F0F",
            "pattern": "^#?([0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})$",
            "maxLength": 7
          },
          "mood": {
            "title": "Mood Color",
            "description": "An Events+ hub color configuration that can be set to light, dark, or a similar shade to the main color.",
            "type": "string",
            "example": "#0F0F0F",
            "pattern": "^#?([0-9A-Fa-f]{6}|[0-9A-Fa-f]{3})$",
            "default": "#FFFFFF",
            "maxLength": 7
          }
        }
      },
      "hub-fonts.json": {
        "title": "HubFonts",
        "type": "object",
        "description": "The fonts of the Events+ hub.",
        "properties": {
          "headingId": {
            "type": "string",
            "format": "uuid",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3",
            "description": "The id of the font used in this Events+ hub's heading. Custom fonts are previously uploaded in the account."
          },
          "bodyId": {
            "type": "string",
            "format": "uuid",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3",
            "description": "The id of the font used in this Events+ hub's body text. Custom fonts are previously uploaded in account."
          }
        }
      },
      "hub-id-property-read-only.json": {
        "title": "HubIdPropertyReadOnly",
        "description": "The unique ID of an Events+ Hub.",
        "type": "string",
        "format": "uuid",
        "example": "1e7e0f38-d73c-4326-9f93-422086b91304",
        "readOnly": true
      },
      "hub-login.json": {
        "title": "HubLogin",
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "default": "MAGIC_LINK",
            "enum": [
              "MAGIC_LINK",
              "SSO",
              "BOTH"
            ],
            "description": "Login method for the members of the Events+ hub. MAGIC_LINK: The members can log in via a 'magic link' provided via email. Magic links are unique for each member, allowing the member to log in without requiring credentials. SSO: The members log in via a single-sign-on (SSO) method previously configured in the Events+ hub. BOTH: Members can log in via the magic link method or the single-sign-on (SSO) method."
          },
          "organizationId": {
            "type": "string",
            "description": "Organization identifier of a Cvent identity provider when SSO login type is selected. This value is provided by Cvent when an account is first configured to support SSO. To read more about Cvent SSO support, see https://developers.cvent.com/docs/sso/overview.",
            "example": "OneloginforFlexGuestside",
            "maxLength": 255
          },
          "idpUrl": {
            "type": "string",
            "format": "uri",
            "description": "The service provider-initiated URL, used by Events+ hub members for single sign-on (SSO). Used when the `type` property is SSO or BOTH.",
            "example": "https://login.cvent.com/redirect?redirectUrl=https://cvent-login.com/oauth2/oauth-redirect&productId=0oaztigu7sVcS4PHM0h7&identityProviderName=OneloginforFlexGuestside"
          }
        },
        "description": "Fields relating to the login process for the Events+ hub."
      },
      "hub-logo.json": {
        "title": "HubLogo",
        "type": "object",
        "description": "The logo for the Events+ hub.",
        "properties": {
          "url": {
            "description": "The optimized Events+ hub logo image URL.",
            "type": "string",
            "format": "uri",
            "example": "https://images.cvent.com/ab5d5f790f6b4a90b29a3711d4ec381f/video-center/4833fde2-eedf-4751-92a5-f788cfa70674/43c5b520abf9635f4168a2ce37a89d89!_!6fbef1a131b81d4bed2b16c175ef57cd.jpeg"
          },
          "originalUrl": {
            "description": "The original URL of the logo image that was uploaded to the Events+ hub. Supported file types are JPEG, JPG, PNG, GIF. Recommended logo size is 170 x 90 pixels and 72 PPI.",
            "type": "string",
            "format": "uri",
            "example": "https://custom.cvent.com/ab5d5f790f6b4a90b29a3711d4ec381f/video-center/4833fde2-eedf-4751-92a5-f788cfa70674/43c5b520abf9635f4168a2ce37a89d89.jpeg"
          },
          "altText": {
            "type": "string",
            "description": "Alternate text for the logo image.",
            "example": "A mostly empty conference room.",
            "minLength": 1,
            "maxLength": 100
          }
        }
      },
      "hub-owner.json": {
        "title": "HubOwner",
        "type": "object",
        "description": "The owner of the Events+ hub and their information.",
        "properties": {
          "firstName": {
            "type": "string",
            "description": "First name of the Events+ hub owner.",
            "example": "Achuthanandan",
            "maxLength": 255,
            "minLength": 1
          },
          "lastName": {
            "type": "string",
            "description": "Last name of the Events+ hub owner.",
            "example": "Velikkakathu Sankaran",
            "maxLength": 255,
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the Events+ hub owner.",
            "example": "owner@example.com",
            "maxLength": 255,
            "minLength": 1
          }
        }
      },
      "hub-status-property.json": {
        "title": "HubStatusProperty",
        "type": "string",
        "enum": [
          "Inactive",
          "Active",
          "Deleted"
        ],
        "description": "The current Events+ Hub status. Inactive: The Events+ Hub is inactive and unavailable to members. Active: Members can access the Events+ Hub. Deleted: The Events+ Hub has been deleted and is unavailable to members or planners."
      },
