      "standard-survey-email-template-response": {
        "title": "StandardSurveyEmailTemplates",
        "description": "A standard survey email template",
        "type": "object",
        "allOf": [
          {
            "title": "EmailTemplateCommon",
            "description": "Email Template",
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/response-common/allOf/0"
              }
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the email template.",
                "example": "Invitation"
              },
              "subject": {
                "type": "string",
                "description": "Subject of the email template.",
                "example": "Email Template Testing"
              },
              "fromName": {
                "type": "string",
                "description": "Name of the sender.",
                "example": "Henry Potterfield"
              },
              "fromEmail": {
                "type": "string",
                "description": "The email address of the sender.",
                "example": "h.potterfield@test.com"
              },
              "plaintextBody": {
                "type": "string",
                "description": "Plain text body of the page in the email.",
                "example": "We\u2019d love to hear your thoughts!\\n\\nPlease take a few minutes to let us know about your recent experience.\\n\\nStart Survey Now ({[RES-SURVEY URL]})"
              },
              "htmlBody": {
                "type": "string",
                "description": "html body of the page sent in the email",
                "example": "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Strict//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd\"><html><head><title></title></head><body style=\"margin:0;padding:0\" id=\"body\"><table ><tbody><tr><td align=\"center\" bgcolor=\"#041532\"><table ><tbody><tr><td align=\"center\" bgcolor=\"#DDE2E6\" style=\"padding-top:0;padding-bottom:0;padding-left:0;padding-right:0\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"max-width:600px\" class=\"wrapper\"><tbody><tr><td><table><tbody><tr><td valign=\"top\"><table><tbody><tr><td><table><tbody><tr><td bgcolor=\"transparent\" style=\"padding-top:15px;padding-bottom:15px;padding-left:15px;padding-right:15px\"><table><tbody><tr><td><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"><tr><td>{[C-FIRST NAME]}, <br></td></tr> <tr><td>We&#x2019;d love to hear your thoughts!</td></tr> </table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td valign=\"top\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" align=\"left\" class=\"column\"><tbody><tr><td><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" data-cvent-id=\"widget-NucleusText-widget:13ea36d2-1eb4-452f-ae17-9d582dbeb7eb\"><tbody><tr><td bgcolor=\"transparent\" style=\"padding-top:15px;padding-bottom:15px;padding-left:15px;padding-right:15px\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"><tbody><tr><td><table><tr><td>Please take a few minutes to let us know about your recent experience.</td></tr> </table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td valign=\"top\"><table><tbody><tr><td><table><tbody><tr><td><table><tbody><tr><td >Start Survey Now</a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td valign=\"top\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" align=\"left\" class=\"column\"><tbody><tr><td><table ><tbody><tr><td bgcolor=\"transparent\" style=\"padding-top:15px;padding-bottom:15px;padding-left:15px;padding-right:15px\"><table ><tbody><tr><td><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"><tr><td style=\"font-size:16px;line-height:20px;font-family:Arial,Helvetica,sans-serif;color:#273F69;font-style:normal;font-weight:400;text-align:center; padding: 6px 0;\">If you have any questions, feel free to email us at {[SUR-AUTHOR EMAIL]}.<br>Thank you,<br>{[SUR-AUTHOR COMPANY]}&#xA0;</td></tr> </table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td valign=\"top\"><table><tbody><tr><td><table><tbody><tr><td bgcolor=\"transparent\" style=\"padding-top:15px;padding-bottom:15px;padding-left:15px;padding-right:15px\"><table ><tbody><tr><td><table><tr><td>Click the link below to opt out of receiving emails from {[SUR-AUTHOR FIRST NAME]} {[SUR-AUTHOR LAST NAME]}.<br>{[EMAIL OPT OUT]}&#xA0;</td></tr> </table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td><table><tbody><tr><td><table><tbody></tbody></table></td></tr></tbody></table></td></tr></tbody></table> ></td></tr></tbody></table></body></html>"
              },
              "locale": {
                "type": "string",
                "description": "The locale of the email template using the IETF Language Tag format.",
                "example": "en-US"
              },
              "clickTrackingEnabled": {
                "type": "boolean",
                "description": "Enables tracking when respondent clicks on the email",
                "example": true
              },
              "replyToName": {
                "type": "string",
                "description": "Name of the person to reply to",
                "example": "Henry Potterfield"
              },
              "replyToEmail": {
                "type": "string",
                "description": "Email address to reply to",
                "example": "h.potterfield@test.com"
              }
            }
          }
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/uuid-property"
          },
          "active": {
            "type": "boolean",
            "description": "Status of the email",
            "example": true
          }
        }
      },
      "standard-survey-email-template.json": {
        "title": "StandardSurveyEmailTemplates",
        "description": "A standard survey email template",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/standard-survey-email-template-response/allOf/0"
          }
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/uuid-property"
          },
          "active": {
            "type": "boolean",
            "description": "Status of the email",
            "example": true
          }
        }
      },
      "standard-survey-email-templates-paginated-response": {
        "title": "StandardSurveyEmailTemplatesPaginatedResponse",
        "description": "Response include paging and collection of email templates of a particular standard survey",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/standard-survey-email-template.json"
            },
            "description": "Collection of standard survey email templates"
          }
        }
      },
      "standard-survey-question.json": {
        "title": "StandardSurveyQuestion",
        "description": "A standard survey question.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/question.json2/allOf/0"
          }
        ],
        "properties": {
          "survey": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "chapter": {
            "$ref": "#/components/schemas/uuid.json"
          }
        }
      },
      "standard-survey-questions-paginated-response": {
        "title": "StandardSurveyQuestionsPaginatedResponse",
        "description": "Response include paging and collection of questions of a particular standard survey",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/standard-survey-question.json"
            },
            "description": "Collection of standard survey questions"
          }
        }
      },
      "standard-survey-respondent": {
        "title": "StandardSurveyRespondent",
        "description": "Standard survey respondent.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/event-survey-respondent/allOf/0"
          }
        ],
        "properties": {
          "contact": {
            "description": "Respondent contact.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
                "description": "Contact Id of the respondent"
              }
            }
          },
          "status": {
            "$ref": "#/components/schemas/respondent-status.json"
          },
          "unsubscribed": {
            "type": "boolean",
            "description": "Whether or not the respondent has unsubscribed from Survey",
            "example": false,
            "readOnly": true
          },
          "unsubscribedBy": {
            "type": "string",
            "description": "Who unsubscribed the respondent",
            "example": "Respondent",
            "readOnly": true
          },
          "invitationList": {
            "$ref": "#/components/schemas/invitation-list-common.json"
          },
          "chapters": {
            "description": "List of respondent chapters.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/respondent-chapter-reference.json"
            },
            "readOnly": true
          },
          "transactionId": {
            "$ref": "#/components/schemas/transaction-id-common.json"
          }
        }
      },
      "standard-survey-respondents-paginated-response": {
        "title": "StandardSurveyRespondentsPaginatedResponse",
        "description": "Response include paging and respondents for a survey",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/standard-survey-respondent"
            },
            "description": "Respondent for a survey"
          }
        }
      },
      "standard-survey-response": {
        "title": "StandardSurveyResponse",
        "description": "A standard survey response.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/event-survey-response/allOf/0"
          }
        ],
        "properties": {
          "survey": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "loopingChoice": {
            "$ref": "#/components/schemas/looping-choice.json"
          }
        }
      },
      "standard-survey-responses-paginated-response": {
        "title": "StandardSurveyResponsesPaginatedResponse",
        "description": "Response include paging and responses for a survey",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/standard-survey-response"
            },
            "description": "Response for a survey"
          }
        }
      },
      "standard-survey-send-email-response": {
        "title": "StandardSurveySendEmailResponse",
        "description": "A standard survey, sent-email response.",
        "type": "object",
        "properties": {
          "survey": {
            "description": "Survey of response.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
                "description": "Id of the the survey"
              }
            }
          },
          "respondent": {
            "description": "Respondent of response.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
                "description": "Id of the respondent"
              }
            }
          },
          "emailTemplate": {
            "description": "Email template used.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
                "description": "Id of the email template"
              }
            }
          }
        }
      },
      "standard-survey.json": {
        "title": "StandardSurvey",
        "description": "A standard survey.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/survey.json/allOf/0"
          }
        ],
        "properties": {
          "responseCount": {
            "description": "The count of responses.",
            "type": "integer",
            "minimum": 0,
            "example": 10
          },
          "status": {
            "$ref": "#/components/schemas/survey-status.json"
          },
          "archiveAfter": {
            "type": "string",
            "format": "date-time",
            "description": "The survey will be archived after this ISO 8601 formatted date and time.",
            "example": "2022-05-07T12:00:00.00Z"
          },
          "customFields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/custom-field.json4"
            },
            "description": "Collection of survey custom fields."
          }
        }
      },
      "standard-surveys-paginated-response": {
        "title": "StandardSurveysPaginatedResponse",
        "description": "The response from a request to get the list of standard surveys. This includes the paging object as well as the collection of surveys.",
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/standard-survey.json"
            },
            "description": "Collection of standard surveys."
          }
        },
        "required": [
          "paging",
          "data"
        ]
      },
