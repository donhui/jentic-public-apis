    "/contacts/hooks": {
      "get": {
        "summary": "List Contact Hooks",
        "description": "Gets a list of contact hooks configured in your account.",
        "operationId": "ListContactHooks",
        "tags": [
          "Hooks"
        ],
        "security": [
          {
            "OAuth2.clientCredentials": [
              "account/hooks:read"
            ]
          },
          {
            "OAuth2.authorizationCode": [
              "account/hooks:read"
            ]
          }
