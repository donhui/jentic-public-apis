          },
          "createdBy": {
            "type": "string",
            "description": "The identifier of the user that created this record.",
            "readOnly": true,
            "example": "hporter"
          },
          "lastModified": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when this record was updated.",
            "readOnly": true,
            "example": "2019-02-12T03:00:00Z"
          },
          "lastModifiedBy": {
            "type": "string",
            "description": "The identifier of the user that last updated this record.",
            "readOnly": true,
            "example": "hporter"
          }
        }
      },
      "authentication-schema.json": {
        "title": "Authentication Schema",
        "description": "Authentication Schema",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the authentication.",
            "example": "OAuth Bearer Token"
          },
          "description": {
            "type": "string",
            "description": "The description of the authentication.",
            "example": "Authentication scheme using the OAuth Bearer Token Standard"
          },
          "specUri": {
            "type": "string",
            "description": "The location of the authentication specifications.",
            "example": "https://developers.cvent.com/documentation#section/Introduction"
          },
          "documentationUri": {
            "type": "string",
            "description": "The location of the API documentation.",
            "example": "https://developers.cvent.com/documentation#section/Introduction"
          },
          "type": {
            "type": "string",
            "description": "The type of the authentication.",
            "example": "oauthbearertoken"
          },
          "primary": {
            "type": "boolean",
            "description": "True indicates the authentication is primary.",
            "example": true
          }
        }
      },
      "available-night.json": {
        "description": "Night availability details.",
        "title": "AvailableNight",
        "type": "object",
        "required": [
          "hotel",
          "roomType",
          "attendeeType",
          "date",
          "quantity",
          "roomRate",
          "currency",
          "minLengthOfStay",
          "hideRate",
          "waitListEnabled"
        ],
        "properties": {
          "hotel": {
            "$ref": "#/components/schemas/hotel-id.json"
          },
          "roomType": {
            "$ref": "#/components/schemas/room-type-id.json"
          },
          "attendeeType": {
            "$ref": "#/components/schemas/attendee-type.json"
          },
          "date": {
            "description": "Date the rooms are available.",
            "type": "string",
            "example": "2025-03-25",
            "format": "date"
          },
          "quantity": {
            "description": "Number of rooms available.",
            "type": "integer",
            "example": 130
          },
          "roomRate": {
            "description": "Cost of room per night booked.",
            "type": "number",
            "example": 150
          },
          "displayRate": {
            "$ref": "#/components/schemas/display-rate.json"
          },
          "additionalGuestFees": {
            "description": "List of additional guest fees.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/additional-guest-fees.json"
            },
            "maxItems": 4
          },
          "taxStructure": {
            "$ref": "#/components/schemas/tax-structure.json"
          },
          "currency": {
            "$ref": "#/components/schemas/currency.json2"
          },
          "maxGuests": {
            "$ref": "#/components/schemas/max-guests.json"
          },
          "minLengthOfStay": {
            "description": "Minimum number of nights required for a stay.",
            "type": "integer",
            "example": 1,
            "minimum": 1,
            "maximum": 10
          },
          "hideRate": {
            "description": "True indicates the cost of the room is hidden from attendees on the booking site.",
            "type": "boolean",
            "example": false
          },
          "waitListEnabled": {
            "description": "True indicates a waitlist is enabled for this night.",
            "type": "boolean",
            "example": false
          }
        }
      },
      "available-nights": {
        "type": "object",
        "title": "AvailableNightsList",
        "description": "List of available room nights and the availabilities associated details.",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/available-night.json"
            },
            "description": "List of available room nights and their associated details."
          }
        }
      },
      "available-time.json": {
        "title": "Available Times",
        "description": "Time availability for an event appointment,",
        "type": "object",
        "required": [
          "id",
          "startTime",
          "endTime",
          "type",
          "appointmentType"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The unique ID representing the time range.",
            "example": "0046e875-79a5-4851-8332-da105d58088a"
          },
          "startTime": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted start date/time of the time slot in UTC.",
            "example": "2019-04-12T15:15:00.000Z"
          },
          "endTime": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted end date/time of the time slot in UTC.",
            "example": "2019-04-12T15:30:00.000Z"
          },
          "type": {
            "$ref": "#/components/schemas/time-range-type.json"
          },
          "appointmentType": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "location": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "availableAppointments": {
            "type": "integer",
            "description": "The number of appointments that can be created in this time range. -1 indicates unlimited appointments.",
            "example": 2
          }
        }
      },
      "available-times-paginated-response": {
        "title": "Available Times Paginated Response",
        "type": "object",
        "description": "The response for a request of available time ranges for scheduling appointments.",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/available-time.json"
            },
            "description": "Collection of available time ranges and their associated details."
          }
        }
      },
      "badge": {
