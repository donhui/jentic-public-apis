                "type": "string",
                "description": "Title of the admission item.",
                "maxLength": 100,
                "example": "General Admission"
              },
              "code": {
                "type": "string",
                "description": "A planner-specified code for the admission item. By default, it matches the title.",
                "maxLength": 20,
                "readOnly": true,
                "example": "General Admission"
              },
              "description": {
                "type": "string",
                "description": "Description of the admission item.",
                "maxLength": 2500,
                "example": "General admission to the event. Includes all basic sessions."
              },
              "allowOptionalSessions": {
                "type": "boolean",
                "description": "True indicates the feature to restrict available sessions is active.",
                "example": false
              }
            }
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier of the admission item.",
            "readOnly": true
          },
          "event": {
            "$ref": "#/components/schemas/uuid.json"
          }
        }
      },
