            "default": -1,
            "example": 100,
            "minimum": -1,
            "maximum": 32767
          }
        }
      },
      "discount-capacity.json": {
        "title": "Discount Capacity",
        "type": "object",
        "description": "Details about the discount capacity.",
        "properties": {
