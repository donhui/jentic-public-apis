      },
      "exhibitor-admins-list-response": {
        "title": "ExhibitorAdminsListResponse",
        "type": "object",
        "description": "Exhibitor Admins List Response schema",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
