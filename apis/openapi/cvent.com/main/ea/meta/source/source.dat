                  "regionCode": {
                    "type": "string",
                    "description": "The abbreviation of the state/province/region of the address.",
                    "minLength": 2,
                    "maxLength": 10,
                    "example": "TX"
                  },
                  "country": {
                    "type": "string",
                    "description": "Name of the country of the address.",
                    "readOnly": true,
                    "example": "United States of America"
                  },
                  "latitude": {
                    "type": "integer",
                    "description": "The geo latitude of the address.",
                    "minimum": -180,
                    "maximum": 180,
                    "example": 30
                  },
                  "longitude": {
                    "type": "integer",
                    "description": "The geo longitude of the address.",
                    "minimum": -180,
                    "maximum": 180,
                    "example": -97
                  }
                }
              },
              {
                "properties": {
                  "latitude": {
                    "type": "integer",
                    "description": "The geo longitude of the address.",
                    "minimum": -180,
                    "maximum": 180,
                    "example": 30,
                    "readOnly": true
                  },
                  "longitude": {
                    "type": "integer",
                    "description": "The geo latitude of the address.",
                    "minimum": -180,
                    "maximum": 180,
                    "example": -97,
                    "readOnly": true
                  }
                }
              }
            ]
          },
          "homePhone": {
            "description": "Home phone number.",
            "type": "string",
            "deprecated": true,
            "readOnly": true,
            "maxLength": 30,
            "example": "555-555-5555"
          },
          "homeFax": {
            "description": "Home fax number.",
            "type": "string",
            "deprecated": true,
            "readOnly": true,
            "maxLength": 30,
            "example": "555-555-5555"
          },
          "workAddress": {
            "type": "object",
            "deprecated": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/planner.json2/properties/homeAddress/allOf/0"
              },
              {
                "properties": {
                  "latitude": {
                    "type": "integer",
                    "description": "The geo longitude of the address.",
                    "minimum": -180,
                    "maximum": 180,
                    "example": 30,
                    "readOnly": true
                  },
                  "longitude": {
                    "type": "integer",
                    "description": "The geo latitude of the address.",
                    "minimum": -180,
                    "maximum": 180,
                    "example": -97,
                    "readOnly": true
                  }
                }
              }
            ]
          },
          "workPhone": {
            "description": "Work phone number.",
            "type": "string",
            "deprecated": true,
            "readOnly": true,
            "maxLength": 30,
            "example": "555-555-5555"
          },
          "workFax": {
            "description": "Work fax number.",
            "type": "string",
            "deprecated": true,
            "readOnly": true,
            "maxLength": 30,
            "example": "555-555-5555"
          },
          "customFields": {
            "type": "array",
            "deprecated": true,
            "items": {
              "$ref": "#/components/schemas/custom-field.json5"
            },
            "description": "Collection of custom fields.",
            "readOnly": true
          },
          "sourceId": {
            "description": "This is an ID for the contact in an external system. NOTE: This value is expected to be unique for each contact within an account. Consider adding the external system name as part of the ID.",
            "type": "string",
            "deprecated": true,
            "readOnly": true,
            "maxLength": 50,
            "example": "system-a-00000000-0000-0000-0000-000000000000"
          },
          "mobilePhone": {
            "description": "Mobile phone number.",
            "type": "string",
            "deprecated": true,
            "readOnly": true,
            "maxLength": 30,
            "example": "555-555-5555"
          },
          "created": {
            "type": "string",
            "deprecated": true,
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when this record was created.",
            "example": "2023-12-31T15:00:00Z",
            "readOnly": true
          },
          "createdBy": {
            "type": "string",
            "deprecated": true,
            "description": "The identifier of the user that created this record.",
            "readOnly": true,
            "example": "hporter"
          },
          "lastModified": {
            "type": "string",
            "deprecated": true,
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when this record was updated.",
            "example": "2024-01-25T16:00:00Z",
            "readOnly": true
          },
          "lastModifiedBy": {
            "type": "string",
            "deprecated": true,
            "description": "The identifier of the user that last updated this record.",
            "readOnly": true,
            "example": "hporter"
          }
        }
      },
      "planning-document-event-id.json": {
        "title": "PlanningDocumentEventId",
        "description": "Event associated with the document.",
        "type": "object",
        "properties": {
          "id": {
            "description": "A unique identifier of the event.",
            "type": "string",
            "format": "uuid",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          }
        }
      },
      "planning-document-reference-link.json": {
        "title": "PlanningDocumentReferenceLink",
        "description": "A reference link contains the URL that provides direct access to download the file for the document. The expiration of the URL can be included if applicable.",
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "The URL to download the file resource for the document. This URL will expire after the time indicated by the field expiration. If not provided, the URL is considered dynamic and not guaranteed to remain constant. Clients should always retrieve the latest URL before attempting to download the file, as it may change over time.",
            "example": "https://custom.cvent.com/4B31940730B6475A8D6A7785748A67EE/files/smm/8cfc2168a00342f5ba9e13f7a808df8e/78ce60fbf1da4cf5af139a65f59aed60.pdf"
          },
          "expiration": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted date and time at which the reference document will expire if an explicit expiration is defined.",
            "example": "2025-12-31T23:59:59Z"
          }
        }
      },
      "planning-document.json": {
        "title": "PlanningDocument",
        "description": "Represents a planning document associated with an event.",
        "type": "object",
        "allOf": [
          {
            "title": "document",
            "description": "The base model for the document metadata.",
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "description": "Unique identifier of the document.",
                "type": "string",
                "format": "uuid"
              },
              "name": {
                "type": "string",
                "maxLength": 255,
                "description": "Name of the document.",
                "example": "Agenda"
              },
              "size": {
                "type": "integer",
                "description": "Size of the document in bytes",
                "example": 204800
              },
              "uploaded": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO-8601 formatted date and time when the document was uploaded.",
                "example": "2024-06-15T13:45:30Z"
              },
              "uploadedBy": {
                "type": "string",
                "description": "The user who uploaded the document.",
                "example": "John Doe"
              },
              "lastModified": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO-8601 formatted date and time when this document was last updated.",
                "example": "2024-10-12T03:00:00Z"
              },
              "lastModifiedBy": {
                "type": "string",
                "description": "The user who last updated the document.",
                "example": "John Doe"
              }
            }
          }
        ],
        "properties": {
          "event": {
            "$ref": "#/components/schemas/planning-document-event-id.json"
          },
          "category": {
            "type": "string",
            "description": "Category of the document.",
            "maxLength": 50,
            "example": "Category 1"
          },
          "mimeType": {
            "type": "string",
            "description": "The MIME type of the document. Supported MIME types: application/pdf, application/vnd.ms-powerpoint, application/msword, text/plain, application/vnd.ms-excel, image/gif, image/jpeg, image/bmp, image/tiff, image/png, application/vnd.openxmlformats-officedocument.wordprocessingml.document, application/vnd.openxmlformats-officedocument.presentationml.presentation, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/postscript, application/vnd.ms-outlook, font/ttf, font/woff, font/otf, font/woff2, message/rfc822, video/x-msvideo, video/x-flv, video/quicktime, video/mp4, video/x-ms-wmv, text/calendar",
            "example": "application/pdf"
          },
          "description": {
            "type": "string",
            "description": "Description of the document.",
            "maxLength": 255,
            "example": "A detailed description of the document."
          },
          "secured": {
            "type": "boolean",
            "description": "True indicates the document is stored in a secured bucket and needs a signed URL to be retrieved.",
            "example": true
          },
          "referenceLink": {
            "$ref": "#/components/schemas/planning-document-reference-link.json"
          }
        }
      },
      "planning-documents-paginated-response": {
        "title": "PlanningDocumentResponse",
        "description": "Represents a paginated collection of event planning documents.",
        "required": [
          "data",
          "paging"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/planning-document.json"
            },
            "description": "Collection of event planning documents.",
            "maxItems": 200
          }
        }
      },
      "player-paginated-response": {
        "title": "PlayerPaginatedResponse",
        "description": "The response from a request to get the list of players.  This includes the paging object as well as the collection of players.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/existing-player"
            },
            "description": "Collection of players."
          }
        }
      },
      "player-type-provider.json": {
        "title": "PlayerTypeProvider",
        "enum": [
          "Brightcove",
          "Amazon IVS",
          "Cvent VOD"
        ],
        "type": "string",
        "description": "This is used to denote the type of a video player used for the Cvent Video Player",
        "example": "Amazon IVS",
        "readOnly": true
      },
      "player-type.json": {
        "title": "PlayerType",
        "enum": [
          "Cvent Video Player",
          "Brightcove",
          "Vimeo",
          "Weblink"
        ],
        "type": "string",
        "description": "This is used to denote the type of a video player",
        "example": "Cvent Video Player"
      },
      "policy-value-type.json": {
        "title": "Policy Value Type",
        "enum": [
          "selection_list",
          "integer",
          "money",
          "percent",
          "multi_select",
          "text_multi_line",
          "percent_or_money"
        ],
        "type": "string",
        "description": "Value type of the policy"
      },
      "poll-response.json": {
        "title": "PollResponse",
        "description": "This is used to denote the poll details.",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The name of the poll.",
            "example": "Do you like the session?"
          },
          "responses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/base-question-response.json"
            },
            "description": "The list of question and answers for a poll."
          }
        }
      },
      "pricing-config.json": {
        "title": "PricingConfig",
        "description": "Represents the configuration of the event's pricing feature.",
        "type": "object",
        "required": [
          "enabled"
        ],
        "properties": {
          "enabled": {
            "type": "boolean",
            "description": "True enables pricing for the event.",
            "example": true
          },
          "invoicePrefix": {
            "type": "string",
            "description": "A prefix helps distinguish invoices for this event from those of other events.",
            "example": "EVE001",
            "maxLength": 6
          },
          "revenueGoal": {
            "type": "number",
            "description": "Revenue goal for the event.",
            "example": 10000
          },
          "merchantAccount": {
            "type": "string",
            "description": "Name of the merchant account associated with the event. This merchant account is where all event payments are deposited and refunds are withdrawn.",
            "example": "Event merchant account - USD",
            "default": ""
          },
          "currency": {
            "type": "string",
            "description": "The ISO 4217 standard format currency code representing the currency used for event pricing.",
            "maxLength": 3,
            "example": "USD"
          },
          "allowedPaymentMethods": {
            "type": "array",
            "description": "Names of allowed payment methods for the merchant account. Not all options are valid for all merchants.",
            "items": {
              "$ref": "#/components/schemas/payment-method-type.json"
            },
            "uniqueItems": true,
            "example": [
              "Visa",
              "Diners Club",
              "Mastercard"
            ]
          }
        }
      },
      "process-form-question-type.json": {
        "title": "QuestionType",
        "enum": [
          "CommentBox",
          "Currency",
          "Decimal",
          "DateTime",
          "Email",
          "General",
          "Number",
          "MultiSelect",
          "SingleSelect",
          "USPhoneNumber",
          "Unknown"
        ],
        "type": "string",
        "description": "Denotes the type of data collected by a question.",
        "example": "FreeText",
        "readOnly": true
      },
      "process-form-submission-question.json": {
        "title": "ProcessFormSubmissionQuestion",
        "description": "A question for a process form submission.",
        "required": [
          "id",
          "value"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique ID representing this question.",
            "format": "uuid",
            "example": "f1ea56cd-6860-4f1a-baf7-973118384384"
          },
          "name": {
            "type": "string",
            "description": "The actual text of the custom field.",
            "example": "What is your favorite color?",
            "readOnly": true
          },
          "type": {
            "$ref": "#/components/schemas/process-form-question-type.json"
          },
          "value": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "example": "Green"
            },
            "description": "The set of answers to the question."
          }
        }
      },
      "process-form-submission.json": {
        "title": "ProcessFormSubmission",
        "description": "Represents a process form submission in the context of a specific event.",
        "required": [
          "id, event",
          "form"
        ],
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/meeting-request/allOf/0"
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "readOnly": true,
            "description": "The unique ID representing the process form submission.",
            "example": "f66a6cb0-4531-0f3a-cb1a-64f3017f1149"
          },
          "event": {
            "description": "The event which the process form submission is associated with.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The unique ID of the event.",
                "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
              }
            }
          },
          "process-form": {
            "$ref": "#/components/schemas/process-form.json"
          },
          "status": {
            "type": "string",
            "description": "The status of the process form submission. The status is planner defined and can be any string.",
            "example": "initialized"
          },
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/process-form-submission-question.json"
            },
            "description": "The list of possible answers to a question."
          }
        }
      },
      "process-form-submissions-paginated-response": {
        "title": "ProcessFormSubmissionPaginatedResponse",
        "description": "The response from a request to get the list of process form submissions. This includes the paging object as well as the collection of process form submissions.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/process-form-submission.json"
            },
            "description": "Collection of process form submission objects."
          }
        }
      },
      "process-form.json": {
        "title": "ProcessForm",
        "description": "An object that contains the process form ID.\n\nThis is an **expandable** object and if requested will contain the name of a process form object.",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The ID of the process form.",
            "readOnly": true,
            "example": "9c97eb50-9f88-4972-a603-f617fc3258dd"
          }
        }
      },
      "product-line.json": {
        "title": "ProductLine",
        "enum": [
          "ABSTRACT_MANAGEMENT",
          "ADMIN",
          "API_PLATFORM",
          "APPOINTMENTS",
          "AUTO_BLOCK",
          "BOOK",
          "CHANNEL_PUBLISHER",
          "CONTACT",
          "CROWD_COMPASS",
          "CSN",
          "DASHBOARD",
          "DEFAULT",
          "E_MARKETING",
          "ENGAGEMENTS_AND_PROJECTS",
          "EVENT",
          "LEGACY_SURVEY",
          "MEMBERSHIP",
          "OPT_IN",
          "ORGANIZATION",
          "OSS",
          "PORTAL",
          "RATE_INTEGRITY",
          "RES_DESK",
          "REVERSE_AUCTION",
          "RFP",
          "RFP_ALERTS",
          "RFP_PUBLISHER",
          "STARGATE",
          "SURVEY",
          "USER_ADMINISTRATION",
          "VAULT_MAIL"
        ],
        "type": "string",
        "description": "Cvent product lines or additional features.",
        "example": "EVENT"
      },
      "product-order-item.json": {
        "title": "ProductOrderItem",
        "type": "object",
        "description": "This is used to denote the product details in an order item",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/uuid-property"
          },
          "type": {
            "$ref": "#/components/schemas/order-item-type.json"
          }
        }
      },
      "product-type.json": {
        "description": "Represents a product's type. `AdmissionItem`: Product is a ticket to an event, typically denotes the day(s) the individual is attending. Every attendee must have an admission item. `Session`: Product is a agenda item at the event. Typically denotes a talk, presentation, or other scheduled occurrence at the event. `SessionBundle`: Product is a session bundle that enrolls the attendee into all the sessions included in the bundle, sometimes at a discounted rate. `QuantityItem`: Product is a quantity of things an attendee is purchasing at an event, like t-shirts or raffle tickets.",
        "title": "ProductType",
        "type": "string",
        "enum": [
          "AdmissionItem",
          "Session",
          "SessionBundle",
          "QuantityItem"
        ],
        "example": "AdmissionItem"
      },
      "product.json": {
        "type": "object",
        "description": "Represents a product. Products are items that can be purchased during registration.",
        "title": "Product",
        "properties": {
          "id": {
            "description": "ID of the associated product.",
            "readOnly": true,
            "type": "string",
            "format": "uuid",
            "example": "a64b648e-b7b0-4031-8f8a-8d5e0919b936"
          },
          "type": {
            "$ref": "#/components/schemas/product-type.json"
          },
          "name": {
            "type": "string",
            "description": "Name of the associated product.",
            "example": "Admission Item 1"
          }
        }
      },
      "program-item": {
        "title": "ProgramItem",
        "type": "object",
        "description": "Represents a program item object that will be added to a session.",
        "required": [
          "event",
          "session",
          "name"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/session-segment/allOf/0"
          }
        ],
        "properties": {
          "id": {
            "description": "ID of the program item.",
            "type": "string",
            "format": "uuid",
            "example": "38db6ae2-0dc3-487b-953e-86d6abbdf7d3",
            "readOnly": true
          },
          "event": {
            "$ref": "#/components/schemas/event-lite.json1"
          },
          "session": {
            "$ref": "#/components/schemas/session-lite.json1"
          },
          "name": {
            "type": "string",
            "description": "Name of the program item.",
            "maxLength": 500,
            "example": "Day 1 Program Item."
          },
          "duration": {
            "type": "integer",
            "description": "The duration of the program item in minutes.",
            "default": 0,
            "example": 30
          },
          "description": {
            "type": "string",
            "description": "Description of the program item.",
            "maxLength": 2500,
            "example": "This is a sample description of the day 1 program item."
          },
          "rteDescription": {
            "type": "string",
            "description": "Rich-text-editor description in json formatting.",
            "example": "{\"format\":\"draftjs-nucleus\",\"version\":1,\"content\":{\"blocks\":[{\"key\":\"cubve\",\"text\":\"Program Item Description\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}}"
          }
        }
      },
      "program-item-copy-responses": {
        "title": "ProgramItemCopyResponse",
        "description": "Returns a program item containing status, error message, and request details.",
        "type": "object",
        "allOf": [
          {
            "title": "BulkResponseItem",
            "description": "Represents a single item that is returned as part of a Bulk request call.",
            "type": "object",
            "required": [
              "status",
              "data"
            ],
            "properties": {
              "data": {
                "type": "object",
                "description": "The data returned for a single item in the bulk request call.",
                "example": {
                  "event_id": 1234,
                  "attendee_count": 50
                },
                "additionalProperties": true
              },
              "status": {
                "type": "integer",
                "description": "http status code representing processing status of a single item",
                "example": 400
              },
              "message": {
                "type": "string",
                "description": "Quick description of what happened with processing",
                "example": "Example error message."
              },
              "request": {
                "type": "object",
                "description": "The processed request tied to this response. This field is only sent when processing fails.",
                "example": {
                  "operation": "PUT",
                  "headers": {
                    "header1": "header1Value",
                    "header2": "header2Value"
                  },
                  "queryParams": {
                    "param1": "param1Value",
                    "param2": "param2Value"
                  }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        ],
        "properties": {
          "data": {
            "description": "The source and target program item or error response",
            "anyOf": [
              {
                "title": "ProgramItemCopyResponseItem",
                "required": [
                  "source",
                  "target"
                ],
                "description": "Represents a mapping between source and target program items for copying.",
                "type": "object",
                "properties": {
                  "source": {
                    "description": "The unique identifier for an existing event and session to be copied.",
                    "type": "object",
                    "example": {
                      "programItem": {
                        "id": "d8c68eb3-f5ab-40da-a7e4-d662e265877c"
                      }
                    },
                    "allOf": [
                      {
                        "$ref": "#/components/schemas/program-item-lite.json1"
                      }
                    ]
                  },
                  "target": {
                    "description": "The unique identifier for the target event and session to be copied.",
                    "type": "object",
                    "example": {
                      "programItem": {
                        "id": "d8c68eb3-f5ab-40da-a7e4-d662e265877c"
                      }
                    },
                    "allOf": [
                      {
                        "$ref": "#/components/schemas/program-item-lite.json1"
                      }
                    ]
                  }
                }
              },
              {
                "title": "ErrorResponse",
                "description": "Represents an error response with additional details of cascading error messages.",
                "allOf": [
                  {
                    "$ref": "#/components/schemas/baseErrorResponse/allOf/0"
                  }
                ],
                "type": "object",
                "required": [
                  "code",
                  "message"
                ],
                "properties": {
                  "details": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/baseErrorResponse/allOf/0"
                    },
                    "description": "Additional details of cascading error messages."
                  }
                }
              }
            ]
          }
        }
      },
      "program-item-document-paginated-response": {
        "title": "ProgramItemDocumentPaginatedResponse",
        "description": "The response from a request to get the list of session program item documents.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/program-item-session-document"
            },
            "description": "Collection of Session Program Item Documents.",
            "maxItems": 200
          }
        }
      },
      "program-item-id.json": {
        "title": "ProgramItemId",
        "description": "The unique identifier for a program item.",
        "type": "string",
        "format": "uuid",
        "example": "221984b2-9e3e-4c1c-8ef4-306b1b75fa3e"
      },
      "program-item-id.json1": {
        "title": "ProgramItemId",
        "description": "The unique identifier for a program item",
        "type": "string",
        "format": "uuid",
        "example": "788426ac-5d83-11ee-8c99-0242ac120002"
      },
      "program-item-lite.json": {
        "required": [
          "id"
        ],
        "type": "object",
        "title": "ProgramItemLite",
        "description": "The unique identifier of a program item.",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/program-item-id.json"
          }
        }
      },
