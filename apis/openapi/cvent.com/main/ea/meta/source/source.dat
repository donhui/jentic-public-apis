    "schemas": {
      "Account": {
        "title": "Account",
        "description": "The definition of a Cvent Core Account. This is the primary entity a Cvent User interacts. Once logged into the Cvent platform, the User can interact with the different product lines the account is allotted to.",
        "required": [
          "id",
          "tinyId",
          "number",
          "stub",
          "activated",
          "inactivated",
          "audit"
        ],
        "type": "object",
        "allOf": [
          {
            "title": "Account Base",
            "description": "The base definition of a Cvent Core Account.",
            "required": [
              "status",
              "type",
              "name",
              "company",
              "url",
              "showCreditCardWarning",
              "creditCardEntryDeadline"
            ],
            "type": "object",
            "properties": {
              "customer": {
                "$ref": "#/components/schemas/customer-reference.json"
              },
              "name": {
                "type": "string",
                "description": "The name of the Account.",
                "example": "Cvent"
              },
              "company": {
                "type": "string",
                "description": "The Account's company name.",
                "example": "Cvent"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "A url which points to the Account's company website.",
                "example": "https://www.cvent.com"
              },
              "status": {
                "$ref": "#/components/schemas/account-status.json"
              },
              "type": {
                "$ref": "#/components/schemas/account-type.json"
              },
              "showCreditCardWarning": {
                "type": "boolean",
                "description": "True means to show the credit card warning for the Account."
              },
              "creditCardEntryDeadline": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time of the Account's credit card entry deadline.",
                "example": "2019-07-15T09:00:39Z"
              }
            }
          }
        ],
        "properties": {
          "organization": {
            "type": "object",
            "allOf": [
              {
                "title": "Organization Reference",
                "description": "A model used to reference the identifier to a Cvent Organization.",
                "required": [
                  "id",
                  "number",
                  "stub"
                ],
                "type": "object",
                "properties": {
                  "id": {
                    "$ref": "#/components/schemas/organization-id.json"
                  },
                  "stub": {
                    "$ref": "#/components/schemas/Organization/properties/stub/allOf/0"
                  },
                  "number": {
                    "$ref": "#/components/schemas/organization-number.json"
                  }
                }
              },
              {
                "readOnly": true
              }
            ]
          },
          "id": {
            "$ref": "#/components/schemas/account-id.json"
          },
          "tinyId": {
            "type": "string",
            "description": "The Account's shortened alphanumeric identifier.",
            "example": "vnzb",
            "readOnly": true
          },
          "number": {
            "$ref": "#/components/schemas/account-number.json"
          },
          "stub": {
            "$ref": "#/components/schemas/account-stub.json"
          },
          "administratorRole": {
            "type": "object",
            "allOf": [
              {
                "title": "Account User Role Reference",
                "description": "A model used to reference a Cvent core account user role by its ID.",
                "required": [
                  "id"
                ],
                "type": "object",
                "properties": {
                  "id": {
                    "$ref": "#/components/schemas/AccountUserRole/properties/id/allOf/1"
                  }
                }
              },
              {
                "readOnly": true
              }
            ]
          },
          "activated": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when this Account has been activated.",
            "readOnly": true,
            "example": "2019-07-15T09:00:39Z"
          },
          "inactivated": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when this Account has been inactivated.",
            "readOnly": true,
            "example": "2019-07-15T09:00:39Z"
          },
          "audit": {
            "type": "object",
            "allOf": [
              {
                "title": "Audit",
                "description": "Audit information",
                "type": "object",
                "properties": {
                  "created": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The ISO 8601 zoned date time when this record was created.",
                    "readOnly": true,
                    "example": "2017-01-02T02:00:00Z"
                  },
                  "createdBy": {
                    "type": "string",
                    "description": "The identifier of the user that created this record.",
                    "readOnly": true,
                    "example": "hporter"
                  },
                  "lastModified": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The ISO 8601 zoned date time when this record was updated.",
                    "readOnly": true,
                    "example": "2019-02-12T03:00:00Z"
                  },
                  "lastModifiedBy": {
                    "type": "string",
                    "description": "The identifier of the user that last updated this record.",
                    "readOnly": true,
                    "example": "hporter"
                  }
                }
              },
              {
                "readOnly": true
              }
            ]
          }
        }
      },
      "account-budget-item-list-response.json": {
        "title": "AccountBudgetItemListResponse",
        "description": "The response from a request to retrieve list of budget items across all events linked to the account.",
        "type": "object",
        "allOf": [
          {
            "title": "Audit",
            "description": "Audit information",
            "type": "object",
            "properties": {
              "created": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was created.",
                "readOnly": true,
                "example": "2017-01-02T02:00:00Z"
              },
              "createdBy": {
                "type": "string",
                "description": "The identifier of the user that created this record.",
                "readOnly": true,
                "example": "hporter"
              },
              "lastModified": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was updated.",
                "readOnly": true,
                "example": "2019-02-12T03:00:00Z"
              },
              "lastModifiedBy": {
                "type": "string",
                "description": "The identifier of the user that last updated this record.",
                "readOnly": true,
                "example": "hporter"
              }
            }
          }
        ],
        "properties": {
          "event": {
            "$ref": "#/components/schemas/event.json4"
          },
          "rfp": {
            "$ref": "#/components/schemas/rfp-id.json1"
          },
          "budgetVersion": {
            "$ref": "#/components/schemas/budget-version-id.json"
          },
          "id": {
            "type": "string",
            "description": "The identifier of the budget item.",
            "format": "uuid",
            "example": "9463c74e-18c6-401a-a710-ae0f485bf959",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Name of the budget item.",
            "example": "Airport Transportation"
          },
          "code": {
            "type": "string",
            "maxLength": 30,
            "description": "User defined code of the budget item.",
            "example": "AIRTRP"
          },
          "category": {
            "$ref": "#/components/schemas/budget-category.json"
          },
          "subCategory": {
            "$ref": "#/components/schemas/budget-sub-category.json"
          },
          "deleted": {
            "type": "boolean",
            "description": "True indicates the event budget item is deleted.",
            "example": false
          }
        }
      },
      "account-budget-items-paginated-response": {
        "title": "AccountBudgetItemsPaginatedResponse",
        "description": "The response from a request to retrieve a paginated list of budget items across all events linked to the account.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "maxItems": 200,
            "items": {
              "$ref": "#/components/schemas/account-budget-item-list-response.json"
            },
            "description": "Collection of budget items."
          }
        }
      },
      "account-id.json": {
        "title": "Account Id",
        "description": "The unique auto-incremented numeric identifier generated for an Account.",
        "type": "integer",
        "readOnly": true,
        "example": 801472078
      },
      "account-number.json": {
        "title": "Account Number",
        "description": "The unique customer defined alphanumeric identifier used by customers to differentiate accounts when logging into the Cvent Platform. This identifier can be modified to a different unused identifier.",
        "type": "string",
        "example": "CVENT00001",
        "minLength": 10,
        "maxLength": 10,
        "pattern": "^[A-Z]{3,}[0-9]*$"
      },
      "account-status.json": {
        "title": "Account Status",
        "description": "Enumerated value representing the status of an Account.\n\nPossible values:\n* ACTIVE - Account is operational.\n* INACTIVE - Account deactivated either temporarily or permanently and pending archival or purge process.\n* PURGED - Account data deleted from main database.\n* PURGING_ERROR - Purging of the account by Archival Service failed.\n* READ_ONLY - Account allows users to log in and access existing data (e.g., run reports, export/download), but prevents creation or activation of any new data or workflow.\n* SUSPENDED - Account temporarily disabled due to payment or other non compliance.\n* QUEUED_FOR_PURGE - Account is queued to be purged with Archival Service with standard priority. Expected to be purged within 30 days.",
        "readOnly": true,
        "type": "string",
        "enum": [
          "ACTIVE",
          "INACTIVE",
          "PURGED",
          "PURGING_ERROR",
          "READ_ONLY",
          "SUSPENDED",
          "QUEUED_FOR_PURGE"
        ]
      },
      "account-stub.json": {
        "title": "Account Stub",
        "type": "string",
        "format": "uuid",
        "description": "Unique identifier for an account. This identifier is safe to use for external references.",
        "readOnly": true,
        "example": "1CC2F054-B174-4FC3-9501-F63AA5FF84BD"
      },
      "account-type.json": {
        "title": "Account Type",
        "description": "An enumeration of different available account types.\nPossible values:\n* CUSTOMER - The account is owned by a Customer at Cvent.\n* CVENT_MARKETING - The account is owned by Cvent's Marketing Team.\n* CVENT_INTERNAL - The account is owned by an internal Cvent team or individual employee.\n* CUSTOMER_SANDBOX - The account is owned by a Customer for sandbox testing purposes.",
        "type": "string",
        "enum": [
          "CUSTOMER",
          "CVENT_MARKETING",
          "CVENT_INTERNAL",
          "CUSTOMER_SANDBOX"
        ],
        "example": "CUSTOMER"
      },
      "AccountUserRole": {
        "title": "Account User Role",
        "description": "Represents an account user role in Cvent. An account user role defines a set of permissions and is assigned to account users. The permissions associated with the role determine what actions the user can perform within the account.",
        "required": [
          "id",
          "name",
          "administratorRole",
          "created",
          "createdBy",
          "lastModified",
          "lastModifiedBy"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/Account/properties/audit/allOf/0"
          }
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "allOf": [
              {
                "readOnly": true
              },
              {
                "title": "Account User Role Id",
                "description": "Represents the unique ID of an account user role.",
                "type": "string",
                "format": "uuid",
                "example": "946505F6-6B29-421A-BDA2-0815FCDEA73C"
              }
            ]
          },
          "name": {
            "type": "string",
            "description": "The name of the account user role.",
            "example": "Administrators",
            "minLength": 1,
            "maxLength": 50
          },
          "description": {
            "type": "string",
            "description": "The description of the account user role.",
            "example": "A descriptive message about the account user role.",
            "maxLength": 300
          },
          "administratorRole": {
            "type": "boolean",
            "description": "True means this account user role is an administrative account user role.",
            "readOnly": true
          }
        }
      },
      "activity-ad.json": {
        "type": "object",
        "title": "ActivityAd",
        "description": "The details of the advertisement.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The unique identifier of the ad.",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          },
          "name": {
            "type": "string",
            "description": "The name of the ad.",
            "example": "New Year Sale"
          },
          "product": {
            "type": "string",
            "description": "The product for which ad is created",
            "example": "ATTENDEE_HUB"
          },
          "location": {
            "$ref": "#/components/schemas/ad-location.json"
          },
          "attribution": {
            "type": "object",
            "description": "The entity to which the ad is associated.",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The unique identifier of the attribution."
              },
              "type": {
                "type": "string",
                "description": "The type of attribution.",
                "example": "CUSTOM"
              }
            }
          }
        }
      },
      "activity-appointment.json": {
        "type": "object",
        "title": "ActivityAppointment",
        "description": "An activity appointment.",
        "allOf": [
          {
            "$ref": "#/components/schemas/activity-base-appointment.json"
          }
        ],
        "properties": {
          "start": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when an appointment starts.",
            "example": "2020-02-03T13:00:00.000Z"
          },
          "end": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when an appointment ends.",
            "example": "2020-02-03T14:00:00.000Z"
          }
        }
      },
      "activity-base-appointment.json": {
        "type": "object",
        "title": "ActivityBaseAppointment",
        "description": "Base entity of an activity appointment.",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/uuid-property"
          },
          "name": {
            "type": "string",
            "description": "The name of the appointment.",
            "example": "Meeting with Cvent"
          },
          "code": {
            "type": "string",
            "description": "The code of an appointment.",
            "example": "NTNHR3XMX5Z"
          },
          "appointmentEvent": {
            "type": "object",
            "description": "",
            "properties": {
              "title": {
                "type": "string",
                "description": "The title of linked appointment event.",
                "example": "Demo- Attendee Activity"
              },
              "code": {
                "type": "string",
                "description": "The code of linked appointment event.",
                "example": "VFNGZT7LH7D"
              }
            }
          }
        }
      },
      "activity-contact.json": {
        "title": "ActivityContact",
        "description": "An activity contact.",
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "description": "The first name of the attendee.",
            "maxLength": 30,
            "example": "Henry"
          },
          "lastName": {
            "type": "string",
            "description": "The last name of the attendee.",
            "maxLength": 50,
            "example": "Potterfield"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "The email address of the attendee.",
            "minLength": 6,
            "maxLength": 80,
            "example": "h.potterfield@test.com"
          }
        }
      },
      "activity-data.json": {
        "title": "ActivityData",
        "description": "This is used to denote the type of the attendee activity",
        "readOnly": true,
        "anyOf": [
          {
            "title": "appointment.accepted",
            "allOf": [
              {
                "title": "Appointment Activity",
                "description": "Appointment activity",
                "type": "object",
                "properties": {
                  "appointment": {
                    "$ref": "#/components/schemas/activity-appointment.json"
                  },
                  "contact": {
                    "$ref": "#/components/schemas/activity-contact.json"
                  }
                }
              }
            ]
          },
          {
            "title": "appointment.cancelled",
            "allOf": [
              {
                "$ref": "#/components/schemas/activity-data.json/anyOf/0/allOf/0"
              }
            ]
          },
          {
            "title": "appointment.checkedIn",
            "allOf": [
              {
                "type": "object",
                "title": "appointment.checkedIn",
