        "required": [
          "data",
          "paging"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/existing-registration-path.json"
            },
            "description": "Collection of registration paths."
          }
        }
      },
      "registration-status.json": {
        "title": "Registration Status",
        "enum": [
          "Active",
          "Cancelled",
          "Closed",
          "Completed",
          "Deleted",
          "NoRegistrationRequired",
          "Pending",
          "Processing"
        ],
        "type": "string",
        "readOnly": true,
        "description": "This is used to denote the registration status for an event.",
        "example": "Pending"
      },
      "registration-type-id.json": {
        "title": "Registration Type ID",
        "description": "A unique identifier of the registration type",
        "type": "string",
        "format": "uuid",
        "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d4"
      },
      "registration-type-paginated-response": {
        "title": "RegistrationTypePaginatedResponse",
        "description": "Represents a paginated collection of registration types.",
        "required": [
          "data",
          "paging"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/existing-registration-type-with-associated-reg-path.json"
            },
            "description": "Collection of registration types."
          }
        }
      },
      "registration-type-response": {
        "title": "ExistingRegistrationType",
        "description": "Represents the details of an existing registration type.",
        "type": "object",
        "required": [
          "id"
        ],
        "allOf": [
          {
            "title": "RegistrationType",
            "description": "Represents the details of a registration type.",
            "type": "object",
            "required": [
              "openForRegistration"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the registration type.",
                "maxLength": 50,
                "readOnly": true,
                "example": "Member"
              },
              "code": {
                "type": "string",
                "description": "Code for this registration type.",
                "maxLength": 30,
                "readOnly": true,
                "example": "MemberCode"
              },
              "description": {
                "type": "string",
                "description": "Detailed description of the registration type.",
                "maxLength": 2500,
                "readOnly": true,
                "example": "Registration type assigned to invitees who are members"
              },
              "virtual": {
                "type": "boolean",
                "description": "True indicates the registration type is virtual.",
                "example": true,
                "readOnly": true
              },
              "openForRegistration": {
                "type": "boolean",
                "description": "True indicates the registration type can be chosen for registration.",
                "example": true
              },
              "automaticOpenDate": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 formatted date-time (in UTC) the registration type automatically opens for registration.",
                "example": "2017-01-02T02:00:00Z"
              },
              "automaticEndDate": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 formatted date-time (in UTC) the registration type automatically closes for registration.",
                "example": "2017-01-02T02:00:00Z"
              },
              "event": {
                "description": "Event associated with the registration.",
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The unique identifier of the event.",
                    "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
                  }
                },
                "readOnly": true
              }
            }
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier of the registration type.",
            "readOnly": true,
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          },
          "capacity": {
            "$ref": "#/components/schemas/capacity.json1"
          }
        }
      },
      "registration-type-update": {
        "$ref": "#/components/schemas/registration-type-response"
      },
      "relevance.json": {
        "title": "Relevance",
        "description": "Returned when the `match` filter is applied. Indicates how relevant the `match` filter term is to the search result. Larger numbers represent higher relevance with respect to other search results in the request. Null if no `match` filter is provided.",
        "type": "number",
        "exclusiveMinimum": true,
        "example": 2.3,
        "minimum": 0
      },
      "reportingField.json": {
        "title": "Virtual card reporting field and value.",
        "description": "Reporting fields and values for a virtual card.",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The reporting field's name.",
            "example": "Department Code",
            "readOnly": true
          },
          "value": {
            "type": "string",
            "description": "The reporting field value.",
            "example": "12",
            "readOnly": true
          }
        }
      },
      "requested-meeting-request-question.json": {
        "title": "MeetingRequestQuestion",
        "description": "A question for a meeting request.",
        "required": [
          "id",
          "value"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique ID representing this question.",
            "format": "uuid",
            "example": "f1ea56cd-6860-4f1a-baf7-973118384384"
          },
          "name": {
            "type": "string",
            "description": "The actual text of the question.",
            "example": "What is your favorite color?",
            "readOnly": true
          },
          "type": {
            "$ref": "#/components/schemas/question-type.json1"
          },
          "value": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "example": "Green"
            },
            "description": "An array of non-null answers to the question.\n\nFor standard questions, this contains string values.\n\nIf the question is any one of:\n* Event Country/Region (`da9a6706-7af3-42fc-b2c1-708050a791c1`)\n* Requester Country/Region (`d8fa449b-ec97-4e91-8193-b753df11e064`)\n* Stakeholder Country/Region (`ddd9035a-44a2-49b0-8d31-66cdca0c13c7`)\n\nthe answer can be either the country name (for example, \"Canada\") or the country code (for example, \"CA\"), but not both. The country code specification can be found [here](https://developers.cvent.com/docs/rest-api/reference/api-standards#country-codes).\n\nFor complex questions (such as Meeting Room Requirements, Sleeping Room Requirements, or Budget Estimates), this contains JSON strings matching the format defined in `compositeValue`.\n\nNote: Use this field when updating question answers; the `compositeValue` field is read-only and should not be used for updates.\n\nFor more details, see [Get Meeting Request](#tag/Meeting-Request/operation/getMeetingRequestById)."
          },
          "compositeValue": {
            "$ref": "#/components/schemas/composite-value.json"
          }
        }
      },
      "reservation-contact.json": {
        "title": "ReservationContact",
        "description": "Reservation contact details for this event.",
        "type": "object",
        "properties": {
          "phone": {
            "description": "Phone number.",
            "type": "string",
            "example": "2345239540-123"
          },
          "fax": {
            "description": "Fax number.",
            "type": "string",
            "example": "25123-234-12"
          },
          "tollFree": {
            "description": "Toll-free number.",
            "type": "string",
            "example": "323-324"
          },
          "email": {
            "description": "Email address.",
            "type": "string",
            "example": "venue@example.com"
          }
        }
      },
      "reservation-guest.json": {
        "type": "object",
        "title": "ReservationGuest",
        "description": "Guest details for confirmed reservation.",
        "required": [
          "firstName",
          "lastName",
          "arrival",
          "departure",
          "email"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/guest.json"
          }
        ],
        "properties": {
          "ageQualifyingCode": {
            "description": "Code that specifies if the guest is an adult or child. (10 - adult, 8 - child)",
            "type": "integer",
            "enum": [
              10,
              8
            ],
            "default": 10
          },
          "primary": {
            "description": "True indicates this guest is the primary guest for the reservation.",
            "type": "boolean",
            "example": true,
            "default": false
          },
          "paymentInfo": {
            "$ref": "#/components/schemas/reservation-payment-info.json"
          },
          "locale": {
            "$ref": "#/components/schemas/locale.json-01"
          }
        }
      },
      "reservation-night-rate.json": {
        "description": "Rate details for a single reservation night.",
        "title": "ReservationNightRate",
