      "responded-through.json": {
        "title": "RespondedThrough",
        "type": "string",
        "description": "Indicates the mode by which a respondent submitted their response.\n\nThis field contains one of the enumerated, string constants listed below.\n\nEnum values:\n\n- \"Not Responded\": Respondent did not provide a response.\n- \"API\": Response was submitted via an API.\n- \"Import\": Response was created by a bulk import process.\n- \"Mobile\" (deprecated): Historically indicated submission from a mobile device. This value is deprecated.\n- \"Desktop\" (deprecated): Historically indicated submission from a desktop device. This value is deprecated.",
        "example": "API",
        "enum": [
          "Not Responded",
          "API",
          "Import",
          "Mobile",
          "Desktop"
        ]
      },
