                "example": 70,
                "readOnly": true
              },
              "maxPossibleScore": {
                "type": "number",
                "description": "Maximum Possible Score",
                "example": 100,
                "readOnly": true
              },
              "percentageScore": {
                "type": "number",
                "description": "Percentage Score",
                "example": 70,
                "readOnly": true
              }
            }
          }
        ],
        "properties": {
          "session": {
            "description": "Associated session.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
                "readOnly": true,
                "description": "Loop Session is the session for which the survey is looped. Questions in the looping survey get repeated once for each session defined in the configuration depending on eligibility"
              }
            }
          }
        }
      },
