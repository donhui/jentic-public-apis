            "example": "+911234567890",
            "minLength": 1,
            "maxLength": 30
          }
        }
      },
      "phone-type.json": {
        "title": "PhoneType",
        "description": "The type of the phone number.",
        "enum": [
          "work",
          "home",
          "mobile"
        ],
        "type": "string",
