  "components": {
    "examples": {},
    "parameters": {
      "accessCode": {
        "in": "header",
        "name": "Cvent-Access-Code",
        "description": "Example:\n\nCvent-Access-Code: c44bf029-f7f1-43dc-95c7-79403b247e2a\n\n\nAccess code for the event. It can be provided to integration partner in an email.\n",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "adminId": {
        "in": "path",
        "name": "adminId",
        "description": "ID of an exhibitor admin.",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid",
          "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
        }
      },
      "after": {
        "name": "after",
        "required": false,
        "description": "Used to query records that have been added or updated after this time point. Default to the beginning of time of the data store.",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date-time",
          "example": "2017-01-02T02:00:00Z"
        }
      },
      "after1": {
        "in": "query",
        "name": "after",
        "description": "Used to query records that have been created after this time point. Defaults to 6 months back from current time.",
        "required": false,
        "schema": {
          "type": "string",
          "example": "2021-03-26T02:30:00Z"
        }
      },
      "after_inclusive": {
        "name": "after",
        "required": false,
        "description": "Used to query records that have been added or updated on or after this time point. Defaults to the beginning of time of the data store.",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date-time",
          "example": "2017-01-02T02:00:00Z"
        }
      },
      "afterRequired": {
        "name": "after",
        "required": true,
        "description": "Used to query records that have been modified after this time point.",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date-time",
          "example": "2017-01-02T02:00:00Z"
        }
      },
      "agendaItemId1": {
        "in": "path",
        "name": "agendaItemId",
        "description": "Unique ID of an agenda item.",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/uuid-property"
        }
      },
      "appointmentAttendeeId": {
        "in": "path",
        "name": "id",
        "description": "The unique identifier of an appointment attendee. The appointment attendee's ID is a combination of the associated appointment event ID and the attendee's contact ID, concatenated with \"::\" symbols.",
        "required": true,
        "schema": {
          "type": "string",
          "example": "0cdfa3f7-05da-4121-857b-d7732891e01a::52a68001-70ce-4ec4-a6fe-d0888123c715"
        }
      },
      "appointmentAvailabilityTimeId": {
        "in": "path",
        "name": "id",
        "description": "The unique identifier of an attendee's availability times in a particular event. The attendee's availability times ID is a combination of the associated appointment event ID and the attendee's contact ID, concatenated with \"::\" symbols.",
        "required": true,
        "schema": {
          "type": "string",
          "example": "da8b035b-428b-4069-b25b-92afbcf514b3::2d8234f1-55df-483c-abe3-7e2cb98f8275"
        }
      },
      "appointmentEventId": {
        "in": "path",
        "name": "id",
        "description": "The unique identifier of an appointment event.",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/uuid-property"
        }
      },
      "appointmentId": {
        "in": "path",
        "name": "id",
        "description": "The unique identifier of an appointment.",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/uuid-property"
        }
      },
      "appointmentMeetingInterestId": {
        "in": "path",
        "name": "id",
        "description": "The unique identifier of an attendee's meeting interests in a particular event. The attendee's meeting interests ID is a combination of the associated appointment event ID and the attendee's contact ID, concatenated with \"::\" symbols.",
        "required": true,
