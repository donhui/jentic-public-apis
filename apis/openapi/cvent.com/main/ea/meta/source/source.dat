      "badge-status.json": {
        "title": "BadgeStatus",
        "type": "string",
        "enum": [
          "Assigned",
          "Active",
          "Deactivated",
          "Deleted"
        ],
        "description": "Badge status",
        "example": "Active"
      },
      "badge-type.json": {
        "title": "BadgeType",
        "type": "string",
        "enum": [
          "Epc",
          "Qr"
        ],
        "description": "Badge type",
