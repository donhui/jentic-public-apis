            "$ref": "#/components/schemas/meta.json"
          }
        }
      },
      "UsersSchemas": {
        "title": "Schemas",
        "description": "Schemas",
        "type": "object",
        "properties": {
          "schemas": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "urn:ietf:params:scim:api:messages:2.0:ListResponse"
            },
            "description": "The collection of user schemas."
          },
          "itemsPerPage": {
            "type": "integer",
            "description": "The number of schemas per page.",
            "example": 50
          },
          "startIndex": {
            "type": "integer",
            "description": "Starting index of the response.",
            "example": 1
          },
          "totalResults": {
            "type": "integer",
            "description": "The total count of schemas.",
            "example": 5
          },
          "Resources": {
