          }
        },
        "externalDocs": {
          "description": "More about OAuth2 authorization code support for administrators",
          "url": "#oauth2-auth-code-planner-admin"
        }
      },
      "post": {
        "summary": "Create Contact Hook",
        "description": "Creates a contact hook. Contact hooks have a callback URI pointing to your system where Cvent will request contact information.",
        "operationId": "createContactHook",
        "tags": [
          "Hooks"
        ],
        "security": [
          {
            "OAuth2.clientCredentials": [
              "account/hooks:write"
            ]
          },
          {
            "OAuth2.authorizationCode": [
              "account/hooks:write"
            ]
          }
        ],
        "requestBody": {
