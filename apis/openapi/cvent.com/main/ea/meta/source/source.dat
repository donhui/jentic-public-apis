            },
            "description": "Collection of appointments and their related details."
          }
        }
      },
      "appointment-participant.json": {
        "title": "AppointmentParticipant",
        "description": "An appointment participant.",
        "type": "object",
        "required": [
          "attendee",
          "type"
        ],
        "x-extends": {
          "$ref": "#/components/schemas/audit.json"
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/audit.json"
          }
        ],
        "properties": {
          "attendee": {
            "type": "object",
            "description": "Reference information for the attendee.",
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique ID representing the attendee.",
                "readOnly": true,
                "example": "0cdfa3f7-05da-4121-857b-d7732891e01a::52a68001-70ce-4ec4-a6fe-d0888123c715"
              },
              "contact": {
                "$ref": "#/components/schemas/uuid.json"
              }
            },
            "example": {
              "id": "dd1057b9-a957-4c22-be88-741a29d01471/97f2ca58-0f9e-401f-a6b5-a6f20d3a9568",
              "contact": {
                "id": "97f2ca58-0f9e-401f-a6b5-a6f20d3a9568"
              }
            }
          },
          "type": {
            "$ref": "#/components/schemas/participant-type.json"
          },
          "response": {
            "$ref": "#/components/schemas/participant-response.json"
          },
          "participation": {
            "type": "object",
            "description": "The attendee's participation status.",
            "properties": {
              "participated": {
                "type": "boolean",
                "description": "True indicates the attendee was marked as a participant in the appointment.",
                "example": true
              }
            },
            "example": {
              "participated": true
            }
          },
          "questionViewer": {
            "type": "boolean",
            "description": "True indicates custom questions are visible to appointment participant.",
            "example": false
          },
          "privateNoteViewer": {
            "type": "boolean",
            "description": "True indicates private notes are visible to the appointment participant.",
            "example": false
          },
          "deleted": {
            "type": "boolean",
            "description": "True indicates the participant was removed from the appointment.",
            "example": false
          },
          "status": {
            "$ref": "#/components/schemas/participant-status.json"
          }
        }
      },
      "appointment-status.json": {
        "title": "AppointmentStatus",
        "enum": [
          "ACTIVE",
          "CONFIRMED",
          "CANCELLED",
          "PENDING_APPROVAL",
          "DENIED",
          "PENDING",
          "PENDING_ASSIGNMENT",
          "PENDING_HOST_ASSIGNMENT",
          "PENDING_APPROVAL_AND_ASSIGNMENT",
          "TENTATIVE"
        ],
        "type": "string",
        "description": "Denotes the status of an appointment.",
        "example": "CONFIRMED"
      },
      "appointment-type-category.json": {
        "title": "Appointment Type Category",
        "enum": [
          "CUSTOM_APPOINTMENT",
          "EXHIBITOR_NETWORKING",
          "SELF_SIGN_UP"
        ],
        "type": "string",
        "description": "The category of the appointment type.",
        "example": "CUSTOM_APPOINTMENT"
      },
      "appointment-type.json": {
        "title": "Appointment Type",
        "type": "object",
        "required": [
          "id",
          "name",
          "category",
          "timeRangeType"
        ],
        "description": "This is used for storing details of an appointment type.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The unique ID representing the appointment type.",
            "example": "0046e875-79a5-4851-8332-da105d58088a"
          },
          "name": {
            "type": "string",
            "description": "The name of the appointment type.",
            "example": "Event Appointment"
          },
          "category": {
            "$ref": "#/components/schemas/appointment-type-category.json"
          },
          "timeRangeType": {
            "$ref": "#/components/schemas/time-range-type.json"
          }
        }
      },
      "appointment-types-paginated-response": {
        "title": "Appointment Types Paginated Response",
        "type": "object",
        "description": "The response for a request of appointment types configured for scheduling appointments.",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/appointment-type.json"
            },
            "description": "The collection of appointment types object."
          }
        }
      },
      "appointment-with-questions": {
        "title": "Appointment With Questions",
        "description": "Details of an event appointment including questions.",
        "type": "object",
        "required": [
          "id",
          "name",
          "start",
          "end",
          "type",
          "participant"
        ],
        "allOf": [
          {
            "title": "Appointment",
            "description": "Details of an event appointment.",
            "type": "object",
            "required": [
              "id",
              "name",
              "start",
              "end",
              "type",
              "participant"
            ],
            "allOf": [
              {
                "title": "Appointment Base",
                "description": "Base entity for an appointment",
                "type": "object",
                "required": [
                  "id",
                  "name",
                  "start",
                  "end",
                  "type",
                  "participant"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The unique ID representing the appointment.",
                    "readOnly": true,
                    "example": "0046e875-79a5-4851-8332-da105d58088a"
                  },
                  "code": {
                    "type": "string",
                    "description": "The unique appointment code in Cvent or unique reference id of an appointment in the external systems.",
                    "minLength": 1,
                    "maxLength": 36,
                    "example": "APPT-0001",
                    "pattern": "^[a-zA-Z0-9-.%]+$"
                  },
                  "name": {
                    "type": "string",
                    "description": "The name of the appointment.",
                    "example": "Meeting with Cvent"
                  },
                  "description": {
                    "type": "string",
                    "description": "The description of the appointment.",
                    "example": "Discuss about marketing."
                  },
                  "start": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The ISO 8601 formatted start date/time of the appointment.",
                    "example": "2019-04-12T15:20:00.000Z"
                  },
                  "end": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The ISO 8601 formatted end date/time of the appointment.",
                    "example": "2019-04-12T15:30:00.000Z"
                  },
                  "status": {
                    "$ref": "#/components/schemas/appointment-status.json"
                  },
                  "location": {
                    "type": "object",
                    "description": "The location of the appointment.",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "The name of the location.",
                        "example": "Hynes Convention Center"
                      }
                    }
                  },
                  "type": {
                    "type": "object",
                    "description": "The type of the appointment.",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "The name of the appointment type.",
                        "example": "Customer Meeting"
                      }
                    }
                  }
                }
              },
              {
                "$ref": "#/components/schemas/audit.json"
              }
            ],
            "properties": {
              "appointmentEvent": {
                "$ref": "#/components/schemas/uuid.json"
              },
              "participants": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/appointment-participant.json"
                },
                "description": "Collection of attendees participating in this appointment, and their related details."
              },
              "autoAcceptAttendees": {
                "type": "boolean",
                "description": "True indicates participants will be automatically marked as accepted for the appointment.",
                "example": false
              },
              "enforceScheduleRules": {
                "type": "boolean",
                "description": "True indicates that existing schedule rules were enforced when the appointment was created.",
                "example": false
              },
              "modified": {
                "type": "string",
                "format": "date-time",
                "description": "This field is deprecated please use - lastModified",
                "deprecated": true,
                "example": "2019-04-12T15:30:00.000Z"
              },
              "deleted": {
                "type": "boolean",
                "description": "True indicates the appointment has been logically deleted.",
                "example": false
              }
            }
          }
        ],
        "properties": {
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/custom-field"
            },
            "description": "Collection of custom questions asked to participants of the appointment."
          }
        }
      },
      "asset-location.json": {
        "title": "Asset Location",
        "description": "A URL associated with the asset.",
        "required": [
          "href"
        ],
        "type": "object",
        "properties": {
          "href": {
            "type": "string",
            "description": "A pre-signed URL with an expiration of 2 hours to the asset's location.",
            "example": "https://ap-southeast-2.example.com/sign2-bucket-hchq3nwuo8ns/sign-demo.json?X-Exa-Date=20170125T044127Z&X-Exa-Expires=60&X-Exa-Signature=24db05",
            "readOnly": true
          }
        }
      },
      "associated-registration-path.json": {
        "title": "AssociatedRegistrationPath",
        "description": "Represents the details of a registration path.",
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "A unique identifier of the registration path.",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          }
        }
      },
      "attachment.json1": {
        "title": "Attachment",
        "description": "A message attachment.",
        "type": "object",
        "required": [
          "link"
        ],
        "properties": {
          "link": {
            "description": "A link to the attachment allowing it to be downloaded",
            "type": "string",
            "format": "uri",
            "example": "https://foo.com/a/picture/of/a/cat.jpg"
          }
        }
      },
      "attempt.json": {
        "title": "Survey Attempt",
        "type": "integer",
        "format": "int32",
        "example": 2,
        "description": "Counts the number of times a respondent has attempted the survey and answered the question."
      },
      "attendee": {
        "title": "Attendee",
        "description": "An event attendee.",
        "type": "object",
        "x-extends": {
          "$ref": "#/components/schemas/audit.json"
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/audit.json"
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The ID of attendee in the given event."
          },
          "event": {
            "description": "The attendee's associated event.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The event ID."
              }
            }
          },
          "confirmationNumber": {
            "type": "string",
            "description": "The confirmation number is a code unique to each attendee. Cvent assigns one to the attendee upon registration for the event. Serves as proof of registration.",
            "maxLength": 18,
            "example": "VNNDLJ6DKVK"
          },
          "contact": {
            "$ref": "#/components/schemas/attendee-contact-info.json"
          },
          "checkedIn": {
            "type": "boolean",
            "description": "True indicates the attendee checked in to the event.",
            "maxLength": 18,
            "example": true
          },
          "checkin": {
            "type": "string",
            "format": "date-time",
            "description": "The date time when attendee was checked in to an event. Note: this field is deprecated. Please use the `checkIn` field instead.",
            "example": "2018-01-13T02:00:00Z",
            "deprecated": true
          },
          "checkIn": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when attendee was checked in to an event.",
            "example": "2018-01-13T02:00:00Z"
          },
          "checkOut": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when attendee checked out from an event.",
            "example": "2018-01-13T02:00:00Z"
          },
          "duration": {
            "type": "integer",
            "description": "The duration, in milliseconds, the attendee was present at the event.",
            "example": 4000
          },
          "registrationPath": {
            "$ref": "#/components/schemas/lookup.json"
          },
          "invitationList": {
            "$ref": "#/components/schemas/id-name.json"
          },
          "webLinks": {
            "$ref": "#/components/schemas/attendee-web-links.json"
          },
          "registrationType": {
            "$ref": "#/components/schemas/lookup.json"
          },
          "referenceId": {
            "type": "string",
            "description": "The reference ID of an attendee. A planner determined string used to track which link attendee's used to reach the event registration.",
            "maxLength": 100,
            "example": "refid-plannerside"
          },
          "externalReferences": {
            "type": "array",
            "description": "The details of an attendee in an external systems.",
            "items": {
              "$ref": "#/components/schemas/external-reference.json"
            }
          },
          "note": {
            "type": "string",
            "description": "A planner created note for an attendee, used to track details about the attendee.",
            "maxLength": 300,
            "example": "Would like to sit near the front of the room for sessions."
          },
          "guest": {
            "type": "boolean",
            "description": "True indicates the attendee is a guest of another attendee.",
            "example": true
          },
          "deletedGuest": {
            "type": "boolean",
            "description": "True indicates this attendee is a deleted guest.",
            "example": false,
            "readOnly": true
          },
          "primaryId": {
            "type": "string",
            "format": "uuid",
            "description": "The ID of the primary attendee to whom this guest attendee is associated. Only applicable if this attendee is a guest."
          },
          "group": {
            "$ref": "#/components/schemas/attendee-group.json"
          },
          "administrator": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "unsubscribed": {
            "type": "boolean",
            "description": "True indicates this attendee is unsubscribed from this event's emails. They'll still recieve emails triggered by their own actions (like registration modification).",
            "example": false
          },
          "status": {
            "$ref": "#/components/schemas/attendee-status.json"
          },
          "registeredAt": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when attendee was registered.",
            "example": "2018-01-13T02:00:00Z"
          },
          "registrationLastModified": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when attendee's registration was modified. This field is updated when there are changes to the registration, such as adding or removing products.",
            "example": "2018-01-13T02:00:00Z"
          },
          "registrationCancelledAt": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when attendee registration was cancelled.",
            "example": "2018-01-13T02:00:00Z"
          },
          "invitedBy": {
            "$ref": "#/components/schemas/attendee-invited-by.json"
          },
          "responseMethod": {
            "$ref": "#/components/schemas/attendee-response-method.json"
          },
          "questions": {
            "type": "array",
            "deprecated": true,
            "items": {
              "$ref": "#/components/schemas/custom-field.json3"
            },
            "description": "A list of answers to contact custom fields. Note: This field is deprecated. Answers to custom contact fields can be found in the 'contact' model, `customFields` field instead."
          },
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/attendee-answer.json"
            },
            "description": "The list of answers to the registration questions.",
            "readOnly": true
          },
          "admissionItem": {
            "description": "Contains details related to the attendee's admission item.",
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/lookup.json"
              },
              {
                "description": "Contains details related to the attendee's admission item."
              }
            ]
          },
          "visibility": {
            "$ref": "#/components/schemas/attendee-visibility.json"
          },
          "bio": {
            "type": "string",
            "description": "The attendee's biographical writeup.",
            "maxLength": 2500,
            "example": "In west Philadelphia, born and raised, on the playground is where I spent most of my days."
          },
          "showPopupNotification": {
            "deprecated": true,
            "type": "boolean",
            "description": "Notification setting in the Attendee Hub app or website. Note: This field is deprecated. Use `allowPushNotification` field instead.",
            "example": false
          },
          "websiteUrl": {
            "type": "string",
            "description": "An attendee's website URL, appears on their profile.",
            "format": "uri",
            "example": "https://www.example.com",
            "readOnly": true
          },
          "allowPushNotifications": {
            "type": "boolean",
            "description": "True indicates attendee will recieve push notifications for session-schedule changes, promotions and other event activities in the Attendee Hub app.",
            "example": false,
            "readOnly": true
          },
          "allowAppointmentPushNotifications": {
            "type": "boolean",
            "description": "True indicaites attendee will recieve push notifications for appointments related activities in the Attendee Hub app.",
            "example": false,
            "readOnly": true
          },
          "testRecord": {
            "type": "boolean",
            "description": "True indicates this attendee record was created as part of a test scenario.",
            "example": false,
            "readOnly": true
          },
          "attendeeLastModified": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date-time indicates when the attendee's non-contact properties were modified. Updates to the attendee's contact properties do not update this field. This field is updated when planners or attendees make changes to the attendee record, such as flagging as a participant. It is not updated for registration or product changes.",
            "example": "2018-01-13T02:00:00Z"
          },
          "appointmentGroups": {
            "type": "array",
            "description": "List of appointment groups associated with attendee. These control permissions and visibility in appointments associated with the event.",
            "minItems": 0,
            "maxItems": 20,
            "items": {
              "$ref": "#/components/schemas/appointment-group.json"
            },
            "readOnly": true
          },
          "credit": {
            "description": "The amount of credit associated with the attendee.",
            "type": "number",
            "example": 10
          }
        }
      },
      "attendee-activities-paginated-response": {
        "title": "AttendeeActivitiesPaginatedResponse",
        "description": "The response from a request to get the list of attendee activities. This includes the paging object as well as the collection of attendee activities.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/activity.json"
            },
            "description": "Collection of attendee activities."
          }
        }
      },
      "attendee-add-bulk": {
        "title": "AttendeeAddBulk",
        "description": "List of attendees to add.",
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/attendee-add.json"
        }
      },
      "attendee-add-bulk-item": {
        "title": "AttendeeInvitesBulkResponseItem",
        "description": "This entity is used to represent a single item that is returned as part of a bulk request call.",
        "allOf": [
          {
            "title": "BulkResponseItem",
            "description": "Represents a single item that is returned as part of a Bulk request call.",
            "type": "object",
            "required": [
              "status",
              "data"
            ],
            "properties": {
              "data": {
                "type": "object",
                "description": "The data returned for a single item in the bulk request call.",
                "example": {
                  "event_id": 1234,
                  "attendee_count": 50
                },
                "additionalProperties": true
              },
              "status": {
                "type": "integer",
                "description": "http status code representing processing status of a single item",
                "example": 400
              },
              "message": {
                "type": "string",
                "description": "Quick description of what happened with processing",
                "example": "Example error message."
              },
              "request": {
                "type": "object",
                "description": "The processed request tied to this response. This field is only sent when processing fails.",
                "example": {
                  "operation": "PUT",
                  "headers": {
                    "header1": "header1Value",
                    "header2": "header2Value"
                  },
                  "queryParams": {
                    "param1": "param1Value",
                    "param2": "param2Value"
                  }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        ],
        "properties": {
          "data": {
            "title": "Attendees",
            "oneOf": [
              {
                "title": "AttendeeAddResponse",
                "description": "AttendeeAddResponse",
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The unique id representing an attendee.",
                    "example": "a96e7faa-b23e-49de-9040-c908473ba7ac"
                  }
                }
              },
              {
                "title": "ErrorResponse",
                "description": "Represents an error response with additional details of cascading error messages.",
                "allOf": [
                  {
                    "title": "ErrorResponseBase",
                    "type": "object",
                    "description": "Represents an error response with no additional details.",
                    "required": [
                      "code",
                      "message"
                    ],
                    "properties": {
                      "code": {
                        "type": "integer",
                        "description": "The HTTP status code representing the error.",
                        "example": 400
                      },
                      "message": {
                        "type": "string",
                        "description": "A brief description of the error.",
                        "example": "Bad Request"
                      },
                      "target": {
                        "type": "string",
                        "description": "The target resource of the error.",
                        "example": "example target"
                      }
                    }
                  }
                ],
                "type": "object",
                "required": [
                  "code",
                  "message"
                ],
                "properties": {
                  "details": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/attendee-add-bulk-item/properties/data/oneOf/1/allOf/0"
                    },
                    "description": "Additional details of cascading error messages."
                  }
                }
              }
            ]
          }
        }
      },
