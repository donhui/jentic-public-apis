      "sleeping-room-block.json": {
        "type": "object",
        "title": "SleepingRoomBlock",
        "description": "The sleeping room block.",
        "properties": {
          "proposalDateType": {
            "$ref": "#/components/schemas/date-type.json1"
          },
          "sleepingRoomType": {
            "$ref": "#/components/schemas/sleeping-room-type.json"
          },
          "date": {
            "type": "string",
            "format": "date",
