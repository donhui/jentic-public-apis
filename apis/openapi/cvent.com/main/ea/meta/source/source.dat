      "hook": {
        "title": "Hook",
        "description": "A hook with a callback URI.",
        "type": "object",
        "required": [
          "name",
          "callback",
          "security"
        ],
        "allOf": [
          {
            "title": "Audit",
            "description": "Audit information",
            "type": "object",
            "properties": {
              "created": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was created.",
                "readOnly": true,
                "example": "2017-01-02T02:00:00Z"
              },
              "createdBy": {
                "type": "string",
                "description": "The identifier of the user that created this record.",
                "readOnly": true,
                "example": "hporter"
              },
              "lastModified": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was updated.",
                "readOnly": true,
                "example": "2019-02-12T03:00:00Z"
              },
              "lastModifiedBy": {
                "type": "string",
                "description": "The identifier of the user that last updated this record.",
                "readOnly": true,
                "example": "hporter"
              }
            }
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique ID representing the hook",
            "format": "uuid",
            "readOnly": true,
            "example": "3b2359a7-4583-40ed-8afd-67e5f15373d3"
          },
          "name": {
            "type": "string",
            "description": "Name of the contact hook.",
            "example": "Attendee Identification",
            "minLength": 1,
            "maxLength": 100
          },
          "callback": {
            "type": "string",
            "format": "uri",
            "description": "A client hosted callback URI to which callback would be invoked. TLS is mandatory. Callback URL should not contain any confidential information such as API keys or login credentials.",
            "example": "https://myserver.com/send/callback/here",
            "minLength": 1,
            "maxLength": 300
          },
          "security": {
            "$ref": "#/components/schemas/hook-security.json"
          }
        }
      },
      "hook-security.json": {
        "title": "Hook Security",
        "description": "Describe security for a web hook callback. Each option corresponds to an Authorization header variant.",
        "type": "object",
        "oneOf": [
          {
            "title": "API Key Authentication",
            "description": "API Key Authentication.",
            "type": "object",
            "required": [
              "secret"
            ],
            "allOf": [
              {
                "title": "Authorization Header",
                "description": "Authorization header support characterizing the authentication type to be used for callbacks to the client system.",
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "apiKey",
                      "basic"
                    ],
                    "title": "Authorization Header Type",
                    "description": "Authorization header support characterizing the authentication type to be used for callbacks to the client system. API Key, or HTTP Basic Authentication, each configured with a corresponding option.",
                    "example": "apiKey"
                  }
                }
              }
            ],
            "properties": {
              "secret": {
                "type": "string",
                "title": "API Key Value",
                "description": "An API key to be included in callback requests.",
                "writeOnly": true,
                "example": "2b3cc2bf083ff11206ce6b2f3ee09591",
                "maxLength": 300
              },
              "authHeaderKey": {
                "type": "string",
                "title": "Authorization Header Key",
                "description": "The header key for which API Key will be sent in callback requests. If this field is not set, the API key is sent in the 'Authorization' header.",
                "example": "x-api-key",
                "minLength": 1,
                "default": "Authorization"
              },
              "apiKeyPrefix": {
                "type": "boolean",
                "title": "API Key Prefix",
                "description": "Whether API Key Value is prefixed by 'api_key'. When set to true, the authorization header's value in callback requests will be 'api_key 2b3cc2bf083ff11206ce6b2f3ee09591'",
                "example": true,
                "default": true
              }
            }
          },
          {
            "title": "Basic Authentication",
            "description": "HTTP Basic Authentication via Authorization header.",
            "type": "object",
            "required": [
              "secret"
            ],
            "allOf": [
              {
                "$ref": "#/components/schemas/hook-security.json/oneOf/0/allOf/0"
              }
            ],
            "properties": {
              "secret": {
                "type": "string",
                "title": "Basic Auth Credentials",
                "description": "Base64 encoded Basic Authentication credentials.",
                "writeOnly": true,
                "example": "ZGVtbzpwQDU1dzByZA==",
                "maxLength": 300
              }
            }
          }
        ]
      },
      "hooks-paginated-response": {
        "title": "HooksPaginatedResponse",
        "description": "The response from a request to get the list of hooks with a callback URI. This includes the paging object as well as the collection of hooks.",
        "type": "object",
        "required": [
          "paging",
          "data"
        ],
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/hook"
            },
            "description": "Collection of contact hooks."
          }
        }
      },
      "hotel-address.json": {
        "title": "Address",
        "description": "Address of the hotel.",
        "type": "object",
        "allOf": [
          {
            "title": "Base Address",
            "description": "Base Address Model",
            "type": "object",
            "properties": {
              "address1": {
                "type": "string",
                "maxLength": 40,
                "description": "The first line of an address.",
                "example": "Cvent Inc."
              },
              "address2": {
                "type": "string",
                "maxLength": 40,
                "description": "The second line of an address.",
                "example": "4001 West Parmer Lane"
              },
              "address3": {
                "type": "string",
                "maxLength": 40,
                "description": "The third line of an address.",
                "example": "PO Box 123"
              },
              "city": {
                "type": "string",
                "maxLength": 40,
                "description": "The name of the city.",
                "example": "Austin"
              },
              "countryCode": {
                "type": "string",
                "maxLength": 3,
                "minLength": 2,
                "description": "ISO 3166 two-letter (alpha-2) country code.",
                "example": "US"
              },
              "postalCode": {
                "type": "string",
                "maxLength": 25,
                "description": "Postal code (also known as zipcode) of the address.",
                "example": "78727"
              }
            }
          }
        ],
        "properties": {
          "region": {
            "type": "string",
            "description": "The name of the state/province/region of the address.",
            "readOnly": true,
            "example": "Texas"
          },
          "regionCode": {
            "type": "string",
            "description": "The abbreviation of the state/province/region of the address.",
            "minLength": 2,
            "maxLength": 10,
            "example": "TX"
          },
          "country": {
            "type": "string",
            "description": "Name of the country.",
            "readOnly": true,
            "example": "United States of America"
          }
        }
      },
      "hotel-id.json": {
        "type": "object",
        "title": "HotelId",
        "description": "Contains unique ID of the hotel.",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "description": "The unique ID of the hotel.",
            "type": "integer",
            "example": 49543342
          }
        }
      },
      "hotel-info.json": {
        "title": "HotelInfo",
        "type": "object",
        "description": "Hotel information.",
        "readOnly": true,
        "allOf": [
          {
            "$ref": "#/components/schemas/hotel-id.json"
          }
        ],
        "properties": {
          "name": {
            "description": "Hotel name.",
            "type": "string",
            "example": "Northern Hotel"
          }
        }
      },
      "hotel-rating.json": {
        "description": "The hotel's rating, used to classify the hotel's quality.",
        "title": "HotelRating",
        "type": "string",
        "enum": [
          "N/A",
          "Budget",
          "1 Star",
          "2 Star",
          "3 Star",
          "4 Star",
          "5 Star"
        ],
        "example": "3 Star"
      },
      "hotel-request.json": {
        "title": "HotelRequest",
        "description": "Representation of a hotel request.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/alternate-travel-detail.json/allOf/0"
          }
        ],
        "properties": {
          "hotelRequestId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the hotel request.",
            "example": "3b2359a7-4583-40ed-8afd-67e5f15373d3"
          },
          "requesterId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the flight requester. For an event attendee, this field is contact ID. For guest, this field is guest ID.",
            "example": "3b2359a7-4583-40ed-8afd-67e5f15373d3"
          },
          "requesterType": {
            "type": "string",
            "description": "Attendee type of the hotel requester. Contact means the requester is an independent attendee. Guest means the attendee is accompanying another attendee.",
            "enum": [
              "Contact",
              "Guest"
            ],
            "example": "Contact"
          },
          "requesterFirstName": {
            "type": "string",
            "description": "First name of the hotel requester.",
            "example": "John",
            "maxLength": 30
          },
          "requesterLastName": {
            "type": "string",
            "description": "Last name of the hotel requester.",
            "example": "Doe",
            "maxLength": 50
          },
          "hotelName": {
            "type": "string",
            "description": "Name of the hotel.",
            "example": "Fairmont Chicago",
            "maxLength": 100
          },
          "hotelCode": {
            "type": "string",
            "description": "Code of the hotel.",
            "example": "6BNMSHJFSRP",
            "maxLength": 30
          },
          "roomName": {
            "type": "string",
            "description": "Name of the room.",
            "example": "Deluxe Room",
            "maxLength": 50
          },
          "roomCode": {
            "type": "string",
            "description": "Code of the room.",
            "example": "6BNMSHJFSR",
            "maxLength": 10
          },
          "quantity": {
            "type": "integer",
            "description": "Number of hotel requests made by requester.",
            "example": 1
          },
          "roommateRequested": {
            "type": "string",
            "description": "Name of the roommate requested by requester.",
            "example": "Will Doe"
          },
          "specialRequest": {
            "type": "string",
            "description": "Any special requests the requester asks of the hotel.",
            "maxLength": 300,
            "example": "Please provide early check-in."
          },
          "rewardsCode": {
            "type": "string",
            "description": "Requesters' reward code for the hotel's loyalty program.",
            "example": "ROYALTY",
            "maxLength": 50
          },
          "checkinDate": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time (in UTC) when the guest will check in to the hotel.",
            "example": "2023-05-19T00:00:00"
          },
          "checkoutDate": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time (in UTC) when the guest will check out of the hotel.",
            "example": "2023-05-20T00:00:00"
          },
          "smoking": {
            "type": "boolean",
            "description": "True indicates smoking should be allowed in the room."
          },
          "cancelled": {
            "type": "boolean",
            "description": "True indicates this hotel request is cancelled."
          },
          "status": {
            "$ref": "#/components/schemas/travel-request-status.json"
          },
          "confirmationNumber": {
            "type": "string",
            "description": "The hotel's confirmation number.",
            "example": "CONFIRM_123"
          },
          "isADAAccessible": {
            "type": "boolean",
            "description": "True indicate the room should meet the Americans with Disabilities Act (ADA) accessibility requirements."
          },
          "shareRoom": {
            "type": "boolean",
            "description": "True indicates the requester wants a roommate."
          },
          "roommateLeader": {
            "type": "boolean",
            "description": "True indicates the requester is the roommate in charge of the room."
          },
          "gender": {
            "$ref": "#/components/schemas/gender.json1"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total cost of the hotel stay.",
            "example": 500
          },
          "currencyCode": {
            "type": "string",
            "description": "ISO 4217 currency code for the cost of the hotel stay.",
            "example": "USD",
            "maxLength": 3
          },
          "roomCharge": {
            "type": "boolean",
            "description": "Specifies if the planner will charge for the hotel."
          },
          "roomTaxBillingInstructions": {
            "type": "string",
            "description": "Specifies who the hotel will charge for the room rate's tax.",
            "example": "tax instructions"
          },
          "incidentalBillingInstructions": {
            "type": "string",
            "description": "Specifies who the hotel will charge incidental (extra) room expenses, like room service or long-distance calling.",
            "example": "billing instructions"
          },
          "plannerMemo": {
            "type": "string",
            "description": "Additional note by, or intended for, event planners.",
            "maxLength": 300,
            "example": "Planner's notes here."
          },
          "earliestShoulderDate": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time (in UTC) when the requester is requesting for an earliest shoulder date.",
            "example": "2023-05-19T00:00:00"
          },
          "latestShoulderDate": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time (in UTC) when the requester is requesting for an latest shoulder date.",
            "example": "2023-05-19T00:00:00"
          },
          "roomTaxBillingExceptions": {
            "type": "string",
            "description": "Specifies who the hotel will charge for the room rate's tax.",
            "example": "exceptions noted here."
          },
          "incidentalBillingExceptions": {
            "type": "string",
            "description": "Specifies who the hotel will charge incidental (extra) room expenses, like room service or long-distance calling.",
            "example": "exceptions noted here."
          },
          "hotelAddress": {
            "$ref": "#/components/schemas/hotel-address.json"
          },
          "hotelRoomRates": {
            "type": "array",
            "description": "Collection of hotel room rates the requester has taken.",
            "items": {
              "$ref": "#/components/schemas/hotel-room-rate.json"
            }
          },
          "hotelRequestAnswers": {
            "type": "array",
            "description": "Answer provided by requester to the hotel request related question.",
            "items": {
              "$ref": "#/components/schemas/attendee-answer.json1"
            }
          }
        }
      },
      "hotel-reservation-detail": {
        "title": "HotelReservationPaginatedResponse",
        "description": "The response from a request to get the list of hotel reservation for the attendees.  This includes the paging object as well as the collection of air actual details.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/hotel-reservation-detail.json"
            },
            "description": "Collection of hotel reservation for attendees."
          }
        }
      },
      "hotel-reservation-detail.json": {
        "title": "HotelReservationDetail",
        "description": "Representation of a hotel reservation detail response.",
        "type": "object",
        "properties": {
          "attendee": {
            "$ref": "#/components/schemas/attendee.json4"
          },
          "hotelRequestDetails": {
            "description": "List of all the hotel requests by attendee and its guest.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/hotel-request.json"
            }
          }
        }
      },
      "hotel-room-rate.json": {
        "title": "HotelRoomRate",
        "description": "Representation of a hotel room rate",
        "type": "object",
        "properties": {
          "roomNight": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 date-time (in UTC) of the night for which the room has been booked.",
            "example": "2023-05-19T00:00:00"
          },
          "roomRate": {
            "type": "number",
            "description": "The nightly rate at which the room has been booked.",
            "example": 100
          }
        }
      },
      "HotelRoomRatesRequest": {
        "description": "Represents hotel room rates request.",
        "title": "HotelRoomRatesRequest",
        "type": "object",
        "required": [
          "startDate",
          "endDate",
          "roomRate"
        ],
        "properties": {
          "rateCode": {
            "type": "string",
            "description": "The rate code.",
            "example": "VIPRATE"
          },
          "startDate": {
            "description": "The start of the date range the rate applies. Date is in ISO 8601 format.",
            "type": "string",
            "example": "2025-03-25",
            "format": "date"
          },
          "endDate": {
            "description": "The end of the date range the rate applies. Date is in ISO 8601 format.",
            "type": "string",
            "example": "2025-03-25",
            "format": "date"
          },
          "roomRate": {
            "description": "Cost of room per night.",
            "type": "number",
            "example": 150
          },
          "currencyCode": {
            "$ref": "#/components/schemas/currency.json"
          }
        }
      },
      "HotelRoomRatesResponse": {
        "description": "Represents hotel room rates response.",
        "title": "HotelRoomRatesResponse",
        "type": "object",
        "required": [
          "hotelCode",
          "roomCode",
          "startDate",
          "endDate",
          "roomRate",
          "currencyCode"
        ],
        "allOf": [
          {
            "description": "Represents hotel room rates request.",
            "title": "HotelRoomRatesRequest",
            "type": "object",
            "required": [
              "startDate",
              "endDate",
              "roomRate"
            ],
            "properties": {
              "rateCode": {
                "type": "string",
                "description": "The rate code.",
                "example": "VIPRATE"
              },
              "startDate": {
                "description": "The start of the date range the rate applies. Date is in ISO 8601 format.",
                "type": "string",
                "example": "2025-03-25",
                "format": "date"
              },
              "endDate": {
                "description": "The end of the date range the rate applies. Date is in ISO 8601 format.",
                "type": "string",
                "example": "2025-03-25",
                "format": "date"
              },
              "roomRate": {
                "description": "Cost of room per night.",
                "type": "number",
                "example": 150
              },
              "currencyCode": {
                "$ref": "#/components/schemas/currency.json"
              }
            }
          }
        ],
        "properties": {
          "hotelCode": {
            "type": "string",
            "description": "The hotel code.",
            "example": "HOTELCODE"
          },
          "roomCode": {
            "type": "string",
            "description": "The room code.",
            "example": "VLR"
          }
        }
      },
      "housing-event": {
        "type": "object",
        "title": "HousingEvent",
        "description": "Information about housing event.",
        "allOf": [
          {
            "type": "object",
            "title": "HousingEventSummary",
            "description": "Information about housing event with key information, providing a summarized view.",
            "required": [
              "id",
              "name",
              "start",
              "end",
              "cutOff",
              "timeZone",
              "venue",
              "status"
            ],
            "properties": {
              "id": {
                "description": "The unique ID of the housing event.",
                "type": "integer",
                "example": 21738574
              },
              "name": {
                "description": "Event name.",
                "type": "string",
                "example": "Summit 2027"
              },
              "start": {
                "description": "The ISO 8601 formatted date and time of the first attended day of the event, excluding shoulder days.",
                "type": "string",
                "example": "2027-01-13T05:00:00Z",
                "format": "date-time"
              },
              "end": {
                "description": "The ISO 8601 date and time of the last attended day of the event, excluding shoulder days.",
                "type": "string",
                "example": "2027-01-15T05:00:00Z",
                "format": "date-time"
              },
              "cutOff": {
                "description": "The ISO 8601 formatted date and time of a contractually agreed date which triggers configurable business rules, like releasing reserved room blocks back to general availability.",
                "type": "string",
                "example": "2026-10-13T04:00:00Z",
                "format": "date-time"
              },
              "timeZone": {
                "description": "The event timezone from the Olson specification.",
                "type": "string",
                "example": "America/New_York",
                "maxLength": 29
              },
              "venue": {
                "$ref": "#/components/schemas/venue.json1"
              },
              "status": {
                "$ref": "#/components/schemas/housing-event-statuses.json"
              }
            }
          }
        ],
        "required": [
          "id",
          "name",
          "start",
          "end",
          "resOpen",
          "resClose",
          "webResOpen",
          "webResClose",
          "cutOff",
          "timeZone",
          "defaultLocale",
          "locales",
          "image",
          "venue",
          "reservationContact",
          "attendeeTypes",
          "planners",
          "status",
          "currency"
        ],
        "properties": {
          "launchAfter": {
            "description": "The ISO 8601 formatted date and time when event will launch.",
            "type": "string",
            "example": "2027-01-12T05:00:00Z",
            "format": "date-time"
          },
          "closeAfter": {
            "description": "The ISO 8601 formatted date and time, after which no reservation can be made.",
            "type": "string",
            "example": "2027-02-16T05:00:00Z",
            "format": "date-time"
          },
          "webLaunchAfter": {
            "description": "The ISO 8601 formatted date and time when event will be available for reservations through website.",
            "type": "string",
            "example": "2026-01-13T05:00:00Z",
            "format": "date-time"
          },
          "webCloseAfter": {
            "description": "The ISO 8601 formatted date and time after which no website reservation can be made.",
            "type": "string",
            "example": "2026-12-13T05:00:00Z",
            "format": "date-time"
          },
          "defaultLocale": {
            "$ref": "#/components/schemas/locale.json-01"
          },
          "locales": {
            "description": "List of event locales.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/locale.json-01"
            }
          },
          "image": {
            "description": "Event image URL.",
            "type": "string",
            "format": "uri",
            "example": "https://example.com/content/example.jpg"
          },
          "reservationContact": {
            "$ref": "#/components/schemas/reservation-contact.json"
          },
          "attendeeTypes": {
            "description": "List of attendee types for this event.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/attendee-type.json"
            }
          },
          "planners": {
            "description": "A collection of event planners for this housing event.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/planner.json1"
            }
          },
          "currency": {
            "$ref": "#/components/schemas/currency.json2"
          },
          "roomsSortType": {
            "$ref": "#/components/schemas/rooms-sort-type.json"
          }
        }
      },
      "housing-event-hotel": {
        "type": "object",
        "title": "HotelDetails",
        "description": "Hotel details including name, description, policies and IDs.",
        "required": [
          "id",
          "housingEvent",
          "name",
          "description"
        ],
        "properties": {
