          "EVENT_CANCELLED",
          "REQUIREMENTS_CHANGED",
          "OTHER",
          "BOOKED_ANOTHER_VENUE_DESTINATION",
          "CLIENT_BOOKED_DIRECTLY",
          "EVENT_POSTPONED",
          "MEDICAL_EMERGENCY",
          "EPIDEMIC_OR_PANDEMIC",
          "NATURAL_DISASTER",
          "POLITICAL_OR_CIVIL_UNREST"
        ]
