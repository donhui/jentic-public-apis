          "DANKORT",
          "DINERS_CLUB",
          "DIRECT_BILL",
          "DISCOVER",
          "EUROCARD_MASTERCARD",
          "INVOICE",
          "JCB",
          "LASER",
          "MAESTRO",
          "MAESTROUK",
          "MASTERCARD",
          "MASTERCARD_DEBIT",
          "MONEY_ORDER",
          "NETRESERVE",
          "OTHER",
          "OTHER_2",
          "OTHER_3",
          "PAY_GOV",
          "PAYMENT_CREDITS",
          "PAYPAL",
          "P_CARD",
