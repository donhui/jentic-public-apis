            "$ref": "#/components/schemas/salesforce-account-id.json"
          },
          "name": {
            "type": "string",
            "description": "The name of this organization.",
            "minLength": 1,
            "maxLength": 255,
            "example": "Cvent"
          },
          "url": {
            "type": "string",
            "description": "The Url to this organization's website.",
            "format": "uri",
            "maxLength": 255,
            "default": "",
            "example": "https://www.cvent.com"
          },
          "note": {
            "type": "string",
            "description": "Additional details about this organization.",
            "maxLength": 1000,
            "default": "",
            "example": "Additional details about this organization."
          }
        }
      },
