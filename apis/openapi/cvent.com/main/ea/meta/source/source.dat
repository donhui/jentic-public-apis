                  "Work"
                ],
                "type": "string",
                "description": "The type of address.",
                "example": "Home"
              }
            ]
          },
          "homeAddress": {
            "type": "object",
            "deprecated": true,
            "allOf": [
              {
                "title": "Address",
                "description": "Address details",
                "type": "object",
