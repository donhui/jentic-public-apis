            "$ref": "#/components/schemas/organization-id.json"
          },
          "stub": {
            "type": "string",
            "format": "uuid",
            "allOf": [
              {
                "title": "Organization Stub",
                "type": "string",
                "description": "The unique identifier which represents this organization for a specific region.",
                "format": "uuid"
              },
              {
                "readOnly": true
              }
            ]
          },
