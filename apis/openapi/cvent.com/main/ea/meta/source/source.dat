    "/program-items": {
      "post": {
        "security": [
          {
            "OAuth2.clientCredentials": [
              "event/program-items:write"
            ]
          },
          {
            "OAuth2.authorizationCode": [
              "event/program-items:write"
            ]
          }
        ],
        "summary": "Create Program Item",
        "description": "Create a session program item based on the details provided in the body of the request. A session program item is a specific part of a session's schedule, like a talk, workshop, or panel discussion. Max 25 program items per session.",
        "operationId": "createProgramItem",
        "tags": [
          "Sessions"
        ],
        "requestBody": {
          "description": "Session program item to be created.",
          "required": true,
          "content": {
