      "phone-number.json1": {
        "title": "Phone Number",
        "description": "Phone Number",
        "type": "object",
        "required": [
          "type",
          "value"
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/phone-type.json"
          },
          "value": {
            "type": "string",
