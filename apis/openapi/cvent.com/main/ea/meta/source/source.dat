      "email.json1": {
        "title": "Email",
        "description": "Email",
        "type": "object",
        "required": [
          "value",
          "type",
          "primary"
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/email-type.json1"
          },
          "value": {
            "type": "string",
            "description": "The email of the user.",
            "example": "support@cvent.com",
            "minLength": 1,
            "maxLength": 80
          },
          "primary": {
            "type": "boolean",
            "description": "True indicates the email is primary.",
            "example": true,
            "default": false
          }
        }
      },
      "email.json2": {
        "title": "Email",
        "description": "Details of an email to be send.",
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "a150f1ee-6c54-4b01-90e6-d701748f0851",
            "description": "The unique ID of the email to be sent."
          }
        }
      },
      "encoding-profile.json": {
        "title": "EncodingProfile",
        "enum": [
          "Planner",
          "Attendee"
        ],
        "type": "string",
        "description": "Denotes the profile to use when encoding the video. Planner profile is for encoding high-quality event content, like session videos. Attendee profile is for encoding lower-quality content intended to go on attendee profiles and social feeds in the event.",
        "example": "Planner",
        "default": "Planner"
      },
      "error-response": {
        "title": "ErrorResponse",
        "description": "Represents an error response with additional details of cascading error messages.",
        "allOf": [
          {
            "title": "ErrorResponseBase",
            "type": "object",
            "description": "Represents an error response with no additional details.",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "integer",
                "description": "The HTTP status code representing the error.",
                "example": 400
              },
              "message": {
                "type": "string",
                "description": "A brief description of the error.",
                "example": "Bad Request"
              },
              "target": {
                "type": "string",
                "description": "The target resource of the error.",
                "example": "example target"
              }
            }
          }
        ],
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/error-response/allOf/0"
            },
            "description": "Additional details of cascading error messages."
          }
        }
      },
      "error-response.json20": {
        "title": "ErrorResponse",
        "description": "The error response.",
        "type": "object",
        "required": [
          "status",
          "detail"
        ],
        "properties": {
          "schemas": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "urn:ietf:params:scim:api:messages:2.0:Error"
            },
            "description": "The collection of error schemas."
          },
          "status": {
            "type": "integer",
            "example": 400,
            "description": "Status code for error."
          },
          "detail": {
            "type": "string",
            "example": "Request is unparsable, syntactically incorrect, or violates schema.",
            "description": "Details of the error."
          },
          "scimType": {
            "$ref": "#/components/schemas/error-scim-type.json"
          }
        }
      },
      "error-scim-type.json": {
        "title": "ErrorScimType",
        "description": "This is used to denote the scim type of the error.",
        "enum": [
          "invalidFilter",
          "uniqueness",
          "invalidSyntax",
          "invalidValue"
        ],
        "type": "string",
        "example": "invalidSyntax"
      },
      "ErrorResponse": {
        "title": "ErrorResponse",
        "description": "Represents an error response with additional details of cascading error messages.",
        "allOf": [
          {
            "title": "ErrorResponseBase",
            "type": "object",
            "description": "Represents an error response with no additional details.",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "integer",
                "description": "The HTTP status code representing the error.",
                "example": 400
              },
              "message": {
                "type": "string",
                "description": "A brief description of the error.",
                "example": "Bad Request"
              },
              "target": {
                "type": "string",
                "description": "The target resource of the error.",
                "example": "example target"
              }
            }
          }
        ],
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ErrorResponse/allOf/0"
            },
            "description": "Additional details of cascading error messages."
          }
        }
      },
      "estimated-cost.json": {
        "type": "object",
        "title": "EstimatedCost",
        "description": "The estimated cost",
        "properties": {
          "guestRoom": {
            "type": "number",
            "description": "Guest room cost.",
            "example": 100
          },
          "meetingRoom": {
            "type": "number",
            "description": "Meeting room cost.",
            "example": 10
          },
          "foodAndBeverage": {
            "type": "number",
            "description": "Food and beverage cost.",
            "example": 100
          },
          "foodAndBeverageMinimum": {
            "type": "number",
            "description": "Minimum cost for food and beverage.",
            "example": 10
          },
          "notes": {
            "type": "string",
            "maxLength": 2500,
            "description": "Extra notes on the cost.",
            "example": "Estimated cost includes taxes."
          }
        }
      },
      "evaluation-result.json": {
        "title": "Evaluation Result",
        "enum": [
          "Passed",
          "Failed",
          "Unevaluated"
        ],
        "type": "string",
        "description": "This represents the evaluation status of an assessment chapter.",
        "example": "Passed",
        "readOnly": true
      },
      "event": {
        "title": "Event",
        "description": "Represents an event.",
        "type": "object",
        "required": [
          "title",
          "format",
          "planners",
          "timezone",
          "languages",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The identifier of the event.",
            "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
            "readOnly": true
          },
          "title": {
            "type": "string",
            "description": "Title of the event being organized.",
            "maxLength": 300,
            "example": "Cvent Connect 2020"
          },
          "code": {
            "type": "string",
            "description": "A system-generated code for this event.",
            "maxLength": 18,
            "readOnly": true,
            "example": "R5NP4NJYB3D"
          },
          "virtual": {
            "type": "boolean",
            "description": "True indicates the event is virtual. DEPRECATED - Refer to the 'format' field for the 'virtual' indicator.",
            "example": true,
            "deprecated": true,
            "readOnly": true
          },
          "format": {
            "$ref": "#/components/schemas/event-format.json"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the event.",
            "maxLength": 20000,
            "example": "Cvent annual user conference."
          },
          "start": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted date and time when the event starts.",
            "example": "2020-02-03T13:00:00.000Z"
          },
          "end": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 formatted date and time when the event ends.",
            "example": "2020-02-07T17:00:00.000Z"
          },
          "closeAfter": {
            "type": "string",
            "format": "date-time",
            "description": "The event will be closed for registration after this ISO 8601 formatted date and time.",
            "example": "2020-02-01T23:59:00.000Z",
            "readOnly": true
          },
          "archiveAfter": {
            "type": "string",
            "format": "date-time",
            "description": "The event will be archived after this ISO 8601 formatted date and time.",
            "example": "2020-05-07T12:00:00.000Z",
            "readOnly": true
          },
          "launchAfter": {
            "type": "string",
            "format": "date-time",
            "description": "The event will launch after this ISO 8601 formatted date and time. If the event has not yet launched, this field shows a date of 1/1/1900.",
            "example": "2020-01-07T12:00:00.000Z",
            "readOnly": true
          },
          "timezone": {
            "type": "string",
            "description": "List of supported [timezones](/docs/rest-api/reference/api-standards#time-zones).",
            "maxLength": 29,
            "example": "America/New_York"
          },
          "venues": {
            "type": "array",
            "maxItems": 1,
            "items": {
              "$ref": "#/components/schemas/venue.json"
            },
            "description": "Collection of venues."
          },
          "showVenueLocation": {
            "type": "boolean",
            "description": "True indicates the venue location is visible to guests for essential events. If used with other event types, the request returns a 400 error."
          },
          "showPointOfContact": {
            "type": "boolean",
            "description": "True indicates the venue location is visible to guests for essential events. If used with other event types, the request returns a 400 error."
          },
          "phone": {
            "type": "string",
            "description": "The phone number for the event.",
            "maxLength": 13,
            "example": "555-555-5555",
            "readOnly": true
          },
          "note": {
            "type": "string",
            "description": "Event note created by planners for internal use.",
            "maxLength": 300,
            "example": "This event will need some coordination with external systems."
          },
          "defaultLocale": {
            "type": "string",
            "description": "The event default locale using the IETF language tag format.",
            "maxLength": 35,
            "example": "en-US",
            "readOnly": true
          },
          "languages": {
            "type": "array",
            "uniqueItems": true,
            "maxItems": 32,
            "items": {
              "type": "string",
              "example": "en-US"
            },
            "description": "List of IETF language tags enabled for the event. This field supports reading multiple language tags but supports writing only one language to an event."
          },
          "currency": {
            "type": "string",
            "description": "The ISO 4217 standard format currency code used of this event.",
            "maxLength": 3,
            "example": "USD",
            "readOnly": true
          },
          "registrationSecurityLevel": {
            "$ref": "#/components/schemas/event-security-level.json"
          },
          "status": {
            "$ref": "#/components/schemas/registration-status.json"
          },
          "eventStatus": {
            "$ref": "#/components/schemas/event-status.json"
          },
          "planningStatus": {
            "type": "string",
            "description": "The planner-created planning status for this event. Used for internal tracking purposes.",
            "maxLength": 50,
            "example": "Submitted",
            "readOnly": true
          },
          "testMode": {
            "type": "boolean",
            "description": "True indicates the event is in test mode.",
            "example": false,
            "readOnly": true
          },
          "capacity": {
            "type": "integer",
            "description": "The maximum amount of attendees that can attend the event. Only used for events with the registration feature.",
            "example": 50,
            "readOnly": true
          },
          "planners": {
            "type": "array",
            "maxItems": 1,
            "items": {
              "$ref": "#/components/schemas/planner.json2"
            },
            "description": "A collection of contacts representing the event planners."
          },
          "stakeholders": {
            "type": "array",
            "maxItems": 1,
            "items": {
              "$ref": "#/components/schemas/stakeholder.json"
            },
            "description": "A collection of contacts representing event stakeholders.",
            "readOnly": true
          },
          "customFields": {
            "type": "array",
            "readOnly": true,
            "items": {
              "$ref": "#/components/schemas/custom-field.json5"
            },
            "description": "Collection of custom fields."
          },
          "category": {
            "type": "object",
            "deprecated": true,
            "readOnly": true,
            "description": "The category to which this event belongs (no longer supported).",
            "allOf": [
              {
                "title": "Lookup",
                "description": "Lookup response object",
                "type": "object",
                "properties": {
                  "id": {
                    "$ref": "#/components/schemas/uuid-property"
                  },
                  "code": {
                    "type": "string",
                    "description": "Code / Abbreviation of the lookup item.",
                    "maxLength": 30,
                    "example": "MU"
                  },
                  "name": {
                    "type": "string",
                    "description": "Name of the lookup item.",
                    "maxLength": 30,
                    "example": "Meet up"
                  }
                }
              }
            ]
          },
          "type": {
            "$ref": "#/components/schemas/event-type.json1"
          },
          "_links": {
            "$ref": "#/components/schemas/event-links.json"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when this record was created.",
            "readOnly": true,
            "example": "2017-01-02T02:00:00Z"
          },
          "lastModified": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date time when this record was updated.",
            "readOnly": true,
            "example": "2019-02-12T03:00:00Z"
          },
          "meetingRequestId": {
            "type": "string",
            "format": "uuid",
            "description": "The identifier of the meeting request related to the event, if any.",
            "readOnly": true,
            "example": "b566c24e-12a8-452d-c490-ad0e796be093"
          },
          "createdBy": {
            "type": "string",
            "maxLength": 100,
            "description": "The name of the user who created the event.",
            "readOnly": true,
            "example": "John Doe"
          },
          "lastModifiedBy": {
            "type": "string",
            "maxLength": 100,
            "description": "The name of the user who last modified the event.",
            "readOnly": true,
            "example": "Jane Doe"
          }
        }
      },
      "event-activity-details.json": {
        "title": "Event Activity Detail",
        "description": "Details for an event activity.",
        "type": "object",
        "properties": {
          "id": {
            "description": "The identifier of the event.",
            "type": "string",
            "format": "uuid",
            "example": "d84855b0-eeda-41c4-8e7a-53e80364cb95"
          },
          "title": {
            "type": "string",
            "description": "The title of the event.",
            "example": "Cvent Connect 2020",
            "readOnly": true
          },
          "code": {
            "type": "string",
            "description": "The code of the event.",
            "example": "XRNGB4YY3CX",
            "readOnly": true
          },
          "timezone": {
            "type": "string",
            "description": "The timezone of the event.",
            "example": "America/New_York",
            "readOnly": true
          }
        }
      },
      "event-async-response": {
        "title": "EventAsyncResponse",
        "description": "Asynchronous event operation job details.",
        "type": "object",
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The identifier to be used to get the async status of the event being created or copied.",
            "example": "9163c74j-67c6-401c-k710-oe0f783bf022",
            "readOnly": true
          },
          "status": {
            "type": "string",
            "enum": [
              "Processing",
              "Created",
              "Failed"
            ],
            "description": "The status of the event being created or copied.",
            "example": "Processing",
            "readOnly": true
          }
        }
      },
      "event-async-status": {
        "title": "EventAsyncStatus",
        "description": "Status of an event asynchronous operation.",
        "type": "object",
        "allOf": [
          {
            "title": "EventAsyncResponse",
            "description": "Asynchronous event operation job details.",
            "type": "object",
            "required": [
              "id",
              "status"
            ],
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The identifier to be used to get the async status of the event being created or copied.",
                "example": "9163c74j-67c6-401c-k710-oe0f783bf022",
                "readOnly": true
              },
              "status": {
                "type": "string",
                "enum": [
                  "Processing",
                  "Created",
                  "Failed"
                ],
                "description": "The status of the event being created or copied.",
                "example": "Processing",
                "readOnly": true
              }
            }
          }
        ],
        "properties": {
          "event": {
            "description": "The event for the operation.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The identifier of the event that was created or copied.",
                "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
                "readOnly": true
              }
            }
          }
        }
      },
      "event-budget-cost-detail.json": {
        "title": "Budget Cost Detail",
        "description": "Event Budget cost detail information.",
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/uuid-property"
          },
          "name": {
            "$ref": "#/components/schemas/budget-cost-name.json"
          },
          "totalCostValue": {
            "type": "number",
            "description": "The total cost amount of the budget version in an event.",
            "example": 5500.5
          },
          "totalAppliedTax": {
            "type": "number",
            "description": "The total tax amount of the budget version in an event for the cost column.",
            "example": 500
          },
          "totalAppliedGratuity": {
            "type": "number",
            "description": "The total gratuity amount of the budget version in an event for the cost column.",
            "example": 100.5
          }
        }
      },
      "event-budget-paginated-response": {
        "title": "Event Budget Paginated Response",
        "description": "The response from a request to get the list of event budget totals.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-budget-totals.json"
            },
            "description": "Collection of Event Budget Totals Information."
          }
        }
      },
      "event-budget-totals.json": {
        "title": "Event Budget Totals",
        "description": "Budget Totals for a Event.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/budget-item/allOf/0/allOf/0"
          }
        ],
        "properties": {
          "version": {
            "type": "object",
            "properties": {
              "id": {
                "$ref": "#/components/schemas/uuid-property"
              },
              "name": {
                "type": "string",
                "description": "Name of the budget version.",
                "example": "Budget Version 2"
              },
              "default": {
                "type": "boolean",
                "description": "True indicates the associated budget is the default budget version of the event.",
                "example": true
              }
            },
            "description": "The identifier of the Budget version for an event."
          },
          "lastModifiedDate": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date and time for budget version last modified date.",
            "example": "2020-02-07T00:00:00.00Z"
          },
          "currency": {
            "type": "string",
            "description": "The ISO 4217 standard format currency code used of transaction currency.",
            "maxLength": 3,
            "example": "USD"
          },
          "totalHighLevelEstimate": {
            "type": "object",
            "description": "Total High-level estimation details.",
            "properties": {
              "amount": {
                "type": "number",
                "description": "The total amount of high level estimate of the event.",
                "example": 5001.99
              }
            }
          },
          "costDetail": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-budget-cost-detail.json"
            },
            "description": "The list of cost details."
          }
        }
      },
      "event-contact-id.json": {
        "title": "EventContactId",
        "description": "A pair of event and contact id.",
        "required": [
          "eventId",
          "contactId"
        ],
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the event."
          },
          "contactId": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the contact."
          }
        }
      },
      "event-copy": {
        "title": "EventCopy",
        "description": "Represents directives for the event copy operation.",
        "type": "object",
        "properties": {
          "event": {
            "$ref": "#/components/schemas/event-copy-target.json"
          },
          "registration": {
            "type": "object",
            "description": "Determines if registration feature data should be copied over from the source event.",
            "allOf": [
              {
                "title": "EventCopyOverride",
                "description": "Represents event copy operation overrides.",
                "type": "object",
                "properties": {
                  "featureData": {
                    "type": "boolean",
                    "description": "True indicates the feature data should be copied from the source event.",
                    "default": true,
                    "example": true
                  }
                }
              }
            ]
          },
          "planning": {
            "type": "object",
            "description": "Determines if planning feature data should be copied over from the source event.",
            "allOf": [
              {
                "$ref": "#/components/schemas/event-copy/properties/registration/allOf/0"
              }
            ]
          },
          "agenda": {
            "type": "object",
            "description": "Determines if agenda feature data should be copied over from the source event.",
            "allOf": [
              {
                "$ref": "#/components/schemas/event-copy/properties/registration/allOf/0"
              }
            ]
          },
          "travel": {
            "type": "object",
            "description": "Determines if travel feature data should be copied over from the source event.",
            "allOf": [
              {
                "$ref": "#/components/schemas/event-copy/properties/registration/allOf/0"
              }
            ]
          },
          "surveys": {
            "type": "object",
            "description": "Determines if surveys feature data should be copied over from the source event.",
            "allOf": [
              {
                "$ref": "#/components/schemas/event-copy/properties/registration/allOf/0"
              }
            ]
          },
          "speakers": {
            "type": "object",
            "description": "Determines if speakers feature data should be copied over from the source event.",
            "allOf": [
              {
                "$ref": "#/components/schemas/event-copy/properties/registration/allOf/0"
              }
            ]
          },
          "exhibitors": {
            "type": "object",
            "description": "Determines if exhibitors feature data should be copied over from the source event.",
            "allOf": [
              {
                "$ref": "#/components/schemas/event-copy/properties/registration/allOf/0"
              }
            ]
          }
        }
      },
      "event-copy-target.json": {
        "title": "EventCopyTarget",
        "description": "Represents the target event information for an event copy operation.",
        "type": "object",
        "properties": {
          "id": {
            "description": "The ID of an existing event that you want to copy the source event data into. If this value is not present, a new event is created.",
            "type": "string",
            "format": "uuid",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          }
        }
      },
      "event-email.json": {
        "title": "EventEmail",
        "description": "An email and its details for a specific event.",
        "type": "object",
        "required": [
          "id",
          "active"
        ],
        "allOf": [
          {
            "title": "EmailTemplateCommon",
            "description": "Email Template",
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/invitation-list.json/allOf/0"
              }
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the email template.",
                "example": "Invitation"
              },
              "subject": {
                "type": "string",
                "description": "Subject of the email template.",
                "example": "Email Template Testing"
              },
              "fromName": {
                "type": "string",
                "description": "Name of the sender.",
                "example": "Henry Potterfield"
              },
              "fromEmail": {
                "type": "string",
                "description": "The email address of the sender.",
                "example": "h.potterfield@test.com"
              },
              "plaintextBody": {
                "type": "string",
                "description": "Plain text body of the page in the email.",
                "example": "We\u2019d love to hear your thoughts!\\n\\nPlease take a few minutes to let us know about your recent experience.\\n\\nStart Survey Now ({[RES-SURVEY URL]})"
              },
              "htmlBody": {
                "type": "string",
                "description": "html body of the page sent in the email",
                "example": "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Strict//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd\"><html><head><title></title></head><body style=\"margin:0;padding:0\" id=\"body\"><table ><tbody><tr><td align=\"center\" bgcolor=\"#041532\"><table ><tbody><tr><td align=\"center\" bgcolor=\"#DDE2E6\" style=\"padding-top:0;padding-bottom:0;padding-left:0;padding-right:0\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"max-width:600px\" class=\"wrapper\"><tbody><tr><td><table><tbody><tr><td valign=\"top\"><table><tbody><tr><td><table><tbody><tr><td bgcolor=\"transparent\" style=\"padding-top:15px;padding-bottom:15px;padding-left:15px;padding-right:15px\"><table><tbody><tr><td><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"><tr><td>{[C-FIRST NAME]}, <br></td></tr> <tr><td>We&#x2019;d love to hear your thoughts!</td></tr> </table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td valign=\"top\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" align=\"left\" class=\"column\"><tbody><tr><td><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" data-cvent-id=\"widget-NucleusText-widget:13ea36d2-1eb4-452f-ae17-9d582dbeb7eb\"><tbody><tr><td bgcolor=\"transparent\" style=\"padding-top:15px;padding-bottom:15px;padding-left:15px;padding-right:15px\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"><tbody><tr><td><table><tr><td>Please take a few minutes to let us know about your recent experience.</td></tr> </table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td valign=\"top\"><table><tbody><tr><td><table><tbody><tr><td><table><tbody><tr><td >Start Survey Now</a></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td valign=\"top\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" align=\"left\" class=\"column\"><tbody><tr><td><table ><tbody><tr><td bgcolor=\"transparent\" style=\"padding-top:15px;padding-bottom:15px;padding-left:15px;padding-right:15px\"><table ><tbody><tr><td><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"><tr><td style=\"font-size:16px;line-height:20px;font-family:Arial,Helvetica,sans-serif;color:#273F69;font-style:normal;font-weight:400;text-align:center; padding: 6px 0;\">If you have any questions, feel free to email us at {[SUR-AUTHOR EMAIL]}.<br>Thank you,<br>{[SUR-AUTHOR COMPANY]}&#xA0;</td></tr> </table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td valign=\"top\"><table><tbody><tr><td><table><tbody><tr><td bgcolor=\"transparent\" style=\"padding-top:15px;padding-bottom:15px;padding-left:15px;padding-right:15px\"><table ><tbody><tr><td><table><tr><td>Click the link below to opt out of receiving emails from {[SUR-AUTHOR FIRST NAME]} {[SUR-AUTHOR LAST NAME]}.<br>{[EMAIL OPT OUT]}&#xA0;</td></tr> </table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></td></tr><tr><td><table><tbody><tr><td><table><tbody></tbody></table></td></tr></tbody></table></td></tr></tbody></table> ></td></tr></tbody></table></body></html>"
              },
              "locale": {
                "type": "string",
                "description": "The locale of the email template using the IETF Language Tag format.",
                "example": "en-US"
              },
              "clickTrackingEnabled": {
                "type": "boolean",
                "description": "Enables tracking when respondent clicks on the email",
                "example": true
              },
              "replyToName": {
                "type": "string",
                "description": "Name of the person to reply to",
                "example": "Henry Potterfield"
              },
              "replyToEmail": {
                "type": "string",
                "description": "Email address to reply to",
                "example": "h.potterfield@test.com"
              }
            }
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The unique ID of the event email.",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          },
          "active": {
            "type": "boolean",
            "description": "True indicates the email is active and can be sent.",
            "example": true
          },
          "invitationList": {
            "$ref": "#/components/schemas/invitation-list-id.json"
          }
        }
      },
      "event-emails-paginated-response": {
        "title": "EventEmailsPaginatedResponse",
        "description": "Paginated response for the collection of emails for a specified event.",
        "required": [
          "data",
          "paging"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json25"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-email.json"
            },
            "description": "Collection of emails for a specific event."
          }
        }
      },
      "event-feature-launch-request": {
        "title": "EventFeaturesLaunchRequest",
        "description": "Event-features launch request parameters.",
        "type": "object",
        "properties": {
          "deleteTestData": {
            "description": "True keeps email data collected in test mode, prior to the registration feature being launched.",
            "type": "boolean",
            "default": false
          }
        }
      },
      "event-feature.json": {
        "title": "EventFeature",
        "description": "Representation of an event's feature along with its properties",
        "type": "object",
        "required": [
          "type",
          "locked",
          "enabled"
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/feature-type.json"
          },
          "enabled": {
            "type": "boolean",
            "description": "If a particular feature is enabled for the event",
            "example": true
          },
          "locked": {
            "type": "boolean",
            "description": "If a particular feature is locked to perform any mutation over it",
            "example": true
          },
          "lockedReason": {
            "type": "string",
            "description": "Generic message informing feature is locked due to some sub-feature/child feature in use",
            "example": "Your event is already using some Registration features"
          },
          "enabledTier": {
            "$ref": "#/components/schemas/tier.json"
          },
          "availableTiers": {
            "description": "Available feature tiers.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/feature-tier.json"
            }
          },
          "config": {
            "type": "object",
            "description": "Feature configuration.",
            "anyOf": [
              {
                "$ref": "#/components/schemas/event-features-response/properties/config/anyOf/0"
              }
            ]
          },
          "weblink": {
            "type": "string",
            "format": "uri",
            "readOnly": true,
            "description": "URL of the feature's webpage.",
            "example": "https://cvent.me/XX51b9"
          }
        }
      },
      "event-features-paginated-response": {
        "title": "EventFeaturesPaginatedResponse",
        "description": "Paginated collection of event features.",
        "required": [
          "data",
          "paging"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-feature.json"
            },
            "description": "Collection of event features"
          }
        }
      },
      "event-features-response": {
        "title": "EventFeature",
        "description": "Representation of an event's feature along with its properties",
        "type": "object",
        "required": [
          "type",
          "locked",
          "enabled"
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/feature-type.json"
          },
          "enabled": {
            "type": "boolean",
            "description": "If a particular feature is enabled for the event",
            "example": true
          },
          "locked": {
            "type": "boolean",
            "description": "If a particular feature is locked to perform any mutation over it",
            "example": true
          },
          "lockedReason": {
            "type": "string",
            "description": "Generic message informing feature is locked due to some sub-feature/child feature in use",
            "example": "Your event is already using some Registration features"
          },
          "enabledTier": {
            "$ref": "#/components/schemas/tier.json"
          },
          "availableTiers": {
            "description": "Available feature tiers.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/feature-tier.json"
            }
          },
          "config": {
            "type": "object",
            "description": "Feature configuration.",
            "anyOf": [
              {
                "title": "RegistrationFeatureConfig",
                "description": "Denote the configuration for the registration feature.",
                "type": "object",
                "properties": {
                  "pricing": {
                    "$ref": "#/components/schemas/pricing-config.json"
                  }
                }
              }
            ]
          },
          "weblink": {
            "type": "string",
            "format": "uri",
            "readOnly": true,
            "description": "URL of the feature's webpage.",
            "example": "https://cvent.me/XX51b9"
          }
        }
      },
      "event-format.json": {
        "title": "Event Format",
        "enum": [
          "In-person",
          "Virtual",
          "Hybrid"
        ],
        "type": "string",
        "description": "Denotes the format of an event.",
        "example": "Virtual"
      },
      "event-id.json": {
        "title": "EventId",
        "description": "The unique identifier for an event.",
        "type": "string",
        "format": "uuid",
        "example": "2ef03846-fced-4ce3-a077-d64ca891a4b1"
      },
      "event-id.json1": {
        "title": "EventId",
        "description": "The unique identifier for an event",
        "type": "string",
        "format": "uuid",
        "example": "78842378-5d83-11ee-8c99-0242ac120002"
      },
      "event-id1": {
        "title": "Event ID",
        "description": "The UUID identifier for an Event.",
        "type": "string",
        "format": "uuid",
        "example": "eeeeb4b4-d132-4db4-aaa7-5ec58efd65c8"
      },
      "event-links.json": {
        "title": "EventLinks",
        "description": "Represents the links associated with an event.",
        "type": "object",
        "readOnly": true,
        "properties": {
          "invitation": {
            "$ref": "#/components/schemas/link.json"
          },
          "agenda": {
            "$ref": "#/components/schemas/link.json"
          },
          "summary": {
            "$ref": "#/components/schemas/link.json"
          },
          "registration": {
            "$ref": "#/components/schemas/link.json"
          }
        },
        "example": {
          "invitation": {
            "href": "https://cvent.com"
          },
          "agenda": {
            "href": "https://cvent.com"
          },
          "summary": {
            "href": "https://cvent.com"
          },
          "registration": {
            "href": "https://cvent.com"
          }
        }
      },
      "event-lite.json": {
        "required": [
          "id"
        ],
        "type": "object",
        "title": "EventLite",
        "description": "The unique identifier of an event.",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/event-id.json"
          }
        }
      },
      "event-lite.json1": {
        "type": "object",
        "title": "Event",
        "description": "The related event object.",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/event-id.json1"
          }
        }
      },
      "event-paginated-response": {
        "title": "EventPaginatedResponse",
        "description": "Represents a paginated collection of event objects.",
        "required": [
          "data",
          "paging"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event"
            },
            "description": "A collection of event objects."
          }
        }
      },
      "event-question-choice.json": {
        "title": "Choice",
        "type": "object",
        "description": "This is used to denote the choice of questions in an event.",
        "required": [
          "text"
        ],
        "allOf": [
          {
            "title": "Choice",
            "type": "object",
            "description": "This is used to denote the choice of question.",
            "required": [
              "text"
            ],
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The ID of the question choice. If you supply the choice's existing ID in a PUT call, the choice keeps its current ID and the choice text is updated. If this `id` field is left blank in a PUT call, this choice text will be replaced with the text supplied, and a new choice ID is created.",
                "readOnly": true
              },
              "text": {
                "type": "string",
                "description": "The text for the question choice.",
                "example": "What is your current designation?",
                "minLength": 1
              }
            }
          }
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/choice-type.json"
          }
        }
      },
      "event-question-choices-response": {
        "title": "EventQuestionChoicesResponse",
        "description": "Response to the request to get a list of event question choices.",
        "required": [
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-question-choice.json"
            },
            "description": "Collection of choices for a choice question."
          }
        }
      },
      "event-question.json": {
        "title": "EventQuestion",
        "description": "Represents a question associated with an event.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/session1/allOf/0"
          }
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/uuid-property"
          },
          "event": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "text": {
            "type": "string",
            "description": "Text of the question.",
            "maxLength": 300,
            "example": "Let us know why you can't attend."
          },
          "code": {
            "type": "string",
            "description": "Code of the question.",
            "maxLength": 30,
            "readOnly": true,
            "example": "ONE_LINE_43534"
          },
          "tag": {
            "type": "string",
            "description": "Tag of the question. It allows comparison of similar questions across multiple events.",
            "maxLength": 25,
            "readOnly": true,
            "example": "All Admission Items"
          },
          "session": {
            "type": "object",
            "description": "Represents the session associated to the question, if any. Blank if no session is associated. In addition, only one of the `session` or `admissionItem` object are populated - never both.",
            "properties": {
              "id": {
                "description": "ID of the session associated with the question.",
                "type": "string",
                "format": "uuid",
                "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
              }
            }
          },
          "admissionItem": {
            "type": "object",
            "description": "Represents the admission item associated to the question, if any. Blank if no admission item is associated. In addition, only one of the `session` or `admissionItem` object are populated - never both.",
            "properties": {
              "id": {
                "description": "ID of the admission item associated with the question.",
                "type": "string",
                "format": "uuid",
                "example": "06ca5ae2-0dc3-487b-953e-86d6abbdf7d3"
              }
            }
          },
          "type": {
            "$ref": "#/components/schemas/question-type.json3"
          },
          "internalNote": {
            "type": "string",
            "description": "Optional description to provide additional context of the question.",
            "maxLength": 300,
            "example": "This question is for the event registration form."
          }
        }
      },
      "event-questions-paginated-response": {
        "title": "EventQuestionsPaginatedResponse",
        "description": "Represents the response from a request to get the list of event questions. This includes the paging object as well as the collection of event questions.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-question.json"
            },
            "description": "Collection of event questions."
          }
        }
      },
      "event-role-assignment.json": {
        "title": "EventRoleAssignment",
        "description": "An assignment of an event role to a user for an event.",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique ID of the event role assignment, which concatenates the IDs of the event, the event role, and the user assigned the role.",
            "readOnly": true,
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3::2b1a3bba-84b2-46f4-bddb-4b4a44442dcc::6807e044-993b-428c-aec8-7316f13c1b95"
          },
          "event": {
            "description": "The event where the user gets a role. For more details, use the [Get Event](#tag/Events/operation/getEventById) endpoint with the event ID.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The unique ID of the event.",
                "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
              }
            }
          },
          "user": {
            "description": "The user to whom the event role is assigned. For more details, use the [Get User](#tag/User-SCIM/operation/getUser) endpoint with the user ID.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "The unique ID of the user.",
                "example": "6807e044-993b-428c-aec8-7316f13c1b95"
              }
            }
          },
          "eventRole": {
            "$ref": "#/components/schemas/event-role.json"
          },
          "assigned": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned date-time when the event role was assigned to the user.",
            "readOnly": true,
            "example": "2017-01-02T02:00:00Z"
          },
          "assignedBy": {
            "type": "string",
            "description": "The identifier of the user who assigned the event role.",
            "readOnly": true,
            "example": "hporter"
          }
        }
      },
      "event-role-assignments-paginated-response": {
        "title": "EventRoleAssignmentPaginatedResponse",
        "description": "The response to a request to get a paginated list of event role assignments. This includes the paging object and the collection of event role assignments.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "description": "A collection of event role assignments.",
            "items": {
              "$ref": "#/components/schemas/event-role-assignment.json"
            }
          }
        }
      },
      "event-role.json": {
        "title": "EventRole",
        "description": "An object that contains the event role ID. This is an **expandable** object and, if requested, will contain the name of the event role.",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The ID of the event role.",
            "readOnly": true,
            "example": "2b1a3bba-84b2-46f4-bddb-4b4a44442dcc"
          }
        }
      },
      "event-security-level.json": {
        "title": "EventSecurityLevel",
        "description": "Represents the security level used for event registrations.",
        "enum": [
          "Private",
          "Public",
          "Public and Private"
        ],
        "type": "string",
        "readOnly": true,
        "example": "Private"
      },
      "event-status.json": {
        "title": "EventStatus",
        "description": "Event status denotes if the event is in the past, present or future. Also can denote if the event was cancelled or deleted. ",
        "readOnly": true,
        "type": "string",
        "enum": [
          "Upcoming",
          "Ongoing",
          "Completed",
          "Cancelled",
          "Deleted",
          "Processing",
          "Archived"
        ],
        "example": "Upcoming"
      },
      "event-summary.json": {
        "description": "Schema for event summary associated with this proposal.",
        "type": "object",
        "title": "EventSummary",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The unique ID of the event in the proposal.",
            "example": "bedc1f8e-f68b-40cf-b901-487e407f637a"
          }
        }
      },
      "event-survey-audience-type.json": {
        "title": "EventSurveyAudienceType",
        "enum": [
          "Attendee",
          "Stakeholder",
          "Speaker"
        ],
        "type": "string",
        "description": "Audience types of event surveys",
        "example": "Attendee",
        "readOnly": true
      },
      "event-survey-availability.json": {
        "title": "EventSurveyAvailability",
        "enum": [
          "Event Registrants",
          "Event Participants",
          "Session Registrants",
          "Session Participants"
        ],
        "type": "string",
        "description": "Describes the availability of the event survey",
        "example": "Session Registrants",
        "readOnly": true
      },
      "event-survey-question.json": {
        "title": "EventSurveyQuestion",
        "description": "An event survey question.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/question.json2/allOf/0"
          }
        ],
        "properties": {
          "survey": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "event": {
            "$ref": "#/components/schemas/uuid.json"
          }
        }
      },
      "event-survey-questions-paginated-response": {
        "title": "SurveyQuestionPaginatedResponse",
        "description": "Response include Paging and collection os questions",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-survey-question.json"
            },
            "description": "Collection of Questions"
          }
        }
      },
      "event-survey-respondent": {
        "title": "EventSurveyRespondent",
        "type": "object",
        "description": "Respondent detail object for event survey.",
        "allOf": [
          {
            "title": "RespondentCommon",
            "description": "Common base model for a Respondent.",
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/response-common/allOf/0"
              }
            ],
            "properties": {
              "id": {
                "description": "Id of the respondent that has to be in a format matching the industry standard uuid",
                "type": "string",
                "format": "uuid",
                "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3",
                "readOnly": true
              },
              "responseCode": {
                "type": "string",
                "description": "Response Code",
                "example": "92OM10RO",
                "readOnly": true
              },
              "responseDuration": {
                "type": "number",
                "description": "Time taken by respondent to respond to the survey (in seconds)",
                "example": 1035,
                "readOnly": true
              },
              "localeId": {
                "type": "string",
                "description": "Locale Id of the respondent using the IETF Language Tag format",
                "example": "en-US"
              },
              "respondedThrough": {
                "$ref": "#/components/schemas/responded-through.json"
              },
              "referenceId": {
                "type": "string",
                "example": "facebook",
                "description": "Reference ids are used to track where response is coming from. Survey Author can create multiple weblinks with different values of referenceId query param in them."
              },
              "score": {
                "type": "number",
                "description": "Respondent Score",
                "example": 70,
                "readOnly": true
              },
              "maxPossibleScore": {
                "type": "number",
                "description": "Respondent Maximum Possible Score",
                "example": 100,
                "readOnly": true
              },
              "percentageScore": {
                "type": "number",
                "description": "Respondent Percentage Score",
                "example": 70,
                "readOnly": true
              },
              "_links": {
                "type": "object",
                "description": "Related links.",
                "properties": {
                  "surveyUrl": {
                    "$ref": "#/components/schemas/link.json"
                  }
                },
                "readOnly": true
              },
              "sourceId": {
                "type": "string",
                "example": "IN4IDS1",
                "description": "Source IDs track respondents in an external system integrated with the Cvent survey."
              }
            }
          }
        ],
        "properties": {
          "event": {
            "$ref": "#/components/schemas/event.json7"
          },
          "attendee": {
            "description": "Associated attendee.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
                "description": "Id of the attendee"
              }
            }
          },
          "contact": {
            "description": "Associated contact.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
                "description": "Contact Id of the respondent"
              }
            },
            "readOnly": true
          },
          "surveys": {
            "description": "List of associated surveys.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/respondent-event-survey-reference.json"
            },
            "readOnly": true
          }
        }
      },
      "event-survey-respondents-paginated-response": {
        "title": "EventSurveyRespondentsPaginatedResponse",
        "description": "Response includes paging and respondents data for a event survey",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-survey-respondent"
            },
            "description": "Respondent information for an event survey"
          }
        }
      },
      "event-survey-response": {
        "title": "EventSurveyResponse",
        "type": "object",
        "description": "Response object for event survey respondent.",
        "allOf": [
          {
            "title": "ResponseCommon",
            "description": "Base model with properties common to a survey response.",
            "type": "object",
            "required": [
              "answers",
              "question"
            ],
            "allOf": [
              {
                "$ref": "#/components/schemas/response-common/allOf/0"
              }
            ],
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "description": "Response ID",
                "readOnly": true
              },
              "respondent": {
                "type": "object",
                "allOf": [
                  {
                    "$ref": "#/components/schemas/uuid.json"
                  }
                ],
                "readOnly": true
              },
              "question": {
                "$ref": "#/components/schemas/uuid.json"
              },
              "answers": {
                "description": "List of responded survey answers.",
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/answer.json1"
                },
                "minItems": 1
              },
              "score": {
                "deprecated": true,
                "type": "number",
                "description": "Answer score (This property is not supported).",
                "example": 20,
                "readOnly": true
              }
            }
          }
        ],
        "properties": {
          "event": {
            "$ref": "#/components/schemas/event.json7"
          },
          "survey": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "session": {
            "$ref": "#/components/schemas/uuid.json"
          },
          "speaker": {
            "$ref": "#/components/schemas/uuid.json"
          }
        }
      },
      "event-survey-responses-paginated-response": {
        "title": "EventSurveyResponsesPaginatedResponse",
        "description": "Response include paging and responses for a survey",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-survey-response"
            },
            "description": "Response for a survey"
          }
        }
      },
      "event-survey-session-match.json": {
        "title": "EventSurveySessionMatch",
        "enum": [
          "Only certain sessions",
          "All sessions"
        ],
        "type": "string",
        "description": "What is the criteria of adding sessions to a event survey",
        "example": "Only certain sessions",
        "readOnly": true
      },
      "event-survey-type.json": {
        "title": "EventSurveyType",
        "enum": [
          "Event Feedback",
          "Session Feedback",
          "Stakeholder Feedback"
        ],
        "type": "string",
        "description": "This is used to denote the different survey types.",
        "example": "Session Feedback",
        "readOnly": true
      },
      "event-survey.json": {
        "title": "EventSurvey",
        "description": "An event survey.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/survey.json/allOf/0"
          }
        ],
        "properties": {
          "type": {
            "$ref": "#/components/schemas/event-survey-type.json"
          },
          "availableTo": {
            "$ref": "#/components/schemas/event-survey-availability.json"
          },
          "audienceType": {
            "$ref": "#/components/schemas/event-survey-audience-type.json"
          },
          "sessionMatch": {
            "$ref": "#/components/schemas/event-survey-session-match.json"
          },
          "sessions": {
            "type": "array",
            "description": "Associated session ids of the survey, this can also be null",
            "items": {
              "$ref": "#/components/schemas/uuid-property"
            },
            "example": [
              "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3",
              "05ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
            ]
          },
          "parentId": {
            "type": "string",
            "format": "uuid",
            "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
            "description": "Id of the parent survey"
          }
        }
      },
      "event-surveys-paginated-response": {
        "title": "EventSurveysPaginatedResponse",
        "description": "The response from a request to get the list of event surveys.  This includes the paging object as well as the collection of surveys.",
        "required": [
          "paging",
          "data"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-survey.json"
            },
            "description": "Collection of event surveys."
          }
        }
      },
      "event-type.json1": {
        "title": "EventType",
        "enum": [
          "Celebration",
          "Conference",
          "CventEssentials",
          "CventWebinar",
          "Dinner",
          "Forum",
          "FundraiserBenefit",
          "Holiday",
          "IncentiveTrip",
          "Meeting",
          "OtherGeneral",
          "PoliticalEvent",
          "Reunion",
          "SaveTheDate",
          "Seminar",
          "SimpleEvent",
          "SportsEvent",
          "TradeShow",
          "TrainingSession",
          "Webinar"
        ],
        "type": "string",
        "description": "Type of event being created. The following event types are not supported: Cvent Webinar, Cvent Essentials.",
        "example": "Conference"
      },
      "event-update": {
        "title": "Event Update",
        "description": "Represents updates to an event.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/event"
          }
        ],
        "properties": {
          "closeAfter": {
            "type": "string",
            "format": "date-time",
            "description": "The event will be closed for registration after this ISO 8601 formatted date and time.",
            "example": "2020-02-01T23:59:00.000Z",
            "readOnly": false
          },
          "archiveAfter": {
            "type": "string",
            "format": "date-time",
            "description": "The event will be archived after this ISO 8601 formatted date and time.",
            "example": "2020-05-07T12:00:00.000Z",
            "readOnly": false
          },
          "capacity": {
            "type": "integer",
            "description": "The maximum number of individuals that can attend the event. Only used for events with the registration feature.",
            "example": 50,
            "readOnly": false
          }
        }
      },
      "event-weblink.json": {
        "title": "EventWeblink",
        "description": "Metadata for an event weblink.",
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 50,
            "description": "Name of the weblink, used by planners to identify the weblinks in their event.",
            "example": "VIP Registration"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Short URL of the webpage.",
            "example": "https://cvent.me/XX51b9"
          },
          "landingPage": {
            "type": "string",
            "description": "The name of the webpage attendees will be directed to when using the weblink.",
            "example": "Registration"
          },
          "locale": {
            "$ref": "#/components/schemas/locale.json"
          }
        }
      },
      "event-weblinks-paginated-response": {
        "title": "EventWeblinksPaginatedResponse",
        "description": "Paginated collection of event weblinks.",
        "required": [
          "data",
          "paging"
        ],
        "type": "object",
        "properties": {
          "paging": {
            "type": "object",
            "allOf": [
              {
                "properties": {
                  "limit": {
                    "description": "The number of records to return on the page, not to exceed 100.",
                    "example": 100
                  }
                }
              },
              {
                "$ref": "#/components/schemas/paging.json"
              }
            ]
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/event-weblink.json"
            },
            "description": "Collection of event weblinks."
          }
        }
      },
      "event.json": {
        "type": "object",
        "description": "The reference to the event. Contains only the ID of the event.",
        "title": "Event",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier of the event.",
            "example": "4a0e8d1f-8fd6-4ebe-977a-602b4a1f9c56"
          }
        }
      },
      "event.json11": {
        "title": "Event",
        "description": "Details of the event.",
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "a150f1ee-6c54-4b01-90e6-d701748f0851",
            "description": "The unique ID of the event."
          }
        }
      },
      "event.json3": {
        "title": "Event",
        "required": [
          "id"
        ],
        "description": "ID of the event.",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "UUID of the event.",
            "example": "103097a4-143d-11e5-9f99-d0a637ee0032"
          }
        }
      },
      "event.json4": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifier of a particular Event.",
            "format": "uuid",
            "example": "3d808ee8-94f8-4f3a-9ad1-6b23f4e4c329"
          }
        },
        "description": "Event ID Information."
      },
      "event.json6": {
        "description": "The Associated Event.",
        "title": "Event",
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "3db28cfc-db22-11eb-8d19-0242ac130003",
            "description": "Event id"
          }
        }
      },
      "event.json7": {
        "title": "Event",
        "type": "object",
        "description": "Detail object of an event which is associated to a survey.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
            "description": "Id of the associated event"
          }
        },
        "readOnly": true
      },
      "event.json9": {
        "title": "Event",
        "description": "An event reference used in attendee insights to identify the event context for engagement data",
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier (UUID) for the event where the engagement score applies",
            "example": "04cb6ae2-0dc3-487b-953e-86d6abbdf7d3"
          }
        }
      },
      "exhibitor-address.json": {
        "title": "Address",
        "type": "object",
        "description": "An object representing an address with various properties.",
        "properties": {
          "address1": {
            "type": "string",
            "description": "The first line of an address",
            "example": "Cvent Inc."
          },
          "address2": {
            "type": "string",
            "description": "The second line of an address",
            "example": "4001 West Parmer Lane"
          },
          "city": {
            "type": "string",
            "description": "The name of the city.",
            "example": "Austin"
          },
          "region": {
            "type": "string",
            "description": "The name of the state/province/region of the address.",
            "example": "Texas"
          },
          "postalCode": {
            "type": "string",
            "description": "postal code (also known as zipcode) of the address",
            "example": "78727"
          },
          "country": {
            "type": "string",
            "description": "Name of the country for example, 'United States'",
            "example": "United States of America"
          }
        }
      },
      "exhibitor-admin-request": {
        "title": "Exhibitor Admin",
        "type": "object",
        "description": "An object representing the exhibitor admin.",
        "allOf": [
          {
            "title": "OSS-Audit",
            "description": "OSS Audit information",
            "type": "object",
            "properties": {
              "created": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was created.",
                "readOnly": true,
                "example": "2017-01-02T02:00:00Z"
              },
              "createdBy": {
                "type": "string",
                "description": "The identifier of the user that created this record.",
                "readOnly": true,
                "example": "hporter"
              },
              "lastModified": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was updated.",
                "readOnly": true,
                "example": "2019-02-12T03:00:00Z"
              },
              "lastModifiedBy": {
                "type": "string",
                "description": "The identifier of the user that last updated this record.This filed is deprecated.",
                "deprecated": true,
                "readOnly": true,
                "example": "hporter"
              }
            }
          }
        ],
        "required": [
          "exhibitor",
          "email",
          "firstName",
          "lastName"
        ],
        "properties": {
          "exhibitor": {
            "$ref": "#/components/schemas/exhibitor.json"
          },
          "firstName": {
            "type": "string",
            "description": "The first name of the exhibitor admin",
            "minLength": 1,
            "maxLength": 30,
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "description": "The last name of the exhibitor admin",
            "minLength": 1,
            "maxLength": 30,
            "example": "Eddy"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "The email address of the exhibitor admin",
            "example": "john.eddy@test.com"
          }
        }
      },
      "exhibitor-admin-response": {
        "title": "Exhibitor Admin",
        "type": "object",
        "allOf": [
          {
            "title": "Exhibitor Admin",
            "type": "object",
            "description": "An object representing the exhibitor admin.",
            "allOf": [
              {
                "$ref": "#/components/schemas/exhibitor-admin-request/allOf/0"
              }
            ],
            "required": [
              "exhibitor",
              "email",
              "firstName",
              "lastName"
            ],
            "properties": {
              "exhibitor": {
                "$ref": "#/components/schemas/exhibitor.json"
              },
              "firstName": {
                "type": "string",
                "description": "The first name of the exhibitor admin",
                "minLength": 1,
                "maxLength": 30,
                "example": "John"
              },
              "lastName": {
                "type": "string",
                "description": "The last name of the exhibitor admin",
                "minLength": 1,
                "maxLength": 30,
                "example": "Eddy"
              },
              "email": {
                "type": "string",
                "format": "email",
                "description": "The email address of the exhibitor admin",
                "example": "john.eddy@test.com"
              }
            }
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3",
