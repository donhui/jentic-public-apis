      "program-item-update-request": {
        "title": "ProgramItemUpdateRequest",
        "type": "object",
        "description": "Represents a program item object that will be updated.",
        "required": [
          "id",
          "event",
          "session",
          "name"
        ],
        "allOf": [
          {
            "$ref": "#/components/schemas/session-segment/allOf/0"
          }
        ],
        "properties": {
          "id": {
            "description": "ID of the program item.",
            "type": "string",
            "format": "uuid",
            "example": "38db6ae2-0dc3-487b-953e-86d6abbdf7d3"
          },
          "event": {
            "$ref": "#/components/schemas/event-lite.json1"
          },
          "session": {
            "$ref": "#/components/schemas/session-lite.json1"
          },
          "name": {
            "type": "string",
            "description": "Name of the program item.",
            "maxLength": 500,
            "example": "Day 1 Program Item."
          },
          "duration": {
            "type": "integer",
            "description": "The duration of the program item in minutes.",
            "example": 30
          },
          "description": {
            "type": "string",
            "description": "Description of the program item.",
            "maxLength": 2500,
            "example": "This is a sample description of the day 1 program item."
          },
          "rteDescription": {
            "type": "string",
            "description": "Rich-text-editor description in json formatting.",
            "example": "{\"format\":\"draftjs-nucleus\",\"version\":1,\"content\":{\"blocks\":[{\"key\":\"cubve\",\"text\":\"Program Item Description\",\"type\":\"unstyled\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}}"
          }
        }
      },
      "property": {
        "title": "property",
        "description": "Details of the property",
        "type": "object",
        "allOf": [
          {
            "title": "Audit",
            "description": "Audit information",
            "type": "object",
            "properties": {
              "created": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was created.",
                "readOnly": true,
                "example": "2017-01-02T02:00:00Z"
              },
              "createdBy": {
                "type": "string",
                "description": "The identifier of the user that created this record.",
                "readOnly": true,
                "example": "hporter"
              },
              "lastModified": {
                "type": "string",
                "format": "date-time",
                "description": "The ISO 8601 zoned date time when this record was updated.",
                "readOnly": true,
                "example": "2019-02-12T03:00:00Z"
              },
              "lastModifiedBy": {
                "type": "string",
                "description": "The identifier of the user that last updated this record.",
                "readOnly": true,
                "example": "hporter"
              }
            }
          }
        ],
        "properties": {
          "id": {
            "title": "Property ID",
            "description": "The ID of the property.",
            "type": "string",
            "format": "uuid",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          },
          "name": {
            "type": "string",
            "maxLength": 50,
            "example": "The Grand Property",
            "description": "The name of the property."
          },
          "chain": {
            "description": "The chain that the property belongs to.",
            "type": "object",
            "properties": {
              "id": {
                "title": "Chain ID",
                "description": "The ID of the chain.",
                "type": "string",
                "format": "uuid",
                "example": "415079ab-4bee-491e-84ad-c2379f840379"
              }
            }
          },
          "brand": {
            "description": "The brand that the property belongs to.",
            "type": "object",
            "properties": {
              "id": {
                "title": "Brand ID",
                "description": "The ID of the brand.",
                "type": "string",
                "example": "NorthernHotels"
              }
            }
          },
          "code": {
            "type": "string",
            "maxLength": 15,
            "example": "GH101",
            "description": "The property code for the property."
          },
          "deleted": {
            "type": "boolean",
            "description": "True indicates that the property is deleted.",
            "default": false,
            "example": false,
            "readOnly": true
          },
          "currencyCode": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3,
            "default": "USD",
            "example": "USD",
            "description": "The ISO 4217 standard format currency code specified for the property."
          },
          "address": {
            "$ref": "#/components/schemas/address.json5"
          },
          "externalCodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/property-external-code.json"
            },
            "description": "Collection of external codes for a property. This includes GDS nd other codes used to identify a property in external systems.",
            "maxItems": 5
          }
        }
      },
      "property-external-code.json": {
        "title": "Property External Codes",
        "description": "The external chain and property codes for the property",
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/external-code-type.json"
          },
          "chainCode": {
            "type": "string",
            "maxLength": 6,
            "example": "NH",
            "description": "The code identifying the property's chain in the given external system."
          },
          "propertyCode": {
            "type": "string",
            "maxLength": 15,
            "example": "GH1",
            "description": "The code identifying a property in the given external system."
          }
        }
      },
      "property-paginated-response": {
        "title": "Property paginated response",
        "description": "A list of properties.",
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/property"
            },
            "description": "Collection of properties and their related details."
          }
        }
      },
      "property-room": {
        "title": "Property Room",
        "description": "Property room details.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/property/allOf/0"
          }
        ],
        "properties": {
          "id": {
            "title": "Property Room ID",
            "description": "The ID of the property room.",
            "type": "string",
            "format": "uuid",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
          },
          "name": {
            "type": "string",
            "description": "The name of the property room.",
            "maxLength": 30,
            "example": "Standard"
          },
          "code": {
            "type": "string",
            "maxLength": 6,
            "description": "Room code of the property room.",
            "example": "std"
          },
          "property": {
            "description": "The property that the room belongs to.",
            "type": "object",
            "properties": {
              "id": {
                "title": "property ID",
                "description": "The ID of the property.",
                "type": "string",
                "format": "uuid",
                "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3"
              }
            }
          },
          "deleted": {
            "type": "boolean",
            "description": "True indicates the property room is deleted.",
            "default": false,
            "example": false,
            "readOnly": true
          },
          "bedTypeCode": {
            "$ref": "#/components/schemas/room-bed-type.json1"
          },
          "numberOfBeds": {
            "type": "integer",
            "description": "The number of beds in the room.",
            "example": 2
          },
          "capacity": {
            "type": "integer",
            "description": "Maximum capacity of people that can sleep in the room.",
            "example": 6
          },
          "description": {
            "type": "string",
            "maxLength": 2000,
            "description": "A description of the room.",
            "example": "A standard room with two queen beds."
          },
          "externalCodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/property-room-external-code.json"
            },
            "description": "Collection of external codes for the room. This includes GDS and other codes used to identify a room in external systems.",
            "maxItems": 5
          }
        }
      },
      "property-room-external-code.json": {
        "title": "Property Room External Code",
        "description": "The external room codes for the room",
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/external-code-type.json"
          },
          "roomCode": {
            "type": "string",
            "maxLength": 10,
            "example": "std887",
            "description": "The code identifying the room in the given external system."
          }
        }
      },
      "property-room-paginated-response": {
        "title": "Property room paginated response",
        "description": "A list of property sleeping rooms.",
        "type": "object",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/property-room"
            },
            "description": "Collection of property rooms and related details."
          }
        }
      },
      "proposal-date.json": {
        "type": "object",
        "title": "ProposalDate",
        "description": "The proposal date.",
        "properties": {
          "dateType": {
            "$ref": "#/components/schemas/date-type.json1"
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "description": "The start date of the event.",
            "example": "2021-01-13"
          },
          "endDate": {
            "type": "string",
            "format": "date",
            "description": "The end date of the event.",
            "example": "2021-01-13"
          }
        }
      },
      "proposal-status-type.json": {
        "title": "Proposal Status Type",
        "enum": [
          "participation_requested",
          "new",
          "active",
          "submitted",
          "declined_participation",
          "verified",
          "approved",
          "account_accepted",
          "account_rejected",
          "internal_rejected",
          "request_renegotiation",
          "decline_renegotiation",
          "deleted"
        ],
        "type": "string",
        "description": "The status of the proposal",
        "example": "account_accepted"
      },
      "proposal-status.json": {
        "type": "string",
        "title": "ProposalStatus",
        "description": "The status of the proposal. See [definitions of proposal statuses](https://support.cvent.com/s/communityarticle/Understanding-RFP-and-Proposal-Statuses)",
        "enum": [
          "NOT_SENT",
          "SUBMITTED",
          "AWARDED",
          "DECLINED",
          "DELETED",
          "NO_RESPONSE",
          "CANCELLED",
          "WITHDRAWN"
        ],
        "default": "NOT_SENT"
      },
      "proposal-type.json": {
        "type": "string",
        "title": "ProposalType",
        "description": "The type of the proposal.",
        "enum": [
          "VENUE"
        ],
        "default": "VENUE"
      },
      "ProposalRequest": {
        "description": "Schema for proposal request.",
        "type": "object",
        "title": "ProposalRequest",
        "allOf": [
          {
            "description": "Schema for proposal request.",
            "type": "object",
            "title": "BaseProposal",
            "allOf": [
              {
                "title": "Audit",
                "description": "Audit information",
                "type": "object",
                "properties": {
                  "created": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The ISO 8601 zoned date time when this record was created.",
                    "readOnly": true,
                    "example": "2017-01-02T02:00:00Z"
                  },
                  "createdBy": {
                    "type": "string",
                    "description": "The identifier of the user that created this record.",
                    "readOnly": true,
                    "example": "hporter"
                  },
                  "lastModified": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The ISO 8601 zoned date time when this record was updated.",
                    "readOnly": true,
                    "example": "2019-02-12T03:00:00Z"
                  },
                  "lastModifiedBy": {
                    "type": "string",
                    "description": "The identifier of the user that last updated this record.",
                    "readOnly": true,
                    "example": "hporter"
                  }
                }
              }
            ],
            "properties": {
              "scpTemplateId": {
                "format": "uuid",
                "type": "string",
                "example": "a633b01c-e461-4cc2-8c66-8ae036115658",
                "description": "The ID of the smart custom proposal template."
              },
              "type": {
                "$ref": "#/components/schemas/proposal-type.json"
              },
              "supplierSummary": {
                "$ref": "#/components/schemas/supplier-summary.json"
              },
              "rfpSummary": {
                "$ref": "#/components/schemas/rfp-summary.json"
              },
              "eventSummary": {
                "$ref": "#/components/schemas/event-summary.json"
              },
              "statusSummary": {
                "$ref": "#/components/schemas/status-summary.json"
              },
              "introduction": {
                "type": "string",
                "maxLength": 2500,
                "description": "Introduction text for the proposal.",
                "example": "Let us design the day of your dreams at our property."
              },
              "billingContractualResponse": {
                "type": "string",
                "maxLength": 2500,
                "description": "Details about concessions or contractual requirements from the supplier. DEPRECATED - This field is deprecated. Only applied to proposal made from vendor marketplace, a sunset product.",
                "example": "All invoices must be paid in 30 days.",
                "deprecated": true
              },
              "currencyCode": {
                "$ref": "#/components/schemas/currency.json1"
              },
              "commissionableBid": {
                "type": "boolean",
                "description": "True indicates this is a commissionable bid.",
                "example": true
              },
              "commissionRate": {
                "type": "number",
                "description": "The proposal's commission rate.",
                "example": 10.12
              },
              "name": {
                "type": "string",
                "maxLength": 50,
                "description": "Name of the proposal.",
                "example": "Proposal for Royal Bank of Spain."
              },
              "blockCode": {
                "type": "string",
                "maxLength": 50,
                "description": "Block code for the proposal.",
                "example": "ABDCFD-234535-3535"
              },
              "proposalDates": {
                "type": "array",
                "description": "List of dates the venue is available.",
                "items": {
                  "$ref": "#/components/schemas/proposal-date.json"
                }
              },
              "sleepingRooms": {
                "type": "array",
                "description": "List of all sleeping rooms offered in the proposal.",
                "items": {
                  "$ref": "#/components/schemas/sleeping-room.json"
                }
              },
              "categoryItemsCost": {
                "$ref": "#/components/schemas/category-items-cost.json"
              },
              "aggregatedCost": {
                "$ref": "#/components/schemas/aggregated-cost.json"
              },
              "estimatedCost": {
                "$ref": "#/components/schemas/estimated-cost.json"
              },
              "contacts": {
                "type": "array",
                "description": "List of all contacts.",
                "items": {
                  "$ref": "#/components/schemas/contact.json1"
                }
              },
              "plannerContacts": {
                "type": "array",
                "description": "List of all planner contacts.",
                "items": {
                  "$ref": "#/components/schemas/contact.json1"
                }
              },
              "meetingRoom": {
                "$ref": "#/components/schemas/meeting-room.json"
              },
              "transaction": {
                "$ref": "#/components/schemas/transaction.json1"
              }
            }
          }
        ]
      },
      "ProposalResponse": {
        "description": "Schema for proposal.",
        "type": "object",
        "title": "Proposal",
        "allOf": [
          {
            "$ref": "#/components/schemas/ProposalRequest/allOf/0"
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "The unique ID of the proposal.",
            "example": "cf5fd2cc-3d09-11ee-be56-0242ac120002"
          },
          "proposalCode": {
            "type": "string",
            "minLength": 14,
            "maxLength": 14,
            "description": "A 14-character human readable proposal code.",
            "example": "P230810-G7T9DR"
          },
          "status": {
            "$ref": "#/components/schemas/proposal-status.json"
          },
          "version": {
            "type": "integer",
            "description": "The version number associated with the proposal.",
            "example": 1
          },
          "lastSubmittedTime": {
            "type": "string",
            "format": "date-time",
            "description": "The ISO 8601 zoned Coordinated Universal Time (UTC) when the proposal was last submitted.",
            "example": "2023-02-12T03:00:00Z"
          },
          "responseReason": {
            "type": "string",
            "description": "The reason for the response.",
            "oneOf": [
              {
                "$ref": "#/components/schemas/declined-reason.json"
              },
              {
                "$ref": "#/components/schemas/cancelled-reason.json"
              }
            ],
            "example": "BOOKED_ANOTHER_VENUE_DESTINATION"
          },
          "responseDetails": {
            "type": "string",
            "description": "Additional details provided while responding to the proposal.",
            "example": "The location is far from the event venue."
          }
        },
        "required": [
          "id",
          "proposalCode",
          "status",
          "version"
        ]
      },
      "proximity.json": {
        "description": "Proximity of the event venue to the hotel.",
        "title": "Proximity",
        "type": "object",
        "properties": {
          "distance": {
            "$ref": "#/components/schemas/distance.json1"
          },
          "mapMessage": {
            "description": "Message shown on map.",
            "type": "string",
            "example": "Your hotel is located here."
          }
        }
      },
      "public-usage-plan": {
        "title": "Public Usage Plan",
        "description": "Object representing an API Platform Usage Tier, including information when the usage plan is scheduled to revert to a previous plan, if any.",
        "type": "object",
        "allOf": [
          {
            "title": "Usage Plan",
            "description": "Object representing an API Platform Usage Tier",
            "required": [
              "name",
              "quota",
              "burstLimit",
              "rateLimit"
            ],
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "The name of the usage tier",
                "example": "API_Platform_Free_Tier"
              },
              "quota": {
                "type": "number",
                "description": "The daily quota of the usage tier. If this value is null, this means the usage tier is unlimited.",
                "example": 1000
              },
              "burstLimit": {
                "type": "number",
                "description": "The burst limit capacity of the usage tier",
                "example": 1
              },
              "rateLimit": {
                "type": "number",
                "description": "The per-second steady rate-limit of the usage tier",
                "example": 2
              }
            }
          }
        ],
        "properties": {
          "switchBackPlan": {
            "$ref": "#/components/schemas/switch-back-target-usage-plan.json"
          }
        }
      },
      "quantity-item": {
        "title": "Quantity Item",
        "description": "Represents a quantity item. A quantity item allows invitees to specify the amount of a particular product, such as raffle tickets, t-shirts, or tote bags, they would like to purchase.",
        "type": "object",
        "required": [
          "name"
        ],
        "allOf": [
          {
            "title": "Product",
            "description": "Represents a product. Products are items that can be purchased during registration.",
            "type": "object",
            "properties": {
              "registrantInformation": {
                "type": "string",
                "maxLength": 1000,
                "description": "This text will be displayed in emails using the registration information widget.",
                "example": "Registrant Note."
              }
            }
          }
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "A unique identifier of the quantity item.",
            "example": "04ca6ae2-0dc3-487b-953e-86d6abbdf7d3",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "Title of the quantity item.",
            "example": "General Quantity Item"
          },
          "description": {
            "type": "string",
            "description": "Description of the quantity item.",
            "maxLength": 2500,
            "example": "Some description of the quantity item."
          },
          "code": {
            "type": "string",
            "maxLength": 30,
            "description": "A planner-specified code for the quantity item. By default, it matches the title.",
            "example": "R5NP4NJYB3D"
          },
          "maximumItemsPerInvitee": {
            "type": "integer",
            "minimum": 1,
            "maximum": 32000,
            "description": "The maximum number of items that an invitee can purchase during registration.",
            "example": 10
          },
          "registrationTypes": {
            "maxItems": 200,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/registration-type-id.json"
            },
            "description": "Contains unique identifiers for registration types associated with this quantity item."
          },
          "openForRegistration": {
            "type": "boolean",
            "description": "True indicates the quantity item is selectable during registration.",
            "example": false
          },
          "automaticallyClosesOn": {
            "type": "string",
            "format": "date",
            "description": "The ISO 8601 formatted date when the quantity item registration automatically closes. The item closes at the start (12 AM) of the chosen date, according to UTC timezone.",
            "example": "2022-08-12"
          },
          "capacity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 999999,
            "description": "The maximum number of attendees who can purchase the quantity item.",
            "example": 150
          },
          "closeEventOnCapacityFull": {
            "type": "boolean",
            "description": "True indicates the event will close if the quantity item reaches capacity.",
            "example": false
          }
        }
      },
      "quantity-item-response": {
        "$ref": "#/components/schemas/quantity-item-update"
      },
      "quantity-item-update": {
        "title": "QuantityItemUpdate",
        "type": "object",
        "description": "Represents details for updating a quantity item for an attendee's registration.",
        "required": [
          "attendee",
          "updatedQuantity",
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "8163c74e-18c6-401a-a710-ae0f485bf059",
            "description": "Unique identifier of a quantity item."
          },
          "attendee": {
            "description": "The reference to the attendee. Contains only the ID of the attendee.",
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid",
                "example": "9463c74e-18c6-401a-a710-ae0f485bf059",
                "description": "Unique identifier of the attendee."
              }
            }
          },
          "updatedQuantity": {
            "type": "integer",
            "description": "Updated quantity of the item.",
            "example": 5
          },
          "sendEmail": {
            "type": "boolean",
            "description": "True indicates a registration modification email should be triggered after the request succeeds.",
            "example": false
          }
        }
      },
      "quantity-items-paginated-response": {
        "title": "Quantity Items Paginated Response",
        "required": [
          "data",
          "paging"
        ],
        "type": "object",
        "description": "A paginated response of quantity items objects.",
        "properties": {
          "paging": {
            "$ref": "#/components/schemas/paging.json"
          },
          "data": {
            "maxItems": 200,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/quantity-item"
            },
            "description": "Collection of quantity items."
          }
        }
      },
      "question": {
        "title": "Travel Program Question",
        "description": "A question, defined by the program, for the supplier to answer as part of their proposal.",
        "type": "object",
        "allOf": [
          {
            "$ref": "#/components/schemas/travel-account/allOf/0"
          }
        ],
        "properties": {
          "id": {
            "title": "Question ID",
