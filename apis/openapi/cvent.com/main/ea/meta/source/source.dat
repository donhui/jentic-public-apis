    "/usage": {
      "get": {
        "tags": [
          "Usage"
        ],
        "operationId": "getUsage",
        "summary": "Get Current Usage",
        "description": "Returns API call usage for the last seven days, or between some date range (up to the past seven days) for\nthe current caller's account.\n",
        "security": [
          {
            "OAuth2.clientCredentials": []
          }
        ],
        "parameters": [
          {
            "name": "before",
            "in": "query",
            "description": "Returns usage for the seven days before (inclusive) the date provided. If after is also provided, then\nonly the dates between (inclusive) those dates are returned. before must be a valid ISO8601 date stamp.\nbefore and after must not be more then seven days apart.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "after",
            "in": "query",
            "description": "Returns usage for the seven days after (inclusive) the date provided. If before is also provided, then\nonly the dates between (inclusive) those dates are returned. after must be a valid ISO8601 date stamp.\nafter and before must not be more then seven days apart.\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/usage-paginated-response"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest1"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized1"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden1"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests1"
          }
        }
      }
    },
    "/usage/tier": {
      "get": {
        "tags": [
          "Usage"
        ],
        "operationId": "getUsageTier",
        "summary": "Get Current Usage Tier",
        "description": "Returns the current usage tier of the caller's account.\n",
        "security": [
