          "description": "A filter query string narrows search results and supports the combination of logical and comparison operators. The filter adheres to the pattern filter='field' comparisonType 'value'.\nIn case user wants to filter on multiple survey IDs, they can use 'or' operator.\nFollowing are the comparison types that can be used in filter expressions:\n  * equal: eq\n  * not equal: ne\n\nThe following fields are filterable:\n  * id (eq|ne)\n  * type (eq|ne)\n",
          "schema": {
            "type": "string",
            "example": "id eq '04ca6ae2-0dc3-487b-953e-86d6abbdf7d3' and type eq 'Standalone'"
          }
        }
      ],
      "get": {
        "summary": "List Surveys",
        "description": "Gets a paginated list of event and standalone surveys associated to an account.",
        "operationId": "getSurvey",
        "security": [
          {
            "OAuth2.clientCredentials": [
              "survey/surveys:read"
            ]
          },
          {
            "OAuth2.authorizationCode": [
              "survey/surveys:read"
            ]
          }
        ],
        "tags": [
          "Surveys"
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved a paginated list of surveys.",
            "headers": {},
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/surveys-paginated-response"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest1"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized1"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden1"
          },
          "429": {
            "$ref": "#/components/responses/TooManyRequests1"
          }
        },
        "deprecated": false
      }
    },
