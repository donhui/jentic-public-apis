{
  "openapi": "3.0.3",
  "info": {
    "title": "Airtable Web API",
    "description": "Airtable REST API for managing bases, tables, records, fields, and webhooks.",
    "version": "0.1.0",
    "x-jentic-source-url": "https://airtable.com/developers/web/api/introduction"
  },
  "servers": [
    {"url": "https://api.airtable.com/v0"}
  ],
  "security": [
    {"bearerAuth": []}
  ],
  "tags": [
    {"name": "Records", "description": "Record operations"},
    {"name": "Bases", "description": "Base operations"},
    {"name": "Tables", "description": "Table operations"},
    {"name": "Fields", "description": "Field operations"},
    {"name": "Webhooks", "description": "Webhook operations"},
    {"name": "Users", "description": "User information"}
  ],
  "paths": {
    "/{baseId}/{tableIdOrName}": {
      "get": {
        "operationId": "listRecords",
        "tags": ["Records"],
        "summary": "List records in a table",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"$ref": "#/components/parameters/TableIdOrNameParam"},
          {"name": "fields[]", "in": "query", "description": "Only return specific fields", "schema": {"type": "array", "items": {"type": "string"}}},
          {"name": "filterByFormula", "in": "query", "schema": {"type": "string"}},
          {"name": "maxRecords", "in": "query", "schema": {"type": "integer"}},
          {"name": "pageSize", "in": "query", "schema": {"type": "integer", "maximum": 100}},
          {"name": "sort[0][field]", "in": "query", "schema": {"type": "string"}},
          {"name": "sort[0][direction]", "in": "query", "schema": {"type": "string", "enum": ["asc", "desc"]}},
          {"name": "view", "in": "query", "schema": {"type": "string"}},
          {"name": "offset", "in": "query", "schema": {"type": "string"}},
          {"name": "cellFormat", "in": "query", "schema": {"type": "string", "enum": ["json", "string"]}},
          {"name": "timeZone", "in": "query", "schema": {"type": "string"}},
          {"name": "userLocale", "in": "query", "schema": {"type": "string"}},
          {"name": "returnFieldsByFieldId", "in": "query", "schema": {"type": "boolean"}}
        ],
        "responses": {
          "200": {
            "description": "Records list",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecordList"}}}
          },
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "createRecords",
        "tags": ["Records"],
        "summary": "Create records",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"$ref": "#/components/parameters/TableIdOrNameParam"}
        ],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecordCreateRequest"}}}
        },
        "responses": {
          "200": {"description": "Records created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecordList"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateRecords",
        "tags": ["Records"],
        "summary": "Update records (partial update)",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"$ref": "#/components/parameters/TableIdOrNameParam"}
        ],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecordUpdateRequest"}}}
        },
        "responses": {
          "200": {"description": "Records updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecordList"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "put": {
        "operationId": "replaceRecords",
        "tags": ["Records"],
        "summary": "Replace records (full update)",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"$ref": "#/components/parameters/TableIdOrNameParam"}
        ],
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecordUpdateRequest"}}}
        },
        "responses": {
          "200": {"description": "Records replaced", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecordList"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/{baseId}/{tableIdOrName}/deleteRecords": {
      "delete": {
        "operationId": "deleteRecords",
        "tags": ["Records"],
        "summary": "Delete multiple records by IDs",
        "description": "Delete up to 10 records at a time by passing their IDs as query parameters.",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"$ref": "#/components/parameters/TableIdOrNameParam"},
          {"name": "records[]", "in": "query", "required": true, "description": "Record IDs to delete (up to 10)", "schema": {"type": "array", "items": {"type": "string"}}}
        ],
        "responses": {
          "200": {"description": "Records deleted", "content": {"application/json": {"schema": {"type": "object", "properties": {"records": {"type": "array", "items": {"type": "object", "properties": {"id": {"type": "string"}, "deleted": {"type": "boolean"}}}}}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/{baseId}/{tableIdOrName}/{recordId}": {
      "get": {
        "operationId": "getRecord",
        "tags": ["Records"],
        "summary": "Get a single record",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"$ref": "#/components/parameters/TableIdOrNameParam"},
          {"$ref": "#/components/parameters/RecordIdParam"},
          {"name": "returnFieldsByFieldId", "in": "query", "schema": {"type": "boolean"}}
        ],
        "responses": {
          "200": {"description": "Record details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Record"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "patch": {
        "operationId": "updateRecord",
        "tags": ["Records"],
        "summary": "Update a single record",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"$ref": "#/components/parameters/TableIdOrNameParam"},
          {"$ref": "#/components/parameters/RecordIdParam"}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/RecordFieldsInput"}}}},
        "responses": {
          "200": {"description": "Record updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Record"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteRecord",
        "tags": ["Records"],
        "summary": "Delete a record",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"$ref": "#/components/parameters/TableIdOrNameParam"},
          {"$ref": "#/components/parameters/RecordIdParam"}
        ],
        "responses": {
          "200": {"description": "Record deleted", "content": {"application/json": {"schema": {"type": "object", "properties": {"id": {"type": "string"}, "deleted": {"type": "boolean"}}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/meta/bases": {
      "get": {
        "operationId": "listBases",
        "tags": ["Bases"],
        "summary": "List all accessible bases",
        "parameters": [
          {"name": "offset", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "List of bases", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BaseList"}}}},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/meta/bases/{baseId}/tables": {
      "get": {
        "operationId": "listTables",
        "tags": ["Tables"],
        "summary": "List tables in a base",
        "parameters": [{"$ref": "#/components/parameters/BaseIdParam"}],
        "responses": {
          "200": {"description": "Tables list", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TableList"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "createTable",
        "tags": ["Tables"],
        "summary": "Create a table in a base",
        "parameters": [{"$ref": "#/components/parameters/BaseIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TableCreate"}}}},
        "responses": {
          "200": {"description": "Table created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Table"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/meta/bases/{baseId}/tables/{tableId}": {
      "patch": {
        "operationId": "updateTable",
        "tags": ["Tables"],
        "summary": "Update a table",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"name": "tableId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"name": {"type": "string"}, "description": {"type": "string"}}}}}},
        "responses": {
          "200": {"description": "Table updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Table"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/meta/bases/{baseId}/tables/{tableId}/fields": {
      "post": {
        "operationId": "createField",
        "tags": ["Fields"],
        "summary": "Create a field in a table",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"name": "tableId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/FieldCreate"}}}},
        "responses": {
          "200": {"description": "Field created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Field"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/meta/bases/{baseId}/tables/{tableId}/fields/{fieldId}": {
      "patch": {
        "operationId": "updateField",
        "tags": ["Fields"],
        "summary": "Update a field",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"name": "tableId", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "fieldId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/FieldCreate"}}}},
        "responses": {
          "200": {"description": "Field updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Field"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/bases/{baseId}/webhooks": {
      "get": {
        "operationId": "listWebhooks",
        "tags": ["Webhooks"],
        "summary": "List webhooks for a base",
        "parameters": [{"$ref": "#/components/parameters/BaseIdParam"}],
        "responses": {
          "200": {"description": "Webhooks list", "content": {"application/json": {"schema": {"type": "object", "properties": {"webhooks": {"type": "array", "items": {"$ref": "#/components/schemas/Webhook"}}}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "post": {
        "operationId": "createWebhook",
        "tags": ["Webhooks"],
        "summary": "Create a webhook",
        "parameters": [{"$ref": "#/components/parameters/BaseIdParam"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/WebhookCreate"}}}},
        "responses": {
          "200": {"description": "Webhook created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Webhook"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/bases/{baseId}/webhooks/{webhookId}/payloads": {
      "get": {
        "operationId": "listWebhookPayloads",
        "tags": ["Webhooks"],
        "summary": "List payloads for a webhook",
        "description": "Retrieve notification payloads for a webhook. Use cursor parameter to page through results.",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"name": "webhookId", "in": "path", "required": true, "schema": {"type": "string"}},
          {"name": "cursor", "in": "query", "description": "Pagination cursor from previous response", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {"description": "Webhook payloads", "content": {"application/json": {"schema": {"type": "object", "properties": {"payloads": {"type": "array", "items": {"type": "object", "properties": {"timestamp": {"type": "string", "format": "date-time"}, "baseTransactionNumber": {"type": "integer"}, "payloadFormat": {"type": "string"}, "actionMetadata": {"type": "object"}}}}, "cursor": {"type": "integer"}, "mightHaveMore": {"type": "boolean"}}}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/bases/{baseId}/webhooks/{webhookId}/enableNotifications": {
      "post": {
        "operationId": "enableWebhookNotifications",
        "tags": ["Webhooks"],
        "summary": "Enable notifications for a webhook",
        "description": "Re-enable notifications for a webhook that had notifications disabled due to too many errors.",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"name": "webhookId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Notifications enabled"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/bases/{baseId}/webhooks/{webhookId}": {
      "patch": {
        "operationId": "updateWebhook",
        "tags": ["Webhooks"],
        "summary": "Update a webhook",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"name": "webhookId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/WebhookCreate"}}}},
        "responses": {
          "200": {"description": "Webhook updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Webhook"}}}},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteWebhook",
        "tags": ["Webhooks"],
        "summary": "Delete a webhook",
        "parameters": [
          {"$ref": "#/components/parameters/BaseIdParam"},
          {"name": "webhookId", "in": "path", "required": true, "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {"description": "Webhook deleted"},
          "400": {"$ref": "#/components/responses/BadRequest"},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    },
    "/meta/whoami": {
      "get": {
        "operationId": "whoami",
        "tags": ["Users"],
        "summary": "Get current user information",
        "responses": {
          "200": {"description": "User info", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UserInfo"}}}},
          "401": {"$ref": "#/components/responses/Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "parameters": {
      "BaseIdParam": {"name": "baseId", "in": "path", "required": true, "schema": {"type": "string"}},
      "TableIdOrNameParam": {"name": "tableIdOrName", "in": "path", "required": true, "schema": {"type": "string"}},
      "RecordIdParam": {"name": "recordId", "in": "path", "required": true, "schema": {"type": "string"}}
    },
    "schemas": {
      "Record": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "createdTime": {"type": "string", "format": "date-time"},
          "fields": {"type": "object", "additionalProperties": true}
        }
      },
      "RecordList": {
        "type": "object",
        "properties": {
          "records": {"type": "array", "items": {"$ref": "#/components/schemas/Record"}},
          "offset": {"type": "string"}
        }
      },
      "RecordFieldsInput": {
        "type": "object",
        "properties": {
          "fields": {"type": "object", "additionalProperties": true},
          "typecast": {"type": "boolean"}
        }
      },
      "RecordCreateRequest": {
        "type": "object",
        "properties": {
          "records": {"type": "array", "items": {"$ref": "#/components/schemas/RecordFieldsInput"}},
          "typecast": {"type": "boolean"},
          "returnFieldsByFieldId": {"type": "boolean"}
        }
      },
      "RecordUpdateRequest": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id"],
              "properties": {
                "id": {"type": "string"},
                "fields": {"type": "object", "additionalProperties": true}
              }
            }
          },
          "typecast": {"type": "boolean"},
          "returnFieldsByFieldId": {"type": "boolean"}
        }
      },
      "BaseList": {
        "type": "object",
        "properties": {
          "bases": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Base"}
          },
          "offset": {"type": "string"}
        }
      },
      "Base": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "permissionLevel": {"type": "string", "enum": ["none", "read", "comment", "edit", "create"]}
        }
      },
      "TableList": {
        "type": "object",
        "properties": {
          "tables": {"type": "array", "items": {"$ref": "#/components/schemas/Table"}}
        }
      },
      "Table": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "primaryFieldId": {"type": "string"},
          "fields": {"type": "array", "items": {"$ref": "#/components/schemas/Field"}},
          "views": {"type": "array", "items": {"$ref": "#/components/schemas/View"}}
        }
      },
      "TableCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"},
          "fields": {"type": "array", "items": {"$ref": "#/components/schemas/FieldCreate"}}
        }
      },
      "Field": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "type": {"type": "string"},
          "description": {"type": "string"},
          "options": {"type": "object", "additionalProperties": true}
        }
      },
      "FieldCreate": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string"},
          "description": {"type": "string"},
          "options": {"type": "object", "additionalProperties": true}
        }
      },
      "View": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "type": {"type": "string"}
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "isEnabled": {"type": "boolean"},
          "notificationUrl": {"type": "string"},
          "cursorForNextPayload": {"type": "integer"},
          "areNotificationsEnabled": {"type": "boolean"},
          "createdTime": {"type": "string", "format": "date-time"},
          "specification": {"type": "object", "properties": {"options": {"type": "object"}}}
        }
      },
      "WebhookCreate": {
        "type": "object",
        "required": ["notificationUrl"],
        "properties": {
          "notificationUrl": {"type": "string"},
          "specification": {"type": "object", "properties": {"options": {"type": "object"}}}
        }
      },
      "UserInfo": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "email": {"type": "string"},
          "scopes": {"type": "array", "items": {"type": "string"}}
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "type": {"type": "string"},
              "message": {"type": "string"}
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {"description": "Bad request", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}},
      "Unauthorized": {"description": "Unauthorized - invalid or missing bearer token"}
    }
  }
}
