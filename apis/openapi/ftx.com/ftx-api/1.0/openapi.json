                  "market": { "type": "string", "example": "BTC/USD" },
                  "side": { "type": "string", "enum": ["buy", "sell"] },
                  "price": { "type": "number", "nullable": true, "description": "Required for limit orders." },
                  "type": { "type": "string", "enum": ["limit", "market"] },
                  "size": { "type": "number" },
                  "reduceOnly": { "type": "boolean", "default": false },
                  "ioc": { "type": "boolean", "default": false },
                  "postOnly": { "type": "boolean", "default": false },
                  "clientId": { "type": "string", "nullable": true }
                }
              }
