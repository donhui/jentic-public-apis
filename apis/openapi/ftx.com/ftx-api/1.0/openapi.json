                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/markets/{market_name}/candles": {
      "get": {
        "summary": "Get historical prices",
        "description": "Get historical OHLCV candlestick data.",
        "operationId": "getCandles",
        "tags": ["Markets"],
        "security": [],
        "parameters": [
          {
            "name": "market_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "resolution",
            "in": "query",
            "required": true,
            "description": "Window length in seconds. Options: 15, 60, 300, 900, 3600, 14400, 86400.",
            "schema": { "type": "integer", "enum": [15, 60, 300, 900, 3600, 14400, 86400] }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 1501, "maximum": 5000 }
          },
          {
            "name": "start_time",
            "in": "query",
            "schema": { "type": "number" }
          },
          {
            "name": "end_time",
            "in": "query",
            "schema": { "type": "number" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "result": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "startTime": { "type": "string", "format": "date-time" },
                          "time": { "type": "number" },
                          "open": { "type": "number" },
                          "high": { "type": "number" },
                          "low": { "type": "number" },
                          "close": { "type": "number" },
                          "volume": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
