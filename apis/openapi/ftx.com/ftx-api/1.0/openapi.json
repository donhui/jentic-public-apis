{
  "openapi": "3.0.3",
  "info": {
    "title": "FTX API",
    "description": "FTX cryptocurrency exchange REST API for trading, market data, and account management. Note: FTX filed for bankruptcy in November 2022 and is no longer operational.",
    "version": "1.0",
    "contact": {
      "name": "FTX",
      "url": "https://ftx.com"
    }
  },
  "servers": [
    {
      "url": "https://ftx.com/api"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": [],
      "ApiSignature": [],
      "ApiTimestamp": []
    }
  ],
  "paths": {
    "/markets": {
      "get": {
        "summary": "List markets",
        "description": "Get a list of all available markets.",
        "operationId": "getMarkets",
        "tags": ["Markets"],
        "security": [],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "result": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Market" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/markets/{market_name}": {
      "get": {
        "summary": "Get single market",
        "description": "Get details of a specific market.",
        "operationId": "getMarket",
        "tags": ["Markets"],
        "security": [],
        "parameters": [
          {
            "name": "market_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "BTC/USD"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "result": { "$ref": "#/components/schemas/Market" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/markets/{market_name}/orderbook": {
      "get": {
        "summary": "Get orderbook",
        "description": "Get the orderbook for a market.",
        "operationId": "getOrderbook",
        "tags": ["Markets"],
        "security": [],
        "parameters": [
          {
            "name": "market_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "depth",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "result": {
                      "type": "object",
                      "properties": {
                        "asks": {
                          "type": "array",
                          "items": {
                            "type": "array",
                            "items": { "type": "number" }
                          }
                        },
                        "bids": {
                          "type": "array",
                          "items": {
                            "type": "array",
                            "items": { "type": "number" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/markets/{market_name}/trades": {
      "get": {
        "summary": "Get trades",
        "description": "Get recent trades for a market.",
        "operationId": "getTrades",
        "tags": ["Markets"],
        "security": [],
        "parameters": [
          {
            "name": "market_name",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20, "maximum": 100 }
          },
          {
            "name": "start_time",
            "in": "query",
            "schema": { "type": "number", "description": "Unix timestamp" }
          },
          {
            "name": "end_time",
            "in": "query",
            "schema": { "type": "number", "description": "Unix timestamp" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "result": {
                      "type": "array",
