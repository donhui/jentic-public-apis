            "description": "Tax deduction percentage. Range: 9.9-70."
          },
          "contactPersonName": {
            "type": "string",
            "description": "Name of the contact person."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Client email address."
          },
          "address": {
            "type": "string",
            "description": "Client address."
          }
