            "type": "number",
            "format": "double",
            "description": "Estimated annual self-employed income."
          },
          "estimatedSalaryIncome": {
            "type": "number",
            "format": "double",
            "description": "Estimated annual salary income from other employment."
          },
          "estimatedOtherIncome": {
            "type": "number",
            "format": "double",
            "description": "Estimated annual other income."
          },
