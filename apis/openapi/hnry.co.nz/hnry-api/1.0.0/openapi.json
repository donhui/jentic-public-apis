          },
          "studentLoan": {
            "type": "boolean",
            "description": "Whether the user has a student loan."
          },
          "registeredBusiness": {
            "type": "boolean",
            "description": "Whether the user has a registered business."
          },
          "taxIdentificationNumber": {
            "type": "string",
            "description": "Tax identification number (IRD number for NZ, TFN for AU)."
