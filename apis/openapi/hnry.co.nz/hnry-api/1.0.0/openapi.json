              },
              "periodEndDate": {
                "type": "string",
                "format": "date",
                "description": "End date of the invoicing period."
              },
              "poNumber": {
                "type": "string",
                "description": "Purchase order number."
              },
              "status": {
                "type": "string",
                "enum": [
                  "DRAFT",
                  "SENT",
                  "VOID"
                ],
                "description": "Status of the invoice."
