            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "The ID of the invoice to update."
              },
              "clientId": {
                "type": "string",
                "description": "Global ID of the client."
              },
              "dueDate": {
                "type": "string",
                "format": "date",
                "description": "Updated due date."
              },
              "invoiceDate": {
                "type": "string",
                "format": "date",
                "description": "Updated invoice date."
              },
              "periodStartDate": {
                "type": "string",
                "format": "date",
                "description": "Updated period start date."
              },
              "periodEndDate": {
                "type": "string",
                "format": "date",
                "description": "Updated period end date."
              },
              "poNumber": {
                "type": "string",
                "description": "Updated purchase order number."
              },
              "status": {
                "type": "string",
                "enum": [
                  "DRAFT",
                  "SENT",
                  "VOID"
                ],
                "description": "Updated status. Only editable by the creating application. Status changes limited to DRAFT, SENT, or VOID."
              },
              "externalIdentifier": {
                "type": "string",
                "description": "Updated external identifier."
              },
              "invoiceItems": {
                "$ref": "#/components/schemas/InvoiceItemsUpdateInput"
              }
            }
          }
        }
      },
      "InvoiceItemsUpdateInput": {
        "type": "object",
        "description": "Input for bulk updating invoice items. Supports creating, updating, and deleting items in a single operation.",
        "properties": {
          "create": {
            "type": "array",
            "description": "New invoice items to create.",
            "items": {
              "$ref": "#/components/schemas/InvoiceItemCreationInput"
            }
          },
          "update": {
            "type": "array",
            "description": "Existing invoice items to update.",
            "items": {
              "$ref": "#/components/schemas/InvoiceItemUpdateInput"
            }
          },
          "delete": {
            "type": "array",
            "description": "IDs of invoice items to delete.",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "InvoiceItemUpdateInput": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "ID of the invoice item to update."
          },
          "description": {
            "type": "string",
            "description": "Updated description."
          },
          "quantity": {
            "type": "number",
            "format": "float",
            "description": "Updated quantity."
          },
          "price": {
            "type": "number",
            "format": "float",
            "description": "Updated price."
          }
        }
      },
      "PayLine": {
        "type": "object",
        "description": "A payslip/payline record for the user.",
