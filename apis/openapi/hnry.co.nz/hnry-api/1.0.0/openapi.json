            "$ref": "#/components/schemas/InvoiceItemCreationInput"
          }
        }
      },
      "UpdateInvoiceInput": {
        "type": "object",
        "required": [
          "invoice"
        ],
        "properties": {
          "invoice": {
            "type": "object",
            "required": [
