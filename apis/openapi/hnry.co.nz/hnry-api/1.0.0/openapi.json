{
  "openapi": "3.0.3",
  "info": {
    "title": "Hnry Partner API",
    "description": "Hnry Partner API provides a GraphQL interface for partners to manage users, invoices, expenses, clients, and payslips on the Hnry platform. Hnry is a tax management service for freelancers and self-employed individuals in New Zealand and Australia. All operations are performed via a single GraphQL endpoint using POST requests with JSON-encoded query bodies.",
    "version": "1.0.0",
    "contact": {
      "name": "Hnry Partners",
      "email": "partners@hnry.co.nz",
      "url": "https://hnry.co.nz"
    },
    "x-jentic-source-url": "https://hnrynz.github.io/hnry-apidocs/"
  },
  "servers": [
    {
      "url": "https://app.hnry.io",
      "description": "Hnry Production"
    }
  ],
  "paths": {
    "/graphql": {
      "post": {
        "summary": "Execute a GraphQL query or mutation",
        "description": "Single endpoint for all Hnry Partner API GraphQL operations. Send a JSON body containing the GraphQL query/mutation string and any variables. Supported queries: clientSearch, expenseSearch, invoice, invoiceSearch, payLineSearch. Supported mutations: createClient, createExpense, createInvoice, createInvoiceItem, deleteExpense, registerUser, updateInvoice.",
        "operationId": "executeGraphQL",
        "tags": [
          "GraphQL"
        ],
        "security": [
          {
            "oauth2": [
              "user:show"
            ]
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GraphQLRequest"
              },
              "examples": {
                "clientSearch": {
                  "summary": "Search for clients by name",
                  "value": {
                    "query": "query ClientSearch($name: String) { clientSearch(name: $name) { ... on Clients { clients { id name taxDeductionPercentage contactPersonName email address link } } ... on AuthenticationError { message } ... on AuthorizationError { message } } }",
                    "variables": {
                      "name": "Acme"
                    }
                  }
                },
                "expenseSearch": {
                  "summary": "Search expenses by IDs",
                  "value": {
                    "query": "query ExpenseSearch($ids: [String!]) { expenseSearch(ids: $ids) { ... on Expenses { expenses { id description expenseDate status salesTaxInclusiveCost salesTaxAmount businessPurposePercentage expenseType receipt { url filename } } } ... on AuthenticationError { message } ... on AuthorizationError { message } } }",
                    "variables": {
                      "ids": [
                        "abc123"
                      ]
                    }
                  }
                },
                "invoice": {
                  "summary": "Retrieve a specific invoice",
                  "value": {
                    "query": "query Invoice($id: ID!) { invoice(id: $id) { ... on Invoice { id invoiceNumber status dueDate invoiceDate periodStartDate periodEndDate poNumber externalIdentifier client { id name } invoiceItems { id description quantity price } } ... on AuthenticationError { message } ... on AuthorizationError { message } } }",
                    "variables": {
                      "id": "inv_123"
                    }
                  }
                },
                "invoiceSearch": {
                  "summary": "Search invoices with filters",
                  "value": {
                    "query": "query InvoiceSearch($clientId: String, $poNumber: String, $onlyDraft: Boolean) { invoiceSearch(clientId: $clientId, poNumber: $poNumber, onlyDraft: $onlyDraft) { ... on Invoices { invoices { id invoiceNumber status dueDate client { id name } invoiceItems { id description quantity price } } } ... on AuthenticationError { message } ... on AuthorizationError { message } } }",
                    "variables": {
                      "clientId": "client_123",
                      "onlyDraft": false
                    }
                  }
                },
                "payLineSearch": {
                  "summary": "Retrieve all user payslips",
                  "value": {
                    "query": "query PayLineSearch { payLineSearch { ... on PayLines { payLines { grossPayment taxableIncome paidAt client { id name } invoice { id invoiceNumber } } } ... on AuthenticationError { message } ... on AuthorizationError { message } } }"
                  }
                },
                "createClient": {
                  "summary": "Create a new client",
                  "value": {
                    "query": "mutation CreateClient($input: CreateClientInput!) { createClient(input: $input) { ... on Client { id name taxDeductionPercentage contactPersonName email address link } ... on AuthenticationError { message } ... on AuthorizationError { message } ... on ValidationError { message fieldErrors { path message } } } }",
                    "variables": {
                      "input": {
                        "client": {
                          "name": "Acme Corp",
                          "taxDeductionPercentage": 33.0,
                          "contactPersonName": "John Doe",
                          "email": "john@acme.com",
                          "address": "123 Main St, Auckland"
                        }
                      }
                    }
                  }
                },
                "createExpense": {
                  "summary": "Create a new expense",
                  "value": {
                    "query": "mutation CreateExpense($input: CreateExpenseInput!) { createExpense(input: $input) { ... on Expense { id description expenseDate status salesTaxInclusiveCost salesTaxAmount businessPurposePercentage expenseType } ... on AuthenticationError { message } ... on AuthorizationError { message } ... on ValidationError { message fieldErrors { path message } } } }",
                    "variables": {
                      "input": {
                        "expense": {
                          "description": "Office supplies",
                          "expenseDate": "2026-03-24T00:00:00Z",
                          "expenseType": "BUSINESS_EXPENSE",
                          "salesTaxInclusiveCost": 115.00,
                          "salesTaxAmount": 15.00,
                          "businessPurposePercentage": 100
                        }
                      }
                    }
                  }
                },
                "createInvoice": {
                  "summary": "Create a new draft invoice",
                  "value": {
                    "query": "mutation CreateInvoice($input: CreateInvoiceInput!) { createInvoice(input: $input) { ... on Invoice { id invoiceNumber status dueDate invoiceDate client { id name } invoiceItems { id description quantity price } } ... on AuthenticationError { message } ... on AuthorizationError { message } ... on ValidationError { message fieldErrors { path message } } } }",
                    "variables": {
                      "input": {
                        "invoice": {
                          "clientId": "client_123",
                          "invoiceDate": "2026-03-24",
                          "dueDate": "2026-04-24",
                          "poNumber": "PO-001",
                          "status": "DRAFT"
                        },
                        "invoiceItems": [
                          {
                            "description": "Consulting services",
                            "quantity": 10,
                            "price": 150.00
                          }
                        ]
                      }
                    }
                  }
                },
                "createInvoiceItem": {
                  "summary": "Create an invoice line item",
                  "value": {
                    "query": "mutation CreateInvoiceItem($input: CreateInvoiceItemInput!) { createInvoiceItem(input: $input) { ... on InvoiceItem { id description quantity price } ... on AuthenticationError { message } ... on AuthorizationError { message } ... on ValidationError { message fieldErrors { path message } } } }",
                    "variables": {
                      "input": {
                        "invoiceId": "inv_123",
                        "invoiceItem": {
                          "description": "Additional hours",
                          "quantity": 5,
                          "price": 150.00
                        }
                      }
                    }
                  }
                },
                "deleteExpense": {
                  "summary": "Delete an expense",
                  "value": {
                    "query": "mutation DeleteExpense($input: DeleteExpenseInput!) { deleteExpense(input: $input) { ... on ExpenseDeletionSuccess { message } ... on AuthenticationError { message } ... on AuthorizationError { message } ... on ValidationError { message fieldErrors { path message } } } }",
                    "variables": {
                      "input": {
                        "expense": {
                          "id": "exp_123"
                        }
                      }
                    }
                  }
                },
                "registerUser": {
                  "summary": "Register or update a user",
                  "value": {
                    "query": "mutation RegisterUser($input: RegisterUserInput!) { registerUser(input: $input) { ... on User { id firstName lastName phoneNumber } ... on AuthenticationError { message } ... on AuthorizationError { message } ... on ValidationError { message fieldErrors { path message } } } }",
                    "variables": {
                      "input": {
                        "user": {
                          "firstName": "Jane",
                          "lastName": "Doe",
                          "phoneNumber": "+6421234567",
                          "birthDate": "1990-01-15",
                          "workType": "Software Development",
                          "jurisdiction": {
                            "code": "NZ",
                            "tradingSituation": "SOLE_TRADER",
                            "estimatedSelfEmployedIncome": 80000,
                            "salesTaxRegistered": true,
                            "studentLoan": false,
                            "registeredBusiness": false,
                            "clients": [
                              {
                                "name": "Acme Corp"
                              }
                            ]
                          },
                          "address": {
                            "streetAddress": "123 Main St",
                            "postalCode": "1010",
                            "addressLocality": "Auckland",
                            "addressCountry": "NZ"
                          }
                        }
                      }
                    }
                  }
                },
                "updateInvoice": {
                  "summary": "Update an existing invoice",
                  "value": {
                    "query": "mutation UpdateInvoice($input: UpdateInvoiceInput!) { updateInvoice(input: $input) { ... on Invoice { id invoiceNumber status dueDate invoiceDate client { id name } invoiceItems { id description quantity price } } ... on AuthenticationError { message } ... on AuthorizationError { message } ... on ValidationError { message fieldErrors { path message } } } }",
                    "variables": {
                      "input": {
                        "invoice": {
                          "id": "inv_123",
                          "dueDate": "2026-05-01",
                          "status": "SENT"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful GraphQL response. The data field contains the result of the query or mutation. Errors may still be present in the errors field for partial failures.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphQLResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication error - invalid or expired access token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GraphQLResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded. The registerUser mutation is limited to 30 requests per client per day."
          }
        }
      }
    },
    "/oauth/authorize": {
      "get": {
        "summary": "OAuth2 Authorization Endpoint",
        "description": "Initiates the OAuth2 Authorization Code with PKCE flow. Redirect the user to this endpoint to begin authorization.",
        "operationId": "oauthAuthorize",
        "tags": [
          "OAuth"
        ],
        "parameters": [
          {
            "name": "response_type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "code"
              ]
            },
            "description": "Must be 'code' for authorization code flow."
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The client ID issued to the partner application."
          },
          {
            "name": "redirect_uri",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "description": "The URI to redirect the user to after authorization."
          },
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Space-separated list of requested scopes. Available scopes: user:show, user:update, bank_account:show, expense:create."
          },
          {
            "name": "code_challenge",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "PKCE code challenge derived from the code verifier."
          },
          {
            "name": "code_challenge_method",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "S256"
              ]
            },
            "description": "PKCE code challenge method. Must be 'S256'."
          },
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Opaque value to maintain state between request and callback."
          }
        ],
        "responses": {
          "302": {
            "description": "Redirects the user to the Hnry login/authorization page."
          }
        }
      }
    },
    "/oauth/token": {
      "post": {
        "summary": "OAuth2 Token Endpoint",
        "description": "Exchange an authorization code for an access token, or refresh an existing token.",
        "operationId": "oauthToken",
        "tags": [
          "OAuth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "authorization_code",
                      "refresh_token"
                    ],
                    "description": "The type of grant being requested."
                  },
                  "code": {
                    "type": "string",
                    "description": "The authorization code received from the authorize endpoint. Required when grant_type is 'authorization_code'."
                  },
                  "redirect_uri": {
                    "type": "string",
                    "format": "uri",
                    "description": "Must match the redirect_uri used in the authorization request."
                  },
                  "client_id": {
                    "type": "string",
                    "description": "The client ID issued to the partner application."
                  },
                  "code_verifier": {
                    "type": "string",
                    "description": "PKCE code verifier. Required when grant_type is 'authorization_code'."
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "The refresh token. Required when grant_type is 'refresh_token'."
                  }
                },
                "required": [
                  "grant_type",
                  "client_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful token response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request - missing or invalid parameters"
          },
          "401": {
            "description": "Invalid client credentials or authorization code"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth2 Authorization Code flow with PKCE for partner authentication.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://app.hnry.io/oauth/authorize",
            "tokenUrl": "https://app.hnry.io/oauth/token",
            "scopes": {
              "user:show": "View Hnry user profile information",
              "user:update": "Modify Hnry user profile information",
              "bank_account:show": "Access bank account details",
              "expense:create": "Create expenses on behalf of the user"
            }
          }
        }
      }
    },
    "schemas": {
      "GraphQLRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "The GraphQL query or mutation string."
          },
          "variables": {
            "type": "object",
            "description": "Variables for the GraphQL operation.",
            "additionalProperties": true
          },
          "operationName": {
            "type": "string",
            "description": "The name of the operation to execute, if the query contains multiple operations."
          }
        }
      },
      "GraphQLResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "description": "The result data from the GraphQL operation.",
            "additionalProperties": true
          },
          "errors": {
            "type": "array",
            "description": "Any errors that occurred during the operation.",
            "items": {
              "$ref": "#/components/schemas/GraphQLError"
            }
          }
        }
      },
      "GraphQLError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "A human-readable error message."
          },
          "locations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "line": {
                  "type": "integer"
                },
                "column": {
                  "type": "integer"
                }
              }
            }
          },
          "path": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "OAuthTokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The access token to use for API requests."
          },
          "token_type": {
            "type": "string",
            "enum": [
              "Bearer"
            ],
            "description": "The type of token issued."
          },
          "expires_in": {
            "type": "integer",
            "description": "The lifetime of the access token in seconds."
          },
          "refresh_token": {
            "type": "string",
            "description": "The refresh token to obtain new access tokens."
          },
          "scope": {
            "type": "string",
            "description": "The scopes granted for this token."
          }
        }
      },
      "Client": {
        "type": "object",
        "description": "A client entity representing a business or individual that the user invoices.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the client."
          },
          "name": {
            "type": "string",
            "description": "The name of the client."
          },
          "taxDeductionPercentage": {
            "type": "number",
            "format": "double",
            "description": "Tax deduction percentage for this client. Range: 9.9 to 70.",
            "minimum": 9.9,
            "maximum": 70
          },
          "contactPersonName": {
            "type": "string",
            "description": "Name of the contact person at the client."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address for the client."
          },
          "address": {
            "type": "string",
            "description": "Physical address of the client."
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "URL link associated with the client."
          }
        }
      },
      "CreateClientInput": {
        "type": "object",
        "required": [
          "client"
        ],
        "properties": {
          "client": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "The name of the client."
              },
              "taxDeductionPercentage": {
                "type": "number",
                "format": "double",
                "description": "Tax deduction percentage. Defaults to 0.0. Range: 9.9-70.",
                "default": 0.0,
                "minimum": 9.9,
                "maximum": 70
              },
              "contactPersonName": {
                "type": "string",
                "description": "Name of the contact person."
              },
              "email": {
                "type": "string",
                "format": "email",
                "description": "Email address for the client."
              },
              "address": {
                "type": "string",
                "description": "Physical address of the client."
              }
            }
          }
        }
      },
      "Expense": {
        "type": "object",
        "description": "An expense record for the user.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the expense."
          },
          "description": {
            "type": "string",
            "description": "Description of the expense."
          },
          "expenseDate": {
            "type": "string",
            "format": "date-time",
            "description": "Date of the expense in ISO 8601 format."
          },
          "status": {
            "type": "string",
            "description": "Current status of the expense."
          },
          "salesTaxInclusiveCost": {
            "type": "number",
            "format": "float",
            "description": "Total cost including sales tax."
          },
          "salesTaxAmount": {
            "type": "number",
            "format": "float",
            "description": "Amount of sales tax included."
          },
          "businessPurposePercentage": {
            "type": "integer",
            "description": "Percentage of the expense used for business purposes."
          },
          "expenseType": {
            "type": "string",
            "enum": [
              "BUSINESS_EXPENSE",
              "CLIENT_REIMBURSEMENT"
            ],
            "description": "Type of expense."
          },
          "receipt": {
            "$ref": "#/components/schemas/Receipt"
          }
        }
      },
      "CreateExpenseInput": {
        "type": "object",
        "required": [
          "expense"
        ],
        "properties": {
          "expense": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string",
                "description": "Description of the expense."
              },
              "expenseDate": {
                "type": "string",
                "format": "date-time",
                "description": "Date of the expense in ISO 8601 format."
              },
              "expenseType": {
                "type": "string",
                "enum": [
                  "BUSINESS_EXPENSE",
                  "CLIENT_REIMBURSEMENT"
                ],
                "description": "Type of expense."
              },
              "salesTaxInclusiveCost": {
                "type": "number",
                "format": "float",
                "description": "Total cost including sales tax."
              },
              "salesTaxAmount": {
                "type": "number",
                "format": "float",
                "description": "Amount of sales tax."
              },
              "businessPurposePercentage": {
                "type": "integer",
                "description": "Percentage used for business purposes."
              },
              "receipt": {
                "type": "string",
                "format": "binary",
                "description": "Receipt file upload."
              }
            }
          }
        }
      },
      "DeleteExpenseInput": {
        "type": "object",
        "required": [
          "expense"
        ],
        "properties": {
          "expense": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "The ID of the expense to delete."
              }
            }
          }
        }
      },
      "Receipt": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the receipt file."
          },
          "filename": {
            "type": "string",
            "description": "Filename of the receipt."
          }
        }
      },
      "Invoice": {
        "type": "object",
        "description": "An invoice created by the user.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the invoice."
          },
          "invoiceNumber": {
            "type": "string",
            "description": "Human-readable invoice number."
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "SENT",
              "VOID"
            ],
            "description": "Current status of the invoice."
          },
          "dueDate": {
            "type": "string",
            "format": "date",
            "description": "Due date of the invoice."
          },
          "invoiceDate": {
            "type": "string",
            "format": "date",
            "description": "Date the invoice was issued."
          },
          "periodStartDate": {
            "type": "string",
            "format": "date",
            "description": "Start date of the invoicing period."
          },
          "periodEndDate": {
            "type": "string",
            "format": "date",
            "description": "End date of the invoicing period."
          },
          "poNumber": {
            "type": "string",
            "description": "Purchase order number."
          },
          "externalIdentifier": {
            "type": "string",
            "description": "External identifier for partner system reference."
          },
          "client": {
            "$ref": "#/components/schemas/Client"
          },
          "invoiceItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvoiceItem"
            }
          }
        }
      },
      "InvoiceItem": {
        "type": "object",
        "description": "A line item on an invoice.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the invoice item."
          },
          "description": {
            "type": "string",
            "description": "Description of the line item."
          },
          "quantity": {
            "type": "number",
            "format": "float",
            "description": "Quantity of items or hours."
          },
          "price": {
            "type": "number",
            "format": "float",
            "description": "Unit price."
          }
        }
      },
      "CreateInvoiceInput": {
        "type": "object",
        "required": [
          "invoice"
        ],
        "properties": {
          "invoice": {
            "type": "object",
            "required": [
              "clientId"
            ],
            "properties": {
              "clientId": {
                "type": "string",
                "description": "Global ID of the client for this invoice."
              },
              "invoiceDate": {
                "type": "string",
                "format": "date",
                "description": "Date of the invoice."
              },
              "dueDate": {
                "type": "string",
                "format": "date",
                "description": "Due date of the invoice."
              },
              "periodStartDate": {
                "type": "string",
                "format": "date",
