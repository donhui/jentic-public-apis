              "firstName",
              "lastName",
              "workType",
              "jurisdiction"
            ],
            "properties": {
              "firstName": {
                "type": "string",
                "description": "User's first name."
              },
              "lastName": {
                "type": "string",
                "description": "User's last name."
              },
              "preferredName": {
                "type": "string",
                "description": "User's preferred name."
              },
              "middleName": {
                "type": "string",
                "description": "User's middle name."
              },
              "phoneNumber": {
                "type": "string",
                "description": "User's phone number in E.164 format (e.g., +6421234567)."
              },
              "birthDate": {
                "type": "string",
                "format": "date",
                "description": "User's date of birth in ISO 8601 format."
              },
              "workType": {
                "type": "string",
                "description": "Type of work the user performs (e.g., 'Software Development')."
