      "AuthenticationError": {
        "type": "object",
        "description": "Returned when the provided credentials are invalid.",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message describing the authentication failure."
          }
        }
      },
      "AuthorizationError": {
        "type": "object",
        "description": "Returned when the user lacks sufficient permissions/scopes.",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message describing the authorization failure."
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "description": "Returned when input data is invalid.",
        "properties": {
          "message": {
            "type": "string",
            "description": "General validation error message."
          },
          "fieldErrors": {
            "type": "array",
            "description": "Specific field-level validation errors.",
            "items": {
              "$ref": "#/components/schemas/FieldError"
            }
          }
        }
      },
      "FieldError": {
        "type": "object",
        "properties": {
          "path": {
            "type": "array",
            "description": "Path to the field that caused the error.",
            "items": {
              "type": "string"
            }
          },
          "message": {
            "type": "string",
            "description": "Description of the validation error."
          }
        }
      }
    }
