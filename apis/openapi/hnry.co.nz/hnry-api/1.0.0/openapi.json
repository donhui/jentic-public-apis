              "externalIdentifier": {
                "type": "string",
                "description": "External identifier for partner system reference."
              }
            }
          },
          "invoiceItems": {
            "type": "array",
            "description": "Line items for the invoice.",
            "items": {
              "$ref": "#/components/schemas/InvoiceItemCreationInput"
            }
          }
        }
      },
      "InvoiceItemCreationInput": {
        "type": "object",
        "required": [
          "quantity",
          "price"
        ],
        "properties": {
          "description": {
            "type": "string",
            "description": "Description of the line item."
          },
          "quantity": {
            "type": "number",
            "format": "float",
            "description": "Quantity of items or hours."
          },
          "price": {
            "type": "number",
            "format": "float",
            "description": "Unit price."
          }
        }
      },
      "CreateInvoiceItemInput": {
        "type": "object",
        "required": [
          "invoiceId",
