    "schemas": {
      "ActivityLogAlert": {
        "description": "An Azure activity log alert.",
        "properties": {
          "actions": {
            "$ref": "#/components/schemas/ActivityLogAlertActionList",
            "description": "The actions that will activate when the condition is met."
          },
          "condition": {
