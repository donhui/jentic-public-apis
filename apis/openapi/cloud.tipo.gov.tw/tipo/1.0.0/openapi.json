{
  "openapi": "3.0.3",
  "info": {
    "title": "TIPO Open Data API",
    "description": "Taiwan Intellectual Property Office (TIPO) Open Data API provides access to patent and trademark gazette data published by the Taiwan government. Includes patent search, publication data, and gazette information. Note: Documentation was extracted from a JavaScript SPA; some endpoint details are inferred from the TIPO open data portal structure.",
    "version": "1.0.0",
    "contact": {
      "name": "Taiwan Intellectual Property Office (TIPO)",
      "url": "https://cloud.tipo.gov.tw/S220/opdata"
    },
    "license": {
      "name": "Open Government Data License, Taiwan",
      "url": "https://data.gov.tw/license"
    },
    "x-jentic-source-url": "https://tiponet.tipo.gov.tw/Gazette/OpenData/OD/OD05.aspx?QryDS=API00"
  },
  "servers": [
    {
      "url": "https://cloud.tipo.gov.tw/S220",
      "description": "TIPO Open Data production server"
    }
  ],
  "tags": [
    {
      "name": "Patent",
      "description": "Patent gazette and publication data"
    },
    {
      "name": "Trademark",
      "description": "Trademark gazette data"
    },
    {
      "name": "OpenData",
      "description": "Open data downloads and catalog"
    }
  ],
  "paths": {
    "/opdata": {
      "get": {
        "operationId": "listOpenData",
        "summary": "List available open data resources",
        "description": "Browse available open data resources from TIPO including patent and trademark gazette data.",
        "tags": ["OpenData"],
        "parameters": [
          {
            "name": "QryDS",
            "in": "query",
            "description": "Dataset query identifier (e.g., API00 for all APIs)",
            "schema": {
              "type": "string",
              "example": "API00"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of available open data resources",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/patent/search": {
      "get": {
        "operationId": "searchPatents",
        "summary": "Search patent records",
        "description": "Search Taiwan patent records by keyword, applicant, inventor, or patent number.",
        "tags": ["Patent"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search query keyword",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "applicant",
            "in": "query",
            "description": "Filter by applicant name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "inventor",
            "in": "query",
            "description": "Filter by inventor name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "patentNo",
            "in": "query",
            "description": "Patent publication number",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "appNo",
            "in": "query",
            "description": "Application number",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dateFrom",
            "in": "query",
            "description": "Publication date range start (YYYYMMDD)",
            "schema": {
              "type": "string",
              "pattern": "^\\d{8}$"
            }
          },
          {
            "name": "dateTo",
            "in": "query",
            "description": "Publication date range end (YYYYMMDD)",
            "schema": {
              "type": "string",
              "pattern": "^\\d{8}$"
            }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Patent type filter",
            "schema": {
              "type": "string",
              "enum": ["invention", "utility_model", "design"]
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Results per page",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patent search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatentSearchResults"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/patent/{patentNo}": {
      "get": {
        "operationId": "getPatentDetail",
        "summary": "Get patent details",
        "description": "Retrieve detailed information about a specific patent by its publication number.",
        "tags": ["Patent"],
        "parameters": [
          {
            "name": "patentNo",
            "in": "path",
            "required": true,
            "description": "Patent publication number",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patent details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Patent"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/patent/gazette": {
      "get": {
        "operationId": "listPatentGazettes",
        "summary": "List patent gazette issues",
        "description": "List available patent gazette publications by date range.",
        "tags": ["Patent"],
        "parameters": [
          {
            "name": "year",
            "in": "query",
            "description": "Publication year (ROC calendar or Western year)",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "month",
            "in": "query",
            "description": "Publication month",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 12
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of gazette issues",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GazetteList"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/trademark/search": {
      "get": {
        "operationId": "searchTrademarks",
        "summary": "Search trademark records",
        "description": "Search Taiwan trademark records by keyword, applicant, or registration number.",
        "tags": ["Trademark"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "description": "Search query keyword",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "applicant",
            "in": "query",
            "description": "Filter by applicant name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "regNo",
            "in": "query",
            "description": "Registration number",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "classNo",
            "in": "query",
            "description": "Nice classification number",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Results per page",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Trademark search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrademarkSearchResults"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/api/download/{resourceId}": {
      "get": {
        "operationId": "downloadResource",
        "summary": "Download open data resource",
        "description": "Download a specific open data resource file (XML, JSON, or CSV format).",
        "tags": ["OpenData"],
        "parameters": [
          {
            "name": "resourceId",
            "in": "path",
            "required": true,
            "description": "Resource identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Download format",
            "schema": {
              "type": "string",
              "enum": ["xml", "json", "csv"],
              "default": "xml"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File download",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "apikey",
        "description": "API key for accessing TIPO open data. Some endpoints may be accessible without authentication."
      }
    },
    "schemas": {
      "Patent": {
        "type": "object",
        "properties": {
          "patentNo": {
            "type": "string",
            "description": "Patent publication number"
          },
          "applicationNo": {
            "type": "string",
            "description": "Application number"
          },
          "title": {
            "type": "string",
            "description": "Patent title"
          },
          "titleEN": {
            "type": "string",
            "description": "Patent title in English"
          },
          "abstract": {
            "type": "string",
            "description": "Patent abstract"
          },
          "applicant": {
            "type": "string",
            "description": "Applicant name"
          },
          "inventor": {
            "type": "string",
            "description": "Inventor name(s)"
          },
          "agent": {
            "type": "string",
            "description": "Patent agent"
          },
          "ipc": {
            "type": "string",
            "description": "International Patent Classification code"
          },
          "applicationDate": {
            "type": "string",
            "description": "Application filing date"
          },
          "publicationDate": {
            "type": "string",
            "description": "Publication date"
          },
          "patentType": {
            "type": "string",
            "description": "Patent type (invention, utility model, design)",
            "enum": ["invention", "utility_model", "design"]
          },
          "status": {
            "type": "string",
            "description": "Patent status"
          }
        }
      },
      "PatentSearchResults": {
        "type": "object",
        "properties": {
          "totalCount": {
            "type": "integer",
            "description": "Total number of matching results"
          },
          "page": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Patent"
            }
          }
        }
      },
      "TrademarkSearchResults": {
        "type": "object",
        "properties": {
          "totalCount": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Trademark"
            }
          }
        }
      },
      "Trademark": {
        "type": "object",
        "properties": {
          "registrationNo": {
            "type": "string"
          },
          "applicationNo": {
            "type": "string"
          },
          "trademarkName": {
            "type": "string"
          },
          "applicant": {
            "type": "string"
          },
          "classNo": {
            "type": "string",
            "description": "Nice classification number"
          },
          "goodsServices": {
            "type": "string",
            "description": "Description of goods and services"
          },
          "applicationDate": {
            "type": "string"
          },
          "registrationDate": {
            "type": "string"
          },
          "expirationDate": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "GazetteList": {
        "type": "object",
        "properties": {
          "gazettes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "gazetteId": {
                  "type": "string"
                },
                "volume": {
                  "type": "string"
                },
                "issueDate": {
                  "type": "string"
                },
                "downloadUrl": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "security": [
    {},
    {
      "apiKey": []
    }
  ]
}
