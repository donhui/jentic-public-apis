{
  "openapi": "3.0.3",
  "info": {
    "title": "Eledo API",
    "version": "1.0.0",
    "description": "Eledo is a PDF service that helps you with automated document creation. Build your document template in Eledo online editor and include dynamic elements. The API allows you to generate PDFs, manage files, list templates, retrieve schemas, and access profile information.",
    "x-jentic-source-url": "https://eledo.online/documentation/api_reference"
  },
  "servers": [
    {
      "url": "https://eledo.online/api/RESTv1",
      "description": "Eledo REST API v1"
    }
  ],
  "paths": {
    "/Generate": {
      "post": {
        "operationId": "generatePdf",
        "summary": "Generate a PDF document",
        "description": "Converts a template and input data into a PDF document.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated PDF document",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "headers": {
              "Content-Disposition": {
                "schema": {
                  "type": "string"
                },
                "description": "attachment; filename=\"file_name\""
              }
            }
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/CreateFile": {
      "post": {
        "operationId": "createFile",
        "summary": "Create a file",
        "description": "Stores transaction data for subsequent use. Creates a file from a template and input data, returning a download URL.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateFileResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/Download/{file_id}": {
      "get": {
        "operationId": "downloadFile",
        "summary": "Download a file",
        "description": "Retrieves a PDF document from a stored file. Removes a temporary file if applicable after download.",
        "parameters": [
          {
            "name": "file_id",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the file",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PDF document",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "headers": {
              "Content-Disposition": {
                "schema": {
                  "type": "string"
                },
                "description": "attachment; filename=\"file_name\""
              }
            }
          },
          "400": {
            "description": "Error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/List": {
      "get": {
        "operationId": "listTemplates",
        "summary": "List templates",
        "description": "Retrieves a list of available templates.",
        "parameters": [
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "description": "Filter results by scope. Available values: Mine, Public.",
            "schema": {
              "type": "string",
              "enum": ["Mine", "Public"]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Controls result set size for pagination.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Specifies page number for paginated results.",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of templates",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListTemplatesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/Profile": {
      "get": {
        "operationId": "getProfile",
        "summary": "Get user profile",
        "description": "Retrieves authenticated user account information.",
        "responses": {
          "200": {
            "description": "User profile information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponse"
                }
              }
            }
          }
        }
      }
    },
    "/Schema/{template_id}/{template_version}": {
      "get": {
        "operationId": "getSchema",
        "summary": "Get template schema",
        "description": "Retrieves a template's JSON schema for valid file structure composition.",
        "parameters": [
          {
            "name": "template_id",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the template",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "template_version",
            "in": "path",
            "required": true,
            "description": "Version number of the template",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "schemaType",
            "in": "query",
            "required": false,
            "description": "Select schema type. Available: zapier.",
            "schema": {
              "type": "string",
              "enum": ["zapier"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Template schema",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchemaResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GenerateRequest": {
        "type": "object",
        "required": ["templateId"],
        "properties": {
          "templateId": {
            "type": "string",
            "description": "Unique identifier of the template to use"
          },
          "templateVersion": {
            "type": "integer",
            "description": "Version of the template to apply"
          },
          "file": {
            "type": "object",
            "description": "The data file/object requiring processing"
          }
        }
      },
      "CreateFileRequest": {
        "type": "object",
        "required": ["templateId"],
        "properties": {
          "templateId": {
            "type": "string",
            "description": "Unique identifier of the template"
          },
          "templateVersion": {
            "type": "integer",
            "description": "Version specification for the template"
          },
          "file": {
            "type": "object",
            "description": "Data to be stored within the service"
          },
          "temporary": {
            "type": "boolean",
            "description": "If set to true, file is removed after first download"
          }
        }
      },
      "CreateFileResponse": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "description": "Download URL for the created file"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Collection of any issues encountered during processing"
          }
        }
      },
      "ListTemplatesResponse": {
        "type": "object",
        "properties": {
          "templates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Template"
            },
            "description": "Collection of template objects"
          }
        }
      },
      "Template": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier"
          },
          "name": {
            "type": "string",
            "description": "Template name"
          },
          "version": {
            "type": "integer",
            "description": "Version number"
          },
          "bulk": {
            "type": "boolean",
            "description": "Indicates bulk-use capability"
          }
        }
      },
      "ProfileResponse": {
        "type": "object",
        "properties": {
          "account": {
            "type": "string",
            "description": "Account login identifier (email)"
          }
        }
      },
      "SchemaResponse": {
        "type": "object",
        "properties": {
          "schema": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SchemaItem"
            },
            "description": "Array of schema items"
          }
        }
      },
      "SchemaItem": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique identifier of the item"
          },
          "type": {
            "type": "string",
            "enum": ["string", "number"],
            "description": "Item data type"
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SchemaItem"
            },
            "description": "Nested schema items"
          },
          "list": {
            "type": "boolean",
            "description": "Indicates if the item is a list"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of error messages"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "Api-Key",
        "in": "header",
        "description": "API key authentication. Include your API key in the Api-Key header."
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}