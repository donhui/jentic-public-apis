  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API token from your ola.cv developer account dashboard"
      }
    },
    "schemas": {
      "CreateContactRequest": {
        "type": "object",
        "required": [
          "name",
          "email",
          "phone",
          "address",
          "city",
          "postcode",
          "country"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Contact's full name"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Contact's email address"
          },
          "phone": {
            "type": "string",
            "description": "Contact's phone number"
          },
          "fax": {
            "type": "string",
            "description": "Contact's fax number"
          },
          "organization": {
            "type": "string",
            "description": "Contact's organization or company name"
          },
          "address": {
            "type": "string",
            "description": "Contact's physical or street address"
          },
          "city": {
            "type": "string",
            "description": "Contact's city"
          },
          "state": {
            "type": "string",
            "description": "Contact's state or province"
          },
          "postcode": {
            "type": "string",
            "description": "Contact's postal code"
          },
          "country": {
            "type": "string",
            "description": "2-letter ISO 3166 country code (e.g., US)"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "fax": {
            "type": "string",
            "nullable": true
          },
          "organization": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "nullable": true
          },
          "postcode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ContactResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Contact"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ContactListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contact"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "CheckDomainsRequest": {
        "type": "object",
        "required": [
          "domains"
        ],
        "properties": {
          "domains": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of .cv domain names to check"
          }
        }
      },
      "CheckDomainsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/DomainAvailability"
            }
          },
          "message": {
            "type": "string"
          }
        }
      },
      "DomainAvailability": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string"
          },
          "available": {
            "type": "boolean"
          },
          "premium": {
            "type": "boolean"
          },
          "registration_fee": {
            "type": "number"
          },
          "renewal_fee": {
            "type": "number"
          },
          "transfer_fee": {
            "type": "number"
          },
          "redemption_fee": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "RegisterDomainRequest": {
        "type": "object",
        "required": [
          "name",
          "registrant"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "The .cv domain name to register"
          },
          "registrant": {
            "type": "string",
            "description": "ID of an existing contact as registrant"
          },
          "admin": {
            "type": "string",
            "description": "ID of an existing contact as admin contact"
          },
          "tech": {
            "type": "string",
            "description": "ID of an existing contact as technical contact"
          },
          "billing": {
            "type": "string",
            "description": "ID of an existing contact as billing contact"
          },
          "nameservers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of nameservers to attach"
          }
        }
      },
      "Domain": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "auto_renew": {
            "type": "boolean"
          },
          "registered_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
