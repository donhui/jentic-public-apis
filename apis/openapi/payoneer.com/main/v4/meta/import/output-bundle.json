{
  "openapi": "3.0.3",
  "info": {
    "title": "Payoneer Payouts API",
    "version": "v4",
    "description": "Payoneer's Payouts API for managing mass payouts to payees worldwide.",
    "x-jentic-source-url": "https://payouts.developer.payoneer.com/docs"
  },
  "servers": [
    {
      "url": "https://api.payoneer.com/v4"
    }
  ],
  "paths": {
    "/oauth2/token": {
      "post": {
        "operationId": "getAccessToken",
        "summary": "Get Access Token",
        "description": "Obtain an OAuth 2.0 access token using client credentials.",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "client_credentials"
                    ],
                    "description": "The OAuth 2.0 grant type."
                  },
                  "scope": {
                    "type": "string",
                    "description": "The requested scope for the access token."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid client credentials.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/programs/{program_id}": {
