              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/programs/{program_id}/payouts": {
      "post": {
        "operationId": "createPayout",
        "summary": "Create Payout",
        "description": "Create a new payout to a payee.",
        "tags": [
          "Payouts"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProgramId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePayoutRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payout created.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/BaseResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/Payout"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listPayouts",
        "summary": "List Payouts",
        "description": "Retrieve a list of payouts for a program.",
        "tags": [
          "Payouts"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProgramId"
          },
          {
            "$ref": "#/components/parameters/StartDate"
          },
          {
            "$ref": "#/components/parameters/EndDate"
          },
          {
            "name": "payee_id",
            "in": "query",
            "description": "Filter by payee ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by payout status.",
            "schema": {
              "$ref": "#/components/schemas/PayoutStatus"
            }
          },
          {
            "name": "group_id",
            "in": "query",
            "description": "Filter by group ID.",
            "schema": {
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/Offset"
          },
          {
            "$ref": "#/components/parameters/Limit"
          }
        ],
        "responses": {
          "200": {
            "description": "List of payouts.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/BaseResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/PayoutListResult"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/programs/{program_id}/payouts/{payout_id}": {
      "get": {
        "operationId": "getPayout",
        "summary": "Get Payout",
        "description": "Retrieve details for a specific payout.",
        "tags": [
          "Payouts"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProgramId"
          },
          {
            "name": "payout_id",
            "in": "path",
            "required": true,
            "description": "The unique identifier of the payout.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payout details.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/BaseResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/Payout"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Payout not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/programs/{program_id}/payouts/batch": {
      "post": {
        "operationId": "createBatchPayout",
        "summary": "Create Batch Payout",
        "description": "Create multiple payouts in a single batch request.",
        "tags": [
          "Payouts"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProgramId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBatchPayoutRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch payout created.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/BaseResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/BatchPayoutResult"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/programs/{program_id}/reports/payouts": {
      "get": {
        "operationId": "getPayoutsReport",
        "summary": "Payouts Report",
        "description": "Generate a report of payouts for a program.",
        "tags": [
          "Reports"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProgramId"
          },
          {
            "$ref": "#/components/parameters/StartDate"
          },
          {
            "$ref": "#/components/parameters/EndDate"
          },
          {
            "name": "format",
            "in": "query",
            "description": "The report output format.",
            "schema": {
              "type": "string",
              "enum": [
                "csv",
                "json"
              ],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Report data.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/BaseResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "type": "object",
                          "description": "Report data containing payout records.",
                          "properties": {
                            "payouts": {
                              "type": "array",
                              "items": {
                                "$ref": "#/components/schemas/Payout"
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string",
                  "description": "CSV formatted report data."
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://api.payoneer.com/v4/oauth2/token",
            "scopes": {}
          }
        }
      }
    },
    "parameters": {
      "ProgramId": {
        "name": "program_id",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the program.",
        "schema": {
          "type": "string"
        }
      },
      "PayeeId": {
        "name": "payee_id",
        "in": "path",
        "required": true,
        "description": "The unique identifier of the payee.",
        "schema": {
          "type": "string"
        }
      },
      "StartDate": {
        "name": "start_date",
        "in": "query",
        "description": "Filter results from this date (ISO 8601 format).",
        "schema": {
          "type": "string",
          "format": "date-time"
        }
      },
      "EndDate": {
        "name": "end_date",
        "in": "query",
        "description": "Filter results up to this date (ISO 8601 format).",
        "schema": {
          "type": "string",
          "format": "date-time"
        }
      },
      "Offset": {
        "name": "offset",
        "in": "query",
        "description": "Number of records to skip for pagination.",
        "schema": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "description": "Maximum number of records to return.",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "default": 50
        }
      }
    },
    "schemas": {
      "BaseResponse": {
        "type": "object",
        "properties": {
          "audit_id": {
            "type": "string",
            "description": "Unique identifier for the API call, used for auditing and troubleshooting."
          },
          "code": {
            "type": "integer",
            "description": "Response code. 0 indicates success."
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the response."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "audit_id": {
            "type": "string",
            "description": "Unique identifier for the API call."
          },
          "code": {
            "type": "integer",
            "description": "Error code."
          },
          "description": {
            "type": "string",
            "description": "Human-readable error description."
          },
          "errors": {
            "type": "array",
            "description": "Detailed list of errors.",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "description": "Specific error code."
                },
                "description": {
                  "type": "string",
                  "description": "Error detail message."
                },
                "field": {
                  "type": "string",
                  "description": "The field that caused the error."
                }
              }
            }
          }
        }
      },
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "The OAuth 2.0 access token."
          },
          "token_type": {
            "type": "string",
            "description": "The type of the token (e.g., Bearer)."
          },
          "expires_in": {
            "type": "integer",
            "description": "Token expiration time in seconds."
          },
          "scope": {
            "type": "string",
            "description": "The scope granted for the token."
          }
        }
      },
      "Program": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The unique identifier of the program."
          },
          "name": {
            "type": "string",
            "description": "The name of the program."
          },
          "currency": {
            "type": "string",
            "description": "The default currency of the program (ISO 4217)."
          },
          "status": {
            "type": "string",
            "description": "The current status of the program."
          }
        }
      },
      "MoneyAmount": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "format": "double",
            "description": "The monetary amount."
          },
          "currency": {
            "type": "string",
            "description": "The currency code (ISO 4217)."
          }
        }
      },
      "ProgramBalance": {
        "type": "object",
        "properties": {
          "balance": {
            "$ref": "#/components/schemas/MoneyAmount"
          },
          "pending": {
            "$ref": "#/components/schemas/MoneyAmount"
          }
        }
      },
      "CreatePayeeRequest": {
        "type": "object",
        "required": [
          "payee_id"
        ],
        "properties": {
          "payee_id": {
            "type": "string",
            "description": "A unique identifier for the payee in your system."
          },
          "redirect_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to redirect the payee after registration."
          },
          "redirect_time": {
            "type": "integer",
            "description": "Time in seconds before redirecting the payee."
          }
        }
      },
      "PayeeRegistrationResult": {
        "type": "object",
        "properties": {
          "registration_link": {
            "type": "string",
            "format": "uri",
            "description": "The URL for the payee to complete registration."
          },
          "payee_id": {
            "type": "string",
            "description": "The unique identifier of the payee."
          }
        }
      },
      "PayeeStatus": {
        "type": "string",
        "enum": [
          "ACTIVE",
          "PENDING",
          "DECLINED",
          "NOT_VERIFIED"
        ],
        "description": "The status of a payee."
      },
      "Payee": {
        "type": "object",
        "properties": {
          "payee_id": {
            "type": "string",
            "description": "The unique identifier of the payee."
          },
          "status": {
            "$ref": "#/components/schemas/PayeeStatus"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "The payee's email address."
          },
          "first_name": {
            "type": "string",
            "description": "The payee's first name."
          },
          "last_name": {
            "type": "string",
            "description": "The payee's last name."
          },
          "company_name": {
            "type": "string",
            "description": "The payee's company name."
          },
          "registration_date": {
            "type": "string",
            "format": "date-time",
            "description": "The date the payee registered."
          },
          "payout_methods": {
            "type": "array",
            "description": "Available payout methods for this payee.",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "The payout method type."
                },
                "currency": {
                  "type": "string",
                  "description": "The currency for this payout method."
                }
              }
            }
          }
        }
      },
      "PayeeStatusResult": {
        "type": "object",
        "properties": {
          "payee_id": {
            "type": "string",
            "description": "The unique identifier of the payee."
          },
          "status": {
            "$ref": "#/components/schemas/PayeeStatus"
          },
          "status_reason": {
            "type": "string",
            "description": "The reason for the current status."
          }
        }
      },
      "PayeeListResult": {
        "type": "object",
        "properties": {
          "payees": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Payee"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of payees matching the query."
          },
          "offset": {
            "type": "integer",
            "description": "Current offset."
          },
          "limit": {
            "type": "integer",
            "description": "Current page size limit."
          }
        }
      },
      "PayoutStatus": {
        "type": "string",
        "enum": [
          "PENDING",
          "FUNDED",
          "CANCELLED",
          "RETURNED"
        ],
        "description": "The status of a payout."
