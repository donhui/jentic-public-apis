        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/ProgramId"
          },
          {
            "$ref": "#/components/parameters/PayeeId"
          }
        ],
        "responses": {
          "200": {
            "description": "Payee status.",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/BaseResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "result": {
                          "$ref": "#/components/schemas/PayeeStatusResult"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Payee not found.",
