  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "API secret token passed as a query parameter. Also supports HTTP Basic Auth with the token as the username."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "QueuedResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "queued"
          }
        }
      },
      "Signer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique ID for the signer"
          },
          "name": {
            "type": "string",
            "description": "Name of the signer"
          },
          "email": {
            "type": "string",
            "description": "Email address of the signer"
          },
          "mobile": {
            "type": "string",
            "description": "Mobile number of the signer"
          },
          "company_name": {
            "type": "string",
            "description": "Company name of the signer"
          },
          "sign_page_url": {
