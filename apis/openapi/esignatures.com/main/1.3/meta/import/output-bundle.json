{
  "openapi": "3.0.3",
  "info": {
    "title": "eSignatures API",
    "description": "REST API for managing electronic signature contracts, signers, and templates on the eSignatures.com platform. Supports creating and querying contracts, managing signers, and template CRUD operations.",
    "version": "1.3",
    "x-jentic-source-url": "https://esignatures.com/docs/api"
  },
  "servers": [
    {
      "url": "https://esignatures.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/api/contracts": {
      "post": {
        "operationId": "createContract",
        "summary": "Create a new contract",
        "description": "Generates a contract from a template and sends it to the signers for signature collection.",
        "tags": [
          "Contracts"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateContractRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contract creation queued successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateContractResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
