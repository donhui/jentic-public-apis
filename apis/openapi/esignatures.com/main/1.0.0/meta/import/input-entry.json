  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "API secret token retrieved from account API settings."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "QueuedResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "queued"
          }
        }
      },
      "Signer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique signer identifier"
          },
          "name": {
            "type": "string",
            "description": "Signer full name"
          },
          "email": {
            "type": "string",
            "description": "Signer email address"
          },
          "mobile": {
            "type": "string",
            "description": "Signer mobile number"
          },
          "company_name": {
            "type": "string",
            "description": "Signer company name"
          },
          "sign_page_url": {
            "type": "string",
            "description": "URL for signer to sign the contract"
          },
          "signer_field_values": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Field values entered by the signer"
          }
        }
      },
      "Contract": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique contract identifier"
          },
          "status": {
            "type": "string",
            "enum": [
              "sent",
              "signed",
              "withdrawn"
            ],
            "description": "Current contract status"
          },
          "title": {
            "type": "string",
            "description": "Contract title"
          },
          "metadata": {
            "type": "string",
            "description": "Custom metadata string"
          },
          "source": {
            "type": "string",
            "enum": [
              "api",
              "ui",
              "zapier"
            ],
            "description": "How the contract was created"
          },
          "test": {
            "type": "string",
            "enum": [
              "yes",
              "no"
            ],
            "description": "Whether this is a test contract"
