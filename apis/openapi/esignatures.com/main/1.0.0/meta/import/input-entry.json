{
  "openapi": "3.0.3",
  "info": {
    "title": "eSignatures.com API",
    "description": "API for creating and managing electronic signature contracts, templates, and signers.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://esignatures.com/docs/api"
  },
