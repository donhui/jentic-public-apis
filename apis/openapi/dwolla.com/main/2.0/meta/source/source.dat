      }
    },
    "/customers/{id}/exchange-sessions": {
      "post": {
        "tags": [
          "exchange sessions"
        ],
        "summary": "Create customer exchange session",
        "description": "Creates an exchange session for a customer. Use cases include:\n- **Plaid / MX**: Instant bank account verification (open banking). For faster verification as compared to traditional micro-deposits.\n- **Checkout.com**: Debit card capture for Push to Card. Create a session, then retrieve it to get `externalProviderSessionData` (payment session) for the Checkout.com Flow component.\n",
        "operationId": "createCustomerExchangeSession",
        "x-speakeasy-group": "customers.exchangeSessions",
        "x-speakeasy-name-override": "create",
