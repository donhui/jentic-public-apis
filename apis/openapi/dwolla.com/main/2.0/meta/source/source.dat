      "CreateTokenBasedExchange": {
        "title": "CreateTokenBasedExchange",
        "description": "Create an exchange using a token. Supports MX, Plaid, and Flinks secure exchange flows, and Checkout.com for Push to Card (debit card).",
        "type": "object",
        "required": [
          "_links",
          "token"
        ],
        "properties": {
          "_links": {
            "type": "object",
            "required": [
