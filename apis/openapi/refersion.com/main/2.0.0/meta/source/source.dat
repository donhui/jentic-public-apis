{
  "openapi": "3.0.3",
  "info": {
    "title": "Refersion Affiliate API",
    "version": "2.0.0",
    "description": "Refersion REST API v2 for managing affiliates, conversions, and commissions in your affiliate marketing program.",
    "x-jentic-source-url": "https://www.refersion.dev/reference/welcome-to-refersion"
  },
  "servers": [
    {
      "url": "https://api.refersion.com/v2",
      "description": "Refersion API v2"
    }
  ],
  "security": [
    {
      "publicKey": [],
      "secretKey": []
    }
  ],
  "tags": [
    {
      "name": "Affiliates",
      "description": "Affiliate management operations"
    },
    {
      "name": "Conversions",
      "description": "Conversion and commission operations"
    },
    {
      "name": "Offers",
      "description": "Offer and SKU commission management"
    },
    {
      "name": "Reporting",
      "description": "Report generation and download"
    }
  ],
  "paths": {
    "/affiliate/new": {
      "post": {
        "operationId": "createAffiliate",
        "summary": "Create a new affiliate",
        "description": "Register a new affiliate in the system with personal details and optional conversion trigger.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAffiliateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Affiliate created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateAffiliateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required field",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error (duplicate email, weak password, etc.)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/affiliate/get": {
      "post": {
        "operationId": "getAffiliate",
        "summary": "Get affiliate details",
        "description": "Retrieve affiliate details by ID or affiliate code.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetAffiliateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Affiliate details retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AffiliateDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Affiliate not found or missing filter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/affiliate/edit": {
      "post": {
        "operationId": "editAffiliate",
        "summary": "Edit affiliate details",
        "description": "Update one or more affiliates with new field values. At least one field besides ID must be provided.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EditAffiliateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Affiliates updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchUpdateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required field",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/affiliate/search": {
      "post": {
        "operationId": "searchAffiliates",
        "summary": "Search affiliates",
        "description": "Search affiliates by keyword (ID or email), with optional name filters.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchAffiliatesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AffiliateListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/affiliate/list": {
      "post": {
        "operationId": "listAffiliates",
        "summary": "List all affiliates",
        "description": "Retrieve all affiliates with pagination support. Max 100 per call.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ListAffiliatesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Affiliates retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AffiliateListResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/affiliate/status_change": {
      "post": {
        "operationId": "changeAffiliateStatus",
        "summary": "Change affiliate status",
        "description": "Change the status of one or more affiliates. Max 50 IDs per call.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AffiliateStatusChangeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status change result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchUpdateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversion/manual_credit": {
      "post": {
        "operationId": "createManualCommissionCredit",
        "summary": "Create manual commission credit",
        "description": "Manually credit a commission to an affiliate. Commission amount can be negative.",
        "tags": ["Conversions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManualCreditRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Commission credited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversion/status_change": {
      "post": {
        "operationId": "changeConversionStatus",
        "summary": "Change conversion status",
        "description": "Manually change the status of one or more conversions.",
        "tags": ["Conversions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConversionStatusChangeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status change result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchUpdateResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/affiliate/trigger": {
      "post": {
        "operationId": "createConversionTrigger",
        "summary": "Create a conversion trigger",
        "description": "Create a conversion trigger (coupon, SKU, or email) for an affiliate to enable automatic conversion tracking.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTriggerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Trigger created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TriggerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required field",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/trigger/delete": {
      "post": {
        "operationId": "deleteConversionTriggers",
        "summary": "Delete conversion triggers",
        "description": "Delete one or more conversion triggers for affiliates. Max 50 triggers per request.",
        "tags": ["Affiliates"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeleteTriggersRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Triggers deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "integer" },
                  "description": "IDs of deleted triggers"
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Affiliate or trigger not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversion/manual_credit_order_id": {
      "post": {
        "operationId": "manualCreditOrderId",
        "summary": "Manual credit by order ID",
        "description": "Manually credit an affiliate with an existing order ID, automating commission assignment for orders not automatically captured.",
        "tags": ["Conversions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ManualCreditOrderIdRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order credit processing",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ManualCreditOrderIdResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversion/totals": {
      "post": {
        "operationId": "getConversionTotals",
        "summary": "Get conversion totals",
        "description": "Retrieve aggregated conversion totals with optional date range, affiliate, offer, and status filters.",
        "tags": ["Conversions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GetTotalsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversion totals",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionTotalsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/offer/new_sku_commission": {
      "post": {
        "operationId": "createSkuLevelCommission",
        "summary": "Create SKU level commission",
        "description": "Add product-specific commission rates to an offer. Requires a plan that supports SKU/Product Level Commissions. Max 50 SKUs per request.",
        "tags": ["Offers"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SkuCommissionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SKU commissions created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SkuCommissionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required field",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Plan does not support feature or invalid offer ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/reporting/link": {
      "post": {
        "operationId": "generateReportDownloadLink",
        "summary": "Generate report download link",
        "description": "Generate a public download link for a report. Links expire after 2 minutes.",
        "tags": ["Reporting"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["report_id"],
                "properties": {
                  "report_id": { "type": "integer", "description": "Report ID to generate a download link for" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Download link generated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportLinkResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/conversion/cancel": {
      "post": {
        "operationId": "cancelConversion",
        "summary": "Create a cancellation conversion",
        "description": "Cancel a conversion by order ID, optionally specifying individual SKUs to cancel.",
        "tags": ["Conversions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelConversionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Conversion cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "publicKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Refersion-Public-Key",
        "description": "Refersion public API key (format: pub_abc12300000000000000)"
      },
      "secretKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Refersion-Secret-Key",
        "description": "Refersion secret API key (format: sec_abc12300000000000000)"
      }
    },
    "schemas": {
      "CreateAffiliateRequest": {
        "type": "object",
        "required": ["first_name", "last_name", "email", "password", "status"],
        "properties": {
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 9, "maxLength": 72, "description": "Requires uppercase, lowercase, number, and symbol" },
          "status": { "type": "string", "enum": ["ACTIVE", "PENDING"] },
          "offer": { "type": "string", "description": "Specific Offer ID" },
          "company": { "type": "string" },
          "paypal_email": { "type": "string", "format": "email" },
          "address1": { "type": "string" },
          "address2": { "type": "string" },
          "city": { "type": "string" },
          "state": { "type": "string" },
          "zip": { "type": "string" },
          "country": { "type": "string", "description": "Two-letter country code" },
          "phone": { "type": "string" },
          "send_welcome": { "type": "string", "enum": ["TRUE", "FALSE"], "default": "FALSE" },
          "conversion_trigger_coupon": { "type": "string" },
          "unique_merchant_id": { "type": "string" }
        }
      },
      "CreateAffiliateResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "link": { "type": "string", "description": "Referral link for the affiliate" },
          "message": { "type": "string" }
        }
      },
      "GetAffiliateRequest": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Affiliate ID" },
          "affiliate_code": { "type": "string", "description": "Affiliate code" }
        }
      },
      "AffiliateDetail": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "offer_id": { "type": "string" },
          "status": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "company_name": { "type": "string" },
          "email": { "type": "string" },
          "link": { "type": "string" },
          "custom_fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CustomField"
            }
          }
        }
      },
      "EditAffiliateRequest": {
        "type": "object",
        "required": ["affiliates"],
        "properties": {
          "affiliates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id"],
              "properties": {
                "id": { "type": "integer" },
                "first_name": { "type": "string" },
                "last_name": { "type": "string" },
                "email": { "type": "string", "format": "email" },
                "paypal_email": { "type": "string" },
                "offer": { "type": "number" },
                "company": { "type": "string" },
                "address1": { "type": "string" },
                "address2": { "type": "string" },
                "city": { "type": "string" },
                "state": { "type": "string" },
                "zip": { "type": "string" },
                "country": { "type": "string" },
                "phone": { "type": "string" },
                "custom_fields": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CustomField"
                  }
                }
              }
            }
          }
        }
      },
      "SearchAffiliatesRequest": {
        "type": "object",
        "required": ["keyword"],
        "properties": {
          "keyword": { "type": "string", "description": "Affiliate ID or registered email address" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "page": { "type": "string", "default": "1" }
        }
      },
      "ListAffiliatesRequest": {
        "type": "object",
        "properties": {
          "limit": { "type": "string", "description": "Max 100 per call, default 3" },
          "page": { "type": "string", "default": "1" }
        }
      },
      "AffiliateListResponse": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AffiliateDetail"
            }
          }
        }
      },
      "AffiliateStatusChangeRequest": {
        "type": "object",
        "required": ["ids", "status"],
        "properties": {
          "ids": {
            "type": "array",
            "items": { "type": "integer" },
            "maxItems": 50
          },
          "status": { "type": "string", "enum": ["ACTIVE", "DENIED", "DISABLED"] }
        }
      },
      "ManualCreditRequest": {
        "type": "object",
        "required": ["id", "commission", "status"],
        "properties": {
          "id": { "type": "integer", "description": "Affiliate ID" },
          "commission": { "type": "number", "description": "Commission amount (can be negative)" },
          "status": { "type": "string", "enum": ["APPROVED", "PENDING"] },
          "currency": { "type": "string", "maxLength": 3 },
          "notes": { "type": "string" }
        }
      },
      "ConversionStatusChangeRequest": {
        "type": "object",
        "required": ["ids", "status"],
        "properties": {
          "ids": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "status": { "type": "string", "enum": ["APPROVED", "UNQUALIFIED", "DENIED"] }
        }
      },
      "CancelConversionRequest": {
        "type": "object",
        "required": ["order_id"],
        "properties": {
          "order_id": { "type": "string" },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sku"],
              "properties": {
                "sku": { "type": "string" },
                "price": { "type": "number" },
                "quantity": { "type": "integer" }
              }
            }
          }
        }
      },
      "ConversionResponse": {
        "type": "object",
        "properties": {
          "conversion_id": { "type": "integer" }
        }
      },
      "BatchUpdateResponse": {
        "type": "object",
        "properties": {
          "ids_changed": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "ids_not_changed": {
            "type": "array",
            "items": { "type": "integer" }
          }
        }
      },
      "CustomField": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "value": { "type": "string" }
        }
      },
      "CreateTriggerRequest": {
        "type": "object",
        "required": ["affiliate_code", "type", "trigger"],
        "properties": {
          "affiliate_code": { "type": "string", "description": "Refersion affiliate identifier" },
          "type": { "type": "string", "enum": ["COUPON", "SKU", "EMAIL"], "description": "Conversion trigger type" },
          "trigger": { "type": "string", "description": "Trigger value (coupon code, SKU name, or email)" }
        }
      },
      "TriggerResponse": {
        "type": "object",
        "properties": {
          "trigger_id": { "type": "integer" },
          "trigger": { "type": "string" }
        }
      },
      "DeleteTriggersRequest": {
        "type": "object",
        "required": ["affiliates"],
        "properties": {
          "affiliates": {
            "type": "array",
            "maxItems": 50,
            "items": {
              "type": "object",
              "required": ["id", "trigger", "type"],
              "properties": {
                "id": { "type": "integer", "description": "Affiliate ID" },
                "trigger": { "type": "string", "description": "Trigger value" },
                "type": { "type": "string", "enum": ["COUPON", "EMAIL", "SKU"] }
              }
            }
          }
        }
      },
      "ManualCreditOrderIdRequest": {
        "type": "object",
        "required": ["id", "order_id"],
        "properties": {
          "id": { "type": "integer", "description": "Affiliate ID" },
          "order_id": { "type": "string", "description": "Order ID to credit" },
          "status": { "type": "string", "enum": ["APPROVED", "PENDING"], "default": "APPROVED" },
          "notes": { "type": "string", "description": "Manual order credit note" }
        }
      },
      "ManualCreditOrderIdResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "description": "Processing status notification" },
          "warning": { "type": "string", "description": "Alert if order already credited elsewhere" }
        }
      },
      "GetTotalsRequest": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "created_from": { "type": "string", "description": "Start date in UTC (YYYY-MM-DD hh:mm:ss)" },
          "created_to": { "type": "string", "description": "End date in UTC (YYYY-MM-DD hh:mm:ss)" },
          "offer_id": { "type": "integer", "description": "Filter by offer ID" },
          "affiliate_id": { "type": "integer", "description": "Filter by affiliate ID" },
          "status": { "type": "array", "items": { "type": "string", "enum": ["APPROVED", "PENDING", "UNQUALIFIED", "DENIED"] } },
          "payment_status": { "type": "string", "enum": ["PAID", "UNPAID"] },
          "type": { "type": "array", "items": { "type": "string" }, "description": "Conversion type filter" },
          "is_test_conversion": { "type": "boolean" }
        }
      },
      "ConversionTotalsResponse": {
        "type": "object",
        "properties": {
          "conversions_count": { "type": "integer", "description": "Number of conversions" },
          "commission_total": { "type": "number", "description": "Sum of commissions" },
          "order_total": { "type": "number", "description": "Sum of order totals" },
          "commissionable_order_total": { "type": "number", "description": "Sum of commissionable order totals" },
          "currency": { "type": "string", "description": "Currency code" }
        }
      },
      "SkuCommissionRequest": {
        "type": "object",
        "required": ["offer_id", "skus"],
        "properties": {
          "offer_id": { "type": "string", "description": "Offer ID" },
          "skus": {
            "type": "array",
            "maxItems": 50,
            "items": {
              "type": "object",
              "required": ["sku", "commission_type", "commission_amount"],
              "properties": {
                "sku": { "type": "string" },
                "product_description": { "type": "string" },
                "commission_type": { "type": "string", "enum": ["PERCENT_OF_SALE", "FLAT_RATE"] },
                "commission_amount": { "type": "string", "description": "Numeric commission value" }
              }
            }
          }
        }
      },
      "SkuCommissionResponse": {
        "type": "object",
        "properties": {
          "duplicate_not_added": { "type": "array", "items": { "type": "string" } },
          "added": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ReportLinkResponse": {
        "type": "object",
        "properties": {
          "download_link": { "type": "string", "format": "uri", "description": "Public download URL (expires in 2 minutes)" },
          "expire_time": { "type": "integer", "description": "Unix timestamp when link expires" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}