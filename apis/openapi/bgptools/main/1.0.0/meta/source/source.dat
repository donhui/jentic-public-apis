{
  "openapi": "3.0.3",
  "info": {
    "title": "BGP.tools API",
    "description": "BGP.tools API for exporting BGP routing data including tags, routing table, and ASN mappings. All requests require a custom User-Agent header.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://bgp.tools/kb/api"
  },
  "servers": [
    {
      "url": "https://bgp.tools",
      "description": "BGP.tools API server"
    }
  ],
  "paths": {
    "/tags.txt": {
      "get": {
        "operationId": "listAllTags",
        "summary": "List all available tags",
        "description": "Retrieve a list of all available tags in plaintext format.",
        "tags": ["Tags"],
        "responses": {
          "200": {
            "description": "List of tags",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request - missing User-Agent" }
        }
      }
    },
    "/tags/{tagname}.csv": {
      "get": {
        "operationId": "exportTagCsv",
        "summary": "Export tag data as CSV",
        "description": "Export all entries for a specific tag in CSV format.",
        "tags": ["Tags"],
        "parameters": [
          {
            "name": "tagname",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Tag name to export"
          }
        ],
        "responses": {
          "200": {
            "description": "Tag data in CSV format",
            "content": {
              "text/csv": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/tags/{tagname}.txt": {
      "get": {
        "operationId": "exportTagTxt",
        "summary": "Export tag data as plaintext",
        "description": "Export all entries for a specific tag in plaintext format.",
        "tags": ["Tags"],
        "parameters": [
          {
            "name": "tagname",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Tag name to export"
          }
        ],
        "responses": {
          "200": {
            "description": "Tag data in text format",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/table.txt": {
      "get": {
        "operationId": "getRoutingTableTxt",
        "summary": "Get routing table as text",
        "description": "Download the full routing table in space-delimited format (CIDR and ASN pairs). Updates every ~30 minutes.",
        "tags": ["Routing Table"],
        "responses": {
          "200": {
            "description": "Routing table in space-delimited format",
            "content": {
              "text/plain": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/table.jsonl": {
      "get": {
        "operationId": "getRoutingTableJsonl",
        "summary": "Get routing table as JSONL",
        "description": "Download the full routing table as JSON Lines format with CIDR, ASN, and hit count data. Updates every ~30 minutes.",
        "tags": ["Routing Table"],
        "responses": {
          "200": {
            "description": "Routing table in JSON Lines format",
            "content": {
              "application/x-ndjson": {
                "schema": {
                  "type": "string",
                  "description": "Each line is a JSON object with CIDR, ASN, and hit count"
                }
              }
            }
          },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/asns.csv": {
      "get": {
        "operationId": "getAsnMappings",
        "summary": "Get ASN to name mappings",
        "description": "Download a CSV file of all ASN numbers to name mappings. Suggested cache duration is 24 hours.",
        "tags": ["ASN"],
        "responses": {
          "200": {
            "description": "ASN mappings in CSV format",
            "content": {
              "text/csv": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": { "description": "Bad request" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RoutingEntry": {
        "type": "object",
        "properties": {
          "cidr": { "type": "string", "description": "CIDR prefix" },
          "asn": { "type": "integer", "description": "Autonomous System Number" },
          "hits": { "type": "integer", "description": "Hit count" }
        }
      },
      "AsnMapping": {
        "type": "object",
        "properties": {
          "asn": { "type": "integer" },
          "name": { "type": "string" },
          "class": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "userAgent": {
        "type": "apiKey",
        "in": "header",
        "name": "User-Agent",
        "description": "Custom User-Agent header identifying your system (required)"
      }
    }
  },
  "security": [
    {
      "userAgent": []
    }
  ]
}