{
  "openapi": "3.0.3",
  "info": {
    "title": "Toss Payments API",
    "version": "1.0.0",
    "description": "Toss Payments REST API for creating and managing payment transactions. Supports card payments, virtual accounts, mobile phone billing, bank transfers, and foreign easy pay methods.",
    "x-jentic-source-url": "https://docs.tosspayments.com/en/integration"
  },
  "servers": [
    {
      "url": "https://api.tosspayments.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/v1/payments": {
      "post": {
        "operationId": "createPayment",
        "summary": "Create a payment",
        "description": "Creates a payment window as an alternative to SDK integration. Establishes a new payment session.",
        "tags": ["Payments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    },
    "/v1/payments/{paymentKey}": {
      "get": {
        "operationId": "getPaymentByPaymentKey",
        "summary": "Retrieve payment by paymentKey",
        "description": "Retrieves the details of a payment using the paymentKey.",
        "tags": ["Payments"],
        "parameters": [
          {
            "name": "paymentKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique payment key"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Payment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    },
    "/v1/payments/orders/{orderId}": {
      "get": {
        "operationId": "getPaymentByOrderId",
        "summary": "Retrieve payment by orderId",
        "description": "Retrieves the details of a payment using the orderId.",
        "tags": ["Payments"],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique order identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Payment details retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Payment not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    },
    "/v1/payments/{paymentKey}/confirm": {
      "post": {
        "operationId": "confirmPayment",
        "summary": "Confirm a payment",
        "description": "Confirms and finalizes a payment after the customer completes the payment process.",
        "tags": ["Payments"],
        "parameters": [
          {
            "name": "paymentKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique payment key"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfirmPaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment confirmed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    },
    "/v1/payments/{paymentKey}/cancel": {
      "post": {
        "operationId": "cancelPayment",
        "summary": "Cancel a payment",
        "description": "Cancels a confirmed payment. Can perform full or partial cancellation.",
        "tags": ["Payments"],
        "parameters": [
          {
            "name": "paymentKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique payment key"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelPaymentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment cancelled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "CreatePaymentRequest": {
        "type": "object",
        "required": ["method", "amount", "orderId", "orderName"],
        "properties": {
          "method": {
            "type": "string",
            "enum": ["CARD", "VIRTUAL_ACCOUNT", "MOBILE_PHONE", "TRANSFER", "FOREIGN_EASY_PAY"],
            "description": "Payment method"
          },
          "amount": {
            "type": "number",
            "description": "Amount to charge the customer"
          },
          "currency": {
            "type": "string",
            "description": "Currency code. Defaults to KRW.",
            "default": "KRW"
          },
          "orderId": {
            "type": "string",
            "minLength": 6,
            "maxLength": 64,
            "description": "Unique order identifier (6-64 characters, alphanumeric with - and _)"
          },
          "orderName": {
            "type": "string",
            "maxLength": 100,
            "description": "Order name (max 100 characters)"
          },
          "successUrl": {
            "type": "string",
            "format": "uri",
            "description": "Redirect URL on success (required for domestic payments)"
          },
          "failUrl": {
            "type": "string",
            "format": "uri",
            "description": "Redirect URL on failure (required for domestic payments)"
          },
          "pendingUrl": {
            "type": "string",
            "format": "uri",
            "description": "Redirect URL for foreign payments (required except PayPal)"
          },
          "flowMode": {
            "type": "string",
            "enum": ["DEFAULT", "DIRECT"],
            "description": "Window type"
          },
          "easyPay": {
            "type": "string",
            "description": "Digital wallet provider code"
          },
          "cardCompany": {
            "type": "string",
            "description": "Card company code (Korean cards only)"
          },
          "provider": {
            "type": "string",
            "description": "Foreign easy pay provider code (e.g., ALIPAY, PAYPAL, GCASH)"
          },
          "appScheme": {
            "type": "string",
            "description": "App scheme for mobile redirect"
          }
        }
      },
      "ConfirmPaymentRequest": {
        "type": "object",
        "required": ["orderId", "amount"],
        "properties": {
          "orderId": {
            "type": "string",
            "description": "Order ID used when creating the payment"
          },
          "amount": {
            "type": "number",
            "description": "Payment amount to confirm"
          }
        }
      },
      "CancelPaymentRequest": {
        "type": "object",
        "required": ["cancelReason"],
        "properties": {
          "cancelReason": {
            "type": "string",
            "description": "Reason for cancellation"
          },
          "cancelAmount": {
            "type": "number",
            "description": "Amount to cancel. If omitted, full cancellation is performed."
          }
        }
      },
      "PaymentResponse": {
        "type": "object",
        "properties": {
          "paymentKey": {
            "type": "string",
            "description": "Unique payment key"
          },
          "orderId": {
            "type": "string",
            "description": "Order identifier"
          },
          "orderName": {
            "type": "string",
            "description": "Order name"
          },
          "status": {
            "type": "string",
            "description": "Payment status"
          },
          "method": {
            "type": "string",
            "description": "Payment method"
          },
          "totalAmount": {
            "type": "number",
            "description": "Total payment amount"
          },
          "currency": {
            "type": "string",
            "description": "Currency code"
          },
          "approvedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Approval timestamp"
          },
          "requestedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Request timestamp"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic HTTP Authorization. Encode your secret key (with colon appended) in Base64. Use test keys starting with test_sk for sandbox."
      }
    }
  },
  "security": [
    {
      "basicAuth": []
    }
  ]
}