{
  "openapi": "3.0.3",
  "info": {
    "title": "Bugcrowd API",
    "description": "Bugcrowd is a bug bounty and vulnerability disclosure platform. The API provides programmatic access to programs, submissions, and targets. Uses JSON:API specification for request/response formatting.",
    "version": "1.0.0",
    "contact": {
      "name": "Bugcrowd Support",
      "url": "https://www.bugcrowd.com"
    },
    "x-jentic-source-url": "https://docs.bugcrowd.com/api/getting-started/"
  },
  "servers": [
    {
      "url": "https://api.bugcrowd.com",
      "description": "Bugcrowd API production server"
    }
  ],
  "security": [
    {
      "TokenAuth": []
    }
  ],
  "tags": [
    { "name": "Programs", "description": "Bug bounty program management" },
    { "name": "Submissions", "description": "Vulnerability submission management" },
    { "name": "Targets", "description": "Program target management" }
  ],
  "paths": {
    "/programs": {
      "get": {
        "operationId": "listPrograms",
        "summary": "List programs",
        "description": "Retrieve a list of all accessible bug bounty programs.",
        "tags": ["Programs"],
        "parameters": [
          {
            "name": "fields[program]",
            "in": "query",
            "required": false,
            "description": "Sparse fieldsets - comma-separated list of attributes to return",
            "schema": { "type": "string" }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of related resources to include",
            "schema": { "type": "string" }
          },
          {
            "name": "filter[organization_id]",
            "in": "query",
            "required": false,
            "description": "Filter by organization ID",
            "schema": { "type": "string" }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort field and direction (e.g. name-asc)",
            "schema": { "type": "string" }
          },
          {
            "name": "page[limit]",
            "in": "query",
            "required": false,
            "description": "Number of records per page (0-100, default 25)",
            "schema": { "type": "integer", "minimum": 0, "maximum": 100, "default": 25 }
          },
          {
            "name": "page[offset]",
            "in": "query",
            "required": false,
            "description": "Pagination offset",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of programs",
            "content": {
              "application/vnd.bugcrowd+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProgramListResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/programs/{program_id}": {
      "get": {
        "operationId": "getProgram",
        "summary": "Get a program",
        "description": "Retrieve a specific bug bounty program by its UUID.",
        "tags": ["Programs"],
        "parameters": [
          {
            "name": "program_id",
            "in": "path",
            "required": true,
            "description": "Program UUID",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "fields[program]",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Program details",
            "content": {
              "application/vnd.bugcrowd+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProgramResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/submissions": {
      "get": {
        "operationId": "listSubmissions",
        "summary": "List submissions",
        "description": "Retrieve a list of vulnerability submissions with optional filtering.",
        "tags": ["Submissions"],
        "parameters": [
          {
            "name": "fields[submission]",
            "in": "query",
            "required": false,
            "description": "Sparse fieldsets for submission attributes",
            "schema": { "type": "string" }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "description": "Related resources to include (e.g. program, assignee)",
            "schema": { "type": "string" }
          },
          {
            "name": "filter[program]",
            "in": "query",
            "required": false,
            "description": "Filter by program UUID",
            "schema": { "type": "string" }
          },
          {
            "name": "filter[assignee]",
            "in": "query",
            "required": false,
            "description": "Filter by assignee (email, 'me', or 'none')",
            "schema": { "type": "string" }
          },
          {
            "name": "filter[duplicate]",
            "in": "query",
            "required": false,
            "description": "Filter duplicate submissions",
            "schema": { "type": "boolean" }
          },
          {
            "name": "filter[blocked_by]",
            "in": "query",
            "required": false,
            "description": "Filter by blocking status",
            "schema": { "type": "string" }
          },
          {
            "name": "filter[submitted][from]",
            "in": "query",
            "required": false,
            "description": "Filter submissions from date",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "filter[submitted][to]",
            "in": "query",
            "required": false,
            "description": "Filter submissions to date",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "filter[organization_id]",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Sort field (e.g. severity-asc, severity-desc)",
            "schema": { "type": "string" }
          },
          {
            "name": "page[limit]",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "maximum": 100, "default": 25 }
          },
          {
            "name": "page[offset]",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of submissions",
            "content": {
              "application/vnd.bugcrowd+json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionListResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/submissions/{submission_id}": {
      "get": {
        "operationId": "getSubmission",
        "summary": "Get a submission",
        "description": "Retrieve a specific vulnerability submission by UUID.",
        "tags": ["Submissions"],
        "parameters": [
          {
            "name": "submission_id",
            "in": "path",
            "required": true,
            "description": "Submission UUID",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "fields[submission]",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Submission details",
            "content": {
              "application/vnd.bugcrowd+json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      },
      "patch": {
        "operationId": "updateSubmission",
        "summary": "Update a submission",
        "description": "Update the state or attributes of a submission.",
        "tags": ["Submissions"],
        "parameters": [
          {
            "name": "submission_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.bugcrowd+json": {
              "schema": {
                "$ref": "#/components/schemas/SubmissionUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission updated",
            "content": {
              "application/vnd.bugcrowd+json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/targets": {
      "get": {
        "operationId": "listTargets",
        "summary": "List targets",
        "description": "Retrieve a list of program targets with optional filtering.",
        "tags": ["Targets"],
        "parameters": [
          {
            "name": "fields[target]",
            "in": "query",
            "required": false,
            "description": "Sparse fieldsets for target attributes",
            "schema": { "type": "string" }
          },
          {
            "name": "include",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "filter[program]",
            "in": "query",
            "required": false,
            "description": "Filter by program UUID",
            "schema": { "type": "string" }
          },
          {
            "name": "filter[organization_id]",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "page[limit]",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "maximum": 100, "default": 25 }
          },
          {
            "name": "page[offset]",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of targets",
            "content": {
              "application/vnd.bugcrowd+json": {
                "schema": {
                  "$ref": "#/components/schemas/TargetListResponse"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "TokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token-based authentication. Format: 'Token {api_key}:{api_secret}'"
      }
    },
    "schemas": {
      "JsonApiResource": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "string", "format": "uuid" },
          "attributes": { "type": "object" },
          "relationships": { "type": "object" }
        }
      },
      "PaginationLinks": {
        "type": "object",
        "properties": {
          "self": { "type": "string" },
          "next": { "type": "string", "nullable": true },
          "prev": { "type": "string", "nullable": true }
        }
      },
      "Program": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "example": "program" },
          "id": { "type": "string", "format": "uuid" },
          "attributes": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "name": { "type": "string" },
              "organization_id": { "type": "string" },
              "program_url": { "type": "string" },
              "tagline": { "type": "string" },
              "starts_at": { "type": "string", "format": "date-time", "nullable": true },
              "ends_at": { "type": "string", "format": "date-time", "nullable": true }
            }
          },
          "relationships": { "type": "object" }
        }
      },
      "ProgramResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Program" },
          "included": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/JsonApiResource" }
          }
        }
      },
      "ProgramListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Program" }
          },
          "included": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/JsonApiResource" }
          },
          "links": { "$ref": "#/components/schemas/PaginationLinks" }
        }
      },
      "Submission": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "example": "submission" },
          "id": { "type": "string", "format": "uuid" },
          "attributes": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "severity": { "type": "integer" },
              "state": { "type": "string" },
              "submitted_at": { "type": "string", "format": "date-time" },
              "closed_at": { "type": "string", "format": "date-time", "nullable": true },
              "duplicate": { "type": "boolean" },
              "description": { "type": "string" },
              "extra_info": { "type": "string", "nullable": true },
              "bug_url": { "type": "string", "nullable": true },
              "vrt_id": { "type": "string" },
              "custom_fields": { "type": "object" }
            }
          },
          "relationships": { "type": "object" }
        }
      },
      "SubmissionResponse": {
        "type": "object",
        "properties": {
          "data": { "$ref": "#/components/schemas/Submission" },
          "included": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/JsonApiResource" }
          }
        }
      },
      "SubmissionListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Submission" }
          },
          "included": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/JsonApiResource" }
          },
          "links": { "$ref": "#/components/schemas/PaginationLinks" }
        }
      },
      "SubmissionUpdateRequest": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "example": "submission" },
              "id": { "type": "string", "format": "uuid" },
              "attributes": {
                "type": "object",
                "properties": {
                  "state": { "type": "string" },
                  "severity": { "type": "integer" },
                  "duplicate": { "type": "boolean" }
                }
              }
            }
          }
        }
      },
      "Target": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "example": "target" },
          "id": { "type": "string", "format": "uuid" },
          "attributes": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "uri": { "type": "string" },
              "category": { "type": "string" },
              "tags": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "relationships": { "type": "object" }
        }
      },
      "TargetListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Target" }
          },
          "included": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/JsonApiResource" }
          },
          "links": { "$ref": "#/components/schemas/PaginationLinks" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "status": { "type": "string" },
                "title": { "type": "string" },
                "detail": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - validation error",
        "content": {
          "application/vnd.bugcrowd+json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing token",
        "content": {
          "application/vnd.bugcrowd+json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/vnd.bugcrowd+json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "TooManyRequests": {
        "description": "Rate limit exceeded - 60 requests per minute per IP",
        "content": {
          "application/vnd.bugcrowd+json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  }
}
