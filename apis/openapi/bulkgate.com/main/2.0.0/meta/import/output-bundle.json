        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvancedTransactionalRequestV2"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS accepted for delivery",
