{
  "openapi": "3.0.3",
  "info": {
    "title": "BulkGate SMS API",
    "description": "BulkGate is a messaging platform that enables companies and individuals to send personalized bulk SMS and SMS notifications. This API provides endpoints for sending transactional and promotional SMS messages, checking account credit balance, and managing multichannel messaging.",
    "version": "2.0.0",
    "contact": {
      "name": "BulkGate",
      "url": "https://www.bulkgate.com"
    },
    "x-jentic-source-url": "https://help.bulkgate.com/docs/en/http-advanced-transactional.html"
  },
  "servers": [
    {
      "url": "https://portal.bulkgate.com",
      "description": "BulkGate API Server"
    }
  ],
  "paths": {
    "/api/1.0/simple/transactional": {
      "post": {
        "operationId": "sendSimpleTransactionalSms",
        "summary": "Send simple transactional SMS",
        "description": "Sends a transactional SMS notification to a single recipient using the simple API (v1). Transactional SMS must not be used for promotional/marketing purposes.",
        "tags": [
          "Transactional SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SimpleTransactionalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS accepted for delivery",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionalResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/simple/promotional": {
      "post": {
        "operationId": "sendSimplePromotionalSms",
        "summary": "Send simple promotional SMS",
        "description": "Sends promotional SMS messages to one or more recipients using the simple API (v1). Supports semicolon-separated phone numbers for multiple recipients.",
        "tags": [
          "Promotional SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SimplePromotionalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS accepted for delivery",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromotionalResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/advanced/transactional": {
      "post": {
        "operationId": "sendAdvancedTransactionalSmsV1",
        "summary": "Send advanced transactional SMS (v1)",
        "description": "Sends a transactional SMS notification to an individual recipient using the advanced API v1. Supports template variables, scheduling, and sender customization.",
        "tags": [
          "Transactional SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvancedTransactionalRequestV1"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS accepted for delivery",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionalResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/1.0/advanced/promotional": {
      "post": {
        "operationId": "sendAdvancedPromotionalSmsV1",
        "summary": "Send advanced promotional SMS (v1)",
        "description": "Sends promotional SMS messages to individual recipients, groups from address book, or administrators using the advanced API v1. Supports template variables, scheduling, and duplicate checking.",
        "tags": [
          "Promotional SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvancedPromotionalRequestV1"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS accepted for delivery",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromotionalResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/2.0/advanced/transactional": {
      "post": {
        "operationId": "sendAdvancedTransactionalSmsV2",
        "summary": "Send advanced transactional SMS (v2)",
        "description": "Sends transactional SMS notifications to one or multiple recipients using the advanced API v2. Supports alternative delivery channels (Viber, RCS, WhatsApp) in cascade format, template variables, and scheduling.",
        "tags": [
