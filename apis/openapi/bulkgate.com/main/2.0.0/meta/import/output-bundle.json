                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "applicationAuth": {
        "type": "apiKey",
        "in": "body",
        "name": "application_token",
        "description": "Authentication via application_id and application_token included in the request body. Obtain credentials from the BulkGate Portal under API administration."
      }
    },
    "schemas": {
      "AuthRequest": {
        "type": "object",
        "required": [
          "application_id",
          "application_token"
        ],
        "properties": {
          "application_id": {
            "type": "string",
            "description": "Application identifier obtained from BulkGate Portal"
          },
          "application_token": {
            "type": "string",
            "description": "Application authentication token"
          }
        }
      },
      "SimpleTransactionalRequest": {
        "type": "object",
        "required": [
          "application_id",
          "application_token",
          "number",
          "text"
        ],
        "properties": {
          "application_id": {
            "type": "string",
            "description": "Application identifier"
          },
          "application_token": {
            "type": "string",
            "description": "Application authentication token"
          },
          "number": {
            "type": "string",
            "description": "Recipient phone number in international format"
          },
          "text": {
            "type": "string",
            "description": "Message content"
          },
          "unicode": {
            "type": "boolean",
            "description": "Enable Unicode encoding for the message"
          },
          "sender_id": {
            "type": "string",
            "description": "Sender identifier type",
            "enum": [
              "gSystem",
              "gText",
              "gOwn",
              "gMobile",
              "gPush"
            ]
          },
          "sender_id_value": {
            "type": "string",
            "description": "Custom sender name or identifier value"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code for number formatting"
          }
        }
      },
      "SimplePromotionalRequest": {
        "type": "object",
        "required": [
          "application_id",
          "application_token",
          "number",
          "text"
        ],
        "properties": {
          "application_id": {
            "type": "string",
            "description": "Application identifier"
          },
          "application_token": {
            "type": "string",
            "description": "Application authentication token"
          },
          "number": {
            "type": "string",
            "description": "Recipient phone numbers separated by semicolons"
          },
          "text": {
            "type": "string",
            "description": "Message content"
          },
          "unicode": {
            "type": "boolean",
            "description": "Enable Unicode encoding for the message"
          },
          "sender_id": {
            "type": "string",
            "description": "Sender identifier type"
          },
          "sender_id_value": {
            "type": "string",
            "description": "Custom sender name or identifier value"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code for number formatting"
          },
          "schedule": {
            "type": "string",
            "description": "Scheduled delivery time in ISO 8601 format or Unix timestamp"
          }
        }
      },
      "AdvancedTransactionalRequestV1": {
        "type": "object",
        "required": [
          "application_id",
          "application_token",
          "number",
          "text"
        ],
        "properties": {
          "application_id": {
            "type": "string",
            "description": "Application identifier"
          },
          "application_token": {
            "type": "string",
            "description": "Application authentication token"
          },
          "number": {
            "type": "string",
            "description": "Recipient phone number in international format"
          },
          "text": {
            "type": "string",
            "description": "Message content (max 612 characters, 268 with Unicode)",
            "maxLength": 612
          },
          "variables": {
            "type": "object",
            "description": "Template variable substitutions as key-value pairs",
            "additionalProperties": {
              "type": "string"
            }
          },
          "unicode": {
            "type": "boolean",
            "description": "Enable Unicode encoding"
          },
          "sender_id": {
            "type": "string",
            "description": "Sender identifier type",
            "enum": [
              "gSystem",
              "gText",
              "gOwn",
              "gMobile",
              "gPush"
            ]
          },
          "sender_id_value": {
            "type": "string",
            "description": "Custom sender name or identifier value"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code"
          },
          "schedule": {
            "type": "string",
            "description": "Scheduled delivery time in ISO 8601 format or Unix timestamp"
          },
          "duplicates_check": {
            "type": "string",
            "description": "Duplicate prevention mode",
            "enum": [
              "same_text",
              "same_number"
            ]
          },
          "tag": {
            "type": "string",
            "description": "Message label for retrieval and tracking"
          }
        }
      },
      "AdvancedPromotionalRequestV1": {
        "type": "object",
        "required": [
          "application_id",
          "application_token",
          "text"
        ],
        "properties": {
          "application_id": {
            "type": "string",
            "description": "Application identifier"
          },
          "application_token": {
            "type": "string",
            "description": "Application authentication token"
          },
          "number": {
            "type": "array",
            "description": "Array of recipient phone numbers or objects with number/text/variables",
            "items": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "$ref": "#/components/schemas/RecipientObject"
                }
              ]
            }
          },
          "groups": {
            "type": "array",
            "description": "Array of group IDs from the address book",
            "items": {
              "type": "string"
            }
          },
          "admins": {
            "type": "array",
            "description": "Array of administrator notification IDs",
            "items": {
              "type": "string"
            }
          },
          "text": {
            "type": "string",
            "description": "Message content (max 612 characters, 268 with Unicode)",
            "maxLength": 612
          },
          "unicode": {
            "type": "boolean",
            "description": "Enable Unicode encoding"
          },
          "sender_id": {
            "type": "string",
            "description": "Sender identifier type",
            "enum": [
              "gSystem",
              "gText",
              "gOwn",
              "gMobile",
              "gPush"
            ]
          },
          "sender_id_value": {
            "type": "string",
            "description": "Custom sender name or identifier value"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code"
          },
          "schedule": {
            "type": "string",
            "description": "Scheduled delivery time in ISO 8601 or Unix timestamp"
          },
          "duplicates_check": {
            "type": "string",
            "description": "Duplicate prevention mode",
            "enum": [
              "same_text",
              "same_number"
            ]
          },
          "tag": {
            "type": "string",
            "description": "Message label for retrieval and tracking"
          }
        }
      },
      "AdvancedTransactionalRequestV2": {
        "type": "object",
        "required": [
          "application_id",
          "application_token",
          "number",
          "text"
        ],
        "properties": {
          "application_id": {
            "type": "string",
            "description": "Application identifier"
          },
          "application_token": {
            "type": "string",
            "description": "Application authentication token"
          },
          "number": {
            "type": "array",
            "description": "Array of recipient phone numbers",
            "items": {
              "type": "string"
            }
          },
          "text": {
            "type": "string",
            "description": "Message content (max 612 characters, 268 with Unicode)",
            "maxLength": 612
          },
          "variables": {
            "type": "object",
            "description": "Template variable substitutions",
            "additionalProperties": {
              "type": "string"
            }
          },
          "channel": {
            "$ref": "#/components/schemas/ChannelConfig"
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code"
          },
          "schedule": {
            "type": "string",
            "description": "Scheduled delivery time in ISO 8601 or Unix timestamp"
          },
          "duplicates_check": {
            "type": "string",
            "description": "Duplicate prevention mode",
            "enum": [
              "same_text",
              "same_number"
            ]
          },
          "tag": {
            "type": "string",
            "description": "Message label for retrieval and tracking"
          }
        }
      },
      "AdvancedPromotionalRequestV2": {
        "type": "object",
        "required": [
          "application_id",
          "application_token",
          "text"
        ],
        "properties": {
          "application_id": {
            "type": "string",
            "description": "Application identifier"
          },
          "application_token": {
            "type": "string",
            "description": "Application authentication token"
          },
          "number": {
            "type": "array",
            "description": "Array of recipient phone numbers or objects",
            "items": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "$ref": "#/components/schemas/RecipientObject"
                }
              ]
            }
          },
          "groups": {
            "type": "array",
            "description": "Array of address book group IDs",
            "items": {
              "type": "string"
            }
          },
          "admins": {
            "type": "array",
            "description": "Array of administrator notification IDs",
            "items": {
              "type": "string"
            }
          },
          "text": {
            "type": "string",
            "description": "Message content (max 612 characters, 268 with Unicode)",
            "maxLength": 612
          },
          "country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code"
          },
          "schedule": {
            "type": "string",
            "description": "Scheduled delivery time in ISO 8601 or Unix timestamp"
          },
          "duplicates_check": {
            "type": "string",
            "description": "Duplicate prevention mode",
            "enum": [
              "same_text",
              "same_number"
            ]
          },
          "tag": {
            "type": "string",
            "description": "Message label for tracking"
          },
          "channel": {
            "$ref": "#/components/schemas/ChannelConfig"
          }
        }
      },
      "RecipientObject": {
        "type": "object",
        "properties": {
          "number": {
            "type": "string",
            "description": "Recipient phone number"
          },
          "text": {
            "type": "string",
            "description": "Custom message text for this recipient"
          },
          "variables": {
            "type": "object",
            "description": "Template variables for this recipient",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "ChannelConfig": {
        "type": "object",
        "description": "Alternative delivery channel configuration for cascade delivery (Viber, RCS, WhatsApp)",
        "properties": {
          "viber": {
            "type": "object",
            "description": "Viber channel configuration",
            "properties": {
              "sender_id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          },
          "rcs": {
            "type": "object",
            "description": "RCS channel configuration",
            "properties": {
              "sender_id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          },
          "whatsapp": {
            "type": "object",
            "description": "WhatsApp channel configuration",
            "properties": {
              "sender_id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          }
        }
      },
      "TransactionalResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "description": "Message status (e.g., accepted)"
              },
              "sms_id": {
                "type": "string",
                "description": "Unique message identifier"
              },
              "part_id": {
                "type": "array",
                "description": "Array of part IDs for split messages",
                "items": {
                  "type": "string"
                }
              },
              "number": {
                "type": "string",
                "description": "Recipient phone number"
              }
            }
          }
        }
      },
      "PromotionalResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "total": {
                "$ref": "#/components/schemas/StatusSummary"
              },
              "response": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/MessageStatus"
                }
              }
            }
          }
        }
      },
      "AdvancedResponseV2": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "total": {
                "$ref": "#/components/schemas/StatusSummary"
              },
              "response": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/MessageStatusV2"
                }
              }
            }
          }
        }
      },
      "StatusSummary": {
        "type": "object",
        "properties": {
          "status": {
            "type": "object",
            "properties": {
              "sent": {
                "type": "integer"
              },
              "accepted": {
                "type": "integer"
              },
              "scheduled": {
                "type": "integer"
              },
              "error": {
                "type": "integer"
              },
              "blacklisted": {
                "type": "integer"
              },
              "invalid_number": {
                "type": "integer"
              },
              "invalid_sender": {
                "type": "integer"
              }
            }
          }
        }
      },
      "MessageStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Message delivery status"
          },
          "sms_id": {
            "type": "string",
            "description": "Unique message identifier"
          },
          "part_id": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of part IDs for split messages"
          },
          "number": {
            "type": "string",
            "description": "Recipient phone number"
          }
        }
      },
      "MessageStatusV2": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Message delivery status"
          },
          "message_id": {
            "type": "string",
            "description": "Unique message identifier"
          },
          "part_id": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of part IDs for split messages"
