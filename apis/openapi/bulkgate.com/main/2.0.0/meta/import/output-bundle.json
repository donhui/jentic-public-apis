                  "$ref": "#/components/schemas/AdvancedResponseV2"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/2.0/advanced/promotional": {
      "post": {
        "operationId": "sendAdvancedPromotionalSmsV2",
        "summary": "Send advanced promotional SMS (v2)",
        "description": "Sends promotional SMS and multichannel messages using the advanced API v2. Supports alternative channels in cascade format, delivering through prioritized channels before falling back to SMS.",
        "tags": [
          "Promotional SMS"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdvancedPromotionalRequestV2"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMS accepted for delivery",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdvancedResponseV2"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid credentials",
            "content": {
              "application/json": {
