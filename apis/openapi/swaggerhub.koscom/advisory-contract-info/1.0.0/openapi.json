{
    "openapi": "3.0.0",
    "info": {
        "description": "자문계약의 통지와 계약조건 등의 전달",
        "version": "1.0.0",
        "title": "자문계약통지",
        "contact": {
            "email": "khj932@koscom.co.kr"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/KOSCOM/advisory_contract_info/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "플랫폼",
            "description": "자문계약이 발생하는 서비스에서 호출"
        }
    ],
    "paths": {
        "/advisory-contract-notice": {
            "post": {
                "tags": [
                    "플랫폼"
                ],
                "summary": "체결된 자문계약내용을 판매사로 통지",
                "operationId": "advisoryContractInfo",
                "description": "체결된 자문계약내용을 판매사로 통지",
                "parameters": [
                    {
                        "in": "query",
                        "name": "advisoryContractType",
                        "description": "자문계약유형",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "신규",
                                "갱신",
                                "철회",
                                "만료",
                                "해지",
                                "추가입금"
                            ]
                        }
                    },
                    {
                        "in": "query",
                        "name": "salesCompId",
                        "description": "판매사 번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryId",
                        "description": "자산관리회사 번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "ci",
                        "description": "본인확인결과인 CI",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "name",
                        "description": "계좌명의자 이름",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "accountNo",
                        "description": "dash(-)없는 계좌번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryType",
                        "description": "자문유형",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "포괄",
                                "위탁",
                                "파생",
                                "연금저축",
                                "IRP",
                                "ISA"
                            ]
                        }
                    },
                    {
                        "in": "query",
                        "name": "contractDate",
                        "description": "자문계약일(YYYYMMDD)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "contractEndDate",
                        "description": "자문계약만기일(YYYYMMDD)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "contractId",
                        "description": "자문계약번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "OrgcontractId",
                        "description": "원자문계약번호",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "amountOfInvested",
                        "description": "투자예정금액(자문수수료제외)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "withdrawalProhibition",
                        "description": "계좌설정",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "입금금지",
                                "출금금지",
                                "입출금금지"
                            ]
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryRemunerationType",
                        "description": "자문보수유형",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "무료",
                                "선취",
                                "후취",
                                "성과보수",
                                "기타"
                            ]
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryRemunerationCondition",
                        "description": "자문보수수취방법",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "정률",
                                "정액",
                                "기타"
                            ]
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryRemuneration",
                        "description": "자문보수수취조건(정률-00.00%, 정액-000.0원)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryFee",
                        "description": "자문보수(선취/원)",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryFirmAccountNo",
                        "description": "자문보수입금계좌번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryFirmAccountNoIssueBank",
                        "description": "자문보수입금계좌개설은행명",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "정상처리완료"
                    },
                    "400": {
                        "description": "처리 오류",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Error"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/KOSCOM/advisory_contract_info/1.0.0"
        }
    ],
    "components": {
        "schemas": {
            "Error": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "integer",
                        "description": "error code"
                    },
                    "message": {
                        "type": "string",
                        "description": "처리 불가 이유"
                    }
                }
            }
        }
    }
}