{
    "openapi": "3.0.0",
    "info": {
        "description": "간편계좌조회(투자가능금액조회 - 예수금)",
        "version": "1.0.0",
        "title": "간편계좌조회(투자가능금액조회)",
        "contact": {
            "email": "khj932@koscom.co.kr"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/KOSCOM/account_balance_simple_query/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "플랫폼",
            "description": "플랫폼이 판매사로 조회요청"
        }
    ],
    "paths": {
        "/get-deposit": {
            "get": {
                "tags": [
                    "플랫폼"
                ],
                "summary": "투자가능금액확인을 위한 예수금조회",
                "operationId": "getDeposit",
                "description": "계좌개설 후 투자금입금, 추가입금 등 후 투자가능금액 확인",
                "parameters": [
                    {
                        "in": "query",
                        "name": "salesCompId",
                        "description": "판매사 번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryId",
                        "description": "자산관리회사 번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "accountNo",
                        "description": "조회하고자 하는 계좌번호, dash(-)없는 계좌번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "ci",
                        "description": "본인확인의 결과인 CI",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "search results matching criteria",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/DepositList"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "bad input parameter"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/KOSCOM/account_balance_simple_query/1.0.0"
        }
    ],
    "components": {
        "schemas": {
            "DepositList": {
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/Deposit"
                }
            },
            "Deposit": {
                "required": [
                    "depositAmt",
                    "currency"
                ],
                "properties": {
                    "depositAmt": {
                        "type": "number",
                        "description": "예수금(주문가능금액)",
                        "example": 15202000
                    },
                    "currency": {
                        "type": "string",
                        "description": "통화코드",
                        "example": "KRW"
                    }
                }
            }
        }
    }
}