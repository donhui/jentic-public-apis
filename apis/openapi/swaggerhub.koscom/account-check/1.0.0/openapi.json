{
    "openapi": "3.0.0",
    "info": {
        "description": "자문이 가능한 계좌가 개설되어 있는지 확인하기 위해 CI를 키로 계좌리스트 조회",
        "version": "1.0.0",
        "title": "개설계좌조회",
        "contact": {
            "email": "khj932@koscom.co.kr"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/KOSCOM/account_check/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "플랫폼",
            "description": "개설된 계좌리스트 조회"
        }
    ],
    "paths": {
        "/get-account-list": {
            "post": {
                "tags": [
                    "플랫폼->판매사"
                ],
                "summary": "개설계좌리스트조회",
                "operationId": "getAccountList",
                "description": "자문계약전 자문이 가능한 계좌가 존재하는지 확인하기 위해 계좌리스트를 CI를 KEY로 조회하고 그 결과를 응답으로 받음\n",
                "parameters": [
                    {
                        "in": "query",
                        "name": "salesCompId",
                        "description": "판매사 번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "advisoryId",
                        "description": "자산관리회사 번호",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "ci",
                        "description": "본인확인결과인 CI",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "in": "query",
                        "name": "name",
                        "description": "계좌명의자 이름",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "계좌를 찾아 그 리스트를 응답",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/AccountList"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "bad input parameter"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://virtserver.swaggerhub.com/KOSCOM/account_check/1.0.0"
        }
    ],
    "components": {
        "schemas": {
            "AccountList": {
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/Account"
                }
            },
            "Account": {
                "required": [
                    "accountNo",
                    "accountName",
                    "issueDate",
                    "accountType",
                    "advioryContracted",
                    "advisoryName"
                ],
                "properties": {
                    "accountNo": {
                        "type": "string",
                        "description": "dash(-)없는 계좌번호",
                        "example": "02123323"
                    },
                    "accountName": {
                        "type": "string",
                        "description": "계좌명",
                        "example": "김흥재"
                    },
                    "issuedDate": {
                        "type": "string",
                        "description": "계좌개설일",
                        "example": "20200402"
                    },
                    "accountType": {
                        "type": "string",
                        "description": "계좌유형구분자",
                        "enum": [
                            "종합-00",
                            "위탁-01",
                            "상품-02",
                            "연금저축-03",
                            "퇴직연금(IRP)-04",
                            "퇴직연금(DC)-05",
                            "ISA-06",
                            "파생-07",
                            "외화-08"
                        ],
                        "example": "03"
                    },
                    "advioryContracted": {
                        "description": "자문계약설정여부",
                        "type": "boolean",
                        "example": true
                    },
                    "advisoryName": {
                        "type": "string",
                        "description": "계약자문사명",
                        "example": "플레인바닐라투자자문"
                    }
                }
            }
        }
    }
}