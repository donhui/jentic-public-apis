{
    "openapi": "3.0.0",
    "info": {
        "version": "0.2",
        "title": "AI-GREEN-RESERVATION-FLIGHT-CORE",
        "description": "The internal API of the core microsoervice from the Reservation team. It manages our view on flights.",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/Octav14n/AI-GREEN-RESERVATION-FLIGHT-CORE/0.2/swagger.json"
    },
    "paths": {
        "/flights": {
            "get": {
                "description": "Returns all flights that have extra informations provided by us.",
                "responses": {
                    "200": {
                        "description": "Successfully requested the resource.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Flight"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Could not request the resource.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Exception"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Creates a new flight.",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Flight"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Successfully created the resource.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Flight"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Could not create the resource.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Exception"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/flights/{flightId}": {
            "parameters": [
                {
                    "name": "flightId",
                    "in": "path",
                    "required": true,
                    "description": "The ID of the flight you wan't to access.",
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "get": {
                "description": "Returns the specified flight.",
                "responses": {
                    "200": {
                        "description": "Successfully requested the resource.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Flight"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Could not request the resource.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Exception"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "The requested resource was not found.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Exception"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/flights/{flightId}/{reserveBuy}/{class}": {
            "parameters": [
                {
                    "name": "flightId",
                    "in": "path",
                    "required": true,
                    "description": "The ID of the flight you want to access.",
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "reserveBuy",
                    "in": "path",
                    "required": true,
                    "description": "Defines which action you want to access in the specified flight. [you must only use \"reserve\" or \"buy\".]",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "reserve",
                            "buy"
                        ]
                    }
                },
                {
                    "name": "class",
                    "in": "path",
                    "required": true,
                    "description": "Definies which class you want to access in the specified flight. [you must only use \"business\" or \"economy\".]",
                    "schema": {
                        "type": "string",
                        "enum": [
                            "business",
                            "economy"
                        ]
                    }
                }
            ],
            "post": {
                "description": "Adds/Subtracts the specified amount of reservations/buies to the specified flights specified class.",
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "amount": {
                                        "description": "Amount that shall be added/subtracted to the specified flight.",
                                        "type": "integer"
                                    }
                                },
                                "required": [
                                    "amount"
                                ]
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successfully updated the resource.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Flight"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Could not update the resource.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Exception"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "The requested resource was not found.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Exception"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Flight": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "description": "PrimaryKey. Has to be identical with the ID provided by FlightOP."
                    },
                    "seatsTotalBusiness": {
                        "type": "integer",
                        "description": "Total seats available in business class."
                    },
                    "seatsReservedBusiness": {
                        "type": "integer",
                        "default": 0,
                        "description": "Number of seats that are reserved in business class."
                    },
                    "seatsSoldBusiness": {
                        "type": "integer",
                        "default": 0,
                        "description": "Number of seats that are sold in business class."
                    },
                    "seatsTotalEconomy": {
                        "type": "integer",
                        "description": "Total seats available in economy class."
                    },
                    "seatsReservedEconomy": {
                        "type": "integer",
                        "default": 0,
                        "description": "Number of seats that are reserved in economy class."
                    },
                    "seatsSoldEconomy": {
                        "type": "integer",
                        "default": 0,
                        "description": "Number of seats that are sold in economy class."
                    },
                    "airlineID": {
                        "type": "integer",
                        "description": "ID of the airline that provides this flight."
                    }
                },
                "required": [
                    "id",
                    "seatsTotalBusiness",
                    "seatsTotalEconomy",
                    "airlineID"
                ]
            },
            "Exception": {
                "type": "object",
                "properties": {
                    "class": {
                        "type": "string",
                        "description": "Class of the thrown top most Exception."
                    },
                    "message": {
                        "type": "string",
                        "description": "A userdefined and user readable explaination of why this Exception occured."
                    },
                    "stacktrace": {
                        "type": "array",
                        "description": "Stacktrace as string array.",
                        "items": {
                            "type": "string"
                        }
                    },
                    "causedBy": {
                        "$ref": "#/components/schemas/Exception"
                    }
                },
                "required": [
                    "class",
                    "message",
                    "stacktrace"
                ]
            }
        }
    }
}