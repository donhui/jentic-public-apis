{
    "openapi": "3.0.0",
    "info": {
        "version": "0.1",
        "title": "Reservation Core",
        "description": "The internal API of the core microservice from the Reservation team of group Green.",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/Octav14n/AI-GREEN-RESERVATION-CORE/0.1/swagger.json"
    },
    "paths": {
        "/user/{userId}/reservations": {
            "parameters": [
                {
                    "name": "userId",
                    "in": "path",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "get": {
                "description": "Returns all reservations made by the specified user.",
                "responses": {
                    "200": {
                        "description": "Returns all reservations made by the specified user."
                    }
                }
            },
            "post": {
                "description": "Creates a new reservation for the specified user.",
                "requestBody": {
                    "$ref": "#/components/requestBodies/Reservation"
                },
                "responses": {
                    "200": {
                        "description": "User was created successful."
                    },
                    "400": {
                        "description": "User could not be created."
                    }
                }
            }
        },
        "/user/{userId}/reservations/{reservationId}": {
            "parameters": [
                {
                    "name": "userId",
                    "in": "path",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "reservationId",
                    "in": "path",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "get": {
                "description": "Returns the specified reservation made by the specified user.",
                "responses": {
                    "200": {
                        "description": "Successful requested the resource.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/Reservation"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to request the resource."
                    }
                }
            },
            "put": {
                "description": "Updates the specified reservation made by the specified user.",
                "requestBody": {
                    "$ref": "#/components/requestBodies/Reservation"
                },
                "responses": {
                    "200": {
                        "description": "Successful updated the resource."
                    },
                    "400": {
                        "description": "Falied to update the resource."
                    }
                }
            },
            "delete": {
                "description": "Deletes the specified reservation made by the specified user.",
                "responses": {
                    "200": {
                        "description": "Sucessful deleted the resource."
                    },
                    "400": {
                        "description": "Failed to delete the resource."
                    }
                }
            }
        }
    },
    "components": {
        "requestBodies": {
            "Reservation": {
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/Reservation"
                        }
                    }
                },
                "required": true
            }
        },
        "schemas": {
            "Reservation": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "flight": {
                        "type": "integer"
                    },
                    "customer": {
                        "type": "integer"
                    },
                    "reservedOn": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "airline": {
                        "type": "string"
                    },
                    "validUntil": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            }
        }
    }
}