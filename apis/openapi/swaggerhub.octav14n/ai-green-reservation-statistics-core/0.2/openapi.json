{
  "swagger": "2.0",
  "info": {
    "version": "0.2",
    "title": "AI-GREEN-RESERVATION-STATISTICS-CORE",
    "description": "The internal API of the statistics-core microservice from the Reservation team.",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Octav14n/AI-GREEN-RESERVATION-STATISTICS-CORE/0.2/swagger.json"
  },
  "paths": {
    "/partners": {
      "get": {
        "description": "Lists all statistics of all partners.",
        "responses": {
          "200": {
            "description": "Returns the requested resources successfully.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/PartnerStats"
              }
            }
          }
        }
      },
      "post": {
        "description": "Creates a new stasistic for a new partner.",
        "parameters": [
          {
            "name": "partnerStats",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PartnerStats"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Successfully created the resource.",
            "schema": {
              "$ref": "#/definitions/PartnerStats"
            }
          }
        }
      }
    },
    "/partners/{partnerID}": {
      "parameters": [
        {
          "name": "partnerID",
          "in": "path",
          "description": "ID of the partner of which you want to access the statistics.",
          "type": "integer",
          "required": true
        }
      ],
      "get": {
        "description": "Returns the statistics of the specified partner.",
        "responses": {
          "200": {
            "description": "Returns the requested resource successfully.",
            "schema": {
              "$ref": "#/definitions/PartnerStats"
            }
          },
          "404": {
            "description": "The requested resource was not found.",
            "schema": {
              "$ref": "#/definitions/Exception"
            }
          }
        }
      }
    },
    "/partners/{partnerID}/{action}": {
      "parameters": [
        {
          "name": "partnerID",
          "in": "path",
          "description": "ID of the partner of which you want to access the statistics.",
          "type": "integer",
          "required": true
        },
        {
          "name": "action",
          "description": "Statistic you want to update. Has to be either \"reserved\" or \"searched\".",
          "type": "string",
          "in": "path",
          "required": true,
          "enum": [
            "reserved",
            "searched"
          ]
        }
      ],
      "post": {
        "description": "Adds/Subtracts the specified amount to the specified statistic of the specified partner.",
        "parameters": [
          {
            "name": "amount",
            "in": "formData",
            "type": "integer",
            "description": "Amount that shall be added/subtracted to the specified statistic.",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully updated the resource.",
            "schema": {
              "$ref": "#/definitions/PartnerStats"
            }
          },
          "400": {
            "description": "Could not update the resource.",
            "schema": {
              "$ref": "#/definitions/Exception"
            }
          },
          "404": {
            "description": "The requested resource was not found.",
            "schema": {
              "$ref": "#/definitions/Exception"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "PartnerStats": {
      "type": "object",
      "description": "Representation of the Partner Statistics.",
      "properties": {
        "id": {
          "type": "integer"
        },
        "partnerID": {
          "type": "integer"
        },
        "numberOfReservedFlights": {
          "type": "integer"
        },
        "numberOfSearchedFlights": {
          "type": "integer"
        }
      },
      "required": [
        "id",
        "partnerID"
      ]
    },
    "Exception": {
      "type": "object",
      "properties": {
        "class": {
          "type": "string",
          "description": "Class of the thrown top most Exception."
        },
        "message": {
          "type": "string",
          "description": "A userdefined and user readable explaination of why this Exception occured."
        },
        "stacktrace": {
          "type": "array",
          "description": "Stacktrace as string array.",
          "items": {
            "type": "string"
          }
        },
        "causedBy": {
          "description": "The Exception this reported Exception was caused by.",
          "type": "object",
          "$ref": "#/definitions/Exception"
        }
      },
      "required": [
        "class",
        "message",
        "stacktrace"
      ]
    }
  }
}