{
  "openapi": "3.0.3",
  "info": {
    "title": "RxNorm API",
    "version": "1.0.0",
    "description": "The RxNorm API provides access to standardized drug nomenclature and drug-drug interaction information. RxNorm is produced by the National Library of Medicine and provides normalized names for clinical drugs and links between these names and associated drug information from various sources.",
    "x-jentic-source-url": "https://lhncbc.nlm.nih.gov/RxNav/APIs/RxNormAPIs.html"
  },
  "servers": [
    {
      "url": "https://rxnav.nlm.nih.gov/REST",
      "description": "RxNorm Production API"
    }
  ],
  "security": [],
  "tags": [
    {
      "name": "Concept Lookup",
      "description": "Operations to find and retrieve RxNorm concepts"
    },
    {
      "name": "Relationships",
      "description": "Operations to explore relationships between concepts"
    },
    {
      "name": "NDC Operations",
      "description": "Operations related to National Drug Codes"
    },
    {
      "name": "Metadata",
      "description": "Operations to retrieve API and data version information"
    }
  ],
  "paths": {
    "/rxcui": {
      "get": {
        "operationId": "findRxcuiByString",
        "summary": "Find RxCUI by name string",
        "description": "Search for RxNorm concepts matching a drug name query string",
        "tags": ["Concept Lookup"],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Drug name to search for"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [0, 1, 2]
            },
            "description": "Search type: 0=exact match (default), 1=normalized, 2=best match"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RxcuiResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/rxcui/{rxcui}": {
      "get": {
        "operationId": "getRxNormName",
        "summary": "Get RxNorm name for RxCUI",
        "description": "Retrieve the name associated with a specific RxCUI",
        "tags": ["Concept Lookup"],
        "parameters": [
          {
            "name": "rxcui",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "RxNorm Concept Unique Identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RxNormNameResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "RxCUI not found"
          }
        }
      }
    },
    "/rxcui/{rxcui}/properties": {
      "get": {
        "operationId": "getRxConceptProperties",
        "summary": "Get concept properties",
        "description": "Retrieve properties for a specific RxNorm concept",
        "tags": ["Concept Lookup"],
        "parameters": [
          {
            "name": "rxcui",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "RxNorm Concept Unique Identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConceptPropertiesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "RxCUI not found"
          }
        }
      }
    },
    "/rxcui/{rxcui}/allProperties": {
      "get": {
        "operationId": "getAllProperties",
        "summary": "Get all concept properties",
        "description": "Retrieve comprehensive properties and attributes for a specific RxNorm concept",
        "tags": ["Concept Lookup"],
        "parameters": [
          {
            "name": "rxcui",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "RxNorm Concept Unique Identifier"
          },
          {
            "name": "prop",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Specific property to retrieve"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllPropertiesResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "RxCUI not found"
          }
        }
      }
    },
    "/rxcui/{rxcui}/related": {
      "get": {
        "operationId": "getRelatedByType",
        "summary": "Get related concepts",
        "description": "Retrieve concepts related to the specified RxCUI by relationship type or term type",
        "tags": ["Relationships"],
        "parameters": [
          {
            "name": "rxcui",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "RxNorm Concept Unique Identifier"
          },
          {
            "name": "tty",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Term type (e.g., IN, BN, SCD, GPCK)"
          },
          {
            "name": "rela",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Relationship attribute"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RelatedConceptsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "RxCUI not found"
          }
        }
      }
    },
    "/rxcui/{rxcui}/allrelated": {
      "get": {
        "operationId": "getAllRelatedInfo",
        "summary": "Get all related information",
        "description": "Retrieve all directly and indirectly related concepts for a given RxCUI",
        "tags": ["Relationships"],
        "parameters": [
          {
            "name": "rxcui",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "RxNorm Concept Unique Identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AllRelatedResponse"
