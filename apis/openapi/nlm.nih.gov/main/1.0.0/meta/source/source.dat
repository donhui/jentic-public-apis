            "description": "RxCUI not found"
          }
        }
      }
    },
    "/rxcui/{rxcui}/filter": {
      "get": {
        "operationId": "filterByProperty",
        "summary": "Filter concepts by property",
        "description": "Filter RxNorm concepts using property predicates",
        "tags": ["Concept Lookup"],
        "parameters": [
          {
            "name": "rxcui",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "RxNorm Concept Unique Identifier"
          },
          {
            "name": "propName",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Property name to filter by"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FilterResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "RxCUI not found"
          }
        }
      }
    },
    "/rxcui/{rxcui}/generic": {
      "get": {
        "operationId": "getGenericProduct",
        "summary": "Get generic equivalent",
        "description": "Retrieve the generic (unbranded) RxCUI equivalent for a brand-name drug",
        "tags": ["Concept Lookup"],
        "parameters": [
          {
            "name": "rxcui",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "RxNorm Concept Unique Identifier for brand-name drug"
