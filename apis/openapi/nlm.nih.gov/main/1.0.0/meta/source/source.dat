            "description": "Unauthorized"
          },
          "404": {
            "description": "RxCUI not found"
          }
        }
      }
    },
    "/rxcui/{rxcui}/allhistoricalndcs": {
      "get": {
        "operationId": "getAllHistoricalNDCs",
        "summary": "Get all historical NDCs",
        "description": "Retrieve all NDC codes that have ever been associated with the specified RxCUI, including historical codes",
        "tags": ["NDC Operations"],
        "parameters": [
          {
            "name": "rxcui",
            "in": "path",
            "required": true,
