          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "RxCUI not found"
          }
        }
      }
    },
    "/rxcui/{rxcui}/ndcs": {
      "get": {
        "operationId": "getNDCs",
        "summary": "Get NDCs for concept",
        "description": "Retrieve National Drug Codes (NDCs) associated with the specified RxCUI",
