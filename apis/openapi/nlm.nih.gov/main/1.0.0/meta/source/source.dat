    },
    "/approximateTerm": {
      "get": {
        "operationId": "getApproximateMatch",
        "summary": "Get approximate matches",
        "description": "Find RxNorm concepts that approximately match a search term using fuzzy matching",
        "tags": ["Concept Lookup"],
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search term for approximate matching"
          },
          {
            "name": "maxEntries",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            },
            "description": "Maximum number of results to return"
          },
          {
            "name": "option",
            "in": "query",
            "schema": {
              "type": "integer",
              "enum": [0, 1],
              "default": 0
            },
            "description": "0 for current concepts, 1 for active concepts"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApproximateMatchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/spellingsuggestions": {
      "get": {
        "operationId": "getSpellingSuggestions",
        "summary": "Get spelling suggestions",
        "description": "Retrieve spelling suggestions for a drug name query",
        "tags": ["Concept Lookup"],
        "parameters": [
          {
            "name": "name",
            "in": "query",
