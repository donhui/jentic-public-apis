    },
    "/rxcui/{rxcui}/historystatus": {
      "get": {
        "operationId": "getRxcuiHistoryStatus",
        "summary": "Get RxCUI history status",
        "description": "Retrieve the history and status information for a specific RxCUI",
        "tags": ["Concept Lookup"],
        "parameters": [
          {
            "name": "rxcui",
            "in": "path",
