{
  "openapi": "3.0.3",
  "info": {
    "title": "Screenshot Machine API",
    "description": "Website screenshot capture API. Capture screenshots of any website as PNG, JPG, or GIF images.",
    "version": "v1",
    "x-jentic-source-url": "https://screenshotmachine.com/website-screenshot-api.php"
  },
  "servers": [
    {
      "url": "https://api.screenshotmachine.com"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {"name": "screenshots"}
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "captureScreenshot",
        "summary": "Capture a website screenshot",
        "description": "Captures a screenshot of the specified URL and returns it as a binary image.",
        "tags": ["screenshots"],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "required": true,
            "description": "Customer API key for authentication",
            "schema": {"type": "string"}
          },
          {
            "name": "url",
            "in": "query",
            "required": true,
            "description": "Web page URL to capture (percent-encoding recommended)",
            "schema": {"type": "string", "format": "uri"}
          },
          {
            "name": "dimension",
            "in": "query",
            "required": false,
            "description": "Screenshot size as [width]x[height] or [width]xfull. Defaults to 120x90.",
            "schema": {"type": "string", "default": "120x90"}
          },
          {
            "name": "device",
            "in": "query",
            "required": false,
            "description": "Device type for rendering",
            "schema": {
              "type": "string",
              "enum": ["desktop", "phone", "tablet"],
              "default": "desktop"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Output image format",
            "schema": {
              "type": "string",
              "enum": ["jpg", "png", "gif"],
              "default": "jpg"
            }
          },
          {
            "name": "hash",
            "in": "query",
            "required": false,
            "description": "MD5 hash for security (required if secret phrase is configured)",
            "schema": {"type": "string"}
          },
          {
            "name": "cacheLimit",
            "in": "query",
            "required": false,
            "description": "Cache age tolerance in days (0-14). Defaults to 14.",
            "schema": {
              "type": "integer",
              "minimum": 0,
              "maximum": 14,
              "default": 14
            }
          },
          {
            "name": "delay",
            "in": "query",
            "required": false,
            "description": "Wait time before capture in milliseconds (0, 200-10000). Defaults to 200.",
            "schema": {
              "type": "integer",
              "default": 200
            }
          },
          {
            "name": "zoom",
            "in": "query",
            "required": false,
            "description": "Zoom scale percentage (10-400). Defaults to 100.",
            "schema": {
              "type": "integer",
              "minimum": 10,
              "maximum": 400,
              "default": 100
            }
          },
          {
            "name": "click",
            "in": "query",
            "required": false,
            "description": "CSS selector for element to click before capture",
            "schema": {"type": "string"}
          },
          {
            "name": "hide",
            "in": "query",
            "required": false,
            "description": "CSS selectors (comma-separated) for elements to hide",
            "schema": {"type": "string"}
          },
          {
            "name": "cookies",
            "in": "query",
            "required": false,
            "description": "Semicolon-separated cookie name-value pairs",
            "schema": {"type": "string"}
          },
          {
            "name": "accept-language",
            "in": "query",
            "required": false,
            "description": "Language preference header value",
            "schema": {"type": "string"}
          },
          {
            "name": "user-agent",
            "in": "query",
            "required": false,
            "description": "Custom User-Agent header value",
            "schema": {"type": "string"}
          },
          {
            "name": "selector",
            "in": "query",
            "required": false,
            "description": "CSS selector for capturing a single DOM element",
            "schema": {"type": "string"}
          },
          {
            "name": "crop",
            "in": "query",
            "required": false,
            "description": "Crop region as x,y,width,height in pixels",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Screenshot image",
            "headers": {
              "X-Screenshotmachine-Response": {
                "description": "Response status code from Screenshot Machine",
                "schema": {"type": "string"}
              }
            },
            "content": {
              "image/png": {
                "schema": {"type": "string", "format": "binary"}
              },
              "image/jpeg": {
                "schema": {"type": "string", "format": "binary"}
              },
              "image/gif": {
                "schema": {"type": "string", "format": "binary"}
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters"
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "Customer API key"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {"type": "string"},
          "code": {
            "type": "string",
            "description": "Error code returned in X-Screenshotmachine-Response header",
            "enum": ["invalid_hash", "invalid_key", "invalid_url", "missing_key", "missing_url", "no_credits", "invalid_selector", "invalid_crop", "system_error"]
          }
        }
      }
    }
  }
}