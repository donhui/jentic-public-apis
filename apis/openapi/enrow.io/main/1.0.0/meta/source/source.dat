{
  "openapi": "3.0.3",
  "info": {
    "title": "Enrow API",
    "version": "1.0.0",
    "description": "Enrow enriches your contacts with a valid email. With Enrow, you get lightspeed verification without using external databases or sending emails.",
    "x-jentic-source-url": "https://enrow.readme.io/"
  },
  "servers": [
    {
      "url": "https://api.enrow.io"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Email Find",
      "description": "Find email addresses for contacts"
    },
    {
      "name": "Email Verify",
      "description": "Verify email addresses"
    },
    {
      "name": "Phone",
      "description": "Find phone numbers for contacts"
    },
    {
      "name": "Account",
      "description": "Account information"
    }
  ],
  "paths": {
    "/email/find/single": {
      "post": {
        "operationId": "createSingleEmailSearch",
        "summary": "Find a single email",
        "description": "This endpoint allows you to run a single email search by providing a person's name and company information.",
        "tags": ["Email Find"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SingleEmailSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email search initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SingleEmailSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "get": {
        "operationId": "getSingleEmailSearchResult",
        "summary": "Get single email search result",
        "description": "Retrieve the result of a single email search by its ID.",
        "tags": ["Email Find"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The search ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search result retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailSearchResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/email/find/bulk": {
      "post": {
        "operationId": "createBulkEmailSearch",
        "summary": "Find emails in bulk",
        "description": "This endpoint allows you to run a bulk email search for multiple contacts at once.",
        "tags": ["Email Find"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkEmailSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk email search initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "get": {
        "operationId": "getBulkEmailSearchResult",
        "summary": "Get bulk email search result",
        "description": "Retrieve the result of a bulk email search by its ID.",
        "tags": ["Email Find"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The bulk search ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bulk search result retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkEmailSearchResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/email/verify/single": {
      "post": {
        "operationId": "createSingleEmailVerification",
        "summary": "Verify a single email",
        "description": "This endpoint allows you to verify a single email address.",
        "tags": ["Email Verify"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SingleEmailVerifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email verification initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "get": {
        "operationId": "getSingleEmailVerificationResult",
        "summary": "Get single email verification result",
        "description": "Retrieve the result of a single email verification by its ID.",
        "tags": ["Email Verify"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The single verification ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Verification result retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerificationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/email/verify/bulk": {
      "post": {
        "operationId": "createBulkEmailVerification",
        "summary": "Verify emails in bulk",
        "description": "This endpoint allows you to verify multiple email addresses at once.",
        "tags": ["Email Verify"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkEmailVerifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk email verification initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkVerificationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "get": {
        "operationId": "getBulkEmailVerificationResult",
        "summary": "Get bulk email verification result",
        "description": "Retrieve the result of a bulk email verification by its ID.",
        "tags": ["Email Verify"],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "required": true,
            "description": "The bulk verification ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bulk verification result retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkVerificationResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/phone/single": {
      "post": {
        "operationId": "createSinglePhoneSearch",
        "summary": "Find a single phone number",
        "description": "This endpoint allows you to find a phone number for a single contact using their LinkedIn URL or name and company info.",
        "tags": ["Phone"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SinglePhoneSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Phone search initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhoneSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "get": {
        "operationId": "getSinglePhoneSearchResult",
        "summary": "Get single phone search result",
        "description": "Retrieve the result of a single phone search.",
        "tags": ["Phone"],
        "responses": {
          "200": {
            "description": "Phone search result retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhoneSearchResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/phone/bulk": {
      "post": {
        "operationId": "createBulkPhoneSearch",
        "summary": "Find phone numbers in bulk",
        "description": "This endpoint allows you to find phone numbers for multiple contacts at once.",
        "tags": ["Phone"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkPhoneSearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk phone search initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      },
      "get": {
        "operationId": "getBulkPhoneSearchResult",
        "summary": "Get bulk phone search result",
        "description": "Retrieve the result of a bulk phone search.",
        "tags": ["Phone"],
        "responses": {
          "200": {
            "description": "Bulk phone search result retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkPhoneSearchResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    },
    "/account/info": {
      "get": {
        "operationId": "getAccountInfo",
        "summary": "Get account information",
        "description": "Retrieve information about the current account including credits and webhooks.",
        "tags": ["Account"],
        "responses": {
          "200": {
            "description": "Account info retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountInfo"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "SingleEmailSearchRequest": {
        "type": "object",
        "required": ["fullname"],
        "properties": {
          "fullname": {
            "type": "string",
            "description": "The fullname of the person for which to find the email"
          },
          "company_domain": {
            "type": "string",
            "description": "The company's domain, multiple formats accepted (e.g. \"apple.com\", \"https://www.apple.com\")"
          },
          "company_name": {
            "type": "string",
            "description": "The company's name (e.g. \"Apple\", \"Air France\")"
          },
          "custom": {
            "type": "object",
            "description": "Custom params that will be returned in the GET response and in the webhook notification"
          },
          "settings": {
            "type": "object",
            "description": "A set of settings related to this search (webhook, country code...)"
          }
        }
      },
      "SingleEmailSearchResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The search ID to use for retrieving results"
          },
          "credits_used": {
            "type": "integer",
            "description": "Number of credits used for this search"
          }
        }
      },
      "EmailSearchResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "custom": {
            "type": "object"
          }
        }
      },
      "BulkEmailSearchRequest": {
        "type": "object",
        "required": ["searches"],
        "properties": {
          "searches": {
            "type": "array",
            "description": "Searches payloads for which to find corresponding emails",
            "items": {
              "$ref": "#/components/schemas/SingleEmailSearchRequest"
            }
          },
          "custom": {
            "type": "object",
            "description": "Custom params that will be returned in the GET response and in the webhook notification"
          },
          "settings": {
            "type": "object",
            "description": "Settings relative to the whole bulk search"
          }
        }
      },
      "BulkSearchResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The bulk search ID"
          },
          "credits_used": {
            "type": "integer",
            "description": "Number of credits used"
          },
          "estimated_duration": {
            "type": "integer",
            "description": "Estimated duration in minutes"
          }
        }
      },
      "BulkEmailSearchResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EmailSearchResult"
            }
          },
          "custom": {
            "type": "object"
          }
        }
      },
      "SingleEmailVerifyRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "The email to verify"
          },
          "custom": {
            "type": "object",
            "description": "Custom params that will be returned in the GET response and in the webhook notification"
          },
          "settings": {
            "type": "object",
            "description": "Settings related to this verification (webhook, country code...)"
          }
        }
      },
      "VerificationResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The verification ID"
          },
          "credits_used": {
            "type": "integer"
          }
        }
      },
      "VerificationResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "result": {
            "type": "string"
          },
          "custom": {
            "type": "object"
          }
        }
      },
      "BulkEmailVerifyRequest": {
        "type": "object",
        "required": ["verifications"],
        "properties": {
          "verifications": {
            "type": "array",
            "description": "An array containing all the emails you wish to verify",
            "items": {
              "type": "string"
            }
          },
          "custom": {
            "type": "object",
            "description": "Custom params that will be returned in the GET response and in the webhook notification"
          },
          "settings": {
            "type": "object",
            "description": "Settings relative to the whole bulk verification"
          }
        }
      },
      "BulkVerificationResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "credits_used": {
            "type": "integer"
          },
          "estimated_duration": {
            "type": "integer"
          }
        }
      },
      "BulkVerificationResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VerificationResult"
            }
          },
          "custom": {
            "type": "object"
          }
        }
      },
      "SinglePhoneSearchRequest": {
        "type": "object",
        "properties": {
          "linkedin_url": {
            "type": "string",
            "description": "Profile LinkedIn URL of the format \"https://linkedin.com/in/....\""
          },
          "firstname": {
            "type": "string",
            "description": "First name of the contact"
          },
          "lastname": {
            "type": "string",
            "description": "Last name of the contact"
          },
          "company_name": {
            "type": "string",
            "description": "Company name"
          },
          "company_domain": {
            "type": "string",
            "description": "Company domain"
          },
          "custom": {
            "type": "object",
            "description": "Custom properties that will be returned on result"
          }
        }
      },
      "PhoneSearchResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "credits_used": {
            "type": "integer"
          }
        }
      },
      "PhoneSearchResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "custom": {
            "type": "object"
          }
        }
      },
      "BulkPhoneSearchRequest": {
        "type": "object",
        "properties": {
          "searches": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SinglePhoneSearchRequest"
            }
          }
        }
      },
      "BulkPhoneSearchResult": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PhoneSearchResult"
            }
          }
        }
      },
      "AccountInfo": {
        "type": "object",
        "properties": {
          "credits": {
            "type": "integer",
            "description": "Available credits"
          },
          "webhooks": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Configured webhook URLs"
          }
        }
      }
    }
  }
}