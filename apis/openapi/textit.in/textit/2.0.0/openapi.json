{
  "openapi": "3.0.3",
  "info": {
    "title": "TextIt API",
    "version": "2.0.0",
    "description": "TextIt is a visual flow builder for SMS, voice, and messaging apps. The v2 API provides a RESTful JSON interface for managing contacts, broadcasts, campaigns, flows, messages, and more.",
    "x-jentic-source-url": "https://textit.in/api/v2"
  },
  "servers": [
    { "url": "https://textit.in/api/v2", "description": "Production" }
  ],
  "security": [{ "tokenAuth": [] }],
  "paths": {
    "/archives.json": {
      "get": {
        "operationId": "listArchives",
        "tags": ["Archives"],
        "summary": "List archives of messages and runs",
        "parameters": [
          { "name": "archive_type", "in": "query", "schema": { "type": "string", "enum": ["message", "run"] } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/broadcasts.json": {
      "get": {
        "operationId": "listBroadcasts",
        "tags": ["Broadcasts"],
        "summary": "List broadcasts",
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "integer" } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "sendBroadcast",
        "tags": ["Broadcasts"],
        "summary": "Send a broadcast message",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BroadcastRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Broadcast" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts.json": {
      "get": {
        "operationId": "listContacts",
        "tags": ["Contacts"],
        "summary": "List contacts",
        "parameters": [
          { "name": "uuid", "in": "query", "schema": { "type": "string" } },
          { "name": "urn", "in": "query", "schema": { "type": "string" } },
          { "name": "group", "in": "query", "schema": { "type": "string" } },
          { "name": "deleted", "in": "query", "schema": { "type": "boolean" } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createOrUpdateContact",
        "tags": ["Contacts"],
        "summary": "Create or update a contact",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } } },
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteContact",
        "tags": ["Contacts"],
        "summary": "Delete a contact",
        "parameters": [
          { "name": "uuid", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "No Content" },
          "404": { "description": "Not Found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contact_actions.json": {
      "post": {
        "operationId": "bulkContactActions",
        "tags": ["Contacts"],
        "summary": "Perform bulk contact actions (add/remove groups, etc.)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactActionRequest" }
            }
          }
        },
        "responses": {
          "204": { "description": "No Content" },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/flows.json": {
      "get": {
        "operationId": "listFlows",
        "tags": ["Flows"],
        "summary": "List flows",
        "parameters": [
          { "name": "uuid", "in": "query", "schema": { "type": "string" } },
          { "name": "type", "in": "query", "schema": { "type": "string" } },
          { "name": "archived", "in": "query", "schema": { "type": "boolean" } },
          { "name": "labels", "in": "query", "schema": { "type": "string" } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/flow_starts.json": {
      "get": {
        "operationId": "listFlowStarts",
        "tags": ["Flows"],
        "summary": "List flow starts",
        "parameters": [
          { "name": "uuid", "in": "query", "schema": { "type": "string" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "startFlow",
        "tags": ["Flows"],
        "summary": "Start contacts in a flow",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FlowStartRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FlowStart" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/messages.json": {
      "get": {
        "operationId": "listMessages",
        "tags": ["Messages"],
        "summary": "List messages",
        "parameters": [
          { "name": "id", "in": "query", "schema": { "type": "integer" } },
          { "name": "broadcast", "in": "query", "schema": { "type": "integer" } },
          { "name": "contact", "in": "query", "schema": { "type": "string" } },
          { "name": "folder", "in": "query", "schema": { "type": "string", "enum": ["inbox", "flows", "archived", "outbox", "sent", "failed"] } },
          { "name": "type", "in": "query", "schema": { "type": "string" } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/groups.json": {
      "get": {
        "operationId": "listGroups",
        "tags": ["Groups"],
        "summary": "List contact groups",
        "parameters": [
          { "name": "uuid", "in": "query", "schema": { "type": "string" } },
          { "name": "name", "in": "query", "schema": { "type": "string" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createGroup",
        "tags": ["Groups"],
        "summary": "Create a contact group",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GroupRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Group" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/runs.json": {
      "get": {
        "operationId": "listRuns",
        "tags": ["Flows"],
        "summary": "List flow runs",
        "parameters": [
          { "name": "uuid", "in": "query", "schema": { "type": "string" } },
          { "name": "flow", "in": "query", "schema": { "type": "string" } },
          { "name": "contact", "in": "query", "schema": { "type": "string" } },
          { "name": "responded", "in": "query", "schema": { "type": "boolean" } },
          { "name": "after", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "before", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/fields.json": {
      "get": {
        "operationId": "listFields",
        "tags": ["Fields"],
        "summary": "List contact fields",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PaginatedResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createOrUpdateField",
        "tags": ["Fields"],
        "summary": "Create or update a contact field",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FieldRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Field" } } } },
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Field" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/workspace.json": {
      "get": {
        "operationId": "getWorkspace",
        "tags": ["Workspace"],
        "summary": "View workspace information",
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Workspace" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token-based authentication. Include header: Authorization: Token YOUR_API_TOKEN"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": { "type": "string" }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "next": { "type": "string", "nullable": true },
          "previous": { "type": "string", "nullable": true },
          "results": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
        }
      },
      "BroadcastRequest": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "object", "additionalProperties": { "type": "string" }, "description": "Translatable text object with language codes as keys" },
          "urns": { "type": "array", "items": { "type": "string" } },
          "contacts": { "type": "array", "items": { "type": "string" } },
          "groups": { "type": "array", "items": { "type": "string" } },
          "channel": { "type": "string" }
        }
      },
      "Broadcast": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "text": { "type": "object", "additionalProperties": { "type": "string" } },
          "contacts": { "type": "array", "items": { "$ref": "#/components/schemas/Reference" } },
          "groups": { "type": "array", "items": { "$ref": "#/components/schemas/Reference" } },
          "created_on": { "type": "string", "format": "date-time" }
        }
      },
      "Reference": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "ContactRequest": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "language": { "type": "string" },
          "urns": { "type": "array", "items": { "type": "string" } },
          "groups": { "type": "array", "items": { "type": "string" } },
          "fields": { "type": "object", "additionalProperties": true }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "language": { "type": "string" },
          "urns": { "type": "array", "items": { "type": "string" } },
          "groups": { "type": "array", "items": { "$ref": "#/components/schemas/Reference" } },
          "fields": { "type": "object", "additionalProperties": true },
          "blocked": { "type": "boolean" },
          "stopped": { "type": "boolean" },
          "created_on": { "type": "string", "format": "date-time" },
          "modified_on": { "type": "string", "format": "date-time" }
        }
      },
      "ContactActionRequest": {
        "type": "object",
        "required": ["contacts", "action"],
        "properties": {
          "contacts": { "type": "array", "items": { "type": "string" } },
          "action": { "type": "string", "enum": ["add_group", "remove_group", "interrupt", "archive", "delete", "block", "unblock"] },
          "group": { "type": "string" }
        }
      },
      "FlowStartRequest": {
        "type": "object",
        "required": ["flow"],
        "properties": {
          "flow": { "type": "string", "description": "Flow UUID" },
          "contacts": { "type": "array", "items": { "type": "string" } },
          "groups": { "type": "array", "items": { "type": "string" } },
          "urns": { "type": "array", "items": { "type": "string" } },
          "restart_participants": { "type": "boolean" },
          "extra": { "type": "object", "additionalProperties": true }
        }
      },
      "FlowStart": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "flow": { "$ref": "#/components/schemas/Reference" },
          "contacts": { "type": "array", "items": { "$ref": "#/components/schemas/Reference" } },
          "groups": { "type": "array", "items": { "$ref": "#/components/schemas/Reference" } },
          "restart_participants": { "type": "boolean" },
          "status": { "type": "string" },
          "created_on": { "type": "string", "format": "date-time" }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "count": { "type": "integer" }
        }
      },
      "GroupRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" }
        }
      },
      "Field": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "value_type": { "type": "string" }
        }
      },
      "FieldRequest": {
        "type": "object",
        "required": ["label", "value_type"],
        "properties": {
          "label": { "type": "string" },
          "value_type": { "type": "string", "enum": ["text", "number", "datetime", "state", "district", "ward"] }
        }
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "uuid": { "type": "string" },
          "name": { "type": "string" },
          "country": { "type": "string" },
          "languages": { "type": "array", "items": { "type": "string" } },
          "primary_language": { "type": "string" },
          "timezone": { "type": "string" },
          "date_style": { "type": "string" },
          "anon": { "type": "boolean" }
        }
      }
    }
  }
}
