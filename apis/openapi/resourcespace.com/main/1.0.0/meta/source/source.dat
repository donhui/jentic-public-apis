{
  "openapi": "3.0.3",
  "info": {
    "title": "ResourceSpace API",
    "description": "ResourceSpace digital asset management API providing functions for managing resources, collections, metadata, users, and search.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.resourcespace.com/knowledge-base/api/"
  },
  "servers": [
    {
      "url": "https://{domain}/api/",
      "description": "ResourceSpace API server",
      "variables": {
        "domain": {
          "default": "my.resourcespace.system",
          "description": "Your ResourceSpace installation domain"
        }
      }
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "callFunction",
        "summary": "Call an API function",
        "description": "Generic API endpoint. All ResourceSpace API functions are called via query parameters specifying the function name and its parameters.",
        "tags": ["General"],
        "parameters": [
          { "name": "user", "in": "query", "required": true, "schema": { "type": "string" }, "description": "User identifier" },
          { "name": "function", "in": "query", "required": true, "schema": { "type": "string" }, "description": "API function name" },
          { "name": "param1", "in": "query", "schema": { "type": "string" }, "description": "First function parameter" },
          { "name": "param2", "in": "query", "schema": { "type": "string" }, "description": "Second function parameter" },
          { "name": "param3", "in": "query", "schema": { "type": "string" }, "description": "Third function parameter" },
          { "name": "param4", "in": "query", "schema": { "type": "string" }, "description": "Fourth function parameter" },
          { "name": "param5", "in": "query", "schema": { "type": "string" }, "description": "Fifth function parameter" },
          { "name": "param6", "in": "query", "schema": { "type": "string" }, "description": "Sixth function parameter" },
          { "name": "param7", "in": "query", "schema": { "type": "string" }, "description": "Seventh function parameter" },
          { "name": "param8", "in": "query", "schema": { "type": "string" }, "description": "Eighth function parameter" },
          { "name": "param9", "in": "query", "schema": { "type": "string" }, "description": "Ninth function parameter" },
          { "name": "sign", "in": "query", "required": true, "schema": { "type": "string" }, "description": "SHA256 signature hash" },
          { "name": "authmode", "in": "query", "schema": { "type": "string", "enum": ["userkey", "sessionkey", "native"] }, "description": "Authentication mode" }
        ],
        "responses": {
          "200": {
            "description": "Function result (JSON)",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      },
      "post": {
        "operationId": "callFunctionPost",
        "summary": "Call an API function via POST",
        "description": "Same as GET but preferred for sensitive data. All parameters sent in request body.",
        "tags": ["General"],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["user", "function", "sign"],
                "properties": {
                  "user": { "type": "string" },
                  "function": { "type": "string" },
                  "param1": { "type": "string" },
                  "param2": { "type": "string" },
                  "param3": { "type": "string" },
                  "param4": { "type": "string" },
                  "param5": { "type": "string" },
                  "param6": { "type": "string" },
                  "param7": { "type": "string" },
                  "param8": { "type": "string" },
                  "param9": { "type": "string" },
                  "sign": { "type": "string" },
                  "authmode": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Function result (JSON)",
            "content": {
              "application/json": { "schema": { "type": "object" } }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "signatureAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "sign",
        "description": "SHA256 hash of private API key concatenated with query string parameters"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "security": [
    {
      "signatureAuth": []
    }
  ]
}
