  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 Bearer Token"
      }
    },
    "parameters": {
      "PageParam": {
        "name": "page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 1
        },
        "description": "Page number"
      },
      "PerPageParam": {
        "name": "per_page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 25
        },
        "description": "Items per page"
      },
      "PropertyIdParam": {
        "name": "propertyId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Property ID"
      },
      "InspectionIdParam": {
        "name": "inspectionId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Inspection ID"
      },
      "RoomIdParam": {
        "name": "roomId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Room/Section ID"
      },
      "ItemIdParam": {
        "name": "itemId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Item ID"
      },
      "ActionIdParam": {
        "name": "actionId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Action ID"
      },
      "ContactIdParam": {
        "name": "contactId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Contact ID"
      },
      "MeterIdParam": {
        "name": "meterId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Meter ID"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
