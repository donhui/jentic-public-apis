            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v2/inspections/{inspectionId}/rooms/{roomId}/items/{itemId}/fields": {
      "put": {
        "operationId": "reorderItemFields",
        "summary": "Reorder item fields",
