          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/attachments/{attachmentId}/rotation": {
      "put": {
        "operationId": "rotateAttachment",
        "summary": "Rotate attachment",
        "description": "Rotate an attachment image.",
        "tags": [
          "Attachments"
        ],
        "parameters": [
          {
            "name": "attachmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "degrees": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Attachment rotated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/settings/account/self-service/templates": {
      "get": {
        "operationId": "listSelfServiceTemplates",
        "summary": "List self-service templates",
