    "/inspections/{inspectionId}/report/copy-from-property/{sourcePropertyId}": {
      "put": {
        "operationId": "copyReportFromProperty",
        "summary": "Copy report from another property",
        "description": "Copy an inspection report from another property into this inspection.",
        "tags": [
          "Inspections"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/InspectionIdParam"
          },
          {
            "name": "sourcePropertyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Source property ID to copy from"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string",
                    "enum": [
                      "append",
                      "reset"
                    ],
                    "description": "Whether to append to or reset the existing report"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Report copied successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/inspections/{inspectionId}/initialization": {
      "put": {
        "operationId": "initializeInspection",
        "summary": "Initialize an inspection",
        "description": "Initialize an inspection report, optionally copying from a previous inspection.",
        "tags": [
          "Inspections"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/InspectionIdParam"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "init_from": {
                    "type": "string",
                    "description": "Inspection ID to initialize from"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inspection initialized"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v2/inspections/{inspectionId}/rooms/{roomId}/fields": {
      "put": {
        "operationId": "reorderRoomFields",
        "summary": "Reorder room fields",
        "description": "Reorder the fields within a room by providing an ordered array of field IDs.",
        "tags": [
