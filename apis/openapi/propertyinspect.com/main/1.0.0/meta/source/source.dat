    "/inspections": {
      "get": {
        "operationId": "listInspections",
        "summary": "List inspections",
        "description": "Retrieve a paginated list of all the user's inspections.",
        "tags": [
          "Inspections"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/PerPageParam"
          },
          {
            "name": "client_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by client ID"
          },
          {
            "name": "clerk_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by clerk ID"
          },
          {
            "name": "property_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by property ID"
          },
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by address"
          },
          {
            "name": "state_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by state"
          },
          {
            "name": "conduct_date",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by conduct date"
          }
        ],
        "responses": {
          "200": {
            "description": "Inspections retrieved",
            "content": {
