                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Ordered array of field IDs"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fields reordered"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
