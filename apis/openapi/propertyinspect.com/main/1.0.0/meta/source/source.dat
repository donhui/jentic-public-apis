            "type": "string"
          },
          "token_type": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer"
          },
          "refresh_token": {
            "type": "string"
          }
        }
      },
      "PaginatedPropertyResponse": {
        "type": "object",
        "properties": {
