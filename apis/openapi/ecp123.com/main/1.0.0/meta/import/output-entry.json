{
  "openapi": "3.0.3",
  "info": {
    "title": "ECP Clinical API",
    "description": "REST API for ECP Assisted Living Software providing access to locations, buildings, rooms, residents, contacts, and status logs for senior living communities. Supports webhook notifications for resident, contact, and user lifecycle events.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.ecp123.com/api-docs"
  },
  "servers": [
    {
      "url": "https://api.ecp123.com/clinical/v1",
      "description": "Production API server"
    }
  ],
  "paths": {
    "/oauth/token": {
      "post": {
        "operationId": "getOAuthToken",
        "summary": "Retrieve OAuth bearer token",
        "description": "Retrieves a temporary bearer token (60-minute expiration) required for all REST API calls.",
        "tags": [
          "Authentication"
        ],
        "security": [],
        "servers": [
          {
            "url": "https://oauth2.ecp123.com",
            "description": "OAuth server"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/OAuthTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully retrieved bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthTokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/locations": {
