          "Residents"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/LocationIdParam"
          },
          {
            "name": "discharged",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Filter by discharged status"
          },
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/ResultsPerPageParam"
          }
        ],
        "responses": {
          "200": {
