  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 bearer token obtained from the token endpoint"
      },
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication"
      }
    },
    "parameters": {
      "PageParam": {
        "name": "page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 1
        },
        "description": "Page number for pagination"
      },
      "ResultsPerPageParam": {
        "name": "resultsPerPage",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 100,
          "maximum": 100
        },
        "description": "Number of results per page (max 100)"
      },
      "LocationIdParam": {
        "name": "locationId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "The location ID"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing authentication",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string"
          }
        }
      },
      "OAuthTokenRequest": {
        "type": "object",
        "required": [
          "grant_type",
          "client_id",
          "client_secret",
          "scope"
        ],
        "properties": {
          "grant_type": {
            "type": "string",
            "example": "client_credentials"
          },
          "client_id": {
            "type": "string"
          },
          "client_secret": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          }
        }
      },
      "OAuthTokenResponse": {
        "type": "object",
        "properties": {
          "token_type": {
            "type": "string",
            "example": "Bearer"
          },
          "expires_in": {
            "type": "integer",
            "example": 3600
          },
          "access_token": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          }
        }
      },
      "LocationListResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "boolean"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Location"
            }
          },
          "numberOfResults": {
            "type": "integer"
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Location": {
        "type": "object",
        "properties": {
          "locationId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "zip": {
            "type": "string"
          }
        }
      },
      "BuildingListResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "boolean"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Building"
            }
          },
          "numberOfResults": {
            "type": "integer"
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Building": {
        "type": "object",
        "properties": {
          "buildingId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "RoomListResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "boolean"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Room"
            }
          },
          "numberOfResults": {
            "type": "integer"
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Room": {
        "type": "object",
        "properties": {
          "roomId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "StageListResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "boolean"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Stage"
            }
          },
          "numberOfResults": {
            "type": "integer"
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Stage": {
        "type": "object",
        "properties": {
          "stageId": {
            "type": "string"
          },
          "displayValue": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "order": {
            "type": "integer"
          },
          "restricted": {
            "type": "boolean"
          }
        }
      },
      "CreateResidentRequest": {
        "type": "object",
        "required": [
          "dateOfBirth",
          "firstName",
          "lastName",
          "locationId"
        ],
        "properties": {
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "locationId": {
            "type": "string"
          },
          "middleName": {
            "type": "string"
          },
          "nickname": {
            "type": "string"
          },
          "suffix": {
            "type": "string"
          },
          "gender": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "codeStatus": {
            "type": "string"
          },
          "livingWill": {
            "type": "boolean"
          },
          "otherAdvancedDirectives": {
            "type": "string"
          },
          "financialMoveInDate": {
            "type": "string",
            "format": "date"
          },
          "physicalMoveInDate": {
            "type": "string",
            "format": "date"
          },
          "readyForDeposit": {
            "type": "boolean"
          },
          "readyForPreAssessment": {
            "type": "boolean"
          },
          "room": {
            "type": "string"
          },
          "stageId": {
            "type": "string"
          },
          "externalIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "coResident": {
            "type": "string"
          }
        }
      },
      "CreateResidentResponse": {
        "type": "object",
        "properties": {
          "result": {
            "type": "boolean"
          },
          "error": {
            "type": "string",
            "nullable": true
          },
          "residentId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
