        "operationId": "listLocations",
        "summary": "Retrieve all locations",
        "description": "Retrieves a paginated list of all locations.",
        "tags": [
          "Locations"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/PageParam"
          },
          {
            "$ref": "#/components/parameters/ResultsPerPageParam"
          }
