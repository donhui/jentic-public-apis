{
  "openapi": "3.1.0",
  "info": {
    "title": "IEX Cloud API",
    "description": "IEX Cloud financial data API providing stock quotes, market data, financials, news, and reference data.",
    "version": "1.0.0",
    "contact": {
      "name": "IEX Cloud Support",
      "url": "https://iexcloud.io/docs"
    },
    "termsOfService": "https://iexcloud.io/terms/"
  },
  "servers": [
    {
      "url": "https://cloud.iexapis.com/stable",
      "description": "IEX Cloud Stable API"
    },
    {
      "url": "https://sandbox.iexapis.com/stable",
      "description": "IEX Cloud Sandbox (testing)"
    }
  ],
  "security": [
    { "tokenAuth": [] }
  ],
  "paths": {
    "/stock/{symbol}/quote": {
      "get": {
        "operationId": "getQuote",
        "summary": "Quote",
        "description": "Get a real-time or delayed stock quote for a given symbol.",
        "tags": ["Stock Prices"],
        "parameters": [
          { "name": "symbol", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Stock ticker symbol." },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" }, "description": "API token." }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "symbol": { "type": "string" },
                    "companyName": { "type": "string" },
                    "primaryExchange": { "type": "string" },
                    "calculationPrice": { "type": "string" },
                    "open": { "type": "number" },
                    "openTime": { "type": "integer" },
                    "close": { "type": "number" },
                    "closeTime": { "type": "integer" },
                    "high": { "type": "number" },
                    "low": { "type": "number" },
                    "latestPrice": { "type": "number" },
                    "latestSource": { "type": "string" },
                    "latestTime": { "type": "string" },
                    "latestUpdate": { "type": "integer" },
                    "latestVolume": { "type": "integer" },
                    "iexRealtimePrice": { "type": "number" },
                    "iexRealtimeSize": { "type": "integer" },
                    "iexLastUpdated": { "type": "integer" },
                    "delayedPrice": { "type": "number" },
                    "delayedPriceTime": { "type": "integer" },
                    "extendedPrice": { "type": "number" },
                    "extendedChange": { "type": "number" },
                    "extendedChangePercent": { "type": "number" },
                    "extendedPriceTime": { "type": "integer" },
                    "previousClose": { "type": "number" },
                    "previousVolume": { "type": "integer" },
                    "change": { "type": "number" },
                    "changePercent": { "type": "number" },
                    "volume": { "type": "integer" },
                    "avgTotalVolume": { "type": "integer" },
                    "iexBidPrice": { "type": "number" },
                    "iexBidSize": { "type": "integer" },
                    "iexAskPrice": { "type": "number" },
                    "iexAskSize": { "type": "integer" },
                    "marketCap": { "type": "integer" },
                    "peRatio": { "type": "number" },
                    "week52High": { "type": "number" },
                    "week52Low": { "type": "number" },
                    "ytdChange": { "type": "number" },
                    "isUSMarketOpen": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stock/{symbol}/quote/{field}": {
      "get": {
        "operationId": "getQuoteField",
        "summary": "Quote Field",
        "description": "Get a single field from the quote data.",
        "tags": ["Stock Prices"],
        "parameters": [
          { "name": "symbol", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "field", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Specific field from the quote object." },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/stock/{symbol}/batch": {
      "get": {
        "operationId": "getBatch",
        "summary": "Batch Requests",
        "description": "Fetch multiple data types for a single stock in one request.",
        "tags": ["Stock Prices"],
        "parameters": [
          { "name": "symbol", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "types", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Comma-delimited list of endpoint types (quote, chart, news, etc.)." },
          { "name": "range", "in": "query", "schema": { "type": "string" } },
          { "name": "last", "in": "query", "schema": { "type": "integer" } },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/stock/{symbol}/chart/{range}": {
      "get": {
        "operationId": "getHistoricalPrices",
        "summary": "Historical Prices",
        "description": "Get historical stock price data for a given time range.",
        "tags": ["Stock Prices"],
        "parameters": [
          { "name": "symbol", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "range", "in": "path", "required": true, "schema": { "type": "string", "enum": ["max", "5y", "2y", "1y", "ytd", "6m", "3m", "1m", "1mm", "5d", "5dm", "date", "dynamic"] }, "description": "Time range." },
          { "name": "chartCloseOnly", "in": "query", "schema": { "type": "boolean" }, "description": "Return only close prices." },
          { "name": "chartSimplify", "in": "query", "schema": { "type": "boolean" }, "description": "Simplify chart data." },
          { "name": "chartInterval", "in": "query", "schema": { "type": "integer" }, "description": "Return every nth element." },
          { "name": "changeFromClose", "in": "query", "schema": { "type": "boolean" } },
          { "name": "chartLast", "in": "query", "schema": { "type": "integer" } },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "date": { "type": "string" },
                      "open": { "type": "number" },
                      "high": { "type": "number" },
                      "low": { "type": "number" },
                      "close": { "type": "number" },
                      "volume": { "type": "integer" },
                      "uOpen": { "type": "number" },
                      "uHigh": { "type": "number" },
                      "uLow": { "type": "number" },
                      "uClose": { "type": "number" },
                      "uVolume": { "type": "integer" },
                      "change": { "type": "number" },
                      "changePercent": { "type": "number" },
                      "label": { "type": "string" },
                      "changeOverTime": { "type": "number" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stock/{symbol}/intraday-prices": {
      "get": {
        "operationId": "getIntradayPrices",
        "summary": "Intraday Prices",
        "description": "Get intraday prices for a stock.",
        "tags": ["Stock Prices"],
        "parameters": [
          { "name": "symbol", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "chartIEXOnly", "in": "query", "schema": { "type": "boolean" } },
          { "name": "chartReset", "in": "query", "schema": { "type": "boolean" } },
          { "name": "chartSimplify", "in": "query", "schema": { "type": "boolean" } },
          { "name": "chartInterval", "in": "query", "schema": { "type": "integer" } },
          { "name": "chartLast", "in": "query", "schema": { "type": "integer" } },
          { "name": "exactDate", "in": "query", "schema": { "type": "string" } },
          { "name": "chartIEXWhenNull", "in": "query", "schema": { "type": "boolean" } },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/stock/{symbol}/previous": {
      "get": {
        "operationId": "getPreviousDayPrice",
        "summary": "Previous Day Price",
        "description": "Get previous day adjusted price data.",
        "tags": ["Stock Prices"],
        "parameters": [
          { "name": "symbol", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/stock/{symbol}/company": {
      "get": {
        "operationId": "getCompany",
        "summary": "Company",
        "description": "Get company information for a stock symbol.",
        "tags": ["Stock Fundamentals"],
        "parameters": [
          { "name": "symbol", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "symbol": { "type": "string" },
                    "companyName": { "type": "string" },
                    "exchange": { "type": "string" },
                    "industry": { "type": "string" },
                    "website": { "type": "string" },
                    "description": { "type": "string" },
                    "CEO": { "type": "string" },
                    "securityName": { "type": "string" },
                    "issueType": { "type": "string" },
                    "sector": { "type": "string" },
                    "primarySicCode": { "type": "integer" },
                    "employees": { "type": "integer" },
                    "tags": { "type": "array", "items": { "type": "string" } },
                    "address": { "type": "string" },
                    "address2": { "type": "string" },
                    "state": { "type": "string" },
                    "city": { "type": "string" },
                    "zip": { "type": "string" },
                    "country": { "type": "string" },
                    "phone": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stock/{symbol}/stats": {
      "get": {
        "operationId": "getKeyStats",
        "summary": "Key Stats",
        "description": "Get key statistics for a stock symbol including PE ratio, market cap, etc.",
        "tags": ["Stock Fundamentals"],
        "parameters": [
          { "name": "symbol", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
