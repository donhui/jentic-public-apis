      "get": {
        "operationId": "getNews",
        "summary": "News",
        "description": "Get news articles related to a stock.",
        "tags": ["News"],
        "parameters": [
          { "name": "symbol", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "last", "in": "query", "schema": { "type": "integer" }, "description": "Number of news items (1-50)." },
          { "name": "token", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Successful response" }
        }
      }
    },
    "/stock/{symbol}/peers": {
      "get": {
        "operationId": "getPeers",
