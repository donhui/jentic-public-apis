{
    "openapi": "3.0.0",
    "info": {
        "version": "v2",
        "title": "Animal Identity Service Boundary",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/LIC/animal-identity_service_boundary/v2/swagger.json"
    },
    "paths": {
        "/v2/animals/{startDate}/{endDate}": {
            "post": {
                "tags": [
                    "LIC.Services.AnimalIdentity.WebApi.Areas.v2.Controllers.AnimalsController"
                ],
                "summary": "Gets animals details using their animal keys. If a date range is supplied, the\r\n             latest management number and eid within the given date range is returned.\r\n             Current ahb-id and birth-id is always returned.\r\n            \r\n             NOTE: while this is sematically a POST it performs the function of a GET\r\n             There may be many animal keys passed to this method so the querystring\r\n             could get larger than is sensible. One day when browsers and proxies support\r\n             unlimited query string lengths this should get turned into a GET",
                "operationId": "LIC.Services.AnimalIdentity.WebApi.Areas.v2.Controllers.AnimalsController_Post",
                "parameters": [
                    {
                        "name": "startDate",
                        "in": "path",
                        "description": "The start date range to look at",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date-time"
                        }
                    },
                    {
                        "name": "endDate",
                        "in": "path",
                        "description": "The end date range to look at",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date-time"
                        }
                    },
                    {
                        "name": "animalGroupBpNumber",
                        "in": "query",
                        "description": "The bp number for the herd",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "format": "int32",
                                    "type": "integer"
                                }
                            }
                        },
                        "text/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "format": "int32",
                                    "type": "integer"
                                }
                            }
                        },
                        "text/javascript": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "format": "int32",
                                    "type": "integer"
                                }
                            }
                        },
                        "application/xml": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "format": "int32",
                                    "type": "integer"
                                }
                            }
                        },
                        "text/xml": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "format": "int32",
                                    "type": "integer"
                                }
                            }
                        },
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "format": "int32",
                                    "type": "integer"
                                }
                            }
                        }
                    },
                    "description": "The set of animal keys to lookup",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.Contract.AnimalIdentities"
                                }
                            },
                            "text/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.Contract.AnimalIdentities"
                                }
                            },
                            "text/javascript": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.Contract.AnimalIdentities"
                                }
                            }
                        }
                    }
                },
                "deprecated": false
            }
        },
        "/v2/animals/{animalKey}/notes/latest": {
            "get": {
                "summary": "Gets the latest note lodged against an animal, that the caller has permission to see.",
                "tags": [
                    "Notes and Comments"
                ],
                "description": "This operation should only return the most recent note that was lodged. Most recent at an animal level, rather than at a MINDA Live User level. If Fred and Sally have access to the same animal and Sally lodges a note straight after Fred, when either of them make this request, they should see Sally's note. First in, First Out.\n\nIf a user does not have permissions to see the latest note, we could either return an error, or return the most recent note that the user DOES have permission to see. We need Farm Information to choose one of these.",
                "operationId": "LIC.Services.AnimalIdentity.WebApi.Areas.v2.Controllers.AnimalsController_GetMostRecentNote",
                "parameters": [
                    {
                        "name": "animalKey",
                        "in": "path",
                        "description": "The animalKey of the animal in question.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "animalGroupBpNumber",
                        "in": "query",
                        "description": "This query parameter limits the notes returned to the specified herd. If this value is not populated, the API should return the notes for the animal's current herd.",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.Contract.Animal.Note"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Given when an animal with the specified identifier can not be found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.ApiResponseMessage"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v2/animals/{animalKey}/notes": {
            "get": {
                "summary": "Gets all notes lodged against an animal",
                "tags": [
                    "Notes and Comments"
                ],
                "description": "Returns all available notes for the animal that the user has permission to see. If the animal has comments lodged against it that the user does not have permission to see, they should be stripped from the response on the server side, rather than using javascript to filter out those items on the client side.\n\nThe reason we soft delete and not hard, is because of this function. It should only ever return a list of notes, or a 404 error. There should be no case where a user lacks permissions to call this - because instead, we strip the data they aren't allowed to see. This also facilitates notes following an animal from herd to herd and back.",
                "operationId": "LIC.Services.AnimalIdentity.WebApi.Areas.v2.Controllers.AnimalsController_GetAllNotes",
                "parameters": [
                    {
                        "name": "animalKey",
                        "in": "path",
                        "description": "The animalKey of the animal in question.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "animalGroupBpNumber",
                        "in": "query",
                        "description": "This query parameter limits the notes returned to the specified herd. If this value is not populated, the API should return the notes for the animal's current herd.",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "notes": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.Contract.Animal.Note"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Given when an animal with the specified identifier can not be found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.ApiResponseMessage"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "summary": "Creates a new note against the subject animal where the user has permission to do so.",
                "tags": [
                    "Notes and Comments"
                ],
                "description": "Creates a new note for the subject animal. We should return an error for requests to create a note against an animal that the user does not have access to.",
                "operationId": "LIC.Services.AnimalIdentity.WebApi.Areas.v2.Controllers.AnimalsController_CreateNote",
                "parameters": [
                    {
                        "name": "animalKey",
                        "in": "path",
                        "description": "The animalKey of the animal in question.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "note"
                                ],
                                "properties": {
                                    "note": {
                                        "type": "string"
                                    },
                                    "categoryId": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "description": "The note to be created. All other fields in the notes object should be inferred by the server"
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.Contract.Animal.Note"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Given when the user attempts to interact with an animal they do not have permissions for.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.ApiResponseMessage"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Given when an animal with the specified identifier can not be found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.ApiResponseMessage"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v2/animals/{animalKey}/notes/{noteIdentifier}": {
            "put": {
                "summary": "Idempotently updates an existing note for a subject animal",
                "tags": [
                    "Notes and Comments"
                ],
                "description": "This operation should be idempotent and non-destructive. If the client only submits partial data, we should first take the new data submitted and save that, and then bring across old data that would otherwise be null, and save that. This is in effect, a merge, rather than a 1:1 replacement.",
                "operationId": "LIC.Services.AnimalIdentity.WebApi.Areas.v2.Controllers.AnimalsController_UpdateNote",
                "parameters": [
                    {
                        "name": "animalKey",
                        "in": "path",
                        "description": "The animalKey of the animal in question.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "noteIdentifier",
                        "in": "path",
                        "description": "The identifier of the note",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "noteContent": {
                                        "type": "string"
                                    },
                                    "categories": {
                                        "type": "array",
                                        "items": {
                                            "properties": {
                                                "categoryIdentifier": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "description": "The new note to be created. Audit related fields should always be inferred from the server. We want to fail safe here. This is a merge, not a replace. If you don't submit note content for example, and only submit category data, we should take the old note content and add it to the new representation, rather than dropping the old data and having the new representation return null for that content.",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.Contract.Animal.Note"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Given when an animal or note with the specified identifier can not be found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.ApiResponseMessage"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "summary": "Deletes a note on an existing animal",
                "tags": [
                    "Notes and Comments"
                ],
                "description": "It's important to note that this is a SOFT delete. Not a hard delete. If a user does not have permission to create a note against an animal, they should not have permission to delete a note either. Further, users should only be allowed to delete notes created while the animal was in that herd. Attempts to delete a comment created while the animal was in a different herd should throw an error.",
                "operationId": "LIC.Services.AnimalIdentity.WebApi.Areas.v2.Controllers.AnimalsController_SoftDeleteNote",
                "parameters": [
                    {
                        "name": "animalKey",
                        "in": "path",
                        "description": "The animalKey of the animal in question.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "noteIdentifier",
                        "in": "path",
                        "description": "The identifier of the note.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "No Content"
                    },
                    "401": {
                        "description": "Given when the user attempts to interact with an animal they do not have permissions for, or they attempt to interact with an animal in a way they do not have permission for.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.ApiResponseMessage"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Given when an animal or note with the specified identifier can not be found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.ApiResponseMessage"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v2/herds/{animalGroupBpNumber}/notes": {
            "get": {
                "summary": "Gets all notes for each animal in a herd",
                "tags": [
                    "Notes and Comments"
                ],
                "description": "Returns all available notes for all animals in the specified herd. This is endpoint is for use primarily by the mobile team as a way of avoiding the overhead of 500+ HTTP calls in poor network conditions. MINDA Live suffers from this problem less, and has different use cases so pick and choose endpoints as you need.\n\nThis function should return notes only for the specified herd, rather than all notes against an animal that the client has permission for. This is both to reduce processing time on the server, and also because the mobile use case sees users needing current and contextual data, rather than historic. This use case can differ slightly from the Live use case, where users perhaps want a bit more \"sit down and think\" time.",
                "operationId": "LIC.Services.AnimalIdentity.WebApi.Areas.v2.Controllers.AnimalsController_GetAllNotesForHerd",
                "parameters": [
                    {
                        "name": "animalGroupBpNumber",
                        "in": "path",
                        "description": "The animalGroupBpNumber for the herd in question.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "notes": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.Contract.Animal.Note"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Given when an animal with the specified identifier can not be found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.ApiResponseMessage"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v2/notes/categories": {
            "get": {
                "summary": "Gets all note categories",
                "tags": [
                    "Note Categories - Cut 1"
                ],
                "description": "Returns all category types currently loaded in the database. Note that for cut 1, adding new categories is a manual process, not available via API.\n\nIt is also important to note that there are big chunks of work we could do to improve this, once we see some data about how categories are used. For example, we could return all notes in a herd with a set of categories against them. This would be handy for groups and reports. We could return statistics on what the most popular category types are so that a farmer can track how many health category notes they have made. All of this is speculation until we do more research and observe how categories are used in the wild. For this reason I omit them deliberately.\n\nThis endpoint does not follow the rest pattern for naming. Following the pattern in this case leads to a name that is less clear then the current endpoint, that is why I have decided to break the spec for this endpoint.",
                "operationId": "LIC.Services.AnimalIdentity.WebApi.Areas.v2.Controllers.AnimalsController_GetAllNoteCategories",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "categories": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/LIC.Services.AnimalIdentity.WebApi.Areas.v2.Contract.Animal.Note.Category"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
