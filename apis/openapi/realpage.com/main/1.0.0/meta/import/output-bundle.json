  "components": {
    "schemas": {
      "Resident": {
        "type": "object",
        "properties": {
          "residentId": {
            "type": "string",
            "description": "Unique resident identifier"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "current",
              "past",
              "future",
              "applicant"
            ]
          },
          "siteId": {
            "type": "string"
          },
          "pmcId": {
            "type": "string"
          },
          "unitId": {
            "type": "string"
          },
          "moveInDate": {
            "type": "string",
            "format": "date"
          },
          "moveOutDate": {
            "type": "string",
            "format": "date"
          },
          "leases": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Lease"
            }
          }
        }
      },
      "ResidentListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Resident"
            }
          },
          "total": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          }
        }
      },
      "ResidentEvent": {
        "type": "object",
        "properties": {
