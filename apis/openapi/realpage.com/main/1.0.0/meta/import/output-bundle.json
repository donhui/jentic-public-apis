{
  "openapi": "3.0.3",
  "info": {
    "title": "RealPage Exchange API",
    "version": "1.0.0",
    "description": "The RealPage Exchange (RPX) API enables integration with RealPage's property management platform. The API provides access to resident management, lease tracking, property operations, and financial data. Access requires an active RealPage partner agreement through the RPX AppPartner Program. The API supports both REST and SOAP interfaces; this specification covers the REST API endpoints.",
    "contact": {
      "name": "RealPage Developer Support",
      "url": "https://www.realpage.com"
    },
    "x-jentic-source-url": "https://www.realpage.com/"
  },
  "servers": [
    {
      "url": "https://api.realpage.com/v1",
      "description": "RealPage API production endpoint"
    }
  ],
  "paths": {
    "/residents": {
      "get": {
        "tags": [
          "Residents"
        ],
        "summary": "List residents",
        "description": "Retrieve a list of residents filtered by site, property management company, status, or event date range.",
        "operationId": "listResidents",
        "parameters": [
          {
            "name": "siteId",
            "in": "query",
            "description": "Site identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pmcId",
            "in": "query",
            "description": "Property Management Company identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by resident status",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "current",
                "past",
                "future",
                "applicant",
                "all"
              ]
            }
          },
          {
            "name": "fromDate",
            "in": "query",
            "description": "Filter by event start date",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "toDate",
            "in": "query",
            "description": "Filter by event end date",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "events",
            "in": "query",
            "description": "Filter by event types (comma-separated)",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "movein,moveout,renewal"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResidentListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
