            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "eventType": {
            "type": "string",
            "enum": [
              "movein",
              "moveout",
              "renewal",
              "transfer",
              "eviction",
              "skip",
              "notice"
            ]
          },
          "eventDate": {
            "type": "string",
            "format": "date"
          },
          "siteId": {
            "type": "string"
          },
          "unitId": {
            "type": "string"
          }
        }
      },
      "ResidentEventListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ResidentEvent"
            }
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "Lease": {
        "type": "object",
        "properties": {
          "leaseId": {
            "type": "string"
          },
          "siteId": {
