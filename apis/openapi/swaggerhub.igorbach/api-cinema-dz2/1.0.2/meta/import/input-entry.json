    "/booking_database": {
      "post": {
        "tags": [
          "Booking database"
        ],
        "summary": "Забронировать место",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "IdCustomer": {
                    "type": "integer",
                    "example": 12345,
                    "description": "ID покупателя"
                  },
                  "IdFilm": {
                    "type": "integer",
                    "example": 678,
                    "description": "ID фильма"
                  },
                  "DateSession": {
                    "type": "string",
                    "format": "date-time",
                    "example": "14.02.2024",
                    "description": "Дата и время сеанса"
                  },
                  "CinemaSeats": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      21,
                      4
                    ],
                    "description": "Выбранные места в формате (№места, №ряда)"
                  },
                  "NumberOfTickets": {
                    "type": "number",
                    "example": 2,
                    "description": "Количество купленных билетов в бронировании"
                  },
                  "BonusCard": {
                    "type": "integer",
                    "example": 454767678061,
                    "description": "Номер бонусной карты"
                  },
                  "NumberOfPointsDebitedFromBalance": {
                    "type": "number",
                    "example": 300,
                    "description": "Количество бонусных баллов, списанных со счета при текущем бронировании (до 50%)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "OrderNumber": {
                      "type": "number",
                      "example": 124695,
                      "description": "Номер заказа (для покупателя)"
                    },
                    "StatusBooking": {
                      "type": "string",
                      "example": "Активно",
                      "description": "Статус бронирования"
                    },
                    "NumberOfTickets": {
                      "type": "number",
                      "example": 2,
                      "description": "Количество купленных билетов в бронировании"
                    },
                    "BookingCost": {
                      "type": "number",
                      "example": 850,
                      "description": "Итоговая стоимость бронирования"
                    },
                    "CinemaSeats": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "example": [
                        21,
                        4
                      ],
                      "description": "Выбранные места в формате (№места, №ряда)"
                    },
                    "PercentageOfPaymentWithPoints": {
                      "type": "number",
                      "example": 40,
                      "description": "процент оплаты стоимости билетов бонусными баллами"
                    }
                  },
                  "xml": {
                    "name": "user"
                  }
                }
