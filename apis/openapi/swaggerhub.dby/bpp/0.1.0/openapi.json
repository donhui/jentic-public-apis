{
  "openapi": "3.0.0",
  "info": {
    "title": "BerryPKIProxy",
    "description": "BerryPKIProxy distributed by Digitalberry provides an openssl soft PKI and an REST API interface to communicate with PKIs",
    "contact": {
      "name": "Alexis",
      "email": "alexis.janin@digitalberry.fr"
    },
    "license": {
      "name": "Proprietaire"
    },
    "version": "0.1.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/DBY/BPP/0.1.0/swagger.json"
  },
  "paths": {
    "/api/v1/cert/{requestId}": {
      "get": {
        "summary": "Get Certificate by requestId,",
        "parameters": [
          {
            "description": "The csr request 'id' (should exist)",
            "in": "path",
            "name": "requestId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Certificate Available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCertResponseSchema"
                }
              }
            }
          },
          "202": {
            "description": "Certificate Not Available",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseSchema"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseSchema"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Ressource Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseSchema"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/csr": {
      "post": {
        "summary": "Certificate sign request",
        "requestBody": {
          "description": "",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostCsrBodySchema"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created CSR",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PostCsrResponseSchema"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponseSchema"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    }
  },
