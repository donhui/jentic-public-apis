                                    },
                                    "role": {
                                        "type": "string",
                                        "example": "examiner",
                                        "description": "User's role, which determines the functionalities accessible on sign-in<br>examiner - can conduct tests, view and shortlit data<br>consultant - can conduct tests, view data, add comments and upload reports"
