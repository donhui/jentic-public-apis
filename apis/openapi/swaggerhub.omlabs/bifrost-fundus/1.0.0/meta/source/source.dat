                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "Unique reference number to the patients record"
                                    },
                                    "id": {
                                        "type": "integer",
                                        "format": "int64",
                                        "description": "Reference number to the session<br>Useful for record retrieval when both eyes are tested in the same session"
                                    },
                                    "eye": {
                                        "type": "string",
                                        "description": "The eye tested to retrieve this data<br>OS - left eye<br>OD - right eye"
                                    },
                                    "source": {
                                        "type": "string",
                                        "description": "Name of the fundus camera type used for data capture"
                                    },
                                    "img_ext": {
                                        "type": "string",
                                        "description": "The file extension representing image format<br>jpg<br>jpeg"
                                    },
                                    "img": {
                                        "type": "string",
                                        "format": "byte",
                                        "description": "Base64-encoded string of the raw image data"
                                    },
                                    "user": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "user@domain.com",
                                        "description": "The email ID of the authenticated Bifrost user uploading the image"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Fundus image details to upload to Bifrost",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Fundus image uploaded successfully"
                    },
                    "400": {
                        "description": "Failed to upload fundus image data"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/fundus/results/list": {
            "post": {
                "tags": [
                    "results"
                ],
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "eye",
                                    "start_date",
                                    "end_date"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "Unique reference number to the patients record"
                                    },
                                    "eye": {
                                        "type": "string",
                                        "description": "Eye(s) tested<br>OS - left eye<br>OD - right eye<br>OU - both eyes"
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2019-10-17",
                                        "description": "Start UTC date of search"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2019-10-23",
                                        "description": "End UTC date of search"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Search parameters to retrieve list of available data",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "List of available records retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "id": {
                                                "type": "integer",
                                                "format": "int64",
                                                "description": "Unique reference to all data uploaded in a session"
                                            },
                                            "eye": {
                                                "type": "string",
                                                "description": "Eye imaged<br>OS - left eye<br>OD - right eye"
                                            },
                                            "test_date": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/23/2019 11:59:59 PM",
                                                "description": "UTC date and time at which the image was uploaded"
                                            },
                                            "shortlisted": {
                                                "type": "boolean",
                                                "description": "Indicator of whether this data was shortlisted for review in Bifrost"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to retrieve available records"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/fundus/results/get": {
            "post": {
                "tags": [
                    "results"
                ],
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "id"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "Unique reference number to the patients record"
                                    },
                                    "id": {
                                        "type": "integer",
                                        "format": "int64",
                                        "description": "Reference number to the session<br>Useful for record retrieval when both eyes are tested in the same session"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Session details to retrieve fundus data",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "All matched fundus images retrieved",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "eye": {
                                                "type": "string",
                                                "description": "Eye imaged<br>OS - left eye<br>OD - right eye"
                                            },
                                            "test_date": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/23/2019 11:59:59 PM",
                                                "description": "The UTC date and time at which the fundus image was uploaded"
                                            },
                                            "image": {
                                                "type": "string",
                                                "format": "uri",
                                                "description": "Download link containing the fundus image active for 15 minutes"
                                            },
                                            "source": {
                                                "type": "string",
                                                "description": "Name of the fundus camera type used for data capture"
                                            },
                                            "comment": {
                                                "type": "string",
                                                "description": "Comments added by clinicians in Bifrost"
                                            },
                                            "prediction": {
                                                "type": "object",
                                                "description": "Json object with labels provided by Sgmoid"
                                            },
                                            "age": {
                                                "type": "integer",
                                                "format": "int32",
                                                "description": "Age of the patient<br>Returned as -1 on failure to retrieve"
                                            },
                                            "shortlisted": {
                                                "type": "boolean",
                                                "description": "Indicator of record being shortlisted for review through Bifrost"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to retrieve all details",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "eye": {
                                                "type": "string",
                                                "description": "Eye imaged<br>OS - left eye<br>OD - right eye"
                                            },
                                            "test_date": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/23/2019 11:59:59 PM",
                                                "description": "The UTC date and time at which the fundus image was uploaded"
                                            },
                                            "image": {
                                                "type": "string",
                                                "format": "uri",
                                                "description": "Download link containing the fundus image active for 15 minutes"
                                            },
                                            "source": {
                                                "type": "string",
                                                "description": "Name of the fundus camera type used for data capture"
                                            },
                                            "comment": {
                                                "type": "string",
                                                "description": "Comments added by clinicians in Bifrost"
                                            },
                                            "prediction": {
                                                "type": "object",
                                                "description": "Json object with labels provided by Sgmoid"
                                            },
                                            "age": {
                                                "type": "integer",
                                                "format": "int32",
                                                "description": "Age of the patient<br>Returned as -1 on failure to retrieve"
                                            },
                                            "shortlisted": {
                                                "type": "boolean",
                                                "description": "Indicator of record being shortlisted for review through Bifrost"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://bifrost-api.azurewebsites.net/api"
        }
    ]
