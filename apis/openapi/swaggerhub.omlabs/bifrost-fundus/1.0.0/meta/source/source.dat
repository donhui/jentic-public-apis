        "/patients/add": {
            "post": {
                "tags": [
                    "patients"
                ],
                "description": "Creates a new patient record",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "name",
                                    "mrn",
                                    "dob",
                                    "gender",
                                    "phone"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "New User",
                                        "description": "Patient's full name"
                                    },
                                    "mrn": {
                                        "type": "string",
                                        "example": "P12345",
                                        "description": "Patient's record reference number used by the organization"
                                    },
                                    "dob": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2019-11-20",
                                        "description": "Patient's date of birth"
                                    },
                                    "gender": {
                                        "type": "string",
                                        "example": "F",
                                        "description": "Patient's gender<br>M - male<br>F - female<br>O - other"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": 919999999999,
                                        "description": "Phone number to link patient record to in international format"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "user@domain.com",
                                        "description": "Patient's email address"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Patient record to add",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Record added or retrieved",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "format": "int32",
                                            "example": 1,
                                            "description": "Indicator of whether a new record was created or an existing record was retrieved<br>0 - Failed to add the new record<br>1 - Record added successfully<br>2 - Existing record found"
                                        },
                                        "id": {
                                            "type": "string",
                                            "format": "uuid",
                                            "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                            "description": "Patient record reference number, if applicable<br>Required for entry as patient_id in other methods"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to add the new record",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "format": "int32",
                                            "example": 0,
                                            "description": "Indicator of whether a new record was created or an existing record was retrieved<br>0 - Failed to add the new record<br>1 - Record added successfully<br>2 - Existing record found"
                                        },
                                        "id": {
                                            "type": "string",
                                            "format": "uuid",
                                            "example": null,
                                            "description": "Patient record reference number, if applicable<br>Required for entry as patient_id in other methods"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
