{
    "openapi": "3.0.0",
    "info": {
        "description": "This is the section of the Bifrost API that provides all methods to incorporate fundus image upload and handling in custom apps.",
        "version": "1.0.0",
        "title": "Bifrost API",
        "contact": {
            "email": "support@omlabs.io",
            "name": "OM Labs"
        },
        "license": {
            "name": "OM Labs",
            "url": "https://omlabs.io"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/omlabs/Bifrost-Fundus-Cameras/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "tests",
            "description": "Methods to handle the fundus image capture and upload to Bifrost"
        },
        {
            "name": "results",
            "description": "Methods to retrieve fundus images captured through Bifrost"
        },
        {
            "name": "tenants",
            "description": "Methods to retrieve all the organizations using Bifrost-powered systems"
        },
        {
            "name": "patients",
            "description": "Methods to create and manage patient records"
        }
    ],
    "paths": {
        "/results/shortlist": {
            "post": {
                "tags": [
                    "results"
                ],
                "description": "Shortlists the session data from a Bifrost-powered diagnostic system for review by consultant",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "id"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "Patient record reference number"
                                    },
                                    "id": {
                                        "type": "integer",
                                        "format": "int64",
                                        "description": "Reference to the image capture session"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Session data reference to shortlist"
                },
                "responses": {
                    "200": {
                        "description": "Session data shortlisted successfully"
                    },
                    "400": {
                        "description": "Failed to shortlist session data"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/patients/search": {
            "post": {
                "tags": [
                    "patients"
                ],
                "description": "Retrieve all matched records from search",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "search_tag": {
                                        "type": "string",
                                        "example": "P1234",
                                        "description": "Search text to find records with match record number, name, email or phone number"
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2019-10-03",
                                        "description": "Start UTC date of search"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2019-10-03",
                                        "description": "End UTC date of search"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Search parameters"
                },
                "responses": {
                    "200": {
                        "description": "Records retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "id": {
                                                "type": "string",
                                                "format": "uuid",
                                                "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                                "description": "Patient record reference number"
                                            },
                                            "name": {
                                                "type": "string",
                                                "example": "New User",
                                                "description": "Patient's full name"
                                            },
                                            "mrn": {
                                                "type": "string",
                                                "example": "P12345",
                                                "description": "Patient's record reference number used by the organization"
                                            },
                                            "dob": {
                                                "type": "string",
                                                "format": "date",
                                                "example": "2019-10-03",
                                                "description": "Patient's date of birth"
                                            },
                                            "gender": {
                                                "type": "string",
                                                "example": "F",
                                                "description": "Patient's gender<br>M - male<br>F - female<br>O - other"
                                            },
                                            "phone": {
                                                "type": "string",
                                                "example": 919999999999,
                                                "description": "Phone number to link patient record to in international format"
                                            },
                                            "email": {
                                                "type": "string",
                                                "example": "user@domain.com",
                                                "description": "Patient's email address"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to retrieve all information from records",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "id": {
                                                "type": "string",
                                                "format": "uuid",
                                                "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                                "description": "Patient record reference number"
                                            },
                                            "name": {
                                                "type": "string",
                                                "example": "New User",
                                                "description": "Patient's full name"
                                            },
                                            "mrn": {
                                                "type": "string",
                                                "example": "P12345",
                                                "description": "Patient's record reference number used by the organization"
                                            },
                                            "dob": {
                                                "type": "string",
                                                "format": "date",
                                                "example": "2019-10-03",
                                                "description": "Patient's date of birth"
                                            },
                                            "gender": {
                                                "type": "string",
                                                "example": "F",
                                                "description": "Patient's gender<br>M - male<br>F - female<br>O - other"
                                            },
                                            "phone": {
                                                "type": "string",
                                                "example": 919999999999,
                                                "description": "Phone number to link patient record to in international format"
                                            },
                                            "email": {
                                                "type": "string",
                                                "example": "user@domain.com",
                                                "description": "Patient's email address"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/tenants/list": {
            "get": {
                "tags": [
                    "tenants"
                ],
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Tenant names and reference IDs returned",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "tenant_id": {
                                                "description": "Unique reference number for organization",
                                                "type": "string",
                                                "format": "uuid"
                                            },
                                            "tenant_name": {
                                                "type": "string",
                                                "description": "Name of the organization registered in Bifrost"
                                            },
                                            "domain": {
                                                "type": "string",
                                                "example": "domain.com",
                                                "description": "Domain associated with organization<br>Can be used to restrict further functionalities to authenticated users with email IDs under this domain"
                                            },
                                            "om": {
                                                "type": "boolean",
                                                "description": "Indicates whether this organization uses OM"
                                            },
                                            "fofo": {
                                                "type": "boolean",
                                                "description": "Indicates whether this organization uses FoFo"
                                            },
                                            "pupil_plus": {
                                                "type": "boolean",
                                                "description": "Indicates whether this organization uses Pupil+"
                                            },
                                            "fundus": {
                                                "type": "boolean",
                                                "description": "Indicates whether this organization uses fundus image management"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/fundus/tests/log": {
            "post": {
                "tags": [
                    "tests"
                ],
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "id",
                                    "eye",
                                    "source",
                                    "img_ext",
                                    "img",
                                    "user"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "Unique reference number to the patients record"
                                    },
                                    "id": {
                                        "type": "integer",
                                        "format": "int64",
                                        "description": "Reference number to the session<br>Useful for record retrieval when both eyes are tested in the same session"
                                    },
                                    "eye": {
                                        "type": "string",
                                        "description": "The eye tested to retrieve this data<br>OS - left eye<br>OD - right eye"
                                    },
                                    "source": {
                                        "type": "string",
                                        "description": "Name of the fundus camera type used for data capture"
                                    },
                                    "img_ext": {
                                        "type": "string",
                                        "description": "The file extension representing image format<br>.jpg<br>.jpeg<br>.dicom<br>.png<br>.tiff<br>.tif"
                                    },
                                    "img": {
                                        "type": "string",
                                        "format": "byte",
                                        "description": "Base64-encoded string of the raw image data"
                                    },
                                    "user": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "user@domain.com",
                                        "description": "The email ID of the authenticated Bifrost user uploading the image"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Fundus image details to upload to Bifrost"
                },
                "responses": {
                    "200": {
                        "description": "Fundus image uploaded successfully"
                    },
                    "400": {
                        "description": "Failed to upload fundus image data"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://bifrost-api.azurewebsites.net/api"
        }
    ]
}