{
  "swagger": "2.0",
  "info": {
    "description": "This is the section of the Bifrost API that provides all methods to integrate Bifrost-powered systems into your telemedicine command center",
    "version": "1.0.0",
    "title": "Bifrost API",
    "contact": {
      "email": "support@omlabs.io",
      "name": "OM Labs"
    },
    "license": {
      "name": "OM Labs",
      "url": "https://omlabs.io"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/om-labs/Bifrost-Telemedicine/1.0.0/swagger.json"
  },
  "host": "bifrost-api.azurewebsites.net",
  "basePath": "/api",
  "schemes": [
    "https"
  ],
  "tags": [
    {
      "name": "telemedicine",
      "description": "Methods to handle Bifrost-powered tests specifically through telemedicine"
    },
    {
      "name": "results",
      "description": "Methods to handle Bifrost-powered test results such as adding comments and generating reports for EMR"
    },
    {
      "name": "patients",
      "description": "Methods to sync patient information between Bifrost and EMR"
    }
  ],
  "paths": {
    "/emr/patients/add": {
      "post": {
        "tags": [
          "patients"
        ],
        "description": "Add a list of patient details to Bifrost for use with diagnostic systems",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "request",
            "description": "Details to add to Bifrost",
            "schema": {
              "required": [
                "tenant_id",
                "organization",
                "patients"
              ],
              "properties": {
                "tenant_id": {
                  "type": "string",
                  "format": "uuid",
                  "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                  "description": "The API key issued on subscription"
                },
                "organization": {
                  "type": "string",
                  "example": "OM Labs",
                  "description": "Name of the organization as registered in Bifrost"
                },
                "patients": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "mrn",
                      "name",
                      "dob",
                      "gender",
                      "phone"
                    ],
                    "properties": {
                      "mrn": {
                        "type": "string",
                        "example": "P1234",
                        "description": "Patient record reference maintained by the organization"
                      },
                      "name": {
                        "type": "string",
                        "example": "Test User",
                        "description": "Patient's full name in record"
                      },
                      "dob": {
                        "type": "string",
                        "format": "date-time",
                        "example": "10/23/2019 2:44:59 PM",
                        "description": "Patient's date of birth in record"
                      },
                      "gender": {
                        "type": "string",
                        "example": "F",
                        "description": "Patient's gender in record<br>F - female<br>M - male<br>O - other"
                      },
                      "phone": {
                        "type": "string",
                        "example": 919999999999,
                        "description": "Patient's phone number in record"
                      },
                      "email": {
                        "type": "string",
                        "format": "email",
                        "example": "user@domain.com",
                        "description": "Patient's email address in record"
                      },
                      "tags": {
                        "type": "string",
                        "description": "Any other organization-specific information tagged to patient record in format of choice"
                      }
                    }
                  }
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "New patient records added successfully and existing matched records in Bifrost returned",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "example": "P1234",
                "description": "Patient record reference maintained by the organization"
              }
            }
          },
          "400": {
            "description": "Failed to add all patient records"
          },
          "401": {
            "description": "Invalid tenant ID provided"
          }
        }
      }
    },
    "/telemedicine/review": {
      "post": {
        "tags": [
          "telemedicine"
        ],
        "description": "Retrieve all shortlisted tests from Bifrost-powered diagnostics",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "request",
            "description": "Search filter for shortlisted tests",
            "schema": {
              "required": [
                "tenant_id",
                "from",
                "to"
              ],
              "properties": {
                "tenant_id": {
                  "type": "string",
                  "format": "uuid",
                  "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                  "description": "The API key provided on subscription"
                },
                "from": {
                  "type": "string",
                  "format": "date",
                  "example": "2019-10-13",
                  "description": "Start UTC date of search"
                },
                "to": {
                  "type": "string",
                  "format": "date",
                  "example": "2019-10-17",
                  "description": "End UTC date of search"
                },
                "system": {
                  "type": "string",
                  "description": "Indicator of the type of diagnostic results to retrieve<br>om - OM<br>fofo - FoFo<br>fundus - Fundus Image Management"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of shortlisted results",
            "schema": {
              "type": "array",
              "items": {
                "properties": {
                  "patient_id": {
                    "type": "string",
                    "format": "uuid",
                    "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                    "description": "Patient record reference number"
                  },
                  "id": {
                    "type": "integer",
                    "format": "int64",
                    "description": "Unique identifier for the test session"
                  },
                  "patient_info": {
                    "type": "string",
                    "description": "Basic patient information - name, date of birth and record reference number from organization"
                  },
                  "system": {
                    "type": "string",
                    "description": "Indicator of the type of diagnostic results retrieved<br>om - OM<br>fofo - FoFo<br>fundus - Fundus Image Management"
                  },
                  "eye": {
                    "type": "string",
                    "description": "Eye tested<br>OS - left eye<br>OD - right eye"
                  },
                  "test_date": {
                    "type": "string",
                    "format": "date-time",
                    "example": "10/13/2019 8:00:30 AM",
                    "description": "UTC date and time of the test"
                  },
                  "test_metrics": {
                    "type": "string",
                    "description": "All metrics specific to the test"
                  },
                  "plot": {
                    "type": "string",
                    "format": "uri",
                    "description": "Link to any associated plots or images, if applicable"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid tenant ID or API key provided"
          }
        }
      }
    },
    "/results/save": {
      "post": {
        "tags": [
          "results"
        ],
        "description": "Saves a pdf report<br>Required for backup to partnered EMR, if any",
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "request",
            "description": "Report to push to server",
            "schema": {
              "required": [
                "tenant_id",
                "test_date",
                "mrn",
                "report",
                "system"
              ],
              "properties": {
                "tenant_id": {
                  "type": "string",
                  "format": "uuid",
                  "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                  "description": "The unique reference number to the tenant (returned by /tenants/list)"
                },
                "test_date": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2019-10-13 18:28:45",
                  "description": "Test UTC date and time"
                },
                "mrn": {
                  "type": "string",
                  "example": "P1234",
                  "description": "Patient's record reference number used by the organization"
                },
                "report": {
                  "type": "string",
                  "format": "byte",
                  "description": "Base64-encoded string of PDF report generated"
                },
                "system": {
                  "type": "string",
                  "description": "Indicator of the type of diagnostic results for which comments are being added<br>om - OM<br>fofo - FoFo<br>fundus - Fundus Image Management"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Report saved successfully"
          },
          "400": {
            "description": "Failed to save report"
          },
          "401": {
            "description": "Invalid tenant ID or API key provided"
          }
        }
      }
    },
    "/results/comment": {
      "post": {
        "tags": [
          "results"
        ],
        "description": "Adds a comment on the diagnostics to the session data",
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "request",
            "description": "Comment to add to session data",
            "schema": {
              "required": [
                "tenant_id",
                "patient_id",
                "comment",
                "system"
              ],
              "properties": {
                "tenant_id": {
                  "type": "string",
                  "format": "uuid",
                  "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                  "description": "The unique reference number to the tenant (returned by /tenants/list)"
                },
                "patient_id": {
                  "type": "string",
                  "format": "uuid",
                  "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                  "description": "Patient record reference number"
                },
                "comment": {
                  "type": "string",
                  "description": "Comment to be added to session data"
                },
                "system": {
                  "type": "string",
                  "description": "Indicator of the type of diagnostic results for which comments are being added<br>om - OM<br>fofo - FoFo<br>fundus - Fundus Image Management"
                }
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Comment added successfully"
          },
          "400": {
            "description": "Failed to add the comment"
          },
          "401": {
            "description": "Invalid tenant ID or API key provided"
          }
        }
      }
    }
  }
}