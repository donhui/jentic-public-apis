{
    "openapi": "3.0.0",
    "info": {
        "description": "This describes all the API methods to sync data between any EMR and Bifrost",
        "version": "1.0.0",
        "title": "Bifrost for EMR",
        "contact": {
            "email": "support@omlabs.io",
            "name": "Customer Support"
        },
        "license": {
            "name": "OM Labs",
            "url": "https://omlabs.io"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/om-labs/Bifrost-EMR/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "results",
            "description": "Methods to sync reports from Bifrost-powered diagnostic systems"
        },
        {
            "name": "patients",
            "description": "Methods to sync patient information between Bifrost and EMR"
        }
    ],
    "paths": {
        "/emr/organizations/list": {
            "post": {
                "description": "Retrieves a list of all organizations in partnership with your EMR",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The API key issued on subscription"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Details to retrieve available organizations"
                },
                "responses": {
                    "200": {
                        "description": "List of organizations retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "string",
                                        "example": "OM Labs",
                                        "description": "Name of the organization as registered in Bifrost"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID provided"
                    }
                }
            }
        },
        "/emr/patients/add": {
            "post": {
                "tags": [
                    "patients"
                ],
                "description": "Add a list of patient details to Bifrost for use with diagnostic systems",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "organization",
                                    "patients"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The API key issued on subscription"
                                    },
                                    "organization": {
                                        "type": "string",
                                        "example": "OM Labs",
                                        "description": "Name of the organization as registered in Bifrost"
                                    },
                                    "patients": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "required": [
                                                "mrn",
                                                "name",
                                                "dob",
                                                "gender",
                                                "phone"
                                            ],
                                            "properties": {
                                                "mrn": {
                                                    "type": "string",
                                                    "example": "P1234",
                                                    "description": "Patient record reference maintained by the organization"
                                                },
                                                "name": {
                                                    "type": "string",
                                                    "example": "Test User",
                                                    "description": "Patient's full name in record"
                                                },
                                                "dob": {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "example": "10/23/2019 2:44:59 PM",
                                                    "description": "Patient's date of birth in record"
                                                },
                                                "gender": {
                                                    "type": "string",
                                                    "example": "F",
                                                    "description": "Patient's gender in record<br>F - female<br>M - male<br>O - other"
                                                },
                                                "phone": {
                                                    "type": "string",
                                                    "example": 919999999999,
                                                    "description": "Patient's phone number in record"
                                                },
                                                "email": {
                                                    "type": "string",
                                                    "format": "email",
                                                    "example": "user@domain.com",
                                                    "description": "Patient's email address in record"
                                                },
                                                "tags": {
                                                    "type": "object",
                                                    "description": "All organization-specific data tagged to patient record"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "description": "Details to add to Bifrost"
                },
                "responses": {
                    "200": {
                        "description": "New patient records added successfully and existing matched records in Bifrost returned",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "string",
                                        "example": "P1234",
                                        "description": "Patient record reference maintained by the organization"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to add all patient records"
                    },
                    "401": {
                        "description": "Invalid tenant ID provided"
                    }
                }
            }
        },
        "/emr/patients/export": {
            "post": {
                "tags": [
                    "patients"
                ],
                "description": "List all the patients associated with the organization as registered on Bifrost",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "organization"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The API key issued on subscription"
                                    },
                                    "organization": {
                                        "type": "string",
                                        "example": "OM Labs",
                                        "description": "Name of the organization as registered in Bifrost"
                                    },
                                    "mrn": {
                                        "type": "string",
                                        "example": "P1234",
                                        "description": "Patient record reference maintained by the organization"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Details to export patient details"
                },
                "responses": {
                    "200": {
                        "description": "All patient details retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "mrn": {
                                                "type": "string",
                                                "example": "P1234",
                                                "description": "Patient record reference maintained by the organization"
                                            },
                                            "name": {
                                                "type": "string",
                                                "example": "Test User",
                                                "description": "Patient's full name in record"
                                            },
                                            "dob": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/23/2019 2:44:59 PM",
                                                "description": "Patient's date of birth in record"
                                            },
                                            "gender": {
                                                "type": "string",
                                                "example": "F",
                                                "description": "Patient's gender in record<br>F - female<br>M - male<br>O - other"
                                            },
                                            "phone": {
                                                "type": "string",
                                                "example": 919999999999,
                                                "description": "Patient's phone number in record"
                                            },
                                            "email": {
                                                "type": "string",
                                                "format": "email",
                                                "example": "user@domain.com",
                                                "description": "Patient's email address in record"
                                            },
                                            "tags": {
                                                "type": "object",
                                                "description": "All organization-specific data tagged to patient record"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to retrieve all patient details"
                    },
                    "401": {
                        "description": "Invalid tenant ID provided"
                    }
                }
            }
        },
        "/emr/results/export": {
            "post": {
                "tags": [
                    "results"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "from",
                                    "to"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The API key issued on subscription"
                                    },
                                    "from": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2019-10-23 23:59:59.999",
                                        "description": "Start UTC date and time for search"
                                    },
                                    "to": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2019-10-25 4:00:00.679",
                                        "description": "End UTC date and time for search"
                                    },
                                    "system": {
                                        "type": "string",
                                        "example": "om",
                                        "description": "Code for Bifrost-powered diagnostic system<br>om - OM<br>pupil-plus - Pupil+<br>fofo - FoFo<br>fundus - Fundus Images"
                                    },
                                    "organization": {
                                        "type": "string",
                                        "description": "Name of the organization as registered"
                                    },
                                    "mrn": {
                                        "type": "string",
                                        "example": "P1234",
                                        "description": "Patient record reference maintained by the organization"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Details to export specific reports"
                },
                "responses": {
                    "200": {
                        "description": "All reports matching search parameters retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "system": {
                                                "type": "string",
                                                "example": "om",
                                                "description": "Code for Bifrost-powered diagnostic system<br>om - OM<br>pupil-plus - Pupil+<br>fofo - FoFo<br>fundus - Fundus Images"
                                            },
                                            "organization": {
                                                "type": "string",
                                                "description": "Name of the organization as registered"
                                            },
                                            "reports": {
                                                "type": "array",
                                                "items": {
                                                    "properties": {
                                                        "mrn": {
                                                            "type": "string",
                                                            "example": "P1234",
                                                            "description": "Patient record reference maintained by the organization"
                                                        },
                                                        "test_date": {
                                                            "type": "string",
                                                            "format": "date-time",
                                                            "example": "10/23/2019 11:59:59 PM",
                                                            "description": "UTC date and time of the test"
                                                        },
                                                        "report": {
                                                            "type": "string",
                                                            "format": "byte",
                                                            "description": "Base64-encoded string containing the pdf report"
                                                        },
                                                        "tags": {
                                                            "type": "object",
                                                            "description": "All organization-specific data tagged to patient record"
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID provided"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://bifrost-api.azurewebsites.net/api"
        }
    ]
}