                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "uuid",
                                    "email",
                                    "role",
                                    "name"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "uuid": {
                                        "type": "string",
                                        "format": "uuid",
                                        "description": "Unique identifier for the new user returned by the authentication service"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "user@domain.com",
                                        "description": "User's email address registered with authentication service"
                                    },
                                    "role": {
                                        "type": "string",
                                        "example": "examiner",
                                        "description": "User's role, which determines the functionalities accessible on sign-in<br>examiner - can conduct tests, view and shortlit data<br>consultant - can conduct tests, view data, add comments and upload reports"
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "New User",
                                        "description": "User's full name"
                                    },
                                    "pic": {
                                        "type": "string",
                                        "format": "byte",
                                        "description": "Base64-encoded profile picture jpeg"
                                    },
                                    "department": {
                                        "type": "string",
                                        "example": "Retina",
                                        "description": "User's department within the organization"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Profile to create"
                },
                "responses": {
                    "200": {
                        "description": "User profile created successfully"
                    },
                    "400": {
                        "description": "Failed to create a new user profile"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
