        "/om/results/list": {
            "post": {
                "tags": [
                    "results"
                ],
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "eye",
                                    "start_date",
                                    "end_date"
                                ],
                                "properties": {
