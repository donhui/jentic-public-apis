                        }
                    },
                    "description": "Session details to retrieve fundus data"
                },
                "responses": {
                    "200": {
                        "description": "All matched OM datasets retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "eye": {
                                                "type": "string",
                                                "description": "Eye tested<br>OS - left eye<br>OD - right eye"
                                            },
                                            "test_date": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/23/2019 11:59:59 PM",
                                                "description": "The UTC date and time at which the fundus image was uploaded"
                                            },
                                            "duration": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "Total duration of Om test on the target eye (in minutes)"
                                            },
                                            "fp": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "False positive score"
                                            },
                                            "fp_count": {
                                                "type": "integer",
                                                "format": "int32",
                                                "description": "Number of false positive checks during the test"
                                            },
                                            "fl": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "Fixation loss score"
                                            },
                                            "fl_count": {
                                                "type": "integer",
                                                "format": "int32",
                                                "description": "Number of fixation loss checks during the test"
                                            },
                                            "va": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "LogMAR visual acuity measure<br>< 0 when visual acuity test was not conducted"
                                            },
                                            "ft": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "Fovea threshold value"
                                            },
                                            "rt": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "User's reaction time during the test"
                                            },
                                            "field": {
                                                "type": "string",
                                                "description": "CSV string location-wise OM results<br>For 24-2,![24-2](https://srujana.blob.core.windows.net/bifrost-materials/24-2.PNG)<br>For Armaly,![Armaly](https://srujana.blob.core.windows.net/bifrost-materials/Armaly.PNG)"
                                            },
                                            "protocol": {
                                                "type": "string",
                                                "description": "The test protocol used<br>24-2<br>Armaly"
                                            },
                                            "comment": {
                                                "type": "string",
                                                "description": "Comments added by clinicians in Bifrost"
                                            },
                                            "prediction": {
                                                "type": "string",
                                                "description": "Labels added by automated clinical decision support system<br>Provided by Sgmoid"
                                            },
                                            "age": {
                                                "type": "integer",
                                                "format": "int32",
                                                "description": "Age of the patient<br>Returned as -1 on failure to retrieve"
                                            },
                                            "shortlisted": {
                                                "type": "boolean",
                                                "description": "Indicator of record being shortlisted for review through Bifrost"
                                            },
                                            "fp_reliable": {
                                                "type": "boolean",
                                                "description": "Indicator of whether the false positive metrics show test reliability"
                                            },
                                            "fl_reliable": {
                                                "type": "boolean",
                                                "description": "Indicator of whether the fixation loss metrics show test reliability"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to retrieve all details",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "eye": {
                                                "type": "string",
                                                "description": "Eye tested<br>OS - left eye<br>OD - right eye"
                                            },
                                            "test_date": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/23/2019 11:59:59 PM",
                                                "description": "The UTC date and time at which the fundus image was uploaded"
                                            },
                                            "image": {
                                                "type": "string",
                                                "format": "uri",
                                                "description": "Download link containing the fundus image active for 15 minutes"
                                            },
                                            "source": {
                                                "type": "string",
                                                "description": "Name of the fundus camera type used for data capture"
                                            },
                                            "comment": {
                                                "type": "string",
                                                "description": "Comments added by clinicians in Bifrost"
                                            },
                                            "prediction": {
                                                "type": "string",
                                                "description": "Labels added by automated clinical decision support system<br>Provided by Sgmoid"
                                            },
                                            "age": {
                                                "type": "integer",
                                                "format": "int32",
                                                "description": "Age of the patient<br>Returned as -1 on failure to retrieve"
                                            },
                                            "shortlisted": {
                                                "type": "boolean",
                                                "description": "Indicator of record being shortlisted for review through Bifrost"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://bifrost-api.azurewebsites.net/api"
        }
    ]
}