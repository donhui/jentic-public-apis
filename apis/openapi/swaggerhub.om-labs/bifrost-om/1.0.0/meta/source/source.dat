                                        "description": "Unique reference to all data uploaded in a session"
                                    },
                                    "eye": {
                                        "type": "string",
                                        "description": "Eye(s) tested<br>OS - left eye<br>OD - right eye<br>OU - both eyes"
                                    },
                                    "protocol": {
                                        "type": "string",
                                        "description": "The test protocol used<br>24-2<br>Armaly"
