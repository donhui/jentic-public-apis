                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "id": {
                                                "type": "integer",
                                                "format": "int64",
                                                "description": "Unique reference to all data uploaded in a session"
                                            },
                                            "eye": {
                                                "type": "string",
                                                "description": "Eye tested<br>OS - left eye<br>OD - right eye"
                                            },
                                            "test_date": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/23/2019 11:59:59 PM",
                                                "description": "UTC date and time at which the image was uploaded"
                                            },
                                            "shortlisted": {
                                                "type": "boolean",
                                                "description": "Indicator of whether this data was shortlisted for review in Bifrost"
                                            },
                                            "duration": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "Total duration of Om test on the target eye (in minutes)"
                                            },
                                            "fp": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "False positive score"
                                            },
                                            "fp_count": {
                                                "type": "integer",
                                                "format": "int32",
                                                "description": "Number of false positive checks during the test"
                                            },
                                            "fl": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "Fixation loss score"
                                            },
                                            "fl_count": {
                                                "type": "integer",
                                                "format": "int32",
                                                "description": "Number of fixation loss checks during the test"
                                            },
                                            "va": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "LogMAR visual acuity measure<br>< 0 when visual acuity test was not conducted"
                                            },
                                            "ft": {
                                                "type": "number",
                                                "format": "float",
                                                "description": "Fovea threshold value"
                                            },
                                            "protocol": {
                                                "type": "string",
                                                "description": "The test protocol used<br>24-2<br>Armaly"
                                            },
                                            "reliable": {
                                                "type": "boolean",
                                                "description": "Indicator of whether the test was reliable, i.e. honest performance of test by patient"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to retrieve available records"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
