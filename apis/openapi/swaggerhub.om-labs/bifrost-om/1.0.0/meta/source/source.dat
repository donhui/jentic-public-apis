{
    "openapi": "3.0.0",
    "info": {
        "description": "This is the section of the Bifrost API that provides all methods to incorporate fundus image upload and handling in custom apps.",
        "version": "1.0.0",
        "title": "Bifrost API",
        "contact": {
            "email": "support@omlabs.io",
            "name": "OM Labs"
        },
        "license": {
            "name": "OM Labs",
            "url": "https://omlabs.io"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/om-labs/Bifrost-OM/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "tests",
            "description": "Methods to handle the OM tests and upload results to Bifrost"
        },
        {
            "name": "results",
            "description": "Methods to retrieve OM data captured through Bifrost"
        },
        {
            "name": "tenants",
            "description": "Methods to retrieve all the organizations using Bifrost-powered systems"
        },
        {
            "name": "patients",
            "description": "Methods to create and manage patient records"
        },
        {
            "name": "users",
            "description": "Methods to create and manage user profiles for clinicians and examiners. These are necessary if using the messaging features of Bifrost."
        },
        {
            "name": "messages",
            "description": "Methods to handle notification features between consultants and patients"
        },
        {
            "name": "admin",
            "description": "Methods to manage users. Mainly used by assigned admin by the organization"
        }
    ],
    "paths": {
        "/tenants/users/approve": {
            "post": {
                "tags": [
                    "tenants",
                    "admin"
                ],
                "description": "Enables or blocks access to users in consultant or examiner role within the organization",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "uuid",
                                    "email",
                                    "role",
                                    "approved"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "uuid": {
                                        "type": "string",
                                        "description": "A unique identifier for the user generated by authentication system of choice"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "description": "User's email address with registered organization domain"
                                    },
                                    "role": {
                                        "type": "string",
                                        "example": "examiner",
                                        "description": "Any one of the two major Bifrost roles<br>examiner<br>consultant"
                                    },
                                    "approved": {
                                        "type": "boolean",
                                        "description": "Indicator of whether the user must be approved or not for Bifrost access"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Tenant details for search"
                },
                "responses": {
                    "200": {
                        "description": "User access enabled/blocked successfully"
                    },
                    "400": {
                        "description": "Failed to update user access"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/tenants/users/list": {
            "post": {
                "tags": [
                    "tenants",
                    "admin"
                ],
                "description": "List all registered users in examiner and consultant role for approval<br>To be used by assign admin",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Tenant details for search"
                },
                "responses": {
                    "200": {
                        "description": "Users retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "uuid": {
                                                "type": "string",
                                                "description": "A unique identifier for the user generated by authentication system of choice"
                                            },
                                            "name": {
                                                "type": "string",
                                                "description": "User's full name"
                                            },
                                            "email": {
                                                "type": "string",
                                                "format": "email",
                                                "description": "User's email address with registered organization domain"
                                            },
                                            "doj": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/23/2019 11:30:00 AM",
                                                "description": "UTC date and time of user request"
                                            },
                                            "role": {
                                                "type": "string",
                                                "example": "examiner",
                                                "description": "Any one of the two major Bifrost roles<br>examiner<br>consultant"
                                            },
                                            "approved": {
                                                "type": "boolean",
                                                "description": "Indicator of whether the user has been approved for Bifrost access by the assigned admin"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/patients/messages/unread": {
            "post": {
                "tags": [
                    "patients",
                    "messages"
                ],
                "description": "List all unread messages sent to a patient",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "Patient record reference number"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Patient details to list messages"
                },
                "responses": {
                    "200": {
                        "description": "Messages listed successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "required": [
                                        "from",
                                        "id",
                                        "unread_count"
                                    ],
                                    "properties": {
                                        "from": {
                                            "type": "string",
                                            "description": "Name & department for consultant/Name & record number from organization for patient"
                                        },
                                        "id": {
                                            "type": "string",
                                            "description": "Patient record reference number/Consultant's email address"
                                        },
                                        "unread_count": {
                                            "type": "integer",
                                            "format": "int32",
                                            "description": "Number of unread messages for patient or consultant"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/patients/messages/send": {
            "post": {
                "tags": [
                    "patients",
                    "messages"
                ],
                "description": "Sends a message to a consultant",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "to_email",
                                    "message"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "Patient record reference number"
                                    },
                                    "to_email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "user@domain.com",
                                        "description": "Consultant's email address"
                                    },
                                    "message": {
                                        "type": "string",
                                        "description": "Message content"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Message to send to consultant"
                },
                "responses": {
                    "200": {
                        "description": "Message sent successfully"
                    },
                    "400": {
                        "description": "Failed to send message"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/consultants/messages/unread": {
            "post": {
                "tags": [
                    "users",
                    "messages"
                ],
                "description": "List all unread messages sent to a consultant",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "user"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The API key issued on subscription"
                                    },
                                    "user": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "user@domain.com",
                                        "description": "Consultant's email address"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Patient details to list messages"
                },
                "responses": {
                    "200": {
                        "description": "Messages listed successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "from": {
                                            "type": "string",
                                            "description": "Name & department for consultant/Name & record number from organization for patient"
                                        },
                                        "id": {
                                            "type": "string",
                                            "description": "Patient record reference number/Consultant's email address"
                                        },
                                        "unread_count": {
                                            "type": "integer",
                                            "format": "int32",
                                            "description": "Number of unread messages for patient or consultant"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/consultants/messages/sent": {
            "post": {
                "tags": [
                    "users",
                    "messages"
                ],
                "description": "Sends a message to a patient",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "from_email",
                                    "message"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The API key issued on subscription"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "Patient record reference number"
                                    },
                                    "from_email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "user@domain.com",
                                        "description": "Consultant's email address"
                                    },
                                    "message": {
                                        "type": "string",
                                        "description": "Message content"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Message to send to patient"
                },
                "responses": {
                    "200": {
                        "description": "Message sent successfully"
                    },
                    "400": {
                        "description": "Failed to send message"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/messages/update": {
            "post": {
                "tags": [
                    "messages"
                ],
                "description": "Mark all messages as read",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "end_date",
                                    "user",
                                    "patient_id"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The API key issued on subscription"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "Patient record reference number"
                                    },
                                    "user": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "user@domain.com",
                                        "description": "Clinician's email address"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2019-10-18 23:59:99.999",
                                        "description": "Last seen UTC timestamp to mark all previous messages as read"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Details to mark messages"
                },
                "responses": {
                    "200": {
                        "description": "Messages marked as read successfully"
                    },
                    "400": {
                        "description": "Failed to mark messages as read"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/messages/get": {
            "post": {
                "tags": [
                    "messages"
                ],
                "description": "Retrieve all the messages between clinician and patient for a given time period",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "user",
                                    "start_date",
                                    "end_date"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The API key issued on subscription"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "Patient record reference number"
                                    },
                                    "user": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "user@domain.com",
                                        "description": "Clinician's email address"
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2019-10-20",
                                        "description": "Start UTC date of search"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2019-10-23",
                                        "description": "End UTC date of search"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Details to retrieve messages"
                },
                "responses": {
                    "200": {
                        "description": "Messages retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "from": {
                                                "type": "string",
                                                "description": "Sender's information<br>Email address for clinician<br>Name and organization record number for patient"
                                            },
                                            "to": {
                                                "type": "string",
                                                "description": "Receiver's information<br>Email address for clinician<br>Name and organization record number for patient"
                                            },
                                            "message": {
                                                "type": "string",
                                                "description": "Text content of message"
                                            },
                                            "timestamp": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/14/2019 9:34:00 PM",
                                                "description": "Message date and time (UTC)"
                                            },
                                            "seen": {
                                                "type": "boolean",
                                                "description": "Indicates whether the message has been seen by the receiver<br>"
                                            },
                                            "incoming": {
                                                "type": "boolean",
                                                "description": "Indicates whether the message was received or sent by the patient<br>true - received by patient<br>false - sent by patient"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/results/shortlist": {
            "post": {
                "tags": [
                    "results"
                ],
                "description": "Shortlists the session data from a Bifrost-powered diagnostic system for review by consultant",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "id",
                                    "maps"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "Patient record reference number"
                                    },
                                    "id": {
                                        "type": "integer",
                                        "format": "int64",
                                        "description": "Reference to the OM session"
                                    },
                                    "maps": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "eye",
                                                "map"
                                            ],
                                            "properties": {
                                                "eye": {
                                                    "type": "string",
                                                    "description": "Eye for which map is generated<br>OS - left eye<br>OD - right eye"
                                                },
                                                "map": {
                                                    "type": "string",
                                                    "description": "Base64-encoded string of the field map in png format"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "description": "Session data reference to shortlist"
                },
                "responses": {
                    "200": {
                        "description": "Session data shortlisted successfully"
                    },
                    "400": {
                        "description": "Failed to shortlist session data"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/results/show": {
            "post": {
                "tags": [
                    "results"
                ],
                "description": "Retrieve all PDF reports that match search criteria",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "mrn"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "mrn": {
                                        "type": "string",
                                        "example": "P1234",
                                        "description": "Patient's record reference number used by the organization"
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2019-10-13",
                                        "description": "Start UTC date of search"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2019-10-17",
                                        "description": "End UTC date of search"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Search filter for reports"
                },
                "responses": {
                    "200": {
                        "description": "Reports retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "test_date": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "10/13/2019 6:28:45 PM",
                                                "description": "Test UTC date and time"
                                            },
                                            "mrn": {
                                                "type": "string",
                                                "example": "P1234",
                                                "description": "Patient's record reference number used by the organization"
                                            },
                                            "report": {
                                                "type": "string",
                                                "format": "uri",
                                                "description": "Temporarily accessible url linking to pdf report<br>Will be accessible for 30 minutes"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/results/save": {
            "post": {
                "tags": [
                    "results"
                ],
                "description": "Saves a pdf report<br>Required for backup to partnered EMR, if any",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "test_date",
                                    "mrn",
                                    "report"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "d290f1ee-6c54-4b01-90e6-d701748f0851",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "test_date": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2019-10-13 18:28:45",
                                        "description": "Test UTC date and time"
                                    },
                                    "mrn": {
                                        "type": "string",
                                        "example": "P1234",
                                        "description": "Patient's record reference number used by the organization"
                                    },
                                    "report": {
                                        "type": "string",
                                        "format": "byte",
                                        "description": "Base64-encoded string of PDF report generated"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Report to push to server"
                },
                "responses": {
                    "200": {
                        "description": "Report saved successfully"
                    },
                    "400": {
                        "description": "Failed to save report"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
