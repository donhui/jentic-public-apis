        "/om/tests/update": {
            "post": {
                "tags": [
                    "tests"
                ],
                "description": "Update the status of an OM session in progress",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "id",
                                    "device_num"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "Unique reference number to the patients record"
                                    },
                                    "id": {
                                        "type": "integer",
                                        "format": "int64",
                                        "description": "Reference number to the session<br>Useful for record retrieval when both eyes are tested in the same session"
                                    },
                                    "device_num": {
                                        "type": "integer",
                                        "format": "int32",
                                        "description": "The target device number to conduct the OM session"
                                    },
                                    "stage": {
                                        "type": "integer",
                                        "format": "int32",
                                        "description": "Indicator of the stage of the session that is currently in progress<br>-1 - session has not begun<br>0 - adjust headset for left eye<br>1 - visual acuity test for left eye<br>2 - fovea thresholding of left eye<br>3 - visual field evaluation of left eye<br>4 - adjust headset for right eye<br>5 - visual acuity test for right eye<br>6 - fovea thresholding of right eye<br>7 - visual field evaluation of right eye<br>8 - session completed<br>9 - session aborted"
                                    },
                                    "locations": {
                                        "type": "integer",
                                        "format": "int32",
                                        "description": "Number of locations of the protocol tested<br>Total number of locations to complete test are:<br>54 for 24-2 pattern<br>48 for Armaly grid"
                                    },
                                    "play": {
                                        "type": "boolean",
                                        "description": "Indicator of whether the stage has begun or is paused<br>true - step has begun<br>false - step is paused"
                                    },
                                    "duration": {
                                        "type": "number",
                                        "format": "float",
                                        "description": "Total duration of the test<br>Prediction based on status variables updates expected duration"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Status of session to update"
                },
                "responses": {
                    "200": {
                        "description": "Status updated successfully"
                    },
                    "400": {
                        "description": "Failed to update status of the session"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/om/tests/get": {
            "post": {
                "tags": [
                    "tests"
                ],
                "description": "Retrieve the latest status variable for an OM session",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "patient_id",
                                    "id",
                                    "device_num"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "Unique reference number to the patients record"
                                    },
                                    "id": {
                                        "type": "integer",
                                        "format": "int64",
                                        "description": "Reference number to the session<br>Useful for record retrieval when both eyes are tested in the same session"
                                    },
                                    "device_num": {
                                        "type": "integer",
                                        "format": "int32",
                                        "description": "The target device number to conduct the OM session"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Status of session to update"
                },
                "responses": {
                    "200": {
                        "description": "Session status retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "stage": {
                                            "type": "integer",
                                            "format": "int32",
                                            "description": "Indicator of the stage of the session that is currently in progress<br>-1 - session has not begun<br>0 - adjust headset for left eye<br>1 - visual acuity test for left eye<br>2 - fovea thresholding of left eye<br>3 - visual field evaluation of left eye<br>4 - adjust headset for right eye<br>5 - visual acuity test for right eye<br>6 - fovea thresholding of right eye<br>7 - visual field evaluation of right eye<br>8 - session completed<br>9 - session aborted"
                                        },
                                        "locations": {
                                            "type": "integer",
                                            "format": "int32",
                                            "description": "Number of locations of the protocol tested<br>Total number of locations to complete test are:<br>54 for 24-2 pattern<br>48 for Armaly grid"
                                        },
                                        "play": {
                                            "type": "boolean",
                                            "description": "Indicator of whether the stage has begun or is paused<br>true - step has begun<br>false - step is paused"
                                        },
                                        "duration": {
                                            "type": "number",
                                            "format": "float",
                                            "description": "Total duration of the test<br>Prediction based on status variables updates expected duration"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to retrieve session status"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/om/tests/capture": {
            "post": {
                "tags": [
                    "tests"
                ],
                "description": "Upload a screenshot from headset for view in control screen",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
