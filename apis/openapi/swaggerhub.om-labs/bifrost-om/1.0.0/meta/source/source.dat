                                    "device_num"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "patient_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "Unique reference number to the patients record"
                                    },
                                    "id": {
                                        "type": "integer",
                                        "format": "int64",
                                        "description": "Reference number to the session<br>Useful for record retrieval when both eyes are tested in the same session"
                                    },
                                    "eye": {
                                        "type": "string",
                                        "description": "The eye tested to retrieve this data<br>OS - left eye<br>OD - right eye"
                                    },
                                    "duration": {
                                        "type": "number",
                                        "format": "float",
                                        "description": "Total duration of Om test on the target eye (in minutes)"
                                    },
                                    "fp": {
                                        "type": "number",
                                        "format": "float",
                                        "description": "False positive score"
                                    },
                                    "fp_count": {
                                        "type": "integer",
                                        "format": "int32",
                                        "description": "Number of false positive checks during the test"
                                    },
                                    "fl": {
                                        "type": "number",
                                        "format": "float",
                                        "description": "Fixation loss score"
                                    },
                                    "fl_count": {
                                        "type": "integer",
                                        "format": "int32",
                                        "description": "Number of fixation loss checks during the test"
                                    },
                                    "va": {
                                        "type": "number",
                                        "format": "float",
                                        "description": "LogMAR visual acuity measure<br>< 0 when visual acuity test was not conducted"
                                    },
                                    "ft": {
                                        "type": "number",
                                        "format": "float",
                                        "description": "Fovea threshold value"
                                    },
                                    "rt": {
                                        "type": "number",
                                        "format": "float",
                                        "description": "User's reaction time during the test"
                                    },
                                    "field": {
                                        "type": "string",
                                        "description": "CSV string location-wise OM results<br>For 24-2,![24-2](https://srujana.blob.core.windows.net/bifrost-materials/24-2.PNG)<br>For Armaly,![Armaly](https://srujana.blob.core.windows.net/bifrost-materials/Armaly.PNG)"
                                    },
                                    "protocol": {
                                        "type": "string",
                                        "description": "The test protocol used<br>24-2<br>Armaly"
                                    },
                                    "blind_spot": {
                                        "type": "string",
                                        "description": "The location in Unity reference space where the blind spot was detected<br>NA when blind spot is not detected"
                                    },
                                    "battery": {
                                        "type": "number",
                                        "format": "float",
                                        "description": "Battery level of the VR headset<br>Value between 0 and 1"
                                    },
                                    "device_num": {
                                        "type": "integer",
                                        "format": "int32",
                                        "description": "The device number that is auto-assigned on registration of a new license key"
                                    }
                                }
                            }
                        }
                    },
                    "description": "OM data details to upload to Bifrost"
                },
                "responses": {
                    "200": {
                        "description": "OM data uploaded successfully"
                    },
                    "400": {
                        "description": "Failed to upload OM data"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
        "/om/tests/load": {
            "post": {
                "tags": [
                    "tests"
                ],
                "description": "Load a queued test session into VR headset",
                "parameters": [
                    {
                        "in": "query",
                        "name": "code",
                        "description": "API key provided on subscription",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tenant_id",
                                    "device_num"
                                ],
                                "properties": {
                                    "tenant_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                        "description": "The unique reference number to the tenant (returned by /tenants/list)"
                                    },
                                    "device_num": {
                                        "type": "integer",
                                        "format": "int32",
                                        "description": "The target device number to conduct the OM session"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Device details to load session from queue"
                },
                "responses": {
                    "200": {
                        "description": "Queued session retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "patient_id": {
                                            "type": "string",
                                            "format": "uuid",
                                            "example": "a1a1a1a1-b2b2-c3c3-d4d4-e5e5e5e5e5e5",
                                            "description": "Unique reference number to the patients record"
                                        },
                                        "id": {
                                            "type": "integer",
                                            "format": "int64",
                                            "description": "Unique reference to all data uploaded in a session"
                                        },
                                        "eye": {
                                            "type": "string",
                                            "description": "Eye(s) tested<br>OS - left eye<br>OD - right eye<br>OU - both eyes"
                                        },
                                        "protocol": {
                                            "type": "string",
                                            "description": "The test protocol used<br>24-2<br>Armaly"
                                        },
                                        "va_test": {
                                            "type": "boolean",
                                            "description": "Indicator of whether a visual acuity test is to be conducted"
                                        },
                                        "device_num": {
                                            "type": "integer",
                                            "format": "int32",
                                            "description": "The target device number to conduct the OM session"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Failed to retrieve test from the queue"
                    },
                    "401": {
                        "description": "Invalid tenant ID or API key provided"
                    }
                }
            }
        },
