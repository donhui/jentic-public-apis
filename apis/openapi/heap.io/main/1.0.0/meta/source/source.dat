{
  "openapi": "3.0.3",
  "info": {
    "title": "Heap API",
    "version": "1.0.0",
    "description": "Heap is a digital analytics platform that automatically captures user interactions. The server-side API allows tracking custom events, identifying users, adding user and account properties, bulk operations, and user deletion for privacy compliance.",
    "x-jentic-source-url": "https://developers.heap.io/"
  },
  "servers": [
    {
      "url": "https://heapanalytics.com",
      "description": "Heap US Server"
    },
    {
      "url": "https://c.eu.heap-api.com",
      "description": "Heap EU Server"
    }
  ],
  "security": [
    {
      "appId": []
    }
  ],
  "tags": [
    { "name": "Events", "description": "Track and manage events" },
    { "name": "Users", "description": "User identification and properties" },
    { "name": "Accounts", "description": "Account property management" },
    { "name": "Auth", "description": "Authentication for management APIs" }
  ],
  "paths": {
    "/api/track": {
      "post": {
        "operationId": "trackEvent",
        "summary": "Track a custom event",
        "description": "Sends a custom event to Heap. Rate limited to 30 requests per 30 seconds per identity per app_id.",
        "tags": ["Events"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TrackEventRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event tracked successfully",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid app_id",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/identify": {
      "post": {
        "operationId": "identifyUser",
        "summary": "Identify a user",
        "description": "Links an anonymous user_id to a known identity string.",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/IdentifyUserRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User identified successfully",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/add_user_properties": {
      "post": {
        "operationId": "addUserProperties",
        "summary": "Add user properties",
        "description": "Attaches custom properties to an identified user profile.",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddUserPropertiesRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Properties added",
            "content": {
              "application/json": { "schema": { "type": "object" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/api/add_account_properties": {
      "post": {
        "operationId": "addAccountProperties",
        "summary": "Add account properties",
        "description": "Attaches custom properties to an account, supporting both single and bulk updates.",
        "tags": ["Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddAccountPropertiesRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account properties added",
            "content": {
              "application/json": { "schema": { "type": "object" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/api/integrations/track": {
      "post": {
        "operationId": "bulkTrackEvents",
        "summary": "Bulk track events",
        "description": "Sends multiple events in a single request for third-party integrations.",
        "tags": ["Events"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkTrackRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Events tracked",
            "content": {
              "application/json": { "schema": { "type": "object" } }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    },
    "/api/public/v0/auth_token": {
      "post": {
        "operationId": "getAuthToken",
        "summary": "Get authentication token",
        "description": "Generates an authentication token for user deletion operations. Requires Basic Auth with app_id and api_key.",
        "tags": ["Auth"],
        "security": [
          { "basicAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Auth token generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "auth_token": { "type": "string", "description": "Bearer token for deletion API" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "appId": {
        "type": "apiKey",
        "in": "header",
        "name": "app_id",
        "description": "Heap application ID included in request body as app_id field"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic Auth with app_id as username and api_key as password"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "Error message" }
        }
      },
      "TrackEventRequest": {
        "type": "object",
        "required": ["app_id", "event"],
        "properties": {
          "app_id": { "type": "string", "description": "Heap application ID" },
          "event": { "type": "string", "maxLength": 1024, "description": "Event name" },
          "identity": { "type": "string", "maxLength": 255, "description": "User identity string (use identity or user_id, not both)" },
          "user_id": { "type": "string", "description": "Numeric user ID (0 to 2^53-1)" },
          "session_id": { "type": "string", "description": "Optional session identifier" },
          "properties": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Custom event properties (keys/values max 1024 chars)"
          },
          "timestamp": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp" },
          "idempotency_key": { "type": "string", "description": "Key to prevent duplicate events" }
        }
      },
      "IdentifyUserRequest": {
        "type": "object",
        "required": ["app_id", "user_id", "identity"],
        "properties": {
          "app_id": { "type": "string", "description": "Heap application ID" },
          "user_id": { "type": "string", "description": "Numeric user ID (0 to 2^53-1)" },
          "identity": { "type": "string", "maxLength": 255, "description": "Known user identity" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "AddUserPropertiesRequest": {
        "type": "object",
        "required": ["app_id", "identity", "properties"],
        "properties": {
          "app_id": { "type": "string" },
          "identity": { "type": "string", "maxLength": 255, "description": "User identity" },
          "properties": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "Properties to add (keys/values max 1024 chars)"
          }
        }
      },
      "AddAccountPropertiesRequest": {
        "type": "object",
        "required": ["app_id"],
        "properties": {
          "app_id": { "type": "integer", "description": "Heap application ID" },
          "account_id": { "type": "string", "description": "Account identifier (for single update)" },
          "properties": {
            "type": "object",
            "additionalProperties": true,
            "description": "Properties for single account"
          },
          "accounts": {
            "type": "array",
            "description": "Array of accounts for bulk update",
            "items": {
              "type": "object",
              "properties": {
                "account_id": { "type": "string" },
                "properties": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "BulkTrackRequest": {
        "type": "object",
        "required": ["app_id", "library", "events"],
        "properties": {
          "app_id": { "type": "string" },
          "library": { "type": "string", "description": "Integration source name (e.g., 'Salesforce')" },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["identity", "event"],
              "properties": {
                "identity": { "type": "string" },
                "event": { "type": "string" },
                "properties": { "type": "object", "additionalProperties": true },
                "timestamp": { "type": "string", "format": "date-time" },
                "idempotency_key": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}