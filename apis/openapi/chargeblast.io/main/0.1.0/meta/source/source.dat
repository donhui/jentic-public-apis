{
  "openapi": "3.0.3",
  "info": {
    "title": "Chargeblast API",
    "description": "Chargeblast is a chargeback alert tool that notifies merchants whenever a dispute is initiated to help avoid chargebacks. The API provides endpoints for managing alerts, orders, merchants, enrollment, deflections, and credit requests.",
    "version": "0.1.0",
    "x-jentic-source-url": "https://docs.chargeblast.com/openapi.json"
  },
  "servers": [
    {
      "url": "https://api.chargeblast.com",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {"name": "Alerts", "description": "Manage chargeback alerts"},
    {"name": "Orders", "description": "Manage orders"},
    {"name": "Sync Data", "description": "Upload orders and IP data"},
    {"name": "Enrollment", "description": "Manage merchant enrollment"},
    {"name": "Credit Requests", "description": "Manage credit requests for rejected alerts"},
    {"name": "Deflections", "description": "Deflection logs"}
  ],
  "paths": {
    "/api/v3/deflections/logs": {
      "get": {
        "operationId": "deflection-logs",
        "summary": "Fetch Deflection Logs",
        "description": "Get a list of all look up requests.",
        "tags": ["Deflections"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {"type": "integer", "format": "int64", "nullable": true},
            "description": "The starting page of the request. Default value of 0."
          },
          {
            "name": "per",
            "in": "query",
            "schema": {"type": "integer", "format": "int64", "nullable": true},
            "description": "How many objects to request per page. Default value of 10."
          },
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/ClarityLogBody"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ClarityLogResponse"}
              }
            }
          }
        }
      }
    },
    "/api/v2/track": {
      "post": {
        "operationId": "track",
        "summary": "Upload IP Data",
        "description": "Upload IP data for integration purposes.",
        "tags": ["Sync Data"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/TrackPayload"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"type": "integer", "format": "int64"}
              }
            }
          }
        }
      }
    },
    "/api/v2/orders/{id}": {
      "get": {
        "operationId": "getOrder",
        "summary": "Fetch Order",
        "description": "Retrieve a specific order from your account with receipt information.",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {"type": "string"}
          },
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/GetOrder"}
              }
            }
          }
        }
      }
    },
    "/api/v2/orders": {
      "get": {
        "operationId": "listOrders",
        "summary": "Fetch Orders",
        "description": "Retrieve all orders from your account (paginated, receipt info omitted).",
        "tags": ["Orders"],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {"type": "integer", "format": "int64", "nullable": true},
            "description": "The starting page. Default: 0."
          },
          {
            "name": "per",
            "in": "query",
            "schema": {"type": "integer", "format": "int64", "nullable": true},
            "description": "Objects per page. Default: 10."
          },
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/APIOrdersResponse"}
              }
            }
          }
        }
      }
    },
    "/api/v2/orders/upload": {
      "post": {
        "operationId": "orders-upload",
        "summary": "Upload Orders",
        "description": "Upload orders (amounts in cents). Rate limit: 100 requests/10 seconds.",
        "tags": ["Sync Data"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/OrderUploadBody"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/OrderUploadResponse"}
              }
            }
          }
        }
      }
    },
    "/api/alerts": {
      "get": {
        "operationId": "listAlertsV1",
        "summary": "Fetch Alerts (v1)",
        "description": "Get all alerts from your account.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          },
          {
            "name": "merchant_id",
            "in": "query",
            "schema": {"type": "string", "nullable": true}
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/ExportAlert"}
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/alerts": {
      "get": {
        "operationId": "listAlertsV2",
        "summary": "Fetch Alerts (v2)",
        "description": "Get paginated alerts with optional filtering.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "schema": {"type": "string", "nullable": true},
            "description": "Alert types: RDR, CDRN, Ethoca, TC40, SAFE"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {"type": "integer", "format": "int64", "nullable": true}
          },
          {
            "name": "per",
            "in": "query",
            "schema": {"type": "integer", "format": "int64", "nullable": true}
          },
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ExportAPIAlertsResponse"}
              }
            }
          }
        }
      }
    },
    "/api/alert/{id}": {
      "get": {
        "operationId": "getAlertV1",
        "summary": "Fetch an Alert (v1)",
        "description": "Retrieve a specific alert.",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          },
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ExportAlert"}
              }
            }
          }
        }
      }
    },
    "/api/v2/alert/{id}": {
      "get": {
        "operationId": "getAlertV2",
        "summary": "Fetch an Alert (v2)",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          },
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/ExportAPIAlertResponse"}
              }
            }
          }
        }
      }
    },
    "/api/alerts/update/{id}": {
      "post": {
        "operationId": "updateAlertV1",
        "summary": "Update Alert (v1)",
        "description": "Update alert state (action within 24 hours recommended; auto-declines after 72 hours).",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          },
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/AlertUpdateBodyOpenAPI"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"type": "integer", "format": "int64"}
              }
            }
          }
        }
      }
    },
    "/api/v2/alerts/update/{id}": {
      "post": {
        "operationId": "updateAlertV2",
        "summary": "Update Alert (v2)",
        "tags": ["Alerts"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          },
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {"type": "string"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/AlertUpdateBodyOpenAPI"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"type": "integer", "format": "int64"}
              }
            }
          }
        }
      }
    },
    "/api/v2/credit-request/create": {
      "post": {
        "operationId": "createCreditRequest",
        "summary": "Create Credit Request",
        "description": "Create a credit request for rejected alerts (fails if credit already exists).",
        "tags": ["Credit Requests"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/RefundRequestBody"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"type": "integer", "format": "int64"}
              }
            }
          }
        }
      }
    },
    "/api/v2/merchants": {
      "get": {
        "operationId": "listMerchants",
        "summary": "Fetch Merchants",
        "description": "Get paginated merchants from account.",
        "tags": ["Enrollment"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          },
          {
            "name": "page",
            "in": "query",
            "schema": {"type": "integer", "format": "int64", "nullable": true},
            "description": "Starting page. Default: 1."
          },
          {
            "name": "per",
            "in": "query",
            "schema": {"type": "integer", "format": "int64", "nullable": true},
            "description": "Per page. Default: 10."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/EmbedMerchantResponseDTO"}
              }
            }
          }
        }
      }
    },
    "/api/merchant": {
      "get": {
        "operationId": "getMerchant",
        "summary": "Fetch Merchant",
        "description": "Get an individual merchant.",
        "tags": ["Enrollment"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          },
          {
            "name": "merchant_id",
            "in": "query",
            "schema": {"type": "string", "nullable": true}
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/PayshieldRetailerDTO"}
              }
            }
          }
        }
      }
    },
    "/api/descriptors": {
      "get": {
        "operationId": "listDescriptors",
        "summary": "Fetch Descriptors",
        "description": "Fetch all descriptors for merchants.",
        "tags": ["Enrollment"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"$ref": "#/components/schemas/EmbedDescriptorsResponseDTO"}
              }
            }
          }
        }
      }
    },
    "/api/enroll_merchant": {
      "post": {
        "operationId": "enrollMerchant",
        "summary": "Enroll Merchant",
        "description": "Enroll merchant in alert program (auto-generates merchant if none specified).",
        "tags": ["Enrollment"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          },
          {
            "name": "merchant_id",
            "in": "query",
            "schema": {"type": "string", "nullable": true}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/EmbedEnrollmentBody"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"type": "integer", "format": "int64"}
              }
            }
          }
        }
      }
    },
    "/api/unenroll": {
      "post": {
        "operationId": "unenrollMerchant",
        "summary": "Unenroll Merchant",
        "description": "Unenroll descriptor (Ethoca: 48hrs, RDR: ~2 weeks, CDRN: ~24hrs confirmation).",
        "tags": ["Enrollment"],
        "parameters": [
          {
            "name": "X-API-Key",
            "required": true,
            "in": "header",
            "schema": {"type": "string"},
            "description": "Your API key."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/UnenrollmentBody"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {"type": "integer", "format": "int64"}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "ClarityLogBody": {
        "type": "object",
        "properties": {
          "filter": {"$ref": "#/components/schemas/ClarityLogBodyFilter"}
        }
      },
      "ClarityLogBodyFilter": {
        "type": "object",
        "properties": {
          "startDate": {"type": "string", "nullable": true, "description": "ISO8601 format"},
          "endDate": {"type": "string", "nullable": true, "description": "ISO8601 format"},
          "gateway": {"type": "string", "nullable": true},
          "status": {"type": "string", "nullable": true}
        }
      },
      "ClarityLogResponse": {
        "type": "object",
        "required": ["logs", "page", "per", "total"],
        "properties": {
          "logs": {"type": "array", "items": {"$ref": "#/components/schemas/ClarityLog"}},
          "total": {"type": "integer", "format": "int64"},
          "page": {"type": "integer", "format": "int64"},
          "per": {"type": "integer", "format": "int64"}
        }
      },
      "ClarityLog": {
        "type": "object",
        "required": ["request", "response"],
        "properties": {
          "request": {"$ref": "#/components/schemas/ClarityLogRequest"},
          "response": {"$ref": "#/components/schemas/ClarityLogResponseData"}
        }
      },
      "ClarityLogRequest": {
        "type": "object",
        "properties": {
          "arn": {"type": "string", "nullable": true},
          "descriptor": {"type": "string", "nullable": true},
          "transactionDate": {"type": "string", "nullable": true},
          "amount": {"type": "number", "format": "double", "nullable": true},
          "currency": {"type": "string", "nullable": true},
          "bin": {"type": "string", "nullable": true},
          "last4": {"type": "string", "nullable": true},
          "type": {"$ref": "#/components/schemas/ClarityType"}
        }
      },
      "ClarityLogResponseData": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {"$ref": "#/components/schemas/ClarityStatus"},
          "hasDeflectElements": {"type": "boolean", "nullable": true},
          "deflectElementsMissing": {"type": "string", "nullable": true},
          "chargeId": {"type": "string", "nullable": true},
          "gateway": {"type": "string", "nullable": true}
        }
      },
      "ClarityType": {"type": "string", "enum": ["OI", "Clarity"]},
      "ClarityStatus": {"type": "string", "enum": ["Matched", "Unmatched", "Error"]},
      "TrackPayload": {
        "type": "object",
        "required": ["email", "ip"],
        "properties": {
          "email": {"type": "string"},
          "ip": {"type": "string"}
        }
      },
      "OrderUploadBody": {
        "type": "object",
        "required": ["orders"],
        "properties": {
          "orders": {"type": "array", "items": {"$ref": "#/components/schemas/OrderUploadBodyOrder"}}
        }
      },
      "OrderUploadBodyOrder": {
        "type": "object",
        "required": ["amount", "currency", "id", "transactionDate"],
        "properties": {
          "id": {"type": "string", "description": "Internal order ID"},
          "amount": {"type": "integer", "format": "int64", "description": "Amount in cents"},
          "currency": {"type": "string", "description": "3-char ISO currency"},
          "transactionDate": {"type": "string", "description": "ISO8601 or yyyy-MM-dd format"},
          "ip": {"type": "string", "nullable": true},
          "authCode": {"type": "string", "nullable": true},
          "bin": {"type": "string", "nullable": true},
          "descriptor": {"type": "string", "nullable": true},
          "brand": {"type": "string", "nullable": true, "description": "visa, mastercard, amex, discover"},
          "gateway": {"type": "string", "nullable": true},
          "arn": {"type": "string", "nullable": true},
          "status": {"type": "string", "nullable": true, "description": "succeeded or failed"},
          "last4": {"type": "string", "nullable": true},
          "refunded": {"type": "boolean", "nullable": true},
          "network_id": {"type": "string", "nullable": true},
          "receipt": {"$ref": "#/components/schemas/Receipt"}
        }
      },
      "Receipt": {
        "type": "object",
        "properties": {
          "merchantInfo": {"$ref": "#/components/schemas/MerchantInfo"},
          "lineItems": {"type": "array", "items": {"$ref": "#/components/schemas/LineItem"}},
          "customerEmail": {"type": "string", "nullable": true},
          "customerPhone": {"type": "string", "nullable": true},
          "shippingAddress": {"$ref": "#/components/schemas/Address"},
          "billingAddress": {"$ref": "#/components/schemas/Address"},
          "name": {"$ref": "#/components/schemas/Name"}
        }
      },
      "LineItem": {
        "type": "object",
        "properties": {
          "productName": {"type": "string"},
          "productDescription": {"type": "string", "nullable": true},
          "currency": {"type": "string", "nullable": true},
          "quantity": {"type": "integer", "format": "int64", "nullable": true},
          "price": {"type": "integer", "format": "int64"}
        }
      },
      "MerchantInfo": {
        "type": "object",
        "properties": {
          "merchantReceiptContact": {"$ref": "#/components/schemas/MerchantContact"},
          "name": {"type": "string", "nullable": true},
          "description": {"type": "string", "nullable": true},
          "refundPolicyLink": {"type": "string", "nullable": true},
          "cancellationPolicyLink": {"type": "string", "nullable": true},
          "termsAndConditionsLink": {"type": "string", "nullable": true},
          "logoUrl": {"type": "string", "nullable": true}
        }
      },
      "MerchantContact": {
        "type": "object",
        "properties": {
          "phoneForReceipt": {"type": "string", "nullable": true},
          "emailForReceipt": {"type": "string", "nullable": true},
          "websiteForReceipt": {"type": "string", "nullable": true},
          "receiptAddress": {"$ref": "#/components/schemas/Address"}
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "line1": {"type": "string", "nullable": true},
          "line2": {"type": "string", "nullable": true},
          "city": {"type": "string", "nullable": true},
          "countrySubdivision": {"type": "string", "nullable": true},
          "postalCode": {"type": "string", "nullable": true},
          "country": {"type": "string", "nullable": true},
          "latitude": {"type": "string", "nullable": true},
          "longitude": {"type": "string", "nullable": true}
        }
      },
      "Name": {
        "type": "object",
        "properties": {
          "givenName": {"type": "string", "nullable": true},
          "familyName": {"type": "string", "nullable": true}
        }
      },
      "OrderUploadResponse": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {"type": "string"}
        }
      },
      "APIOrdersResponse": {
        "type": "object",
        "required": ["orders", "page", "per", "total"],
        "properties": {
          "total": {"type": "integer", "format": "int64"},
          "page": {"type": "integer", "format": "int64"},
          "per": {"type": "integer", "format": "int64"},
          "orders": {"type": "array", "items": {"type": "string"}}
        }
      },
      "GetOrder": {
        "type": "object",
        "required": ["compellingEvidence"],
        "properties": {
          "charge": {"$ref": "#/components/schemas/CommonChargeDirect"},
          "compellingEvidence": {"$ref": "#/components/schemas/CompellingEvidenceResult"},
          "digitalReceipt": {"$ref": "#/components/schemas/OITransactionResponse"}
        }
      },
      "CompellingEvidenceResult": {
        "type": "object",
        "required": ["isEligible"],
        "properties": {
          "isEligible": {"type": "boolean"},
          "explanation": {"type": "string", "nullable": true}
        }
      },
      "CommonChargeDirect": {
        "type": "object",
        "description": "Charge details object"
      },
      "OITransactionResponse": {
        "type": "object",
        "description": "Digital receipt transaction response"
      },
      "ExportAlert": {
        "type": "object",
        "description": "Alert export object"
      },
      "ExportAPIAlertResponse": {
        "type": "object",
        "required": ["alert"],
        "properties": {
          "alert": {"$ref": "#/components/schemas/ExportAlert"}
        }
      },
      "ExportAPIAlertsResponse": {
        "type": "object",
        "required": ["alerts", "page", "per", "total"],
        "properties": {
          "alerts": {"type": "array", "items": {"$ref": "#/components/schemas/ExportAlert"}},
          "page": {"type": "integer", "format": "int64"},
          "per": {"type": "integer", "format": "int64"},
          "total": {"type": "integer", "format": "int64"}
        }
      },
      "AlertUpdateBodyOpenAPI": {
        "type": "object",
        "required": ["result"],
        "properties": {
          "result": {"$ref": "#/components/schemas/AlertReasonCode"},
          "action_at_expiration": {"type": "boolean", "default": false}
        }
      },
      "AlertReasonCode": {
        "type": "string",
        "enum": ["Resolved", "ResolvedPartial", "ResolvedCancelled", "AccountCancelled", "CancellationProcessed", "UnmatchedGeneral", "UnmatchedCannotFindTransaction", "Duplicate", "MIDLost", "AlreadyRefunded", "AlreadyChargeback", "Ineligible", "TDS", "CannotCancel", "MatchedWillShip", "EscalateChargeback", "ContactedShipper", "WIP", "Error", "None", "NotMyDescriptor", "Unactioned"]
      },
      "RefundRequestBody": {
        "type": "object",
        "required": ["alert_id"],
        "properties": {
          "alert_id": {"type": "string"},
          "comments": {"type": "string", "nullable": true}
        }
      },
      "EmbedMerchantResponseDTO": {
        "type": "object",
        "required": ["merchants", "page", "total"],
        "properties": {
          "page": {"type": "integer", "format": "int64"},
          "total": {"type": "integer", "format": "int64"},
          "merchants": {"type": "array", "items": {"$ref": "#/components/schemas/MerchantListItem"}}
        }
      },
      "MerchantListItem": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {"type": "string", "description": "Chargeblast ID (e.g., cb_xxxxxxxxxxxxx)"},
          "name": {"type": "string", "description": "Merchant name or DBA"}
        }
      },
      "PayshieldRetailerDTO": {
        "type": "object",
        "required": ["sites", "user"],
        "properties": {
          "sites": {"type": "array", "items": {"$ref": "#/components/schemas/PayshieldSiteDTO"}},
          "name": {"type": "string", "nullable": true},
          "rcode": {"type": "string", "nullable": true},
          "user": {"type": "object"},
          "verifiRiskLevel": {"$ref": "#/components/schemas/VerifiRiskLevel"},
          "verifi_name": {"type": "string", "nullable": true},
          "source": {"$ref": "#/components/schemas/ProviderSource"},
          "merchant_id": {"type": "string", "nullable": true},
          "id": {"type": "string", "nullable": true}
        }
      },
      "PayshieldSiteDTO": {
        "type": "object",
        "required": ["descriptors", "name"],
        "properties": {
          "descriptors": {"type": "array", "items": {"$ref": "#/components/schemas/PayshieldDescriptorDTO"}},
          "id": {"type": "string", "nullable": true},
          "name": {"type": "string"}
        }
      },
      "PayshieldDescriptorDTO": {
        "type": "object",
        "required": ["details", "hasEmailSent", "status", "type"],
        "properties": {
          "id": {"type": "string", "nullable": true},
          "hasEmailSent": {"type": "boolean"},
          "type": {"$ref": "#/components/schemas/DescriptorType"},
          "bankMid": {"type": "string", "nullable": true},
          "status": {"$ref": "#/components/schemas/PayshieldDescriptorStatus"},
          "details": {"$ref": "#/components/schemas/DescriptorDetails"}
        }
      },
      "DescriptorType": {"type": "string", "enum": ["Ethoca", "CDRN", "RDR", "Discover", "AMEX", "JCB", "Unknown"]},
      "PayshieldDescriptorStatus": {"type": "string", "enum": ["Pending", "Enrolled", "Disabled", "Surpressed", "Processing", "Rejected", "InReview"]},
      "DescriptorDetails": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"type": "string"}
        }
      },
      "VerifiRiskLevel": {"type": "string", "enum": ["High", "Medium", "Low"]},
      "ProviderSource": {"type": "string", "enum": ["Banks", "Ethoca", "Verifi"]},
      "EmbedDescriptorsResponseDTO": {
        "type": "object",
        "required": ["descriptors"],
        "properties": {
          "descriptors": {"type": "array", "items": {"$ref": "#/components/schemas/PayshieldDescriptorDTO"}}
        }
      },
      "EmbedEnrollmentBody": {
        "type": "object",
        "required": ["requestData", "type"],
        "properties": {
          "type": {"$ref": "#/components/schemas/DescriptorType"},
          "requestData": {"$ref": "#/components/schemas/DescriptorRequestBody"},
          "merchantId": {"type": "string", "nullable": true}
        }
      },
      "DescriptorRequestBody": {
        "type": "object",
        "properties": {
          "type": {"type": "string", "nullable": true},
          "dbaName": {"type": "string", "nullable": true},
          "legalName": {"type": "string", "nullable": true},
          "mcc": {"type": "string", "nullable": true},
          "streetAddress": {"type": "string", "nullable": true},
          "city": {"type": "string", "nullable": true},
          "state": {"type": "string", "nullable": true},
          "zip": {"type": "string", "nullable": true},
          "country": {"type": "string", "nullable": true},
          "amexDescriptor": {"type": "string", "nullable": true},
          "amexSe": {"type": "string", "nullable": true},
          "discoverSe": {"type": "string", "nullable": true},
          "processor": {"type": "string", "nullable": true},
          "caids": {"type": "array", "items": {"type": "string"}, "nullable": true},
          "arns": {"type": "array", "items": {"type": "string"}, "nullable": true},
          "selectedAlerts": {"type": "array", "items": {"type": "string"}, "nullable": true},
          "ruleset": {"type": "string", "nullable": true},
          "descriptors": {"type": "array", "items": {"type": "string"}, "nullable": true},
          "bins": {"type": "array", "items": {"type": "string"}, "nullable": true}
        }
      },
      "UnenrollmentBody": {
        "type": "object",
        "required": ["descriptor_id"],
        "properties": {
          "descriptor_id": {"type": "string"}
        }
      }
    }
  }
}