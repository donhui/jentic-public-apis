  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Pass your API key as a Bearer token."
      }
    },
    "schemas": {
      "Customer": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "company": {
            "type": "string"
          },
          "phonenumber": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateCustomerRequest": {
        "type": "object",
        "required": [
          "company"
        ],
        "properties": {
          "company": {
            "type": "string",
            "description": "Company name"
          },
          "vat": {
            "type": "string",
            "description": "VAT number"
          },
          "phonenumber": {
            "type": "string",
            "description": "Phone number"
          }
