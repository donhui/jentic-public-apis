    "/appointment/{appointment_id}/{appointment_type}": {
      "post": {
        "tags": [
          "appointment"
        ],
        "summary": "Pull forward quotes into appointment",
        "description": "Pull Quotes & Change Appointment Type",
        "operationId": "pullQuotes",
        "parameters": [
          {
            "name": "appointment_id",
            "in": "path",
            "description": "Vendo Appointment ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "appointment_type",
            "in": "path",
            "description": "Expected Vendo Appointment Type",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "sales",
                "change_order",
                "second_measure"
              ]
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "quote_ids"
                ],
                "type": "object",
                "properties": {
                  "quote_ids": {
                    "uniqueItems": true,
                    "type": "array",
                    "description": "Vendo Quote IDs",
                    "example": [
                      12344,
                      12345
                    ],
                    "items": {
                      "minimum": 1,
                      "type": "integer",
                      "description": "Vendo Quote ID"
                    }
                  }
                },
                "description": "Quote IDs to pull into Appointment"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "pulled_quotes": {
                      "type": "array",
                      "description": "Pulled Quotes",
                      "items": {
                        "type": "object",
                        "properties": {
                          "quote_id": {
                            "type": "integer",
                            "description": "Vendo Quote ID",
                            "example": 12344
                          },
                          "new_quote_id": {
                            "type": "integer",
                            "description": "New Vendo Quote ID",
                            "example": 12346
                          }
                        }
                      }
                    },
                    "not_pulled_quotes": {
                      "type": "array",
                      "description": "Not Pulled Quotes",
                      "items": {
                        "type": "object",
                        "properties": {
                          "quote_id": {
                            "type": "integer",
                            "description": "Vendo Quote ID",
                            "example": 12345
                          },
                          "error": {
                            "type": "string",
                            "description": "Error Message",
                            "example": "Only one contracted quote can be pulled"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable Content"
          }
        },
        "security": [
          {
            "BasicAuth": []
          },
          {
            "BearerAuth": []
          }
        ]
      }
    },
