            "example": "55947"
          },
          "country": {
            "type": "string",
            "description": "Office Country",
            "example": "US"
          },
          "timezone": {
            "type": "string",
            "description": "Office Timezone"
          },
          "sub_domain": {
            "type": "string",
            "description": "Office Sub Domain"
          },
          "status": {
            "type": "string",
            "description": "Office Status",
            "example": "active"
          }
        }
      }
