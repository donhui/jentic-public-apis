      "Appointment": {
        "required": [
          "customer",
          "duration",
          "house",
          "schedule_time"
        ],
        "type": "object",
        "properties": {
          "schedule_time": {
            "type": "string",
            "description": "Appointment Starts At (ISO Date)",
            "format": "date-time"
          },
          "duration": {
            "type": "string",
            "description": "Appointment Duration (30m, 1h, 1h30m, 2h, 3h)",
            "example": "30m",
            "enum": [
              "30m",
              "1h",
              "1h30m",
              "2h",
              "3h"
            ]
          },
          "notes": {
            "maxLength": 1000,
            "type": "string",
            "description": "Appointment Notes",
            "example": "Any notes",
            "default": "null"
          },
          "products_interests": {
            "type": "array",
            "description": "Appointment Products Interests",
            "example": [
              "Windows",
              "Doors"
            ],
            "items": {
              "maxLength": 50,
              "minLength": 1,
              "type": "string",
              "description": "Appointment Products Interest"
            }
          },
          "office": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "description": "Vendo Office Identification(e.g 45442)",
                "example": 45442
              },
              "external_id": {
                "maxLength": 255,
                "minLength": 1,
                "type": "string",
                "description": "External Office Identification(e.g ext45442)",
                "example": "ext45442",
                "default": "null"
              }
            },
            "description": "Office to which this appointment belongs to"
          },
          "customer": {
            "required": [
              "first_name",
              "last_name"
            ],
            "type": "object",
            "properties": {
              "first_name": {
                "type": "string",
                "description": "Customer First Name",
                "example": "John"
              },
              "last_name": {
                "type": "string",
                "description": "Customer Last Name",
                "example": "Doe"
              },
              "phone_number": {
                "maxLength": 10,
                "minLength": 10,
                "pattern": "^\\d{10}$",
                "type": "string",
                "description": "Customer Phone Number must have 10 digits",
                "example": "2999999999",
                "default": "null"
              },
              "email": {
                "maxLength": 255,
                "minLength": 3,
                "type": "string",
                "description": "Customer Primary Email",
                "format": "email",
                "example": "john.doe@gmail.com",
                "default": "null"
              },
              "additional_phone_numbers": {
                "type": "array",
                "description": "Customer Additional Phone Numbers Array of Data",
                "example": [
                  {
                    "phone_number": "2888888888",
                    "tag": "mobile"
                  },
                  {
                    "phone_number": "2777777777",
                    "tag": "mobile"
                  }
                ],
                "items": {
                  "type": "object",
                  "properties": {
                    "phone_number": {
                      "maxLength": 10,
                      "minLength": 10,
                      "pattern": "^\\d{10}$",
                      "type": "string",
                      "description": "Customer Additional Phone Number must have 10 digits",
                      "example": "2888888888"
                    },
                    "tag": {
                      "type": "string",
                      "description": "Customer Additional Phone Number `primary` OR `mobile`",
                      "enum": [
                        "primary",
                        "mobile"
                      ]
                    }
                  }
                }
              },
              "additional_emails": {
                "type": "array",
                "description": "Customer Additional Emails Array of Data",
                "example": [
                  {
                    "email": "john.doe001@gmail.com",
                    "tag": null
                  },
                  {
                    "email": "john.doe002@gmail.com",
                    "tag": null
                  }
                ],
                "items": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "maxLength": 255,
                      "minLength": 3,
                      "type": "string",
                      "description": "Customer Additional Email",
                      "format": "email"
                    },
                    "tag": {
                      "type": "string",
                      "description": "Customer Additional Email Tag `primary` OR null",
                      "enum": [
                        "primary"
                      ]
                    }
                  }
                }
              }
            },
            "description": "Customer Object of Data"
          },
          "second_customer": {
            "required": [
              "first_name",
              "last_name"
            ],
            "type": "object",
            "properties": {
              "first_name": {
                "type": "string",
                "description": "Second Customer First Name",
                "example": "Janice"
              },
              "last_name": {
                "type": "string",
                "description": "Second Customer Last Name",
                "example": "Doe"
              },
              "phone_number": {
                "maxLength": 10,
                "minLength": 10,
                "pattern": "^\\d{10}$",
                "type": "string",
                "description": "Second Customer Phone Number must have 10 digits",
                "example": "2999999998",
                "default": "null"
              },
              "email": {
                "maxLength": 255,
                "minLength": 3,
                "type": "string",
                "description": "Second Customer Email",
                "format": "email",
                "example": "janice.doe@gmail.com",
                "default": "null"
              },
              "additional_phone_numbers": {
                "type": "array",
                "description": "Second Customer Additional Phone Numbers Array of Data",
                "example": [
                  {
                    "phone_number": "2988888887",
                    "tag": "mobile"
                  },
                  {
                    "phone_number": "2977777776",
                    "tag": "mobile"
                  }
                ],
                "items": {
                  "type": "object",
                  "properties": {
                    "phone_number": {
                      "maxLength": 10,
                      "minLength": 10,
                      "pattern": "^\\d{10}$",
                      "type": "string",
                      "description": "Second Customer Additional Phone Number must have\n10 digits",
                      "example": "2888888888"
                    },
                    "tag": {
                      "type": "string",
                      "description": "Second Customer Additional Phone Number `primary`\nor `mobile`",
                      "default": "mobile",
                      "enum": [
                        "primary",
                        "mobile"
                      ]
                    }
                  }
                }
              },
              "additional_emails": {
                "type": "array",
                "description": "Second Customer Additional Emails Array of Data",
                "example": [
                  {
                    "email": "janice.doe001@gmail.com",
                    "tag": null
                  },
                  {
                    "email": "janice.doe002@gmail.com",
                    "tag": null
                  }
                ],
                "items": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "maxLength": 255,
                      "minLength": 3,
                      "type": "string",
                      "description": "Second Customer Additional Email",
                      "format": "email"
                    },
                    "tag": {
                      "type": "string",
                      "description": "Second Customer Additional Email Tag `primary` or\nnull",
                      "default": "null",
                      "enum": [
                        "primary"
                      ]
                    }
                  }
                }
              }
            },
            "description": "Second Customer Object of Data"
          },
          "house": {
            "required": [
              "address1",
              "city",
              "country",
              "postal_code",
              "state"
            ],
            "type": "object",
            "properties": {
              "address1": {
                "maxLength": 255,
                "type": "string",
                "description": "Job Site Address",
                "example": "3691 Highway 50 E"
              },
              "address2": {
                "maxLength": 255,
                "type": "string",
                "description": "Job Site Second Address",
                "example": "",
                "default": "null"
              },
              "city": {
                "maxLength": 255,
                "type": "string",
                "description": "Job Site City",
                "example": "Salida"
              },
              "state": {
                "maxLength": 2,
                "type": "string",
                "description": "Job Site State - 2 letters",
                "example": "CO"
              },
              "country": {
                "maxLength": 2,
                "type": "string",
                "description": "Job Site Country - 2 letters",
                "example": "US"
              },
              "postal_code": {
                "maxLength": 60,
                "type": "string",
                "description": "Job Site Postal Code",
                "example": "81201"
              }
            },
            "description": "Job Site Address Object of Data"
          },
          "second_house": {
            "required": [
              "address1",
              "city",
              "country",
              "postal_code",
              "state"
            ],
            "type": "object",
            "properties": {
              "address1": {
                "maxLength": 255,
                "type": "string",
                "description": "Mailing Address",
                "example": "1200 N 1st St"
              },
              "address2": {
                "maxLength": 255,
                "type": "string",
                "description": "Mailing Second Address",
                "example": "",
                "default": "null"
              },
              "city": {
                "maxLength": 255,
                "type": "string",
                "description": "Mailing City",
                "example": "La Crescent"
              },
              "state": {
                "maxLength": 2,
                "type": "string",
                "description": "Mailing State",
                "example": "MN"
              },
              "country": {
                "maxLength": 2,
                "type": "string",
                "description": "Mailing Country",
                "example": "US"
              },
              "postal_code": {
                "maxLength": 60,
                "type": "string",
                "description": "Mailing Postal Code",
                "example": "55947"
              }
            },
            "description": "Mailing Address Object of Data"
          }
        },
        "xml": {
          "name": "Appointment"
        }
      },
