    "/bearer-auth/login": {
      "post": {
        "tags": [
          "bearer-auth"
        ],
        "summary": "Login with api keys",
        "description": "Login to obtain access/refresh tokens by keys to use them with\nBearer token authentication.",
        "operationId": "bearerAuthLogin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "private_key",
                  "public_key"
                ],
                "type": "object",
                "properties": {
                  "public_key": {
                    "type": "string",
                    "description": "Public key (8 characters)"
                  },
                  "private_key": {
                    "type": "string",
                    "description": "Private key (32 characters)"
                  }
                },
                "description": "Api Keys"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BearerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Content"
          }
        }
      }
    },
    "/bearer-auth/refresh": {
      "post": {
        "tags": [
          "bearer-auth"
        ],
        "summary": "Refresh access token using refresh token",
        "description": "Use this method to obtain new access token by refresh token",
        "operationId": "bearerAuthRefresh",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "public_key",
                  "refresh_token"
                ],
                "type": "object",
                "properties": {
                  "public_key": {
                    "type": "string",
                    "description": "Public key (8 characters)"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token obtained by bearer-auth/login api"
                  }
                },
                "description": "Refresh token"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BearerResponse"
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable Content"
          }
        }
      }
    },
