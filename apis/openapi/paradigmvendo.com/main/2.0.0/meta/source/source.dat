      "ImportQuoteResponse": {
        "type": "object",
        "properties": {
          "appointment": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 28
              },
              "name": {
                "type": "string",
                "example": "Jane Doe"
              },
              "schedule_time": {
                "type": "string",
                "description": "Appointment Starts At (ISO Date)",
                "format": "date-time"
              },
              "canceled_previous": {
                "type": "boolean"
              },
              "customer": {
                "type": "object",
                "properties": {
                  "first_name": {
                    "type": "string",
                    "description": "Customer First Name",
                    "example": "John"
                  },
                  "last_name": {
                    "type": "string",
                    "description": "Customer Last Name",
                    "example": "Doe"
                  },
                  "phone_number": {
                    "maxLength": 10,
                    "minLength": 10,
                    "pattern": "^\\d{10}$",
                    "type": "string",
                    "description": "Customer Phone Number must have 10 digits",
                    "example": "2999999999",
                    "default": "null"
                  },
                  "email": {
                    "maxLength": 255,
                    "minLength": 3,
                    "type": "string",
                    "description": "Customer Primary Email",
                    "format": "email",
                    "example": "john.doe@gmail.com",
                    "default": "null"
                  },
                  "additional_phone_numbers": {
                    "type": "array",
                    "description": "Customer Additional Phone Numbers Array of Data",
                    "example": [
                      {
                        "phone_number": "2888888888",
                        "tag": "mobile"
                      },
                      {
                        "phone_number": "2777777777",
                        "tag": "mobile"
                      }
                    ],
                    "items": {
                      "type": "object",
                      "properties": {
                        "phone_number": {
                          "maxLength": 10,
                          "minLength": 10,
                          "pattern": "^\\d{10}$",
                          "type": "string",
                          "description": "Customer Additional Phone Number must have 10\ndigits",
                          "example": "2888888888"
                        },
                        "tag": {
                          "type": "string",
                          "description": "Customer Additional Phone Number `primary` OR\n`mobile`",
                          "enum": [
                            "primary",
                            "mobile"
                          ]
                        }
                      }
                    }
                  },
                  "additional_emails": {
                    "type": "array",
                    "description": "Customer Additional Emails Array of Data",
                    "example": [
                      {
                        "email": "john.doe001@gmail.com",
                        "tag": null
                      },
                      {
                        "email": "john.doe002@gmail.com",
                        "tag": null
                      }
                    ],
                    "items": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "maxLength": 255,
                          "minLength": 3,
                          "type": "string",
                          "description": "Customer Additional Email",
                          "format": "email"
                        },
                        "tag": {
                          "type": "string",
                          "description": "Customer Additional Email Tag `primary` OR null",
                          "enum": [
                            "primary"
                          ]
                        }
                      }
                    }
                  }
                },
                "description": "Customer Object of Data"
              },
              "second_customer": {
                "type": "object",
                "properties": {
                  "first_name": {
                    "type": "string",
                    "description": "Second Customer First Name",
                    "example": "Janice"
                  },
                  "last_name": {
                    "type": "string",
                    "description": "Second Customer Last Name",
                    "example": "Doe"
                  },
                  "phone_number": {
                    "maxLength": 10,
                    "minLength": 10,
                    "pattern": "^\\d{10}$",
                    "type": "string",
                    "description": "Second Customer Phone Number must have 10 digits",
                    "example": "2999999998",
                    "default": "null"
                  },
                  "email": {
                    "maxLength": 255,
                    "minLength": 3,
                    "type": "string",
                    "description": "Second Customer Email",
                    "format": "email",
                    "example": "janice.doe@gmail.com",
                    "default": "null"
                  },
                  "additional_phone_numbers": {
                    "type": "array",
                    "description": "Second Customer Additional Phone Numbers Array of Data",
                    "example": [
                      {
                        "phone_number": "2988888887",
                        "tag": "mobile"
                      },
                      {
                        "phone_number": "2977777776",
                        "tag": "mobile"
                      }
                    ],
                    "items": {
                      "type": "object",
                      "properties": {
                        "phone_number": {
                          "maxLength": 10,
                          "minLength": 10,
                          "pattern": "^\\d{10}$",
                          "type": "string",
                          "description": "Second Customer Additional Phone Number must\nhave 10 digits",
                          "example": "2888888888"
                        },
                        "tag": {
                          "type": "string",
                          "description": "Second Customer Additional Phone Number `primary`\nor `mobile`",
                          "default": "mobile",
                          "enum": [
                            "primary",
                            "mobile"
                          ]
                        }
                      }
                    }
                  },
                  "additional_emails": {
                    "type": "array",
                    "description": "Second Customer Additional Emails Array of Data",
                    "example": [
                      {
                        "email": "janice.doe001@gmail.com",
                        "tag": null
                      },
                      {
                        "email": "janice.doe002@gmail.com",
                        "tag": null
                      }
                    ],
                    "items": {
                      "type": "object",
                      "properties": {
                        "email": {
                          "maxLength": 255,
                          "minLength": 3,
                          "type": "string",
                          "description": "Second Customer Additional Email",
                          "format": "email"
                        },
                        "tag": {
                          "type": "string",
                          "description": "Second Customer Additional Email Tag `primary`\nor null",
                          "default": "null",
                          "enum": [
                            "primary"
                          ]
                        }
                      }
                    }
                  }
                },
                "description": "Second Customer Object of Data"
              },
              "house": {
                "required": [
                  "address1",
                  "city",
                  "country",
                  "postal_code",
                  "state"
                ],
                "type": "object",
                "properties": {
                  "address1": {
                    "maxLength": 255,
                    "type": "string",
                    "description": "Job Site Address",
                    "example": "3691 Highway 50 E"
                  },
                  "address2": {
                    "maxLength": 255,
                    "type": "string",
                    "description": "Job Site Second Address",
                    "example": "",
                    "default": "null"
                  },
                  "city": {
                    "maxLength": 255,
                    "type": "string",
                    "description": "Job Site City",
                    "example": "Salida"
                  },
                  "state": {
                    "maxLength": 2,
                    "type": "string",
                    "description": "Job Site State - 2 letters",
                    "example": "CO"
                  },
                  "country": {
                    "maxLength": 2,
                    "type": "string",
                    "description": "Job Site Country - 2 letters",
                    "example": "US"
                  },
                  "postal_code": {
                    "maxLength": 60,
                    "type": "string",
                    "description": "Job Site Postal Code",
                    "example": "81201"
                  }
                },
                "description": "Job Site Address Object of Data"
              },
              "second_house": {
                "required": [
                  "address1",
                  "city",
                  "country",
                  "postal_code",
                  "state"
                ],
                "type": "object",
                "properties": {
                  "address1": {
                    "maxLength": 255,
                    "type": "string",
                    "description": "Mailing Address",
                    "example": "1200 N 1st St"
                  },
                  "address2": {
                    "maxLength": 255,
                    "type": "string",
                    "description": "Mailing Second Address",
                    "example": "",
                    "default": "null"
                  },
                  "city": {
                    "maxLength": 255,
                    "type": "string",
                    "description": "Mailing City",
                    "example": "La Crescent"
                  },
                  "state": {
                    "maxLength": 2,
                    "type": "string",
                    "description": "Mailing State",
                    "example": "MN"
                  },
                  "country": {
                    "maxLength": 2,
                    "type": "string",
                    "description": "Mailing Country",
                    "example": "US"
                  },
                  "postal_code": {
                    "maxLength": 60,
                    "type": "string",
                    "description": "Mailing Postal Code",
                    "example": "55947"
                  }
                },
                "description": "Mailing Address Object of Data"
              }
            }
          },
          "quote": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "quote_number": {
                "type": "number"
              },
              "reassigned": {
                "type": "boolean"
              }
            }
          },
          "line_items": {
            "type": "object",
            "properties": {
              "imported": {
                "type": "number"
              },
              "created": {
                "type": "number"
              }
            }
          }
        }
      },
