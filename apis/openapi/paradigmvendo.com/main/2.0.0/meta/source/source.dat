      "CreateUserModel": {
        "required": [
          "email",
          "first_name",
          "last_name",
          "phone",
          "role_name",
          "status"
        ],
        "type": "object",
        "properties": {
          "office_id": {
            "type": "number",
            "description": "User Office ID must be the same as configured in Vendo. Whether\nthis field is required depends on the API Keys and how they were configured\nin the Vendo.",
            "example": 2882
          },
          "office_name": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "User Office Name must be the same as configured in Vendo. Whether this field is required depends on the API Keys and how they were configured in the Vendo, also it is required if office_id is omitted",
            "example": "Office Name"
          },
          "assigned_offices": {
            "uniqueItems": true,
            "type": "array",
            "description": "User assigned offices",
            "example": [
              {
                "office_id": 12344
              },
              {
                "office_name": "Office Name"
              }
            ],
            "items": {
              "type": "object",
              "properties": {
                "office_id": {
                  "type": "number",
                  "description": "User Office ID"
                },
                "office_name": {
                  "maxLength": 255,
                  "minLength": 1,
                  "type": "string",
                  "description": "User Office Name",
                  "example": "Office Name"
                }
              },
              "description": "User assigned office (ID or Name)"
            }
          },
          "role_name": {
            "maxLength": 255,
            "type": "string",
            "description": "User Role Name must be the same as configured in the Vendo",
            "example": "Sales Manager"
          },
          "email": {
            "maxLength": 255,
            "minLength": 3,
            "type": "string",
            "description": "User Email - will be used for authorization",
            "format": "email",
            "example": "vendo.seller@gmail.com"
          },
          "phone": {
            "maxLength": 10,
            "minLength": 10,
            "pattern": "^\\d{10}$",
            "type": "string",
            "description": "User Phone must have 10 digits",
            "example": "2999999999",
            "default": "null"
          },
          "first_name": {
            "type": "string",
            "description": "User First Name",
            "example": "John"
          },
          "last_name": {
            "type": "string",
            "description": "User Last Name",
            "example": "Doe"
          },
          "employee_id": {
            "maxLength": 255,
            "type": "string",
            "description": "Employee ID",
            "example": null,
            "default": "null"
          },
          "external_id": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "External User Identification",
            "example": null,
            "default": "null"
          },
          "crm_integration_hash": {
            "maxLength": 255,
            "type": "string",
            "description": "User CRM Integration Hash",
            "example": null,
            "default": "null"
          },
          "avatar": {
            "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
            "type": "string",
            "description": "Avatar",
            "format": "byte",
            "example": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==",
            "default": "null"
          },
          "status": {
            "type": "string",
            "description": "User Status",
            "default": "active",
            "enum": [
              "active",
              "inactive"
            ]
          },
          "wcp_settings": {
            "$ref": "#/components/schemas/UserWcpSettings"
          }
        },
        "description": "Create User Model",
        "xml": {
          "name": "Create Users"
        }
      },
