    "/import-quote": {
      "post": {
        "tags": [
          "import-quote"
        ],
        "summary": "Parsing WCP Quote.",
        "description": "Creating/Updating Vendo Appointment with status 'Pending', which includes a specified quote.",
        "operationId": "importWcpQuote",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "quote",
                  "sellers",
                  "settings"
                ],
                "type": "object",
                "properties": {
                  "sellers": {
                    "$ref": "#/components/schemas/Sellers"
                  },
                  "quote": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "WCP Quote ID",
                        "format": "uuid",
                        "example": "cb9debcd-ae22-4506-a544-ce60aa83cc8b"
                      },
                      "number": {
                        "type": "integer",
                        "description": "WCP Quote Number(e.g 45442)",
                        "example": 45442
                      }
                    },
                    "description": "WCP Quote Searching Conditions"
                  },
                  "appointment": {
                    "$ref": "#/components/schemas/Appointment"
                  },
                  "settings": {
                    "type": "object",
                    "properties": {
                      "apply_adders": {
                        "type": "boolean",
                        "description": "Need To Apply Default Adders To Quote",
                        "example": true,
                        "default": false
                      },
                      "replace_quote_if_exist": {
                        "type": "boolean",
                        "description": "Need To Replace Quote If That Is Exists",
                        "example": true,
                        "default": false
                      }
                    },
                    "description": "Parsing WCP Quote Settings"
                  }
                },
                "description": "Customer Object of Data"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportQuoteResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable Content"
          }
        },
        "security": [
          {
            "BasicAuth": []
          },
          {
            "BearerAuth": []
          }
        ]
      }
    },
