  "components": {
    "schemas": {
      "AnyValue": {
        "type": "object",
        "description": "Can be anything: string, number, array, object, etc."
      },
      "SellerEmail": {
        "maxLength": 255,
        "minLength": 3,
        "type": "string",
        "description": "Seller Email For Who Appointment Will Be Assigned",
        "format": "email",
        "example": "vendo.seller@gmail.com",
        "xml": {
          "name": "SellerEmail"
        }
      },
      "Sellers": {
        "required": [
          "owner_email"
        ],
        "type": "object",
        "properties": {
          "owner_email": {
            "maxLength": 255,
            "minLength": 3,
            "type": "string",
            "description": "Seller Email For Who Appointment Will Be Assigned",
            "format": "email",
            "example": "vendo.seller@gmail.com"
          },
          "assign_to_email": {
            "maxLength": 255,
            "minLength": 3,
            "type": "string",
            "description": "Seller Email For Who Appointment Will Be Assigned",
            "format": "email",
            "example": "vendo.seller@gmail.com"
          }
        },
        "description": "Seller Emails",
        "xml": {
          "name": "Sellers"
        }
      },
      "CreateOrganizationModel": {
        "required": [
          "name",
          "street_address",
          "city",
          "state",
          "postal_code",
          "country",
          "timezone",
          "quote_project_name",
          "status",
          "currency",
          "crm",
          "payment",
          "measurement_system",
          "voice_recording",
          "auth",
          "email_service"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "Organization Name",
            "example": "Acme Corporation"
          },
          "street_address": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "Organization Street Address",
            "example": "123 Main Street"
          },
          "city": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "Organization City",
            "example": "New York"
          },
          "state": {
            "maxLength": 10,
            "minLength": 1,
            "type": "string",
            "description": "Organization State",
            "example": "NY"
          },
          "postal_code": {
            "maxLength": 60,
            "minLength": 1,
            "type": "string",
            "description": "Organization Postal Code",
            "example": "10001"
          },
          "country": {
            "maxLength": 40,
            "minLength": 1,
            "type": "string",
            "description": "Organization Country",
            "example": "US"
          },
          "timezone": {
            "maxLength": 100,
            "type": "string",
            "description": "Organization Timezone",
            "example": "US/Eastern"
          },
          "sub_domain": {
            "maxLength": 30,
            "type": "string",
            "description": "Organization Sub Domain (optional)",
            "example": "acme",
            "default": "null"
          },
          "quote_project_name": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string",
            "description": "Custom Project Name",
            "example": "My Project"
          },
          "logo_file": {
            "type": "string",
            "description": "Logo file as base64 or default image will be used",
            "example": "data:image/png;base64,iVBORw0KGgoAAAANS...",
            "default": "null"
          },
          "status": {
            "type": "string",
            "description": "Organization Status",
            "default": "active",
            "enum": [
              "active",
              "inactive"
            ]
          },
          "is_real": {
            "type": "boolean",
            "description": "Is this a real organization",
            "default": true
          },
          "currency": {
            "type": "array",
            "minItems": 1,
            "description": "List of currency codes",
            "items": {
              "type": "string",
              "enum": [
                "usd",
                "cad",
                "eur"
              ],
              "example": "usd"
            }
          },
          "feedback_configuration": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "description": "Feedback configuration status",
                "enum": [
                  "active",
                  "inactive"
                ]
              },
              "display_frequency": {
                "type": "integer",
                "minimum": 1,
                "default": 1,
                "description": "Display frequency"
              },
              "max_per_month": {
                "type": "integer",
                "minimum": 1,
                "default": 1,
                "description": "Maximum feedback requests per month"
              }
            }
          },
          "crm": {
            "type": "array",
            "description": "CRM integrations",
            "items": {
              "type": "object",
              "required": [
                "crm"
              ],
              "properties": {
                "crm": {
                  "type": "string",
                  "description": "CRM integration hash",
                  "example": "salesforce"
                },
                "active": {
                  "type": "boolean",
                  "default": true,
                  "description": "Is this CRM integration active"
                }
              }
            }
          },
          "payment": {
            "type": "array",
            "description": "Payment integrations",
            "items": {
              "type": "object",
              "required": [
                "payment"
              ],
              "properties": {
                "payment": {
                  "type": "string",
                  "description": "Payment integration hash",
                  "example": "paradigm_payments"
                },
                "active": {
                  "type": "boolean",
                  "default": true,
                  "description": "Is this payment integration active"
                }
              }
            }
          },
          "measurement_system": {
            "type": "array",
            "description": "Measurement system integrations",
            "items": {
              "type": "object",
              "required": [
                "measurement_system"
              ],
              "properties": {
                "measurement_system": {
                  "type": "string",
                  "description": "Measurement system hash",
                  "example": "eagle_view"
                },
                "active": {
                  "type": "boolean",
                  "default": true,
                  "description": "Is this measurement system active"
                }
              }
            }
          },
          "voice_recording": {
            "type": "array",
            "minItems": 1,
            "description": "Voice recording integrations (at least one must be active)",
            "items": {
              "type": "object",
              "required": [
                "voice_recording"
              ],
              "properties": {
                "voice_recording": {
                  "type": "string",
                  "description": "Voice recording service",
                  "example": "rilla"
                },
                "active": {
                  "type": "boolean",
                  "default": true,
                  "description": "Is this voice recording service active"
                }
              }
            }
          },
          "auth": {
            "type": "array",
            "minItems": 1,
            "description": "Authentication methods (at least one must be active)",
            "items": {
              "type": "object",
              "required": [
                "auth"
              ],
              "properties": {
                "auth": {
                  "type": "string",
                  "description": "Authentication method",
                  "example": "password"
                },
                "active": {
                  "type": "boolean",
                  "default": true,
                  "description": "Is this authentication method active"
                }
              }
            }
          },
          "email_service": {
            "type": "array",
            "description": "Email service integrations (at least one must be active)",
            "items": {
              "type": "object",
              "required": [
                "email_service"
              ],
              "properties": {
                "email_service": {
                  "type": "string",
                  "description": "Email service provider",
                  "example": "default"
                },
                "active": {
                  "type": "boolean",
                  "default": true,
                  "description": "Is this email service active"
                }
              }
            }
          },
          "organization_features": {
            "type": "array",
            "description": "Organization features (optional)",
            "items": {
              "type": "object",
              "properties": {
                "feature_id": {
                  "oneOf": [
                    {
                      "type": "integer",
                      "minimum": 1
                    },
                    {
                      "type": "string"
                    }
                  ],
                  "description": "Feature ID or hash",
                  "example": 1
                }
              }
            }
          }
        },
        "description": "Create Organization Model",
        "xml": {
          "name": "Create Organization"
        }
      },
      "CreateOfficeModel": {
        "required": [
          "city",
          "country",
          "name",
          "postal_code",
          "state",
          "status",
          "street_address",
          "timezone",
          "website"
        ],
        "type": "object",
        "properties": {
          "external_id": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "External Office Identification(e.g ext45442)",
            "example": "ext45442",
            "default": "null"
          },
          "name": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "Office Name - must be unique",
            "example": "Office Name"
          },
          "contact_email": {
            "maxLength": 255,
            "minLength": 3,
            "type": "string",
            "description": "Office Contact Email - using in paperwork",
            "format": "email",
            "example": "vendo.office@gmail.com"
          },
          "website": {
            "maxLength": 200,
            "minLength": 5,
            "type": "string",
            "description": "Office Website URL - `http://site.com`  or `https://site.com`",
            "format": "uri",
            "example": "https://site.com",
            "default": "null"
          },
          "fax": {
            "maxLength": 10,
            "minLength": 10,
            "pattern": "^\\d{10}$",
            "type": "string",
            "description": "Office Fax must have 10 digits",
            "example": "2888888888",
            "default": "null"
          },
          "phone_number": {
            "maxLength": 10,
            "minLength": 10,
            "pattern": "^\\d{10}$",
            "type": "string",
            "description": "Office Phone must have 10 digits",
            "format": "",
            "example": "2999999999",
            "default": "null"
          },
          "street_address": {
            "maxLength": 255,
            "type": "string",
            "description": "Office Street Address",
            "example": "3691 Highway 50 E"
          },
          "city": {
            "maxLength": 255,
            "type": "string",
            "description": "Office City",
            "example": "Salida"
          },
          "state": {
            "maxLength": 2,
            "type": "string",
            "description": "Office State - 2 letters",
            "example": "CO"
          },
          "country": {
            "maxLength": 2,
            "type": "string",
            "description": "Office Country - 2 letters",
            "example": "US"
          },
          "postal_code": {
            "maxLength": 60,
            "type": "string",
            "description": "Office Postal Code",
            "example": "81201"
          },
          "timezone": {
            "maxLength": 100,
            "type": "string",
            "description": "Office Timezone",
            "example": "US/Central",
            "default": "US/Central"
          },
          "sub_domain": {
            "maxLength": 30,
            "type": "string",
            "description": "Office Sub Domain",
            "example": "test",
            "default": "null"
          },
          "status": {
            "type": "string",
            "description": "Office Status",
            "default": "active",
            "enum": [
              "active",
              "inactive"
            ]
          }
        },
        "description": "Create Office Model",
        "xml": {
          "name": "Create Offices"
        }
      },
