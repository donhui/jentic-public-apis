{
  "openapi": "3.0.3",
  "info": {
    "title": "Vendo Public APIs",
    "description": "This is documentation for Vendo Public API.\n#### How to implement this on your side:\n1. Include in your environment configuration or another safe place following data fields:\n   1. Base URL (e.g https://<domain>.com) \n   2. Base Public Path (e.g /v2) \n   3. Public API Key (8 characters) \n   4. Private API Key (32 characters)\n2. Build API URL - https://<domain>.com/v2/<route> \n3. Authorization\n   1. Basic Authorization Header \n      1. JavaScript > Authorization: \"Basic\" + new Buffer(publicKey + \":\" + privateKey).toString(\"base64\") \n      2. PHP > Authorization: \"Basic\" . base64_encode($publicKey . \":\" . $privateKey) \n      3. C# > Authorization: \"Basic\" + Convert.ToBase64String(ASCIIEncoding.ASCII.GetBytes(publicKey + \":\" + privateKey)) \n      4. Postman > Authorization: Username = Public Key and Password = Private Key\n   2. Bearer Authorization Header (e.g Bearer IUzI1NiIsInR5cCI6Ik...)\n      1. Authorization: \"Bearer {{access token}}\"\n",
    "version": "2.0.0",
    "x-jentic-source-url": "https://api.paradigmvendo.com/v2/docs/#/"
  },
  "tags": [
    {
      "name": "appointment",
      "description": "Operations about Appointment"
    },
    {
      "name": "crm",
      "description": "CRM Integration"
    },
    {
      "name": "quote",
      "description": "Operations about Quote"
    },
    {
      "name": "import-quote",
      "description": "Parsing WCP Quote"
    },
    {
      "name": "organization",
      "description": "Operations about Organization"
    },
    {
      "name": "office",
      "description": "Operations about Office"
    },
    {
      "name": "user",
      "description": "Operations about User"
    },
    {
      "name": "adder",
      "description": "Operations about Adder"
    },
    {
      "name": "bearer-auth",
      "description": "Operations about Authentication with Bearer token"
    },
    {
      "name": "wcp-url",
      "description": "Operations about WCP Url"
    }
  ],
  "paths": {
    "/appointment/{appointment_id}": {
      "get": {
        "tags": [
          "appointment"
        ],
        "summary": "Get Appointment by ID",
        "operationId": "getAppointment",
        "parameters": [
          {
            "name": "appointment_id",
            "in": "path",
            "description": "Numeric ID or Integration ID (number or string) of the appointment\nto get.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "answers_as_object",
            "in": "query",
            "description": "Boolean flag to receive answers as object or array of objects.",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "quote_numbers_as_object",
            "in": "query",
            "description": "Boolean flag to receive quote numbers as object or array of objects.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "order_numbers_as_object",
            "in": "query",
            "description": "Boolean flag to receive order numbers as object or array of objects.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "client_numbers_as_object",
            "in": "query",
            "description": "Boolean flag to receive client numbers as object or array of objects.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetAppointmentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable Content"
          }
        },
        "security": [
          {
            "BasicAuth": []
          },
          {
            "BearerAuth": []
          }
        ]
      }
    },
