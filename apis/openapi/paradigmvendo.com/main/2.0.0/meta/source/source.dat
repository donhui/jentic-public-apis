      "Conditions": {
        "type": "object",
        "properties": {
          "conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "filterOperator": {
                  "type": "string",
                  "description": "Filter Operator",
                  "example": "not_equals",
                  "enum": [
                    "equals",
                    "not_equals",
                    "is_less_than",
                    "is_greater_than",
                    "any_of",
                    "none_of",
                    "from_at",
                    "to_at",
                    "contains",
                    "not_contains",
                    "contains_any_of",
                    "not_contains_any_of",
                    "is_empty",
                    "is_not_empty",
                    "starts_with",
                    "ends_with"
                  ]
                },
                "entity": {
                  "type": "string",
                  "description": "Entity",
                  "example": "catalog"
                },
                "field": {
                  "type": "string",
                  "description": "Field",
                  "example": "formula_1"
                },
                "value": {
                  "$ref": "#/components/schemas/AnyValue"
                }
              }
            }
          },
          "logicOperator": {
            "type": "string",
            "description": "Logic Operator",
            "example": "and",
            "enum": [
              "and",
              "or"
            ]
          }
        }
      },
