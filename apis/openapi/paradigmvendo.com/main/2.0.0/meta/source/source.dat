    "/appointment/{appointment_id}/status": {
      "post": {
        "tags": [
          "appointment"
        ],
        "summary": "Change Appointment Status",
        "operationId": "saveAppointmentStatus",
        "parameters": [
          {
            "name": "appointment_id",
            "in": "path",
            "description": "Numeric ID of the appointment.",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": [
                  "result_name",
                  "result_reason_name",
                  "status"
                ],
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "description": "Appointment Status",
                    "default": "won",
                    "enum": [
                      "won",
                      "lost",
                      "pending",
                      "canceled"
                    ]
                  },
                  "result_name": {
                    "type": "string",
                    "description": "Result Name"
                  },
                  "result_reason_name": {
                    "type": "string",
                    "description": "Result Name"
                  },
                  "selected_quote_id": {
                    "type": "integer",
                    "description": "Selected Quote ID"
                  },
                  "enable_events": {
                    "type": "boolean",
                    "description": "Need To Trigger Events/Webhooks",
                    "example": false,
                    "default": false
                  }
                },
                "description": "Appointment status, result, reason, selected quote to change"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "appointment_id": {
                      "type": "number",
                      "description": "Numeric ID of the appointment."
                    },
                    "status": {
                      "type": "string",
                      "description": "Appointment Status"
                    },
                    "result_type": {
                      "type": "string",
                      "description": "Appointment Result Type - won/lost/pending"
                    },
                    "result_name": {
                      "type": "string",
                      "description": "Result Name"
                    },
                    "result_reason_name": {
                      "type": "string",
                      "description": "Result Reason Name"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "422": {
            "description": "Unprocessable Content"
          }
        },
        "security": [
          {
            "BasicAuth": []
          },
          {
            "BearerAuth": []
          }
        ]
      }
    },
