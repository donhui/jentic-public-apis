      "UserWcpSettings": {
        "required": [
          "client_ids",
          "group_id"
        ],
        "type": "object",
        "properties": {
          "group_id": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "WCP Ground Integration ID",
            "example": "system_admin"
          },
          "brand_ids": {
            "uniqueItems": true,
            "type": "array",
            "description": "WCP Brand IDs",
            "example": [
              "2",
              "8"
            ],
            "items": {
              "maxLength": 255,
              "minLength": 1,
              "type": "string",
              "description": "WCP Brand ID"
            }
          },
          "client_ids": {
            "uniqueItems": true,
            "type": "array",
            "description": "WCP Client Integration IDs",
            "example": [
              "SL43454",
              "Play1232221"
            ],
            "items": {
              "maxLength": 255,
              "minLength": 1,
              "type": "string",
              "description": "WCP Client Integration ID"
            }
          },
          "default_client_id": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "Default WCP Client Integration ID",
            "example": "Play1232221"
          },
          "is_active": {
            "type": "boolean",
            "description": "WCP User Is Active",
            "example": true,
            "default": true
          },
          "use_manufacturer": {
            "type": "boolean",
            "description": "Use User Manufacturer Setting",
            "example": false,
            "default": false
          },
          "use_user_context": {
            "type": "boolean",
            "description": "Use User Context Setting",
            "example": false,
            "default": false
          }
        },
        "description": "Build WCP Users on the fly",
        "xml": {
          "name": "User WCP Settings"
        }
      },
      "UserSearchCondition": {
        "required": [
          "email",
          "external_id"
        ],
        "type": "object",
        "properties": {
          "email": {
            "maxLength": 255,
            "minLength": 3,
            "type": "string",
            "description": "User Email - that already used in account",
            "format": "email",
            "example": "vendo.seller2@gmail.com"
          },
          "external_id": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string",
            "description": "External User Identification",
            "example": "45442",
            "default": "null"
          }
        },
        "description": "UserSearchCondition",
        "xml": {
          "name": "UserSearchCondition"
        }
      },
      "IntegrationAppointment": {
        "required": [
          "customer",
          "house",
          "schedule_time"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Appointment Type (sales, change_order, second_measure)",
            "enum": [
              "sales",
              "change_order",
              "second_measure"
            ],
            "default": "sales"
          },
          "schedule_time": {
            "type": "string",
            "description": "Appointment Starts At (ISO Date)",
            "format": "date-time",
            "example": "{isoNow+10minutes}"
          },
          "duration": {
            "type": "string",
            "description": "Appointment Duration (30m, 1h, 1h30m, 2h, 3h)",
            "example": "1h",
            "enum": [
              "30m",
              "1h",
              "1h30m",
              "2h",
              "3h"
            ]
          },
          "notes": {
            "maxLength": 1000,
            "type": "string",
            "description": "Appointment Notes",
            "example": "Any notes",
            "default": "null"
          },
          "products_interests": {
