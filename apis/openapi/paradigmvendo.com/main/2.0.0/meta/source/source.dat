          }
        }
      },
      "UnauthorizedError": {
        "description": "Unauthorized",
        "content": {
          "text/html": {
            "schema": {
              "type": "string"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BasicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Use Public Key as Username and Private Key as Password.\n"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Use received \"access_token\" from /bearer-auth/login or /bearer-auth/refresh as Value.\n"
      }
    }
