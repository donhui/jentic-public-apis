            "type": "string",
            "description": "The date and time when the reminder is set for the event.",
            "format": "date-time"
          },
          "IsReminderSet": {
            "type": "boolean",
            "description": "Indicates whether a reminder is set for the event."
          },
          "EventSubtype": {
            "type": "string",
            "description": "The subtype of the event."
          },
          "IsRecurrence2Exclusion": {
            "type": "boolean",
            "description": "Indicates whether the event is an exclusion from a series of\nrecurring events."
          },
          "Recurrence2PatternText": {
            "type": "string",
            "description": "The text of the recurrence pattern."
          },
          "Recurrence2PatternVersion": {
            "type": "string",
            "description": "The version of the recurrence pattern."
          },
          "IsRecurrence2": {
            "type": "boolean",
            "description": "Indicates whether the event is a recurring event (version 2)."
          },
          "IsRecurrence2Exception": {
            "type": "boolean",
            "description": "Indicates whether the event is an exception to a series of\nrecurring events (version 2)."
          },
          "Recurrence2PatternStartDate": {
            "type": "string",
            "description": "The start date of the recurrence pattern (version 2).",
            "format": "date"
          },
          "Recurrence2PatternTimeZone": {
            "type": "string",
            "description": "The time zone of the recurrence pattern (version 2)."
          }
        }
      },
