    "/users": {
      "get": {
        "tags": [
          "user"
        ],
        "summary": "Get users based on office_id with pagination",
        "description": "This endpoint retrieves user for a specific office with pagination.",
        "operationId": "getUsers",
        "parameters": [
          {
            "name": "office_id",
            "in": "query",
            "description": "The Vendo ID of the office to retrieve users for.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "office_external_id",
            "in": "query",
            "description": "The external ID of the office to retrieve users for.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The page number to retrieve. Defaults to 1.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "The number of items per page. Defaults to 10.",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/UserResponse"
                      }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "current_page": {
                          "type": "integer"
                        },
                        "total_pages": {
                          "type": "integer"
                        },
                        "per_page": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not Found"
          }
        },
        "security": [
          {
            "BasicAuth": []
          },
          {
            "BearerAuth": []
          }
        ]
      }
    },
