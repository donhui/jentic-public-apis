            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "phone": {
                      "$ref": "#/components/schemas/ErrorDescription"
                    },
                    "code": {
                      "$ref": "#/components/schemas/ErrorDescription"
                    },
                    "password": {
                      "$ref": "#/components/schemas/ErrorDescription"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "\u041d\u0435 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u043e\u0432\u0430\u043d",
            "content": {
              "application/json": {
                "schema": {
