          "403": {
            "description": "\u041d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e \u043f\u0440\u0430\u0432",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetailError"
                }
              }
            }
          },
          "404": {
            "description": "\u041d\u0435 \u043d\u0430\u0439\u0434\u0435\u043d\u0430 \u043a\u0430\u043a\u0430\u044f \u043b\u0438\u0431\u043e \u0438\u0437 \u0441\u0443\u0449\u043d\u043e\u0441\u0442\u0435\u0439",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetailError"
                }
              }
            }
          }
        },
        "tags": [
          "auth"
