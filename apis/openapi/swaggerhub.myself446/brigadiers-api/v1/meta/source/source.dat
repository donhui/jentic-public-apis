    "/sign_in_second_step/": {
      "post": {
        "operationId": "sign_in_second_step_create",
        "description": "\u0423\u0441\u043f\u0435\u0448\u043d\u043e \u043f\u0440\u043e\u0439\u0434\u0435\u043d \u0432\u0442\u043e\u0440\u043e\u0439 \u044d\u0442\u0430\u043f \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u0438",
        "responses": {
          "200": {
            "description": "OK",
