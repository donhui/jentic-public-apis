              {
                "$ref": "#/components/schemas/CashBackTransactionPaymentRequest"
              }
            ],
            "nullable": true
          },
          "isAccountable": {
            "title": "\u041d\u0430\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u0435 \u0443\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u043f\u0440\u0438 \u043f\u043e\u0434\u0441\u0447\u0435\u0442\u0435 \u0431\u0430\u043b\u0430\u043d\u0441\u0430",
            "type": "boolean"
          },
          "createdAt": {
            "title": "\u0421\u043e\u0437\u0434\u0430\u043d\u0438\u0435 \u043d\u0430\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u044f",
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "updatedAt": {
            "title": "\u041e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0435 \u043d\u0430\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u044f",
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "brigadier": {
            "title": "\u0411\u0440\u0438\u0433\u0430\u0434\u0438\u0440",
            "type": "integer",
            "nullable": true
          },
          "isRead": {
            "title": "\u041f\u0440\u043e\u0447\u0438\u0442\u0430\u043d\u043e",
            "type": "boolean"
          }
        }
      },
      "CashBackTransactionOrder": {
