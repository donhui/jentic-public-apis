  "servers": [
    {
      "url": "https://brigade-sdvor-dev.itlabs.io/api/v1"
    }
  ],
  "components": {
    "requestBodies": {
      "WritableBrigadier": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/WritableBrigadier"
            }
          }
        },
        "required": true
      },
      "WritePaymentRequest": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/WritePaymentRequest"
            }
          }
        },
        "required": true
      }
    },
    "securitySchemes": {
      "JWT": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "\u0412\u0441\u0435 \u0437\u0430\u043f\u0440\u043e\u0441\u044b \u0434\u043e\u043b\u0436\u043d\u044b \u0432\u043a\u043b\u044e\u0447\u0430\u0442\u044c \u0432 \u0441\u0435\u0431\u044f \u0437\u0430\u0433\u043e\u043b\u043e\u0432\u043e\u043a \u0432\u0438\u0434\u0430 \"JWT \\<token\\>\""
      }
    },
    "schemas": {
      "BrigadierRegistrationState": {
        "type": "object",
        "properties": {
          "isBrigadierExists": {
            "type": "boolean",
            "description": "\u0422\u0430\u043a\u043e\u0439 \u0431\u0440\u0438\u0433\u0430\u0434\u0438\u0440 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442"
          },
          "isActive": {
            "type": "boolean",
            "description": "\u0411\u0440\u0438\u0433\u0430\u0434\u0438\u0440 \u0430\u043a\u0442\u0438\u0432\u0435\u043d"
          },
          "isBrigadierHasFullName": {
            "type": "boolean",
            "description": "\u0411\u0440\u0438\u0433\u0430\u0434\u0438\u0440 \u0438\u043c\u0435\u0435\u0442 \u0438\u043c\u044f \u0438\u043b\u0438 \u0444\u0430\u043c\u0438\u043b\u0438\u044e"
          },
          "isBrigadierRegistered": {
            "type": "boolean",
            "description": "\u0411\u0440\u0438\u0433\u0430\u0434\u0438\u0440 \u0437\u0430\u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0438\u0440\u043e\u0432\u0430\u043d \u0432 \u0441\u0435\u0440\u0432\u0438\u0441\u0435 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u0438"
          }
        }
      },
      "ReadableBrigadier": {
        "required": [
          "phone"
        ],
        "type": "object",
        "properties": {
          "id": {
            "title": "ID",
            "type": "integer",
            "readOnly": true
          },
          "phone": {
            "title": "Phone",
            "type": "string",
            "pattern": "^\\s*([\\+\\s]*7|7|8)[\\s|\\(|-]*[489][0-9]{2}[\\s|\\)|-]*[0-9]{3}[\\s\\-]?[0-9]{2}[\\s\\-]?[0-9]{2}\\s*$",
            "minLength": 1
          },
          "email": {
            "title": "Email",
            "type": "string",
            "maxLength": 255,
            "nullable": true
          },
          "lastName": {
            "title": "\u0424\u0430\u043c\u0438\u043b\u0438\u044f",
            "type": "string",
            "maxLength": 255,
            "nullable": true
          },
          "firstName": {
            "title": "\u0418\u043c\u044f",
            "type": "string",
            "maxLength": 255,
            "nullable": true
          },
          "total": {
            "type": "object",
            "readOnly": true,
            "properties": {
              "balance": {
                "description": "\u0411\u0430\u043b\u0430\u043d\u0441",
                "type": "number",
                "format": "float",
                "readOnly": true
              },
              "paidForAllTime": {
                "readOnly": true,
                "description": "\u0412\u044b\u043f\u043b\u0430\u0447\u0435\u043d\u043e \u0437\u0430 \u0432\u0441\u0451 \u0432\u0440\u0435\u043c\u044f",
                "type": "number",
                "format": "float"
              },
              "promoCodesCount": {
                "type": "integer",
                "readOnly": true,
                "description": "\u041f\u0440\u043e\u043c\u043e\u043a\u043e\u0434\u044b"
              },
              "newCharges": {
                "type": "integer",
                "readOnly": true,
                "description": "\u041d\u043e\u0432\u044b\u0435 \u043d\u0430\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u044f"
              },
              "accruedForAllTime": {
                "title": "accruedForAllTime",
                "type": "number",
                "format": "float",
                "readOnly": true,
                "description": "\u041d\u0430\u0447\u0438\u0441\u043b\u0435\u043d\u043e \u0437\u0430 \u0432\u0441\u0451 \u0432\u0440\u0435\u043c\u044f"
              },
              "totalOrders": {
                "description": "\u0417\u0430\u043a\u0430\u0437\u043e\u0432",
                "type": "integer",
                "readOnly": true
              },
              "newOrders": {
                "type": "integer",
                "readOnly": true,
                "description": "\u041d\u043e\u0432\u044b\u0445 \u0437\u0430\u043a\u0430\u0437\u043e\u0432"
              },
              "completedOrders": {
                "type": "integer",
                "readOnly": true,
                "description": "\u0417\u0430\u0432\u0435\u0440\u0448\u0435\u043d\u043e \u0437\u0430\u043a\u0430\u0437\u043e\u0432"
              }
            }
          }
        }
      },
      "WritableBrigadier": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "\u042d\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0430\u044f \u043f\u043e\u0447\u0442\u0430 \u0431\u0440\u0438\u0433\u0430\u0434\u0438\u0440\u0430"
          },
          "lastName": {
            "type": "string",
            "description": "\u0424\u0430\u043c\u0438\u043b\u0438\u044f"
          },
          "firstName": {
            "type": "string",
            "description": "\u0418\u043c\u044f"
          },
          "isTutorialPassed": {
            "type": "boolean",
            "description": "\u041f\u0440\u043e\u0439\u0434\u0435\u043d\u043e \u043b\u0438 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435",
            "default": false
          }
        }
      },
      "WriteBrigadierErrors": {
        "type": "object",
        "properties": {
          "errors": {
            "$ref": "#/components/schemas/ErrorDescription"
          },
          "email": {
            "$ref": "#/components/schemas/ErrorDescription"
          },
          "isTutorialPassed": {
            "$ref": "#/components/schemas/ErrorDescription"
          }
        }
      },
      "ReadPaymentRequest": {
        "required": [
          "amount"
        ],
        "type": "object",
        "properties": {
          "id": {
            "title": "ID",
            "type": "integer",
            "readOnly": true
          },
          "amount": {
            "title": "\u0421\u0443\u043c\u043c\u0430 \u043a \u0432\u044b\u043f\u043b\u0430\u0442\u0435",
            "type": "string",
            "format": "decimal"
          },
          "type": {
            "title": "\u0422\u0438\u043f \u0432\u044b\u043f\u043b\u0430\u0442\u044b",
            "type": "string",
            "enum": [
              "money",
              "bonus"
            ]
          },
          "status": {
            "title": "\u0421\u0442\u0430\u0442\u0443\u0441 \u0432\u044b\u043f\u043b\u0430\u0442\u044b",
            "type": "string",
            "enum": [
              "request",
              "approve"
            ]
          },
          "createdAt": {
            "title": "\u0414\u0430\u0442\u0430 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0437\u0430\u043f\u0440\u043e\u0441\u0430",
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "isAutomaticallyPaid": {
            "title": "\u0410\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438-\u0432\u044b\u043f\u043b\u0430\u0447\u0438\u0432\u0430\u0435\u043c\u044b\u0435 \u0437\u0430\u043f\u0440\u043e\u0441\u044b",
            "type": "boolean",
            "readOnly": true
          },
          "isPaidOff": {
            "title": "\u0412\u044b\u043f\u043b\u0430\u0447\u0435\u043d\u043e",
            "type": "boolean",
            "readOnly": true
          },
          "isRead": {
            "title": "\u041f\u0440\u043e\u0447\u0438\u0442\u0430\u043d\u043e",
            "type": "boolean"
          }
        }
      },
      "WritePaymentRequest": {
        "required": [
          "amount"
        ],
        "type": "object",
        "properties": {
          "id": {
            "title": "ID",
            "type": "integer",
            "readOnly": true
          },
          "type": {
            "title": "\u0422\u0438\u043f \u0432\u044b\u043f\u043b\u0430\u0442\u044b",
            "type": "string",
            "enum": [
              "money",
              "bonus"
            ]
          },
          "amount": {
            "title": "\u0421\u0443\u043c\u043c\u0430 \u043a \u0432\u044b\u043f\u043b\u0430\u0442\u0435",
            "type": "string",
            "format": "decimal"
          },
          "isRead": {
            "title": "\u041f\u0440\u043e\u0447\u0438\u0442\u0430\u043d\u043e",
            "type": "boolean",
            "default": true
          }
        }
      },
      "WritePaymentRequestErrors": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/ErrorDescription"
          },
          "amount": {
            "$ref": "#/components/schemas/ErrorDescription"
          },
          "errors": {
            "$ref": "#/components/schemas/ErrorDescription"
          }
        }
      },
      "CreatePromoCode": {
        "type": "object",
        "properties": {
          "description": {
            "title": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435",
            "type": "string"
          },
          "discount": {
            "title": "\u0421\u043a\u0438\u0434\u043a\u0430",
            "type": "integer"
          }
        }
      },
      "UpdatePromoCode": {
        "type": "object",
        "properties": {
          "description": {
            "title": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435",
            "type": "string"
          },
          "isActive": {
            "title": "\u041f\u0440\u043e\u043c\u043e \u043a\u043e\u0434 \u0430\u043a\u0442\u0438\u0432\u0435\u043d",
            "type": "boolean"
          }
        }
      },
      "ReadablePromoCode": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "title": "ID"
          },
          "code": {
            "type": "string",
            "title": "\u041a\u043e\u0434"
          },
          "isActive": {
            "type": "boolean",
            "title": "\u0410\u043a\u0442\u0438\u0432\u0435\u043d \u043b\u0438 \u043f\u0440\u043e\u043c\u043e\u043a\u043e\u0434"
          },
          "description": {
            "type": "string",
            "title": "\u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435",
            "maxLength": 255
          },
          "discount": {
            "type": "integer",
            "title": "\u0421\u043a\u0438\u0434\u043a\u0430"
          },
          "income": {
            "type": "integer",
            "title": "\u0414\u043e\u0445\u043e\u0434",
            "format": "float"
          },
          "transactions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "title": "\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0442\u0440\u0430\u043d\u0437\u0430\u043a\u0446\u0438\u0438"
                },
                "isAccountable": {
                  "type": "boolean",
                  "title": "\u0410\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u044c \u0442\u0440\u0430\u043d\u0437\u0430\u043a\u0446\u0438\u0438"
                },
                "amount": {
                  "type": "integer",
                  "title": "\u0421\u0443\u043c\u043c\u0430",
                  "format": "float"
                },
                "createdAt": {
                  "type": "string",
                  "format": "date-time",
                  "title": "\u0414\u0430\u0442\u0430 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0442\u0440\u0430\u043d\u0437\u0430\u043a\u0446\u0438\u0438"
                },
                "promoCode": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "title": "\u041a\u043e\u0434",
                      "example": [
                        "kt6qpfu",
                        "2jkafck"
                      ]
                    },
                    "discount": {
                      "type": "integer",
                      "format": "float",
                      "title": "\u0421\u043a\u0438\u0434\u043a\u0430 \u043d\u0430 \u043c\u043e\u043c\u0435\u043d\u0442 \u0442\u0440\u0430\u043d\u0437\u0430\u043a\u0446\u0438\u0438"
                    },
                    "cashBack": {
                      "type": "integer",
                      "format": "float",
                      "title": "\u041a\u0435\u0448 \u0431\u0435\u043a \u043d\u0430 \u043c\u043e\u043c\u0435\u043d\u0442 \u0442\u0440\u0430\u043d\u0437\u0430\u043a\u0446\u0438\u0438"
                    }
                  }
                },
                "order": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "integer",
                      "title": "\u0418\u0434\u0435\u043d\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0440 \u0437\u0430\u043a\u0430\u0437\u0430"
                    },
                    "number": {
                      "type": "string",
                      "title": "\u041f\u0443\u0431\u043b\u0438\u0447\u043d\u044b\u0439 \u043d\u043e\u043c\u0435\u0440 \u0437\u0430\u043a\u0430\u0437\u0430",
                      "example": [
                        "211218-4",
                        "241218-15"
                      ]
                    },
                    "sum": {
                      "type": "integer",
                      "title": "\u0421\u0443\u043c\u043c\u0430 \u043f\u043e \u0437\u0430\u043a\u0430\u0437\u0443"
                    },
                    "status": {
                      "type": "integer",
                      "title": "\u0421\u0442\u0430\u0442\u0443\u0441"
                    },
                    "statusText": {
                      "type": "string",
                      "title": "\u0421\u0442\u0430\u0442\u0443\u0441 \u0442\u0435\u043a\u0441\u0442\u043e\u043c",
                      "example": [
                        "\u041e\u0436\u0438\u0434\u0430\u0435\u0442 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438",
                        "\u0413\u043e\u0442\u043e\u0432 \u043a \u0432\u044b\u0434\u0430\u0447\u0435"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      },
      "UpdateCashBackTransaction": {
        "type": "object",
        "properties": {
          "isRead": {
            "title": "\u041f\u0440\u043e\u0447\u0438\u0442\u0430\u043d\u043e",
