{
    "openapi": "3.0.0",
    "info": {
        "description": "Апи сервиса Акций\n\nРО: Кривцова Юлия\n\nРазработчики:\nМаслов Максим, Марамыгин Алексей\n\nТестовые данные: Запускать локально после миграции для создания тестовых данных\nclass TestDevValues метод test_dev_values\n",
        "version": "2",
        "title": "Cервис акций",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/myself446/admin/2/swagger.json"
    },
    "externalDocs": {
        "description": "Схема данных",
        "url": "https://gl.sdvor.com/retail/PromotionsService/blob/development/%D0%A1%D1%85%D0%B5%D0%BC%D0%B0%20%D0%B4%D0%B0%D0%BD%D0%BD%D1%8B%D1%85.xlsx"
    },
    "tags": [
        {
            "name": "orgstructures",
            "description": "Оргструктура"
        },
        {
            "name": "promo_template",
            "description": "Шаблон акции"
        },
        {
            "name": "promotion_action",
            "description": "Акция"
        }
    ],
    "paths": {
        "/sync_orgstructures": {
            "post": {
                "tags": [
                    "orgstructures"
                ],
                "summary": "Обновить оргструктуры",
                "description": "Обновить оргструктуры по бизнесу. Даем новый актуальный список оргструктур. Старые которые не в списке, но в БД станут неактивными. (При создании акций будут 'скрыты' на фронте)",
                "operationId": "syncOrgstructures",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/sapToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "code": {
                                            "type": "string",
                                            "description": "значение кода оргструктуры",
                                            "example": "VKORG1000"
                                        },
                                        "business": {
                                            "type": "string",
                                            "description": "Тип Бизнеса:\n * `SDVR` - Строительный двор\n * `ENRG` - Эннергия\n",
                                            "example": "SDVR"
                                        },
                                        "name": {
                                            "type": "string",
                                            "example": "Сбытовая Тюмень"
                                        },
                                        "priority": {
                                            "type": "integer",
                                            "example": 100,
                                            "description": "К примеру - у бизнеса 1, у формата - 50, у города (сбытовой) - 100, Магазин - 150 и т.д. Нужны для расчета акций в корзине - чтобы сработало, нужно чтобы каждый приоритет оказался в оргструктуре корзины. (например Моки (50) + Тюмень (100) + Екатеринбург (100))"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Текст об успешном выполнении",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "apiVersion": {
                                            "type": "string",
                                            "example": "1.0"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "result": {
                                                    "type": "string",
                                                    "example": "success"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/OrgstructuresNoCorrectData"
                    }
                }
            }
        },
        "/get_orgstructure": {
            "post": {
                "tags": [
                    "orgstructures"
                ],
                "summary": "Получить оргструктуру",
                "description": "Получить оргструктуру",
                "operationId": "getOrgstructure",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/readOnlyToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "orgstructure_id": {
                                        "type": "string",
                                        "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0",
                                        "description": "ид оргструктуры(не обязательное поле)"
                                    },
                                    "id_business": {
                                        "type": "integer",
                                        "example": 1,
                                        "enum": [
                                            "1 СД",
                                            "2 Эннергия"
                                        ],
                                        "description": "Тип Бизнеса:\n * `1` - Строительный двор\n * `2` - Эннергиия\n"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Текст об успешном выполнении",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "apiVersion": {
                                            "type": "string",
                                            "example": "1.0"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "result": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object",
                                                        "properties": {
                                                            "is_active": {
                                                                "type": "boolean",
                                                                "example": true
                                                            },
                                                            "pk": {
                                                                "type": "string",
                                                                "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0",
                                                                "description": "id оргструктуры"
                                                            },
                                                            "code": {
                                                                "type": "string",
                                                                "example": "VKORG1000"
                                                            },
                                                            "name": {
                                                                "type": "string",
                                                                "example": "Сбытовая Тюмень"
                                                            },
                                                            "id_business": {
                                                                "type": "integer",
                                                                "example": 1
                                                            },
                                                            "priority": {
                                                                "type": "integer",
                                                                "example": 100
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/SampleError"
                    }
                }
            }
        },
        "/update_promo_template": {
            "post": {
                "tags": [
                    "promo_template"
                ],
                "summary": "Создать/обновить параметры шаблона акции",
                "description": "Создать/обновить параметры шаблона акции",
                "operationId": "updatePromoTemplate",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/editToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "id": {
                                        "type": "string",
                                        "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0",
                                        "description": "если не передаём параметр, то создаётся новый шаблон, иначе обновляем данные по указанному шаблону"
                                    },
                                    "id_business": {
                                        "type": "integer",
                                        "example": 1,
                                        "enum": [
                                            "1 СД",
                                            "2 Эннергия"
                                        ],
                                        "description": "Тип Бизнеса:\n * `1` - Строительный двор\n * `2` - Эннергия\n"
                                    },
                                    "id_currency": {
                                        "type": "integer",
                                        "example": 1,
                                        "enum": [
                                            "1 Рубль"
                                        ],
                                        "description": "Код Валюты:\n * `1` - Рубль\n"
                                    },
                                    "name": {
                                        "type": "string",
                                        "example": "Акция за каждые 2 000 и два мешка цемента второй в подарок"
                                    },
                                    "amount_activation": {
                                        "type": "number",
                                        "example": 2000,
                                        "description": "Сумма в чеке для срабатывания (например на 2000 из выбранной группы). 0 если сумма не важна"
                                    },
                                    "count_activation": {
                                        "type": "number",
                                        "example": 2,
                                        "description": "Количество в чеке для срабатывания (например на 2 из выбранной группы, в БЕИ ТОЛЬКО). 0 если кол-во не важно"
                                    },
                                    "count_use": {
                                        "type": "integer",
                                        "example": 0,
                                        "description": "Максимальное количество срабатывания акции в заказе. К примеру, акция за каждые 2000 купон на скидку в подарок, если будет 0, то дарим любое кол-во купонов, иначе только ограниченное кол-во по заказу кт указали 0 если кол-во не важно"
                                    },
                                    "prize_count": {
                                        "type": "integer",
                                        "example": 0,
                                        "description": "Максимальное количество призовых позиций. 0 Если все позиции дарим. (если меньше чем призов - на выбор) К примеру, хотим подарить только 3 подарка из 4-х"
                                    },
                                    "author": {
                                        "type": "string",
                                        "example": "pivanov"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Текст об успешном выполнении",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "apiVersion": {
                                            "type": "string",
                                            "example": "1.0"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "result": {
                                                    "type": "object",
                                                    "description": "вернётся вся структура шаблона как она записалась в базу"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/SampleError"
                    }
                }
            }
        },
        "/get_promo_templates": {
            "post": {
                "tags": [
                    "promo_template"
                ],
                "summary": "Получить шаблоны акции или указанную по ключу",
                "description": "Получить все шаблоны акции(товары, призы, места проведения) либо указанную по ключу",
                "operationId": "getPromoTemplates",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/readOnlyToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "list_id": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0",
                                            "description": "если не передаём параметр, то получим все шаблоны по указанному бизнесу"
                                        }
                                    },
                                    "id_business": {
                                        "type": "integer",
                                        "example": 1,
                                        "enum": [
                                            "1 СД",
                                            "2 Эннергия"
                                        ],
                                        "description": "Тип Бизнеса:\n * `1` - Строительный двор\n * `2` - Эннергиия\n"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Текст об успешном выполнении",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "apiVersion": {
                                            "type": "string",
                                            "example": "1.0"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "result": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/SampleError"
                    }
                }
            }
        },
        "/update_promo_conditions": {
            "post": {
                "tags": [
                    "promo_template"
                ],
                "summary": "Доп виды условий в шаблоне акции",
                "description": "Создать/обновить доп виды условий учавствующие в шаблоне              акции. Новый список, меняющий старый, если шаблон не использовался",
                "operationId": "updatePromoConditions",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/editToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "id_template": {
                                        "type": "string",
                                        "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0"
                                    },
                                    "conditions_codes": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "cond_code": {
                                                    "type": "string",
                                                    "example": "RR04",
                                                    "description": "Код, который будет игнорироваться при расчете (например ручная цена и акция не сработает по такой позиции)"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Текст об успешном выполнении",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "apiVersion": {
                                            "type": "string",
                                            "example": "1.0"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "result": {
                                                    "type": "object",
                                                    "description": "вернётся вся структура как она записалась в базу"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/SampleError"
                    }
                }
            }
        },
        "/update_promo_goods": {
            "post": {
                "tags": [
                    "promo_template"
                ],
                "summary": "Создать/обновить товары, для срабатывания шаблона акции. Если код товара задать '*' то будут использоваться все товары в шаблоне. Например 'При покупке от 10000, получи 2777 в подарок'",
                "description": "Создать/обновить товары в шаблоне акции. Новый список,     заменяющий старый, если шаблон не использовался",
                "operationId": "updatePromoGoods",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/editToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "id_template": {
                                        "type": "string",
                                        "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0"
                                    },
                                    "goods_codes": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "goods_code": {
                                                    "type": "string",
                                                    "example": "2777"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Текст об успешном выполнении",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "apiVersion": {
                                            "type": "string",
                                            "example": "1.0"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "result": {
                                                    "type": "object",
                                                    "description": "вернётся вся структура как она записалась в базу"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/SampleError"
                    }
                }
            }
        },
        "/update_promo_prize": {
            "post": {
                "tags": [
                    "promo_template"
                ],
                "summary": "Создать/обновить призы шаблона акции",
                "description": "Создать/обновить призы в шаблоне акции. Новый список, меняющий старый, если шаблон не использовался",
                "operationId": "updatePromoPrize",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/editToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "id_template": {
                                        "type": "string",
                                        "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0"
                                    },
                                    "prizes": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "id_type": {
                                                    "type": "integer",
                                                    "example": 1,
                                                    "enum": [
                                                        "1 Товар",
                                                        "2 Сертификат",
                                                        "3 Услуга"
                                                    ],
                                                    "description": "Тип приза:\n * `1` - Товар\n * `2` - Сертификат\n * `3` - Услуга\n"
                                                },
                                                "goods_code": {
                                                    "type": "string",
                                                    "example": "1596",
                                                    "description": "Код товара, который дарим. Только для id_type == Товар или Услуга"
                                                },
                                                "count": {
                                                    "type": "number",
                                                    "example": 2,
                                                    "description": "Количество в подарок"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Текст об успешном выполнении",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "apiVersion": {
                                            "type": "string",
                                            "example": "1.0"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "result": {
                                                    "type": "object",
                                                    "description": "вернётся вся структура как она записалась в базу"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/SampleError"
                    }
                }
            }
        },
        "/update_promotion": {
            "post": {
                "tags": [
                    "promotion_action"
                ],
                "summary": "Создать/обновить параметры акции",
                "description": "Создать/обновить акцию. Если акция еще не наступила - можно менять. (за 12 часов блокируется на редактирование)",
                "operationId": "updatePromotion",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/editToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "id": {
                                        "type": "string",
                                        "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0",
                                        "description": "ключ акции(если создаём новую, то параметр не передаём)"
                                    },
                                    "id_template": {
                                        "type": "string",
                                        "example": "300cc0a4-376f-4778-bd8c-8fac4a25e3b2",
                                        "description": "ключ шаблона акции"
                                    },
                                    "author": {
                                        "type": "string",
                                        "example": "pivanov"
                                    },
                                    "date_from": {
                                        "type": "string",
                                        "example": "20181218093000",
                                        "description": "Дата начала действия акции"
                                    },
                                    "date_to": {
                                        "type": "string",
                                        "example": "20181218093000",
                                        "description": "Дата окончания действия акции"
                                    },
                                    "group_counter": {
                                        "type": "integer",
                                        "example": 1,
                                        "description": "Группа акций, когда необходимо разбить акции, чтобы они между собой не пересекались"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Текст об успешном выполнении",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "apiVersion": {
                                            "type": "string",
                                            "example": "1.0"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "result": {
                                                    "type": "object",
                                                    "description": "вернётся вся структура как она записалась в базу"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/SampleError"
                    }
                }
            }
        },
        "/update_promotion_place": {
            "post": {
                "tags": [
                    "promotion_action"
                ],
                "summary": "Создать/обновить места проведения акции",
                "description": "Создать/обновить места проведения, где проходит акция Новый список, меняющий старый, если акция не использовалась У оргструктур есть поле priority. Акция будет срабатывать, если на каждом priority есть хотя бы одна запись в местах у заказа. Например МОК (приоритет 1), Тюмень (приоритет 2), Сургут (Приоритет 2). Будем искать в заказе код МОКа, И либо Тюмень либо Сургут.",
                "operationId": "updatePromotionPlace",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/editToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "id_promotion": {
                                        "type": "string",
                                        "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0",
                                        "description": "ключ акции"
                                    },
                                    "id_business": {
                                        "type": "integer",
                                        "example": 1,
                                        "enum": [
                                            "1 СД",
                                            "2 Эннергия"
                                        ],
                                        "description": "Тип Бизнеса:\n * `1` - Строительный двор\n * `2` - Эннергиия\n"
                                    },
                                    "promotion_place": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "code_place": {
                                                    "type": "string",
                                                    "example": "VKBUR1005",
                                                    "description": "Место проведения(Формат, Город, Магазин...)"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Текст об успешном выполнении",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "apiVersion": {
                                            "type": "string",
                                            "example": "1.0"
                                        },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "result": {
                                                    "type": "object",
                                                    "description": "вернётся вся структура как она записалась в базу"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/SampleError"
                    }
                }
            }
        },
        "/get_promotions": {
            "post": {
                "tags": [
                    "promotion_action"
                ],
                "summary": "Получить акции со всеми параметрами",
                "description": "Получить все акции(товары, призы, места проведения) по листу ключей (uuid) и/или интервалу дат (дата с, дата по).",
                "operationId": "getPromotion",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/readOnlyToken"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "list_id": {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "example": "322cc0a1-356f-4778-bd2c-8fac2a25e3b0",
                                            "description": "uuid акции. если не передаём параметр, то он игнорируется"
                                        }
                                    },
                                    "date_from": {
                                        "type": "string",
                                        "example": "20181026000000",
                                        "description": "Дата с. Если не передаём параметр или формат не тот, то он игнорируется. Формат даты 'ddMMyyyyHHmmss'"
                                    },
                                    "date_to": {
                                        "type": "string",
                                        "example": "20181126235959",
                                        "description": "Дата по. Если не передаём параметр или формат не тот, то он игнорируется. Формат даты 'ddMMyyyyHHmmss'"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Тело запроса",
                    "required": true
                },
                "responses": {
