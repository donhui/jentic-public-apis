                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "code": {
                                                        "type": "string",
                                                        "example": "VKORG1000"
                                                    },
                                                    "business": {
                                                        "type": "string",
                                                        "example": "SDVR"
                                                    },
                                                    "name": {
                                                        "type": "string",
