                "required": true,
                "schema": {
                    "type": "string"
                }
            },
            "editToken": {
                "name": "token",
                "in": "header",
                "description": "Токен на изменение данных",
                "required": true,
                "schema": {
                    "type": "string"
                }
            },
            "sapToken": {
                "name": "token",
                "in": "header",
                "description": "Токен САПа",
                "required": true,
                "schema": {
                    "type": "string"
                }
            }
        },
        "responses": {
            "OrgstructuresNoCorrectData": {
                "description": "Некорректные данные на входе",
                "content": {
