  "components": {
    "schemas": {
      "LoginRequest": { "type": "object", "required": ["email", "password"], "properties": { "email": { "type": "string" }, "password": { "type": "string" } } },
      "LoginResponse": { "type": "object", "properties": { "data": { "type": "object", "properties": { "token": { "type": "string" }, "expires_in_minutes": { "type": "integer" }, "expires_at": { "type": "string", "format": "date-time" } } } } },
      "BalanceResponse": { "type": "object", "properties": { "data": { "type": "object", "properties": { "amount": { "type": "number" }, "currency": { "type": "string" } } } } },
      "BalanceRequest": { "type": "object", "properties": { "id": { "type": "integer" }, "amount": { "type": "integer" }, "observations": { "type": "string" }, "status": { "type": "string" }, "created_at": { "type": "string", "format": "date-time" }, "updated_at": { "type": "string", "format": "date-time" } } },
      "BalanceRequestListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/BalanceRequest" } }, "total": { "type": "integer" }, "per_page": { "type": "integer" }, "current_page": { "type": "integer" } } },
      "BalanceRequestResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/BalanceRequest" } } },
      "CreateBalanceRequest": { "type": "object", "required": ["amount"], "properties": { "amount": { "type": "integer" }, "observations": { "type": "string" } } },
      "Contact": { "type": "object", "properties": { "id": { "type": "integer" }, "number": { "type": "string" }, "name": { "type": "string" }, "email": { "type": "string" }, "city": { "type": "string" }, "language": { "type": "string" }, "in_sms_blacklist": { "type": "boolean" }, "in_voice_blacklist": { "type": "boolean" }, "in_mail_blacklist": { "type": "boolean" }, "groups": { "type": "array", "items": { "type": "object" } }, "extra_fields": { "type": "array", "items": { "type": "object" } }, "created_at": { "type": "string", "format": "date-time" }, "updated_at": { "type": "string", "format": "date-time" } } },
      "ContactListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Contact" } }, "total": { "type": "integer" }, "per_page": { "type": "integer" }, "current_page": { "type": "integer" } } },
      "ContactResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Contact" } } },
      "CreateContactRequest": { "type": "object", "properties": { "number": { "type": "string" }, "name": { "type": "string" }, "email": { "type": "string" }, "city": { "type": "string" }, "language": { "type": "string" }, "in_sms_blacklist": { "type": "boolean" }, "in_voice_blacklist": { "type": "boolean" }, "in_mail_blacklist": { "type": "boolean" }, "groups": { "type": "string", "description": "Comma-separated group IDs" }, "extra_fields": { "type": "array", "items": { "type": "object" } } } },
      "ImportContactsJsonRequest": { "type": "object", "required": ["contacts_json"], "properties": { "contacts_json": { "type": "array", "items": { "type": "object" }, "description": "Max 1000 contacts" }, "callback_url": { "type": "string" }, "priority_field": { "type": "string", "enum": ["number", "email"] } } },
      "ImportContactsFileRequest": { "type": "object", "required": ["file", "agenda_id"], "properties": { "file": { "type": "string", "format": "binary" }, "agenda_id": { "type": "integer" }, "columns_to_import": { "type": "string" }, "add_prefix": { "type": "string" }, "file_has_heading": { "type": "boolean" }, "priority_field": { "type": "string", "enum": ["number", "email"] } } },
      "Agenda": { "type": "object", "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "users_count": { "type": "integer" }, "created_at": { "type": "string", "format": "date-time" }, "updated_at": { "type": "string", "format": "date-time" } } },
      "AgendaListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Agenda" } }, "total": { "type": "integer" }, "per_page": { "type": "integer" }, "current_page": { "type": "integer" } } },
      "AgendaResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Agenda" } } },
      "ExtraField": { "type": "object", "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "type": { "type": "string", "enum": ["number", "string", "date"] }, "date_format": { "type": "string" } } },
      "ExtraFieldListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/ExtraField" } }, "total": { "type": "integer" }, "per_page": { "type": "integer" }, "current_page": { "type": "integer" } } },
      "ExtraFieldResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/ExtraField" } } },
      "CreateExtraFieldRequest": { "type": "object", "required": ["name", "type"], "properties": { "name": { "type": "string" }, "type": { "type": "string", "enum": ["number", "string", "date"] }, "date_format": { "type": "string" } } },
      "SimpleSmsRequest": { "type": "object", "required": ["message", "numbers"], "properties": { "message": { "type": "string" }, "numbers": { "type": "string" }, "configuration_name": { "type": "string" } } },
      "MultipleSmsRequest": { "type": "object", "required": ["messages"], "properties": { "messages": { "type": "array", "items": { "type": "object", "properties": { "message": { "type": "string" }, "number": { "type": "string" } } } }, "configuration_name": { "type": "string" } } },
      "Send": { "type": "object", "properties": { "id": { "type": "integer" }, "message": { "type": "string" }, "status": { "type": "string" }, "created_at": { "type": "string", "format": "date-time" } } },
      "SendListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/Send" } }, "total": { "type": "integer" }, "per_page": { "type": "integer" }, "current_page": { "type": "integer" } } },
      "SendResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/Send" } } },
      "SmsCampaign": { "type": "object", "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "message": { "type": "string" }, "status": { "type": "string" }, "scheduled_at": { "type": "string", "format": "date-time" }, "created_at": { "type": "string", "format": "date-time" }, "updated_at": { "type": "string", "format": "date-time" } } },
      "SmsCampaignListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/SmsCampaign" } }, "total": { "type": "integer" }, "per_page": { "type": "integer" }, "current_page": { "type": "integer" } } },
      "SmsCampaignResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/SmsCampaign" } } },
      "CreateSmsCampaignRequest": { "type": "object", "required": ["name", "message"], "properties": { "name": { "type": "string" }, "message": { "type": "string" }, "groups": { "type": "string" }, "scheduled_at": { "type": "string", "format": "date-time" } } },
      "SmsCampaignFileRequest": { "type": "object", "required": ["file"], "properties": { "file": { "type": "string", "format": "binary" }, "name": { "type": "string" }, "message": { "type": "string" } } },
      "TransactionalEmailRequest": { "type": "object", "required": ["to", "subject", "body"], "properties": { "to": { "type": "string" }, "subject": { "type": "string" }, "body": { "type": "string" }, "from_name": { "type": "string" }, "from_email": { "type": "string" } } },
      "EmailSendResponse": { "type": "object", "properties": { "data": { "type": "object", "properties": { "id": { "type": "integer" }, "status": { "type": "string" } } } } },
      "EmailCampaign": { "type": "object", "properties": { "id": { "type": "integer" }, "name": { "type": "string" }, "subject": { "type": "string" }, "status": { "type": "string" }, "created_at": { "type": "string", "format": "date-time" }, "updated_at": { "type": "string", "format": "date-time" } } },
      "EmailCampaignListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/EmailCampaign" } }, "total": { "type": "integer" }, "per_page": { "type": "integer" }, "current_page": { "type": "integer" } } },
      "EmailCampaignResponse": { "type": "object", "properties": { "data": { "$ref": "#/components/schemas/EmailCampaign" } } },
      "CreateEmailCampaignRequest": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" }, "subject": { "type": "string" }, "template_id": { "type": "integer" }, "body": { "type": "string" }, "groups": { "type": "string" } } },
      "EmailAddressListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "integer" }, "email": { "type": "string" }, "name": { "type": "string" } } } } } },
      "EmailTemplateListResponse": { "type": "object", "properties": { "data": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "integer" }, "name": { "type": "string" } } } }, "total": { "type": "integer" }, "per_page": { "type": "integer" }, "current_page": { "type": "integer" } } },
      "Send2faPinRequest": { "type": "object", "required": ["phone"], "properties": { "phone": { "type": "string" }, "message_template": { "type": "string" } } },
      "PinSendResponse": { "type": "object", "properties": { "data": { "type": "object", "properties": { "status": { "type": "string" }, "expires_at": { "type": "string", "format": "date-time" } } } } },
