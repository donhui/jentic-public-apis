{
  "openapi": "3.0.3",
  "info": {
    "title": "Mensagia API",
    "version": "1.0.0",
    "description": "Mensagia is a multi-channel messaging platform API supporting SMS, Email, Voice campaigns, 2-Factor Authentication, certified messaging, and contact management. The API allows sending simple and bulk SMS/email messages, managing contacts and groups, creating campaigns, and tracking delivery notifications.",
    "x-jentic-source-url": "https://api.mensagia.com/docs/v1/"
  },
  "servers": [
    {
      "url": "https://api.mensagia.com/v1"
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "operationId": "authenticate",
        "summary": "Obtain a JWT token",
        "description": "Authenticate with email and password to obtain a temporary JWT token for API access.",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/balance": {
      "get": {
        "operationId": "getBalance",
        "summary": "Get current balance",
        "description": "Retrieve the current account balance and currency.",
        "tags": ["Balance"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BalanceResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/balance/requests": {
      "get": {
        "operationId": "listBalanceRequests",
        "summary": "List all balance requests",
        "description": "Retrieve all balance purchase requests with optional filtering.",
        "tags": ["Balance"],
        "parameters": [
          {
            "name": "request_state_id",
            "in": "query",
            "description": "Filter by request state ID",
            "required": false,
            "schema": { "type": "integer" }
          },
          {
            "name": "finish_date_min",
            "in": "query",
            "description": "Minimum finish date filter",
            "required": false,
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "finish_date_max",
            "in": "query",
            "description": "Maximum finish date filter",
            "required": false,
            "schema": { "type": "string", "format": "date-time" }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "required": false,
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Results per page",
            "required": false,
            "schema": { "type": "integer", "default": 10 }
          }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceRequestListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createBalanceRequest",
        "summary": "Create a balance request",
        "description": "Create a new balance purchase request.",
        "tags": ["Balance"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateBalanceRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Request created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceRequestResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/balance/requests/{id}": {
      "get": {
        "operationId": "getBalanceRequest",
        "summary": "Get a balance request",
        "description": "Retrieve a single balance purchase request by ID.",
        "tags": ["Balance"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceRequestResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/balance/requests/{id}/accept": {
      "post": {
        "operationId": "acceptBalanceRequest",
        "summary": "Accept a balance request",
        "description": "Accept a balance purchase request (distributors only).",
        "tags": ["Balance"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Request accepted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceRequestResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Forbidden - distributors only", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/balance/requests/{id}/cancel": {
      "post": {
        "operationId": "cancelBalanceRequest",
        "summary": "Cancel a balance request",
        "tags": ["Balance"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Request cancelled", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceRequestResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/balance/requests/{id}/reject": {
      "post": {
        "operationId": "rejectBalanceRequest",
        "summary": "Reject a balance request",
        "description": "Reject a balance purchase request (distributors only).",
        "tags": ["Balance"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Request rejected", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceRequestResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Forbidden - distributors only", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/balance/requests/{id}/forward": {
      "post": {
        "operationId": "forwardBalanceRequest",
        "summary": "Forward a balance request",
        "description": "Forward a balance purchase request to superior distributor (distributors only).",
        "tags": ["Balance"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Request forwarded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BalanceRequestResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Forbidden - distributors only", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts": {
      "get": {
        "operationId": "listContacts",
        "summary": "List all contacts",
        "description": "Retrieve all contacts with optional search filters. Customers only.",
        "tags": ["Contacts"],
        "parameters": [
          { "name": "name", "in": "query", "description": "Filter by name", "required": false, "schema": { "type": "string" } },
          { "name": "number", "in": "query", "description": "Filter by phone number", "required": false, "schema": { "type": "string" } },
          { "name": "email", "in": "query", "description": "Filter by email", "required": false, "schema": { "type": "string" } },
          { "name": "city", "in": "query", "description": "Filter by city", "required": false, "schema": { "type": "string" } },
          { "name": "language", "in": "query", "description": "Filter by language", "required": false, "schema": { "type": "string" } },
          { "name": "group_ids", "in": "query", "description": "Filter by group IDs (comma-separated)", "required": false, "schema": { "type": "string" } },
          { "name": "in_sms_blacklist", "in": "query", "description": "Filter by SMS blacklist status", "required": false, "schema": { "type": "boolean" } },
          { "name": "search_type", "in": "query", "description": "Search type for string fields", "required": false, "schema": { "type": "string", "enum": ["contains", "equals"], "default": "contains" } },
          { "name": "page", "in": "query", "description": "Page number", "required": false, "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "description": "Results per page", "required": false, "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createContact",
        "summary": "Create a contact",
        "description": "Create a new contact. Requires at minimum a phone number or email.",
        "tags": ["Contacts"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateContactRequest" } } } },
        "responses": {
          "200": { "description": "Contact created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "operationId": "getContact",
        "summary": "Get a contact",
        "tags": ["Contacts"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "updateContact",
        "summary": "Update a contact",
        "tags": ["Contacts"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateContactRequest" } } } },
        "responses": {
          "200": { "description": "Contact updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteContact",
        "summary": "Delete a contact",
        "tags": ["Contacts"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": {
          "200": { "description": "Contact deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DeleteResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/import/json": {
      "post": {
        "operationId": "importContactsJson",
        "summary": "Import contacts via JSON",
        "description": "Import up to 1000 contacts via JSON array. Processing is asynchronous.",
        "tags": ["Contacts"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ImportContactsJsonRequest" } } } },
        "responses": {
          "200": { "description": "Import started", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProcessResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/import/file": {
      "post": {
        "operationId": "importContactsFile",
        "summary": "Import contacts via file",
        "description": "Import contacts from a TXT, CSV, or XLSX file (max 50MB). Processing is asynchronous.",
        "tags": ["Contacts"],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "$ref": "#/components/schemas/ImportContactsFileRequest" } } } },
        "responses": {
          "200": { "description": "Import started", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProcessResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{id}/groups/add": {
      "post": {
        "operationId": "addContactGroups",
        "summary": "Add groups to a contact",
        "tags": ["Contacts"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "groups": { "type": "string", "description": "Comma-separated group IDs" } }, "required": ["groups"] } } } },
        "responses": {
          "200": { "description": "Groups assigned", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/contacts/{id}/groups/remove": {
      "post": {
        "operationId": "removeContactGroups",
        "summary": "Remove groups from a contact",
        "tags": ["Contacts"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "groups": { "type": "string", "description": "Comma-separated group IDs" } }, "required": ["groups"] } } } },
        "responses": {
          "200": { "description": "Groups removed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ContactResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/agendas": {
      "get": {
        "operationId": "listAgendas",
        "summary": "List all contact groups",
        "description": "Retrieve all contact groups/agendas. Customers only.",
        "tags": ["Groups"],
        "parameters": [
          { "name": "name", "in": "query", "description": "Filter by name", "required": false, "schema": { "type": "string" } },
          { "name": "search_type", "in": "query", "required": false, "schema": { "type": "string", "enum": ["contains", "equals"], "default": "contains" } },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "required": false, "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgendaListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createAgenda",
        "summary": "Create a contact group",
        "tags": ["Groups"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] } } } },
        "responses": {
          "200": { "description": "Group created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgendaResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/agendas/{id}": {
      "get": {
        "operationId": "getAgenda",
        "summary": "Get a contact group",
        "tags": ["Groups"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgendaResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "updateAgenda",
        "summary": "Update a contact group",
        "tags": ["Groups"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] } } } },
        "responses": {
          "200": { "description": "Group updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AgendaResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteAgenda",
        "summary": "Delete a contact group",
        "tags": ["Groups"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": {
          "200": { "description": "Group deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DeleteResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/extrafields": {
      "get": {
        "operationId": "listExtraFields",
        "summary": "List custom fields",
        "tags": ["Custom Fields"],
        "parameters": [
          { "name": "name", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "search_type", "in": "query", "required": false, "schema": { "type": "string", "enum": ["contains", "equals"], "default": "contains" } },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "required": false, "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExtraFieldListResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "post": {
        "operationId": "createExtraField",
        "summary": "Create a custom field",
        "tags": ["Custom Fields"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateExtraFieldRequest" } } } },
        "responses": {
          "200": { "description": "Field created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExtraFieldResponse" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/extrafields/{id}": {
      "get": {
        "operationId": "getExtraField",
        "summary": "Get a custom field",
        "tags": ["Custom Fields"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": {
          "200": { "description": "Successful response", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ExtraFieldResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "operationId": "deleteExtraField",
        "summary": "Delete a custom field",
        "tags": ["Custom Fields"],
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": {
          "200": { "description": "Field deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DeleteResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/sends": {
      "get": {
        "operationId": "listSimpleSends",
        "summary": "List all simple SMS sends",
        "tags": ["SMS"],
        "parameters": [
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer", "default": 1 } },
          { "name": "per_page", "in": "query", "required": false, "schema": { "type": "integer", "default": 10 } }
        ],
