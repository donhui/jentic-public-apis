            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/searches/list-cohorts": {
      "get": {
        "tags": ["Searches"],
        "summary": "List cohorts",
        "description": "List cohorts for a specific program.",
        "operationId": "listCohorts",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "programId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Program ID to list cohorts for"
          }
        ],
        "responses": {
          "200": {
            "description": "List of cohorts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Cohort"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/searches/list-resources": {
      "get": {
        "tags": ["Searches"],
        "summary": "List resources",
        "description": "List available resources filtered by type.",
        "operationId": "listResources",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "resourceType",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter resources by type"
          }
        ],
        "responses": {
          "200": {
            "description": "List of resources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Resource"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/searches/list-channels": {
      "get": {
        "tags": ["Searches"],
        "summary": "List channels",
        "description": "List all available messaging channels.",
        "operationId": "listChannels",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of channels",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Channel"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/searches/list-checkin-flows": {
      "get": {
        "tags": ["Searches"],
        "summary": "List check-in flows",
        "description": "List all available check-in flows.",
        "operationId": "listCheckinFlows",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of check-in flows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CheckinFlow"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
