{
  "openapi": "3.0.3",
  "info": {
    "title": "Coachful Zapier API",
    "description": "API for integrating Coachful with Zapier. Provides webhooks, polling triggers, actions for task/habit/message/invoice management, and search endpoints for coaches and creators.",
    "version": "1.0.0",
    "contact": {
      "name": "Coachful",
      "url": "https://coachful.co"
    },
    "x-jentic-source-url": "https://coachful.co/docs/api"
  },
  "servers": [
    {
      "url": "https://app.coachful.co",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "API key verification"
    },
    {
      "name": "Webhooks",
      "description": "Webhook subscription management"
    },
    {
      "name": "Triggers",
      "description": "Event polling triggers"
    },
    {
      "name": "Actions",
      "description": "Create and manage resources"
    },
    {
      "name": "Searches",
      "description": "Find and list resources"
    }
  ],
  "paths": {
    "/api/zapier/auth/test": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Verify API key",
        "description": "Verify your API key and get organization info.",
        "operationId": "testAuth",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/hooks": {
      "post": {
        "tags": ["Webhooks"],
        "summary": "Subscribe to events",
        "description": "Register a webhook URL to receive real-time event notifications.",
        "operationId": "subscribeWebhook",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookSubscribeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Subscription created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookSubscription"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/hooks/{hookId}": {
      "delete": {
        "tags": ["Webhooks"],
        "summary": "Unsubscribe from events",
        "description": "Remove an existing webhook subscription.",
        "operationId": "unsubscribeWebhook",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "hookId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The webhook subscription ID to remove"
          }
        ],
        "responses": {
          "200": {
            "description": "Subscription removed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Webhook not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/triggers/{event}": {
      "get": {
        "tags": ["Triggers"],
        "summary": "Poll for recent events",
        "description": "Poll for recent events of a given type. Returns last 50 events.",
        "operationId": "pollTrigger",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "event",
            "in": "path",
            "required": true,
            "description": "Event type to poll for",
            "schema": {
              "type": "string",
              "enum": [
                "client.checkin.completed",
                "client.added",
                "program.purchased",
                "payment.received",
                "session.completed",
                "habit.completed",
                "goal.achieved",
                "intake.call.booked",
                "intake.call.completed",
                "group.call.completed",
                "course.joined"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of recent events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/triggers/{event}/sample": {
      "get": {
        "tags": ["Triggers"],
        "summary": "Get sample event data",
        "description": "Get sample event data for a given event type.",
        "operationId": "getSampleEvent",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "event",
            "in": "path",
            "required": true,
            "description": "Event type",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sample event data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/zapier/actions/create-task": {
      "post": {
        "tags": ["Actions"],
        "summary": "Create a task",
        "description": "Create a new task for a client.",
        "operationId": "createTask",
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
