  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API key for authentication. Rate limits: 100 reads/min, 30 writes/min per API key."
      }
    },
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "organizationName": {
            "type": "string"
          },
          "coachName": {
            "type": "string"
          },
          "organizationId": {
            "type": "string"
          }
        }
      },
      "WebhookSubscribeRequest": {
        "type": "object",
        "required": ["hookUrl", "event"],
        "properties": {
          "hookUrl": {
            "type": "string",
            "format": "uri",
            "description": "URL to receive webhook payloads"
          },
          "event": {
            "type": "string",
            "enum": [
              "client.checkin.completed",
              "client.added",
              "program.purchased",
              "payment.received",
              "session.completed",
              "habit.completed",
              "goal.achieved",
              "intake.call.booked",
              "intake.call.completed",
              "group.call.completed",
              "course.joined"
            ],
            "description": "Event type to subscribe to"
          }
        }
      },
      "WebhookSubscription": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "hookUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateTaskRequest": {
        "type": "object",
        "required": ["clientEmail", "title"],
        "properties": {
          "clientEmail": {
            "type": "string",
            "format": "email"
          },
          "title": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "listType": {
            "type": "string"
          }
        }
      },
      "CreateHabitRequest": {
        "type": "object",
        "required": ["clientEmail", "text"],
        "properties": {
          "clientEmail": {
            "type": "string",
            "format": "email"
          },
          "text": {
            "type": "string"
          },
          "frequency": {
            "type": "string"
          }
        }
      },
      "SendMessageRequest": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string"
          },
          "clientEmail": {
