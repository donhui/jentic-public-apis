    "/entries.json": {
      "get": {
        "operationId": "listEntries",
        "summary": "List time entries with filters",
        "tags": [
          "Entries"
        ],
        "parameters": [
          {
            "name": "start_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "updated_at",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "billable",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "project_id",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "task_id",
            "in": "query",
            "schema": {
              "type": "integer"
