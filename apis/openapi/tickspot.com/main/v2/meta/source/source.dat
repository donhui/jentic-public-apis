  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Token-based auth. Format: Token token=YOUR_TOKEN"
      },
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication with email and password (used only for /roles.json)"
      }
    },
    "schemas": {
      "Role": {
        "type": "object",
        "properties": {
          "subscription_id": {
            "type": "integer"
          },
          "company": {
            "type": "string"
          },
          "api_token": {
            "type": "string"
          }
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "archive": {
            "type": "boolean"
          },
          "url": {
            "type": "string"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ClientDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Client"
          },
          {
            "type": "object",
            "properties": {
              "projects": {
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer"
                  },
                  "url": {
                    "type": "string"
                  },
                  "updated_at": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        ]
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "budget": {
            "type": "number"
          },
          "date_closed": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "notifications": {
            "type": "boolean"
          },
          "billable": {
            "type": "boolean"
          },
          "recurring": {
            "type": "boolean"
          },
          "client_id": {
            "type": "integer"
          },
          "owner_id": {
            "type": "integer"
          },
          "url": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ProjectDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Project"
          },
          {
            "type": "object",
            "properties": {
              "total_hours": {
                "type": "number"
              },
              "tasks": {
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer"
                  },
                  "url": {
                    "type": "string"
                  },
                  "updated_at": {
                    "type": "string",
                    "format": "date-time",
                    "nullable": true
                  }
                }
              },
              "client": {
                "$ref": "#/components/schemas/Client"
              }
            }
          }
        ]
      },
      "ProjectInput": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "budget": {
            "type": "number"
          },
          "notifications": {
            "type": "boolean"
          },
          "billable": {
            "type": "boolean"
          },
          "recurring": {
            "type": "boolean"
          },
          "client_id": {
            "type": "integer"
          },
          "owner_id": {
            "type": "integer"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "budget": {
            "type": "number"
          },
          "position": {
            "type": "integer"
          },
          "project_id": {
            "type": "integer"
          },
          "date_closed": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "billable": {
            "type": "boolean"
          },
          "url": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TaskDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Task"
          },
          {
            "type": "object",
            "properties": {
              "total_hours": {
                "type": "number"
              },
              "entries": {
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer"
                  },
                  "url": {
                    "type": "string"
                  },
                  "updated_at": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              },
              "project": {
                "$ref": "#/components/schemas/Project"
              }
            }
          }
        ]
      },
      "Entry": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "hours": {
            "type": "number"
          },
          "notes": {
            "type": "string"
          },
          "task_id": {
            "type": "integer"
          },
          "user_id": {
            "type": "integer"
          },
          "url": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EntryDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Entry"
          },
          {
            "type": "object",
            "properties": {
              "task": {
                "$ref": "#/components/schemas/Task"
              }
            }
          }
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "timezone": {
            "type": "string"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
