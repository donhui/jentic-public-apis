{
  "openapi": "3.0.3",
  "info": {
    "title": "NOAA Climate Data Online (CDO) API",
    "description": "NOAA Climate Data Online Web Services API v2 provides access to climate datasets, data categories, data types, locations, stations, and observed data values.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://www.ncdc.noaa.gov/cdo-web/webservices/v2"
  },
  "servers": [
    {
      "url": "https://www.ncei.noaa.gov/cdo-web/api/v2",
      "description": "NOAA CDO API v2"
    }
  ],
  "paths": {
    "/datasets": {
      "get": {
        "operationId": "listDatasets",
        "summary": "List datasets",
        "description": "List available datasets or filter by parameters.",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DataTypeIdParam"
          },
          {
            "$ref": "#/components/parameters/LocationIdParam"
          },
          {
            "$ref": "#/components/parameters/StationIdParam"
          },
          {
            "$ref": "#/components/parameters/StartDateParam"
          },
          {
            "$ref": "#/components/parameters/EndDateParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          },
          {
            "$ref": "#/components/parameters/OffsetParam"
          },
          {
            "$ref": "#/components/parameters/SortFieldParam"
          },
          {
            "$ref": "#/components/parameters/SortOrderParam"
          }
        ],
        "responses": {
          "200": {
            "description": "List of datasets",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DatasetList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - invalid or missing token"
          }
        }
      }
    },
    "/datasets/{id}": {
      "get": {
        "operationId": "getDataset",
        "summary": "Get dataset by ID",
        "description": "Retrieve information about a specific dataset.",
        "tags": [
          "Datasets"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Dataset identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Dataset details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Dataset"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Dataset not found"
          }
        }
      }
    },
    "/datacategories": {
