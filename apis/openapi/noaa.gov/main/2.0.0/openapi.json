        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Location identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Location details"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Location not found"
          }
        }
      }
    },
    "/stations": {
      "get": {
        "operationId": "listStations",
        "summary": "List stations",
        "description": "List weather observing stations.",
        "tags": [
          "Stations"
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DatasetIdParam"
          },
          {
            "$ref": "#/components/parameters/LocationIdParam"
          },
          {
            "$ref": "#/components/parameters/DataCategoryIdParam"
          },
          {
            "$ref": "#/components/parameters/DataTypeIdParam"
          },
          {
            "name": "extent",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Desired geographical extent for stations in format: lat1,lon1,lat2,lon2"
          },
          {
            "$ref": "#/components/parameters/StartDateParam"
          },
          {
            "$ref": "#/components/parameters/EndDateParam"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          },
          {
            "$ref": "#/components/parameters/OffsetParam"
          },
          {
            "$ref": "#/components/parameters/SortFieldParam"
          },
          {
            "$ref": "#/components/parameters/SortOrderParam"
          }
        ],
        "responses": {
          "200": {
            "description": "List of stations",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
