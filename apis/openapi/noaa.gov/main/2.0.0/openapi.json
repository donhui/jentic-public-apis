    "/stations/{id}": {
      "get": {
        "operationId": "getStation",
        "summary": "Get station by ID",
        "description": "Retrieve details for a specific station.",
        "tags": [
          "Stations"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Station identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Station details"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Station not found"
          }
        }
      }
    },
    "/data": {
      "get": {
        "operationId": "getData",
        "summary": "Get data",
        "description": "Fetch actual observed data values. Requires datasetid, startdate, and enddate parameters.",
        "tags": [
          "Data"
        ],
        "parameters": [
          {
            "name": "datasetid",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Dataset identifier"
          },
          {
            "name": "startdate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Start date in ISO format (YYYY-MM-DD)"
          },
          {
            "name": "enddate",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "End date in ISO format (YYYY-MM-DD)"
          },
          {
            "name": "stationid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Station identifier"
          },
          {
            "name": "datatypeid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Data type identifier"
          },
          {
            "name": "locationid",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Location identifier"
          },
          {
            "name": "units",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "standard",
                "metric"
              ]
            },
            "description": "Unit system"
          },
          {
            "name": "includemetadata",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            },
            "description": "Whether to include metadata in the response"
          },
          {
            "$ref": "#/components/parameters/LimitParam"
          },
          {
            "$ref": "#/components/parameters/OffsetParam"
          },
          {
            "$ref": "#/components/parameters/SortFieldParam"
          },
          {
            "$ref": "#/components/parameters/SortOrderParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Observed data values",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DataList"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "tokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "token",
        "description": "NOAA CDO API token. Rate limited to 5 requests/second and 10,000 requests/day."
      }
    },
    "parameters": {
      "DatasetIdParam": {
        "name": "datasetid",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Filter by dataset identifier"
      },
      "DataTypeIdParam": {
        "name": "datatypeid",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Filter by data type identifier"
      },
      "LocationIdParam": {
        "name": "locationid",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Filter by location identifier"
      },
      "StationIdParam": {
        "name": "stationid",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Filter by station identifier"
      },
      "DataCategoryIdParam": {
        "name": "datacategoryid",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Filter by data category identifier"
      },
      "LocationCategoryIdParam": {
        "name": "locationcategoryid",
        "in": "query",
        "schema": {
          "type": "string"
        },
        "description": "Filter by location category identifier"
      },
      "StartDateParam": {
        "name": "startdate",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date"
        },
        "description": "Start date in ISO format (YYYY-MM-DD)"
      },
      "EndDateParam": {
        "name": "enddate",
        "in": "query",
        "schema": {
          "type": "string",
          "format": "date"
        },
        "description": "End date in ISO format (YYYY-MM-DD)"
      },
      "LimitParam": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 25,
          "maximum": 1000
        },
        "description": "Maximum number of results to return"
      },
      "OffsetParam": {
        "name": "offset",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 0
        },
        "description": "Start record number"
      },
      "SortFieldParam": {
        "name": "sortfield",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "id",
            "name",
            "mindate",
            "maxdate",
            "datacoverage"
          ]
        },
        "description": "Field to sort by"
      },
      "SortOrderParam": {
        "name": "sortorder",
        "in": "query",
        "schema": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ],
          "default": "asc"
        },
        "description": "Sort order"
      }
    },
    "schemas": {
      "Dataset": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "datacoverage": {
            "type": "number"
          },
          "mindate": {
            "type": "string",
            "format": "date"
          },
          "maxdate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "DatasetList": {
        "type": "object",
        "properties": {
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Dataset"
            }
          }
        }
      },
      "DataList": {
        "type": "object",
        "properties": {
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DataValue"
            }
          }
        }
      },
      "DataValue": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "datatype": {
            "type": "string"
          },
          "station": {
            "type": "string"
          },
          "attributes": {
            "type": "string"
          },
          "value": {
            "type": "number"
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Metadata": {
        "type": "object",
        "properties": {
          "resultset": {
            "type": "object",
            "properties": {
              "offset": {
                "type": "integer"
              },
              "count": {
                "type": "integer"
              },
              "limit": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "tokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Datasets",
      "description": "Dataset information"
    },
    {
      "name": "DataCategories",
