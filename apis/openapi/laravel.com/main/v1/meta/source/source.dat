{
  "openapi": "3.0.3",
  "info": {
    "title": "Laravel Forge API",
    "version": "v1",
    "description": "Laravel Forge API for managing servers, sites, databases, SSL certificates, deployments, daemons, firewall rules, scheduled jobs, SSH keys, workers, recipes, backups, and more. Requires Bearer token authentication.",
    "x-jentic-source-url": "https://forge.laravel.com/api-documentation"
  },
  "servers": [
    {
      "url": "https://forge.laravel.com/api/v1"
    }
  ],
  "paths": {
    "/user": {
      "get": {
        "operationId": "getAuthenticatedUser",
        "summary": "Get authenticated user",
        "description": "Retrieve the currently authenticated user's profile information.",
        "tags": ["User"],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/servers": {
      "get": {
        "operationId": "listServers",
        "summary": "List servers",
        "description": "List all servers.",
        "tags": ["Servers"],
