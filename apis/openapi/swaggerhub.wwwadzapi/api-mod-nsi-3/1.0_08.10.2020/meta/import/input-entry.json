{
  "openapi": "3.0.0",
  "info": {
    "description": "211 - nsi_service. Описание API",
    "title": "API nsi_service",
    "version": "1.0_08.10.2020",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/wwwadzapi/api-mod_nsi_3/1.0_08.10.2020/swagger.json"
  },
  "servers": [],
  "paths": {
    "/dictionaries/{dict_name}": {
      "get": {
        "parameters": [
          {
            "description": "Название справочника (subjects, parallels, education_levels)",
            "in": "path",
            "name": "dict_name",
            "required": true,
            "schema": {
              "enum": [
                "education_levels",
                "subjects",
                "parallels",
                "studying_levels",
                "subject_areas"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Dictionary"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        },
        "tags": [
          "dictionaries-controller"
        ],
        "deprecated": false,
        "operationId": "getDictionaryUsingGET",
        "summary": "getDictionary"
      }
    },
    "/structure/didactic-themes": {
      "get": {
        "parameters": [
          {
            "description": "идентификатор уровня образования",
            "in": "query",
            "name": "education_level_id",
            "required": true,
            "schema": {
              "format": "int64",
              "type": "integer"
            }
          },
          {
            "description": "идентификатор предмета",
            "in": "query",
            "name": "subject_id",
            "required": true,
            "schema": {
              "format": "int64",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DidacticTheme"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        },
        "tags": [
          "didactic-theme-controller"
        ],
        "deprecated": false,
        "operationId": "getDidacticThemesUsingGET",
        "summary": "getDidacticThemes"
      }
    }
  },
  "components": {
    "schemas": {
      "Dictionary": {
        "description": "Объект справочника для списка элементов фильтра",
        "properties": {
          "dict_name": {
            "description": "Наименование справочника",
            "enum": [
              "education_levels",
              "subjects",
              "parallels",
              "studying_levels",
              "subject_areas"
            ],
            "example": "subjects",
            "type": "string"
          },
          "items": {
            "items": {
              "$ref": "#/components/schemas/DictionaryEntry"
            },
            "type": "array"
          }
        },
        "title": "Dictionary",
        "type": "object"
      },
      "DictionaryEntry": {
        "description": "Запись справочника \"Тематический Каркас\" НСИ3, выводимая в элементы фильтра по материалам",
        "properties": {
          "id": {
            "description": "Идентификатор записи",
            "format": "int64",
            "type": "integer"
          },
          "title": {
            "description": "Название, выводимое в UI",
            "type": "string"
          }
        },
        "title": "DictionaryEntry",
        "type": "object"
      },
      "DidacticTheme": {
        "description": "Объект ответа на запрос структуры ТК (Темы и ДЕ)",
        "properties": {
          "didactic_units": {
            "items": {
              "$ref": "#/components/schemas/DidacticUnit"
            },
            "type": "array"
          },
          "themes": {
            "items": {
              "$ref": "#/components/schemas/Theme"
            },
            "type": "array"
          }
        },
        "title": "DidacticTheme",
        "type": "object"
      },
      "DidacticUnit": {
        "description": "Модель представления DIDACTIC_UNIT[347] ТК НСИ3",
        "properties": {
          "children_ids": {
            "description": "Идентификаторы ДЕ-потомков первого уровня вложенности",
            "items": {
              "format": "int64",
              "type": "integer"
            },
            "type": "array"
          },
          "cis_id": {
            "description": "Идентификатор КЭС",
            "type": "string"
          },
          "id": {
            "description": "Идентификатор ДЕ",
            "format": "int64",
            "type": "integer"
          },
          "theme_id": {
            "description": "Идентификатор темы",
            "format": "int64",
            "type": "integer"
          },
          "title": {
            "description": "Название, выводимое в UI",
            "type": "string"
          }
        },
        "title": "DidacticUnit",
        "type": "object"
      },
      "Theme": {
        "description": "Модель представления THEME[343] ТК НСИ3",
        "properties": {
          "didactic_unit_ids": {
            "items": {
              "format": "int64",
              "type": "integer"
            },
            "type": "array"
          },
          "id": {
            "format": "int64",
            "type": "integer"
          },
          "title": {
            "type": "string"
          }
        },
        "title": "Theme",
        "type": "object"
      }
    }
  },
  "tags": [
    {
      "description": "Запрос справочников НСИ3. (предметы, параллели, уровни образования)",
      "name": "dictionaries-controller"
    },
    {
      "description": "Запрос структуры Тематического Каркаса НСИ3. (Темы и дидактические единицы)",
      "name": "didactic-theme-controller"
    }
  ]
}