{
  "info": {
    "description": "211 - material_service. Описание API",
    "version": "1.0_08.10.2020",
    "title": "API material_service",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/wwwadzapi/api-mod_materials/1.0_08.10.2020/swagger.json"
  },
  "paths": {
    "/materials/register": {
      "post": {
        "tags": [
          "material-uuid-controller"
        ],
        "summary": "registerMaterialsSelect",
        "description": "Регистрация состава выбранных материалов",
        "operationId": "registerMaterialsSelectUsingPOST",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "materials",
            "description": "materials",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/MaterialSelectItem"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/MaterialRegistryInfo"
              }
            }
          },
          "201": {
            "description": "Created"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        },
        "deprecated": false
      }
    },
    "/materials/{uuid}": {
      "get": {
        "tags": [
          "material-uuid-controller"
        ],
        "summary": "findMaterialByUuid",
        "description": "Получение данных о материале",
        "operationId": "findMaterialByUuidUsingGET",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "description": "UUID-идентификатор набора материалов",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/Material"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        },
        "deprecated": false
      }
    },
    "/materials/partners": {
      "get": {
        "tags": [
          "partner-controller"
        ],
        "summary": "getPartners",
        "operationId": "getPartnersUsingGET",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Partner"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        },
        "deprecated": false
      }
    },
    "/materials/{partner_id}": {
      "post": {
        "tags": [
          "filter-controller"
        ],
        "summary": "filter",
        "operationId": "filterUsingPOST",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "partner_id",
            "in": "path",
            "description": "Идентификатор провайдера материалов",
            "required": true,
            "type": "integer",
            "format": "int64"
          },
          {
            "in": "body",
            "name": "filterParams",
            "description": "Объект с параметрами фильтрации материалов",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FilterParams"
            }
          },
          {
            "name": "page",
            "description": "Номер страницы",
            "default": 0,
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "size",
            "description": "Количество материалов на странице",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32",
            "default": 10
          },
          {
            "name": "sort",
            "description": "Поля/направление сортировки (property1,property2(,asc|desc))",
            "default": "average_rating,desc",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/Page«Material»"
            }
          },
          "201": {
            "description": "Created"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        },
        "deprecated": false
      }
    }
  },
  "tags": [
    {
      "name": "filter-controller",
      "description": "Запросы и фильтрация списка материалов с указанием идентификатора партнёра"
    },
    {
      "name": "material-uuid-controller",
      "description": "Запросы состава набранных материалов по UUID"
    },
    {
      "name": "partner-controller",
      "description": "Запросы информации о партнерах провайдерах материалов"
    }
  ],
  "swagger": "2.0",
  "definitions": {
    "FilterParams": {
      "type": "object",
      "description": "Объект с параметрами запроса и фильтрации по материалам",
      "properties": {
        "parallell_ids": {
          "description": "Идентификаторы параллелей",
          "type": "array",
          "items": {
            "type": "integer",
            "format": "string"
          }
        },
        "subject_ids": {
          "description": "Идентификаторы предметов",
          "type": "array",
          "items": {
            "type": "integer",
            "format": "string"
          }
        },
        "didactic_unit_ids": {
          "description": "Идентификаторы ДЕ",
          "type": "array",
          "items": {
            "type": "integer",
            "format": "string"
          }
        },
        "material_types": {
          "description": "Идентификаторы типов материала",
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "lesson_template",
              "game_app",
              "test_specification",
              "composed_document",
              "atomic_object",
              "literature"
            ]
          }
        },
        "search": {
          "description": "Строка поискового запроса",
          "type": "string"
        }
      },
      "title": "FilterParams"
    },
    "Material": {
      "type": "object",
      "description": "Модель учебного материала",
      "properties": {
        "author": {
          "type": "string",
          "description": "Автор материала"
        },
        "description": {
          "type": "string",
          "description": "Описание материала"
        },
        "icon_url": {
          "type": "string",
          "description": "URL иконки материала"
        },
        "uuid": {
          "type": "string",
          "description": "Уникальный идентификатор выбранного материала"
        },
        "name": {
          "type": "string",
          "description": "Название материала"
        },
        "rating": {
          "type": "number",
          "format": "float",
          "description": "Рейтинг материала"
        },
        "votes": {
          "type": "integer",
          "format": "int64",
          "description": "Число голосов рейтинга"
        },
        "source": {
          "type": "string"
        },
        "subject_ids": {
          "type": "array",
          "description": "Список идентификаторов предметов (\"subject_ids\": [])",
          "items": {
            "type": "integer",
            "format": "int64"
          }
        },
        "type": {
          "type": "string",
          "example": [
            "lesson_template",
            "game_app",
            "test_specification",
            "composed_document",
            "atomic_object",
            "literature"
          ],
          "description": "Идентификатор типа материала"
        },
        "url": {
          "type": "string",
          "description": "URL материала"
        }
      },
      "title": "Material"
    },
    "MaterialRegistryInfo": {
      "type": "object",
      "description": "Модель регистрации выбранного материала",
      "properties": {
        "material_uuid": {
          "type": "string",
          "description": "UUID выбора материала"
        },
        "material_url": {
          "type": "string",
          "description": "URL выбора материала"
        },
        "material_select": {
          "$ref": "#/definitions/MaterialsSelectView"
        }
      },
      "title": "MaterialRegistryInfo"
    },
    "MaterialSelectItem": {
      "type": "object",
      "description": "Выбор материала",
      "properties": {
        "material_id": {
          "type": "integer",
          "format": "string",
          "description": "Идентификатор материала"
        },
        "partner_id": {
          "type": "integer",
          "format": "string",
          "description": "Идентификатор партнера"
        }
      },
      "title": "MaterialSelectItem"
    },
    "MaterialsSelectView": {
      "type": "object",
      "description": "Модель выбора с информацией о выбранном материале",
      "properties": {
        "material_item": {
          "$ref": "#/definitions/Material"
        },
        "material_select": {
          "$ref": "#/definitions/MaterialSelectItem"
        }
      },
      "title": "MaterialsSelectView"
    },
    "Pageable": {
      "type": "object",
      "description": "Параметры постраничного вывода данных",
      "properties": {
        "pageNumber": {
          "type": "integer",
          "format": "int32",
          "description": "номер страницы"
        },
        "pageSize": {
          "type": "integer",
          "format": "int32",
          "description": "размер страницы"
        }
      },
      "title": "Pageable"
    },
    "Page«Material»": {
      "type": "object",
      "description": "Материалы в постраничном представлении",
      "properties": {
        "content": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Material"
          },
          "description": "Материалы страницы"
        },
        "pageable": {
          "$ref": "#/definitions/Pageable"
        },
        "totalElements": {
          "type": "integer",
          "format": "int64",
          "description": "общее число материалов"
        },
        "totalPages": {
          "type": "integer",
          "format": "int32",
          "description": "общее число страниц"
        }
      },
      "title": "Page«Material»"
    },
    "Partner": {
      "type": "object",
      "description": "Информация о партнере провайдере материалов",
      "properties": {
        "description": {
          "type": "string",
          "description": "текст описания"
        },
        "partner_icon_url": {
          "type": "string",
          "description": "URL иконки партнера"
        },
        "partner_id": {
          "type": "integer",
          "format": "int64",
          "description": "идентификатор"
        },
        "partner_name": {
          "type": "string",
          "description": "название"
        },
        "redirect_url": {
          "type": "string",
          "description": "Ссылка на страницу выбора материала"
        },
        "info_url": {
          "type": "string",
          "description": "Ссылка на страницу с информацией"
        }
      },
      "title": "Partner"
    }
  }
}