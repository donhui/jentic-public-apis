  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Authentication via MD5 hash of Account Number, API Key and Submission Number. Requires an Application ID registered at QuickFile."
      }
    },
    "requestBodies": {
      "GenericRequest": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiRequest"
            }
          }
        }
      }
    },
    "schemas": {
      "ApiRequest": {
        "type": "object",
        "properties": {
          "Header": {
            "$ref": "#/components/schemas/RequestHeader"
          },
          "Body": {
            "type": "object",
            "description": "Method-specific request body parameters."
          }
        },
        "required": ["Header"]
      },
      "RequestHeader": {
        "type": "object",
        "properties": {
          "MessageType": {
            "type": "string",
            "description": "The API method name (e.g. Bank_Search, Invoice_Create)."
          },
          "SubmissionNumber": {
            "type": "string",
            "description": "A unique submission number for this request."
          },
          "Authentication": {
            "$ref": "#/components/schemas/Authentication"
          }
        },
        "required": ["MessageType", "SubmissionNumber", "Authentication"]
      },
      "Authentication": {
        "type": "object",
        "properties": {
          "AccNumber": {
            "type": "string",
            "description": "Your QuickFile account number."
          },
          "MD5Value": {
            "type": "string",
            "description": "MD5 hash of AccountNumber + APIKey + SubmissionNumber."
          },
          "ApplicationID": {
            "type": "string",
            "description": "Your registered application ID."
          }
        },
        "required": ["AccNumber", "MD5Value", "ApplicationID"]
      },
      "GenericResponse": {
        "type": "object",
        "properties": {
          "Header": {
            "$ref": "#/components/schemas/ResponseHeader"
          },
          "Body": {
            "type": "object",
            "description": "Method-specific response body."
          }
        }
      },
      "ResponseHeader": {
        "type": "object",
        "properties": {
          "MessageType": {
            "type": "string",
            "description": "The API method name."
          },
          "Errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "Code": {
            "type": "string"
          },
          "Message": {
            "type": "string"
          }
        }
      }
    }
  }
}