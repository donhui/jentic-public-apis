{
  "openapi": "3.0.3",
  "info": {
    "title": "QuickFile Accounting API",
    "description": "UK based cloud accounting software. Manage your accounts and bookkeeping in the cloud. QuickFile is simple to use, fast and free! All requests are POST with JSON bodies to method-named endpoints.",
    "version": "1.2",
    "contact": {
      "name": "QuickFile",
      "url": "https://api.quickfile.co.uk/"
    },
    "x-jentic-source-url": "http://api.quickfile.co.uk/"
  },
  "servers": [
    {
      "url": "https://api.quickfile.co.uk",
      "description": "QuickFile API Server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {"name": "Bank", "description": "Bank account and transaction methods"},
    {"name": "Client", "description": "Client management methods"},
    {"name": "Document", "description": "Document upload methods"},
    {"name": "Estimate", "description": "Estimate management methods"},
    {"name": "Invoice", "description": "Invoice management methods"},
    {"name": "Item", "description": "Inventory item and task methods"},
    {"name": "Journal", "description": "Journal management methods"},
    {"name": "Ledger", "description": "Ledger query methods"},
    {"name": "Payment", "description": "Payment management methods"},
    {"name": "Purchase", "description": "Purchase invoice methods"},
    {"name": "PurchaseOrder", "description": "Purchase order methods"},
    {"name": "Report", "description": "Reporting methods"},
    {"name": "Supplier", "description": "Supplier management methods"},
    {"name": "System", "description": "System utility methods"}
  ],
