{
  "openapi": "3.0.3",
  "info": {
    "title": "Odnoklassniki (OK.ru) API",
    "version": "1.0.0",
    "description": "Odnoklassniki social network REST API providing access to user profiles, friends, groups, and social data.",
    "x-jentic-source-url": "https://apiok.ru/en/dev/"
  },
  "servers": [
    {
      "url": "https://api.ok.ru"
    }
  ],
  "security": [
    {
      "oauth2": []
    }
  ],
  "tags": [
    {
      "name": "Users",
      "description": "User profile operations"
    },
    {
      "name": "Friends",
      "description": "Friend list operations"
    },
    {
      "name": "Groups",
      "description": "Group operations"
    }
  ],
  "paths": {
    "/api/users/getCurrentUser": {
      "get": {
        "operationId": "getcurrentuser",
        "summary": "Get information about current user",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "application_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "MD5 request signature"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "JSON"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/users/getLoggedInUser": {
      "get": {
        "operationId": "getloggedinuser",
        "summary": "Get current user's ID",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "application_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "uid": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/users/getInfo": {
      "get": {
        "operationId": "getuserinfo",
        "summary": "Get user information by user IDs",
        "tags": [
          "Users"
        ],
        "parameters": [
          {
            "name": "application_key",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sig",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uids",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated user IDs"
          },
          {
            "name": "fields",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated fields to return"
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "JSON"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
