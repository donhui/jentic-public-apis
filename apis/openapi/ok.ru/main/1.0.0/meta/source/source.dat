  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://connect.ok.ru/oauth/authorize",
            "tokenUrl": "https://api.ok.ru/oauth/token.do",
            "scopes": {
              "VALUABLE_ACCESS": "Access to user data",
              "SET_STATUS": "Set user status",
              "PHOTO_CONTENT": "Access photos",
              "GROUP_CONTENT": "Access group content"
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
