    "/blueprint/{blueprint_id}/budget/{format}": {
      "get": {
        "operationId": "exportBlueprintBudget",
        "summary": "Export budget for a blueprint",
        "description": "Export the budget data for a blueprint as CSV or XLSX.",
        "tags": ["Budgets"],
        "parameters": [
          {
            "name": "blueprint_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["csv", "xlsx"]
            }
          },
          {
            "name": "currency",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "USD"
            },
            "description": "ISO 4217 currency code"
          },
          {
            "name": "period",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["h", "d", "w", "m", "y"],
              "default": "m"
            },
            "description": "Billing cycle period"
          },
          {
            "name": "rate",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["effective", "stated"],
              "default": "effective"
            },
            "description": "Pricing model"
          }
        ],
        "responses": {
          "200": {
            "description": "Budget data",
            "content": {
              "text/csv": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
