{
  "openapi": "3.0.3",
  "info": {
    "title": "Cloudcraft API",
    "version": "1.0.0",
    "description": "API for managing cloud architecture diagrams, AWS/Azure accounts, blueprints, budgets, teams, and users in Cloudcraft.",
    "x-jentic-source-url": "https://docs.datadoghq.com/cloudcraft/api"
  },
  "servers": [
    {
      "url": "https://api.cloudcraft.co"
    }
  ],
  "paths": {
    "/aws/account": {
      "get": {
        "operationId": "listAwsAccounts",
        "summary": "List all AWS accounts",
        "description": "Retrieve all AWS accounts linked to the Cloudcraft account.",
        "tags": ["AWS Accounts"],
        "responses": {
          "200": {
            "description": "List of AWS accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AwsAccount"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "addAwsAccount",
        "summary": "Add an AWS account",
        "description": "Register a new AWS account with Cloudcraft.",
        "tags": ["AWS Accounts"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AwsAccountInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "AWS account created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AwsAccount"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/aws/account/iamParameters": {
      "get": {
        "operationId": "getAwsIamParameters",
        "summary": "Get IAM role parameters",
        "description": "List the parameters required to register a new IAM role in AWS.",
        "tags": ["AWS Accounts"],
        "responses": {
          "200": {
            "description": "IAM parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IamParameters"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/aws/account/{account_id}": {
      "put": {
        "operationId": "updateAwsAccount",
        "summary": "Update an AWS account",
        "description": "Update an existing AWS account linked to Cloudcraft.",
        "tags": ["AWS Accounts"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AwsAccountInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "AWS account updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AwsAccount"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteAwsAccount",
        "summary": "Delete an AWS account",
        "description": "Remove an AWS account from Cloudcraft.",
        "tags": ["AWS Accounts"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "AWS account deleted"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/aws/account/{account_id}/{region}/{format}": {
      "get": {
        "operationId": "snapshotAwsAccount",
        "summary": "Snapshot an AWS account",
        "description": "Generate a blueprint of the infrastructure in an AWS account for a given region.",
        "tags": ["AWS Accounts"],
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "region",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "AWS region, e.g. us-east-1"
          },
          {
            "name": "format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["json", "svg", "png", "pdf", "mxGraph"]
            }
          },
          {
            "name": "filter",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "exclude",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "label",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "autoconnect",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "scale",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "width",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "height",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "grid",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "transparent",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "landscape",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "paperSize",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Snapshot generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              },
              "image/svg+xml": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "202": {
            "description": "Still processing"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
