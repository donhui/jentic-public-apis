    "/blueprint/{blueprint_id}/{format}": {
      "get": {
        "operationId": "exportBlueprint",
        "summary": "Export a blueprint",
        "description": "Export a blueprint as an image or diagram format.",
        "tags": ["Blueprints"],
        "parameters": [
          {
            "name": "blueprint_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "format",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["svg", "png", "pdf", "mxGraph"]
            }
          },
          {
            "name": "scale",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "width",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "height",
            "in": "query",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "grid",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "transparent",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "landscape",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "paperSize",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Exported blueprint",
            "content": {
              "image/svg+xml": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
