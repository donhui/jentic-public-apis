  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Auth-Token",
        "description": "API key authentication token"
      }
    },
    "schemas": {
      "Plan": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "cost": {
            "type": "number"
          },
          "instance_type": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "service_type": {
            "type": "string"
          },
          "size": {
            "type": "integer"
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "accepted": {
            "type": "boolean"
          },
          "active": {
            "type": "boolean"
          },
          "company": {
            "type": "string"
          },
          "created_date": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "login": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Instance": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "service": {
            "type": "string",
            "enum": ["mongodb", "redis", "elasticsearch"]
          },
          "plan": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "zone": {
            "type": "string"
          },
          "connect_string": {
            "type": "string"
          },
          "build_state": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "encryption": {
            "type": "boolean"
          }
        }
      },
      "CreateInstanceRequest": {
        "type": "object",
        "required": ["name", "plan", "service", "type", "version", "zone"],
        "properties": {
          "name": {
            "type": "string"
          },
          "plan": {
            "type": "string"
          },
          "service": {
            "type": "string",
            "enum": ["mongodb", "redis", "elasticsearch"]
          },
          "type": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "zone": {
            "type": "string"
          },
          "encryption": {
            "type": "boolean"
          },
          "storage_engine": {
            "type": "string",
            "enum": ["mmapv1", "wiredtiger"]
          },
          "acls": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateAclRequest"
            }
          }
        }
      },
      "Acl": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "cidr_mask": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "transport": {
            "type": "boolean"
          },
          "kibana": {
            "type": "boolean"
          }
        }
      },
      "CreateAclRequest": {
        "type": "object",
        "required": ["cidr_mask", "description"],
        "properties": {
          "cidr_mask": {
            "type": "string",
            "description": "IP address or CIDR notation"
          },
          "description": {
            "type": "string"
          },
          "transport": {
            "type": "boolean",
            "description": "Elasticsearch Java transport flag"
          },
          "kibana": {
            "type": "boolean",
            "description": "Elasticsearch Kibana access flag"
          }
        }
      },
      "Database": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "sizeOnDisk": {
            "type": "integer"
          },
          "collections": {
            "type": "integer"
          },
          "objects": {
            "type": "integer"
          }
        }
      },
      "CreateDatabaseRequest": {
        "type": "object",
        "required": ["name", "username", "password"],
        "properties": {
          "name": {
            "type": "string"
          },
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "CreateCollectionRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "shard_keys": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "hashed": {
                  "type": "boolean"
                },
                "key": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CollectionStats": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "size": {
            "type": "integer"
          },
          "avgObjSize": {
            "type": "number"
          },
          "storageSize": {
            "type": "integer"
          },
          "nindexes": {
            "type": "integer"
          },
          "totalIndexSize": {
            "type": "integer"
          }
        }
      },
      "DatabaseUser": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Role"
            }
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["username", "password", "roles"],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Role"
            }
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Role"
            }
          }
        }
      },
      "Role": {
        "type": "object",
        "properties": {
          "role": {
