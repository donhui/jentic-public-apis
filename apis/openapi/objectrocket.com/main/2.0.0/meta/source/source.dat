{
  "openapi": "3.0.3",
  "info": {
    "title": "ObjectRocket API",
    "description": "REST API for ObjectRocket, a managed database hosting platform supporting MongoDB, Redis, and Elasticsearch. Provides endpoints for managing plans, accounts, instances, ACLs, databases, collections, users, monitoring, and more.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://docs.objectrocket.com/objectrocket_apidocs.html"
  },
  "servers": [
    {
      "url": "https://sjc-api.objectrocket.com/v2",
      "description": "ObjectRocket API v2 (San Jose)"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "paths": {
    "/plans/": {
      "get": {
        "operationId": "listPlans",
        "summary": "List all plans",
        "description": "Retrieves information about all available service plans.",
        "responses": {
          "200": {
            "description": "Plans retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Plan"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": ["Plans"]
      }
    },
    "/plans/{planId}/": {
      "get": {
        "operationId": "getPlan",
        "summary": "Get plan by ID",
        "description": "Retrieves detailed information for a specific plan.",
        "parameters": [
          {
            "name": "planId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plan retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Plan"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Plan not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": ["Plans"]
      }
    },
