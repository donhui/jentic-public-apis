    "/files": {
      "post": {
        "tags": [
          "Files"
        ],
        "summary": "Upload new file",
        "description": "Users can upload image files (e.g., PNG, JPEG) to the server using a POST request to this endpoint. These uploaded files are stored securely on the server for future use.",
        "operationId": "UploadFile",
        "security": [
          {
            "api_key": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/File"
          },
          "400": {
            "$ref": "#/components/responses/400_error"
          },
