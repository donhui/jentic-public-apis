            "$ref": "#/components/responses/Folders_list"
          },
          "401": {
            "$ref": "#/components/responses/401_error"
          },
          "404": {
            "$ref": "#/components/responses/404_error"
          },
          "429": {
            "$ref": "#/components/responses/429_error"
          },
          "500": {
            "$ref": "#/components/responses/500_error"
          },
          "501": {
            "$ref": "#/components/responses/501_error"
          }
        },
        "x-codeSamples": [
          {
            "lang": "PHP",
            "source": "use GuzzleHttp\\Client;\n\n$client = new Client();\n\n$response = $client->request('GET', 'https://api.openqr.io/api/v1/folders',\n[\n    'headers' => [\n        'Authorization' => 'Bearer api_key',\n        'Accept' => 'application/json',\n    ]\n]);\n\necho $response->getBody()->getContents();"
          }
        ]
      }
    },
