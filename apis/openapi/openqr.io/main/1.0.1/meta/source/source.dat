          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "api_key": {
        "name": "Authorization",
        "type": "Authorization",
        "in": "header",
        "description": "Example: `Authorization: Bearer api_key`"
      }
    },
    "requestBodies": {
      "Folder": {
        "description": "Request body to save Folder",
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "description": "Folder name",
                  "type": "string",
                  "maxLength": 255,
                  "minLength": 5,
                  "required": true,
                  "example": "demo"
                }
              },
              "required": [
                "name"
              ]
            }
          }
        }
      },
      "QRCode": {
        "description": "Request body to save QR Code",
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "description": "QR code name",
                  "type": "string",
                  "maxLength": 255,
                  "minLength": 5,
                  "required": true,
                  "example": "Demo"
                },
                "type": {
                  "$ref": "#/components/schemas/QRCodeType"
                },
                "data": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/TypeUrlData"
                    },
                    {
                      "$ref": "#/components/schemas/TypeTextData"
                    },
                    {
                      "$ref": "#/components/schemas/TypeCallData"
                    },
                    {
                      "$ref": "#/components/schemas/TypeEmailData"
                    },
                    {
                      "$ref": "#/components/schemas/TypeEventData"
                    },
                    {
                      "$ref": "#/components/schemas/TypeGeoData"
                    },
                    {
                      "$ref": "#/components/schemas/TypeSMSData"
                    },
                    {
                      "$ref": "#/components/schemas/TypeVCardData"
                    },
                    {
                      "$ref": "#/components/schemas/TypeWIFIData"
                    }
                  ]
                },
                "design": {
                  "$ref": "#/components/schemas/QRCodeDesign"
                }
              },
              "required": [
                "name",
                "type",
                "data"
              ]
            }
          }
        }
      },
      "File": {
        "description": "Request body to upload file",
        "required": true,
        "content": {
          "multipart/form-data": {
            "schema": {
              "type": "object",
              "properties": {
                "file": {
                  "description": "File to upload. Accept only `PNG` and `JPEG` file formats and max size `5MB`",
                  "type": "string",
                  "format": "binary",
                  "maxSize": 5242880
                }
              },
              "required": [
                "file"
              ]
            }
          }
        }
      }
    },
    "schemas": {
      "Folder": {
        "type": "object",
        "description": "Folder object",
        "properties": {
          "id": {
            "description": "Object id",
            "type": "integer",
            "example": 6
          },
          "name": {
            "description": "Folder name",
            "type": "string",
            "maxLength": 255,
            "minLength": 5,
            "required": true,
            "example": "Demo"
          },
          "created_at": {
            "description": "When folder was created",
            "type": "string",
            "format": "date-time",
            "example": "2023-07-31T19:32:06.000000Z"
          }
        }
      },
      "Problem": {
        "type": "object",
        "description": "Problem described in JSON format .",
        "properties": {
          "message": {
            "type": "string",
            "description": "The error message."
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "links": {
            "type": "object",
            "properties": {
              "first": {
                "description": "First page link",
                "type": "string",
                "nullable": true,
                "example": 6
              },
              "last": {
                "description": "Last page link",
                "type": "string",
                "nullable": true,
                "example": 6
              },
              "prev": {
                "description": "Previous page link",
                "type": "string",
                "nullable": true,
                "example": null
              },
              "next": {
                "description": "Next page link",
                "type": "string",
                "nullable": true,
                "example": "https://api.openqr.io/api/v1/qr-codes?cursor=eyJjcmVhdGVkX2F0IjoiMjAyMy0wNy0zMCAxMDoyNjoxMCIsIl9wb2ludHNUb05leHRJdGVtcyI6dHJ1ZX0"
              }
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "path": {
                "description": "Link for pagination",
                "type": "string",
                "nullable": true,
                "example": "https://api.openqr.io/api/v1/qr-codes"
              },
              "per_page": {
                "description": "Items per page count",
                "type": "integer",
                "nullable": true,
                "example": 20
              },
              "next_cursor": {
                "description": "Next page cursor ID of the pagination",
                "type": "string",
                "nullable": true,
                "example": "eyJjcmVhdGVkX2F0IjoiMjAyMy0wNy0zMCAxMDoyNjoxMCIsIl9wb2ludHNUb05leHRJdGVtcyI6dHJ1ZX0"
              },
              "prev_cursor": {
                "description": "previous cursor ID of the pagination",
                "type": "string",
                "nullable": true,
                "example": "eyJjcmVhdGVkX2F0IjoiMjAyMy0wNy0zMCAxMDoyNjoxMCIsIl9wb2ludHNUb05leHRJdGVtcyI6dHJ1ZX0"
              }
            }
          }
        }
      },
      "QRCodeType": {
        "type": "string",
        "enum": [
          "call",
          "call_static",
          "email",
          "email_static",
          "event",
          "event_static",
          "geo",
          "geo_static",
          "sms",
          "sms_static",
          "text",
          "text_static",
          "url",
          "url_static",
          "vcard",
          "vcard_static",
          "wifi",
          "wifi_static"
        ],
        "example": "url"
      },
      "QRCode": {
        "type": "object",
        "description": "QR Code object",
        "properties": {
          "id": {
            "type": "string",
            "example": "km0yYX0"
          },
          "name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 5,
            "nullable": false,
            "example": "Demo"
          },
          "status": {
            "type": "string",
            "nullable": false,
            "enum": [
              "public",
              "archived"
            ],
            "example": "public"
          },
          "dynamic": {
            "type": "boolean",
            "nullable": false,
            "enum": [
              true,
              false
            ],
            "example": true
          },
          "qr_code_folder_id": {
            "nullable": true,
            "type": "integer"
          },
          "type": {
            "$ref": "#/components/schemas/QRCodeType"
          },
          "image": {
            "type": "string",
            "nullable": false,
            "format": "url",
            "example": "https://cdn.openqr.io/assets/qrcode_files/jk/m0/km0yYX0.svg"
          },
          "created_at": {
            "type": "string",
            "nullable": false,
            "format": "date-time",
            "example": "2023-07-30T10:26:10.000000Z"
          },
          "updated_at": {
            "type": "string",
            "nullable": false,
            "format": "date-time",
            "example": "2023-07-30T10:26:10.000000Z"
          }
        }
      },
      "TypeUrlData": {
        "type": "object",
        "title": "URL QR Code Static/Dynamic type",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "description": "URL QR Code",
            "type": "string",
            "maxLength": 350,
            "required": true,
            "example": "https://openqr.io"
          }
        }
      },
      "TypeTextData": {
        "type": "object",
        "title": "Text QR Code Static/Dynamic type",
        "required": "text",
        "properties": {
          "text": {
            "description": "Qr Code text",
            "type": "string",
            "maxLength": 350,
            "required": true,
            "example": "Demo"
          }
        }
      },
      "TypeCallData": {
        "type": "object",
        "title": "Call QR Code Static/Dynamic type",
        "required": "phone",
        "properties": {
          "phone": {
            "description": "Phone number",
            "type": "string",
            "maxLength": 32,
            "minLength": 3,
            "required": true,
            "example": "+1234567890"
          }
        }
      },
      "TypeEmailData": {
        "type": "object",
        "title": "Email QR Code Static/Dynamic type",
        "required": [
          "email",
          "subject",
          "message"
        ],
        "properties": {
          "email": {
            "description": "Email",
            "type": "string",
            "example": "info@openqr.io"
          },
          "subject": {
            "description": "Email subject",
            "type": "string",
            "maxLength": 180,
            "example": "Subject of the email"
          },
          "message": {
            "description": "Email subject",
            "type": "string",
            "maxLength": 500,
            "example": "Email message"
          }
        }
      },
      "TypeEventData": {
        "type": "object",
        "title": "Event QR Code Static/Dynamic type",
        "required": [
          "title",
          "location",
          "start_at"
        ],
        "properties": {
          "title": {
            "description": "Event title",
            "type": "string",
            "maxLength": 100,
            "example": "OpenQR event"
          },
          "description": {
            "description": "Event description",
            "type": "string",
            "maxLength": 200,
            "example": "OpenQR event description"
          },
          "location": {
            "description": "Event location",
            "type": "string",
            "maxLength": 100,
            "example": "London"
          },
          "start_at": {
            "description": "Event start date",
            "type": "date",
            "example": "2023-08-22T21:04:00.000Z"
          },
          "end_at": {
            "description": "Event end date",
            "type": "date",
            "example": "2023-08-22T21:04:00.000Z"
          }
        }
      },
      "TypeGeoData": {
        "type": "object",
        "title": "Geo QR Code Static/Dynamic type",
        "required": [
          "lat",
          "long"
        ],
        "properties": {
          "lat": {
            "description": "Latitude",
            "type": "number",
            "maxLength": 90,
            "example": 10.33
          },
          "long": {
            "description": "Longitude",
            "type": "number",
            "maxLength": 180,
            "example": 53.23
          }
        }
      },
      "TypeSMSData": {
        "type": "object",
        "title": "SMS QR Code Static/Dynamic type",
        "required": [
          "phone",
          "message"
        ],
        "properties": {
          "phone": {
            "description": "Phone number",
            "type": "string",
            "maxLength": 32,
            "minLength": 3,
            "example": "+1234567890"
          },
          "message": {
            "description": "Message text",
            "type": "string",
            "maxLength": 500,
            "example": "SMS message text"
          }
        }
      },
      "TypeVCardData": {
        "type": "object",
        "title": "VCard QR Code Static/Dynamic type",
        "required": [
          "firstName",
          "lastName"
        ],
        "properties": {
          "firstName": {
            "description": "First name",
            "type": "string",
            "maxLength": 200,
            "example": "Name"
          },
          "lastName": {
            "description": "Last name",
            "type": "string",
            "maxLength": 200,
            "example": "Last name"
          },
          "mobile": {
            "description": "Mobile phone number",
            "type": "string",
            "maxLength": 32,
            "example": 1234567890
          },
          "phone": {
            "description": "Phone number",
            "type": "string",
            "maxLength": 32,
            "example": 1234567890
          },
          "fax": {
            "description": "Fax",
            "type": "string",
            "maxLength": 32,
            "example": 1234565
          },
          "email": {
            "description": "Email",
            "type": "string",
            "maxLength": 200,
            "example": "info@openqr.io"
          },
          "company": {
            "description": "Company name",
            "type": "string",
            "maxLength": 200,
            "example": "OpenQR"
          },
          "job": {
            "description": "Job title",
            "type": "string",
            "maxLength": 200,
            "example": "Developer"
          },
          "street": {
            "description": "Street name",
            "type": "string",
            "maxLength": 200,
            "example": "Street name"
          },
          "city": {
            "description": "City name",
            "type": "string",
            "maxLength": 200,
            "example": "City"
          },
          "zip": {
            "description": "ZIP code",
            "type": "string",
            "maxLength": 200,
            "example": "123WR"
          },
          "state": {
            "description": "State",
            "type": "string",
            "maxLength": 200,
            "example": "State"
          },
          "country": {
            "description": "Country name",
            "type": "string",
            "maxLength": 200,
            "example": "Country"
          },
          "website": {
            "description": "Website url",
            "type": "string",
            "maxLength": 200,
            "example": "https://openqr.io"
          }
        }
      },
      "TypeWIFIData": {
        "type": "object",
        "title": "WIFI QR Code Static type",
        "required": [
          "ssid",
          "type"
        ],
        "properties": {
          "ssid": {
            "description": "SSID name",
            "type": "string",
            "maxLength": 200,
            "example": "WIFI_NAME"
          },
          "type": {
            "description": "WIFI type",
            "type": "string",
            "enum": [
              "nopass",
              "WEB",
              "WPA"
            ],
            "example": "WEB"
          },
          "password": {
            "description": "WIFI password",
            "type": "string",
            "example": "jk230iNM23"
          },
          "hidden": {
            "description": "Is WIFI hidden",
            "type": "boolean",
            "enum": [
              true,
              false
            ],
            "example": true
          }
        }
      },
      "QRCodeDesign": {
        "type": "object",
        "properties": {
          "background_color": {
            "type": "string",
            "nullable": true,
            "default": "#FFFFFF",
            "example": "#FFFFFF"
          },
          "eye_external_color": {
            "type": "string",
            "nullable": true,
            "default": "#000000",
            "example": "#25d0ae"
          },
          "eye_internal_color": {
            "type": "string",
            "nullable": true,
            "default": "#000000",
            "example": "#46bece"
          },
          "module": {
            "type": "string",
            "nullable": true,
            "default": "default",
            "enum": [
              "default",
              "dots",
              "diamond",
              "fourTriangles",
              "triangle",
              "triangleEnd",
              "tree",
              "rhombus",
              "fish",
              "twoTrianglesWithCircle",
              "roundness",
              "star5",
              "star7",
              "verticalLines",
              "horizontalLines"
            ],
            "description": "<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/square.png\" alt=\"Default square\" width=\"50\"/>     **default** This is default value of dot module.\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/dots.png\" alt=\"Dot\" width=\"50\"/>     **dots**   \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/diamond.png\" alt=\"Diamond\" width=\"50\"/>     **diamond**  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/fourTriangles.png\" alt=\"Four triangles\" width=\"50\"/>     **fourTriangles** \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/triangle.png\" alt=\"Triangles\" width=\"50\"/>     **triangle**  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/triangleEnd.png\" alt=\"Triangle end\" width=\"50\"/>     **triangleEnd** \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/tree.png\" alt=\"Tree\" width=\"50\"/>     **tree**  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/rhombus.png\" alt=\"Rhombus\" width=\"50\"/>     **rhombus**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/fish.png\" alt=\"Fish\" width=\"50\"/>     **fish**  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/twoTrianglesWithCircle.png\" alt=\"Two triangles with circle\" width=\"50\"/>     **twoTrianglesWithCircle**  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/roundness.png\" alt=\"Roundness\" width=\"50\"/>     **roundness**  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/star5.png\" alt=\"Five stars\" width=\"50\"/>     **star5** \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/star7.png\" alt=\"Seven stars\" width=\"50\"/>     **star7**   \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/verticalLines.png\" alt=\"Vertical Lines\" width=\"50\"/>     **verticalLines**   \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/dots/horizontalLines.png\" alt=\"Horizontal Lines\" width=\"50\"/>     **horizontalLines**\n"
          },
          "finder": {
            "type": "string",
            "nullable": true,
            "default": "default",
            "enum": [
              "default",
              "circle-dots",
              "circle",
              "eye-shaped",
              "rounded-corners",
              "water-drop",
              "whirlpool",
              "zigzag",
              "octagon"
            ],
            "description": "Available markers:\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finders/default.png\" alt=\"Default square\" width=\"50\"/>     **default** This is default value of finder dot.\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finders/circle-dots.png\" alt=\"circle-dots\" width=\"50\"/>     **circle-dots** \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finders/circle.png\" alt=\"circle\" width=\"50\"/>     **circle** \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finders/eye-shaped.png\" alt=\"eye-shaped\" width=\"50\"/>     **eye-shaped**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finders/rounded-corners.png\" alt=\"rounded-corners\" width=\"50\"/>     **rounded-corners**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finders/water-drop.png\" alt=\"water-drop\" width=\"50\"/>     **water-drop**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finders/whirlpool.png\" alt=\"whirlpool\" width=\"50\"/>     **whirlpool**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finders/zigzag.png\" alt=\"zigzag\" width=\"50\"/>     **zigzag** \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finders/octagon.png\" alt=\"octagon\" width=\"50\"/>     **octagon**\n  \n"
          },
          "finder_dot": {
            "type": "string",
            "nullable": true,
            "default": "default",
            "enum": [
              "default",
              "circle",
              "eye-shaped",
              "rounded-corners",
              "water-drop",
              "whirlpool",
              "zigzag",
              "octagon"
            ],
            "description": "<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finderDots/default.png\" alt=\"Default finder\" width=\"50\"/>     **default** This is default value of finder.    \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finderDots/circle.png\" alt=\"circle\" width=\"50\"/>     **circle**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finderDots/eye-shaped.png\" alt=\"eye-shaped\" width=\"50\"/>     **eye-shaped**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finderDots/rounded-corners.png\" alt=\"rounded-corners\" width=\"50\"/>     **rounded-corners**  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finderDots/rounded-corners.png\" alt=\"rounded-corners\" width=\"50\"/>     **rounded-corners**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finderDots/water-drop.png\" alt=\"water-drop\" width=\"50\"/>     **water-drop**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finderDots/whirlpool.png\" alt=\"whirlpool\" width=\"50\"/>     **whirlpool**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finderDots/zigzag.png\" alt=\"zigzag\" width=\"50\"/>     **zigzag**\n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/finderDots/octagon.png\" alt=\"octagon\" width=\"50\"/>     **octagon**\n"
          },
          "foreground_color": {
            "type": "string",
            "nullable": true,
            "default": "#000000",
            "example": "#d32727"
          },
          "frame": {
            "type": "string",
            "nullable": true,
            "default": "none",
            "enum": [
              "none",
              "simple-text-bottom",
              "simple-text-top",
              "border-around-text-bottom",
              "border-around-text-top",
              "arrow-text-bottom-frame"
            ],
            "description": "<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/frames/none.png\" alt=\"Default without frame\" width=\"50\"/>     **none** This is default value of frame. QR Code will be rendered in default mode.  \n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/frames/simple-text-bottom.png\" alt=\"With the text in the bottom\" width=\"50\"/>     **simple-text-bottom** With the text in the bottom  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/frames/simple-text-top.png\" alt=\"With the text in the top\" width=\"50\"/>   **simple-text-top** With the text in the top  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/frames/border-around-text-bottom.png\" alt=\"With the border around and text in the bottom\" width=\"50\"/>   **border-around-text-bottom** With the border around and text in the bottom  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/frames/border-around-text-top.png\" alt=\"With hte border around and text in the top\" width=\"50\"/>   **border-around-text-top** With hte border around and text in the top  \n\n<img align=\"center\" src=\"https://cdn.openqr.io/qrcode_design/frames/arrow-text-bottom-frame.png\" alt=\"With hte arrow in the right and text in the bottom\" width=\"50\"/>   **arrow-text-bottom-frame** With hte arrow in the right and text in the bottom\n"
          },
          "frame_color": {
            "type": "string",
            "nullable": true,
            "default": "#000000",
            "example": "#000000"
          },
          "frame_font_family": {
            "type": "string",
            "nullable": true,
            "description": "One of Google fonts",
            "default": "Raleway",
            "example": "Raleway"
          },
          "frame_font_variant": {
            "type": "string",
            "nullable": true,
            "example": "900"
          },
          "frame_text": {
            "type": "string",
            "nullable": true,
            "default": "SCAN ME",
            "example": "SCAN ME"
          },
          "frame_text_background_color": {
            "type": "string",
            "nullable": true,
            "default": "#000000",
            "example": "#ffffff"
          },
          "frame_text_color": {
            "type": "string",
            "nullable": true,
            "default": "#000000",
            "example": "#000000"
          },
          "frame_text_size": {
            "type": "integer",
            "nullable": true,
            "default": 0,
            "maximum": 2,
            "minimum": 0,
            "example": 0
          },
          "logo_id": {
            "nullable": true,
            "type": "string",
            "default": null,
            "description": "This value can be get from other API endpoint [`Files`](/#tag/Files)",
            "example": "none"
          },
          "logo_background_fill": {
            "nullable": true,
            "type": "string",
            "default": "#ffffff",
            "example": "#ffffff"
          },
          "logo_background_shape": {
            "type": "string",
            "nullable": true,
            "default": "circle",
            "enum": [
              "circle",
              "square"
            ]
          }
        }
      },
      "File": {
        "type": "object",
        "description": "File object",
        "properties": {
          "id": {
            "description": "Object id",
            "type": "string",
            "example": "XzC1zPwH"
          },
          "name": {
            "description": "File name",
            "type": "string",
            "maxLength": 255,
            "minLength": 5,
            "required": true,
            "example": "8087415_(1).png"
          },
          "mime_type": {
            "description": "File mime type",
            "type": "string",
            "required": true,
            "example": "image/png"
          },
          "url": {
            "description": "Original file URL. If it is image, it will be max 800px width and max 800px height.",
            "type": "string",
            "required": true,
            "nullable": false,
            "example": "https://cdn.openqr.io/assets/files/2023/1/qr_code/logo/XzC1zPwH.png"
          },
          "public": {
            "description": "Show is file preset or user uploaded. `true` - preset, `false` - user uploaded file",
            "type": "boolean",
            "example": true
          }
        }
      }
    },
    "responses": {
      "Folder": {
        "description": "Folder",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "$ref": "#/components/schemas/Folder"
                }
              }
            }
          }
        }
      },
      "400_error": {
        "description": "Bad Request - The request could not be understood by the server. Incoming parameters might not be valid",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "401_error": {
        "description": "Unauthorized - The supplied credentials, if any, are not sufficient to access the resource",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "429_error": {
        "description": "Too Many Requests - Too many requests have been made in a short period of time (Throttling)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "500_error": {
        "description": "Server Error - The server could not return the representation due to an internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "501_error": {
        "description": "Not Implemented - The requested operation is not supported",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "Folders_list": {
        "description": "Folders list",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Folder"
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "$ref": "#/components/schemas/Pagination"
                }
              ]
            }
          }
        }
      },
      "404_error": {
        "description": "Not found - The requested resource is not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Problem"
            }
          }
        }
      },
      "QRCode_list": {
        "description": "QR Codes list",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/QRCode"
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "$ref": "#/components/schemas/Pagination"
                }
              ]
            }
          }
        }
      },
      "QRCode": {
        "description": "QR Code",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "$ref": "#/components/schemas/QRCode"
                }
              }
            }
          }
        }
      },
      "Files_list": {
        "description": "Files",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/File"
                      }
                    }
                  }
                },
                {
                  "type": "object",
                  "$ref": "#/components/schemas/Pagination"
                }
              ]
            }
          }
        }
      },
      "File": {
        "description": "File",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "$ref": "#/components/schemas/File"
                }
              }
            }
          }
        }
      }
    }
  }
}