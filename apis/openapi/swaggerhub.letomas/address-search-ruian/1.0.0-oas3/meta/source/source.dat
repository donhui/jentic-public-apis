{
  "openapi": "3.0.0",
  "info": {
    "description": "This is an API for searching addresses (\"adresn\u00ed m\u00edsta\") in the Czech registry RUIAN (Registry of Territorial Identification, Addresses and Real Estates).",
    "version": "1.0.0-oas3",
    "title": "RUIAN address search API",
    "contact": {
      "email": "letomas1998@gmail.com"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/letomas/Address-search-RUIAN/1.0.0-oas3/swagger.json"
  },
  "tags": [
    {
      "name": "Addresses"
    },
    {
      "name": "Suggestions"
    }
  ],
  "paths": {
    "/addresses": {
      "get": {
        "tags": [
          "Addresses"
        ],
        "summary": "search address by address code",
        "operationId": "searchAddressByCode",
        "description": "By passing the admCode parameter, you can find addresses that have their code\nstarting with the parameter's value.\n",
        "parameters": [
          {
            "in": "query",
            "name": "admCode",
            "description": "A number with which the address code could should begin with",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": 215
          }
        ],
        "responses": {
          "200": {
            "description": "Page containing addresses matching the criteria",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                }
              }
            }
          },
          "400": {
            "description": "Required String parameter 'admCode' is not present"
          }
        }
      }
    },
    "/addresses/{admCode}": {
      "get": {
        "tags": [
          "Addresses"
        ],
        "summary": "information for address",
        "operationId": "getAddressDetail",
        "description": "Returns information for an address given it's unique identifier as a path parameter.",
        "parameters": [
          {
            "in": "path",
            "name": "admCode",
            "description": "Address's unique identifier (*k\u00f3d adresn\u00edho m\u00edsta*).",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "example": 28344987
          }
        ],
        "responses": {
          "200": {
            "description": "Address with matching address code",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Address"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input parameter"
          }
        }
      }
    },
    "/addresses/search": {
      "get": {
        "tags": [
          "Addresses"
        ],
        "summary": "search address by address elements",
        "operationId": "searchAddresses",
        "parameters": [
          {
            "in": "query",
            "name": "city",
            "description": "Specify address's city (*obec*)",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "Praha"
          },
          {
            "in": "query",
            "name": "district",
            "description": "Specify address's district (*\u010d\u00e1st obce*)",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "B\u0159evnov"
          },
          {
            "in": "query",
            "name": "street",
            "description": "Specify address's street (*ulice*)",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "Olympijsk\u00e1"
          },
          {
            "in": "query",
            "name": "houseNumber",
            "description": "Specify address's house number (*\u010d\u00edslo domovn\u00ed*), orientational number(*\u010d\u00edslo orienta\u010dn\u00ed*) or both",
            "required": false,
            "schema": {
              "type": "string"
            },
            "examples": {
              "House Number": {
                "value": 1901
              },
              "Orientational Number": {
                "value": 5
              },
              "House and Orientational Number": {
                "value": "2390/2a"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Page of addresses matching the given query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                }
              }
            }
          }
        }
      }
    },
    "/addresses/nearby": {
      "get": {
        "tags": [
          "Addresses"
        ],
        "summary": "search addresses nearby a point",
        "operationId": "findNearbyAddresses",
        "description": "Given GPS coordinates of a point in decimal degrees, finds addresses within a radius defined by distance.\n",
        "parameters": [
          {
            "in": "query",
            "name": "x",
            "description": "Coordinate X in decimal degrees.",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "example": 49.675549
          },
          {
            "in": "query",
            "name": "y",
            "description": "Coordinate Y in decimal degrees.",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "example": 13.223479
          },
          {
            "in": "query",
            "name": "distance",
            "description": "Distance in kilometers. Defines radius of the search.",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            },
            "example": 0.2
          }
        ],
        "responses": {
          "200": {
            "description": "Page of addresses within the given distance of the point.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Page"
                }
              }
            }
          },
          "400": {
            "description": "Bad input parameters"
          }
        }
      }
    },
    "/suggestions/city": {
      "get": {
        "tags": [
          "Suggestions"
        ],
        "summary": "suggest city names",
        "operationId": "citySuggestions",
        "description": "Returns a list of city names that start with the given string parameter `city`.",
        "parameters": [
          {
            "in": "query",
            "name": "city",
            "description": "String with which the city name should begin with.",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "Prah"
          }
        ],
        "responses": {
          "200": {
            "description": "City suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "Adamov",
                    "Albrechtice",
                    "Albrechtice nad Vltavou",
                    "Abertamy",
                    "And\u011blsk\u00e1 Hora",
                    "Albrechtice nad Orlic\u00ed",
                    "Adr\u0161pach",
                    "Arnoltice",
                    "Alojzov",
                    "Arne\u0161tovice"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Required String parameter 'city' is not present"
          }
        }
      }
    },
    "/suggestions/district": {
      "get": {
        "tags": [
          "Suggestions"
        ],
        "summary": "suggest district names",
        "operationId": "districtSuggestions",
        "description": "Returns a list of district names that start with the given string parameter `district`. If parameter `city` is defined, only the districts from that city are returned.",
        "parameters": [
          {
            "in": "query",
            "name": "city",
            "description": "City name used as a filter to suggest districts. Needs to be exact term. Case sensitive.",
            "required": false,
            "example": "Praha",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "district",
            "description": "String with which the district name should begin with.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "Hr"
          }
        ],
        "responses": {
          "200": {
            "description": "District suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "Stra\u0161nice",
                    "Vinohrady",
                    "Nov\u00e9 M\u011bsto",
                    "Nusle",
                    "Star\u00e9 M\u011bsto",
                    "Vyso\u010dany",
                    "Mal\u00e1 Strana",
                    "Hrad\u010dany",
                    "Vy\u0161ehrad",
                    "Josefov"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/suggestions/street": {
      "get": {
        "tags": [
          "Suggestions"
        ],
        "summary": "suggest street names",
        "operationId": "streetSuggestions",
        "description": "Returns a list of street names that start with the given string parameter `street`. If parameters `city` and `district` are defined, only the streets from that city and district are returned.",
        "parameters": [
          {
            "in": "query",
            "name": "city",
            "description": "City name used as a filter to suggest streets. Needs to be exact term. Case sensitive.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "Praha"
          },
          {
            "in": "query",
            "name": "district",
            "description": "District name used as a filter to suggest streets. Needs to be exact term. Case sensitive.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "Hrad\u010dany"
          },
          {
            "in": "query",
            "name": "street",
            "description": "String with which the street name should begin with.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "j"
          }
        ],
        "responses": {
          "200": {
            "description": "Street suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "Rokycanova",
                    "Rolnick\u00e1",
                    "Rovn\u00e1",
                    "Ro\u017emit\u00e1lsk\u00e1",
                    "Rosick\u00e1",
                    "Rozvojov\u00e1",
                    "Ropick\u00e1",
                    "Ro\u017ekova",
                    "Rokosovsk\u00e9ho",
                    "Ros\u016flkova"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/suggestions/houseNumber": {
      "get": {
        "tags": [
          "Suggestions"
        ],
        "summary": "suggest house identification",
        "operationId": "houseNumberSuggestions",
        "description": "Returns a list of house identifications (combination of house number, orientational number and orientational number letter) that start with the given string parameter `house number`. If parameters `city`, `district` or `street` are defined, only the house identifications from that city, district and street are returned.",
        "parameters": [
          {
            "in": "query",
            "name": "city",
            "description": "City name used as a filter to suggest house numbers. Needs to be exact term. Case sensitive.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "Praha"
          },
          {
            "in": "query",
            "name": "district",
            "description": "District name used as a filter to suggest house numbers. Needs to be exact term. Case sensitive.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "Hrad\u010dany"
          },
          {
            "in": "query",
            "name": "street",
            "description": "Street name used as a filter to suggest house numbers. Needs to be exact term. Case sensitive.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "Jelen\u00ed"
          },
          {
            "in": "query",
            "name": "houseNumber",
            "description": "String with which the house/orientational number should begin with.",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": 9
          }
        ],
        "responses": {
          "200": {
            "description": "House number suggestions",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "example": [
                    "181/2",
                    "275/1",
                    "276/3",
                    "345/6",
                    "346/4",
                    "368/5",
                    "369/7",
                    "370/9",
                    "371/11",
                    "404/13"
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "https://hled\u00e1n\u00ed.r\u00faian.opendata.cz/api"
    }
  ],
  "components": {
    "schemas": {
      "Page": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Address"
            }
          },
          "pageable": {
            "type": "object",
            "properties": {
              "sort": {
                "$ref": "#/components/schemas/Sort"
              },
              "pageNumber": {
                "type": "integer",
                "example": 0
              },
              "pageSize": {
                "type": "integer",
                "example": 10
              },
              "offset": {
                "type": "integer",
                "example": 0
              },
              "unpaged": {
                "type": "boolean",
                "example": false
              },
              "paged": {
                "type": "boolean",
                "example": true
              }
            }
          },
          "facetResultPages": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "example": []
          },
          "facetQueryResult": {
            "$ref": "#/components/schemas/FacetQueryResult"
          },
          "highlited": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          },
          "maxScore": {
            "type": "object",
            "example": null
          },
          "fieldStatsResults": {
            "type": "object",
            "example": {}
          },
          "suggestions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          },
          "facetFields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          },
          "facetPivotFields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": []
          },
          "totalElements": {
            "type": "integer",
            "example": 1
          },
          "totalPages": {
            "type": "integer",
            "example": 1
          },
          "sort": {
            "$ref": "#/components/schemas/Sort"
          },
          "numberOfElements": {
            "type": "integer",
            "example": 10
          },
          "first": {
            "type": "boolean",
            "example": true
          },
          "last": {
            "type": "boolean",
            "example": true
          },
          "size": {
            "type": "integer",
            "example": 10
          },
          "number": {
            "type": "integer",
            "example": 0
          },
          "empty": {
            "type": "boolean",
            "example": false
          }
        }
      },
      "Address": {
        "type": "object",
        "required": [
          "id",
          "admCode",
          "cityName",
          "buildingType",
          "houseNumber",
          "postalCode",
          "identification"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "ee913b3e-d8ef-4422-8b17-42f6871479ee"
          },
          "admCode": {
            "type": "integer",
            "example": 2198371
          },
          "cityName": {
            "type": "string",
            "example": "Praha"
          },
          "boroughName": {
            "type": "string",
            "example": "Praha 6"
          },
          "pragueBoroughName": {
            "type": "string",
            "example": "Praha 6"
          },
          "districtName": {
            "type": "string",
            "example": "Dejvice"
          },
          "streetName": {
            "type": "string",
            "example": "Na Fi\u0161erce"
          },
          "buildingType": {
            "type": "string",
            "enum": [
              "\u010d.p.",
              "\u010d.ev."
            ],
            "example": "\u010d.p."
          },
          "houseNumber": {
            "type": "integer",
            "example": 22
          },
          "orientationalNumber": {
            "type": "integer",
            "example": 15
          },
          "orientationalNumberLetter": {
            "type": "string",
            "example": "a"
          },
          "postalCode": {
            "type": "integer",
            "example": 16000
          },
          "coordinateX": {
            "type": "number",
            "format": "double",
            "example": 1039875.33
          },
          "coordinateY": {
            "type": "number",
            "format": "double",
            "example": 745238.91
          },
          "coordinatesLatLon": {
            "$ref": "#/components/schemas/Coordinates"
          },
          "identification": {
            "type": "string",
            "example": "22/15a"
          }
        }
      },
      "Coordinates": {
        "required": [
          "x",
          "y"
        ],
        "properties": {
          "x": {
            "type": "number",
            "format": "double",
            "example": 50.1124277
          },
          "y": {
            "type": "number",
            "format": "double",
            "example": 14.381625
          }
        }
      },
      "Sort": {
        "type": "object",
        "properties": {
          "sorted": {
            "type": "boolean",
            "example": false
          },
          "unsorted": {
            "type": "boolean",
            "example": true
          },
          "empty": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "FacetQueryResult": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "example": []
          },
          "pageable": {
            "type": "string",
            "example": "INSTANCE"
          },
          "totalElements": {
            "type": "integer",
            "example": 0
          },
          "totalPages": {
            "type": "integer",
            "example": 1
          },
          "last": {
            "type": "boolean",
            "example": true
          },
          "sort": {
            "$ref": "#/components/schemas/Sort"
          },
          "numberOfElements": {
            "type": "integer",
            "example": 0
          },
          "first": {
            "type": "boolean",
            "example": true
          },
          "size": {
            "type": "integer",
            "example": 0
          },
          "number": {
            "type": "integer",
            "example": 0
          },
          "empty": {
            "type": "boolean",
            "example": true
          }
        }
      }
    }
  }
}