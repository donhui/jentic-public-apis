        },
        "type": "object",
        "properties": {
          "node": {
            "type": "object",
            "properties": {
              "id": {
                "description": "Department id",
                "type": "integer"
              },
              "name": {
                "description": "Department name",
                "type": "string",
                "maxLength": 255,
                "minLength": 1
              },
              "url": {
                "description": "Department URL",
                "type": "string",
                "format": "uri"
              }
            }
          },
          "children": {
            "description": "List of all children departments.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DepartmentTreeNode"
