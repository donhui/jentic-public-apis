{
  "openapi": "3.0.3",
  "info": {
    "title": "Spacebin API",
    "description": "Spacebin is a modern Pastebin server. This API allows creating and retrieving text documents (pastes).",
    "version": "1.0.0",
    "x-jentic-source-url": "https://github.com/spacebin-org/spirit"
  },
  "servers": [
    {
      "url": "https://spaceb.in",
      "description": "Public Spacebin instance"
    }
  ],
  "paths": {
    "/api/": {
      "post": {
        "operationId": "createDocument",
        "summary": "Create a new document",
        "description": "Creates a new paste document. Accepts JSON or multipart/form-data with content in a 'content' field.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": {
                    "type": "string",
                    "description": "The text content of the document"
                  }
                }
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": {
                    "type": "string",
                    "description": "The text content of the document"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/{documentId}": {
      "get": {
        "operationId": "getDocument",
        "summary": "Fetch a document",
        "description": "Retrieves the content and metadata of a document by its ID.",
        "parameters": [
          {
            "name": "documentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The document identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Document retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Document not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/{documentId}/raw": {
      "get": {
        "operationId": "getDocumentRaw",
        "summary": "Fetch a document as raw text",
        "description": "Returns the plain text content of a document.",
        "parameters": [
          {
            "name": "documentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The document identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Raw document content",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Document not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Document": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique document identifier"
          },
          "content": {
            "type": "string",
            "description": "Text content of the document"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the document was created"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the document was last updated"
          }
        }
      },
      "DocumentResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "payload": {
            "$ref": "#/components/schemas/Document"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "payload": {
            "type": "object",
            "nullable": true
          }
        }
      }
    }
  }
}