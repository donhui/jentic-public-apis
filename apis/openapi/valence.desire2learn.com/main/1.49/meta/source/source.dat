            }
          },
          {
            "name": "gradeObjectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Grade value"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "operationId": "updateGradeValue",
        "summary": "Update grade value for user",
        "tags": [
          "Grades"
        ],
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgUnitId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "gradeObjectId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IncomingGradeValue"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/d2l/api/lp/{version}/orgstructure/{orgUnitId}": {
      "get": {
        "operationId": "getOrgUnit",
        "summary": "Get org unit properties",
        "tags": [
          "Org Units"
        ],
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgUnitId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Org unit info"
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/d2l/api/lp/{version}/orgstructure/{orgUnitId}/children/paged/": {
      "get": {
        "operationId": "getOrgUnitChildren",
        "summary": "Get org unit children (paged)",
        "tags": [
          "Org Units"
        ],
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgUnitId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "bookmark",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paged children"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/d2l/api/lp/{version}/courses/{orgUnitId}/copy/": {
      "post": {
        "operationId": "createCourseCopyJob",
        "summary": "Create course copy job",
        "tags": [
          "Courses"
        ],
        "parameters": [
          {
            "name": "version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orgUnitId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCopyJobRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Copy job created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "JobToken": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OAuth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://{hostname}/d2l/api/oauth2/auth",
            "tokenUrl": "https://{hostname}/d2l/api/oauth2/token",
            "scopes": {
              "core:*:*": "Full access",
              "enrollment:orgunit:read": "Read enrollments",
              "enrollment:orgunit:delete": "Delete enrollments",
              "enrollment:own_enrollment:read": "Read own enrollments",
              "orgunits:course:delete": "Delete courses"
            }
          }
        }
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "UserId": {
            "type": "integer"
          },
          "FirstName": {
            "type": "string"
          },
          "MiddleName": {
            "type": "string",
            "nullable": true
          },
          "LastName": {
            "type": "string"
          },
          "UserName": {
            "type": "string"
          },
          "ExternalEmail": {
            "type": "string",
            "nullable": true
          },
          "OrgDefinedId": {
            "type": "string",
            "nullable": true
          },
          "UniqueIdentifier": {
            "type": "string"
          },
          "Activation": {
            "type": "object",
            "properties": {
              "IsActive": {
                "type": "boolean"
              }
            }
          },
          "DisplayName": {
            "type": "string"
          }
        }
      },
      "CreateUserData": {
        "type": "object",
        "required": [
          "OrgDefinedId",
          "FirstName",
          "LastName",
          "ExternalEmail",
