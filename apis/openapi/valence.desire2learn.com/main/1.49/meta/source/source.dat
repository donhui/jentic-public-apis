            }
          },
          {
            "name": "orgUnitId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GradeObject"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created grade object"
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/d2l/api/le/{version}/{orgUnitId}/grades/{gradeObjectId}/values/{userId}": {
      "get": {
        "operationId": "getGradeValue",
        "summary": "Get grade value for user",
