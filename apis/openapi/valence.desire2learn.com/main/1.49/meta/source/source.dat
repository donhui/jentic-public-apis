              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "operationId": "updateCourse",
        "summary": "Update course offering",
        "tags": [
          "Courses"
        ],
        "parameters": [
          {
            "name": "version",
            "in": "path",
