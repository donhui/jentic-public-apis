      "feeType": {
        "type": "string",
        "example": "Recording",
        "enum": [
          "Underwriter",
          "Settlement",
          "Lender",
          "Recording",
          "Commission",
          "Proration",
          "Other"
        ]
      },
      "fee": {
        "description": "A rate or fee item",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "type",
          "split",
          "amount",
          "messages"
