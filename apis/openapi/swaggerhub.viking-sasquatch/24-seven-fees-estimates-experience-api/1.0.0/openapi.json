              "EPA ENDORSEMENT"
            ]
          },
          "estimatedClosingDate": {
            "$ref": "#/components/schemas/localDate"
          }
        }
      },
      "underwritersResponse": {
        "title": "Underwriter Response",
        "type": "object",
        "properties": {
          "type": {
            "allOf": [
              {
                "$ref": "#/components/schemas/feeType"
              },
              {
                "example": "Underwriter"
              }
            ]
          },
          "vendor": {
            "type": "string",
            "description": "Name of the source vendor which is providing the listed rates and fees",
            "example": "Old Republic National Title Insurance Company"
          },
          "vendorUuid": {
            "allOf": [
              {
                "$ref": "#/components/schemas/uuid"
              },
              {
                "description": "UUID of vendor source for debugging and verification"
              },
              {
                "example": "ab84df30-e31d-11ea-a71f-9fb07abc474d"
              }
            ]
          },
          "lineItems": {
            "allOf": [
              {
                "$ref": "#/components/schemas/lineItemList"
              },
              {
                "example": {
                  "$ref": "#/components/examples/lineItemsUnderwritersExample"
                }
              }
            ]
          },
          "notes": {
            "$ref": "#/components/schemas/notes"
          },
          "sourceMetadata": {
            "$ref": "#/components/schemas/metadata"
          }
        }
      }
    },
