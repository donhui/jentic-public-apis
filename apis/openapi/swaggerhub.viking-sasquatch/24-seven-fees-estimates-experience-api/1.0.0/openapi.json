    }
  ],
  "paths": {
    "/quickCalc": {
      "post": {
        "description": "Create a new quickCalc",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/quickCalcByEstmateNumberRequestType"
              }
            }
          },
          "required": false
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/generic200"
          },
          "400": {
            "$ref": "#/components/responses/generic400"
          },
          "401": {
            "$ref": "#/components/responses/generic401"
          },
          "403": {
            "$ref": "#/components/responses/generic403"
          },
          "500": {
            "$ref": "#/components/responses/generic500"
          }
        }
      }
    },
    "/quickCalc/{estimateNumber}": {
      "get": {
        "description": "Obtain basic quickCalc information",
        "parameters": [
          {
            "$ref": "#/components/parameters/pathEstimateNumber"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/quickCalcByEstmateNumberResponseType"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/generic400"
          },
          "401": {
            "$ref": "#/components/responses/generic401"
          },
          "403": {
            "$ref": "#/components/responses/generic403"
          },
          "500": {
            "$ref": "#/components/responses/generic500"
          }
        }
      }
    },
    "/quickCalc/{estimateNumber}/basicView": {
      "get": {
        "description": "Get fee results for a quickCalc as a basic view",
        "parameters": [
          {
            "$ref": "#/components/parameters/pathEstimateNumber"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/basicViewType"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/generic400"
          },
          "401": {
            "$ref": "#/components/responses/generic401"
          },
          "403": {
            "$ref": "#/components/responses/generic403"
          },
          "500": {
            "$ref": "#/components/responses/generic500"
          }
        }
      }
    },
    "/quickCalc/{estimateNumber}/cdView": {
      "get": {
        "description": "Get fee results for a quickCalc as a cd view",
        "parameters": [
          {
            "$ref": "#/components/parameters/pathEstimateNumber"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/cdViewType"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/generic400"
          },
          "401": {
            "$ref": "#/components/responses/generic401"
          },
          "403": {
            "$ref": "#/components/responses/generic403"
          },
          "500": {
            "$ref": "#/components/responses/generic500"
          }
        }
      }
    },
    "/quickCalc/{estimateNumber}/altaView": {
      "get": {
        "description": "Get fee results for a quickCalc as an Alta view",
        "parameters": [
          {
            "$ref": "#/components/parameters/pathEstimateNumber"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/altaViewType"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/generic400"
          },
          "401": {
            "$ref": "#/components/responses/generic401"
          },
          "403": {
            "$ref": "#/components/responses/generic403"
          },
          "500": {
            "$ref": "#/components/responses/generic500"
          }
        }
      }
    },
    "/quickCalc/{estimateNumber}/loanEstView": {
      "get": {
        "description": "Get fee results for a quickCalc as a loan estimage view",
        "parameters": [
          {
            "$ref": "#/components/parameters/pathEstimateNumber"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/loanEstimateViewType"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/generic400"
          },
          "401": {
            "$ref": "#/components/responses/generic401"
          },
          "403": {
            "$ref": "#/components/responses/generic403"
          },
          "500": {
            "$ref": "#/components/responses/generic500"
          }
        }
      }
    },
    "/property/info": {
      "get": {
        "description": "Get a list of states, counties, and cities for a provided 5 digit US zip code",
        "parameters": [
          {
            "$ref": "#/components/parameters/queryZip"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/generic200"
          },
          "400": {
            "$ref": "#/components/responses/generic400"
          },
          "401": {
            "$ref": "#/components/responses/generic401"
          },
          "403": {
            "$ref": "#/components/responses/generic403"
          },
          "500": {
            "$ref": "#/components/responses/generic500"
          }
        }
      }
    },
    "/recordingFees": {
      "post": {
        "tags": [
          "Recording"
        ],
        "description": "Gather a list of Recording Fees",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/recordingRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful quote creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/recordingResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/generic400"
          },
          "401": {
            "$ref": "#/components/responses/generic401"
          },
          "403": {
            "$ref": "#/components/responses/generic403"
          },
          "500": {
            "$ref": "#/components/responses/generic500"
          }
        }
      }
    },
    "/underwriterRates": {
      "post": {
        "tags": [
          "Underwriters"
        ],
        "description": "Gather a list of Underwriter Rates",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/underwritersRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful quote creation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/underwritersResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/generic400"
          },
          "401": {
            "$ref": "#/components/responses/generic401"
          },
          "403": {
            "$ref": "#/components/responses/generic403"
          },
          "500": {
            "$ref": "#/components/responses/generic500"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "numberNullable": {
        "description": "A nullable number value",
        "type": "number",
        "nullable": true
      },
      "stringNullable": {
        "description": "A nullable string value",
        "type": "string",
        "nullable": true
      },
      "errorType": {
        "required": [
          "error",
          "errorId",
          "errorType"
        ],
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "errorType": {
            "type": "string"
          },
          "errorId": {
            "type": "string"
          }
        }
      },
      "currency": {
        "description": "A US dollar amount in minimum 1 cent increments",
        "type": "number",
        "multipleOf": 0.01
      },
      "localDate": {
        "description": "Local Date in ISO 8601 format YYYY-MM-DD",
        "type": "string",
        "pattern": "^(\\d{4})-([0]?[1-9]|[1][0-2])-([0]?[1-9]|[1-2]\\d|[3][0-1])$",
        "example": "2023-08-31"
      },
      "state": {
        "description": "2 letter US state abbreviation",
        "type": "string",
        "enum": [
          "AL",
          "AK",
          "AZ",
          "AR",
          "CA",
          "CO",
          "CT",
          "DE",
          "FL",
          "GA",
          "HI",
          "ID",
          "IL",
          "IN",
          "IA",
          "KS",
          "KY",
          "LA",
          "ME",
          "MD",
          "MA",
          "MI",
          "MN",
          "MS",
          "MO",
          "MT",
          "NE",
          "NV",
          "NH",
          "NJ",
          "NM",
          "NY",
          "NC",
          "ND",
          "OH",
          "OK",
          "OR",
          "PA",
          "RI",
          "SC",
          "SD",
          "TN",
          "TX",
          "UT",
          "VT",
          "VA",
          "WA",
          "WV",
          "WI",
          "WY",
          "DC",
          "MH",
          "GU",
          "AS",
          "CM",
          "PW",
          "PR",
          "TT",
          "VI"
        ],
        "example": "FL"
      },
      "uuid": {
        "description": "Universal Unique ID used as a specific record reference",
        "type": "string",
        "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
        "example": "8e62f89c-cbb0-11ec-9d64-0242ac120002"
      },
      "zipCode": {
        "description": "5 digit US Postal Zip code.  Represented by a string to include prepended zeros.",
        "type": "string",
        "pattern": "^\\d{5}$",
        "example": "90210"
      },
      "metadata": {
        "description": "A Generic key/value type metadata represented as an object. May contain any kind of data.",
        "type": "object"
      },
      "address": {
        "description": "A U.S. style physical address",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "city",
          "state",
          "zip",
          "county"
        ],
        "properties": {
          "line1": {
            "type": "string"
          },
          "line2": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/state"
          },
          "zip": {
            "$ref": "#/components/schemas/zipCode"
          },
          "county": {
            "type": "string"
          }
        }
      },
      "split": {
        "description": "A buyer/seller split",
        "type": "object",
        "required": [
          "buyer",
          "seller"
        ],
        "properties": {
          "buyer": {
            "$ref": "#/components/schemas/currency"
          },
          "seller": {
            "$ref": "#/components/schemas/currency"
          },
          "other": {
            "$ref": "#/components/schemas/currency"
          }
        }
      },
      "transactionType": {
        "description": "The transaction type of the call",
        "example": "PURCHASE W/ LOAN",
        "type": "string",
        "enum": [
          "PURCHASE W/ LOAN",
          "CASH",
          "REFINANCE",
          "REVERSE MORTGAGE"
        ]
      },
      "basicViewType": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "header": {
              "type": "string"
            },
            "group": {
              "type": "string"
            },
            "ordinal": {
              "$ref": "#/components/schemas/currency"
            },
            "lineItems": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "object",
                    "properties": {
                      "buyer": {
                        "$ref": "#/components/schemas/currency"
                      },
                      "seller": {
                        "$ref": "#/components/schemas/currency"
                      },
                      "other": {
                        "$ref": "#/components/schemas/currency"
                      }
                    }
                  }
                }
              }
            },
            "sectionTotal": {
              "type": "object",
              "properties": {
                "buyer": {
                  "$ref": "#/components/schemas/currency"
                },
                "seller": {
                  "$ref": "#/components/schemas/currency"
                },
                "other": {
                  "$ref": "#/components/schemas/currency"
                }
              }
            }
          }
        }
      },
      "cdViewType": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "header": {
              "type": "string"
            },
            "sectionTotal": {
              "type": "object",
              "properties": {
                "buyer": {
                  "$ref": "#/components/schemas/currency"
                },
                "seller": {
                  "$ref": "#/components/schemas/currency"
                },
                "other": {
                  "$ref": "#/components/schemas/currency"
                }
              }
            },
            "lineItems": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "object",
                    "properties": {
                      "buyer": {
                        "$ref": "#/components/schemas/currency"
                      },
                      "seller": {
                        "$ref": "#/components/schemas/currency"
                      },
                      "other": {
                        "$ref": "#/components/schemas/currency"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "altaViewType": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "header": {
              "type": "string"
            },
            "lineItems": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "object",
                    "properties": {
                      "buyerDebit": {
                        "$ref": "#/components/schemas/numberNullable"
                      },
                      "buyerCredit": {
                        "$ref": "#/components/schemas/numberNullable"
                      },
                      "sellerDebit": {
                        "$ref": "#/components/schemas/numberNullable"
                      },
                      "sellerCredit": {
                        "$ref": "#/components/schemas/numberNullable"
                      }
                    }
                  }
                }
              }
            },
            "sectionTotal": {
              "type": "object",
              "properties": {
                "buyerDebit": {
                  "$ref": "#/components/schemas/currency"
                },
                "buyerCredit": {
                  "$ref": "#/components/schemas/currency"
                },
                "sellerDebit": {
                  "$ref": "#/components/schemas/currency"
                },
                "sellerCredit": {
                  "$ref": "#/components/schemas/currency"
                }
              }
            }
          }
        }
      },
      "loanEstimateViewType": {
        "type": "array",
        "items": {
          "required": [
            "lineItems",
            "sectionTotal"
          ],
          "type": "object",
          "properties": {
            "header": {
              "type": "string"
            },
            "totalHeader": {
              "type": "string"
            },
            "lineItems": {
              "type": "array",
              "items": {
                "required": [
                  "amount",
                  "description"
                ],
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "amount": {
                    "$ref": "#/components/schemas/currency"
                  }
                }
              }
            },
            "sectionTotal": {
              "$ref": "#/components/schemas/currency"
            }
          }
        }
      },
      "quickCalcByEstmateNumberRequestType": {
        "required": [
          "transactionFile"
        ],
        "type": "object",
        "properties": {
          "transactionFile": {
            "required": [
              "transactionFileType",
              "loanInfo",
              "property",
              "endorsements"
            ],
            "type": "object",
            "properties": {
              "transactionFileType": {
                "$ref": "#/components/schemas/transactionType"
              },
              "loanInfo": {
                "$ref": "#/components/schemas/loanInfo"
              },
              "property": {
                "required": [
                  "address"
                ],
                "type": "object",
                "properties": {
                  "address": {
                    "$ref": "#/components/schemas/quickAddressType"
                  }
                }
              },
              "endorsements": {
                "$ref": "#/components/schemas/endorsementsType"
              }
            }
          }
        },
        "example": {
          "transactionFile": {
            "transactionFileType": "PURCHASE W/ LOAN",
            "loanInfo": {
              "loanAmount": 100000,
              "salesAmount": 123000,
              "downPayment": 0
            },
            "property": {
              "address": {
                "city": "Hollywood",
                "state": "FL",
                "zip": "33019",
                "county": "Broward"
              }
            },
            "endorsements": {
              "ALTA_7": false,
              "ALTA_8.1": true,
              "ALTA_9": true,
              "ALTA_22.1": false,
              "ALTA_116.1": false,
              "ALTA_5": false,
              "ALTA_4": false,
              "ALTA_6.2": false
            }
          }
        }
      },
      "quickCalcByEstmateNumberResponseType": {
        "required": [
          "estimateInfo",
          "estimateResults"
        ],
        "type": "object",
        "properties": {
          "estimateInfo": {
            "required": [
              "transactionFile"
            ],
            "type": "object",
            "properties": {
              "transactionFile": {
                "required": [
                  "endorsements",
                  "loanInfo",
                  "property",
                  "reissue",
                  "selectedAccountId",
                  "tierConfigurationUuid",
                  "transactionFileType"
                ],
                "type": "object",
                "properties": {
                  "reissue": {
                    "type": "boolean"
                  },
                  "loanInfo": {
                    "$ref": "#/components/schemas/loanInfo"
                  },
                  "property": {
                    "required": [
                      "address"
                    ],
                    "type": "object",
                    "properties": {
                      "address": {
                        "$ref": "#/components/schemas/quickAddressType"
                      }
                    }
                  },
                  "endorsements": {
                    "$ref": "#/components/schemas/endorsementsType"
                  },
                  "selectedAccountId": {
                    "type": "string"
                  },
                  "transactionFileType": {
                    "type": "string"
                  },
                  "tierConfigurationUuid": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "estimateResults": {
            "type": "array",
            "items": {
              "required": [
                "group",
                "lineItems",
                "type",
                "vendor"
              ],
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "group": {
                  "type": "string"
                },
                "vendor": {
                  "type": "string"
                },
                "requestId": {
                  "type": "string"
                },
                "vendorUuid": {
                  "type": "string"
                },
                "lineItems": {
                  "type": "array",
                  "items": {
                    "required": [
                      "amount",
                      "name",
                      "split"
                    ],
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "split": {
                        "$ref": "#/components/schemas/split"
                      },
                      "amount": {
                        "$ref": "#/components/schemas/currency"
                      },
                      "defaultPaidBy": {
                        "type": "string"
                      }
                    }
                  }
                },
                "notes": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/stringNullable"
                  }
                },
                "vendorQuoteData": {
                  "type": "object",
                  "properties": {}
                }
              }
            }
          }
        }
      },
      "loanInfo": {
        "type": "object",
        "properties": {
          "loanType": {
            "type": "string"
          },
          "loanAmount": {
            "$ref": "#/components/schemas/currency"
          },
          "downPayment": {
            "$ref": "#/components/schemas/currency"
          },
          "salesAmount": {
            "$ref": "#/components/schemas/currency"
          }
        }
      },
      "endorsementsType": {
        "type": "object",
        "description": "A key/value mapping of endorsement ids and their enabled/disabled state represented by a boolean value.  Example endorsement ids: ALTA_7, ALTA_8.1, ALTA_9, ALTA_22.1, ALTA_116.1, ALTA_5, ALTA_4, ALTA_6.2",
        "additionalProperties": {
          "type": "boolean"
        },
        "example": {
          "ALTA_7": false,
          "ALTA_8.1": true,
          "ALTA_9": true,
          "ALTA_22.1": false,
          "ALTA_116.1": false,
          "ALTA_5": false,
          "ALTA_4": false,
          "ALTA_6.2": false
        }
      },
      "quickAddressType": {
        "required": [
          "county",
          "state",
          "zip"
        ],
        "type": "object",
        "properties": {
          "line1": {
            "type": "string"
          },
          "line2": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "state": {
            "$ref": "#/components/schemas/state"
          },
          "zip": {
            "$ref": "#/components/schemas/zipCode"
          },
          "county": {
            "type": "string"
          }
        },
        "example": {
          "city": "Hollywood",
          "state": "FL",
          "zip": "33019",
          "county": "Broward"
        }
      },
      "notes": {
        "description": "A list of notes that reveal details about the resource it's contained within",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "property": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "address"
        ],
        "properties": {
          "address": {
            "$ref": "#/components/schemas/address"
          },
          "metadata": {
            "allOf": [
              {
                "$ref": "#/components/schemas/metadata"
              },
              {
                "description": "Additional metadata associated with the property.  Such as a New Mexico location code. Typically an empty object"
              }
            ]
          }
        },
        "example": {
          "address": {
            "line1": "123 W Chicago Ave",
            "line2": "",
            "city": "Chicago",
            "state": "IL",
            "zip": "60654",
