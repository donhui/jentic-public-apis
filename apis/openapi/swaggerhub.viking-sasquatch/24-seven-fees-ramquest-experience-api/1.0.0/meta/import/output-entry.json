              "Simultaneous rates applied"
            ],
            "rateEffectiveDate": "2021-02-01"
          },
          {
            "name": "COMPREHENSIVE ENDORSEMENT",
            "type": "Underwriter",
            "typeDetail": "ENDORSEMENT",
            "split": {
              "buyer": 180,
              "seller": 0,
              "other": 0
            },
            "amount": 180,
            "messages": [],
            "rateEffectiveDate": "2022-02-22"
          }
        ]
      }
    }
  }
}