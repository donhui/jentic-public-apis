{
  "openapi": "3.0.3",
  "info": {
    "title": "CM.com Business Messaging API",
    "description": "CM.com Business Messaging API for sending SMS, RCS, WhatsApp, and other channel messages, as well as number validation, lookup, and capability checking.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.cm.com/en-us/sms/sms-gateway-api/"
  },
  "servers": [
    {
      "url": "https://gw.messaging.cm.com/v1.0",
      "description": "CM.com Messaging Gateway"
    }
  ],
  "security": [
    {
      "productToken": []
    }
  ],
  "tags": [
    { "name": "Messages", "description": "Send messages across channels" },
    { "name": "Capabilities", "description": "Check channel capabilities for phone numbers" },
    { "name": "Number Validation", "description": "Validate and lookup phone numbers" }
  ],
  "paths": {
    "/message": {
      "post": {
        "operationId": "sendMessage",
        "summary": "Send message(s)",
        "description": "Sends one or more messages via SMS, RCS, WhatsApp, or other supported channels.",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message(s) sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendMessageResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid message format or parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid product token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/capabilities/{phoneNumber}": {
      "get": {
        "operationId": "getChannelCapabilities",
        "summary": "Check channel capabilities for a phone number",
        "description": "Checks which messaging channels are available for a given phone number.",
        "tags": ["Capabilities"],
        "parameters": [
          {
            "name": "phoneNumber",
            "in": "path",
            "required": true,
            "description": "Phone number in E.164 format.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "channels",
            "in": "query",
            "description": "Comma-separated list of channels to check (e.g., 'RCS').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-CM-PRODUCTTOKEN",
            "in": "header",
            "required": true,
            "description": "CM.com product token.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Capability check result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapabilityResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/v1/capabilities": {
      "post": {
        "operationId": "bulkCheckCapabilities",
        "summary": "Bulk capability check",
        "description": "Checks channel capabilities for multiple phone numbers at once (minimum 500 numbers).",
        "tags": ["Capabilities"],
        "parameters": [
          {
            "name": "channels",
            "in": "query",
            "description": "Supported channels to check.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-CM-PRODUCTTOKEN",
            "in": "header",
            "required": true,
            "description": "CM.com product token.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkCapabilityRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk capability check result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BulkCapabilityResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/numbervalidation/{phoneNumber}": {
      "get": {
        "operationId": "validatePhoneNumber",
        "summary": "Validate a phone number",
        "description": "Validates a phone number and returns details about it.",
        "tags": ["Number Validation"],
        "parameters": [
          {
            "name": "phoneNumber",
            "in": "path",
            "required": true,
            "description": "Phone number to validate.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Phone number validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NumberValidationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/numberlookup/{phoneNumber}": {
      "get": {
        "operationId": "lookupPhoneNumber",
        "summary": "Lookup a phone number",
        "description": "Performs an HLR lookup for a phone number to determine if it is active, the carrier, and roaming status.",
        "tags": ["Number Validation"],
        "parameters": [
          {
            "name": "phoneNumber",
            "in": "path",
            "required": true,
            "description": "Phone number to look up.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Phone number lookup result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NumberLookupResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "productToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CM-PRODUCTTOKEN",
        "description": "CM.com product token for authentication."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "errorCode": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "SendMessageRequest": {
        "type": "object",
        "required": ["messages"],
        "properties": {
          "messages": {
            "type": "object",
            "required": ["authentication", "msg"],
            "properties": {
              "authentication": {
                "type": "object",
                "required": ["producttoken"],
                "properties": {
                  "producttoken": {
                    "type": "string",
                    "description": "Your CM.com product token."
                  }
                }
              },
              "msg": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/MessageItem"
                }
              }
            }
          }
        }
      },
      "MessageItem": {
        "type": "object",
        "required": ["from", "to", "body"],
        "properties": {
          "from": {
            "type": "string",
            "description": "Sender name or number."
          },
          "to": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "number": {
                  "type": "string",
                  "description": "Recipient phone number in E.164 format."
                }
              }
            }
          },
          "body": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Message body type (e.g., auto)."
              },
              "content": {
                "type": "string",
                "description": "Message content."
              }
            }
          },
          "allowedChannels": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["SMS", "RCS", "WhatsApp", "Viber", "LINE", "Telegram", "MobilePush"]
            },
            "description": "Channels allowed for delivery."
          },
          "reference": {
            "type": "string",
            "description": "Custom reference for tracking."
          }
        }
      },
      "SendMessageResponse": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "to": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "reference": {
                  "type": "string"
                },
                "parts": {
                  "type": "integer"
                },
                "messageDetails": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CapabilityResponse": {
        "type": "object",
        "properties": {
          "isCapable": {
            "type": "boolean",
            "description": "Whether the phone number supports the requested channel."
          }
        }
      },
      "BulkCapabilityRequest": {
        "type": "object",
        "required": ["phoneNumbers"],
        "properties": {
          "phoneNumbers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 500,
            "description": "Array of phone numbers in E.164 format."
          }
        }
      },
      "BulkCapabilityResponse": {
        "type": "object",
        "properties": {
          "reachableUsers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Phone numbers that are reachable on the requested channels."
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "NumberValidationResponse": {
        "type": "object",
        "properties": {
          "country_code": {
            "type": "string"
          },
          "country_iso": {
            "type": "string"
          },
          "valid_number": {
            "type": "boolean"
          },
          "type": {
            "type": "string"
          },
          "format_e164": {
            "type": "string"
          },
          "carrier": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          }
        }
      },
      "NumberLookupResponse": {
        "type": "object",
        "properties": {
          "active_number": {
            "type": "boolean"
          },
          "carrier": {
            "type": "string"
          },
          "roaming": {
            "type": "boolean"
          },
          "type": {
            "type": "string"
          }
        }
      }
    }
  }
}