  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Appfigures-assigned product ID"
          },
          "name": {
            "type": "string",
            "description": "Full name of the product"
          },
          "developer": {
            "type": "string",
            "description": "Developer name"
          },
          "icon": {
            "type": "string",
            "description": "URL to the product icon"
          },
          "vendor_identifier": {
            "type": "string",
            "description": "Store-specific identifier"
          },
          "ref_no": {
            "type": "integer",
            "nullable": true,
            "description": "Product store ID (Apple only)"
          },
          "sku": {
            "type": "string",
            "description": "Developer-assigned SKU"
          },
          "store_id": {
            "type": "integer",
            "description": "Store ID"
          },
          "store": {
            "type": "string",
            "description": "Store name (apple, google_play, etc.)"
          },
          "release_date": {
            "type": "string",
            "format": "date-time",
            "description": "Release date"
          },
          "added_date": {
            "type": "string",
            "format": "date-time",
            "description": "Date added to Appfigures"
          },
          "updated_date": {
            "type": "string",
            "format": "date-time",
            "description": "Last update date"
          },
          "version": {
            "type": "string",
            "description": "Current version"
          },
          "type": {
            "type": "string",
            "description": "Product type: app, inapp, book"
          },
          "devices": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Device types: Handheld, Tablet, Desktop"
          },
          "active": {
            "type": "boolean",
            "description": "Whether the product is active"
          },
          "price": {
            "type": "object",
            "properties": {
              "currency": {
                "type": "string"
              },
              "price": {
                "type": "string"
              }
            }
          }
        }
      },
      "SalesReport": {
        "type": "object",
        "properties": {
          "downloads": {
            "type": "integer",
            "description": "Total downloads"
          },
          "net_downloads": {
            "type": "integer",
            "description": "Downloads minus returns"
          },
          "app_downloads": {
            "type": "integer",
            "description": "App downloads (excluding IAP)"
          },
          "re_downloads": {
            "type": "integer",
            "description": "Reinstalls"
          },
          "updates": {
            "type": "integer",
            "description": "Total updates"
          },
          "revenue": {
            "type": "number",
            "description": "Total revenue after store fees"
          },
          "app_revenue": {
            "type": "number",
            "description": "App revenue (excluding IAP)"
          },
          "gross_revenue": {
            "type": "number",
            "description": "Total revenue before store fees"
          },
          "returns": {
            "type": "integer",
            "description": "Total returns"
          },
          "gifts": {
            "type": "integer",
            "description": "Number of gifts"
          },
          "promos": {
            "type": "integer",
            "description": "Promo codes used"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "httpAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication using client key credentials."
      },
      "oauth1": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 1.0 authentication for public-facing applications."
      }
    }
  },
  "security": [
    {
      "httpAuth": []
    }
  ]
}