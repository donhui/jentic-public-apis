{
  "openapi": "3.0.3",
  "info": {
    "title": "Appfigures API",
    "version": "v2",
    "description": "Appfigures provides a simple, RESTful way to interact with app store reports and account data. Access sales and ads data, ranks, reviews, featured data, and perform account management tasks.",
    "x-jentic-source-url": "https://docs.appfigures.com"
  },
  "servers": [
    {
      "url": "https://api.appfigures.com/v2"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getRoot",
        "summary": "API Root",
        "description": "Returns the API root information.",
        "tags": [
          "General"
        ],
        "responses": {
          "200": {
            "description": "API root information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "operationId": "getProductById",
        "summary": "Get product by Appfigures ID",
        "description": "Retrieve a product by its Appfigures-assigned ID.",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The Appfigures-assigned product ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/products/search/{term}": {
      "get": {
        "operationId": "searchProducts",
        "summary": "Search for products",
        "description": "Search for products by name or developer. Prefix with @name= or @developer= to search specific fields.",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "term",
            "in": "path",
            "required": true,
            "description": "Search term. Prefix with @name= or @developer= for field-specific search.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "storefronts",
            "in": "query",
            "description": "Semicolon-separated set of storefronts to filter results (e.g., apple, google_play, amazon_appstore).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page of results to show. Defaults to the first page.",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Number of results per page. Defaults to 25.",
            "schema": {
              "type": "integer",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of matching products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/products/{store}/{id_in_store}": {
      "get": {
        "operationId": "getProductByStoreId",
        "summary": "Get product by store ID",
        "description": "Retrieve a product by its ID in the store. If the product does not exist in the database, the API will attempt a real-time lookup.",
        "tags": [
          "Products"
        ],
        "parameters": [
          {
            "name": "store",
            "in": "path",
            "required": true,
            "description": "The store (e.g., apple, google_play, amazon_appstore)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id_in_store",
            "in": "path",
            "required": true,
            "description": "The product's unique identifier in the store",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          },
          "202": {
            "description": "Lookup in progress - product not yet available",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string",
                      "description": "URL to check the status of the lookup"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
