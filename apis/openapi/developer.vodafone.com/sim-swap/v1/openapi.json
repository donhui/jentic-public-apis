{
  "openapi": "3.0.3",
  "info": {
    "title": "SIM Swap (CAMARA)",
    "description": "SIM Swap (CAMARA) enables you to verify that a SIM card has not recently been swapped.\n",
    "version": "1.0.0",
    "x-jentic-source-url": "https://developer.vodafone.com/sites/default/files/2026-03/JWTORCIBA_SimSwap_inlineAuthenticationFlows.yml",
    "contact": {
      "name": "SIM Swap (CAMARA) Support"
    }
  },
  "servers": [
    {
      "url": "https://api-sandbox.vf-dmp.engineering.vodafone.com",
      "description": "Sandbox"
    },
    {
      "url": "https://api.vf-dmp.engineering.vodafone.com",
      "description": "Production"
    }
  ],
  "paths": {
    "/oauth2/v2/token": {
      "post": {
        "tags": [
          "JWT Authentication Flow"
        ],
        "summary": "Get Access Token using JWT Bearer",
        "description": "Exchange a signed JWT for an OAuth2 access token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "grant_type",
                  "assertion"
                ],
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "description": "OAuth2 JWT Bearer grant type",
                    "example": "urn:ietf:params:oauth:grant-type:jwt-bearer"
                  },
                  "assertion": {
                    "type": "string",
                    "description": "Signed JWT assertion",
                    "example": "eyJraWQiOiJkbXAtcHJvZC1raWQiLCJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9..kWqnabvFM_Y2DB6uenDC9_5DVzwl3lqdmxVWa2YjsSWijq3aXjPtpluHA44HjZec5g7CWAq8bsahIk9HGKV32c7YS_N6d9PvnRR6QDjL7FSR26W85EXtRaRstCmBYvfxIJFiodCl6h7SLPny8I6r6CiQWxOuo_DXsCoZYmrR370ljy60sL_u7Y225kqj7e2FTGGCpJ0KQ5uZHXTi-ChdYEXI62uBa45jrCPB5liyNteXjQJyqBFvn2L4fhJvHIyXxFfDBo99MpmALpTEWuqD39whC18FiZ3H4wPkn4kmbd4ZwR57J7N_zIFNzW6h4BmrpMrZ41fZpc5Rok9A0zyM69EUfxY3NBO8EHg_Q8-z9WHGQxvML_3fs3Q6GFYKPKtuKueRxi0twuo-CUqEHVQUgVTUz8NGiag0tkkouruCbqJ1AZlhPVFFOy6wzLfWq7x3L0-MEQENluhiou2s1HHTsYAJfj60lXdi0BfUkrM2Hw6qA7BYYgEe7-y62xWUjr6OatkOlqCuwtlGThoC7jA27nOX23a7a8oTdEaabj3GAC4WMayGK-GhgQX5xB-Eawn5CQlGpos8jcGbWDaaK8scbHfx6_rNObt0g4MOs5oV5CIvB-rlq3HdCbKsmTa7eSE3dGERr3ClTFNL7PpBdUoNpbmp1dQCk1BZ8pooEYsylto"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "**OK**",
            "content": {
              "application/json": {
                "examples": {
                  "success_response": {
                    "value": {
                      "token_type": "Bearer",
                      "access_token": "43W9uMMOmGzwz8PMllON15hUPYFz",
                      "expires_in": 3599,
                      "scope": "openid retrieve-sim-swap-date"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/Generic400"
          },
          "401": {
            "$ref": "#/components/responses/Generic401"
          }
        },
        "parameters": [],
        "operationId": "post_oauth2_v2_token"
      }
    },
    "/openIDConnectCIBA/v1/bc-authorize": {
      "post": {
        "tags": [
          "CIBA Authentication Flow"
        ],
        "description": "The SP makes a request to Vodafone’s Backchannel Authentication Endpoint to ask for end-user authorization. Vodafone validates the MSISDN is a Vodafone MSISDN and checks consent. If successful, it passes the request to the VF IDGW for processing. Once VF IDGW processing is successful, an “auth_req_id” is provided in the response to the SP.",
        "operationId": "authenticationRequest",
        "parameters": [
          {
            "$ref": "#/components/parameters/authorization-basic"
          },
          {
            "$ref": "#/components/parameters/X-Correlator"
          }
        ],
        "requestBody": {
          "description": "The SP makes a request to Vodafone’s Backchannel Authentication Endpoint to ask for end-user authorization. Vodafone validates the MSISDN is a Vodafone MSISDN and checks consent. If successful, it passes the request to the VF IDGW for processing. Once VF IDGW processing is successful, an “auth_req_id” is provided in the response to the SP.\n",
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/AuthorizeReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "**OK** If the authorization request is successfully completed (i.e. without error), an authorization id (auth_req_id) is returned by ID Gateway, in an HTTP 200 response in json payload with parameters.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationResp"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/AuthError400"
          },
          "401": {
            "$ref": "#/components/responses/AuthError401"
          },
          "403": {
            "$ref": "#/components/responses/AuthError403"
          },
          "406": {
            "$ref": "#/components/responses/AuthError406"
          },
          "415": {
            "$ref": "#/components/responses/AuthError415"
          },
          "500": {
            "$ref": "#/components/responses/AuthError500"
          },
          "502": {
            "$ref": "#/components/responses/AuthError502"
          },
          "503": {
            "$ref": "#/components/responses/AuthError503"
          }
        }
      }
    },
