  "components": {
    "parameters": {
      "authorization-basic": {
        "name": "Authorization",
        "in": "header",
        "required": true,
        "description": "“Basic “ + base_64_encode (client_id + “:” + client_secret)\n",
        "schema": {
          "type": "string",
          "example": "Basic d3lCOHF1R0RPWTdXTnUyVUV2eGF5Sk9aNVpTSU1KM1Y6V2ZHQUJqSUJpRDIySg==\n"
        }
      },
      "authorization-bearer": {
        "name": "Authorization",
        "in": "header",
        "required": true,
        "description": "“Bearer ” concatenated with the access token obtained from either from JWT Authentication Flow or CIBA Authentication Flow.\n",
        "schema": {
          "type": "string",
          "example": "Bearer dUk4Bs0qgKQKujbGxQDvIdXkI6Bz\n"
        }
      },
      "X-Correlator": {
        "name": "X-Correlator",
        "in": "header",
        "required": false,
        "description": "Correlation id for the different services ie 42da5b19-457a-4d30-a5c4-038c62dccbb0.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "AuthorizeReq": {
        "type": "object",
        "required": [
          "login_hint",
          "scope"
        ],
        "properties": {
          "login_hint": {
            "type": "string",
            "example": "tel:+447772000001",
            "description": "End-user for whom the authentication is being requested. This is MSISDN in the format “tel:+{MSISDN}”, where +\" prefix is optional. Examples: “tel:+447772000001” or “tel:447772000001”, Examples for UK: “tel:+447772000001” or “tel:447772000001”, for NL +31777100001, for DE +491722100001 and for ES +34600080001..\n"
          },
          "scope": {
            "type": "string",
            "enum": [
              "openid retrieve-sim-swap-date",
              "openid check-sim-swap"
            ],
            "example": "openid retrieve-sim-swap-date",
            "description": "Authorization request MUST contain the scope value.\n"
          }
        }
      },
      "AuthenticationResp": {
        "type": "object",
        "properties": {
          "interval": {
            "type": "number",
            "format": "number",
            "example": 0,
            "description": "The time required to wait between receiving the authorization endpoint response and making the polling endpoint request (in seconds). This value can be ignored.\n"
          },
          "auth_req_id": {
            "type": "string",
            "format": "UUID",
            "example": "39da5b19-457a-4d30-a5c4-047c62dcca3b",
            "description": "Unique Id of this authorization (to be used in the token request).\n"
          },
          "expires_in": {
            "type": "number",
            "format": "number",
            "example": 300,
            "description": "The timeout available to make a request to the token endpoint. i.e. The request must be made before the “expires_in” time is reached.\n"
          }
        }
      },
      "TokenReq": {
        "type": "object",
        "required": [
          "auth_req_id",
          "grant_type"
        ],
        "properties": {
          "auth_req_id": {
            "type": "string",
            "example": "39da5b19-457a-4d30-a5c4-047c62dcca3b",
            "description": "The auth_req_id received in the successful authorization endpoint response.\n"
          },
          "grant_type": {
            "type": "string",
            "example": "urn:openid:params:grant-type:ciba",
            "description": "For all token requests the value of the grant_type parameter MUST have the value: \"urn:openid:params:grant-type:ciba\" (Note: must be url encoded)\n"
          }
        }
      },
      "TokenResp": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "example": "dUk4Bs0qgKQKujbGxQDvIdXkI6Bz",
            "description": "OAuth 2.0 access_token used to gain access to the end-user information. This token CANNOT can be reused\n"
          },
          "token_type": {
            "type": "string",
            "example": "Always \"Bearer\"",
            "description": "The timeout available to make a request to the token endpoint. i.e. The request must be made before the “expires_in” time is reached.\n"
          },
          "expires_in": {
            "type": "number",
            "format": "number",
            "example": 3599,
            "description": "Expiration time of the Access Token in seconds since the response was generated.\n"
          },
          "id_token": {
            "type": "string",
            "example": ".8Y4SArYeLdwyVUF7zjW9hyWTULiANn_MbvfXkxk62mKdPEeTI0HNOAG9tsItR1KVhHQdotAZOcoTNLRn66w4TMphQ1K2wfRcWTWKrTXtUA3Xuyx_bhZTkm7Zkz8k944JgpxejWgCjVUejlOiaQJZhu23UWufpd1An4x8UY7JU1LsKJj_OFMleESuM4xoJru0fPUkMMcNKB9D76sfBeSaZeMdqUARBhoWLyO_cb79sFfpu1Uf9V8SFB3NLRuktu0KANwqipwc_5c4LtxzP_rw3A_hWcaGpT67Qk1-tisW6ITCvrFKzZ5aqn8qWPEcte-XGoCXwd7pp0HKzgd1G8xw",
            "description": "This token is not used in CAMARA CIBA flows at this stage and can be ignored.\n"
          }
        }
      },
      "SimSwapInfo": {
        "type": "object",
        "properties": {
          "latestSimChange": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of latest SIM swap performed"
          }
        }
      },
      "CheckSimSwapInfo": {
        "type": "object",
        "properties": {
          "swapped": {
            "type": "boolean",
            "description": "Indicates whether the SIM card has been swapped during the period within the provided age."
          }
        }
      },
      "PhoneNumber": {
        "type": "string",
        "pattern": "^\\+?[1-9][0-9]{4,14}$",
        "example": "+447123456789",
        "description": "Subscriber number in E.164 format (starting with country code). Optionally prefixed with '+'."
      },
      "ErrorInfo": {
        "type": "object",
        "required": [
          "status",
          "code",
          "message"
        ],
        "properties": {
          "status": {
            "type": "integer",
            "description": "HTTP response status code"
          },
          "code": {
            "type": "string",
            "description": "Code given to this error"
          },
          "message": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      },
      "AuthErrorInfo": {
        "type": "object",
        "required": [
          "status",
          "code",
          "message"
        ],
        "properties": {
          "error": {
            "type": "integer",
            "description": "HTTP response status code"
          },
          "error_description": {
            "type": "string",
            "description": "Detailed error description"
          }
        }
      },
      "CreateCheckSimSwap": {
        "type": "object",
        "required": [
          "phoneNumber"
        ],
        "properties": {
          "maxAge": {
            "type": "integer",
            "example": 240,
            "description": "Time period in hours to check mobile account for SIM Swap.Minimum value: 1 (hours) Maximum value: 2400 (hours) If not provided, default value used is 240 (hours).\n",
            "format": "int32",
            "minimum": 1,
            "maximum": 2400,
            "default": 240
          }
        }
      },
      "CreateSimSwapDate": {
        "type": "object",
        "required": [
          "phoneNumber"
        ],
        "properties": {
          "phoneNumber": {
            "$ref": "#/components/schemas/PhoneNumber"
          }
        }
      }
    },
    "responses": {
      "Generic400": {
        "description": "**Bad Request**\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorInfo"
            },
            "examples": {
              "invalid argument": {
                "value": {
                  "status": 400,
                  "code": "INVALID_ARGUMENT",
                  "message": "Client specified an invalid argument, request body or query param"
                }
              }
            }
          }
        }
      },
      "Generic401": {
        "description": "**Unauthorized**\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorInfo"
            },
            "examples": {
              "invalid creds": {
                "value": {
                  "status": 401,
                  "code": "UNAUTHENTICATED",
                  "message": "Request not authenticated due to missing, invalid, or expired credentials"
                }
              }
            }
          }
        }
      },
      "Generic403": {
        "description": "**Forbidden**\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorInfo"
            },
            "examples": {
              "permission denied": {
                "value": {
                  "status": 403,
                  "code": "PERMISSION_DENIED",
                  "message": "Client does not have sufficient permissions to perform this action"
                }
              }
            }
          }
        }
      },
      "Generic404": {
        "description": "**Not Found**\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorInfo"
            },
            "examples": {
              "NOT_FOUND": {
                "value": {
                  "status": 404,
                  "code": "NOT_FOUND",
                  "message": "The specified resource is not found."
                }
              },
              "UNKNOWN_PHONE_NUMBER": {
                "value": {
                  "status": 404,
                  "code": "SIM_SWAP.UNKNOWN_PHONE_NUMBER",
                  "message": "SIM Swap can't be checked because the phone number is unknown."
                }
              }
            }
          }
        }
      },
      "Generic405": {
        "description": "**Method Not Allowed**\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorInfo"
            },
            "examples": {
              "METHOD_NOT_ALLOWED": {
                "value": {
                  "status": 405,
                  "code": "METHOD_NOT_ALLOWED",
                  "message": "The requested method is not allowed/supported on the target resource\""
                }
              }
            }
          }
        }
      },
      "Generic406": {
        "description": "**Not Acceptable**\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorInfo"
            },
            "examples": {
              "Not Acceptable": {
                "value": {
                  "status": 406,
                  "code": "Not Acceptable",
