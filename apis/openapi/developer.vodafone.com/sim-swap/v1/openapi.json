    "/sim-swap/v1/ping": {
      "get": {
        "tags": [
          "Monitoring"
        ],
        "summary": "Check the upstream system is up and running.",
        "description": "This API is to check the upstream system is up and running.",
        "operationId": "getPing",
        "parameters": [
          {
            "$ref": "#/components/parameters/X-Correlator"
          }
        ],
        "responses": {
          "200": {
            "description": "**OK**",
            "content": {
              "application/json": {
