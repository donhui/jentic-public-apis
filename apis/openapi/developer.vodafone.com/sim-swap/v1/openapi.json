          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/TokenReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "**OK** If the token request is successfully completed (i.e. without error), an acess_token is returned by Gateway, in an HTTP 200 response in json payload with parameters.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResp"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/AuthError400"
          },
          "401": {
