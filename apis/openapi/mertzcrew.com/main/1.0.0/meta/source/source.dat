{
  "openapi": "3.0.3",
  "info": {
    "title": "Mertzcrew API",
    "description": "Mertzcrew enables AV companies to book live event freelancers with custom rates, manage crews, and process contracts, insurance, and payments.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api-docs.mertzcrew.com"
  },
  "servers": [
    {
      "url": "https://app.mertzcrew.com/api"
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "Login and user authentication" },
    { "name": "Reference Data", "description": "Countries, states, roles, skills, and classifications" },
    { "name": "Dashboard", "description": "Dashboard widgets and search" },
    { "name": "Clients", "description": "Client entities and users" },
    { "name": "Projects", "description": "Project CRUD and status operations" },
    { "name": "Archived Projects", "description": "Archived project listing and statistics" },
    { "name": "Project Reports", "description": "Project-level reports" },
    { "name": "Project Notes", "description": "Notes on projects" },
    { "name": "Assignments", "description": "Project assignments and approval" },
    { "name": "Contractors", "description": "Contractor search and profiles" },
    { "name": "Employees", "description": "Employee search, profiles, and timesheets" }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate user",
        "description": "Authenticate with username and password to receive a bearer token.",
        "tags": ["Authentication"],
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string", "format": "password" },
                  "output": { "type": "string", "default": "json" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LoginResponse" }
              }
            }
          },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/authenticated-user": {
      "get": {
        "operationId": "getAuthenticatedUser",
        "summary": "Get current authenticated user",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Authenticated user details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/countries": {
      "get": {
        "operationId": "listCountries",
        "summary": "List all countries",
        "tags": ["Reference Data"],
        "responses": {
          "200": {
            "description": "List of countries",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Country" } }
              }
            }
          }
        }
      }
    },
    "/state_provinces": {
      "get": {
        "operationId": "listStateProvinces",
        "summary": "List states and provinces",
        "tags": ["Reference Data"],
        "responses": {
          "200": {
            "description": "List of states/provinces",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/StateProvince" } }
              }
            }
          }
        }
      }
    },
    "/pay_rules/{clientId}": {
      "get": {
        "operationId": "listPayRules",
        "summary": "List pay models/rules for a client",
        "tags": ["Reference Data"],
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of pay rules",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/PayRule" } }
              }
            }
          }
        }
      }
    },
    "/contractor_roles": {
      "get": {
        "operationId": "listContractorRoles",
