      }
    },
    "/project_classifications": {
      "get": {
        "operationId": "listProjectClassifications",
        "summary": "List project classifications",
        "tags": ["Reference Data"],
        "responses": {
          "200": {
            "description": "List of project classifications",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "type": "object" } }
              }
            }
          }
        }
      }
    },
    "/project_classifications/{clientId}": {
      "get": {
        "operationId": "listClientProjectClassifications",
        "summary": "List project classifications for a client",
        "tags": ["Clients"],
        "parameters": [
          { "name": "clientId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "List of client project classifications",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "type": "object" } }
              }
            }
          }
        }
      }
    },
