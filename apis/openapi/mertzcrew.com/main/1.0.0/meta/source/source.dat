        "parameters": [
          { "name": "startDate", "in": "path", "required": true, "schema": { "type": "string", "format": "date" } },
          { "name": "endDate", "in": "path", "required": true, "schema": { "type": "string", "format": "date" } },
          { "name": "main_office", "in": "query", "schema": { "type": "string" }, "description": "Main office ID filter" },
          { "name": "field_office", "in": "query", "schema": { "type": "string" }, "description": "Field office ID filter" }
        ],
        "responses": { "200": { "description": "Payroll report data", "content": { "application/json": { "schema": { "type": "object" } } } } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained from the /login endpoint"
      }
    },
    "schemas": {
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "description": "Bearer token for authentication" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "name": { "type": "string" }
        }
      },
      "Country": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "code": { "type": "string" }
        }
      },
      "StateProvince": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "code": { "type": "string" },
          "country_id": { "type": "string" }
        }
      },
      "PayRule": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "client_id": { "type": "string" }
        }
      },
      "ContractorRole": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Skill": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "field_offices": { "type": "array", "items": { "type": "object" } }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "client_id": { "type": "string" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "location": { "type": "string" },
          "project_type": { "type": "string" }
        }
      },
      "ProjectNote": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "project_id": { "type": "string" },
          "content": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Assignment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "project_id": { "type": "string" },
          "contractor_id": { "type": "string" },
          "role": { "type": "string" },
          "status": { "type": "string" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" }
        }
      },
      "Contractor": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "skills": { "type": "array", "items": { "type": "string" } },
          "roles": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Employee": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        }
      },
      "Timesheet": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "employee_id": { "type": "string" },
          "period_start": { "type": "string", "format": "date" },
          "period_end": { "type": "string", "format": "date" },
          "status": { "type": "string" }
        }
      }
    }
  }
}