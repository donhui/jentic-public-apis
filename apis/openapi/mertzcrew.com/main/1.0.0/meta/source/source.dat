          "200": {
            "description": "List of contractor roles",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ContractorRole" } }
              }
            }
          }
        }
      }
    },
    "/contractor_role_departments": {
      "get": {
        "operationId": "listContractorRoleDepartments",
        "summary": "List contractor role departments",
        "tags": ["Reference Data"],
        "responses": {
          "200": {
            "description": "List of role departments",
