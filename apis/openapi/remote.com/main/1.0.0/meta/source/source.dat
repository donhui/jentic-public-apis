            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter by file type (optional)",
            "example": "contract",
            "in": "query",
            "name": "type",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter by file sub_type (optional)",
            "example": "personal_id",
            "in": "query",
            "name": "sub_type",
            "required": false,
            "schema": {
              "type": "string"
            }
