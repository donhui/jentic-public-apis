          {
            "description": "Employment ID",
            "example": "1a716003-ae89-4810-aa00-25df6e799162",
            "in": "path",
            "name": "employment_id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter by contract document statuses",
            "example": [
              "finished",
              "awaiting_signatures"
