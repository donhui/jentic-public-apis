      "EmploymentFullParams": {
        "additionalProperties": false,
        "description": "Description of the basic required and onboarding tasks params to create an employment.\nYou do not need to include all onboarding tasks when creating or updating an employment.\n",
        "example": {
          "basic_information": {
            "email": "jane@smith.com",
            "name": "Jane Smith"
          },
          "company_id": "663e0b79-c893-45ff-a1b2-f6dcabc098b5",
          "country_code": "AUS",
          "work_email": "jane@smith.com"
        },
        "properties": {
          "address_details": {
            "description": "Home address information. As its properties may vary depending on the country,\n               you must query the [Show form schema](#tag/Countries/operation/get_show_form_country) endpoint\n            passing the country code and `address_details` as path parameters.",
            "type": "object"
          },
          "administrative_details": {
            "description": "Administrative information. As its properties may vary depending on the country,\n               you must query the [Show form schema](#tag/Countries/operation/get_show_form_country) endpoint\n            passing the country code and `administrative_details` as path parameters.",
            "type": "object"
          },
          "bank_account_details": {
            "description": "Bank account information. As its properties may vary depending on the country,\n               you must query the [Show form schema](#tag/Countries/operation/get_show_form_country) endpoint\n            passing the country code and `bank_account_details` as path parameters.",
            "type": "object"
          },
          "basic_information": {
            "description": "Employment basic information. As its properties may vary depending on the country,\n               you must query the [Show form schema](#tag/Countries/operation/get_show_form_country) endpoint\n            passing the country code and `employment_basic_information` as path parameters.",
            "type": "object"
          },
          "billing_address_details": {
            "description": "Billing address information. As its properties may vary depending on the country,\n               you must query the [Show form schema](#tag/Countries/operation/get_show_form_country) endpoint\n            passing the country code and `billing_address_details` as path parameters.",
            "type": "object"
          },
          "company_id": {
            "type": "string"
          },
          "contract_details": {
            "description": "Contract information. As its properties may vary depending on the country,\n               you must query the [Show form schema](#tag/Countries/operation/get_show_form_country) endpoint\n            passing the country code and `contract_details` as path parameters.",
            "type": "object"
          },
          "country": {
            "$ref": "#/components/schemas/Country"
          },
          "country_code": {
            "type": "string"
          },
          "department_id": {
            "description": "The department of the employment. The department must belong to the same company as the employment.\nWhen set to `null`, the employment will be unassigned from a department.\n",
            "nullable": true,
            "type": "string"
          },
          "emergency_contact_details": {
            "description": "Emergency contact information. As its properties may vary depending on the country,\n               you must query the [Show form schema](#tag/Countries/operation/get_show_form_country) endpoint\n            passing the country code and `emergency_contact_details` as path parameters.",
            "type": "object"
          },
          "external_id": {
            "description": "A unique reference code for the employment record in a non-Remote system. This optional field links to external data sources. If not provided, it defaults to `null`. While uniqueness is recommended, it is not strictly enforced within Remote's system.",
            "maxLength": 64,
            "type": "string"
          },
          "manager_id": {
            "description": "The user id of the manager, who should have an `admin`, `owner` or `people_manager` role.\nYou can find these users by querying the [Company Managers endpoint](#operation/get_index_company_manager).\n**Update of this field is only available for active employments.**\n",
            "type": "string"
          },
          "personal_details": {
            "description": "Personal details information. As its properties may vary depending on the country,\n               you must query the [Show form schema](#tag/Countries/operation/get_show_form_country) endpoint\n            passing the country code and `personal_details` as path parameters.",
            "type": "object"
          },
          "pricing_plan_details": {
            "description": "Pricing plan details information. As its properties may vary depending on the country,\n               you must query the [Show form schema](#tag/Countries/operation/get_show_form_country) endpoint\n            passing the country code and `pricing_plan_details` as path parameters.",
            "type": "object"
          },
          "type": {
            "description": "If not provided, it will default to `employee`.",
            "enum": [
              "employee",
              "contractor"
            ],
            "type": "string"
          },
          "work_email": {
            "description": "The work email of the employment.",
            "type": "string"
          }
        },
        "title": "EmploymentFullParams",
        "type": "object"
      },
