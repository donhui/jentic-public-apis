      "CreateProbationExtensionParams": {
        "additionalProperties": false,
        "example": {
          "additional_details": "Employee is on leave.",
          "date_of_discussion_with_employee": "2021-09-01",
          "duration_of_extension_in_days": 30,
          "employment_id": "93t3j-employment_id-9suej43",
          "reason_for_extension": "Employee is on leave.",
          "supporting_document": {
            "content": "base64_encoded_content",
            "name": "supporting_document.pdf"
          },
          "was_employee_informed": true
        },
        "properties": {
          "additional_details": {
            "description": "Any additional details that need to be considered for the probation extension.",
            "example": "Employee is on leave.",
            "type": "string"
          },
          "date_of_discussion_with_employee": {
            "description": "The date when the discussion with the employee took place. Is required when `was_employee_informed` is `true` and should be in the past.",
            "example": "2021-09-01",
            "format": "date",
            "type": "string"
          },
          "duration_of_extension_in_days": {
            "description": "The number of days to add to the existing probation end date.",
            "example": 30,
            "type": "integer"
          },
          "employment_id": {
            "description": "The employment ID that is related to the probation extension request.",
            "example": "93t3j-employment_id-9suej43",
            "type": "string"
          },
          "reason_for_extension": {
            "description": "The reason for the probation extension.",
            "example": "Employee is on leave.",
            "type": "string"
          },
          "supporting_document": {
            "allOf": [
              {
                "$ref": "#/components/schemas/ProbationExtensionFile"
              }
            ],
            "description": "Upload performance improvement plan or any other supporting document.\nThis optional document can be sent only if `was_employee_informed` is `true`.\n",
            "example": "https://example.com/supporting_document.pdf",
            "type": "object"
          },
          "was_employee_informed": {
            "description": "Whether the employee was informed about the probation extension.",
            "example": true,
            "type": "boolean"
          }
        },
        "required": [
          "employment_id",
          "duration_of_extension_in_days",
          "reason_for_extension",
          "was_employee_informed"
        ],
        "title": "CreateProbationExtensionParams",
        "type": "object"
      },
