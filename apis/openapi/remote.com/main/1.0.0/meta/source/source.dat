      "ExpenseOrDraft": {
        "description": "An expense or a draft object, depending on the status. Drafts (status `draft` or `archived`) may have incomplete(null) data.\n\nThe expense status `draft` occurs when users want to save expenses but don't want them to be considered for approval just yet.\nOnly expenses in `pending` status can be approved or declined. It is possible to update a pending expense to status draft, or vice versa.\n\nThere are no flows that change the status of an expense to `draft` automatically. This is purely a manual action by the employee.\n",
        "discriminator": {
          "mapping": {
            "approved": "#/components/schemas/Expense",
            "archived": "#/components/schemas/DraftExpense",
            "canceled": "#/components/schemas/Expense",
            "declined": "#/components/schemas/Expense",
            "draft": "#/components/schemas/DraftExpense",
            "pending": "#/components/schemas/Expense",
            "processing": "#/components/schemas/Expense",
            "reimbursed": "#/components/schemas/Expense"
          },
          "propertyName": "status"
        },
        "example": {
          "amount": 8000,
          "converted_amount": 8000,
          "converted_currency": {
            "code": "CZK",
            "name": "Czech Koruna",
            "symbol": "Kč"
          },
          "converted_tax_amount": 0,
          "currency": {
            "code": "CZK",
            "name": "Czech Koruna",
            "symbol": "Kč"
          },
          "employment_id": "ba9ead59-e471-4043-a7ea-07dbb105e72c",
          "expense_date": "2020-12-11",
          "id": "123e4567-e89b-12d3-a456-426614174000",
          "status": "pending",
          "tax_amount": 0,
          "title": "New keyboard"
        },
        "oneOf": [
          {
            "$ref": "#/components/schemas/Expense"
          },
          {
            "$ref": "#/components/schemas/DraftExpense"
          }
        ],
        "required": [
          "status"
        ],
        "title": "ExpenseOrDraft",
        "type": "object"
      },
