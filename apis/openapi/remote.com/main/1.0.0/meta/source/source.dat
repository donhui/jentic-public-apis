      "ImportJobColumnMapping": {
        "additionalProperties": false,
        "description": "The column mapping for the import job. For times when imported data columns do not match the schema fields and\nneed to be manually mapped to the correct schema fields.\n",
        "example": {
          "mapping": {
            "basic_info.age": {
              "index": 1,
              "name": "years_old",
              "sample_data": "25"
            },
            "basic_info.name": {
              "index": 0,
              "name": "full_name",
              "sample_data": "Aaron Carter"
            }
          },
          "source_columns": [
            {
              "index": 0,
              "name": "full_name",
              "sample_data": "Aaron Carter"
            },
            {
              "index": 1,
              "name": "years_old",
              "sample_data": "25"
            }
          ],
          "unmapped_column_count": 1,
          "unmapped_required_field_count": 1
        },
        "nullable": true,
        "properties": {
          "auto_mapped_columns": {
            "description": "The column names that have been automatically mapped by Tiger (rawr!) and maybe also by AI.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "mapping": {
            "description": "The map of schema fields paths to data columns",
            "type": "object"
          },
          "source_columns": {
            "description": "The data columns to map to",
            "items": {
              "additionalProperties": false,
              "example": {
                "index": 0,
                "name": "full_name",
                "sample_data": "Aaron Carter"
              },
              "properties": {
                "index": {
                  "description": "The index of the data column in the file",
                  "type": "integer"
                },
                "name": {
                  "description": "The name of the data column",
                  "type": "string"
                },
                "sample_data": {
                  "description": "A sample data value from the data column",
                  "nullable": true,
                  "type": "string"
                }
              },
              "required": [
                "name",
                "index"
              ],
              "title": "ImportJobDataColumn",
              "type": "object"
            },
            "type": "array"
          },
          "unmapped_column_count": {
            "description": "The number of columns that have not been mapped",
            "type": "integer"
          },
          "unmapped_required_field_count": {
            "description": "The number of required schema field paths that have not been mapped",
            "type": "integer"
          }
        },
        "required": [
          "mapping",
          "source_columns",
          "unmapped_column_count",
          "unmapped_required_field_count"
        ],
        "title": "ImportJobColumnMapping",
        "type": "object"
      },
