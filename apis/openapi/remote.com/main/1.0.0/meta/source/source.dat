          "start_date",
          "end_date",
          "leave_policy_variant_id",
          "timezone",
          "timeoff_days"
        ],
        "title": "CreateEmployeeTimeoffParams",
        "type": "object"
      },
      "CreateCurrencyCustomFieldDefinitionParams": {
        "additionalProperties": false,
