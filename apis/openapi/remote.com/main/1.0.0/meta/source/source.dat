          "time_breakdown": {
            "day": {
              "holiday": {
                "hours": 35,
                "minutes": 13
              },
              "regular": {
                "hours": 35,
                "minutes": 13
              },
              "weekend": {
                "hours": 35,
                "minutes": 13
              }
            },
            "night": {
              "holiday": {
                "hours": 35,
                "minutes": 13
              },
              "regular": {
                "hours": 35,
                "minutes": 13
              },
              "weekend": {
                "hours": 35,
                "minutes": 13
              }
            }
          },
          "timezone": "Etc/UTC",
          "total_hours": {
            "hours": 35,
            "minutes": 13
          },
          "type": "regular_hours",
          "weekend_hours": {
            "hours": 35,
            "minutes": 13
          }
        },
