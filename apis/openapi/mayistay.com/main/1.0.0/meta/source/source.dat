{
  "openapi": "3.0.3",
  "info": {
    "title": "MayiStay API",
    "version": "1.0.0",
    "description": "MayiStay is the RV renter rating app empowering park owners with anonymous ratings, searchable database, and customizable criteria.",
    "contact": {
      "email": "mayistay-no-reply@bubbleapps.io",
      "url": "https://mayistay.com"
    },
    "x-jentic-source-url": "https://devgoldenaxe.github.io/zapier/"
  },
  "servers": [
    {
      "url": "https://mayistay.com/api/1.1",
      "description": "Production server"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization"
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Workflow",
      "description": "Workflow endpoints"
    }
  ],
  "paths": {
    "/wf/me": {
      "get": {
        "description": "Triggers the workflow me",
        "tags": [
          "Workflow"
        ],
        "operationId": "get_wf_me",
        "responses": {
          "200": {
            "description": "Workflow response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "example": "Goldenaxe Tech"
                    },
                    "email": {
                      "type": "string",
                      "format": "email",
                      "example": "integration-testing@zapier.com"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/wf/search": {
      "get": {
        "description": "Triggers the workflow search",
        "tags": [
          "Workflow"
        ],
        "operationId": "get_wf_search",
        "responses": {
          "200": {
            "description": "Workflow response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Outcome of the workflow"
                    },
                    "error": {
                      "type": "string",
                      "description": "Outcome of the workflow"
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Renter Name": {
                            "type": "string"
                          },
                          "Renter Avearage Rating": {
                            "type": "string"
                          },
                          "Total no of ratings": {
                            "type": "string"
                          },
                          "Total no of negative reviews": {
                            "type": "string"
                          },
                          "Renter ID": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "parameters": [
          {
            "name": "first_name",
            "in": "query",
            "description": "Query parameter first_name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "last_name",
            "in": "query",
            "description": "Query parameter last_name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dob",
            "in": "query",
            "description": "Query parameter dob in MM/DD/YYYY format (e.g., 01/01/2000)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "middle_name",
            "in": "query",
            "description": "Query parameter middle_name",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/wf/renter_details": {
      "get": {
        "description": "Triggers the workflow renterdetails",
        "tags": [
          "Workflow"
        ],
        "operationId": "get_wf_renter_details",
        "responses": {
          "200": {
            "description": "Workflow response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Outcome of the workflow"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error details if any"
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Renter Name": {
                            "type": "string"
                          },
                          "Renter Average Rating": {
                            "type": "number"
                          },
                          "Total no of ratings": {
                            "type": "number"
                          },
                          "Total no of negative reviews": {
                            "type": "number"
                          },
                          "Renter ID": {
                            "type": "string"
                          },
                          "Renter First Name": {
                            "type": "string"
                          },
                          "Renter Last Name": {
                            "type": "string"
                          },
                          "Renter Middle Name": {
                            "type": "string"
                          },
                          "Saved for Reviews": {
                            "type": "string"
                          },
                          "Renter Status": {
                            "type": "string"
                          },
                          "Review": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "Rating total": {
                                  "type": "number"
                                },
                                "Description": {
                                  "type": "string"
                                },
                                "Rating": {
                                  "type": "object",
                                  "properties": {
                                    "Were there any issues with Communication?": {
                                      "type": "number"
                                    },
                                    "Were there any issues with maintenance or Cleanliness?": {
                                      "type": "number"
                                    },
                                    "Were there any issues following House Rules?": {
                                      "type": "number"
                                    },
                                    "Were there any issues with payments?": {
                                      "type": "number"
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "parameters": [
          {
            "name": "renter",
            "in": "query",
            "description": "Query parameter id",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/wf/leave_a_review": {
      "post": {
        "description": "Triggers the workflow save",
        "tags": [
          "Workflow"
        ],
        "operationId": "post_wf_leave_a_review",
        "responses": {
          "200": {
            "description": "Workflow response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Outcome of the workflow",
                      "example": "success"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error details if any"
                    },
                    "results": {
                      "type": "object",
                      "properties": {
                        "Review": {
                          "type": "string",
                          "example": "Successfully submitted"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "parameters": [
          {
            "name": "renter",
            "in": "query",
            "description": "Query parameter renter",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "first_name",
            "in": "query",
            "description": "Query parameter first_name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "last_name",
            "in": "query",
            "description": "Query parameter last_name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dob",
            "in": "query",
            "description": "Query parameter dob in MM/DD/YYYY format (e.g., 01/01/2000)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "middle_name",
            "in": "query",
            "description": "Query parameter middle_name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q1",
            "in": "query",
            "description": "Query parameter q1",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q2",
            "in": "query",
            "description": "Query parameter q2",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q3",
            "in": "query",
            "description": "Query parameter q3",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q4",
            "in": "query",
            "description": "Query parameter q4",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "rent_again",
            "in": "query",
            "description": "Query parameter rent_again (yes/no)",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "description",
            "in": "query",
            "description": "Query parameter description",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/wf/past_reviews": {
      "get": {
        "description": "Triggers the workflow past_reviews",
        "tags": [
          "Workflow"
        ],
        "operationId": "get_wf_past_reviews",
        "responses": {
          "200": {
            "description": "Workflow response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Outcome of the workflow",
                      "example": "success"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error details if any",
                      "example": ""
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Renter ID": {
                            "type": "string",
                            "example": "1742555683647x682435536114414100"
                          },
                          "Renter Name": {
                            "type": "string",
                            "example": "Test Zap"
                          },
                          "Would you like to rent this person?": {
                            "type": "string",
                            "example": "No"
                          },
                          "Rating Total": {
                            "type": "number",
                            "example": 2.75
                          },
                          "Total Reviews": {
                            "type": "integer",
                            "example": 3
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Query parameter renter_name",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sorting option (High to Low or Low to High)",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/wf/booking_renter": {
      "post": {
        "description": "Triggers the workflow booking_renter",
        "tags": [
          "Workflow"
        ],
        "operationId": "post_wf_booking_renter",
        "responses": {
          "200": {
            "description": "Workflow response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "Outcome of the workflow",
                      "example": "Booked Successfully"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error details if any"
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Booking status": {
                            "type": "string",
                            "example": "Booked Successfully"
                          },
                          "Renter ID": {
                            "type": "string",
                            "example": "1742794505256x890368286827908000"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "parameters": [
          {
            "name": "renter_id",
            "in": "query",
            "description": "Query parameter renter_id",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "renter_fname",
            "in": "query",
            "description": "Query parameter renter_fname",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "renter_lname",
            "in": "query",
            "description": "Query parameter renter_lname",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dob",
            "in": "query",
            "description": "Query parameter dob in MM/DD/YYYY format (e.g., 01/01/2000)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "renter_mname",
            "in": "query",
            "description": "Query parameter renter_mname",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "description": "Query parameter start_date in MM/DD/YYYY format (e.g., 01/01/2000)",
            "required": false,
            "schema": {
              "type": "date-time"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "description": "Query parameter end_date in MM/DD/YYYY format (e.g., 01/01/2000)",
            "required": false,
            "schema": {
              "type": "date-time"
            }
          }
        ]
      }
    }
  }
}