{
  "openapi": "3.0.3",
  "info": {
    "title": "GDELT DOC 2.0 API",
    "description": "The GDELT DOC 2.0 API provides full-text search across the entire GDELT 2.0 universe spanning 3 months of global news coverage across 65 languages, with support for multiple output modes including article lists, timelines, word clouds, and image collages.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://blog.gdeltproject.org/gdelt-doc-2-0-api-debuts/"
  },
  "servers": [
    {
      "url": "https://api.gdeltproject.org/api/v2",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Doc",
      "description": "Document search and analysis"
    }
  ],
  "paths": {
    "/doc/doc": {
      "get": {
        "operationId": "searchdocuments",
        "summary": "Search GDELT documents",
        "description": "Performs full-text search across GDELT 2.0 global news coverage with support for multiple output modes and formats.",
        "tags": [
          "Doc"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query with operators. Supports quoted phrases, OR boolean logic, domain:, sourcecountry:, sourcelang:, tone:, near: operators."
          },
          {
            "name": "mode",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "artlist",
                "artgallery",
                "imagecollage",
                "imagecollageinfo",
                "imagecollageshare",
                "imagetag",
                "imagetone",
                "imagewebcount",
                "imagewebtag",
                "timeline",
                "timelinetone",
                "timelinelang",
                "timelinesourcecountry",
                "timelinetheme",
                "tonechart",
                "wordcloud"
              ]
            },
            "description": "Output mode controlling the type of results returned."
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "html",
                "csv",
                "json",
                "jsonp",
                "rss",
                "rssarchive",
                "jsonfeed"
              ]
            },
            "description": "Response format."
          },
          {
            "name": "timespan",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Time span for search. Format: Xmin, Xh, Xd, Xw, Xm (minutes, hours, days, weeks, months)."
          },
          {
            "name": "startdatetime",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Start datetime in YYYYMMDDHHMMSS format."
          },
          {
            "name": "enddatetime",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "End datetime in YYYYMMDDHHMMSS format."
          },
          {
            "name": "maxrecords",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 250,
              "default": 75
            },
            "description": "Maximum number of results (1-250)."
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "datedesc",
                "dateasc",
                "tonedesc",
                "toneasc",
                "hybridrel"
              ]
            },
            "description": "Sort order for results."
          },
          {
            "name": "timelinesmooth",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 30
            },
            "description": "Moving window smoothing for timeline modes."
          },
          {
            "name": "timezoom",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "yes",
                "no"
              ]
            },
            "description": "Enable interactive timeline zoom."
          },
          {
            "name": "trans",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Translation widget identifier (e.g., googtrans)."
          },
          {
            "name": "callback",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "JSONP callback function name."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response. Format varies based on mode and format parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid query or parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "DocSearchResponse": {
        "type": "object",
        "properties": {
          "articles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Article"
            }
          }
        }
      },
      "Article": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "url_mobile": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "seendate": {
            "type": "string"
          },
          "socialimage": {
            "type": "string",
            "format": "uri"
          },
          "domain": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "sourcecountry": {
            "type": "string"
          },
          "tone": {
            "type": "number"
          }
        }
      }
    }
  },
  "security": []
}