{
  "openapi": "3.0.3",
  "info": {
    "title": "Agent Gift Cards API Suite",
    "version": "1.2",
    "description": "This set of APIs allows the management of Gift Card balances.  It is only supported for use within the Grapevine system.\n",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/Direct_Wines/AgentGiftCardsApiSuite/1.2/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/Direct_Wines/AgentGiftCardsApiSuite/1.2"
    },
    {
      "description": "This Grapevine site.",
      "url": "/gvapi"
    }
  ],
  "paths": {
    "/agent/giftcards/{cardNumber}/balance": {
      "get": {
        "summary": "Query Gift Card Balance",
        "description": "Retrieves the balance of a specific gift card using its card number only.\n\n  **NOTE** This API is for Grapevine Agent use only. \n\n  **Example Usage:**\n\n  ```\n  GET /giftCards/6280390000000011/balance\n  \n  ```\n",
        "parameters": [
          {
            "name": "cardNumber",
            "in": "path",
            "description": "The card number",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BalanceResponse"
                },
                "examples": {
                  "SuccessfulResponse": {
                    "value": {
                      "statusMessage": "Success",
                      "statusCode": 200,
                      "response": {
                        "requestId": "REQ_29052020_002",
                        "responseCode": 0,
                        "responseText": "Success",
                        "cardNumber": "6280390000000011",
                        "balance": 25.99,
                        "authCode": 175143729
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/apis/Direct_Wines/CommonAPIModelsSuite/1.7.0#/components/schemas/ApiResponse"
                },
                "examples": {
                  "BadlyStructuredRequest": {
                    "value": {
                      "statusMessage": "BAD REQUEST- Please correct the request.",
                      "statusCode": 400,
                      "errorResponse": {
                        "code": "bad_request_error",
                        "message": "The request is not structured per the schema definition."
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "A validation error occured when calling this API method.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/apis/Direct_Wines/CommonAPIModelsSuite/1.7.0#/components/schemas/CommonResponseHeader"
                },
                "examples": {
                  "InvalidCard": {
                    "value": {
                      "statusMessage": "Invalid Gift Card Number",
                      "statusCode": 422,
                      "errorResponse": {
                        "code": "invalid_card_number",
                        "message": "The card number is invalid."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent/giftcards/orders/{cardNumber}": {
      "get": {
        "summary": "Query Orders wtih Gift Card Id",
        "description": "Retrieves the List of orders that have the payment method as that of the input gift card id.\n\n**NOTE** This API is for Grapevine Agent use only. \n\n**Example Usage:**\n\n```\nGET /giftCards/orders/628039000000001\n```\n",
        "parameters": [
          {
            "name": "cardNumber",
            "in": "path",
            "description": "The card number",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GiftCardOrderResponse"
                },
                "examples": {
                  "giftcardOrderResponse": {
                    "$ref": "#/components/examples/GiftCardOrderResponseDetail-1001"
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/apis/Direct_Wines/CommonAPIModelsSuite/1.7.0#/components/schemas/ApiResponse"
                },
                "examples": {
                  "BadlyStructuredRequest": {
                    "value": {
                      "statusMessage": "BAD REQUEST- Please correct the request.",
                      "statusCode": 400,
                      "errorResponse": {
                        "code": "bad_request_error",
                        "message": "The request is not structured per the schema definition."
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "A validation error occured when calling this API method.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/apis/Direct_Wines/CommonAPIModelsSuite/1.7.0#/components/schemas/CommonResponseHeader"
                },
                "examples": {
                  "InvalidCard": {
                    "value": {
                      "statusMessage": "Invalid Gift Card Number",
                      "statusCode": 422,
                      "errorResponse": {
                        "code": "invalid_card_number",
                        "message": "The card number is invalid."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent/giftcards/transactionLogs/{cardNumber}": {
      "get": {
        "summary": "Query Savvy Transaction Log for Gift Card Id",
        "description": "Retrieves the List of transaction logs that have the card number as that of the input gift card number.\n\n**NOTE** This API is for Grapevine Agent use only. \n\n**Example Usage:**\n\n```\nGET /giftCards/transactionLogs/628039000000001\n```\n",
        "parameters": [
          {
            "name": "cardNumber",
            "in": "path",
            "description": "The card number",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GiftCardTransactionLogResponse"
                },
                "examples": {
                  "giftcardTransactionLogResponse": {
                    "$ref": "#/components/examples/GiftCardTransactionLogResponseDetail-1001"
                  }
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/apis/Direct_Wines/CommonAPIModelsSuite/1.7.0#/components/schemas/ApiResponse"
                },
                "examples": {
                  "BadlyStructuredRequest": {
                    "value": {
                      "statusMessage": "BAD REQUEST- Please correct the request.",
                      "statusCode": 400,
                      "errorResponse": {
                        "code": "bad_request_error",
                        "message": "The request is not structured per the schema definition."
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "A validation error occured when calling this API method.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "https://api.swaggerhub.com/apis/Direct_Wines/CommonAPIModelsSuite/1.7.0#/components/schemas/CommonResponseHeader"
                },
                "examples": {
                  "InvalidCard": {
                    "value": {
                      "statusMessage": "Invalid Gift Card Number",
                      "statusCode": 422,
                      "errorResponse": {
                        "code": "invalid_card_number",
                        "message": "The card number is invalid."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent/giftcards/order/payment/remove/{orderId}/{cardNumber}": {
      "delete": {
        "summary": "delete the payment group id from the input order id",
        "description": "Delete the payment group from the order for the input payment group id and order id.\n\n**NOTE** This API is for Grapevine Agent use only. \n\n**Example Usage:**\n\n```\n GET /giftCards/order/payment/remove/eo4563123/987654321123123\n```\n",
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "description": "Order Id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cardNumber",
            "in": "path",
            "description": "Card Number",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GiftCardOrderPaymentUpdateResponse"
                },
                "examples": {
                  "giftcardOrderResponse": {
                    "$ref": "#/components/examples/GiftCardOrderPaymentUpdateResponse-1001"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agent/giftcards/transaction/reverse/{transactionId}/{cardNumber}": {
      "delete": {
        "summary": "update the transaction log after reverse call of gift card details for the given transaction Id and card number",
        "description": "Update the transaction log after reverse service call for the gift card details for the transaction Id and card number.\n\n**NOTE** This API is for Grapevine Agent use only. \n\n**Example Usage:**\n\n```\n GET /agent/giftcards/transaction/reverse/987654321123123/189123123123\n```\n",
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "description": "Order Id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cardNumber",
            "in": "path",
            "description": "Card Number",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GiftCardTransactionReverseUpdateResponse"
                },
                "examples": {
                  "giftcardOrderResponse": {
                    "$ref": "#/components/examples/GiftCardTransactionReverseUpdateResponse-1001"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BalanceResponse": {
        "allOf": [
          {
            "$ref": "https://api.swaggerhub.com/apis/Direct_Wines/CommonAPIModelsSuite/1.7.0#/components/schemas/ApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "response": {
                "$ref": "#/components/schemas/BalanceResponseDetail"
              }
            }
          }
        ]
      },
      "BalanceResponseDetail": {
        "type": "object",
        "properties": {
          "responseCode": {
            "type": "integer",
            "description": "Normally zero. A non-zero value indicates the transaction was declined."
          },
          "responseText": {
            "type": "string",
            "description": "If present, returns some information relating to the transaction, and may include an error message."
          },
          "requestId": {
            "type": "string",
            "description": "This is echoed back from the unique client-generated reference in the request."
          },
          "balance": {
            "type": "number",
            "format": "double",
            "description": "The balance remaining on the card after the transaction was processed."
          },
          "cardNumber": {
            "type": "string",
            "description": "The card number."
          },
          "authCode": {
            "type": "integer",
            "description": "A unique system-generated reference for the transaction."
          }
        }
      },
      "GiftCardOrderResponse": {
        "allOf": [
          {
            "$ref": "https://api.swaggerhub.com/apis/Direct_Wines/CommonAPIModelsSuite/1.7.0#/components/schemas/ApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "response": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/GiftCardOrderResponseDetail"
                }
              }
            }
          }
        ]
      },
      "GiftCardOrderResponseDetail": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "description": "order id of the order in which the gift card is used"
          },
          "orderTotal": {
            "type": "number",
            "format": "double",
            "description": "total order value"
          },
          "orderStatus": {
            "type": "string",
            "description": "Order status"
          },
          "cardNumber": {
            "type": "string",
            "description": "The card number."
          },
          "amountUsed": {
            "type": "number",
            "format": "double",
            "description": "amount used on Voucher for this order"
          },
          "paymentStatus": {
            "type": "string",
            "description": "status of payment"
          }
        }
      },
      "GiftCardOrderPaymentUpdateResponse": {
        "type": "object",
        "properties": {
          "responseMessage": {
            "type": "string",
            "description": "message to be displayed for the action executed"
          }
        }
      },
      "GiftCardTransactionLogResponse": {
        "allOf": [
          {
            "$ref": "https://api.swaggerhub.com/apis/Direct_Wines/CommonAPIModelsSuite/1.7.0#/components/schemas/ApiResponse"
          },
          {
            "type": "object",
            "properties": {
              "response": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/GiftCardTransactionLogResponseDetail"
                }
              }
            }
          }
        ]
      },
      "GiftCardTransactionLogResponseDetail": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string",
            "description": "transaction id of the transaction in which the gift card is used"
          },
          "transactionTime": {
            "type": "string",
            "description": "transaction time of the transaction in which the gift card is used"
          },
          "profileId": {
            "type": "string",
            "description": "profile id of the user involved in the transaction"
          },
          "orderId": {
            "type": "string",
            "description": "order id of the order in which the gift card is used"
          },
          "cardNumber": {
            "type": "string",
            "description": "The card number."
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "amount used on Voucher for this order"
          },
          "status": {
            "type": "string",
            "description": "status of transaction Authorized or Auth Failed"
          },
          "type": {
            "type": "string",
            "description": "type of transaction i.e. Redeem or Reverse"
          },
          "source": {
            "type": "string",
            "description": "source of transaction; one of WEBSITE, shop, GV"
          }
        }
      },
      "GiftCardTransactionReverseUpdateResponse": {
        "type": "object",
        "properties": {
          "responseMessage": {
            "type": "string",
            "description": "message to be displayed for the action executed"
          }
        }
      }
    },
    "examples": {
      "GiftCardOrderResponseDetail-1001": {
        "value": [
          {
            "GiftCardOrderResponseDetail": {
              "orderId": "o100001",
              "orderTotal": "80",
              "orderStatus": "INCOMPLETE",
              "cardNumber": "2098123123123123",
              "amountUsed": "30",
              "paymentStatus": "Authorized"
            }
          },
          {
            "GiftCardOrderResponseDetail": {
              "orderId": "o100002",
              "orderTotal": "110",
              "orderStatus": "INVOICED",
              "cardNumber": "2098123123123345",
              "amountUsed": "40",
              "paymentStatus": "Authorized"
            }
          }
        ]
      },
      "GiftCardOrderPaymentUpdateResponse-1001": {
        "value": {
          "responseMessage": "Gift card - <cardNumber> deleted from order Id - <orderId> successfully"
        }
      },
      "GiftCardTransactionLogResponseDetail-1001": {
        "value": [
          {
            "GiftCardTransactionLogResponseDetail": {
              "transactionId": "65141231",
              "transactionTime": "",
              "profileId": "123451123",
              "orderId": "o100001",
              "amount": "80",
              "cardNumber": "2098123123123123",
              "status": "Authorized",
              "type": "Redeemed",
              "source": "GV"
            }
          },
          {
            "GiftCardTransactionLogResponseDetail": {
              "transactionId": "65141232",
              "transactionTime": "",
              "profileId": "123451123",
              "orderId": "o100002",
              "cardNumber": "2098123123123345",
              "amount": "40",
              "status": "Auth Failed",
              "type": "Redeemed",
              "source": "GV"
            }
          }
        ]
      },
      "GiftCardTransactionReverseUpdateResponse-1001": {
        "value": {
          "responseMessage": "Transaction reversed for Gift card - <cardNumber> in order Id - <orderId> successfully"
        }
      }
    }
  }
}