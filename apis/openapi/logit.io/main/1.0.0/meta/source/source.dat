{
  "openapi": "3.0.3",
  "info": {
    "title": "Logit.io Developer API",
    "description": "Logit.io Developer API for managing accounts, stacks, log management, infrastructure metrics, alerting, and ingestion monitoring.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://logit.io/docs/developer-api/overview/"
  },
  "servers": [
    {
      "url": "https://dashboard.logit.io",
      "description": "Logit.io Dashboard API"
    }
  ],
  "paths": {
    "/api/me/profile": {
      "get": {
        "operationId": "getMyProfile",
        "summary": "Get current user profile",
        "description": "Retrieve the profile information for the currently authenticated user.",
        "tags": [
          "Me"
        ],
        "responses": {
          "200": {
            "description": "User profile retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfile"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/me/apikeys": {
      "get": {
        "operationId": "listMyApiKeys",
        "summary": "List API keys",
        "description": "List all API keys for the authenticated user.",
        "tags": [
          "Me"
        ],
        "responses": {
          "200": {
            "description": "API keys retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "apiKeys": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ApiKey"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/account": {
      "get": {
        "operationId": "getAccount",
        "summary": "Get account information",
        "description": "Retrieve account details for the authenticated user.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Account information retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Account"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/account/users": {
      "get": {
        "operationId": "listAccountUsers",
        "summary": "List account users",
        "description": "List all users associated with the account.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Users retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "users": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/User"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/account/teams": {
      "get": {
        "operationId": "listAccountTeams",
        "summary": "List account teams",
        "description": "List all teams associated with the account.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Teams retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "teams": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Team"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/account/stacks": {
      "get": {
        "operationId": "listAccountStacks",
        "summary": "List account stacks",
        "description": "List all stacks accessible to the account.",
        "tags": [
          "Account"
        ],
        "responses": {
          "200": {
            "description": "Stacks retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "stacks": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Stack"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/stacks/{stackId}/overview": {
      "get": {
        "operationId": "getStackOverview",
        "summary": "Get stack overview",
        "description": "Retrieve overview information for a specific stack.",
        "tags": [
          "Stacks"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "description": "The stack identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stack overview retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StackOverview"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        }
      }
    },
    "/api/stacks/{stackId}/connection-details": {
      "get": {
        "operationId": "getStackConnectionDetails",
        "summary": "Get stack connection details",
        "description": "Retrieve connection details for a specific stack.",
        "tags": [
          "Stacks"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Connection details retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConnectionDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/stacks/{stackId}/statistics": {
      "get": {
        "operationId": "getStackStatistics",
        "summary": "Get stack statistics",
        "description": "Retrieve statistics for a specific stack.",
        "tags": [
          "Stacks"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Stack statistics retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StackStatistics"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/stacks/{stackId}/alerting": {
      "get": {
        "operationId": "getStackAlerting",
        "summary": "Get stack alerting configuration",
        "description": "Retrieve alerting configuration for a specific stack.",
        "tags": [
          "Alerting"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alerting configuration retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      },
      "put": {
        "operationId": "updateStackAlerting",
        "summary": "Update stack alerting configuration",
        "description": "Enable or disable alerting for a specific stack.",
        "tags": [
          "Alerting"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Alerting configuration updated"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        }
      }
    },
    "/api/stacks/{stackId}/alert-rules": {
      "get": {
        "operationId": "listStackAlertRules",
        "summary": "List alert rules",
        "description": "List all alert rules for a specific stack.",
        "tags": [
          "Alerting"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alert rules retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "alertRules": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/AlertRule"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      },
      "post": {
        "operationId": "createStackAlertRule",
        "summary": "Create an alert rule",
        "description": "Create a new alert rule for a specific stack.",
        "tags": [
          "Alerting"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlertRule"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Alert rule created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlertRule"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        }
      }
    },
    "/api/stacks/{stackId}/ingestion/logs": {
      "get": {
        "operationId": "getLogIngestionStats",
        "summary": "Get log ingestion statistics",
        "description": "Retrieve log ingestion statistics for a specific stack.",
        "tags": [
          "Ingestion"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Log ingestion statistics retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/stacks/{stackId}/ingestion/metrics": {
      "get": {
        "operationId": "getMetricsIngestionStats",
        "summary": "Get metrics ingestion statistics",
        "description": "Retrieve metrics ingestion statistics for a specific stack.",
        "tags": [
          "Ingestion"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Metrics ingestion statistics retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/stacks/{stackId}/log-management/pipeline": {
      "get": {
        "operationId": "getLogPipelineConfig",
        "summary": "Get log pipeline configuration",
        "description": "Retrieve the pipeline configuration for log management.",
        "tags": [
          "Log Management"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pipeline configuration retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      },
      "put": {
        "operationId": "updateLogPipelineConfig",
        "summary": "Update log pipeline configuration",
        "description": "Update the pipeline configuration for log management.",
        "tags": [
          "Log Management"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pipeline configuration updated"
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        }
      }
    },
    "/api/stacks/{stackId}/log-management/security": {
      "get": {
        "operationId": "getLogSecurityRules",
        "summary": "Get log security/firewall rules",
        "description": "Retrieve security and firewall rules for log management.",
        "tags": [
          "Log Management"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Security rules retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    },
    "/api/stacks/{stackId}/log-management/diagnostics": {
      "get": {
        "operationId": "getLogDiagnostics",
        "summary": "Get log diagnostics",
        "description": "Retrieve diagnostics information for log management.",
        "tags": [
          "Log Management"
        ],
        "parameters": [
          {
            "name": "stackId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Diagnostics retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Logit.io API user key"
      }
    },
    "schemas": {
      "UserProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ApiKey": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "plan": {
            "type": "string"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "Team": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Stack": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "productType": {
            "type": "string",
            "enum": [
              "logs",
              "metrics",
              "apm"
            ]
          },
          "status": {
            "type": "string"
          }
        }
      },
      "StackOverview": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "productType": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "ConnectionDetails": {
        "type": "object",
        "properties": {
          "stackId": {
            "type": "string"
          },
          "host": {
            "type": "string"
          },
          "port": {
            "type": "integer"
          },
          "protocol": {
            "type": "string"
          }
        }
      },
      "StackStatistics": {
        "type": "object",
        "properties": {
          "stackId": {
            "type": "string"
          },
          "totalEvents": {
            "type": "integer"
          },
          "storageUsed": {
            "type": "integer"
          }
        }
      },
      "AlertRule": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "condition": {
            "type": "object"
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "ProblemDetail": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKeyAuth": []
    }
  ]
}