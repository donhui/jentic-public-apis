{
  "openapi": "3.0.3",
  "info": {
    "title": "Land Matrix API",
    "description": "REST API for the Land Matrix, providing access to data on large-scale land acquisitions (deals), investors, countries, regions, and more. Built on Django REST Framework.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://landmatrix.org/api/"
  },
  "servers": [
    {
      "url": "https://landmatrix.org/api",
      "description": "Production server"
    }
  ],
  "paths": {
