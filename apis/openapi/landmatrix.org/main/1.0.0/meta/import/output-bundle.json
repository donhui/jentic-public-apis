  "components": {
    "parameters": {
      "FormatParam": {
        "name": "format",
        "in": "query",
        "description": "Response format",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "json",
            "api"
          ]
        }
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "Currency": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      },
      "Country": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "code_alpha2": {
            "type": "string"
          },
          "code_alpha3": {
            "type": "string"
          },
          "region": {
            "$ref": "#/components/schemas/Region"
          }
        }
      },
      "Region": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Deal": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "country": {
            "$ref": "#/components/schemas/Country"
          },
          "intended_size": {
            "type": "number"
          },
          "contract_size": {
            "type": "number"
          },
          "production_size": {
            "type": "number"
          },
          "intention_of_investment": {
            "type": "string"
          },
          "nature_of_deal": {
            "type": "string"
          },
          "negotiation_status": {
            "type": "string"
          },
          "implementation_status": {
            "type": "string"
          }
        }
      },
      "DealVersion": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "deal": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Investor": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "country": {
            "$ref": "#/components/schemas/Country"
          },
          "classification": {
            "type": "string"
          },
          "homepage": {
            "type": "string"
          }
        }
      },
      "InvestorVersion": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "investor": {
            "type": "integer"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Chart": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
