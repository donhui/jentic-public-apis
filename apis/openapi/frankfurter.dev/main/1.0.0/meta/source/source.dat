{
  "openapi": "3.0.3",
  "info": {
    "title": "Frankfurter",
    "version": "1.0.0",
    "description": "Frankfurter is a free, open-source currency exchange rate API that tracks foreign exchange rates published by the European Central Bank. It provides current and historical rates for 30+ currencies.",
    "x-jentic-source-url": "https://frankfurter.dev/docs"
  },
  "servers": [
    {
      "url": "https://api.frankfurter.dev"
    }
  ],
  "paths": {
    "/v1/latest": {
      "get": {
        "operationId": "getLatestRates",
        "summary": "Get latest exchange rates",
        "description": "Returns the latest exchange rates published by the ECB.",
        "tags": ["Rates"],
        "parameters": [
          {
            "name": "base",
            "in": "query",
            "required": false,
            "description": "Base currency (default EUR)",
            "schema": { "type": "string", "default": "EUR" }
          },
          {
            "name": "symbols",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of target currencies",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with latest rates",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ExchangeRateResponse" }
              }
            }
          },
          "400": { "description": "Bad request - invalid currency code" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/{date}": {
      "get": {
        "operationId": "getHistoricalRates",
        "summary": "Get historical exchange rates",
        "description": "Returns exchange rates for a specific date.",
        "tags": ["Rates"],
        "parameters": [
          {
            "name": "date",
            "in": "path",
            "required": true,
            "description": "Date in YYYY-MM-DD format",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "base",
            "in": "query",
            "required": false,
            "description": "Base currency (default EUR)",
            "schema": { "type": "string", "default": "EUR" }
          },
          {
            "name": "symbols",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of target currencies",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with historical rates",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ExchangeRateResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/{startDate}..{endDate}": {
      "get": {
        "operationId": "getTimeSeriesRates",
        "summary": "Get time series exchange rates",
        "description": "Returns exchange rates for a date range.",
        "tags": ["Rates"],
        "parameters": [
          {
            "name": "startDate",
            "in": "path",
            "required": true,
            "description": "Start date (YYYY-MM-DD)",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "endDate",
            "in": "path",
            "required": true,
            "description": "End date (YYYY-MM-DD)",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "base",
            "in": "query",
            "required": false,
            "description": "Base currency (default EUR)",
            "schema": { "type": "string", "default": "EUR" }
          },
          {
            "name": "symbols",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of target currencies",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with time series rates",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TimeSeriesResponse" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/v1/currencies": {
      "get": {
        "operationId": "listCurrencies",
        "summary": "List available currencies",
        "description": "Returns all available currencies with their full names.",
        "tags": ["Currencies"],
        "responses": {
          "200": {
            "description": "Successful response with currency list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CurrencyList" }
              }
            }
          },
          "400": { "description": "Bad request" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ExchangeRateResponse": {
        "type": "object",
        "properties": {
          "amount": { "type": "number", "description": "Amount converted (default 1)" },
          "base": { "type": "string", "description": "Base currency code" },
          "date": { "type": "string", "format": "date", "description": "Date of the rates" },
          "rates": {
            "type": "object",
            "additionalProperties": { "type": "number" },
            "description": "Exchange rates keyed by currency code"
          }
        }
      },
      "TimeSeriesResponse": {
        "type": "object",
        "properties": {
          "amount": { "type": "number" },
          "base": { "type": "string" },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "rates": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": { "type": "number" }
            },
            "description": "Rates keyed by date, then by currency code"
          }
        }
      },
      "CurrencyList": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Currency codes mapped to their full names"
      }
    },
    "securitySchemes": {}
  },
  "security": []
}