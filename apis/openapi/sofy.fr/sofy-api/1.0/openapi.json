          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dateAdded",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "perPage",
            "required": false,
            "in": "query",
            "description": "Amount of items per page",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "The current page to show, based on the number of items per page",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "orderBy",
            "required": false,
            "in": "query",
            "description": "Name of field from underlying data model to order items off of",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "headers": {
              "Pagination-TotalItems": {
                "schema": {
                  "type": "integer"
                },
                "description": "Total amount of items"
              },
              "Pagination-TotalPages": {
                "schema": {
                  "type": "integer"
                },
                "description": "Total amount of pages"
              },
              "Pagination-PerPage": {
                "schema": {
                  "type": "integer"
                },
                "description": "Amount of items per page, as requested"
              },
              "Pagination-Page": {
                "schema": {
                  "type": "integer"
                },
                "description": "The current page to show, as requested"
              },
              "Pagination-ItemsOnPage": {
                "schema": {
                  "type": "integer"
                },
                "description": "Amount of items on the current page. Can be less than requested (perPage)"
              }
            },
            "description": ""
          },
          "default": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Contact"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "contacts"
        ],
        "security": [
          {
            "X-API-KEY-ID": []
          },
          {
            "X-API-KEY-SECRET": []
          }
        ]
