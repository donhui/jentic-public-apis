    "/webhooks": {
      "post": {
        "operationId": "create",
        "summary": "",
        "description": "Register a webhook that will be called for defined events. You must register a webhook to receive SMS delivery statuses, as SMS sending is asynchronous operation.<br /><strong>Your webhook endpoint must return a 2xx status to be considered successful.</strong> Webhooks will be replayed following an exponential backoff, if for some reason your system couldn't handle the request at a specific time. <br />Wait for \"n^4 + j\" minutes between each retry.<br />Where:<br />- n: The number of times the webhooks has been retried <br />- j: A random jitter between 0 and 10 seconds<br /><br />Webhook will be replayed a maximum of 10 times.",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateWebhookDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook created successfully"
          },
          "409": {
            "description": "This url is already registered for the same event"
          }
        },
        "tags": [
          "webhooks"
        ],
        "security": [
          {
            "X-API-KEY-ID": []
          },
          {
            "X-API-KEY-SECRET": []
          }
        ]
      },
      "get": {
        "operationId": "retrieve",
        "summary": "",
        "description": "Retrieve all registered webhooks",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": [
