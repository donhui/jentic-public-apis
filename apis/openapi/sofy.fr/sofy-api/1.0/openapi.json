  "info": {
    "title": "Sofy API",
    "description": "The api intended for use by sofy customers <br><strong>Production environment</strong>",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "contacts"
    },
    {
      "name": "customColumns"
    },
    {
      "name": "groups"
    },
    {
      "name": "sms"
    },
    {
      "name": "wallets"
    },
    {
      "name": "webhooks"
    }
  ],
  "servers": [
    {
      "url": "https://api.sofy.fr/v1"
    }
  ],
  "components": {
    "securitySchemes": {
      "X-API-KEY-ID": {
        "in": "header",
        "type": "apiKey",
        "scheme": "https",
        "name": "X-API-KEY-ID",
        "rule": "and"
      },
      "X-API-KEY-SECRET": {
        "in": "header",
        "type": "apiKey",
        "scheme": "https",
        "name": "X-API-KEY-SECRET",
        "rule": "and"
      }
    },
    "schemas": {
      "CreateSmsBroadcastDto": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "If specified, sends the message with this sender. Otherwise will default to a shortcode. Beware that you will not be able to receive a reply if you use a value other than the default",
            "default": "36789"
          },
          "template": {
            "type": "string",
            "description": "Template of the message to send. A single SMS is bound to 160 characters. So sending more characters than this will result in the message being split in multiple parts",
            "example": "Hello world {{variable1}} {{variableN}}!"
          },
          "shortenUrls": {
            "type": "boolean",
            "description": "Whether to reduce urls or not. This is the default behaviour as it improves deliverability. Any links found in the \"body\" property will be reduced to a shortlink.",
            "default": true
          },
          "isTransactional": {
            "type": "boolean",
            "description": "Transactional SMS contain time-sensitive information that is required for customers to use your product or service. Transactional texts include many types of alerts, confirmations or verifications. It's important to note that transactional text messages must contain necessary information. <br /> <br />If not specified, the message will be sent as a promotional message, which is the default behavior",
            "default": false
          }
        },
        "required": [
          "template"
        ]
      },
      "CreateSmsDto": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "description": "If specified, sends the message with this sender. Otherwise will default to a shortcode. Beware that you will not be able to receive a reply if you use a value other than the default",
            "default": "36789"
          },
          "to": {
            "type": "string",
            "description": "Recipient of the message in E.164 notation. Must be a valid mobile phone number",
            "example": "336112233"
          },
          "body": {
            "type": "string",
            "description": "Content of the message to send. A single SMS is bound to 160 characters. So sending more characters than this will result in the message being split in multiple parts",
            "example": "Hello world !"
          },
          "shortenUrls": {
            "type": "boolean",
            "description": "Whether to reduce urls or not. This is the default behaviour as it improves deliverability. Any links found in the \"body\" property will be reduced to a shortlink.",
            "default": true
          },
          "isTransactional": {
            "type": "boolean",
            "description": "Transactional SMS contain time-sensitive information that is required for customers to use your product or service. Transactional texts include many types of alerts, confirmations or verifications. It's important to note that transactional text messages must contain necessary information. <br /> <br />If not specified, the message will be sent as a promotional message, which is the default behavior",
            "default": false
          },
          "data": {
            "type": "object",
            "description": "Additional data that you would like to be passed back when callback is invoked. This will not be stored on your behalf.",
            "example": "{ \"key\": \"value\" }"
          }
        },
        "required": [
          "to",
          "body"
        ]
      },
      "CreateSmsResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique ID for the sms message. Max length of 50 characters with possible characters being a-z,A-Z,0-9,_-"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "sent",
              "errored",
              "delivered"
            ],
            "description": "Will always be SmsStatus.pending for a newly created SMS. Subscribe to a webhook in order to receive further status updates"
          },
          "statusReason": {
            "type": "string",
            "description": "Reason for the status, if status is \"sent\", \"errored\" or \"delivered\" . Eg: UNDELIV, DELIVRD, UNKNOWN, EXPIRED, REJECTD"
          },
          "to": {
            "type": "string",
            "description": "Destination phone number"
          },
          "from": {
            "type": "string",
            "description": "Sender phone number"
          },
          "body": {
            "type": "string",
            "description": "Body of the created SMS"
          },
          "isTransactional": {
            "type": "boolean",
            "description": "If the sms was sent using the transactional route"
          },
          "shortenUrls": {
            "type": "boolean",
            "description": "Wether to reduce urls contained in body"
          },
          "parts": {
            "type": "number",
            "description": "Number of SMS sent. This can be more than 1 if the sms is longer than 160 characters in GSM encoding, and 70 characters in UTF8. Please note that encoding is automatically detected"
          }
        },
        "required": [
          "id",
          "status",
          "statusReason",
          "to",
          "from",
          "body",
          "isTransactional",
          "shortenUrls",
          "parts"
        ]
      },
      "WebhookInvocation": {
        "type": "object",
        "properties": {}
      },
      "CreateWebhookDto": {
        "type": "object",
        "properties": {}
      },
      "CreatedWalletDto": {
        "type": "object",
        "properties": {}
      },
      "CreateGroupDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the address book to created",
            "example": ""
          }
        },
        "required": [
          "name"
        ]
      },
      "CreatedGroupDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "user",
              "fidelity"
            ],
            "description": "Two possible values. \"user\" for user created groups and \"fidelity\" for the system created group used to manage automatically collected contacts from the fidelity qrCode "
          }
        },
        "required": [
          "id",
          "name",
          "createdAt",
          "updatedAt",
          "source"
        ]
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "user",
              "fidelity"
            ],
            "description": "Two possible values. \"user\" for user created groups and \"fidelity\" for the system created group used to manage automatically collected contacts from the fidelity qrCode "
          }
        },
        "required": [
          "id",
          "name",
          "createdAt",
          "updatedAt",
          "source"
        ]
      },
      "CreateContactDto": {
        "type": "object",
        "properties": {}
      },
      "Contact": {
        "type": "object",
        "properties": {}
      }
    }
  }
