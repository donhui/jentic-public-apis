{
  "openapi": "3.0.0",
  "info": {
    "description": "Shipment Service API for Shipments, Legs, Loads, and Trade Data",
    "version": "1.0.0",
    "title": "Shipment Service API",
    "contact": {
      "email": "redefined@blujaysolutions.com"
    },
    "license": {
      "name": "redefined",
      "url": "redefined"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/e2open/AGT-ShipmentService/1.0.0/swagger.json"
  },
  "tags": [
    {
      "name": "Shipment",
      "description": "Calls related to Shipment Object"
    },
    {
      "name": "TradeData",
      "description": "Calls related to TradeData Object"
    },
    {
      "name": "Leg",
      "description": "Calls related to Legs"
    }
  ],
  "paths": {
    "/trade-data": {
      "post": {
        "tags": [
          "TradeData"
        ],
        "summary": "Save single TradeData object.",
        "description": "Save TradeData object.",
        "requestBody": {
          "description": "TradeData Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TradeData"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "201": {
            "description": "Successfully created object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TradeData"
                }
              }
            }
          },
          "400": {
            "description": "Failed to Unmarshal Object"
          }
        }
      }
    },
    "/trade-data/{id}": {
      "get": {
        "tags": [
          "TradeData"
        ],
        "summary": "Finds and returns Tradedata with given ID.",
        "description": "Finds and returns Tradedata with given ID.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of TradeData",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None"
          },
          "200": {
            "description": "TradeData found and returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TradeData"
                }
              }
            }
          },
          "400": {
            "description": "Non empty id is required to find TradeData"
          },
          "404": {
            "description": "TradeData could not be found"
          }
        }
      }
    },
    "/shipments": {
      "get": {
        "tags": [
          "Shipment"
        ],
        "summary": "Get and return all matching Customer Shipment Id + Tenant Id pairs.",
        "description": "Returns shipments matching parameters.",
        "parameters": [
          {
            "in": "query",
            "name": "customerShipmentIds",
            "description": "Array of Customer Shipment IDs",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "in": "query",
            "name": "tenantId",
            "description": "Customer Tenant Id",
            "required": true,
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "Found and deleted entity succesfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Shipments"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Resource not found."
          }
        }
      },
      "put": {
        "tags": [
          "Shipment"
        ],
        "summary": "Updates existing shipment.",
        "description": "Updates and returns shipment that already exists.",
        "requestBody": {
          "description": "Shipment Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Shipment"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "Shipment updated successfully"
          },
          "404": {
            "description": "No Shipment ID found for the PUT request."
          }
        }
      },
      "post": {
        "tags": [
          "Shipment"
        ],
        "summary": "Save single shipment object.",
        "description": "Save shipment object.",
        "requestBody": {
          "description": "Shipment Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Shipment"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "201": {
            "description": "Successfully created objects.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Shipment"
                }
              }
            }
          }
        }
      }
    },
    "/shipments/{id}": {
      "get": {
        "tags": [
          "Shipment"
        ],
        "summary": "Finds and returns shipment with given ID.",
        "description": "Finds and returns shipment with given ID.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of Shipment",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None"
          },
          "200": {
            "description": "Shipment found and returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Shipment"
                }
              }
            }
          },
          "404": {
            "description": "Shipment could not be found"
          }
        }
      },
      "delete": {
        "tags": [
          "Shipment"
        ],
        "summary": "Deletes Shipment with given ID.",
        "description": "Deletes Shipment with given ID.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of Shipment",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "Found and deleted entity."
          },
          "404": {
            "description": "Could not find entity to delete."
          }
        }
      }
    },
    "/leg": {
      "post": {
        "tags": [
          "Leg"
        ],
        "summary": "Creates New Leg Entry in DB",
        "description": "Endpoint for creating new DB",
        "requestBody": {
          "description": "Leg Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Leg"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "201": {
            "description": "Entity Created"
          },
          "400": {
            "description": "Badly Formatted Leg Object"
          },
          "404": {
            "description": "Could not find related Shipment"
          },
          "409": {
            "description": "Leg with exact Customer Leg ID Exists"
          },
          "500": {
            "description": "Uncaptured error occured"
          }
        }
      }
    },
    "/leg/{id}": {
      "get": {
        "tags": [
          "Leg"
        ],
        "summary": "Gets Leg Entry using UUID ID.",
        "description": "Finds and retrieves a Leg based on the passed in value.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of Leg",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "Entity Updated"
          },
          "400": {
            "description": "Badly Formatted Leg Object"
          },
          "404": {
            "description": "Could not find Leg or Shipment"
          },
          "500": {
            "description": "Uncaptured error occured"
          }
        }
      },
      "put": {
        "tags": [
          "Leg"
        ],
        "summary": "Updates Existing Leg Entry in DB.",
        "description": "Endpoint for updating DB entries.",
        "requestBody": {
          "description": "Leg Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Leg"
              }
            }
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of Leg",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "Entity Updated"
          },
          "404": {
            "description": "Could not find Leg or Shipment"
          },
          "500": {
            "description": "Uncaptured error occured"
          }
        }
      },
      "delete": {
        "tags": [
          "Leg"
        ],
        "summary": "Deletes Leg Entry in DB.",
        "description": "Endpoint for Deleting Leg.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of Leg",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "Entity Deleted"
          },
          "404": {
            "description": "Could not find Leg or Shipment"
          },
          "500": {
            "description": "Uncaptured error occured"
          }
        }
      }
    },
    "/leg/declaration-leg-mappings": {
      "post": {
        "tags": [
          "Leg"
        ],
        "summary": "Creates new link between Leg and Declaration.",
        "description": "Creates new DB entry to represent link between Leg and Declaration.",
        "requestBody": {
          "description": "Leg Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeclarationLegMapping"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "Link Created"
          },
          "404": {
            "description": "Declaration ID or Tenant ID is not found"
          },
          "500": {
            "description": "Uncaptured error occured"
          }
        }
      }
    },
    "/leg/declaration-leg-mappings/{id}": {
      "delete": {
        "tags": [
          "Leg"
        ],
        "summary": "Creates New Leg Entry in DB.",
        "description": "Endpoint for creating new DB.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of Declaration Mapping Object",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "Entity Deleted"
          },
          "404": {
            "description": "Could not find Declaration Mapping Object"
          },
          "500": {
            "description": "Uncaptured error occured"
          }
        }
      }
    },
    "/bulk/shipments": {
      "post": {
        "tags": [
          "Shipment"
        ],
        "summary": "Save multiple shipment objects.",
        "description": "Saves multiple shipment objects at once.",
        "requestBody": {
          "description": "Shipment Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Shipment"
                }
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "201": {
            "description": "Successfully created objects.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Shipment"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Shipments": {
        "type": "object",
        "properties": {
          "customerShipmentId": {
            "type": "string"
          }
        },
        "additionalProperties": {
          "$ref": "#/components/schemas/Shipment"
        }
      },
      "Shipment": {
        "type": "object",
        "required": [
          "customerShipmentId",
          "tenantId",
          "ownerId",
          "incoterm",
          "referenceNumber"
        ],
        "properties": {
          "customerShipmentId": {
            "type": "string",
            "description": "ID given by the User when the Shipment is uploaded into our system",
            "example": "Shipment 12345"
          },
          "tenantId": {
            "type": "integer",
            "description": "ID of Tenant shipment is associated with",
            "example": 11185
          },
          "isActive": {
            "type": "integer",
            "description": "Value of the Active property of a Shipment. Inactive Shipments are hidden by default in UI Searches.",
            "example": 1
          },
          "ownerId": {
            "type": "string",
            "description": "May or may not reference an internal parties Party Code.",
            "example": "Code1234"
          },
          "incoterm": {
            "type": "string",
            "description": "A series of three-letter trade terms related to common contractual sales practices",
            "example": "FCA"
          },
          "referenceNumber": {
            "type": "string",
            "description": "Value of the Reference Number property of a Shipment.",
            "example": "REF45634"
          },
          "createdBy": {
            "type": "string",
            "description": "User Name of the person who first created the Shipment. \"System\" if is created through the SFTP process or left blank",
            "example": "user.name"
          },
          "createdOn": {
            "type": "string",
            "description": "Date Time value for first created",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-08-10 11:02"
          },
          "modifiedBy": {
            "type": "string",
            "description": "User Name of the person who last modified the Shipment. \"System\" if is created through the SFTP process or left blank",
            "example": "user.name"
          },
          "modifiedOn": {
            "type": "string",
            "description": "Date Time value for last modified",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-08-10 11:02"
          },
          "shipmentPONumbers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShipmentPONumber"
            }
          },
          "legs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Leg"
            }
          },
          "shipmentDetails": {
            "$ref": "#/components/schemas/ShipmentDetails"
          }
        }
      },
      "ShipmentDetails": {
        "type": "object",
        "required": [
          "deliveryInformation",
          "timingInformation",
          "valueInformation"
        ],
        "properties": {
          "deliveryInformation": {
            "$ref": "#/components/schemas/DeliveryInformation"
          },
          "timingInformation": {
            "$ref": "#/components/schemas/TimingInformation"
          },
          "valueInformation": {
            "$ref": "#/components/schemas/ValueInformation"
          },
          "marks": {
            "type": "string",
            "description": "Shipment marks that identify the cargo (item number, symbols, help to ID)",
            "example": "Star"
          },
          "houseBill": {
            "type": "string",
            "description": "House bill of lading number issued by a freight forwarder or NVOCC",
            "example": "HB12310"
          },
          "subHouseBill": {
            "type": "string",
            "description": "House bill of lading number issued by a freight forwarder or NVOCC",
            "example": "SHB12310"
          },
          "subSubHouseBill": {
            "type": "string",
            "description": "Issued under Sub-Sub House Bill. Used infrequently",
            "example": "SSHB12310"
          },
          "methodOfPayment": {
            "type": "string",
            "description": "Field that denotes how the Shipment was paid for. Expected Values are Cash in Advance, Letter of Credit, Documentary Collections, Open Account, or Consignment",
            "example": "Cash in Advance"
          },
          "parties": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Party"
            }
          },
          "goodsItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GoodsItem"
            }
          },
          "charges": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Charge"
            }
          }
        }
      },
      "ShipmentPONumber": {
        "type": "object",
        "properties": {
          "ponumber": {
            "type": "string",
            "description": "PO number associated with Shipment",
            "example": "PO948"
          }
        }
      },
      "TradeData": {
        "type": "object",
        "required": [
          "customerTradeDataId",
          "tenantId",
          "documentType",
          "isActive",
          "createdOn",
          "createdBy"
        ],
        "properties": {
          "customerTradeDataId": {
            "type": "string",
            "description": "Customer given TradeData ID",
            "example": "Doc1234"
          },
          "tenantId": {
            "type": "integer",
            "description": "ID of Tenant TradeData is associated with",
            "example": 11184
          },
          "documentType": {
            "type": "string",
            "description": "The type of document the trade data is",
            "example": "Export Trade Data Document"
          },
          "isActive": {
            "type": "boolean",
            "description": "Value of the Active property of a TradeData",
            "example": true
          },
          "masterOrderNumber": {
            "type": "string",
            "description": "Used by client to identify an order",
            "example": "MO125213"
          },
          "referenceNumber": {
            "type": "string",
            "description": "Commercial reference, document ID",
            "example": "Commercial invoice 478"
          },
          "poNumber": {
            "type": "string",
            "description": "Alpha Numberic Purchase Order value",
            "example": "PO948"
          },
          "createdBy": {
            "type": "string",
            "description": "User Name of the person who first created the TradeData. \"System\" if is created through the SFTP process or left blank",
            "example": "user.name"
          },
          "createdOn": {
            "type": "string",
            "description": "Date Time value for first created",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-08-10 11:02"
          },
          "modifiedBy": {
            "type": "string",
            "description": "User Name of the person who last modified the TradeData. \"System\" if is created through the SFTP process or left blank",
            "example": "user.name"
          },
          "modifiedOn": {
            "type": "string",
            "description": "Date Time value for last modified",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-08-10 11:02"
          },
          "tradeDataDetail": {
            "$ref": "#/components/schemas/TradeDataDetail"
          }
        }
      },
      "TradeDataDetail": {
        "required": [
          "deliveryInformation",
          "valueInformation"
        ],
        "type": "object",
        "properties": {
          "deliveryInformation": {
            "$ref": "#/components/schemas/DeliveryInformation"
          },
          "valueInformation": {
            "$ref": "#/components/schemas/ValueInformation"
          },
          "transportDetails": {
            "$ref": "#/components/schemas/TransportDetails"
          },
          "invoiceNumber": {
            "type": "string",
            "description": "Commercial invoice number",
            "example": "19-0002"
          },
          "remarks": {
            "type": "string",
            "description": "Notes field for client",
            "example": "Valid Data"
          },
          "packagingType": {
            "type": "string",
            "description": "Type of the package",
            "example": "Carton"
          },
          "totalPieces": {
            "type": "string",
            "description": "Inner count of goods items",
            "example": 500
          },
          "documentDate": {
            "type": "string",
            "description": "Date associated with creation of original document (ex. Invoice has a date on it when created)",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-08-10 11:02"
          },
          "incoterm": {
            "type": "string",
            "description": "Terms of sale specifying who is responsible for paying and managing the TradeData",
            "example": "DAP"
          },
          "marks": {
            "type": "string",
            "description": "Shipping marks that define the cargo (ex. Item number, symbols, things that help ID it)",
            "example": "Mark1"
          },
          "paymentTerms": {
            "type": "string",
            "description": "Payment terms for sale",
            "example": "Next 80 days"
          },
          "parties": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Party"
            }
          },
          "goodsItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GoodsItem"
            }
          },
          "charges": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Charge"
            }
          }
        }
      },
      "Leg": {
        "type": "object",
        "required": [
          "customerShipmentId",
          "customerLegId",
          "customerLoadId"
        ],
        "properties": {
          "customerShipmentId": {
            "type": "string",
            "description": "ID given by the User when the Shipment is uploaded into our system",
            "example": "Shipment 12345"
          },
          "customerLegId": {
            "type": "string",
            "description": "ID given by the User when the Leg is uploaded into our system",
            "example": "LegABC123"
          },
          "customerLoadId": {
            "type": "string",
            "description": "ID given by the User when the Load is uploaded into our system",
            "example": "LoadABC123"
          },
          "tenantId": {
            "type": "integer",
            "description": "ID of Tenant TradeData is associated with",
            "example": 11184
          },
          "invoiceNumber": {
            "type": "string",
            "description": "The invoice number associated with the Leg",
            "example": 871981984
          },
          "createdBy": {
            "type": "string",
            "description": "User Name of the person who first created the Shipment. \"System\" if is created through the SFTP process or left blank",
            "example": "user.name"
          },
          "createdOn": {
            "type": "string",
            "description": "Date Time value for first created",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-08-10 11:02"
          },
          "modifiedBy": {
            "type": "string",
            "description": "User Name of the person who last modified the Shipment. \"System\" if is created through the SFTP process or left blank",
            "example": "user.name"
          },
          "modifiedOn": {
            "type": "string",
            "description": "Date Time value for last modified",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-08-10 11:02"
          },
          "containers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Container"
            }
          },
          "registrationNumbers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RegistrationNumber"
            }
          },
          "linkedDeclarations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeclarationLegMapping"
            }
          }
        }
      },
      "RegistrationNumber": {
        "type": "object",
        "required": [
          "registrationNumber"
        ],
        "properties": {
          "registrationNumber": {
            "type": "string",
            "description": "The Registration Number Associated with the Leg",
            "example": "9485ABC"
