            "example": 1
          },
          "entityType": {
            "type": "string",
            "description": "The type of entity (e.g. DECLARATION, SHIPMENT, ITEM, etc)",
            "example": "SHIPMENT"
          },
          "document": {
            "$ref": "#/components/schemas/DocumentWithS3Path"
          }
        }
      },
      "Documents": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/components/schemas/DocumentWithS3Path"
        }
      },
      "Document": {
        "type": "object",
        "required": [
          "name",
          "extensionType",
          "tenantId",
          "createdOn",
          "createdBy",
          "documentSize"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the document",
            "example": "DocumentTableDesign.pdf"
          },
          "extensionType": {
            "type": "string",
            "description": "Document Extension type",
            "example": ".txt"
          },
          "tenantId": {
            "type": "integer",
            "description": "ID of Tenant document is associated with",
            "example": 11184
          },
          "createdOn": {
            "type": "string",
            "description": "Date Document was created in the system",
            "example": "2021-08-10T 11:02:10"
          },
          "createdBy": {
            "type": "string",
            "description": "User ID of the person who created the document, \"system\" if created through SFTP process",
            "example": "user.name"
          },
          "documentSize": {
            "type": "integer",
            "description": "Size of the Document in bytes",
            "example": 1024
          },
          "description": {
            "type": "string",
            "description": "User-created description of the document.",
            "example": "Trade Document design details"
          },
          "documentType": {
            "type": "string",
            "description": "The type of document.",
            "example": "Trade Document"
          },
          "modifiedOn": {
            "type": "string",
            "description": "Date-Time the document was last modified.",
            "example": "2021-08-09T 2:32:10"
          },
          "modifiedBy": {
            "type": "string",
            "description": "Last user to modify the document",
            "example": "user.name"
          },
          "documentBytes": {
            "type": "string",
            "description": "Doument content in bytes",
            "example": "bytes"
          }
        }
      },
      "DocumentWithS3Path": {
        "type": "object",
        "required": [
          "name",
          "extensionType",
          "tenantId",
          "createdOn",
          "createdBy",
          "documentSize"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the document",
            "example": "DocumentTableDesign.pdf"
          },
          "extensionType": {
            "type": "string",
            "description": "Document Extension type",
            "example": ".txt"
          },
          "tenantId": {
            "type": "integer",
            "description": "ID of Tenant document is associated with",
            "example": 11184
          },
          "s3Path": {
            "type": "string",
            "description": "Path of s3 bucket",
            "example": "blujaysolutions-cm-data-eucentral1/perfcm/Document/CM.BJS.TST/2021-11-01/12345"
          },
          "createdOn": {
            "type": "string",
            "description": "Date Document was created in the system",
            "example": "2021-08-10T 11:02:10"
          },
          "createdBy": {
            "type": "string",
            "description": "User ID of the person who created the document, \"system\" if created through SFTP process",
            "example": "user.name"
          },
          "documentSize": {
            "type": "integer",
            "description": "Size of the Document in bytes",
            "example": 1024
          },
          "description": {
            "type": "string",
            "description": "User-created description of the document.",
            "example": "Trade Document design details"
          },
          "documentType": {
            "type": "string",
            "description": "The type of document.",
            "example": "Trade Document"
          },
          "modifiedOn": {
            "type": "string",
            "description": "Date-Time the document was last modified.",
            "example": "2021-08-09T 2:32:10"
          },
          "modifiedBy": {
            "type": "string",
            "description": "Last user to modify the document",
            "example": "user.name"
          }
        }
      }
    }
  }
}