  "paths": {
    "/document": {
      "get": {
        "tags": [
          "DocumentSearch"
        ],
        "summary": "Searching for Documents.",
        "operationId": "searchDocument",
        "servers": [
          {
            "description": "Perf DocumentService endpoint",
            "url": "https://internal-perfcm-backend-lb-1624536858.eu-central-1.elb.amazonaws.com:8218/documentservice/rest/documentserver"
          }
        ],
        "description": "Searches for the Documents that matches given request params",
        "parameters": [
          {
            "in": "query",
            "name": "requestType",
            "required": true,
            "example": "document",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "fileName",
            "required": false,
            "example": "design.pdf",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "fileExtension",
            "required": false,
            "example": "pdf",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "createdOnFrom",
            "description": "If the 'from' is provided, we will require a 'to' be provided.",
            "required": false,
            "example": "2019-05-18 3:59 AM EDT",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "createdOnTo",
            "description": "If the 'from' is provided, we will require a 'to' be provided. %3A maps to the ':' character. %2B is the '+' character",
            "required": false,
            "example": "2019-05-28 3:59 AM EDT",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "tenantId",
            "required": true,
            "example": 11185,
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "fetchRowLimit",
            "required": false,
            "example": 300,
            "schema": {
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "description",
            "required": false,
            "example": "Design related Document",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "documentType",
            "required": false,
            "example": "TradeDocument",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "None.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Documents"
                  }
                }
              }
            }
          },
          "400": {
            "description": "requestType is required parameter"
          }
        }
      }
    },
    "/documents/{id}": {
      "put": {
        "tags": [
          "Document"
        ],
        "summary": "Updates existing Document.",
        "description": "Updates and returns Document that already exists.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of Document",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          }
        ],
        "requestBody": {
          "description": "Document Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentWithS3Path"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "None."
          },
          "404": {
            "description": "No document found with given ID."
          }
        }
      },
      "get": {
        "tags": [
          "Document"
        ],
        "summary": "Finds and returns Document with given ID.",
        "description": "Finds and returns Document with given ID",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of Document",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None"
          },
          "200": {
            "description": "None",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentWithS3Path"
                }
              }
            }
          },
          "400": {
            "description": "Document ID is missing."
          },
          "404": {
            "description": "No document found with given ID."
          }
        }
      }
    },
    "/documents/{id}/declaration/{entityId}": {
      "post": {
        "tags": [
          "DocumentLink"
        ],
        "summary": "Link single Document object with Declaration entity.",
        "description": "Link Document object with an Declaration entity.",
