  "components": {
    "schemas": {
      "LinkedDocuments": {
        "type": "object",
        "additionalProperties": {
          "$ref": "#/components/schemas/LinkedDocument"
        }
      },
      "LinkedDocument": {
        "type": "object",
        "required": [
          "entityId",
          "documentId",
          "active",
          "entityType",
          "linkedOn",
          "linkedBy"
        ],
        "properties": {
          "entityId": {
            "type": "string",
            "description": "ID of the entity",
            "example": 1140
          },
          "documentId": {
            "type": "string",
            "description": "ID of the document",
            "example": "ab2c8fe3-9a27-4f2b-a002-57b8c068f9c1"
          },
          "linkedOn": {
            "type": "string",
            "description": "Date document was created in the system",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-11-02T 20:44:31"
          },
          "linkedBy": {
            "type": "string",
            "description": "User ID of the person who created the link between the document and the entity",
            "example": "user.name"
          },
          "unlinkedOn": {
            "type": "string",
            "description": "Date link to document was last modified",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-08-10T 11:02:10"
          },
          "unlinkedBy": {
            "type": "string",
            "description": "User ID of the person who last modified the link to the document",
            "example": "user.name"
          },
          "active": {
            "type": "integer",
            "description": "Represents if this link to a specific document is active",
            "example": 1
          },
          "entityType": {
            "type": "string",
            "description": "The type of entity (e.g. DECLARATION, SHIPMENT, ITEM, etc)",
            "example": "SHIPMENT or DECLARATION or ITEM or TRADE_DATA"
          }
        }
      },
      "LinkedDocumentWithDocument": {
        "type": "object",
        "required": [
          "entityId",
          "documentId",
          "active",
          "entityType",
          "linkedOn",
          "linkedBy",
          "document"
        ],
        "properties": {
          "entityId": {
            "type": "string",
            "description": "ID of the entity",
            "example": 1140
          },
          "documentId": {
            "type": "string",
            "description": "ID of the document",
            "example": "ab2c8fe3-9a27-4f2b-a002-57b8c068f9c1"
          },
          "linkedOn": {
            "type": "string",
            "description": "Date document was created in the system",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-11-02T 20:44:31"
          },
          "linkedBy": {
            "type": "string",
            "description": "User ID of the person who created the link between the document and the entity",
            "example": "user.name"
          },
          "unlinkedOn": {
            "type": "string",
            "description": "Date link to document was last modified",
            "format": "yyyy-MM-dd HH:mm",
            "example": "2021-08-10T 11:02:10"
          },
          "unlinkedBy": {
            "type": "string",
            "description": "User ID of the person who last modified the link to the document",
            "example": "user.name"
          },
          "active": {
            "type": "integer",
            "description": "Represents if this link to a specific document is active",
            "example": 1
          },
          "entityType": {
            "type": "string",
            "description": "The type of entity (e.g. DECLARATION, SHIPMENT, ITEM, etc)",
            "example": "SHIPMENT"
          },
          "document": {
            "$ref": "#/components/schemas/Document"
          }
        }
      },
      "LinkedDocumentWithDocumentS3Path": {
        "type": "object",
        "required": [
          "entityId",
          "documentId",
          "active",
          "entityType",
          "linkedOn",
          "linkedBy",
          "document"
        ],
        "properties": {
          "entityId": {
            "type": "string",
