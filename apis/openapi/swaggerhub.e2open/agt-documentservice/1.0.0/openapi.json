    "/linked-documents": {
      "post": {
        "tags": [
          "LinkedDocument"
        ],
        "summary": "Save single LinkedDocument object.",
        "description": "Save LinkedDocument object.",
        "requestBody": {
          "description": "LinkedDocument Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LinkedDocumentWithDocument"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "201": {
            "description": "Successfully created objects.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkedDocumentWithDocumentS3Path"
                }
              }
            }
          },
          "400": {
            "description": "Required fields missing in LinkedDocument object or Failed to Create Document in S3."
          },
          "500": {
            "description": "Failed to create Linked Document."
          }
        }
      },
      "put": {
        "tags": [
          "LinkedDocument"
        ],
        "summary": "Update existing LinkedDocument object.",
        "description": "Updates and returns existing LinkedDocument object.",
        "requestBody": {
          "description": "LinkedDocument Object",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LinkedDocument"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkedDocument"
                }
              }
            }
          },
          "400": {
            "description": "LinkedDocument's isActive status should be false"
          },
          "404": {
            "description": "Attempting to deactivate a Linked Document that is not currently active in the database"
          },
          "500": {
            "description": "Failed to deactivate Linked Document"
          }
        }
      },
      "get": {
        "tags": [
          "LinkedDocument"
        ],
        "summary": "Get and return all matching active LinkedDocuments for entityId + entityType pairs.",
        "description": "Returns active LinkedDocuments matching parameters.",
        "parameters": [
          {
            "in": "query",
            "name": "entityId",
            "description": "Entity Id",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "entityType",
            "description": "Entity Type",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "None.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LinkedDocuments"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to get active Linked Documents for given entityId, entityType."
          }
        }
      }
    }
