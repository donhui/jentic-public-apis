          {
            "in": "path",
            "name": "id",
            "description": "PK UUID of Document",
            "required": true,
            "schema": {
              "type": "string",
              "format": "UUID"
            }
          },
          {
            "in": "path",
            "name": "entityId",
            "description": "ID of Declaration",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Document and Declaration Link",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LinkedDocument"
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "None."
          },
          "200": {
            "description": "None.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkedDocumentWithDocumentS3Path"
                }
              }
            }
          },
          "201": {
            "description": "None.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkedDocumentWithDocumentS3Path"
                }
              }
            }
          },
          "500": {
            "description": "Failed to Link Document to an Entity."
          }
        }
      }
    },
