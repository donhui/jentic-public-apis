{
  "openapi": "3.0.3",
  "info": {
    "title": "ATP - Available To Promise API",
    "description": "**ATP API:** The purpose of the ATP API is to trigger the ATP planning via restful API.  \n**ATP:** The ATP (Available-To-Promise) is to plan (one or more) Customer Orders and get real-time information about their delivery (availability) date.\nThe ATP process is designed to allow orders to be added to an existing plan, without affecting any other already planned orders at all. ATP works as an incremental planning algorithm, i.e., it operates on an existing plan (including pegging). If the ATP planning is successful, a collection of deliveries is returned as a response.",
    "version": "1.0.0",
    "contact": {},
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/e2open/atp-available_to_promise_api/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "http://dev3948.dev.e2open.com"
    }
  ],
  "tags": [
    {
      "name": "atp",
      "description": "Trigger ATP plan"
    }
  ],
  "paths": {
    "/e2pr/rs/public/command/execute/perform-atp": {
      "post": {
        "tags": [
          "atp"
        ],
        "summary": "http://dev3948.dev.e2open.com:11101//e2pr/rs/public/command/execute/perform-atp",
        "description": "http://dev3948.dev.e2open.com:11101//e2pr/rs/public/command/execute/perform-atp",
        "operationId": "httpLocalhost23100E2prRsClientAtpExecute",
        "parameters": [
          {
            "name": "tId",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "ATP_TENANT",
              "description": "Unique ID of the E2PR tenant."
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "The wrapper object for request.",
                "properties": {
                  "editRows": {
                    "type": "array",
                    "description": "The array of orders.",
                    "items": {
                      "type": "object",
                      "description": "The object for each order.",
                      "properties": {
                        "values": {
                          "type": "object",
                          "description": "The cutomer order",
                          "properties": {
                            "CUSTOMER": {
                              "type": "string",
                              "example": "CUSTOMER-B",
                              "description": "Name or identifier of the customer"
                            },
                            "DEPOT": {
                              "type": "string",
                              "example": "CM1",
                              "description": "Location identifier"
                            },
                            "ERD": {
                              "type": "string",
                              "nullable": true,
                              "example": null,
                              "description": "Earliest Requested Date. The earliest date the customer accepts a delivery."
                            },
                            "EXPIRE_DATE": {
                              "type": "string",
                              "nullable": true,
                              "example": null,
                              "description": "Expire Date is defined on demand level (CO, SFC); If (partial) demand cannot be delivered/fulfilled within Pull/Push Window, it is considered expired.."
                            },
                            "ITEM_NO": {
                              "type": "string",
                              "example": "I4",
                              "description": "Customer Item number."
                            },
                            "NO_PULL": {
                              "type": "string",
                              "nullable": true,
                              "example": null,
                              "description": "No Pull flag determines whether an order can be pulled. The order can only be pulled if the flag is set to 0 and ERD date < Req date. If Pull No is set to \u201c1\u201d, order line items are not allowed to be pulled."
                            },
                            "NP_CODE": {
                              "type": "string",
                              "nullable": true,
                              "example": null,
                              "description": "Defines the level of the non partial code."
                            },
                            "OI_GROUP": {
                              "type": "string",
                              "nullable": true,
                              "example": null,
                              "description": "Identifier to group different order line items together in a shopping basket."
                            },
                            "ORDER_DATE": {
                              "type": "string",
                              "nullable": true,
                              "example": null,
                              "description": "Date when the customer placed the order."
                            },
                            "ORDER_NO": {
                              "type": "string",
                              "example": "1",
                              "description": "Customer order number."
                            },
                            "ORDER_QTY": {
                              "type": "number",
                              "nullable": true,
                              "example": null,
                              "description": "The identifier of the item."
                            },
                            "ORDER_STATUS": {
                              "type": "string",
                              "nullable": true,
                              "example": null,
                              "description": "Status of the customer order."
                            },
                            "ORDER_TYPE": {
                              "type": "string",
                              "nullable": true,
                              "example": null,
                              "description": "Type of the customer order."
                            },
                            "PART": {
                              "type": "string",
                              "example": "ASIC_1000",
                              "description": "The identifier of the item."
                            },
                            "PARTIAL_NO": {
                              "type": "string",
                              "example": "P3",
                              "description": "Partial Number, i.e., individual shipment of an order."
                            },
                            "PRIORITY": {
                              "type": "string",
                              "nullable": true,
                              "example": null,
                              "description": "Initial values needed for the calculation of the Num Prio. This column can be updated by the Forecast Allocation process step."
                            },
                            "QTY": {
                              "type": "number",
                              "example": "10",
                              "description": "Order quantity."
                            },
                            "REQ_DATE": {
                              "type": "string",
                              "example": "2021-07-15",
                              "description": "Customer required date."
                            },
                            "UNIT_PRICE": {
                              "nullable": true,
                              "example": null,
                              "description": "The price this product is sold for in this specific order."
                            }
                          }
                        }
                      }
                    },
                    "example": [
                      {
                        "action": "CREATE",
                        "rowId": 4,
                        "values": {
                          "CUSTOMER": "CUSTOMER-B",
                          "DEPOT": "CM1",
                          "ERD": null,
                          "EXPIRE_DATE": null,
                          "ITEM_NO": "I4",
                          "NO_PULL": null,
                          "NP_CODE": null,
                          "OI_GROUP": null,
                          "ORDER_DATE": null,
                          "ORDER_NO": "1",
                          "ORDER_QTY": null,
                          "ORDER_STATUS": null,
                          "ORDER_TYPE": null,
                          "PART": "ASIC_1000",
                          "PARTIAL_NO": "P3",
                          "PRIORITY": null,
                          "QTY": "10",
                          "REQ_DATE": "2021-07-15",
                          "UNIT_PRICE": null
                        }
                      }
                    ]
                  },
                  "scenarioId": {
                    "type": "string",
                    "example": "GLOBAL",
                    "description": "The scenario identifier against which the request is triggered."
                  }
                }
              },
              "example": {
                "editRows": {
                  "values": {
                    "ACK_DATE": "null,",
                    "AUX_REF_ORDER": null,
                    "AUX_REF_ORDER_ITEM": null,
                    "CUSTOMER": "CUSTOMER-B",
                    "DEPOT": "CM1",
                    "ERD": null,
                    "EXPIRE_DATE": null,
                    "ITEM_NO": "I4",
                    "NO_PULL": null,
                    "NP_CODE": null,
                    "OI_GROUP": null,
                    "ORDER_DATE": null,
                    "ORDER_NO": "1",
                    "ORDER_QTY": null,
                    "ORDER_STATUS": null,
                    "ORDER_TYPE": null,
                    "PART": "ASIC_1000",
                    "PARTIAL_NO": "P3",
                    "PRIORITY": null,
                    "QTY": "10",
                    "REQ_DATE": "2021-07-15",
                    "UNIT_PRICE": null
                  }
                },
                "scenarioId": "GLOBAL"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "The delivery element",
                  "properties": {
                    "demandNo": {
                      "type": "string",
                      "description": "The internal ID of the demand element; taken from demand input tables (e.g., the ID of a single CO or AD)",
                      "example": "2023061516315263300066"
                    },
                    "depot": {
                      "type": "string",
                      "description": "Location from which the product is delivered",
                      "example": "CM1"
                    },
                    "part": {
                      "type": "string",
                      "description": "The identifier of the item.",
                      "example": "ASIC_1000"
                    },
                    "customer": {
                      "type": "string",
                      "description": "Identifier of the customer.",
                      "example": "CUSTOMER-B"
                    },
                    "dueDate": {
                      "type": "object",
                      "description": "The due date of the demand element\u2019s order group considered in planning. The due date is determined by using the Req(uested) date and Ack Date information from the demand input, e.g., customer orders.",
                      "properties": {
                        "year": {
                          "type": "integer",
                          "example": 2013
                        },
                        "month": {
                          "type": "integer",
                          "example": 8
                        },
                        "day": {
                          "type": "integer",
                          "example": 15
                        }
                      },
                      "example": "2021-07-15"
                    },
                    "orderItemNo": {
                      "type": "string",
                      "description": "The Order Item Number of the demand element; usually consists of a combination of the order number and item number.",
                      "example": null
                    },
                    "expireDate": {
                      "type": "object",
                      "description": "Expire Date is defined on demand level (CO, FC); If (Partial) demand cannot be delivered/fulfilled within Pull/Push Window, it is considered expired.",
                      "properties": {
                        "year": {
                          "type": "integer",
                          "example": 2013
                        },
                        "month": {
                          "type": "integer",
                          "example": 8
                        },
                        "day": {
                          "type": "integer",
                          "example": 15
                        }
                      },
                      "example": "null"
                    },
                    "deliveryDate": {
                      "type": "object",
                      "description": "The actual Delivery Date of the Demand Item based on demand priorities and available supply.",
                      "properties": {
                        "year": {
                          "type": "integer",
                          "example": 2013
                        },
                        "month": {
                          "type": "integer",
                          "example": 8
                        },
                        "day": {
                          "type": "integer",
                          "example": 15
                        }
                      },
                      "example": "2021-07-15"
                    },
                    "numPriority": {
                      "type": "integer",
                      "description": "Numeric Priority of the demand element, e.g., result of Priority Manager.",
                      "example": "0"
                    },
                    "psd": {
                      "type": "object",
                      "description": "Production Start Date; the actual starting date of building a product.",
                      "properties": {
                        "year": {
                          "type": "integer",
                          "example": 2013
                        },
                        "month": {
                          "type": "integer",
                          "example": 8
                        },
                        "day": {
                          "type": "integer",
                          "example": 15
                        }
                      },
                      "example": "null"
                    },
                    "pcd": {
                      "type": "string",
                      "description": "Production Completion Date.",
                      "properties": {
                        "year": {
                          "type": "integer",
                          "example": 2013
                        },
                        "month": {
                          "type": "integer",
                          "example": 8
                        },
                        "day": {
                          "type": "integer",
                          "example": 15
                        }
                      },
                      "example": "null"
                    },
                    "deliveryQty": {
                      "type": "number",
                      "description": "The quantity to be delivered.",
                      "example": "200"
                    },
                    "reqQty": {
                      "type": "number",
                      "description": "The requested quantity of a demand element\u2019s order group.",
                      "example": "200"
                    },
                    "deliveryMode": {
                      "type": "string",
                      "description": "No Partial-Code:- Allowed shipment Partialling level of a demand item as configured in the system parameters. Either non partial shipments of an order are allowed or partial shipments of complete order lines or shipments of partial quantities of an order line..",
                      "example": "null"
                    },
                    "deliveryRevenue": {
                      "type": "number",
                      "description": "Delivery Qty x Unit Price.",
                      "example": "0"
                    },
                    "reqCost": {
                      "type": "number",
                      "description": "Req Qty x Unit Roll-up Cost.",
                      "example": "0"
                    },
                    "preferredDate": {
                      "type": "object",
                      "description": "The earliest date the customer accepts a delivery. If the Preferred Date deviates from the Due Date and if the No Pull field is set to zero, the Preferred Date is considered for planning.",
                      "properties": {
                        "year": {
                          "type": "integer",
                          "example": 2013
                        },
                        "month": {
                          "type": "integer",
                          "example": 8
                        },
                        "day": {
                          "type": "integer",
                          "example": 15
                        }
                      },
                      "example": "null"
                    },
                    "bandPrio": {
                      "type": "integer",
                      "description": "Band priority.",
                      "example": "0"
                    },
                    "late": {
                      "type": "integer",
                      "description": "Indicates the delay of arrival in days.",
                      "example": "10"
                    }
                  }
                },
                "examples": {
                  "Success Example": {
                    "value": "{\n\"deliveries\": [\n    {\n        \"bandPrio\": null,\n        \"late\": 189,\n        \"depot\": \"CM1\",\n        \"part\": \"LAPTOP_3\",\n        \"orderItemNo\": \"112I4\",\n        \"deliveryNo\": null,\n        \"deliveryDate\": {\n            \"year\": 2014,\n            \"month\": 2,\n            \"day\": 10\n        },\n        \"psd\": null,\n        \"pcd\": null,\n        \"deliveryQty\": 10,\n        \"primaryDemandNo\": null,\n        \"dueDate\": {\n            \"year\": 2013,\n            \"month\": 8,\n            \"day\": 5\n        },\n        \"reqQty\": 10,\n        \"preferredDate\": null,\n        \"expireDate\": null,\n        \"numPriority\": 2147483647,\n        \"deliveryMode\": \"0\",\n        \"deliveryRevenue\": 20,\n        \"deliveryCost\": 10,\n        \"deliveryMargin\": 10,\n        \"reqRevenue\": 20,\n        \"reqCost\": 10,\n        \"reqMargin\": 10,\n        \"customer\": \"CUSTOMER-B\",\n        \"demandNo\": \"2023111522292963100080\",\n        \"demandOrigin\": null\n    }\n  ]\n}"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden"
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    }
  }
}