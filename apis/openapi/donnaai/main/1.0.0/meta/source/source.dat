{
  "openapi": "3.0.3",
  "info": {
    "title": "Donna Webhook Utils",
    "description": "Donna webhook utility APIs. These APIs are required for automation platforms to register their endpoints with Donna webhooks and for discovery of available views to listen to. Views are one of the primary ways in which Donna users consume data which work by creating a slice of data using column selection and filters. Donna webhooks allow users to listen to changes in the data generated using a view definition.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://app.swaggerhub.com/apis/donna_for_agents/donna_webhooks_helper/1.0.0",
    "termsOfService": "https://www.aureusanalytics.com/donna/donna-terms-of-service",
    "contact": {
      "email": "nitin@aureusanalytics.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    }
  },
  "servers": [
    {
      "description": "Donna Server",
      "url": "https://id-au-gateway.gocrux.com/webhookUtils"
    }
  ],
  "tags": [
    {
      "name": "register",
      "description": "Webhook registration"
    },
    {
      "name": "views",
      "description": "Access to views"
    }
  ],
  "paths": {
    "/views/subscribe/{tenant}/{viewId}": {
      "post": {
        "tags": ["register"],
        "summary": "Register a new webhook listener on a view",
        "operationId": "addSubscription",
        "parameters": [
          {
            "name": "tenant",
            "in": "path",
            "description": "The tenant of the user trying to add the subscription",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "viewId",
            "in": "path",
            "description": "The view being added to being subscribed",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/Subscription"
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "405": {
            "description": "Invalid input"
          },
          "500": {
            "description": "Server Failure"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/views/unsubscribe/{tenant}/{viewId}": {
      "post": {
        "tags": ["register"],
        "summary": "Remove an existing webhook listener on a view",
        "operationId": "removeSubscription",
        "parameters": [
          {
            "name": "tenant",
            "in": "path",
            "description": "The tenant of the user trying to remove the subscription",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "viewId",
            "in": "path",
            "description": "The view being removed from subscription",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/Unsubscribe"
        },
        "responses": {
          "200": {
            "description": "Success"
          },
          "405": {
            "description": "Invalid input"
          },
          "500": {
            "description": "Server Failure"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/views/list/{tenant}": {
      "get": {
        "tags": ["views"],
        "summary": "Returns a list of available views",
        "description": "Returns an array of views available to be subscribed to",
        "operationId": "getViews",
        "parameters": [
          {
            "name": "tenant",
            "in": "path",
            "description": "The tenant of the user trying to add the subscription",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/View"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/views/testdata/{tenant}/{viewId}": {
      "get": {
        "tags": ["views"],
        "summary": "Returns test data for a view",
        "operationId": "getTestData",
        "parameters": [
          {
            "name": "tenant",
            "in": "path",
            "description": "The tenant of the user trying to add the subscription",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "viewId",
            "in": "path",
            "description": "The view being added to being subscribed",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "example": {
                      "Customer Id": "CUST-1234",
                      "Customer Name": "John Doe"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid tenant or view id"
          },
          "500": {
            "description": "Something went wrong"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Subscription": {
        "type": "object",
        "properties": {
          "hookUrl": {
            "type": "string",
            "format": "uri",
            "example": "https://hooks.zapier.com/hooks/catch/1234/1234abcd/"
          },
          "displayName": {
            "type": "string",
            "example": "My View"
          },
          "appName": {
            "type": "string",
            "enum": ["zapier"]
          }
        }
      },
      "Unsubscribe": {
        "type": "object",
        "properties": {
          "hookUrl": {
            "type": "string",
            "format": "uri",
            "example": "https://hooks.zapier.com/hooks/catch/1234/1234abcd/"
          }
        }
      },
      "View": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "format": "integer",
            "minimum": 1,
            "example": 21
          },
          "display_name": {
            "type": "string",
            "example": "Test View"
          }
        }
      }
    },
    "requestBodies": {
      "Subscription": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Subscription"
            }
          }
        },
        "description": "Subscription object that needs to be added for a view",
        "required": true
      },
      "Unsubscribe": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Unsubscribe"
            }
          }
        },
        "description": "Unsubscribe object for removing a view subscription",
        "required": true
      }
    },
    "securitySchemes": {
      "api_key": {
        "type": "apiKey",
        "name": "X-Gravitee-Api-Key",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "api_key": []
    }
  ]
}
