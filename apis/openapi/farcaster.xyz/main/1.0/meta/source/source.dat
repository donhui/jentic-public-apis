{
  "openapi": "3.0.3",
  "info": {
    "title": "Farcaster Snapchain HTTP API",
    "version": "1.0",
    "description": "Farcaster Snapchain HTTP API providing access to casts, reactions, links, user data, verifications, on-chain events, FIDs, storage limits, and username proofs on the Farcaster protocol.",
    "x-jentic-source-url": "https://docs.farcaster.xyz/reference/"
  },
  "servers": [
    {
      "url": "https://hub.farcaster.xyz",
      "description": "Farcaster Hub"
    }
  ],
  "paths": {
    "/v1/castById": {
      "get": {
        "operationId": "getCastById",
        "summary": "Get a cast by FID and hash",
        "tags": ["Casts"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "description": "FID of the cast creator"
          },
          {
            "name": "hash",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Cast hash"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/castsByFid": {
      "get": {
        "operationId": "getCastsByFid",
        "summary": "Get casts by FID",
        "tags": ["Casts"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "description": "FID of the cast creator"
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" },
          { "$ref": "#/components/parameters/StartTimestamp" },
          { "$ref": "#/components/parameters/StopTimestamp" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/castsByParent": {
      "get": {
        "operationId": "getCastsByParent",
        "summary": "Get casts by parent cast or URL",
        "tags": ["Casts"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Parent cast FID"
          },
          {
            "name": "hash",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Parent cast hash"
          },
          {
            "name": "url",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Parent URL"
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/castsByMention": {
      "get": {
        "operationId": "getCastsByMention",
        "summary": "Get casts that mention a specific FID",
        "tags": ["Casts"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "description": "FID that is mentioned"
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/reactionById": {
      "get": {
        "operationId": "getReactionById",
        "summary": "Get a reaction by its identifying fields",
        "tags": ["Reactions"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "target_fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "target_hash",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "reaction_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["REACTION_TYPE_LIKE", "REACTION_TYPE_RECAST"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/reactionsByFid": {
      "get": {
        "operationId": "getReactionsByFid",
        "summary": "Get reactions by FID",
        "tags": ["Reactions"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "reaction_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["REACTION_TYPE_LIKE", "REACTION_TYPE_RECAST"] }
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/reactionsByCast": {
      "get": {
        "operationId": "getReactionsByCast",
        "summary": "Get reactions to a specific cast",
        "tags": ["Reactions"],
        "parameters": [
          {
            "name": "target_fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "target_hash",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "reaction_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["REACTION_TYPE_LIKE", "REACTION_TYPE_RECAST"] }
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/reactionsByTarget": {
      "get": {
        "operationId": "getReactionsByTarget",
        "summary": "Get reactions by target URL",
        "tags": ["Reactions"],
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "reaction_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["REACTION_TYPE_LIKE", "REACTION_TYPE_RECAST"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/linkById": {
      "get": {
        "operationId": "getLinkById",
        "summary": "Get a link by its identifying fields",
        "tags": ["Links"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "description": "FID of the link originator"
          },
          {
            "name": "target_fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "description": "FID of the link target"
          },
          {
            "name": "link_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Type of link"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/linksByFid": {
      "get": {
        "operationId": "getLinksByFid",
        "summary": "Get links by FID",
        "tags": ["Links"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "link_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/linksByTargetFid": {
      "get": {
        "operationId": "getLinksByTargetFid",
        "summary": "Get links by target FID",
        "tags": ["Links"],
        "parameters": [
          {
            "name": "target_fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "link_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/userDataByFid": {
      "get": {
        "operationId": "getUserDataByFid",
        "summary": "Get user data by FID",
        "tags": ["UserData"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "user_data_type",
            "in": "query",
            "schema": { "type": "string", "enum": ["USER_DATA_TYPE_PFP", "USER_DATA_TYPE_DISPLAY", "USER_DATA_TYPE_BIO", "USER_DATA_TYPE_URL", "USER_DATA_TYPE_USERNAME", "USER_DATA_TYPE_LOCATION"] },
            "description": "Specific user data type to retrieve"
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/userNameProofByName": {
      "get": {
        "operationId": "getUserNameProofByName",
        "summary": "Get username proof by name",
        "tags": ["UsernameProofs"],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Farcaster username or ENS address"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UsernameProof" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/userNameProofsByFid": {
      "get": {
        "operationId": "getUserNameProofsByFid",
        "summary": "Get username proofs by FID",
        "tags": ["UsernameProofs"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UsernameProofsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/verificationsByFid": {
      "get": {
        "operationId": "getVerificationsByFid",
        "summary": "Get verifications by FID",
        "tags": ["Verifications"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "address",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by ETH address"
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessagesResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/onChainSignersByFid": {
      "get": {
        "operationId": "getOnChainSignersByFid",
        "summary": "Get on-chain signers by FID",
        "tags": ["OnChain"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "signer",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by signer address"
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OnChainEventsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/onChainEventsByFid": {
      "get": {
        "operationId": "getOnChainEventsByFid",
        "summary": "Get on-chain events by FID",
        "tags": ["OnChain"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "event_type",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["EVENT_TYPE_SIGNER", "EVENT_TYPE_STORAGE_RENT", "EVENT_TYPE_SIGNER_MIGRATED", "EVENT_TYPE_ID_REGISTER", "EVENT_TYPE_TIER_PURCHASE", "EVENT_TYPE_NONE"] }
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OnChainEventsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/onChainIdRegistryEventByAddress": {
      "get": {
        "operationId": "getOnChainIdRegistryEventByAddress",
        "summary": "Get on-chain ID registry event by address",
        "tags": ["OnChain"],
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OnChainEvent" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/fidAddressType": {
      "get": {
        "operationId": "getFidAddressType",
        "summary": "Get address type for a FID",
        "tags": ["OnChain"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "address",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FidAddressTypeResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/fids": {
      "get": {
        "operationId": "listFids",
        "summary": "List all FIDs",
        "tags": ["FIDs"],
        "parameters": [
          {
            "name": "shard_id",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Shard to query"
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FidsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/storageLimitsByFid": {
      "get": {
        "operationId": "getStorageLimitsByFid",
        "summary": "Get storage limits by FID",
        "tags": ["Storage"],
        "parameters": [
          {
            "name": "fid",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StorageLimitsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/eventById": {
      "get": {
        "operationId": "getEventById",
        "summary": "Get an event by ID",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "event_id",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Hub event ID"
          },
          {
            "name": "shard_index",
            "in": "query",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Shard index"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HubEvent" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/events": {
      "get": {
        "operationId": "listEvents",
        "summary": "List hub events",
        "tags": ["Events"],
        "parameters": [
          {
            "name": "from_event_id",
            "in": "query",
            "schema": { "type": "integer" },
            "description": "Starting event ID"
          },
          {
            "name": "shard_index",
            "in": "query",
            "schema": { "type": "integer" }
          },
          {
            "name": "stop_id",
            "in": "query",
            "schema": { "type": "integer" }
          },
          { "$ref": "#/components/parameters/PageSize" },
          { "$ref": "#/components/parameters/PageToken" },
          { "$ref": "#/components/parameters/Reverse" }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HubEventsResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/submitMessage": {
      "post": {
        "operationId": "submitMessage",
        "summary": "Submit a signed message",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": { "type": "string", "format": "binary" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message submitted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Message" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/submitBulkMessages": {
      "post": {
        "operationId": "submitBulkMessages",
        "summary": "Submit multiple signed messages",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": { "type": "string", "format": "binary" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Messages submitted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Message" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/v1/validateMessage": {
      "post": {
        "operationId": "validateMessage",
        "summary": "Validate a signed message",
        "tags": ["Messages"],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": { "type": "string", "format": "binary" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidateMessageResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "PageSize": {
        "name": "pageSize",
        "in": "query",
        "schema": { "type": "integer", "default": 1000 },
        "description": "Maximum number of messages per response"
      },
      "PageToken": {
        "name": "pageToken",
        "in": "query",
        "schema": { "type": "string" },
        "description": "Pagination token from previous response"
      },
      "Reverse": {
        "name": "reverse",
        "in": "query",
        "schema": { "type": "boolean" },
        "description": "Reverse sort order (latest first)"
      },
      "StartTimestamp": {
        "name": "startTimestamp",
        "in": "query",
        "schema": { "type": "integer" },
        "description": "Range start timestamp (inclusive, Farcaster epoch)"
      },
      "StopTimestamp": {
        "name": "stopTimestamp",
        "in": "query",
        "schema": { "type": "integer" },
        "description": "Range stop timestamp (inclusive, Farcaster epoch)"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "errCode": { "type": "string" },
          "details": { "type": "string" },
          "metadata": { "type": "object" }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "fid": { "type": "integer" },
              "timestamp": { "type": "integer" },
              "network": { "type": "string" }
            }
          },
          "hash": { "type": "string" },
          "hashScheme": { "type": "string" },
          "signature": { "type": "string" },
          "signatureScheme": { "type": "string" },
          "signer": { "type": "string" }
        }
      },
      "MessagesResponse": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Message" }
          },
          "nextPageToken": { "type": "string" }
        }
      },
      "UsernameProof": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "integer" },
          "name": { "type": "string" },
          "owner": { "type": "string" },
          "signature": { "type": "string" },
          "fid": { "type": "integer" },
          "type": { "type": "string" }
        }
      },
      "UsernameProofsResponse": {
        "type": "object",
        "properties": {
          "proofs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UsernameProof" }
          }
        }
      },
      "OnChainEvent": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "chainId": { "type": "integer" },
          "blockNumber": { "type": "integer" },
          "blockHash": { "type": "string" },
          "blockTimestamp": { "type": "integer" },
          "transactionHash": { "type": "string" },
          "logIndex": { "type": "integer" },
          "fid": { "type": "integer" },
          "txIndex": { "type": "integer" }
        }
      },
      "OnChainEventsResponse": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OnChainEvent" }
          }
        }
      },
      "FidAddressTypeResponse": {
        "type": "object",
        "properties": {
          "isCustody": { "type": "boolean" },
          "isAuth": { "type": "boolean" },
          "isVerified": { "type": "boolean" }
        }
      },
      "FidsResponse": {
        "type": "object",
        "properties": {
          "fids": {
            "type": "array",
            "items": { "type": "integer" }
          },
          "nextPageToken": { "type": "string" }
        }
      },
      "StorageLimitsResponse": {
        "type": "object",
        "properties": {
          "limits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "storeType": { "type": "string" },
                "name": { "type": "string" },
                "limit": { "type": "integer" },
                "used": { "type": "integer" },
                "earliestTimestamp": { "type": "integer" },
                "earliestHash": { "type": "string" }
              }
            }
          },
          "units": { "type": "integer" },
          "unitDetails": { "type": "array", "items": { "type": "object" } },
          "tierSubscriptions": { "type": "array", "items": { "type": "object" } }
        }
      },
      "HubEvent": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "integer" },
          "blockNumber": { "type": "integer" },
          "shardIndex": { "type": "integer" }
        }
      },
      "HubEventsResponse": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/HubEvent" }
          }
        }
      },
      "ValidateMessageResponse": {
        "type": "object",
        "properties": {
          "valid": { "type": "boolean" },
          "message": { "$ref": "#/components/schemas/Message" }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Optional HTTP Basic Auth if enabled on the hub"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    }
  },
  "security": []
}