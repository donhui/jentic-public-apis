    }
  ],
  "paths": {
    "/authorization/{product}/{merchantId}": {
      "post": {
        "parameters": [
          {
            "description": "Identificador del producto",
            "example": "ecommerce",
            "in": "path",
            "name": "product",
            "required": true,
            "schema": {
              "enum": [
                "recurrence",
                "ecommerce"
              ],
              "type": "string"
            }
          },
          {
            "description": "Identificador del comercio",
            "example": "341198210",
            "in": "path",
            "name": "merchantId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizationResponse"
                }
              }
            },
            "description": "successful operation"
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Request is not valid"
          }
        },
        "security": [
          {
            "accessToken": []
          }
        ],
        "tags": [
          "Authorization Api"
        ],
        "description": "RESTful API to authorizate transactions.",
        "operationId": "authorize",
        "requestBody": {
          "content": {
            "application/json; charset=utf-8": {
              "schema": {
                "$ref": "#/components/schemas/AuthorizationRequest"
              }
            }
          },
          "description": "Authorization request",
          "required": true
        },
        "summary": "Authorization"
      }
    },
    "/void/{merchantId}": {
      "post": {
        "parameters": [
          {
            "description": "Identificador del comercio",
            "example": "341198210",
