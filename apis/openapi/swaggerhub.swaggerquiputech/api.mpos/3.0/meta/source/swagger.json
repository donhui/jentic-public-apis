  "tags": [
    {
      "name": "MPos Api",
      "description": "RESTful API for MPos operations"
    },
    {
      "name": "MPos Init Api",
      "description": "RESTful API for Init operations"
    },
    {
      "name": "MPos Terminal Api",
      "description": "RESTful API for Terminal operations"
    }
  ],
  "schemes": [
    "https"
  ],
  "paths": {
    "/init/device": {
      "post": {
        "tags": [
          "MPos Init Api"
        ],
        "summary": "InitDevice",
        "description": "RESTful API to initialize device.",
        "operationId": "initDevice",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Initialization device request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/InitDeviceRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/InitDeviceResponse"
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    },
    "/terminal/mpos/{serialNumber}": {
      "get": {
        "tags": [
          "MPos Terminal Api"
        ],
        "summary": "GetTerminal",
        "description": "RESTful API to get terminal",
        "operationId": "getTerminal",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "serialNumber",
            "in": "path",
            "description": "Serial number",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/Terminal"
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    },
    "/validate/card": {
      "post": {
        "tags": [
          "MPos Api"
        ],
        "summary": "ValidateCard",
        "description": "RESTful API to validate card transactions.",
        "operationId": "validateCard",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Authorization request",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ValidateCardRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/ValidateCardResponse"
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ]
      }
    }
  },
  "securityDefinitions": {
    "basicAuth": {
      "type": "basic"
    }
  },
  "definitions": {
    "AIDSet": {
      "type": "object",
      "properties": {
        "aid": {
          "type": "string"
        },
        "floorLimitAmount": {
          "type": "number",
          "format": "double"
        },
        "versionNumber1": {
          "type": "string"
        },
        "versionNumber2": {
          "type": "string"
        },
        "versionNumber3": {
          "type": "string"
        },
        "tacDenial": {
          "type": "string"
        },
        "tacOnline": {
          "type": "string"
        },
        "tacDefault": {
          "type": "string"
        },
        "aidExactMatch": {
          "type": "boolean"
        },
        "tdol": {
          "type": "string"
        },
        "ddol": {
          "type": "string"
        },
        "transactionLimitAmount": {
          "type": "number",
          "format": "double"
        },
        "verificationLimitAmount": {
          "type": "number",
          "format": "double"
        },
        "clessFloorLimitAmount": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "EMVSet": {
      "type": "object",
      "properties": {
        "keyIndex": {
          "type": "string"
        },
        "keyRid": {
          "type": "string"
        },
        "keyExponent": {
          "type": "string"
        },
        "keyLength": {
          "type": "integer",
          "format": "int32"
        },
        "keyValue": {
          "type": "string"
        }
      }
    },
    "GenericParam": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "InitDeviceRequest": {
      "type": "object",
      "properties": {
        "mpos": {
          "$ref": "#/definitions/MobilePos"
        },
        "device": {
          "$ref": "#/definitions/MobileDevice"
        },
        "location": {
          "$ref": "#/definitions/Location"
        }
      }
    },
    "InitDeviceResponse": {
      "type": "object",
      "properties": {
        "networkId": {
          "type": "string"
        },
        "serialNumber": {
          "type": "string"
        },
        "merchantId": {
          "type": "string"
        },
        "terminalId": {
          "type": "string"
        },
        "currencyId": {
          "type": "string",
          "enum": [
            "USD",
            "PEN"
          ]
        },
        "merchantName": {
          "type": "string"
        },
        "operationParams": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GenericParam"
          }
        },
        "aidSets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AIDSet"
          }
        },
        "emvSets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EMVSet"
          }
        }
      }
    },
    "Location": {
      "type": "object",
      "properties": {
        "latitude": {
          "type": "integer",
          "format": "int64"
        },
        "longitude": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "MobileDevice": {
      "type": "object",
      "properties": {
        "osName": {
          "type": "string"
        },
        "osVersion": {
          "type": "string"
        }
      }
    },
    "MobilePos": {
      "type": "object",
      "properties": {
        "serialNumber": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "networkId": {
          "type": "string"
        },
        "cpuId": {
          "type": "string"
        }
      }
    },
    "Terminal": {
      "type": "object",
      "properties": {
        "terminalId": {
          "type": "string"
        },
        "merchantId": {
          "type": "string"
        },
        "currencyId": {
          "type": "string",
          "enum": [
            "USD",
            "PEN"
          ]
        },
        "mobilePos": {
          "$ref": "#/definitions/MobilePos"
        },
        "status": {
          "type": "string",
          "enum": [
            "ACTIVE",
            "INACTIVE"
          ]
        },
        "networkId": {
          "type": "string"
        }
      }
    },
    "ValidateCardRequest": {
      "type": "object",
      "required": [
        "captureType",
        "dataEncrypted",
        "networkId",
        "serialNumber"
      ],
      "properties": {
        "dataEncrypted": {
          "type": "string",
          "description": "Encrypted pan or emv data"
        },
        "captureType": {
          "type": "string",
          "example": "MAGSTRIPE",
          "description": "Capture type",
          "enum": [
            "CHIP",
            "MAGSTRIPE",
            "CONTACT",
            "MANUAL"
          ]
        },
        "networkId": {
          "type": "string",
          "example": "VNB2B",
          "description": "Network Id for mpos device"
        },
        "serialNumber": {
          "type": "string",
          "example": "612345678",
          "description": "Serial number for mpos device"
        }
      },
      "description": "Validate card transaction request"
    },
    "ValidateCardResponse": {
      "type": "object",
      "required": [
        "bin",
        "maskedPan",
        "requiredChip",
        "requiresPin",
        "serviceCode"
      ],
      "properties": {
        "requiresPin": {
          "type": "boolean",
          "description": "Requires pin"
        },
        "requiredChip": {
          "type": "boolean",
          "description": "Requires chip"
        },
        "serviceCode": {
          "type": "string",
          "example": "226",
          "description": "Service code for pan number"
        },
        "maskedPan": {
          "type": "string",
          "example": "**** **** **** 1234",
          "description": "Masked pan"
        },
        "bin": {
          "type": "string",
          "example": "455147",
          "description": "Bin number"
        }
      },
      "description": "Validate card transaction response"
    }
  },
  "host": "virtserver.swaggerhub.com",
  "basePath": "/swaggerquiputech/api.mpos/3.0"
}