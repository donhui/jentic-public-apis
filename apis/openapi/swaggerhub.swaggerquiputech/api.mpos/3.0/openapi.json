  "paths": {
    "/init/device": {
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitDeviceResponse"
                }
              }
            },
            "description": "successful operation"
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "MPos Init Api"
        ],
        "description": "RESTful API to initialize device.",
        "operationId": "initDevice",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InitDeviceRequest"
              }
            }
          },
          "description": "Initialization device request",
          "required": true
        },
        "summary": "InitDevice"
      }
    },
    "/terminal/mpos/{serialNumber}": {
      "get": {
        "parameters": [
          {
            "description": "Serial number",
            "in": "path",
            "name": "serialNumber",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Terminal"
                }
              }
            },
            "description": "successful operation"
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "MPos Terminal Api"
        ],
        "description": "RESTful API to get terminal",
        "operationId": "getTerminal",
        "summary": "GetTerminal"
      }
    },
    "/validate/card": {
      "post": {
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateCardResponse"
                }
              }
            },
            "description": "successful operation"
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "MPos Api"
        ],
        "description": "RESTful API to validate card transactions.",
        "operationId": "validateCard",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateCardRequest"
              }
            }
          },
          "description": "Authorization request",
          "required": true
        },
        "summary": "ValidateCard"
      }
    }
  },
  "components": {
    "schemas": {
      "AIDSet": {
        "properties": {
          "aid": {
            "type": "string"
          },
          "aidExactMatch": {
            "type": "boolean"
          },
          "clessFloorLimitAmount": {
            "format": "double",
            "type": "number"
          },
          "ddol": {
            "type": "string"
          },
          "floorLimitAmount": {
            "format": "double",
            "type": "number"
          },
          "tacDefault": {
            "type": "string"
          },
          "tacDenial": {
            "type": "string"
          },
          "tacOnline": {
            "type": "string"
          },
          "tdol": {
            "type": "string"
          },
          "transactionLimitAmount": {
            "format": "double",
            "type": "number"
          },
          "verificationLimitAmount": {
            "format": "double",
            "type": "number"
          },
          "versionNumber1": {
            "type": "string"
          },
          "versionNumber2": {
            "type": "string"
          },
          "versionNumber3": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "EMVSet": {
        "properties": {
          "keyExponent": {
            "type": "string"
          },
          "keyIndex": {
            "type": "string"
          },
          "keyLength": {
            "format": "int32",
            "type": "integer"
          },
          "keyRid": {
            "type": "string"
          },
          "keyValue": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "GenericParam": {
        "properties": {
          "description": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "InitDeviceRequest": {
        "properties": {
          "device": {
            "$ref": "#/components/schemas/MobileDevice"
          },
          "location": {
            "$ref": "#/components/schemas/Location"
          },
          "mpos": {
            "$ref": "#/components/schemas/MobilePos"
          }
        },
        "type": "object"
      },
      "InitDeviceResponse": {
        "properties": {
          "aidSets": {
            "items": {
              "$ref": "#/components/schemas/AIDSet"
            },
            "type": "array"
          },
          "currencyId": {
            "enum": [
              "USD",
              "PEN"
            ],
            "type": "string"
          },
          "emvSets": {
            "items": {
              "$ref": "#/components/schemas/EMVSet"
            },
            "type": "array"
          },
          "merchantId": {
            "type": "string"
          },
          "merchantName": {
            "type": "string"
          },
          "networkId": {
            "type": "string"
          },
          "operationParams": {
            "items": {
              "$ref": "#/components/schemas/GenericParam"
            },
            "type": "array"
          },
          "serialNumber": {
            "type": "string"
          },
          "terminalId": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "Location": {
        "properties": {
          "latitude": {
            "format": "int64",
            "type": "integer"
          },
          "longitude": {
            "format": "int64",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "MobileDevice": {
        "properties": {
          "osName": {
            "type": "string"
          },
          "osVersion": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "MobilePos": {
        "properties": {
          "cpuId": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "networkId": {
            "type": "string"
          },
          "serialNumber": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "Terminal": {
        "properties": {
          "currencyId": {
            "enum": [
              "USD",
              "PEN"
            ],
            "type": "string"
          },
          "merchantId": {
            "type": "string"
          },
          "mobilePos": {
            "$ref": "#/components/schemas/MobilePos"
          },
          "networkId": {
            "type": "string"
          },
          "status": {
            "enum": [
              "ACTIVE",
              "INACTIVE"
            ],
            "type": "string"
          },
          "terminalId": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "ValidateCardRequest": {
        "description": "Validate card transaction request",
        "properties": {
          "captureType": {
            "description": "Capture type",
            "enum": [
              "CHIP",
              "MAGSTRIPE",
              "CONTACT",
              "MANUAL"
            ],
            "example": "MAGSTRIPE",
            "type": "string"
          },
          "dataEncrypted": {
            "description": "Encrypted pan or emv data",
            "type": "string"
          },
          "networkId": {
            "description": "Network Id for mpos device",
            "example": "VNB2B",
            "type": "string"
          },
          "serialNumber": {
            "description": "Serial number for mpos device",
            "example": "612345678",
            "type": "string"
          }
        },
        "required": [
          "captureType",
          "dataEncrypted",
          "networkId",
          "serialNumber"
        ],
        "type": "object"
      },
      "ValidateCardResponse": {
        "description": "Validate card transaction response",
        "properties": {
          "bin": {
            "description": "Bin number",
            "example": "455147",
            "type": "string"
          },
          "maskedPan": {
            "description": "Masked pan",
            "example": "**** **** **** 1234",
            "type": "string"
          },
          "requiredChip": {
            "description": "Requires chip",
            "type": "boolean"
          },
          "requiresPin": {
            "description": "Requires pin",
            "type": "boolean"
          },
          "serviceCode": {
            "description": "Service code for pan number",
            "example": "226",
            "type": "string"
          }
        },
        "required": [
          "bin",
          "maskedPan",
          "requiredChip",
          "requiresPin",
          "serviceCode"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "scheme": "basic",
        "type": "http"
      }
    }
  },
  "tags": [
    {
      "description": "RESTful API for MPos operations",
      "name": "MPos Api"
    },
    {
      "description": "RESTful API for Init operations",
      "name": "MPos Init Api"
    },
    {
      "description": "RESTful API for Terminal operations",
      "name": "MPos Terminal Api"
    }
  ]
}