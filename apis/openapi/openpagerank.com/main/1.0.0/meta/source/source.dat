{
  "openapi": "3.0.3",
  "info": {
    "title": "Open PageRank API",
    "version": "1.0.0",
    "description": "API for retrieving page rank data for domains. Supports batch lookups of up to 100 domains per request.",
    "x-jentic-source-url": "https://www.domcop.com/openpagerank/documentation"
  },
  "servers": [
    {
      "url": "https://openpagerank.com/api/v1.0"
    }
  ],
  "paths": {
    "/getPageRank": {
      "get": {
        "operationId": "getPageRank",
        "summary": "Get page rank for one or more domains",
        "description": "Retrieves page rank data for specified domains. Supports up to 100 domains per request.",
        "tags": ["PageRank"],
        "parameters": [
          {
            "name": "domains[]",
            "in": "query",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 100
            },
            "description": "Domain names to check (up to 100)",
            "style": "form",
            "explode": true
          }
        ],
        "responses": {
          "200": {
            "description": "Page rank data for requested domains",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageRankResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid domains or exceeds limit"
          },
          "401": {
            "description": "Unauthorized - missing or invalid API key"
          },
          "429": {
            "description": "Rate limit exceeded (10,000 calls per hour)"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PageRankResponse": {
        "type": "object",
        "properties": {
          "status_code": {
            "type": "integer",
            "description": "HTTP status code for overall request"
          },
          "response": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DomainRank"
            }
          },
          "last_updated": {
            "type": "string",
            "description": "Timestamp of last data refresh"
          }
        }
      },
      "DomainRank": {
        "type": "object",
        "properties": {
          "status_code": {
            "type": "integer",
            "description": "Status code for this individual domain lookup"
          },
          "error": {
            "type": "string",
            "description": "Error message if applicable"
          },
          "page_rank_integer": {
            "type": "integer",
            "description": "Integer page rank value"
          },
          "page_rank_decimal": {
            "type": "number",
            "format": "double",
            "description": "Decimal page rank value"
          },
          "rank": {
            "type": "string",
            "description": "Global ranking position"
          },
          "domain": {
            "type": "string",
            "description": "Domain that was queried"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "API-OPR",
        "in": "header",
        "description": "Open PageRank API key"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}
