      "put": {
        "tags": [
          "Asset"
        ],
        "summary": "Update an asset",
        "description": "This endpoint will update the asset by its unique id.",
        "note": "<b>Please Note:</b> assetCategory, assetType, and assetSubType cannot be updated.",
        "security": [
          {
            "OAuth2": [
              "eq2"
            ]
          }
        ],
        "parameters": [
          {
            "name": "assetId",
            "in": "path",
            "description": "The ID of the asset",
            "required": true,
            "schema": {
              "type": "GUID",
              "format": "uuid",
              "example": "acd3fe92-308e-4d0b-b16f-90af96cc38d0"
            }
          }
        ],
        "requestBody": {
          "description": "Asset to be updated.",
          "content": {
            "application/vnd.deere.axiom.v3+json": {
              "schema": {
                "properties": {
                  "title": {
                    "description": "The name of the asset.",
                    "example": "Water Sensor",
                    "type": "string"
                  },
                  "assetCategory": {
                    "description": "Asset Category",
                    "example": "DEVICE",
                    "type": "string"
                  },
                  "assetType": {
                    "description": "Asset Type",
                    "example": "SENSOR",
                    "type": "string"
                  },
                  "assetSubType": {
                    "description": "Asset Sub Type",
                    "example": "OTHER",
                    "type": "string"
                  }
                }
              },
              "examples": {
                "No Header": {
                  "value": {
                    "title": "AgThing Water Device V2",
                    "assetCategory": "DEVICE",
                    "assetType": "SENSOR",
                    "assetSubType": "OTHER"
                  }
                }
              }
            }
          },
          "required": true
        },
        "contentType": {
          "description": "The request body used to create or update a client",
          "content": {
            "application/vnd.deere.axiom.v3+json": {
              "schema": {
                "properties": {
                  "Content-Type": "application/vnd.deere.axiom.v3+json"
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Success",
            "content": {
              "application/vnd.deere.axiom.v3+json": {
                "schema": {
                  "type": "object",
                  "properties": null
                },
                "examples": {
