{
    "openapi": "3.0.0",
    "info": {
        "version": "0.0.1",
        "title": "Account API",
        "description": "The Equity Bank Account API allows a Merchant to fetch full/minimal transaction details for a given operative account, do Account Enquiries and Get a List of Accounts Opened.",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/mkhisa7/account-api/0.0.1/swagger.json"
