    "components": {
        "schemas": {
            "FullStatementRequest": {
                "properties": {
                    "countryCode": {
                        "description": "the account's country code.",
                        "type": "string"
                    },
                    "accountNumber": {
                        "description": "The account number.",
                        "type": "string"
                    },
                    "fromDate": {
                        "description": "The start date of the statement period.",
                        "type": "string",
                        "format": "date"
                    },
                    "toDate": {
                        "description": "The end date of the statement period.",
                        "type": "string",
                        "format": "date"
                    }
                }
            },
            "FullStatementTransaction": {
                "properties": {
                    "reference": {
                        "description": "The transaction reference.",
                        "type": "string"
                    },
                    "date": {
                        "description": "The transaction date",
                        "type": "string",
                        "format": "date-time"
                    },
                    "description": {
                        "description": "The transaction description.",
                        "type": "string"
                    },
                    "amount": {
                        "description": "The transaction amount.",
                        "type": "string"
                    },
                    "type": {
                        "description": "Thr transaction type.",
                        "type": "string"
                    },
                    "runningBalance": {
                        "description": "The running balance.",
                        "type": "string"
                    }
                }
            },
            "MiniStatementTransaction": {
                "properties": {
                    "chequeNumber": {
                        "description": "Cheque number.",
                        "type": "string"
                    },
                    "date": {
                        "description": "The transaction date.",
                        "type": "string",
                        "format": "date-time"
                    },
                    "description": {
                        "description": "The transaction description.",
                        "type": "string"
                    },
                    "amount": {
                        "description": "The transaction amount.",
                        "type": "string"
                    },
                    "type": {
                        "description": "Thr transaction type.",
                        "type": "string"
                    }
                }
            },
            "Customer": {
                "properties": {
                    "id": {
                        "description": "Customer unique identifier.",
                        "type": "string"
                    },
                    "type": {
                        "description": "Customer type.",
                        "type": "string"
                    }
                }
            },
            "Account": {
                "properties": {
                    "number": {
                        "description": "Customer's account number.",
                        "type": "string"
                    },
                    "currency": {
                        "description": "Account currency.",
                        "type": "string"
                    },
                    "status": {
                        "description": "Account Status",
                        "type": "string"
                    }
                }
            },
            "Balance": {
                "properties": {
                    "amount": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string"
                    }
                }
            },
            "FullStatementResponse": {
                "properties": {
                    "accountNumber": {
                        "description": "The account number.",
                        "type": "string"
                    },
                    "currency": {
                        "description": "The account currency.",
                        "type": "string"
                    },
                    "balance": {
                        "description": "The account balance.",
                        "type": "string"
                    },
                    "transactions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/FullStatementTransaction"
                        }
                    }
                }
            },
            "GetMiniStatementResponse": {
                "properties": {
                    "accountNumber": {
                        "description": "Account number",
                        "type": "string"
                    },
                    "currency": {
                        "description": "Account currency.",
                        "type": "string"
                    },
                    "balance": {
                        "description": "Account balance.",
                        "type": "string"
                    },
                    "transactions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/MiniStatementTransaction"
                        }
                    }
                }
            },
            "AccountEnquiryResponse": {
                "properties": {
                    "account": {
                        "$ref": "#/components/schemas/Account"
                    },
                    "customer": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Customer"
                        }
                    }
                }
            },
            "GetBalanceResponse": {
                "properties": {
                    "currency": {
                        "type": "string"
                    },
                    "balances": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Balance"
                        }
                    }
                }
            },
            "ErrorResponse": {
                "properties": {
                    "code": {
                        "type": "string"
                    },
                    "error": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    }
                }
            }
        }
    }
