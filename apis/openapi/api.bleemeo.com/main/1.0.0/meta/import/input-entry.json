  "components": {
    "schemas": {
      "JwtAuthRequest": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "description": "User password"
          }
        }
      },
      "JwtAuthResponse": {
        "type": "object",
        "properties": {
          "access": {
            "type": "string",
            "description": "Access token (5-minute validity)"
          },
          "refresh": {
            "type": "string",
            "description": "Refresh token (7-day validity)"
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer"
          },
          "next": {
            "type": "string",
            "nullable": true
          },
          "previous": {
            "type": "string",
            "nullable": true
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication with Bleemeo username and password"
      },
      "jwtAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT bearer token obtained from /v1/jwt-auth/ endpoint"
      }
    }
  },
  "security": [
    {
      "jwtAuth": []
    }
  ]
