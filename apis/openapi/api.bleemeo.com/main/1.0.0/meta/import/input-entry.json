{
  "openapi": "3.0.3",
  "info": {
    "title": "Bleemeo API",
    "version": "1.0.0",
    "description": "Bleemeo REST API provides programmatic access to monitoring, alerting, and observability features including agents, metrics, services, dashboards, health checks, and notification management.",
    "x-jentic-source-url": "https://docs.bleemeo.com/api/"
  },
  "servers": [
    {
      "url": "https://api.bleemeo.com/v1"
    }
