{
  "openapi": "3.0.3",
  "info": {
    "title": "MPDS API",
    "version": "1.0.0",
    "description": "Materials Platform for Data Science (MPDS) API provides access to materials science data including crystal structures, phase diagrams, physical properties, and literature references. It enables programmatic querying and retrieval of curated materials data.",
    "x-jentic-source-url": "https://developer.mpds.io"
  },
  "servers": [
    {
      "url": "https://api.mpds.io/v0"
    }
  ],
  "paths": {
    "/search/facet": {
      "get": {
        "operationId": "searchFacet",
        "summary": "Search with faceted results",
        "description": "Performs a faceted search across the MPDS database, returning aggregated counts by category.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search query string for materials data",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "facet",
            "in": "query",
            "required": false,
            "description": "Facet field to aggregate results by",
            "schema": {
              "type": "string",
              "enum": ["props", "classes", "lattices", "sgs"]
            }
          },
          {
            "name": "pagesize",
            "in": "query",
            "required": false,
            "description": "Number of results per page",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful search results with facets",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FacetSearchResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/search/phase_id/{phaseId}": {
      "get": {
        "operationId": "getPhaseById",
        "summary": "Get phase by ID",
        "description": "Retrieves detailed information about a specific crystalline phase by its MPDS identifier.",
        "tags": ["Phases"],
        "parameters": [
          {
            "name": "phaseId",
            "in": "path",
            "required": true,
            "description": "Unique phase identifier in MPDS",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Phase details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhaseResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid phase ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/search/entry/{entryId}": {
      "get": {
        "operationId": "getEntryById",
        "summary": "Get entry by ID",
        "description": "Retrieves a specific data entry by its unique MPDS identifier, including all associated properties and references.",
        "tags": ["Entries"],
        "parameters": [
          {
            "name": "entryId",
            "in": "path",
            "required": true,
            "description": "Unique entry identifier in MPDS",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Entry details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid entry ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/download/s/{dataType}": {
      "get": {
        "operationId": "downloadDataByType",
        "summary": "Download data by type",
        "description": "Downloads materials data in bulk for a specified data type category.",
        "tags": ["Download"],
        "parameters": [
          {
            "name": "dataType",
            "in": "path",
            "required": true,
            "description": "Type of data to download (e.g., structures, properties)",
            "schema": {
              "type": "string",
              "enum": ["ab_initio", "machine_learning", "peer_reviewed"]
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Optional search filter for the download",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fmt",
            "in": "query",
            "required": false,
            "description": "Output format",
            "schema": {
              "type": "string",
              "enum": ["json", "csv"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Data file download",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FacetSearchResponse": {
        "type": "object",
        "properties": {
          "out": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer",
                  "description": "Entry identifier"
                },
                "S": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Chemical system elements"
                },
                "P": {
                  "type": "string",
                  "description": "Property name"
                }
              }
            }
          },
          "npages": {
            "type": "integer",
            "description": "Total number of pages"
          },
          "count": {
            "type": "integer",
            "description": "Total number of results"
          },
          "facets": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            },
            "description": "Faceted counts by category"
          }
        }
      },
      "PhaseResponse": {
        "type": "object",
        "properties": {
          "out": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "phase_id": {
                  "type": "integer"
                },
                "formula": {
                  "type": "string",
                  "description": "Chemical formula"
                },
                "space_group": {
                  "type": "string",
                  "description": "Space group symbol"
                },
                "crystal_system": {
                  "type": "string",
                  "description": "Crystal system name"
                },
                "lattice_parameters": {
                  "type": "object",
                  "properties": {
                    "a": { "type": "number" },
                    "b": { "type": "number" },
                    "c": { "type": "number" },
                    "alpha": { "type": "number" },
                    "beta": { "type": "number" },
                    "gamma": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      },
      "EntryResponse": {
        "type": "object",
        "properties": {
          "out": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "phase_id": {
                  "type": "integer"
                },
                "chemical": {
                  "type": "string"
                },
                "property": {
                  "type": "string"
                },
                "value": {
                  "type": "number"
                },
                "units": {
                  "type": "string"
                },
                "reference": {
                  "type": "string",
                  "description": "Literature reference"
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Key",
        "description": "MPDS API key for authentication"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}