{
  "openapi": "3.0.3",
  "info": {
    "title": "Qminder API",
    "description": "Qminder is a waiting list management system for physical locations. Manage locations, lines, tickets, appointments, users, and webhooks.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://www.qminder.com/docs/api/"
  },
  "servers": [
    {
      "url": "https://api.qminder.com/v1"
    }
  ],
  "security": [
    {
      "apiKeyHeader": []
    }
  ],
  "tags": [
    {"name": "Locations", "description": "Location management"},
    {"name": "Lines", "description": "Line/queue management"},
    {"name": "Tickets", "description": "Queue ticket operations"},
    {"name": "Appointments", "description": "Appointment scheduling"},
    {"name": "Users", "description": "User management"},
    {"name": "Webhooks", "description": "Webhook management"}
  ],
  "paths": {
    "/locations": {
      "get": {
        "tags": ["Locations"],
        "summary": "Get list of locations",
        "operationId": "listLocations",
        "responses": {
          "200": {
            "description": "Locations retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LocationListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/locations/{id}": {
      "get": {
        "tags": ["Locations"],
        "summary": "Get location details",
        "operationId": "getLocation",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Location details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LocationResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/locations/{id}/desks": {
      "get": {
        "tags": ["Locations"],
        "summary": "Get desks at location",
        "operationId": "getLocationDesks",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Desks retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeskListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/locations/{id}/lines": {
      "get": {
        "tags": ["Lines"],
        "summary": "Get list of lines at location",
        "operationId": "listLines",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Lines retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LineListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Lines"],
        "summary": "Create a line at location",
        "operationId": "createLine",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/LineInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Line created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LineResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lines/{id}": {
      "get": {
        "tags": ["Lines"],
        "summary": "Get line details",
        "operationId": "getLine",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Line details retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LineResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Lines"],
        "summary": "Edit a line",
        "operationId": "editLine",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/LineInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Line updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LineResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "tags": ["Lines"],
        "summary": "Delete a line",
        "operationId": "deleteLine",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Line deleted" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lines/{id}/enable": {
      "post": {
        "tags": ["Lines"],
        "summary": "Enable a line",
        "operationId": "enableLine",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Line enabled" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lines/{id}/disable": {
      "post": {
        "tags": ["Lines"],
        "summary": "Disable a line",
        "operationId": "disableLine",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Line disabled" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lines/{id}/archive": {
      "post": {
        "tags": ["Lines"],
        "summary": "Archive a line",
        "operationId": "archiveLine",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Line archived" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/lines/{id}/unarchive": {
      "post": {
        "tags": ["Lines"],
        "summary": "Unarchive a line",
        "operationId": "unarchiveLine",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Line unarchived" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Create a ticket",
        "operationId": "createTicket",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": { "$ref": "#/components/schemas/TicketInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TicketResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}": {
      "get": {
        "tags": ["Tickets"],
        "summary": "Get ticket details",
        "operationId": "getTicket",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Ticket details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TicketResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "patch": {
        "tags": ["Tickets"],
        "summary": "Edit a ticket",
        "operationId": "editTicket",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "X-Qminder-API-Version", "in": "header", "schema": { "type": "string", "default": "2020-09-01" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TicketInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TicketResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/messages": {
      "get": {
        "tags": ["Tickets"],
        "summary": "Get ticket messages",
        "operationId": "getTicketMessages",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Messages retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MessageListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Tickets"],
        "summary": "Send SMS message to ticket visitor",
        "operationId": "sendTicketMessage",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": { "type": "string" }
                },
                "required": ["message"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Message sent" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/assign": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Assign ticket to user",
        "operationId": "assignTicket",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "user": { "type": "integer", "description": "User ID to assign to" }
                },
                "required": ["user"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Ticket assigned" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/unassign": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Unassign ticket",
        "operationId": "unassignTicket",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Ticket unassigned" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/call": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Call ticket",
        "operationId": "callTicket",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Ticket called" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/recall": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Re-call ticket",
        "operationId": "recallTicket",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Ticket re-called" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/forward": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Forward ticket to another line",
        "operationId": "forwardTicket",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "line": { "type": "integer", "description": "Line ID to forward to" }
                },
                "required": ["line"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Ticket forwarded" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/markserved": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Mark ticket as served",
        "operationId": "markTicketServed",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Ticket marked as served" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/marknoshow": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Mark ticket as no-show",
        "operationId": "markTicketNoShow",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Ticket marked as no-show" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/cancel": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Remove ticket from queue",
        "operationId": "cancelTicket",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Ticket cancelled" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/returntoqueue": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Return ticket to queue",
        "operationId": "returnTicketToQueue",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Ticket returned to queue" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/reorder": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Reorder ticket in queue",
        "operationId": "reorderTicket",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "position": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Ticket reordered" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/labels/add": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Add label to ticket",
        "operationId": "addTicketLabel",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "value": { "type": "string" }
                },
                "required": ["value"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Label added" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{id}/labels/remove": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Remove label from ticket",
        "operationId": "removeTicketLabel",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "value": { "type": "string" }
                },
                "required": ["value"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Label removed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/{ticketId}/fields/{inputFieldId}": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Save field value for ticket",
        "operationId": "saveTicketFieldValue",
        "parameters": [
          { "name": "ticketId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "inputFieldId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "value": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Field value saved" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "delete": {
        "tags": ["Tickets"],
        "summary": "Remove field value from ticket",
        "operationId": "removeTicketFieldValue",
        "parameters": [
          { "name": "ticketId", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "inputFieldId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Field value removed" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/count": {
      "post": {
        "tags": ["Tickets"],
        "summary": "Count tickets",
        "operationId": "countTickets",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "location": { "type": "integer" },
                  "line": { "type": "integer" },
                  "status": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ticket count",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TicketCountResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/tickets/search": {
      "get": {
        "tags": ["Tickets"],
        "summary": "Search tickets",
        "operationId": "searchTickets",
        "parameters": [
          { "name": "location", "in": "query", "schema": { "type": "integer" } },
          { "name": "line", "in": "query", "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "caller", "in": "query", "schema": { "type": "integer" } },
          { "name": "minCreated", "in": "query", "schema": { "type": "string" } },
          { "name": "maxCreated", "in": "query", "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "order", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TicketListResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/appointments": {
      "post": {
        "tags": ["Appointments"],
        "summary": "Create an appointment",
        "operationId": "createAppointment",
        "parameters": [
          { "name": "X-Qminder-API-Version", "in": "header", "schema": { "type": "string", "default": "2020-09-01" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AppointmentInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Appointment created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AppointmentResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/appointments/auto-assign": {
      "post": {
        "tags": ["Appointments"],
        "summary": "Create auto-assigning appointment",
        "operationId": "createAutoAssigningAppointment",
        "parameters": [
          { "name": "X-Qminder-API-Version", "in": "header", "schema": { "type": "string", "default": "2020-09-01" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AppointmentInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Auto-assigning appointment created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AppointmentResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/appointments/{ticketId}/cancel": {
      "post": {
        "tags": ["Appointments"],
