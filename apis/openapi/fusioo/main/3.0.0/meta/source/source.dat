  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "OAuth 2.0 Bearer token"
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer", "example": 10000 },
          "data": { "type": "object" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "message": { "type": "string" }
        }
      },
      "CountResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "data": {
            "type": "object",
            "properties": {
              "count": { "type": "integer" }
            }
          }
        }
      },
      "Record": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "key_field": { "type": "string" }
        },
        "additionalProperties": true
      },
      "RecordCreatedResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "integer" },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "key_field": { "type": "string" }
            }
          }
        }
      },
      "FilterConditions": {
        "type": "object",
        "description": "Filter conditions with field-based operators like equal, contains, from, to, etc.",
        "additionalProperties": {
          "type": "object"
        }
      },
      "App": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          }
        }
      },
      "Discussion": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "content": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "created_by": { "type": "string" }
        }
      },
      "CreateDiscussionRequest": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "content": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "created_by": { "type": "string" }
        }
      },
      "CreateCommentRequest": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "lite": { "type": "boolean" },
          "enabled": { "type": "boolean" }
        }
      },
      "FileMetadata": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "size": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" },
          "created_by": { "type": "string" }
        }
      },
      "FileUploadResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "Webhook": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "secret": { "type": "string" },
          "app_id": { "type": "string" },
          "on_create": { "type": "boolean" },
          "on_update": { "type": "boolean" },
          "on_delete": { "type": "boolean" }
        }
      },
      "CreateWebhookRequest": {
        "type": "object",
        "required": ["url", "app_id"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "app_id": { "type": "string" },
          "on_create": { "type": "boolean" },
          "on_update": { "type": "boolean" },
          "on_delete": { "type": "boolean" }
        }
      }
    }
  }
}