{
  "openapi": "3.0.3",
  "info": {
    "title": "Limnu Whiteboard API",
    "version": "v1",
    "description": "Online whiteboard API for creating and managing collaborative whiteboards, users, and board content.",
    "x-jentic-source-url": "https://limnu.com/docs/api/"
  },
  "servers": [
    {
      "url": "https://{endpoint}/v1",
      "variables": {
        "endpoint": {
          "default": "api.limnu.com",
          "description": "Endpoint provided by Limnu"
        }
      }
    }
  ],
  "paths": {
    "/userActive": {
      "post": {
        "operationId": "userActive",
        "summary": "User activation/status",
        "description": "Check or set user activation status.",
        "tags": ["Users"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserRequest" } } } },
        "responses": {
          "200": { "description": "Success", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/userCreate": {
      "post": {
        "operationId": "userCreate",
        "summary": "Create user account",
        "description": "Create a new user account.",
        "tags": ["Users"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserRequest" } } } },
        "responses": {
          "200": { "description": "User created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/userUsage": {
      "post": {
        "operationId": "userUsage",
        "summary": "Get user usage metrics",
        "description": "Retrieve user usage statistics.",
        "tags": ["Users"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserRequest" } } } },
        "responses": {
          "200": { "description": "Usage data", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardActive": {
      "post": {
        "operationId": "boardActive",
        "summary": "Board activation/status",
        "description": "Check or set board activation status.",
        "tags": ["Boards"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BoardRequest" } } } },
        "responses": {
          "200": { "description": "Success", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardCreate": {
      "post": {
        "operationId": "boardCreate",
        "summary": "Create a board",
        "description": "Create a new whiteboard.",
        "tags": ["Boards"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BoardRequest" } } } },
        "responses": {
          "200": { "description": "Board created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardInfo": {
      "post": {
        "operationId": "boardInfo",
        "summary": "Get board information",
        "description": "Retrieve board details.",
        "tags": ["Boards"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BoardRequest" } } } },
        "responses": {
          "200": { "description": "Board info", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardRole": {
      "post": {
        "operationId": "boardRole",
        "summary": "Manage board user roles",
        "description": "Manage user roles on a board.",
        "tags": ["Boards"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BoardRoleRequest" } } } },
        "responses": {
          "200": { "description": "Role updated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardCopy": {
      "post": {
        "operationId": "boardCopy",
        "summary": "Duplicate a board",
        "description": "Create a copy of an existing board.",
        "tags": ["Boards"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BoardRequest" } } } },
        "responses": {
          "200": { "description": "Board copied", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardRename": {
      "post": {
        "operationId": "boardRename",
        "summary": "Rename a board",
        "description": "Rename an existing board.",
        "tags": ["Boards"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BoardRenameRequest" } } } },
        "responses": {
          "200": { "description": "Board renamed", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardDelete": {
      "post": {
        "operationId": "boardDelete",
        "summary": "Delete a board",
        "description": "Delete an existing board.",
        "tags": ["Boards"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BoardRequest" } } } },
        "responses": {
          "200": { "description": "Board deleted", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardList": {
      "post": {
        "operationId": "boardList",
        "summary": "List boards",
        "description": "List user's boards.",
        "tags": ["Boards"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserRequest" } } } },
        "responses": {
          "200": { "description": "Board list", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardUsage": {
      "post": {
        "operationId": "boardUsage",
        "summary": "Board usage statistics",
        "description": "Get usage statistics for a board.",
        "tags": ["Boards"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BoardRequest" } } } },
        "responses": {
          "200": { "description": "Usage data", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardImageURLUpload": {
      "post": {
        "operationId": "boardImageUrlUpload",
        "summary": "Upload image via URL",
        "description": "Upload an image to a board via URL.",
        "tags": ["Board Content"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ImageUrlUploadRequest" } } } },
        "responses": {
          "200": { "description": "Image uploaded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/boardImageFileUpload": {
      "post": {
        "operationId": "boardImageFileUpload",
        "summary": "Upload image via file",
        "description": "Upload an image file to a board.",
        "tags": ["Board Content"],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "$ref": "#/components/schemas/ImageFileUploadRequest" } } } },
        "responses": {
          "200": { "description": "Image uploaded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SuccessResponse" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserRequest": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "userId": { "type": "string" }
        }
      },
      "BoardRequest": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "boardId": { "type": "string" }
        }
      },
      "BoardRoleRequest": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "boardId": { "type": "string" },
          "userId": { "type": "string" },
          "role": { "type": "string" }
        }
      },
      "BoardRenameRequest": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "boardId": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "ImageUrlUploadRequest": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "boardId": { "type": "string" },
          "imageUrl": { "type": "string" }
        }
      },
      "ImageFileUploadRequest": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "boardId": { "type": "string" },
          "file": { "type": "string", "format": "binary" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "required": ["success"],
        "properties": {
          "success": { "type": "boolean" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["success"],
        "properties": {
          "success": { "type": "boolean", "example": false },
          "reason": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "query",
        "name": "apiKey",
        "description": "API key issued by Limnu support"
      }
    }
  },
  "security": [
    {
      "apiKey": []
    }
  ]
}