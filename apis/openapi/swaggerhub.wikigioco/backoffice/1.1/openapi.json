  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "APIKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      },
      "APIKeyQueryParam": {
        "type": "apiKey",
        "in": "query",
        "name": "api_key"
      }
    },
    "schemas": {
      "Authority": {
        "type": "string",
        "enum": [
          "ADMIN",
          "OPERATOR",
          "USER",
          "AUTHORITY",
          "HELPDESK",
          "SUPPLIER"
        ],
        "example": "ADMIN",
        "description": "ADMIN - ADMIN, OPERATOR - OPERATOR, USER - USER, AUTHORITY - AUTHORITY, HELPDESK - HELPDESK, SUPPLIER - SUPPLIER,"
      },
      "MerchantShop": {
        "title": "Change Password Request",
        "description": "Login",
        "required": [
          "username",
          "password",
          "app"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "username to login",
            "example": "test"
          },
          "oldPassword": {
            "type": "string",
            "description": "the old password to login",
            "example": "test"
          },
          "newPassword": {
            "type": "string",
            "description": "the new password",
            "example": "testNew"
          },
          "confirmPassword": {
            "type": "string",
            "description": "the new password to confirm if match",
            "example": "testNew"
          },
          "idUser": {
            "type": "number",
            "description": "name of the application to login",
            "example": 1
          }
        }
      },
      "User": {
        "title": "User model",
        "description": "User model",
        "required": [
          "username"
        ],
        "properties": {
          "id": {
            "type": "number",
            "description": "id of the 'User'",
            "example": 1
          },
          "idUser": {
            "type": "number",
            "description": "id of the 'User'",
            "example": 1
          },
          "authorities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Authority"
            }
          },
          "username": {
            "type": "string",
            "description": "username to login",
            "example": "test"
          },
          "firstName": {
            "type": "string",
            "description": "Name of the User",
            "example": "Giuseppe"
          },
          "lastName": {
            "type": "string",
            "description": "Surname of the User",
            "example": "Garibaldi"
          },
          "email": {
            "type": "string",
            "description": "Email of the User",
            "example": "giuseppe@garibaldi.it"
          },
          "active": {
            "type": "boolean",
            "description": "if the User is active",
            "example": true
          },
          "langId": {
            "type": "string",
            "description": "the default language of the User",
            "example": "it-IT"
          },
          "firstLogin": {
            "type": "boolean",
            "description": "if is true, the user already change his native password",
            "example": true
          }
        }
      },
      "ChangePasswordRequest": {
        "title": "Change Password Request",
        "description": "Login",
        "required": [
          "username",
          "password",
          "app"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "username to login",
            "example": "test"
          },
          "oldPassword": {
            "type": "string",
            "description": "the old password to login",
            "example": "test"
          },
          "newPassword": {
            "type": "string",
            "description": "the new password",
            "example": "testNew"
          },
          "confirmPassword": {
            "type": "string",
            "description": "the new password to confirm if match",
            "example": "testNew"
          },
          "idUser": {
            "type": "number",
            "description": "name of the application to login",
            "example": 1
          }
        }
      },
      "AuthRequest": {
        "title": "Login Request",
        "description": "Login",
        "required": [
          "username",
          "password",
          "app"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "username to login",
            "example": "test"
          },
          "password": {
            "type": "string",
            "description": "password to login",
            "example": "test"
          },
          "app": {
            "type": "string",
            "description": "name of the application to login",
            "example": "gams"
          }
        }
      },
      "AuthResponse": {
        "title": "Login Response",
        "description": "Login",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string",
            "description": "name of the application to login",
            "example": "eyJhbGciOiJIUzI1NiJ9.eyJqdGkiOiI0MWQ2ODRmZi01ZDM2LTQzYTAtOTU5My01OTZiYWY1NTA4MDMiLCJpc3MiOiJodHRwOi8vd3d3Lndpa2lnaW9jby5jb20iLCJhdWQiOiJodHRwOi8vd3d3Lndpa2lnaW9jby5jb20iLCJzdWIiOiJiZXRidXMiLCJpYXQiOjE2MDAwNjc3OTEsImV4cCI6MTYwMDEwMzc5MSwiYXV0aG9yaXRpZXMiOlsiU1VQUExJRVIiXSwicmVmcmVzaENvdW50IjowLCJyZWZyZXNoTGltaXQiOjF9.sHStnHv_XehhRu2AdwJVl_GgwBQ8UILXsvWShOy6meU"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "ReportInput": {
        "title": "Login Response",
        "description": "Login",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
