                "type": "string",
                "example": "WLTORG_BarSport",
                "description": "the id of the wallet of the deposit"
              },
              "Totals": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "Amount": {
                      "type": "integer",
                      "format": "int64",
                      "example": 1000,
                      "description": "the amount expressed in currency cents"
                    },
                    "TotalTypeWalletOrg": {
                      "$ref": "#/components/schemas/TotalTypeWalletOrg"
                    }
                  }
                }
              },
              "Currency": {
                "type": "string",
                "description": "the currency (Format ISO 4217) of the amount",
                "example": "EUR"
              },
              "ClientOperationId": {
                "type": "string",
                "description": "the client unique identification of the operation",
                "example": "HUYTTHY8897768IUH"
              },
              "ServerOperationId": {
                "readOnly": true,
                "type": "string",
                "description": "the server unique identification of the operation",
                "example": "hiufuie9089022ksdjfds"
              },
              "Properties": {
                "type": "object",
                "description": "a json object with information from BO (such as payment type, references of the payment, etc...)"
