      "TransferFundsMessage": {
        "type": "object",
        "required": [
          "Identification",
          "TransferFunds",
          "Result"
        ],
        "properties": {
          "Identification": {
            "$ref": "#/components/schemas/IdentificationNS"
          },
          "TransferFunds": {
            "type": "object",
            "required": [
              "WalletId",
              "TotalBalance",
              "Currency"
            ],
            "properties": {
              "WalletIdFrom": {
                "type": "string",
                "description": "The source wallet id",
                "example": "WLT_MCH_278213",
                "writeOnly": true
              },
              "WalletIdTo": {
                "type": "string",
                "description": "The destination wallet id",
                "example": "WLT_PLY_672836",
                "writeOnly": true
              },
              "TransferReason": {
                "writeOnly": true,
                "allOf": [
                  {
                    "$ref": "#/components/schemas/EntryReason"
                  }
                ]
              },
              "Currency": {
                "writeOnly": true,
                "allOf": [
                  {
                    "$ref": "#/components/schemas/Currency"
                  }
                ]
              },
              "Amount": {
                "writeOnly": true,
                "type": "integer",
                "format": "int64",
                "description": "Amount of funds to transfer",
                "example": 5000
              }
            }
          },
          "Result": {
            "readOnly": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/Result"
              }
            ]
          }
        }
      },
      "SetInitialDepositAndOverdraftMessage": {
        "type": "object",
        "required": [
          "SetInitialDepositAndOverdraft"
        ],
        "properties": {
          "Identification": {
            "$ref": "#/components/schemas/IdentificationNS"
          },
          "SetInitialDepositAndOverdraft": {
            "type": "object",
            "required": [
              "OrganizationId",
              "InitialDeposit",
              "Overdraft",
              "Currency",
