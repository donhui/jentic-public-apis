              },
              "Currency": {
                "type": "string",
                "description": "the currency (Format ISO 4217) of the amount",
                "example": "EUR"
              },
              "ClientOperationId": {
                "type": "string",
                "description": "the client unique identification of the operation",
                "example": "HUYTTHY8897768IUH"
              },
              "ServerOperationId": {
                "readOnly": true,
                "type": "string",
                "description": "the server unique identification of the operation",
