                "items": {
                  "type": "object",
                  "properties": {
                    "Amount": {
                      "type": "integer",
                      "format": "int64",
                      "example": 1000,
                      "description": "the amount expressed in currency cents"
                    },
                    "TotalType": {
                      "$ref": "#/components/schemas/TotalTypeWalletOrg"
                    }
                  }
                }
              }
            }
          },
          "Result": {
            "readOnly": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/Result"
              }
            ]
          }
        }
