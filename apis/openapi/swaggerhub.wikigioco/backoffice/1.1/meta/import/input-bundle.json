              },
              "WalletId": {
                "readOnly": true,
                "type": "string",
                "example": "WLT_ORG_M0000000001",
                "description": "the wallet id associated to the organization"
              },
              "Currency": {
                "readOnly": true,
                "type": "string",
                "description": "the currency (Format ISO 4217) of the wallet",
                "example": "EUR"
              },
              "InitialDeposit": {
                "readOnly": true,
                "type": "integer",
                "format": "int64",
                "description": "the initial deposit of the organization in euro cents",
                "example": 20000
              },
              "InitialOverdraft": {
                "readOnly": true,
                "type": "integer",
                "format": "int64",
                "description": "the initial overdraft of the organization, if any, in euro cents",
                "example": 5000
              },
              "TotalBalance": {
                "readOnly": true,
                "type": "integer",
                "format": "int64",
                "description": "the total wallet balance of the organization in euro cents",
                "example": 11500
              },
              "LastUpdate": {
                "readOnly": true,
                "type": "string",
                "description": "Contains the last update timestamp of the balance",
                "example": "2020-10-10T17:32:28Z"
