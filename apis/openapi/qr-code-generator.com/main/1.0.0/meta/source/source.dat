{
  "openapi": "3.0.3",
  "info": {
    "title": "QR Code Generator API",
    "version": "1.0.0",
    "description": "API for creating customizable QR codes with design options including colors, logos, and frames. Supports multiple image output formats.",
    "x-jentic-source-url": "https://www.qr-code-generator.com/qr-code-api/"
  },
  "servers": [
    {
      "url": "https://api.qr-code-generator.com",
      "description": "QR Code Generator API server"
    }
  ],
  "tags": [
    {
      "name": "QR Code",
      "description": "QR code generation endpoints"
    }
  ],
  "paths": {
    "/v1/create": {
      "get": {
        "operationId": "createQrCodeGet",
        "summary": "Create a QR code via GET request",
        "description": "Generate a QR code image with the specified text content and customization options.",
        "tags": ["QR Code"],
        "parameters": [
          {
            "name": "access-token",
            "in": "query",
            "required": true,
            "description": "API access token for authentication.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "qr_code_text",
            "in": "query",
            "required": true,
            "description": "The text or URL to encode in the QR code.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "image_format",
            "in": "query",
            "description": "Output image format.",
            "schema": {
              "type": "string",
              "enum": ["JPG", "PNG", "SVG", "EPS"],
              "default": "SVG"
            }
          },
          {
            "name": "image_width",
            "in": "query",
            "description": "Image width in pixels (PNG/JPG only).",
            "schema": {
              "type": "integer",
              "default": 500
            }
          },
          {
            "name": "download",
            "in": "query",
            "description": "0 to return data directly, 1 to trigger browser download.",
            "schema": {
              "type": "integer",
              "enum": [0, 1],
              "default": 0
            }
          },
          {
            "name": "foreground_color",
            "in": "query",
            "description": "Foreground color in hex format (e.g., #000000).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "background_color",
            "in": "query",
            "description": "Background color in hex format (e.g., #FFFFFF).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marker_left_inner_color",
            "in": "query",
            "description": "Left marker inner color in hex format.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marker_left_outer_color",
            "in": "query",
            "description": "Left marker outer color in hex format.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marker_right_inner_color",
            "in": "query",
            "description": "Right marker inner color in hex format.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marker_right_outer_color",
            "in": "query",
            "description": "Right marker outer color in hex format.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marker_bottom_inner_color",
            "in": "query",
            "description": "Bottom marker inner color in hex format.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "marker_bottom_outer_color",
            "in": "query",
            "description": "Bottom marker outer color in hex format.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "frame_name",
            "in": "query",
            "description": "Name of the frame template to use.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "frame_color",
            "in": "query",
            "description": "Frame color in hex format.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "frame_text",
            "in": "query",
            "description": "Text to display on the frame.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "frame_text_color",
            "in": "query",
            "description": "Frame text color in hex format.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "QR code image file.",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/svg+xml": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createQrCodePost",
        "summary": "Create a QR code via POST request",
        "description": "Generate a QR code image with the specified text content and customization options using a POST request.",
        "tags": ["QR Code"],
        "parameters": [
          {
            "name": "access-token",
            "in": "query",
            "required": true,
            "description": "API access token for authentication.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQrCodeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "QR code image file.",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/svg+xml": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or missing access token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateQrCodeRequest": {
        "type": "object",
        "properties": {
          "qr_code_text": {
            "type": "string",
            "description": "The text or URL to encode in the QR code."
          },
          "image_format": {
            "type": "string",
            "enum": ["JPG", "PNG", "SVG", "EPS"],
            "default": "SVG"
          },
          "image_width": {
            "type": "integer",
            "default": 500
          },
          "download": {
            "type": "integer",
            "enum": [0, 1],
            "default": 0
          },
          "foreground_color": {
            "type": "string"
          },
          "background_color": {
            "type": "string"
          }
        },
        "required": ["qr_code_text"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message."
          }
        }
      }
    },
    "securitySchemes": {
      "accessToken": {
        "type": "apiKey",
        "in": "query",
        "name": "access-token",
        "description": "API access token retrieved from your account settings."
      }
    }
  },
  "security": [
    {
      "accessToken": []
    }
  ]
}