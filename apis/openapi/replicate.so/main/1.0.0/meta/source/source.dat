{
  "openapi": "3.0.3",
  "info": {
    "title": "Integration API",
    "description": "API for managing integrations and webhooks",
    "version": "1.0.0",
    "contact": {
      "email": "thekawsarhossain@gmail.com"
    },
    "x-jentic-source-url": "https://app.swaggerhub.com/apis-docs/KAWSARHOSSAIN20108_1/Integration/1.0.0"
  },
  "servers": [
    {
      "url": "https://api.replicate.so/v1"
    }
  ],
  "tags": [
    {
      "name": "integrations",
      "description": "Integration management"
    },
    {
      "name": "webhooks",
      "description": "Webhook management"
    },
    {
      "name": "feedback",
      "description": "Feedback retrieval"
    }
  ],
  "paths": {
    "/integration/{channelId}": {
      "get": {
        "summary": "Get integration by channel ID",
        "tags": [
          "integrations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "channelId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Integration"
                }
              }
            }
          },
          "404": {
            "description": "Integration not found"
          }
        }
      }
    },
    "/integration/{channelId}/generate-api-key": {
      "post": {
        "summary": "Generate API key for a channel",
        "tags": [
          "integrations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "channelId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateApiKeyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "API key generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "apiKey": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Unauthorized access"
          },
          "404": {
            "description": "Channel not found"
          }
        }
      }
    },
    "/integration/validate-api-key": {
      "post": {
        "summary": "Validate API key",
        "tags": [
          "integrations"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "x-api-key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "API key is valid",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Integration"
                }
              }
            }
          },
          "401": {
            "description": "API key is missing"
          },
          "403": {
            "description": "Invalid API key"
          }
        }
      }
    },
    "/integration/{channelId}/toggle": {
      "post": {
        "summary": "Toggle integration status",
        "tags": [
          "integrations"
        ],
        "parameters": [
          {
            "in": "path",
            "name": "channelId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ToggleIntegrationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Integration toggled successfully"
          },
          "403": {
            "description": "Unauthorized access"
          },
          "404": {
            "description": "Integration or channel not found"
          }
        }
      }
    },
    "/integration/webhook": {
      "post": {
        "summary": "Add webhook",
        "tags": [
          "webhooks"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "x-api-key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook added successfully"
          },
          "401": {
            "description": "API key is missing"
          },
          "404": {
            "description": "Integration not found"
          }
        }
      },
      "delete": {
        "summary": "Remove webhook",
        "tags": [
          "webhooks"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "x-api-key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook removed successfully"
          },
          "401": {
            "description": "API key is missing"
          },
          "404": {
            "description": "Integration not found"
          }
        }
      }
    },
    "/integration/feedback": {
      "get": {
        "summary": "Get feedbacks by API key",
        "tags": [
          "feedback"
        ],
        "parameters": [
          {
            "in": "header",
            "name": "x-api-key",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Feedback"
                  }
                }
              }
            }
          },
          "401": {
            "description": "API key is missing"
          },
          "403": {
            "description": "Invalid API key"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Integration": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string"
          },
          "channelId": {
            "type": "string"
          },
          "platforms": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/PlatformConfig"
            }
          }
        }
      },
      "PlatformConfig": {
        "type": "object",
        "properties": {
          "isEnabled": {
            "type": "boolean"
          },
          "webhooks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "GenerateApiKeyRequest": {
        "type": "object",
        "required": [
          "platform"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "enum": [
              "zapier",
              "pabbly"
            ]
          }
        }
      },
      "ToggleIntegrationRequest": {
        "type": "object",
        "required": [
          "platform"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "enum": [
              "zapier",
              "pabbly"
            ]
          }
        }
      },
      "WebhookRequest": {
        "type": "object",
        "required": [
          "platform",
          "webhookUrl"
        ],
        "properties": {
          "platform": {
            "type": "string",
            "enum": [
              "zapier",
              "pabbly"
            ]
          },
          "webhookUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Feedback": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "channelId": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}