                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid style name or parameters."
          },
          "429": {
            "description": "Too Many Requests. Rate limit exceeded (10 requests/second for WebP)."
          }
        }
      }
