    "/{styleName}/json": {
      "get": {
        "operationId": "getAvatarJson",
        "summary": "Get avatar metadata as JSON",
        "description": "Returns avatar metadata as JSON without generating an image.",
        "tags": ["Avatars"],
        "parameters": [
          {
            "name": "styleName",
            "in": "path",
            "required": true,
            "description": "The avatar style name in camelCase.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "seed",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flip",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "rotate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "scale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "backgroundColor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Avatar metadata returned as JSON.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AvatarMetadata"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid style name or parameters."
          },
          "429": {
            "description": "Too Many Requests. Rate limit exceeded."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AvatarMetadata": {
        "type": "object",
        "description": "Metadata about the generated avatar.",
        "properties": {
          "seed": {
            "type": "string",
            "description": "The seed used to generate the avatar."
          },
          "style": {
            "type": "string",
            "description": "The style name used."
          },
          "options": {
            "type": "object",
            "description": "The options applied to generate the avatar.",
            "additionalProperties": true
          }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}
