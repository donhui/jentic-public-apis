            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flip",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "rotate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "scale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "backgroundColor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JPG avatar image returned successfully.",
            "content": {
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid style name or parameters."
          },
          "429": {
            "description": "Too Many Requests. Rate limit exceeded (10 requests/second for JPG)."
          }
        }
      }
    },
    "/{styleName}/webp": {
      "get": {
        "operationId": "getAvatarWebp",
        "summary": "Generate an avatar in WebP format",
