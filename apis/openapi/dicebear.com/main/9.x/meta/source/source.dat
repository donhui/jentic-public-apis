{
  "openapi": "3.0.3",
  "info": {
    "title": "DiceBear Avatars HTTP API",
    "version": "9.x",
    "description": "Free avatar and profile picture API by DiceBear. Generate random user avatars and placeholder images via a simple URL with no authentication required. Supports SVG, PNG, JPG, WebP, AVIF, and JSON output formats with customizable styles and options.",
    "x-jentic-source-url": "https://www.dicebear.com/how-to-use/http-api/"
  },
  "servers": [
    {
      "url": "https://api.dicebear.com/9.x"
    }
  ],
  "paths": {
    "/{styleName}/svg": {
      "get": {
        "operationId": "getAvatarSvg",
        "summary": "Generate an avatar in SVG format",
        "description": "Returns an SVG avatar image for the specified style. SVG is the recommended format as it scales indefinitely with no size limit and has a higher rate limit.",
        "tags": ["Avatars"],
        "parameters": [
          {
            "name": "styleName",
            "in": "path",
            "required": true,
            "description": "The avatar style name in camelCase (e.g., pixel-art, lorelei, bottts, adventurer, etc.)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "seed",
            "in": "query",
            "required": false,
            "description": "Seed value to generate a deterministic avatar. Using the same seed always produces the same avatar.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flip",
            "in": "query",
            "required": false,
            "description": "Whether to flip the avatar horizontally.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "rotate",
            "in": "query",
            "required": false,
            "description": "Rotation angle of the avatar in degrees.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "scale",
            "in": "query",
            "required": false,
            "description": "Scale factor for the avatar.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "required": false,
            "description": "Border radius for the avatar.",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "backgroundColor",
            "in": "query",
            "required": false,
            "description": "Background color for the avatar (hex without #).",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "hair",
            "in": "query",
            "required": false,
            "description": "Comma-separated list of hair styles (style-specific option).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SVG avatar image returned successfully.",
            "content": {
              "image/svg+xml": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid style name or parameters."
          },
          "429": {
            "description": "Too Many Requests. Rate limit exceeded (50 requests/second for SVG)."
          }
        }
      }
    },
    "/{styleName}/png": {
      "get": {
        "operationId": "getAvatarPng",
        "summary": "Generate an avatar in PNG format",
        "description": "Returns a PNG avatar image for the specified style. Maximum size is 256x256 pixels. Lower rate limit than SVG.",
        "tags": ["Avatars"],
        "parameters": [
          {
            "name": "styleName",
            "in": "path",
            "required": true,
            "description": "The avatar style name in camelCase.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "seed",
            "in": "query",
            "required": false,
            "description": "Seed value to generate a deterministic avatar.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flip",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "rotate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "scale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "backgroundColor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PNG avatar image returned successfully.",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "400": {
            "description": "Bad request. Invalid style name or parameters."
          },
          "429": {
            "description": "Too Many Requests. Rate limit exceeded (10 requests/second for PNG)."
          }
        }
      }
    },
    "/{styleName}/jpg": {
      "get": {
        "operationId": "getAvatarJpg",
        "summary": "Generate an avatar in JPG format",
