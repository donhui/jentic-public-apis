  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Authentication token obtained from the Login endpoint"
      }
    },
    "schemas": {
      "AuthToken": {
        "type": "object",
        "properties": {
          "Token": {
            "type": "string"
          },
          "Expiration": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "ContactKey": {
            "type": "string"
          },
          "FirstName": {
            "type": "string"
          },
          "LastName": {
            "type": "string"
          },
          "Email": {
            "type": "string"
          },
          "CompanyName": {
            "type": "string"
          },
          "CompanyTitle": {
            "type": "string"
          }
        }
      },
      "DiscussionPostInput": {
        "type": "object",
        "properties": {
          "DiscussionKey": {
            "type": "string"
          },
          "Subject": {
            "type": "string"
          },
          "Body": {
            "type": "string"
          }
        }
      },
      "DiscussionReplyInput": {
        "type": "object",
        "properties": {
          "DiscussionPostKey": {
            "type": "string"
          },
          "Body": {
            "type": "string"
          }
        }
      },
      "MessageInput": {
        "type": "object",
        "properties": {
          "ContactKey": {
            "type": "string"
          },
          "Subject": {
            "type": "string"
          },
          "Body": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
