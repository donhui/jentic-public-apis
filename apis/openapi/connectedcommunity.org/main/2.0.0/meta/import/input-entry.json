{
  "openapi": "3.0.3",
  "info": {
    "title": "Higher Logic API",
    "version": "2.0.0",
    "description": "Higher Logic Community API providing programmatic access to Community data including announcements, discussions, contacts, blogs, events, messaging, communities, resource libraries, and more.",
    "x-jentic-source-url": "https://api.connectedcommunity.org/"
  },
  "servers": [
    {
      "url": "https://api.connectedcommunity.org",
