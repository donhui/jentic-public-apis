{
  "openapi": "3.0.3",
  "info": {
    "title": "Agiled API",
    "version": "1.0.0",
    "description": "Agiled is an all-in-one business management platform. This API provides access to invoices, contacts, deals, events, CRM and more.",
    "x-jentic-source-url": "https://api.agiled.app/docs"
  },
  "servers": [
    {
      "url": "https://api.agiled.app",
      "description": "Agiled Production API"
    }
  ],
  "security": [
    {
      "apiTokenQuery": []
    }
  ],
  "tags": [
    { "name": "Search", "description": "Search account data" },
    { "name": "Invoices", "description": "Invoice management" },
    { "name": "EventTypes", "description": "Event type management" },
    { "name": "Events", "description": "Event management" },
    { "name": "Accounts", "description": "CRM account management" },
    { "name": "Contacts", "description": "CRM contact management" },
    { "name": "Deals", "description": "CRM deal management" },
    { "name": "Meetings", "description": "CRM meeting management" },
    { "name": "Notes", "description": "CRM note management" },
    { "name": "Files", "description": "CRM file management" },
    { "name": "Activities", "description": "Activity management" },
    { "name": "Pipeline", "description": "Pipeline stage management" }
  ],
  "paths": {
    "/search": {
      "post": {
        "operationId": "searchAccountData",
        "tags": ["Search"],
        "summary": "Search account data",
        "description": "Search account data using a search key.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search results returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/invoices": {
      "get": {
        "operationId": "listInvoices",
        "tags": ["Invoices"],
        "summary": "List all invoices",
        "responses": {
          "200": {
            "description": "List of invoices",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Invoice" }
                    }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createInvoice",
        "tags": ["Invoices"],
        "summary": "Create a new invoice",
