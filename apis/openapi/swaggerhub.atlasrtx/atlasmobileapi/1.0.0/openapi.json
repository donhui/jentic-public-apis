  "definitions": {
    "UserLogin": {
      "type": "object",
      "required": [
        "username",
        "password"
      ],
      "properties": {
        "username": {
          "type": "string",
          "example": "user@domain.com"
        },
        "password": {
          "type": "string",
          "example": "secretpassword"
        },
        "devicetoken": {
          "type": "string",
          "description": "Device token used for push notifications"
        },
        "deviceid": {
          "type": "string",
          "description": "Unique Device ID"
        },
        "devicetype": {
          "type": "string",
          "example": "ios or android"
        }
      }
    },
    "User": {
      "type": "object",
      "required": [
        "userid",
        "nickname",
        "languagetypeid",
        "password"
      ],
      "properties": {
        "userid": {
          "type": "integer",
          "format": "int64"
        },
        "firstname": {
          "type": "string",
          "readOnly": true
        },
        "lastname": {
          "type": "string",
          "readOnly": true
        },
        "nickname": {
          "type": "string"
        },
        "usertypeid": {
          "type": "integer",
          "format": "int64",
          "readOnly": true
        },
        "languagetypeid": {
          "type": "integer",
          "format": "int64"
        },
        "locationid": {
          "type": "integer",
          "format": "int64",
          "readOnly": true
        },
        "password": {
          "type": "string"
        },
        "authtoken": {
          "type": "string",
          "readOnly": true
        }
      }
    },
    "HomeScreenData": {
      "type": "object",
      "required": [
        "notification_count",
        "engagement_count"
      ],
      "properties": {
        "notification_count": {
          "type": "integer",
          "format": "int64"
        },
        "engagement_count": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "Notification": {
      "type": "object",
      "required": [
        "notificationid",
        "userid",
        "title",
        "timestamp",
        "message",
        "isread"
      ],
      "properties": {
        "notificationid": {
          "type": "integer",
          "format": "int64"
        },
        "userid": {
          "type": "integer",
          "format": "int64"
        },
        "title": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "example": "yyyy-mm-dd hh:mm:ss"
        },
        "message": {
          "type": "string"
        },
        "isread": {
          "type": "boolean"
        }
      }
    },
    "Engagement": {
      "type": "object",
      "required": [
        "engagementid",
        "locationid",
        "locationname",
        "customerid",
        "customername",
        "customerphone",
        "programid",
        "programname",
        "statusid",
        "status",
        "userid",
        "engagementdate",
        "isread"
      ],
      "properties": {
        "engagementid": {
          "type": "integer",
          "format": "int64"
        },
        "locationid": {
          "type": "integer",
          "format": "int64"
        },
        "locationname": {
          "type": "string"
        },
        "customerid": {
          "type": "integer",
          "format": "int64"
        },
        "customername": {
          "type": "string"
        },
        "customerphone": {
          "type": "string"
        },
        "programid": {
          "type": "integer",
          "format": "int64"
        },
        "programname": {
          "type": "string"
        },
        "statusid": {
          "type": "integer",
          "format": "int64"
        },
