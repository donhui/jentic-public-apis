                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Engagement"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/getEngagementMessages": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "get messages for an engagement",
                "operationId": "getEngagementMessages",
                "description": "Get a list of messages for the passed in engagementID\n",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "userid": {
                                        "type": "string"
                                    },
                                    "engagementid": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "description": "userid and engagementid from which to get data",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Message"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/newEngagement": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "create a new engagement",
                "operationId": "newEngagement",
                "description": "Create a new engagement with the given data\n",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/NewEngagement"
                            }
                        }
                    },
                    "description": "new engagement data",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Engagement"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/markEngagementHandled": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "Mark the messages of an engagement as \"Handled\"",
                "operationId": "markEngagmentHandled",
                "description": "Update an engagments messages as handled\n",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "userid": {
                                        "type": "string"
                                    },
                                    "engagementid": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "description": "userID and engagementID",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/getLocations": {
            "get": {
                "tags": [
                    "m"
                ],
                "summary": "get locations for a user",
                "operationId": "getLocations",
                "description": "Get a list of locations for the passed in userid\n",
                "parameters": [
                    {
                        "name": "userid",
                        "in": "query",
                        "description": "The userid for whom to get data",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Location"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/getPrograms": {
            "get": {
                "tags": [
                    "m"
                ],
                "summary": "get programs for a user",
                "operationId": "getPrograms",
                "description": "Get a list of programs for the passed in userid\n",
                "parameters": [
                    {
                        "name": "userid",
                        "in": "query",
                        "description": "The userid for whom to get data",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Program"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/getAppData": {
            "get": {
                "tags": [
                    "m"
                ],
                "summary": "get domain table data for a given user",
                "operationId": "getAppData",
                "description": "Get a necessary domain table data for a given user\n",
                "parameters": [
                    {
                        "name": "userid",
                        "in": "query",
                        "description": "The userid for whom to get data",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "type": "object",
                                            "properties": {
                                                "locations": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/Location"
                                                    }
                                                },
                                                "programs": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/Program"
                                                    }
                                                },
                                                "languagetypes": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/LanguageType"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/sendMessage": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "send a new message",
                "operationId": "sendMessage",
                "description": "Send a new message to the specified customer's engagement\n",
                "requestBody": {
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "userid": {
                                        "description": "userid",
                                        "type": "string"
                                    },
                                    "engagementid": {
                                        "description": "engagementid",
                                        "type": "string"
                                    },
                                    "messagetext": {
                                        "description": "messagetext",
                                        "type": "string"
                                    },
                                    "filedata": {
                                        "description": "file to upload",
                                        "type": "string"
                                    },
                                    "filemimetype": {
                                        "description": "mime type of file (jpg, png, mp4)",
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "userid",
                                    "engagementid",
                                    "messagetext"
                                ]
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "$ref": "#/components/schemas/Message"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/getCustomer": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "get customer",
                "operationId": "getCustomer",
                "description": "Get a customer based on the passed in customerid\n",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "userid": {
                                        "type": "integer",
                                        "format": "int64"
                                    },
                                    "customerid": {
                                        "type": "integer",
                                        "format": "int64"
                                    }
                                }
                            }
                        }
                    },
                    "description": "userid and customerid for whom to get data",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Customer"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/updateCustomer": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "updates a customer",
                "operationId": "updateCustomer",
                "description": "You can update a customer's info\n",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Customer"
                            }
                        }
                    },
                    "description": "customer object",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/updateUserToken": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "updates a user token",
                "operationId": "updateUserToken",
                "description": "You can update a user token\n",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "userid": {
                                        "type": "string"
                                    },
                                    "token": {
                                        "type": "string"
                                    },
                                    "devicetype": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    },
                    "description": "customer object",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        }
    },
    "servers": [
        {
            "url": "https://test.atlasrtx.com/api/m"
        }
    ],
    "components": {
        "requestBodies": {
            "UserID": {
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/UserID"
                        }
                    }
                },
                "description": "userid for whom to get data",
                "required": true
            }
        },
        "securitySchemes": {
            "BasicAuth": {
                "type": "http",
                "scheme": "basic"
            }
        },
        "schemas": {
            "UserLogin": {
                "type": "object",
                "required": [
                    "username",
                    "password"
                ],
                "properties": {
                    "username": {
                        "type": "string",
                        "example": "user@domain.com"
                    },
                    "password": {
                        "type": "string",
                        "example": "secretpassword"
                    },
                    "devicetoken": {
                        "type": "string",
                        "description": "Device token used for push notifications"
                    },
                    "deviceid": {
                        "type": "string",
                        "description": "Unique Device ID"
                    },
                    "devicetype": {
                        "type": "string",
                        "example": "ios or android"
                    }
                }
            },
            "User": {
                "type": "object",
                "required": [
                    "userid",
                    "nickname",
                    "languagetypeid",
                    "password"
                ],
                "properties": {
                    "userid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "firstname": {
                        "type": "string",
                        "readOnly": true
                    },
                    "lastname": {
                        "type": "string",
                        "readOnly": true
                    },
                    "nickname": {
                        "type": "string"
                    },
                    "usertypeid": {
                        "type": "integer",
                        "format": "int64",
                        "readOnly": true
                    },
                    "languagetypeid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "locationid": {
                        "type": "integer",
                        "format": "int64",
                        "readOnly": true
                    },
                    "password": {
                        "type": "string"
                    },
                    "authtoken": {
                        "type": "string",
                        "readOnly": true
                    }
                }
            },
            "HomeScreenData": {
                "type": "object",
                "required": [
                    "notification_count",
                    "engagement_count"
                ],
                "properties": {
                    "notification_count": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "engagement_count": {
                        "type": "integer",
                        "format": "int64"
                    }
                }
            },
            "Notification": {
                "type": "object",
                "required": [
                    "notificationid",
                    "userid",
                    "title",
                    "timestamp",
                    "message",
                    "isread"
                ],
                "properties": {
                    "notificationid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "userid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "title": {
                        "type": "string"
                    },
                    "timestamp": {
                        "type": "string",
                        "format": "date-time",
                        "example": "yyyy-mm-dd hh:mm:ss"
                    },
                    "message": {
                        "type": "string"
                    },
                    "isread": {
                        "type": "boolean"
                    }
                }
            },
            "Engagement": {
                "type": "object",
                "required": [
                    "engagementid",
                    "locationid",
                    "locationname",
                    "customerid",
                    "customername",
                    "customerphone",
                    "programid",
                    "programname",
                    "statusid",
                    "status",
                    "userid",
                    "engagementdate",
                    "isread"
                ],
                "properties": {
                    "engagementid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "locationid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "locationname": {
                        "type": "string"
                    },
                    "customerid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "customername": {
                        "type": "string"
                    },
                    "customerphone": {
                        "type": "string"
                    },
                    "programid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "programname": {
                        "type": "string"
                    },
                    "statusid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "score": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "status": {
                        "type": "string"
                    },
                    "userid": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "engagementdate": {
                        "type": "string",
                        "format": "date-time",
                        "example": "yyyy-mm-dd hh:mm:ss"
                    },
                    "targetdate": {
                        "type": "string",
                        "format": "date-time",
                        "example": "yyyy-mm-dd hh:mm:ss"
                    },
                    "latestmessage": {
                        "type": "string"
                    },
                    "messages": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Message"
                        }
                    },
                    "isread": {
                        "type": "boolean"
                    },
                    "custom1value": {
                        "type": "string"
                    },
                    "custom2value": {
                        "type": "string"
                    },
                    "custom3value": {
                        "type": "string"
                    },
                    "custom4value": {
                        "type": "string"
                    },
                    "custom5value": {
                        "type": "string"
                    },
