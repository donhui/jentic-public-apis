{
    "openapi": "3.0.0",
    "info": {
        "description": "This is the AtlasRTX Mobile App API",
        "version": "1.0.0",
        "title": "AtlasRTX Mobile API",
        "contact": {
            "email": "atlas@atlasrtx.com"
        },
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/AtlasRTX/AtlasMobileAPI/1.0.0/swagger.json"
    },
    "tags": [
        {
            "name": "m",
            "description": "Operations available to authenticated users"
        }
    ],
    "paths": {
        "/login": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "logs in a user",
                "operationId": "login",
                "description": "By passing in an appropriate username and password, you can authenticate with the AtlasRTX platform\n",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserLogin"
                            }
                        }
                    },
                    "description": "username and password of the user",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "$ref": "#/components/schemas/User"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/updateUser": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "updates a user",
                "operationId": "updateUser",
                "description": "You can update a user's nickname, password and default language\n",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/User"
                            }
                        }
                    },
                    "description": "user object",
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/getHomeScreenData": {
            "get": {
                "tags": [
                    "m"
                ],
                "summary": "gets data for the home screen",
                "operationId": "getHomeScreenData",
                "description": "Get the information necessary for the home screen\n",
                "parameters": [
                    {
                        "name": "userid",
                        "in": "query",
                        "description": "The userid for whom to get data",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": {
                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "$ref": "#/components/schemas/HomeScreenData"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/getNotifications": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "get notifications for a user",
                "operationId": "getNotifications",
                "description": "Get a list of notifications for the passed in userid\n",
                "requestBody": {
                    "$ref": "#/components/requestBodies/UserID"
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
