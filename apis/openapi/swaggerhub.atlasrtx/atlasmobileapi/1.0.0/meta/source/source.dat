                                            "type": "boolean"
                                        },
                                        "message": {
                                            "type": "string"
                                        },
                                        "response": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Notification"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "BasicAuth": []
                    }
                ]
            }
        },
        "/getEngagements": {
            "post": {
                "tags": [
                    "m"
                ],
                "summary": "get engagements for a user",
                "operationId": "getEngagements",
                "description": "Get a list of engagements for the passed in userid\n",
                "requestBody": {
                    "$ref": "#/components/requestBodies/UserID"
                },
                "responses": {
                    "200": {
                        "description": "successful operation",
