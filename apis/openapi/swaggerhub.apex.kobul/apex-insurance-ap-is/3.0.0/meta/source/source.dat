                      ],
                      "properties": {
                        "birthday": {
                          "type": "string",
                          "format": "dd.mm.yyyy",
                          "description": "Birthdate of the person (dd.mm.yyyy format)."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
