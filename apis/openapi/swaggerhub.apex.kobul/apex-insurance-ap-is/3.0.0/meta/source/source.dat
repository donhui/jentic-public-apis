    "/calculator_passenger": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "passenger"
        ],
        "summary": "Passenger Insurance Cost Calculator",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "risk_info",
                  "air_info",
                  "person_info"
                ],
                "properties": {
                  "risk_info": {
                    "type": "object",
                    "description": "Information about risks",
                    "properties": {
                      "risk_1": {
                        "type": "integer",
                        "description": "Risk value for ACCIDENT - 1 to include, 0 to exclude."
                      },
                      "risk_2": {
                        "type": "integer",
                        "description": "Risk value for TRIP CANCELLATION - 1 to include, 0 to exclude. Note that if the Trip Cancellation risk was included in the insurance policy, this policy cannot be canceled."
                      },
                      "risk_3": {
                        "type": "integer",
                        "description": "Risk value PASSENGER BAGGAGE - 1 to include, 0 to exclude."
                      },
                      "risk_4": {
                        "type": "integer",
                        "description": "Risk value for FLIGHT DELAY OR CANCELLATION - 1 to include, 0 to exclude."
                      },
                      "risk_5": {
                        "type": "integer",
                        "description": "Risk value for LOSS/THEFT OF DOCUMENTS - 1 to include, 0 to exclude."
                      },
                      "risk_6": {
                        "type": "integer",
                        "description": "Risk value for PROPERTY INSURANCE - 1 to include, 0 to exclude."
                      }
                    }
                  },
                  "air_info": {
                    "type": "array",
                    "description": "Information about flights",
                    "items": {
                      "type": "object",
                      "properties": {
                        "dep_date": {
                          "type": "string",
                          "format": "dd.mm.yyyy",
                          "description": "Departure date of the flight (dd.mm.yyyy format)."
                        },
                        "arr_date": {
                          "type": "string",
                          "format": "dd.mm.yyyy",
                          "description": "Arrival date of the flight (dd.mm.yyyy format)."
                        }
                      }
                    }
                  },
                  "person_info": {
                    "type": "array",
                    "description": "Information about additional persons covered by the insurance.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "birthday": {
                          "type": "string",
                          "format": "dd.mm.yyyy",
                          "description": "Birthdate of the person (dd.mm.yyyy format)."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u0423\u0441\u043f\u0435\u0448\u043d\u044b\u0439 \u043e\u0442\u0432\u0435\u0442",
            "content": {
              "application/json": {
                "example": {
                  "result": 0,
                  "result_message": "\u0423\u0441\u043f\u0435\u0448\u043d\u0430\u044f \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u0437\u0430\u043f\u0440\u043e\u0441\u0430",
                  "days": 40,
                  "count_persons": 10,
                  "liability_EUR": "200 500,00",
                  "stoimost_UZS": "2 429 000,00",
                  "stoimost_USD": "192,50"
                }
              }
            }
          },
          "401": {
            "description": "\u041d\u0435 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u043e\u0432\u0430\u043d"
          }
        }
      }
