        ],
        "summary": "Travel Insurance Cost Calculator",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "travel_info",
                  "person_info"
                ],
                "properties": {
                  "travel_info": {
                    "type": "object",
                    "description": "Travel information.",
                    "required": [
                      "start_date",
                      "end_date",
                      "country",
                      "program_id",
                      "purpose_id",
                      "group_id"
                    ],
                    "properties": {
                      "start_date": {
                        "type": "string",
                        "format": "dd.mm.yyyy",
                        "description": "Travel start date (dd.mm.yyyy format)."
                      },
                      "end_date": {
                        "type": "string",
                        "format": "dd.mm.yyyy",
                        "description": "Travel end date (dd.mm.yyyy format)."
                      },
                      "country": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": [
                            "iso"
                          ],
                          "properties": {
                            "iso": {
                              "type": "string",
                              "description": "ISO code of country."
                            }
                          }
                        }
                      },
                      "program_id": {
                        "type": "integer",
                        "description": "Program ID associated with the insurance from 1 to 5."
                      },
                      "purpose_id": {
                        "type": "integer",
                        "description": "Purpose of travel."
                      },
                      "group_id": {
                        "type": "integer",
                        "description": "Group ID for group insurance (0 if individual)."
                      }
                    }
                  },
                  "person_info": {
                    "type": "array",
                    "description": "Information about additional persons covered by the insurance.",
                    "items": {
                      "type": "object",
                      "required": [
