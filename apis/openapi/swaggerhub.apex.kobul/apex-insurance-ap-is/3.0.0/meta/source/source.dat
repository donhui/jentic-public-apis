    "/contract_passenger": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "passenger"
        ],
        "summary": "Create a new insurance policy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "transaction_info",
                  "insurance_info",
                  "risk_info",
                  "air_info",
                  "person_info"
                ],
                "properties": {
                  "transaction_info": {
                    "type": "object",
                    "required": [
                      "tr_id",
                      "user_id"
                    ],
                    "description": "Information about the transaction",
                    "properties": {
                      "tr_id": {
                        "type": "integer",
                        "description": "Transaction ID"
                      },
                      "user_id": {
                        "type": "integer",
                        "description": "User ID initiating the transaction"
                      }
                    }
                  },
                  "insurance_info": {
                    "type": "object",
                    "required": [
                      "resident_s",
                      "country_s",
                      "address_s",
                      "gender_s",
                      "surname_s",
                      "name_s",
                      "middle_s",
                      "birthday_s",
                      "passport_s"
                    ],
                    "description": "Information about the insured person",
                    "properties": {
                      "resident_s": {
                        "type": "integer",
                        "description": "Indicates if the person is a resident (1 for resident, 0 for non-resident)"
                      },
                      "country_s": {
                        "type": "string",
                        "description": "Country code of the insured person (ISO format)"
                      },
                      "region_s": {
                        "type": "integer",
                        "description": "Region code of the insured person's address (has get endpoint /region - required if resident_s=1)"
                      },
                      "district_s": {
                        "type": "integer",
                        "description": "District code of the insured person's address (has get endpoint /district - required if resident_s=1)"
                      },
                      "address_s": {
                        "type": "string",
                        "description": "Street address of the insured person"
                      },
                      "gender_s": {
                        "type": "integer",
                        "description": "Gender of the insured person (1 for male, 0 for female)"
                      },
                      "surname_s": {
                        "type": "string",
                        "description": "Surname of the insured person"
                      },
                      "name_s": {
                        "type": "string",
                        "description": "First name of the insured person"
                      },
                      "middle_s": {
                        "type": "string",
                        "description": "Middle name of the insured person"
                      },
                      "birthday_s": {
                        "type": "string",
                        "format": "dd.mm.yyyy",
                        "description": "Birthdate of the insured person (dd.mm.yyyy format)"
                      },
                      "phone_s": {
                        "type": "string",
                        "description": "Phone number of the insured person - required if resident_s=1"
                      },
                      "email_s": {
                        "type": "string",
                        "format": "email",
                        "description": "Email address of the insured person - required if resident_s=0"
                      },
                      "passport_s": {
                        "type": "object",
                        "required": [
                          "series_s",
                          "number_s"
                        ],
                        "description": "Passport information of the insured person",
                        "properties": {
                          "pinfl_s": {
                            "type": "string",
                            "description": "Personal Identification Number (PINFL) of the insured person - required if resident_s=1"
                          },
                          "series_s": {
                            "type": "string",
                            "description": "Passport series"
                          },
                          "number_s": {
                            "type": "string",
                            "description": "Passport number"
                          }
                        }
                      }
                    }
                  },
                  "risk_info": {
                    "type": "object",
                    "description": "Information about risks.",
                    "required": [
                      "risk_1",
                      "risk_2",
                      "risk_3",
                      "risk_4",
                      "risk_5",
                      "risk_6"
                    ],
                    "properties": {
                      "risk_1": {
                        "type": "integer",
                        "description": "Risk value for ACCIDENT - 1 to include, 0 to exclude."
                      },
                      "risk_2": {
                        "type": "integer",
                        "description": "Risk value for TRIP CANCELLATION - 1 to include, 0 to exclude. Note that if the Trip Cancellation risk was included in the insurance policy, this policy cannot be canceled."
                      },
                      "risk_3": {
                        "type": "integer",
                        "description": "Risk value PASSENGER BAGGAGE - 1 to include, 0 to exclude."
                      },
                      "risk_4": {
                        "type": "integer",
                        "description": "Risk value for FLIGHT DELAY OR CANCELLATION - 1 to include, 0 to exclude."
                      },
                      "risk_5": {
                        "type": "integer",
                        "description": "Risk value for LOSS/THEFT OF DOCUMENTS - 1 to include, 0 to exclude."
                      },
                      "risk_6": {
                        "type": "integer",
                        "description": "Risk value for PROPERTY INSURANCE - 1 to include, 0 to exclude."
                      }
                    }
                  },
                  "air_info": {
                    "type": "array",
                    "description": "Information about flights.",
                    "items": {
                      "type": "object",
                      "required": [
                        "air_number",
                        "air_departure",
                        "dep_date",
                        "dep_time",
                        "air_arrival",
                        "arr_date",
                        "arr_time"
                      ],
                      "properties": {
                        "air_number": {
                          "type": "string",
                          "description": "Flight number."
                        },
                        "air_departure": {
                          "type": "string",
                          "description": "Departure airport information."
                        },
                        "dep_date": {
                          "type": "string",
                          "format": "dd.mm.yyyy",
                          "description": "Departure date (format - dd.mm.yyyy)."
                        },
                        "dep_time": {
                          "type": "string",
                          "format": "HH:MM",
                          "description": "Departure time (format - HH24:MM60)."
                        },
                        "air_arrival": {
                          "type": "string",
                          "description": "Arrival airport information."
                        },
                        "arr_date": {
                          "type": "string",
                          "format": "dd.mm.yyyy",
                          "description": "Arrival date (format - dd.mm.yyyy)."
                        },
                        "arr_time": {
                          "type": "string",
                          "format": "HH:MM",
                          "description": "Arrival time (format - HH24:MM60)."
                        }
                      }
                    }
                  },
                  "person_info": {
