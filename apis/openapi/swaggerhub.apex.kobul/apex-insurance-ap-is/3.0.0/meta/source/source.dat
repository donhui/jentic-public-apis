  "paths": {
    "/contract": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "travel"
        ],
        "summary": "Create a new insurance policy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "transaction_info",
                  "insurance_info",
                  "travel_info",
                  "person_info"
                ],
                "properties": {
                  "transaction_info": {
                    "type": "object",
                    "required": [
                      "tr_id",
                      "user_id"
                    ],
                    "description": "Information about the transaction",
                    "properties": {
                      "tr_id": {
                        "type": "integer",
                        "description": "Transaction ID"
                      },
                      "user_id": {
                        "type": "integer",
                        "description": "User ID initiating the transaction"
                      }
                    }
                  },
                  "insurance_info": {
                    "type": "object",
                    "required": [
                      "resident_s",
                      "country_s",
                      "address_s",
                      "gender_s",
                      "surname_s",
                      "name_s",
                      "middle_s",
                      "birthday_s",
                      "passport_s"
                    ],
                    "description": "Information about the insured person",
                    "properties": {
                      "resident_s": {
                        "type": "integer",
                        "description": "Indicates if the person is a resident (1 for resident, 0 for non-resident)"
                      },
                      "country_s": {
                        "type": "string",
                        "description": "Country code of the insured person (ISO format)"
                      },
                      "region_s": {
                        "type": "integer",
                        "description": "Region code of the insured person's address (has get endpoint /region - required if resident_s=1)"
                      },
                      "district_s": {
                        "type": "integer",
                        "description": "District code of the insured person's address (has get endpoint /district - required if resident_s=1)"
                      },
                      "address_s": {
                        "type": "string",
                        "description": "Street address of the insured person"
                      },
                      "gender_s": {
                        "type": "integer",
                        "description": "Gender of the insured person (1 for male, 0 for female)"
                      },
                      "surname_s": {
                        "type": "string",
                        "description": "Surname of the insured person"
                      },
                      "name_s": {
                        "type": "string",
                        "description": "First name of the insured person"
                      },
                      "middle_s": {
                        "type": "string",
                        "description": "Middle name of the insured person"
                      },
                      "birthday_s": {
                        "type": "string",
                        "format": "dd.mm.yyyy",
                        "description": "Birthdate of the insured person (dd.mm.yyyy format)"
                      },
                      "phone_s": {
                        "type": "string",
                        "description": "Phone number of the insured person - required if resident_s=1"
                      },
                      "email_s": {
                        "type": "string",
                        "format": "email",
                        "description": "Email address of the insured person - required if resident_s=0"
                      },
                      "passport_s": {
                        "type": "object",
                        "required": [
                          "series_s",
                          "number_s"
                        ],
                        "description": "Passport information of the insured person",
                        "properties": {
                          "pinfl_s": {
                            "type": "string",
                            "description": "Personal Identification Number (PINFL) of the insured person - required if resident_s=1"
                          },
                          "series_s": {
                            "type": "string",
                            "description": "Passport series"
                          },
                          "number_s": {
                            "type": "string",
                            "description": "Passport number"
                          }
                        }
                      }
                    }
                  },
                  "travel_info": {
                    "type": "object",
                    "required": [
                      "start_date",
                      "end_date",
                      "country",
                      "program_id",
                      "purpose_id",
                      "group_id"
                    ],
                    "description": "Information about the travel details",
                    "properties": {
                      "start_date": {
                        "type": "string",
                        "format": "dd.mm.yyyy",
                        "description": "Travel start date (dd.mm.yyyy format)"
                      },
                      "end_date": {
                        "type": "string",
                        "format": "dd.mm.yyyy",
                        "description": "Travel end date (dd.mm.yyyy format)"
                      },
                      "country": {
                        "type": "array",
                        "description": "List of countries the person will visit",
                        "items": {
                          "type": "object",
                          "required": [
                            "iso"
                          ],
                          "properties": {
                            "iso": {
                              "type": "string",
                              "description": "Country code (ISO format)"
                            }
                          }
                        }
                      },
                      "program_id": {
                        "type": "integer",
                        "description": "Program ID associated with the insurance from 1 to 5."
                      },
                      "purpose_id": {
                        "type": "integer",
                        "description": "Purpose of travel"
                      },
                      "group_id": {
                        "type": "integer",
                        "description": "Group ID for group insurance (0 if individual)"
                      }
                    }
                  },
                  "person_info": {
                    "type": "array",
                    "description": "Information about additional persons covered by the insurance",
                    "items": {
                      "type": "object",
                      "required": [
                        "resident_p",
                        "country_p",
                        "address_p",
                        "gender_p",
                        "surname_p",
                        "name_p",
                        "middle_p",
                        "birthday_p",
                        "passport_p"
                      ],
                      "properties": {
                        "resident_p": {
                          "type": "integer",
                          "description": "Indicates if the person is a resident (1 for resident, 0 for non-resident, 6 for child of resident)"
                        },
                        "country_p": {
                          "type": "string",
                          "description": "Country code of the person (ISO format)"
                        },
                        "region_p": {
                          "type": "integer",
                          "description": "Region code of the person's address (has get endpoint /region - required if resident_p=1 and resident_p=6)"
                        },
                        "district_p": {
                          "type": "integer",
                          "description": "District code of the person's address (has get endpoint /district - required if resident_p=1 and resident_p=6)"
                        },
                        "address_p": {
                          "type": "string",
                          "description": "Street address of the person"
                        },
                        "gender_p": {
                          "type": "integer",
                          "description": "Gender of the person (1 for male, 0 for female)"
                        },
                        "surname_p": {
                          "type": "string",
                          "description": "Surname of the person"
                        },
                        "name_p": {
                          "type": "string",
                          "description": "First name of the person"
                        },
                        "middle_p": {
                          "type": "string",
                          "description": "Middle name of the person"
                        },
                        "birthday_p": {
                          "type": "string",
                          "format": "dd.mm.yyyy",
                          "description": "Birthdate of the person (dd.mm.yyyy format)"
                        },
                        "phone_p": {
                          "type": "string",
                          "description": "Phone number of the person - required if resident_p=1 and resident_p=6"
                        },
                        "email_p": {
                          "type": "string",
                          "format": "email",
                          "description": "Email address of the person - required if resident_p=0"
                        },
                        "passport_p": {
                          "type": "object",
                          "required": [
                            "series_p",
                            "number_p"
                          ],
                          "description": "Passport information of the person",
                          "properties": {
                            "pinfl_p": {
                              "type": "string",
                              "description": "Personal Identification Number (PINFL) of the person - required if resident_p=1"
                            },
                            "series_p": {
                              "type": "string",
                              "description": "Passport series"
                            },
                            "number_p": {
                              "type": "string",
                              "description": "Passport number"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u0423\u0441\u043f\u0435\u0448\u043d\u044b\u0439 \u043e\u0442\u0432\u0435\u0442",
            "content": {
              "application/json": {
                "example": {
                  "result": 0,
                  "result_message": "\u0423\u0441\u043f\u0435\u0448\u043d\u0430\u044f \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u0437\u0430\u043f\u0440\u043e\u0441\u0430",
                  "contract_id": 1403524,
                  "polis_sery": "EAPD",
                  "polis_number": 14,
                  "stoimost_uzs": 199000,
                  "polis_link": "https://docx.aic.uz/apex/ins/r/117/polis-bookhara?p850_anketa_id=1403524"
                }
              }
            }
          },
          "401": {
            "description": "\u041d\u0435 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u043e\u0432\u0430\u043d"
          }
        }
      }
    },
