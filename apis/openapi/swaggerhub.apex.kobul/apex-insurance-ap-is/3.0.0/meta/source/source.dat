          },
          "401": {
            "description": "\u041d\u0435 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u043e\u0432\u0430\u043d"
          }
        }
      }
    },
    "/get_passenger_risks": {
      "get": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "API information"
        ],
        "summary": "Getting a list of Passenger risks IDs with description",
        "responses": {
          "200": {
            "description": "\u0423\u0441\u043f\u0435\u0448\u043d\u044b\u0439 \u043e\u0442\u0432\u0435\u0442",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "description": "List of risk items with details",
                      "items": {
                        "type": "object",
                        "properties": {
                          "risk": {
                            "type": "integer",
                            "description": "Unique ID representing the type of risk",
                            "example": 1
                          },
                          "name_eng": {
                            "type": "string",
                            "description": "Risk name in English",
                            "example": "ACCIDENT"
                          },
                          "name_ru": {
                            "type": "string",
                            "description": "Risk name in Russian",
                            "example": "\u041d\u0415\u0421\u0427\u0410\u0421\u0422\u041d\u042b\u0419 \u0421\u041b\u0423\u0427\u0410\u0419"
                          },
                          "name_uz": {
                            "type": "string",
                            "description": "Risk name in Uzbek",
                            "example": "BAXTSIZ HODISA"
                          },
                          "liability": {
                            "type": "string",
                            "description": "Liability amount covered for the risk",
                            "example": "10 000,00"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "\u041d\u0435 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u043e\u0432\u0430\u043d"
          }
        }
      }
    },
    "/annulation": {
      "post": {
        "security": [
          {
            "basicAuth": []
          }
        ],
        "tags": [
          "API information"
        ],
        "summary": "Annulation of Insurance policy",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "contract_id",
                  "user_id",
                  "polis_sery",
                  "polis_number",
                  "reason"
                ],
                "properties": {
                  "contract_id": {
                    "type": "integer",
                    "description": "ID of contract."
                  },
                  "user_id": {
                    "type": "integer",
                    "description": "ID of user."
                  },
                  "polis_sery": {
                    "type": "string",
                    "description": "Insurance policy series."
                  },
                  "polis_number": {
                    "type": "integer",
                    "description": "Insurance policy number."
                  },
                  "reason": {
                    "type": "string",
                    "description": "Reason of annulation (will be sent to the Regulator)."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u0423\u0441\u043f\u0435\u0448\u043d\u044b\u0439 \u043e\u0442\u0432\u0435\u0442",
            "content": {
              "application/json": {
                "example": {
                  "result": 0,
                  "result_message": "\u0423\u0441\u043f\u0435\u0448\u043d\u0430\u044f \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u0437\u0430\u043f\u0440\u043e\u0441\u0430"
                }
              }
            }
          },
          "401": {
            "description": "\u041d\u0435 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u043e\u0432\u0430\u043d"
          }
        }
      }
    }
  }
}