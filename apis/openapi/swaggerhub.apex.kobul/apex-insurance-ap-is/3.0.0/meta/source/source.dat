                        },
                        "country_p": {
                          "type": "string",
                          "description": "Country code of the person (ISO format)"
                        },
                        "region_p": {
                          "type": "integer",
                          "description": "Region code of the person's address (has get endpoint /region - required if resident_p=1 and resident_p=6)"
                        },
                        "district_p": {
                          "type": "integer",
                          "description": "District code of the person's address (has get endpoint /district - required if resident_p=1 and resident_p=6)"
                        },
                        "address_p": {
                          "type": "string",
                          "description": "Street address of the person"
                        },
                        "gender_p": {
                          "type": "integer",
                          "description": "Gender of the person (1 for male, 0 for female)"
                        },
                        "surname_p": {
                          "type": "string",
                          "description": "Surname of the person"
                        },
                        "name_p": {
                          "type": "string",
                          "description": "First name of the person"
                        },
                        "middle_p": {
                          "type": "string",
                          "description": "Middle name of the person"
                        },
                        "birthday_p": {
                          "type": "string",
                          "format": "dd.mm.yyyy",
                          "description": "Birthdate of the person (dd.mm.yyyy format)"
                        },
                        "phone_p": {
                          "type": "string",
                          "description": "Phone number of the person - required if resident_p=1 and resident_p=6"
                        },
                        "email_p": {
                          "type": "string",
                          "format": "email",
                          "description": "Email address of the person - required if resident_p=0"
                        },
                        "passport_p": {
                          "type": "object",
                          "required": [
                            "series_p",
                            "number_p"
                          ],
                          "description": "Passport information of the person",
                          "properties": {
                            "pinfl_p": {
                              "type": "string",
                              "description": "Personal Identification Number (PINFL) of the person - required if resident_p=1"
                            },
                            "series_p": {
                              "type": "string",
                              "description": "Passport series"
                            },
                            "number_p": {
                              "type": "string",
                              "description": "Passport number"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "\u0423\u0441\u043f\u0435\u0448\u043d\u044b\u0439 \u043e\u0442\u0432\u0435\u0442",
