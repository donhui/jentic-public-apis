{
  "openapi": "3.0.3",
  "info": {
    "title": "MessengerX.io API",
    "description": "MessengerX.io provides APIs for building ML-powered chat applications. Send messages, manage user tags, and broadcast announcements through the Machaao platform.",
    "version": "1.0.0",
    "contact": {
      "name": "MessengerX.io",
      "url": "https://messengerx.io"
    },
    "x-jentic-source-url": "https://messengerx.rtfd.io"
  },
  "servers": [
    {
      "url": "https://ganglia.machaao.com",
      "description": "MessengerX.io Production API"
    }
  ],
  "security": [
    {
      "ApiTokenAuth": []
    }
  ],
  "tags": [
    {
      "name": "Messages",
      "description": "Send messages and announcements to users"
    },
    {
      "name": "Users",
      "description": "Manage user tags and attributes"
    }
  ],
  "paths": {
    "/v1/messages/send": {
      "post": {
        "tags": ["Messages"],
        "summary": "Send messages to users",
        "description": "Send a message to one or more users by their unique user IDs. Supports text messages, attachments, and quick replies.",
        "operationId": "sendMessage",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/v1/messages/announce": {
      "post": {
        "tags": ["Messages"],
        "summary": "Send announcements to tagged users",
        "description": "Broadcast an announcement to users matching specified tags.",
        "operationId": "sendAnnouncement",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnnouncementRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Announcement sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/v1/users/tag/{userId}": {
      "post": {
        "tags": ["Users"],
        "summary": "Tag a user",
        "description": "Add or update a tag on a specific user. Tags can be activated or deactivated.",
        "operationId": "tagUser",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the user",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TagUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tag applied successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    },
    "/v1/users/tags/{userId}": {
      "get": {
        "tags": ["Users"],
        "summary": "Get user tags",
        "description": "Retrieve all tags associated with a specific user.",
        "operationId": "getUserTags",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the user",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User tags retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserTagsResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiTokenAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "api_token",
        "description": "API token for authenticating requests. Also used as the key for HS512 JWT decryption of incoming webhooks."
      }
    },
    "schemas": {
      "SendMessageRequest": {
        "type": "object",
        "required": ["users", "message"],
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of unique user IDs to send the message to"
          },
          "message": {
            "$ref": "#/components/schemas/Message"
          }
        }
      },
      "AnnouncementRequest": {
        "type": "object",
        "required": ["tags", "message"],
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tag names to target users for the announcement"
          },
          "message": {
            "$ref": "#/components/schemas/Message"
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Text content of the message"
          },
          "attachment": {
            "type": "object",
            "description": "Media attachment (image, video, etc.)",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["image", "video", "audio", "file"],
                "description": "Type of attachment"
              },
              "payload": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "URL of the attachment"
                  }
                }
              }
            }
          },
          "quick_replies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "content_type": {
                  "type": "string",
                  "default": "text"
                },
                "title": {
                  "type": "string",
                  "description": "Display text for the quick reply button"
                },
                "payload": {
                  "type": "string",
                  "description": "Payload sent when the quick reply is tapped"
                }
              }
            },
            "description": "Quick reply buttons"
          }
        }
      },
      "TagUserRequest": {
        "type": "object",
        "required": ["tag", "status"],
        "properties": {
          "tag": {
            "type": "string",
            "description": "Tag name"
          },
          "status": {
            "type": "integer",
            "enum": [0, 1],
            "description": "1 to activate, 0 to deactivate the tag"
          },
          "values": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Values associated with the tag"
          },
          "displayName": {
            "type": "string",
            "description": "Human-readable display name for the tag"
          }
        }
      },
      "UserTagsResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "tag": {
                  "type": "string"
                },
                "status": {
                  "type": "integer"
                },
                "values": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "displayName": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "success"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "error"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid parameters or malformed request body",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Not found - the specified user does not exist",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  }
}
