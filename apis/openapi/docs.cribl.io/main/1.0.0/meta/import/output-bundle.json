{
  "openapi": "3.0.3",
  "info": {
    "title": "Cribl API",
    "version": "1.0.0",
    "description": "Cribl provides observability pipeline solutions for logs, metrics, and traces. The API enables configuration management, worker group operations, search jobs, and system settings across Cribl Stream and Cribl Edge deployments.",
    "x-jentic-source-url": "https://docs.cribl.io/cribl-as-code/api/"
  },
  "servers": [
    {
      "url": "https://{workspaceName}-{organizationId}.cribl.cloud/api/v1",
      "description": "Cribl Cloud/Hybrid - Global Context",
      "variables": {
        "workspaceName": {
          "default": "workspace",
          "description": "Your Cribl workspace name"
        },
        "organizationId": {
          "default": "org",
          "description": "Your organization ID"
        }
      }
    },
    {
      "url": "https://{hostname}:{port}/api/v1",
      "description": "On-Premises Deployment",
      "variables": {
        "hostname": {
          "default": "localhost",
          "description": "Cribl hostname"
        },
        "port": {
          "default": "9000",
          "description": "Cribl port"
        }
      }
    }
  ],
  "paths": {
    "/system/settings/git-settings": {
      "get": {
        "operationId": "getGitSettings",
        "summary": "Get Git Settings",
        "description": "Retrieve git settings for organization or instance",
        "tags": [
          "System"
        ],
        "responses": {
          "200": {
            "description": "Git settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GitSettings"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updateGitSettings",
        "summary": "Update Git Settings",
        "description": "Update git configuration settings",
        "tags": [
          "System"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GitSettings"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Git settings updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GitSettings"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/system/outputs": {
      "post": {
        "operationId": "createOutput",
        "summary": "Create Destination",
        "description": "Create a destination for Worker Group",
        "tags": [
          "Outputs"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OutputRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Output created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Output"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listOutputs",
        "summary": "List Destinations",
        "description": "List all configured outputs",
        "tags": [
          "Outputs"
        ],
        "responses": {
          "200": {
            "description": "List of outputs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Output"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/master/workers": {
      "get": {
        "operationId": "listWorkers",
        "summary": "List Workers",
        "description": "List Worker and Edge node metadata",
        "tags": [
          "Workers"
        ],
        "responses": {
          "200": {
            "description": "List of workers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Worker"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/edge/metadata": {
      "get": {
        "operationId": "getEdgeMetadata",
        "summary": "Get Edge Node Metadata",
        "description": "Get host metadata for specific Edge node",
        "tags": [
          "Workers"
        ],
        "responses": {
          "200": {
            "description": "Edge node metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EdgeMetadata"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/version": {
      "get": {
        "operationId": "listVersions",
        "summary": "List Commit History",
        "description": "List commit history for Worker Group or Edge Fleet",
        "tags": [
          "Version"
        ],
        "responses": {
          "200": {
            "description": "Version history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Version"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/m/default_search/search/jobs": {
      "post": {
        "operationId": "createSearchJob",
        "summary": "Create Search Job",
        "description": "Create a new search job in Cribl Search",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchJobRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Search job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchJob"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/search/jobs": {
      "get": {
        "operationId": "listSearchJobs",
        "summary": "List Search Jobs",
        "description": "List all search jobs",
        "tags": [
          "Search"
        ],
        "responses": {
          "200": {
            "description": "List of search jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchJob"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/search/jobs/{id}": {
      "get": {
        "operationId": "getSearchJob",
        "summary": "Get Search Job",
        "description": "Get search job details and results",
        "tags": [
          "Search"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Search job ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search job details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchJob"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Search job not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "GitSettings": {
        "type": "object",
        "properties": {
          "repoUrl": {
            "type": "string",
            "description": "Git repository URL"
          },
          "branch": {
            "type": "string",
            "description": "Git branch name"
          },
          "username": {
            "type": "string",
            "description": "Git username"
          },
          "token": {
            "type": "string",
            "description": "Git authentication token"
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether git integration is enabled"
          }
        }
      },
      "Output": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "description": "Output type (e.g., splunk, s3, elasticsearch)"
          },
          "pipeline": {
            "type": "string",
            "description": "Associated pipeline"
          },
          "systemFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "config": {
            "type": "object",
            "description": "Output-specific configuration"
          }
        }
      },
      "OutputRequest": {
        "type": "object",
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Output identifier"
          },
          "type": {
            "type": "string",
            "description": "Output type"
          },
          "pipeline": {
            "type": "string",
            "description": "Pipeline to associate"
          },
          "config": {
            "type": "object",
            "description": "Output configuration"
          }
        }
      },
      "Worker": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "group": {
            "type": "string",
            "description": "Worker group name"
          },
          "hostname": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "online",
              "offline",
              "unreachable"
            ]
          },
          "version": {
            "type": "string",
            "description": "Cribl version"
          },
          "lastSeenTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EdgeMetadata": {
        "type": "object",
        "properties": {
          "hostname": {
            "type": "string"
          },
          "osType": {
            "type": "string"
          },
          "cpuCount": {
            "type": "integer"
          },
          "totalMemory": {
            "type": "integer"
          },
          "criblVersion": {
            "type": "string"
          }
        }
      },
      "Version": {
        "type": "object",
        "properties": {
          "commit": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date-time"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "SearchJob": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "running",
              "completed",
              "failed"
            ]
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "results": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "SearchJobRequest": {
        "type": "object",
        "required": [
          "query"
        ],
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query in Cribl query language"
          },
          "earliest": {
            "type": "string",
            "description": "Earliest time for search"
          },
          "latest": {
            "type": "string",
            "description": "Latest time for search"
          },
          "datasets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Datasets to search"
          }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "System",
      "description": "System settings and configuration"
    },
    {
      "name": "Workers",
      "description": "Worker and Edge node management"
    },
    {
      "name": "Outputs",
      "description": "Destination configuration"
    },
    {
      "name": "Search",
      "description": "Search job operations"
    },
    {
      "name": "Version",
      "description": "Version and commit history"
    },
    {
      "name": "Workspaces",
      "description": "Workspace management (Management Plane)"
    }
  ]
}