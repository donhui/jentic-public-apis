{
  "openapi": "3.0.3",
  "info": {
    "title": "Mihu AI (Mindhunters) API",
    "version": "1.0.0",
    "description": "Mihu AI is an AI-powered contact center platform that automates customer calls, appointments, lead qualification, and CRM updates 24/7.",
    "x-jentic-source-url": "https://app.mindhunters.ai/docs/api-docs.json"
  },
  "servers": [
    {
      "url": "https://{subdomain}.mindhunters.ai",
      "description": "Your subdomain",
      "variables": {
        "subdomain": {
          "default": "demo",
          "description": "Subdomain name"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {"name": "Calls", "description": "AI voice call management"},
    {"name": "WhatsApp", "description": "WhatsApp messaging"},
    {"name": "Appointments", "description": "Appointment management"},
    {"name": "AppointmentRequests", "description": "Appointment request management"},
    {"name": "AvailabilityTypes", "description": "Availability type configuration"}
  ],
  "paths": {
    "/api/v1/call": {
      "post": {
        "operationId": "initiateCall",
        "summary": "Initiate a new call",
        "tags": ["Calls"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InitiateCallRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Call initiated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallInitiatedResponse"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Agent or settings not found"},
          "422": {"description": "Validation error"}
        }
      }
    },
    "/api/v1/calls": {
      "get": {
        "operationId": "getCalls",
        "summary": "Get paginated list of calls",
        "tags": ["Calls"],
        "parameters": [
          {"name": "page", "in": "query", "required": false, "schema": {"type": "integer", "default": 1}},
          {"name": "per_page", "in": "query", "required": false, "schema": {"type": "integer", "default": 15}},
          {"name": "agent_id", "in": "query", "required": false, "schema": {"type": "string", "format": "uuid"}, "description": "Filter by agent"},
          {"name": "status", "in": "query", "required": false, "schema": {"type": "string", "enum": ["in-progress", "ended", "missed", "failed"]}},
          {"name": "direction", "in": "query", "required": false, "schema": {"type": "string", "enum": ["Inbound", "Outbound", "webCall"]}}
        ],
        "responses": {
          "200": {
            "description": "Paginated call list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallListResponse"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "422": {"description": "Invalid parameters"}
        }
      }
    },
    "/api/v1/calls/{uuid}": {
      "get": {
        "operationId": "getCallDetails",
        "summary": "Get call details by UUID",
        "tags": ["Calls"],
        "parameters": [
          {"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}
        ],
        "responses": {
          "200": {
            "description": "Call details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallDetail"
                }
              }
            }
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Call not found"}
        }
      }
    },
    "/api/v1/whatsapp/template": {
      "post": {
        "operationId": "sendWhatsAppTemplate",
        "summary": "Send WhatsApp template message",
        "tags": ["WhatsApp"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WhatsAppTemplateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WhatsAppResponse"
                }
              }
            }
          },
          "400": {"description": "Template parameter mismatch"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Agent, template, or WhatsApp not found"},
          "422": {"description": "Validation error"}
        }
      }
    },
    "/api/v1/appointments": {
      "get": {
        "operationId": "listAppointments",
        "summary": "Get all appointments",
        "tags": ["Appointments"],
        "parameters": [
          {"name": "schedule_uuid", "in": "query", "required": false, "schema": {"type": "string", "format": "uuid"}},
          {"name": "contact_uuid", "in": "query", "required": false, "schema": {"type": "string", "format": "uuid"}},
          {"name": "status", "in": "query", "required": false, "schema": {"type": "string", "enum": ["approved", "pending", "rejected"]}},
          {"name": "start_date", "in": "query", "required": false, "schema": {"type": "string", "format": "date"}},
          {"name": "end_date", "in": "query", "required": false, "schema": {"type": "string", "format": "date"}}
        ],
        "responses": {
          "200": {"description": "Appointments retrieved", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/Appointment"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "post": {
        "operationId": "createAppointment",
        "summary": "Create a new appointment",
        "tags": ["Appointments"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentCreate"
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Appointment created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Appointment"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/appointments/{uuid}": {
      "get": {
        "operationId": "getAppointment",
        "summary": "Get a specific appointment",
        "tags": ["Appointments"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Appointment details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Appointment"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not found"}
        }
      },
      "put": {
        "operationId": "updateAppointment",
        "summary": "Update an appointment",
        "tags": ["Appointments"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Appointment updated", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Appointment"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "delete": {
        "operationId": "deleteAppointment",
        "summary": "Delete an appointment",
        "tags": ["Appointments"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Appointment deleted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/appointments/{uuid}/status": {
      "post": {
        "operationId": "updateAppointmentStatus",
        "summary": "Update appointment status",
        "tags": ["Appointments"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {"type": "string", "enum": ["approved", "pending", "rejected"]}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Status updated"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/appointment-requests": {
      "get": {
        "operationId": "listAppointmentRequests",
        "summary": "Get list of appointment requests",
        "tags": ["AppointmentRequests"],
        "parameters": [
          {"name": "status", "in": "query", "required": false, "schema": {"type": "string", "enum": ["pending", "approved", "rejected"]}},
          {"name": "schedule_uuid", "in": "query", "required": false, "schema": {"type": "string", "format": "uuid"}},
          {"name": "start_date", "in": "query", "required": false, "schema": {"type": "string", "format": "date"}},
          {"name": "end_date", "in": "query", "required": false, "schema": {"type": "string", "format": "date"}}
        ],
        "responses": {
          "200": {"description": "Appointment requests", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/AppointmentRequest"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "post": {
        "operationId": "createAppointmentRequest",
        "summary": "Create a new appointment request",
        "tags": ["AppointmentRequests"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AppointmentRequestCreate"
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Request created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AppointmentRequest"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "422": {"description": "Validation error"}
        }
      }
    },
    "/api/v1/appointment-requests/{uuid}": {
      "get": {
        "operationId": "getAppointmentRequest",
        "summary": "Get a specific appointment request",
        "tags": ["AppointmentRequests"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Request details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AppointmentRequest"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not found"}
        }
      }
    },
    "/api/v1/appointment-requests/{uuid}/cancel": {
      "post": {
        "operationId": "cancelAppointmentRequest",
        "summary": "Cancel an appointment request",
        "tags": ["AppointmentRequests"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Request cancelled"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not found"},
          "422": {"description": "Cannot cancel non-pending requests"}
        }
      }
    },
    "/api/v1/appointment-requests/available-slots": {
      "get": {
        "operationId": "getAvailableSlots",
        "summary": "Get available time slots for a schedule",
        "tags": ["AppointmentRequests"],
        "parameters": [
          {"name": "schedule_uuid", "in": "query", "required": true, "schema": {"type": "string", "format": "uuid"}},
          {"name": "date", "in": "query", "required": true, "schema": {"type": "string", "format": "date"}, "description": "Must be today or future date"}
        ],
        "responses": {
          "200": {"description": "Available slots", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AvailableSlotsResponse"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "422": {"description": "Validation error"}
        }
      }
    },
    "/api/v1/availability-types": {
      "get": {
        "operationId": "listAvailabilityTypes",
        "summary": "Get all availability types",
        "tags": ["AvailabilityTypes"],
        "responses": {
          "200": {"description": "Availability types", "content": {"application/json": {"schema": {"type": "array", "items": {"$ref": "#/components/schemas/AvailabilityType"}}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      },
      "post": {
        "operationId": "createAvailabilityType",
        "summary": "Create a new availability type",
        "tags": ["AvailabilityTypes"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AvailabilityTypeCreate"
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Type created", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AvailabilityType"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/api/v1/availability-types/{uuid}": {
      "get": {
        "operationId": "getAvailabilityType",
        "summary": "Get a specific availability type",
        "tags": ["AvailabilityTypes"],
        "parameters": [{"name": "uuid", "in": "path", "required": true, "schema": {"type": "string", "format": "uuid"}}],
        "responses": {
          "200": {"description": "Availability type details", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AvailabilityType"}}}},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"},
          "404": {"description": "Not found"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "InitiateCallRequest": {
        "type": "object",
        "required": ["agentId", "participant"],
        "properties": {
          "agentId": {"type": "string", "format": "uuid"},
          "message": {
            "type": "object",
            "properties": {
              "start": {"type": "string", "description": "Greeting message before call"}
            }
          },
          "prompt": {
            "type": "object",
            "required": ["overwrite"],
            "properties": {
              "overwrite": {"type": "boolean"},
              "content": {"type": "string"}
            }
          },
          "participant": {
            "type": "object",
            "required": ["number"],
            "properties": {
              "number": {"type": "string", "description": "Phone number in E.164 format"},
              "about": {"type": "string"}
            }
          }
        }
      },
      "CallInitiatedResponse": {
        "type": "object",
        "properties": {
          "callId": {"type": "string"},
          "agentId": {"type": "string"},
          "provider": {"type": "string"},
          "status": {"type": "string"}
        }
      },
      "CallListResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/CallDetail"}},
          "pagination": {"$ref": "#/components/schemas/Pagination"}
        }
      },
      "CallDetail": {
        "type": "object",
        "properties": {
          "uuid": {"type": "string", "format": "uuid"},
          "status": {"type": "string"},
          "direction": {"type": "string"},
          "duration": {"type": "integer"},
          "agentId": {"type": "string", "format": "uuid"}
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": {"type": "integer"},
          "per_page": {"type": "integer"},
          "total": {"type": "integer"}
        }
      },
      "WhatsAppTemplateRequest": {
        "type": "object",
        "required": ["agentId", "templateId", "phoneNumber"],
        "properties": {
          "agentId": {"type": "string", "format": "uuid"},
          "templateId": {"type": "string", "format": "uuid"},
          "phoneNumber": {"type": "string", "description": "E.164 format"},
          "parameters": {"type": "object", "additionalProperties": {"type": "string"}},
          "header": {
            "type": "object",
            "properties": {
              "type": {"type": "string", "enum": ["image", "video", "document"]},
              "url": {"type": "string"},
              "filename": {"type": "string"}
            }
          }
        }
      },
      "WhatsAppResponse": {
        "type": "object",
        "properties": {
          "messageId": {"type": "string"},
          "conversationId": {"type": "string"}
        }
      },
      "Appointment": {
        "type": "object",
        "properties": {
          "uuid": {"type": "string", "format": "uuid"},
          "schedule_uuid": {"type": "string", "format": "uuid"},
          "contact_uuid": {"type": "string", "format": "uuid"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "start_time": {"type": "string", "format": "date-time"},
          "end_time": {"type": "string", "format": "date-time"},
          "status": {"type": "string", "enum": ["approved", "pending", "rejected"]},
          "notes": {"type": "string"}
        }
      },
      "AppointmentCreate": {
        "type": "object",
        "required": ["schedule_uuid", "title", "start_time", "end_time"],
        "properties": {
          "schedule_uuid": {"type": "string", "format": "uuid"},
          "contact_uuid": {"type": "string", "format": "uuid"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "start_time": {"type": "string", "format": "date-time"},
          "end_time": {"type": "string", "format": "date-time"},
          "status": {"type": "string", "default": "approved"},
          "notes": {"type": "string"},
          "custom_answers": {"type": "object"}
        }
      },
      "AppointmentUpdate": {
        "type": "object",
        "properties": {
          "title": {"type": "string"},
          "description": {"type": "string"},
          "start_time": {"type": "string", "format": "date-time"},
          "end_time": {"type": "string", "format": "date-time"},
          "status": {"type": "string"}
        }
      },
      "AppointmentRequest": {
        "type": "object",
        "properties": {
          "uuid": {"type": "string", "format": "uuid"},
          "schedule_uuid": {"type": "string", "format": "uuid"},
          "contact_uuid": {"type": "string", "format": "uuid"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "start_time": {"type": "string", "format": "date-time"},
          "end_time": {"type": "string", "format": "date-time"},
          "status": {"type": "string", "enum": ["pending", "approved", "rejected"]},
          "notes": {"type": "string"}
        }
      },
      "AppointmentRequestCreate": {
        "type": "object",
        "required": ["schedule_uuid", "title", "start_time"],
        "properties": {
          "schedule_uuid": {"type": "string", "format": "uuid"},
          "contact_uuid": {"type": "string", "format": "uuid"},
          "contact_name": {"type": "string"},
          "contact_surname": {"type": "string"},
          "contact_email": {"type": "string", "format": "email"},
          "contact_phone": {"type": "string"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "start_time": {"type": "string", "format": "date-time"},
          "end_time": {"type": "string", "format": "date-time"},
          "notes": {"type": "string"}
        }
      },
      "AvailableSlotsResponse": {
        "type": "object",
        "properties": {
          "schedule_name": {"type": "string"},
          "slots": {"type": "array", "items": {"type": "string", "format": "date-time"}}
        }
      },
      "AvailabilityType": {
        "type": "object",
        "properties": {
          "uuid": {"type": "string", "format": "uuid"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "default_duration": {"type": "integer", "description": "Duration in minutes"},
          "buffer_time": {"type": "integer", "description": "Buffer in minutes"},
          "require_approval": {"type": "boolean"},
          "enable_appointments": {"type": "boolean"}
        }
      },
      "AvailabilityTypeCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "value": {"type": "string"},
          "description": {"type": "string"},
          "enable_appointments": {"type": "boolean"},
          "default_duration": {"type": "integer"},
          "buffer_time": {"type": "integer"},
          "require_approval": {"type": "boolean"}
        }
      }
    }
  }
}