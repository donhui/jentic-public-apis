{
  "openapi": "3.0.3",
  "info": {
    "title": "Icanhazip",
    "version": "1.0.0",
    "description": "A simple public IP address lookup service. Returns your public IP address in plain text. Supports IPv4 and IPv6.",
    "x-jentic-source-url": "https://major.io/icanhazip-com-faq/"
  },
  "servers": [
    {
      "url": "https://icanhazip.com"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getPublicIp",
        "summary": "Get your public IP address",
        "description": "Returns your public-facing IP address as plain text. The type of IP returned depends on your connection (IPv4 or IPv6).",
        "tags": [
          "IP"
        ],
        "responses": {
          "200": {
            "description": "Your public IP address as plain text",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "description": "Public IP address",
                  "example": "203.0.113.1"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {},
    "securitySchemes": {}
  },
  "security": []
}