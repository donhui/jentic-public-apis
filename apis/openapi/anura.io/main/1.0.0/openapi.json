{
  "openapi": "3.0.3",
  "info": {
    "title": "Anura Reporting API",
    "description": "Anura Reporting API for ad fraud detection analytics. Provides reporting on sessions, browsers, geography, networks, and more. All requests use HTTP POST. Date-specific requests are limited to a 7-day rolling time frame (31 days for Overview endpoints).",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.anura.io"
  },
  "servers": [
    {
      "url": "https://api.anura.io/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/interface/instances": {
      "post": {
        "operationId": "listinstances",
        "summary": "List instances",
        "description": "Retrieves instances linked to your API token.",
        "tags": [
          "Interface"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "API authentication token"
                  },
                  "name": {
                    "type": "string",
                    "description": "Filter by instance name (broad match)"
                  },
                  "all": {
                    "type": "boolean",
                    "default": true,
                    "description": "Include 'All Instances' result"
                  },
                  "page": {
                    "type": "integer",
                    "default": 1,
                    "description": "Result page number"
                  },
                  "limit": {
                    "type": "integer",
                    "default": 20,
                    "maximum": 1000,
                    "description": "Number of results to return"
                  }
                },
                "required": [
                  "token"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of instances",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InterfaceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid parameters or date range exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - invalid or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiToken": []
          }
        ]
      }
    },
    "/interface/sources": {
      "post": {
        "operationId": "listsources",
        "summary": "List sources",
        "description": "Retrieves sources with optional filtering by instance and date range.",
        "tags": [
          "Interface"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
