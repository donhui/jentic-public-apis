                    "type": "string",
                    "description": "API authentication token"
                  },
                  "start": {
                    "type": "integer",
                    "description": "Start date in YYYYMMDD format"
                  },
                  "end": {
                    "type": "integer",
                    "description": "End date in YYYYMMDD format"
                  },
                  "instance": {
                    "type": "string",
                    "description": "Filter by instance ID"
                  },
                  "source": {
                    "type": "string",
                    "description": "Filter by source (broad match)"
                  },
                  "all": {
                    "type": "boolean",
                    "default": true,
                    "description": "Include 'All Sources' aggregate"
                  },
                  "page": {
                    "type": "integer",
                    "default": 1
                  },
                  "limit": {
                    "type": "integer",
                    "default": 20,
                    "maximum": 1000
                  }
                },
                "required": [
                  "token",
                  "start",
                  "end"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of sources",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InterfaceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "apiToken": []
          }
        ]
      }
    },
