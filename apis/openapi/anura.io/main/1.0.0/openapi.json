  "components": {
    "securitySchemes": {
      "apiToken": {
        "type": "apiKey",
        "in": "query",
        "name": "token",
        "description": "API token created and managed through the Anura Dashboard at https://dashboard.anura.io/api"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "ReportingRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "API authentication token"
          },
          "start": {
            "type": "integer",
            "description": "Start date in YYYYMMDD format"
          },
          "end": {
            "type": "integer",
            "description": "End date in YYYYMMDD format"
          },
          "instance": {
            "type": "string",
            "description": "Filter by instance ID"
          },
          "source": {
            "type": "string",
            "description": "Filter by source"
          },
          "campaign": {
            "type": "string",
            "description": "Filter by campaign"
          },
          "chart": {
            "type": "boolean",
            "default": false,
            "description": "Include daily breakdown"
          },
          "rates": {
            "type": "boolean",
            "default": false,
            "description": "Add percentage calculations"
          },
          "rules": {
            "type": "boolean",
            "default": false,
            "description": "Show violated rule sets"
          },
          "search": {
            "type": "string",
            "description": "Filter first column using broad matching"
          },
          "startswith": {
            "type": "boolean",
            "default": false,
            "description": "Return only results matching search prefix"
          },
          "sort": {
            "type": "string",
            "description": "Sort specification (max 3, comma-separated). Format: column:asc|desc"
          },
          "page": {
            "type": "integer",
            "default": 1,
            "description": "Result page number"
          },
          "limit": {
            "type": "integer",
            "default": 20,
            "maximum": 1000,
            "description": "Number of results per response"
          }
        },
        "required": [
          "token",
          "start",
          "end"
        ]
      },
      "InterfaceResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              }
            }
          },
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "ReportingResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            },
            "description": "Array of reporting data records"
          },
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
