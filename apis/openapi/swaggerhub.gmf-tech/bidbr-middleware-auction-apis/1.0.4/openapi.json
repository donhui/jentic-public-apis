{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.4",
    "title": "API Auctions",
    "description": "Swagger da API respons\u00e1vel pela constru\u00e7\u00e3o e opera\u00e7\u00f5es da tela de lances",
    "contact": {
      "email": "gustavo.freitas@brasil317.com.br",
      "name": "Gustavo Freitas"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/gmf-tech/bidbr-middleware-auction-apis/1.0.4/swagger.json"
  },
  "servers": [
    {
      "description": "SwaggerHub API Auto Mocking",
      "url": "https://virtserver.swaggerhub.com/gmf-tech/bidbr-middleware-auction-apis/1.0.4"
    },
    {
      "description": "servidor local",
      "url": "http://localhost/"
    },
    {
      "description": "servidor de homologa\u00e7\u00e3o",
      "url": "http://api-auction-middleware-homol/"
    },
    {
      "description": "servidor de homologa\u00e7\u00e3o",
      "url": "http://api-auction-middleware/"
    }
  ],
  "tags": [
    {
      "name": "bids",
      "description": "tela de lances (local, web, ERPs)"
    }
  ],
  "paths": {
    "/bids/{proposal_id}": {
      "get": {
        "tags": [
          "bids"
        ],
        "summary": "Procurar por pregoes de hoje",
        "description": "Tras a lista de pregoes do dia de hoje, de acordo com o identifier do usuario\ncontido no token. \n",
        "parameters": [
          {
            "in": "path",
            "name": "proposal_id",
            "description": "uuid4 guid da proposta para pegar os itens aprovados na plataforma\n",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "example": "fa6504cf-b09c-4153-ba63-47f14573e0e8"
          }
        ],
        "responses": {
          "200": {
            "description": "lista de pregoes (auctions) do dia, para a etapa de lances (bids)\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListAuctionsItems"
                }
              }
            }
          },
          "400": {
            "description": "bad input parameter"
          },
          "401": {
            "description": "N\u00e3o autorizado. Token expirado ou usu\u00e1rio bloqueado."
          },
          "403": {
            "description": "Usu\u00e1rio n\u00e3o possui credencial para acesso."
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    },
    "/bids/today": {
      "get": {
        "tags": [
          "bids"
        ],
        "summary": "Procurar por pregoes de hoje",
        "description": "Tras a lista de pregoes do dia de hoje, de acordo com o identifier do usuario\ncontido no token. \n",
        "parameters": [
          {
            "in": "query",
            "name": "portal",
            "description": "acronimo do portal",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "CN",
                "BEC",
                "CP",
                "CCH"
              ]
            },
            "example": "CN"
          }
        ],
        "responses": {
          "200": {
            "description": "lista de pregoes (auctions) do dia, para a etapa de lances (bids)\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListAuctions"
                }
              }
            }
          },
          "401": {
            "description": "N\u00e3o autorizado. Token expirado ou usu\u00e1rio bloqueado."
          },
          "403": {
            "description": "Usu\u00e1rio n\u00e3o possui credencial para acesso."
          },
          "501": {
            "description": "Portal n\u00e3o implementado"
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {
              "me": "Read information about the current user.",
              "admin": "Bidbr admin scopes",
              "user": "Acl user",
              "billing": "Acl billing",
              "collect": "Acl collect",
              "filter": "Acl filter",
              "proposal": "Acl proposal",
              "rollback": "Acl rollback",
              "auction": "Acl auction (lances)",
              "checklist": "Acl checklist",
              "configuration": "Acl configuration",
              "report": "Acl reports",
              "data_minute": "Acl data_minute",
              "monitoring": "Acl monitoring"
            },
            "tokenUrl": "https://api-login.bidbr.com.br/v1/token"
          }
        }
      }
    },
    "schemas": {
      "ListAuctionsItems": {
        "type": "object",
        "description": "lista completa de itens do pregao",
        "properties": {
          "bid": {
            "$ref": "#/components/schemas/AuctionItemsFull"
          }
        },
        "example": {
          "bid": {
            "proposal_id": "fa6504cf-b09c-4153-ba63-47f14573e0e8",
            "identifier": "093be751-33ea-439f-881c-496d8c04e36b",
            "portal": "BEC",
            "buyer_unit": "160006",
            "auction_number": "62022",
            "items": [
              {
                "group_number": "NG",
                "item_number": "2",
                "description": "PILHA",
                "detail_description": "PILHA, TAMANHO NORMAL, TIPO COMUM, MODELO AA",
                "amount": 500,
                "bid_limit_price": 100.99,
                "interval_bid_price": null,
                "init_proposal_price": 399.1,
                "is_cut_zeros": false,
                "is_start_stopped": true
              },
              {
                "group_number": "NG",
                "item_number": "1",
                "description": "PILHA",
                "detail_description": "PILHA, TAMANHO PALITO, TIPO COMUM, MODELO AAA",
                "amount": 100,
                "bid_limit_price": 100.99,
                "interval_bid_price": null,
                "init_proposal_price": 399.1,
                "is_cut_zeros": false,
                "is_start_stopped": false
              }
            ]
          }
        }
      },
      "AuctionItemsFull": {
        "type": "object",
        "description": "model do auction completo",
        "allOf": [
          {
            "$ref": "#/components/schemas/Auction"
          }
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuctionItem"
            }
          }
        }
      },
      "AuctionsItems": {
        "type": "object",
        "description": "Lista de itens aprovados pelo cliente para fase de lances",
        "allOf": [
          {
            "$ref": "#/components/schemas/Auction"
          }
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuctionItem"
            }
          }
        }
      },
      "AuctionItem": {
        "type": "object",
        "description": "Model do item",
        "properties": {
          "group_number": {
            "type": "string",
            "description": "Numero do grupo, e caso n\u00e3o seja grupo, o valor default \u00e9 `NG`. Em casos de grupo do tipo lote, ser\u00e1 utilizado `HEADER`. O robo de cadastro de propostas valida este campo e caso precise atua\n",
            "example": "NG"
          },
          "item_number": {
            "type": "string",
            "description": "Numero identificador que vem do portal, por padr\u00e3o, \u00e9 numerico\n",
            "example": "1"
          },
          "description": {
            "type": "string",
            "description": "descri\u00e7\u00e3o do item\n",
            "example": "PILHA"
          },
          "detail_description": {
            "type": "string",
            "description": "Descri\u00e7\u00e3o detalhada do item. em caso de n\u00e3o ter,  o frontend pode duplicar a descri\u00e7\u00e3o\n",
            "example": "PILHA, TAMANHO PALITO, TIPO COMUM, MODELO AAA"
          },
          "amount": {
            "type": "integer",
            "description": "Quantidade relacionada ao item\n",
            "example": 100
          },
          "bid_limit_price": {
            "type": "number",
            "format": "float",
            "description": "valor limite/ valor minimo para envio de lances, abaixo desse valor\no robo nao pode dar lances mais, e caso no calculo o robo de abaixo,\nenvia o minimo\n",
            "example": 100.99
          },
          "interval_bid_price": {
            "type": "number",
            "format": "float",
            "description": "valor minimo entre lances, caso nao venha da api, o robo de lances\nprecisa pegar via scrapping\n",
            "example": null
          },
          "init_proposal_price": {
            "type": "number",
            "format": "float",
            "description": "valor inicial de lances, referente ao valor da proposta\n",
            "example": 399.1
          },
          "is_cut_zeros": {
            "type": "boolean",
            "description": "corta os zeros na casa decimal no envio de lances\n",
            "example": false
          },
          "is_start_stopped": {
            "type": "boolean",
            "description": "inicia a fase de lances pausado\n",
            "example": false
          }
        }
      },
      "ListAuctions": {
        "type": "array",
        "description": "lista simplificada de editais",
        "items": {
          "$ref": "#/components/schemas/AuctionFull"
        },
        "example": [
          {
            "proposal_id": "d290f1ee-6c54-4b01-90e6-d701748f0851",
            "identifier": "093be751-33ea-439f-881c-496d8c04e36b",
            "portal": "CN",
            "buyer_unit": "160006",
            "auction_number": "62022",
            "details": {
              "buyer_name": "PREFEITURA MUNICIPAL DE ANTA GORDA",
              "dispute_mode": "OPEN",
              "auction_type": "ELETRONIC_AUCTION",
              "process_number": "088/2022",
              "auction_number_alt": "6/2022",
              "auction_date": "2023-12-17T17:06:09.300Z"
            }
          },
          {
            "proposal_id": "fa6504cf-b09c-4153-ba63-47f14573e0e8",
            "identifier": "bdc48943-ffc1-4ab0-90ae-04994db06e88",
            "portal": "BEC",
            "buyer_unit": "092601",
            "auction_number": "092601090602022OC00524",
            "details": {
              "buyer_name": "HOSP. CLINICAS FAC.MED.MARILIA - HCFAMEMA",
              "dispute_mode": "OPEN",
              "auction_type": "ELETRONIC_AUCTION",
              "process_number": "AB/2023",
              "auction_number_alt": "Z/2023",
              "auction_date": "2023-05-17T17:06:09.300Z"
            }
          }
        ]
      },
      "Auction": {
        "type": "object",
        "properties": {
          "proposal_id": {
            "type": "string",
            "format": "uuid",
            "description": "uuid4 da proposta relacionada a esse pregao\n",
            "example": "d290f1ee-6c54-4b01-90e6-d701748f0851"
          },
          "identifier": {
            "type": "string",
            "format": "uuid",
            "description": "Chave uuid do edital/preg\u00e3o gerada na cria\u00e7\u00e3o. Essa chave \u00e9 responsavel por toda navega\u00e7\u00e3o na plataforma, referente ao edital.\n",
            "example": "093be751-33ea-439f-881c-496d8c04e36b"
          },
          "portal": {
            "type": "string",
            "description": "Acronimo do portal\n",
            "example": "CN"
          },
          "buyer_unit": {
            "type": "string",
            "description": "Identificador da unidade compradora definida pelo portal. Precisa existir no modelo `Buyer.buyer_unit`\n",
            "example": "160006"
          },
          "auction_number": {
            "type": "string",
            "description": "Identificador do preg\u00e3o definido pelo portal, o qual a gente utiliza nos coletores.\n",
            "example": "62022"
          }
        }
      },
      "AuctionDetail": {
        "type": "object",
        "properties": {
          "buyer_name": {
            "type": "string",
            "description": "nome da unidade compradora\n",
            "example": "PREFEITURA MUNICIPAL DE ANTA GORDA"
          },
          "dispute_mode": {
            "type": "string",
            "enum": [
              "OPEN",
              "CLOSED",
              "RANDOM",
              "PROPOSAL"
            ],
            "description": "Modo de disputa relacionado ao preg\u00e3o. Apenas informativo ao usuario, pois o robo de lances far\u00e1 essa valida\u00e7\u00e3o  em tempo de execu\u00e7\u00e3o. mais relacionado a relatorios futuramente e ter\u00e1 uma inteligencia artificial no modulo database. O modo de disputa \u00e9 informativo no modulo `auctions`. No caso de vir vazio, lee-se `LER EDITAL`\n",
            "example": "OPEN"
          },
          "auction_type": {
            "type": "string",
            "enum": [
              "PRICE_REGISTER",
              "ELETRONIC_AUCTION"
            ],
            "description": "\"PRICE_REGISTER\"  # registro de pre\u00e7o, consumo parcial/total ao longo do tempo \"ELETRONIC_AUCTION\"  # pregao eletronico, cosumo total da ata pelo comprador\n",
            "example": "ELETRONIC_AUCTION"
          },
          "process_number": {
            "type": "string",
            "description": "Numero/identificador do processo judicial referente ao edital.  Apenas para visualiza\u00e7\u00e3o e n\u00e3o utilizado nos coletores.\n",
            "example": "088/2022"
          },
          "auction_number_alt": {
            "type": "string",
            "description": "Identificador do preg\u00e3o apenas para visualiza\u00e7\u00e3o, n\u00e3o \u00e9 o metodo primario de pesquisa nos scraping\n",
            "example": "6/2022"
          },
          "auction_date": {
            "type": "string",
            "format": "date-time",
            "description": "data do dia que ira acontecer o preg\u00e3o\n",
            "example": "2023-12-17T17:06:09.300Z"
          }
        }
      },
      "AuctionFull": {
        "type": "object",
        "description": "model do auction completo",
        "allOf": [
          {
            "$ref": "#/components/schemas/Auction"
          }
        ],
        "properties": {
          "details": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AuctionDetail"
              }
            ]
          }
        }
      }
    }
  }
}