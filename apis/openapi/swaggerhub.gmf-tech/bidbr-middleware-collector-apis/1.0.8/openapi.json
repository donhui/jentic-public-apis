            "example": 49.97
          },
          "interval_bid_price": {
            "type": "number",
            "format": "float",
            "description": "valor minimo entre lances\n",
            "example": 0.01
          },
          "delivery_place_state": {
            "type": "string",
            "example": "SP",
            "description": "acronimo do estado para entrega, por exemplo, caso BEC, \u00e9 SP\n"
          },
          "delivery_place_location": {
            "type": "string",
            "description": "local de entrega completo, definido no edital/portal. No caso do CN, via OCR, vai cidade/estado e o valor a  ser entregue, ja no BEC tem no website\n",
            "example": "Manaus/AM (104)"
          }
        }
