    "/auction/attachments": {
      "put": {
        "tags": [
          "attachments"
        ],
        "summary": "Subir editais oriundos dos portais\n",
        "description": "Upload de arquivos a ser consumido por acl de robos apenas `robots:update`. Valida o hash md5 se ja existe, caso contrario so faz update do metadata. Por padr\u00e3o ir\u00e1 para o bucket de arquivos publicos. Sem precisar de assign.\n",
        "requestBody": {
          "description": "body tipo model Attachment",
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/AttachmentUpload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Em caso de sucesso do upload.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Success"
                }
              }
            }
          },
          "400": {
            "description": "input invalido"
          },
          "401": {
            "description": "N\u00e3o autorizado. Token expirado ou usu\u00e1rio bloqueado"
          },
          "403": {
            "description": "Usu\u00e1rio n\u00e3o possui credencial para acesso."
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    },
