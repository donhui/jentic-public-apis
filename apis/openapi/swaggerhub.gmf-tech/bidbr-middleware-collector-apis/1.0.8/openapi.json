      "AuctionStatus": {
        "type": "object",
        "description": "model do status de editais na plataforma",
        "properties": {
          "status_name": {
            "type": "string",
            "enum": [
              "OPEN",
              "SUSPENDED",
              "CANCELLED",
              "ABANDONED",
              "CLOSED",
              "PENDING_RESULT",
              "ON_MINUTE",
              "COMMITMENT_PAID"
            ],
            "description": "OPEN = status padr\u00e3o inicial SUSPENDED = pregao suspenso ate segunda ordem, pode voltar a vida CANCELLED = preg\u00e3o cancelado ABANDONED = preg\u00e3o abandonado pois nao houve propostas ou desinteresse do pregoeiro CLOSED = passou da data de acolhimento e esta pronto pra lances, n\u00e3o sendo possivel mais cadastrar PENDING_RESULT = terminou lances, e esta aguardando a ata sair, aqui entra monitoramento ON_MINUTE = ata saiu, aguardando a finaliza\u00e7\u00e3o de todos os itens pra pagamento COMMITMENT_PAID = saiu no portal da transparencia, esse status vai vir do database\n"
          },
          "description": {
            "type": "string",
            "description": "Descri\u00e7\u00e3o do status \n",
            "example": "Edital coletado"
          }
        }
      },
