    "/auction": {
      "get": {
        "tags": [
          "auctions"
        ],
        "summary": "tras lista de editais simplificada\n",
        "description": "Traz uma lista simplificada de todos os editais de um determinado dia. Caso n\u00e3o passe nenhum parametro date (ISO-8601) pega o dia de hoje\n",
        "parameters": [
          {
            "in": "query",
            "name": "dt_search",
            "description": "data de pesquisa, na qual caso n\u00e3o for providenciada, pegara datetime.utcnow()\n",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "in": "query",
            "name": "keyword",
            "description": "Palavra chave na busca, para filtragem simplificada. Utilizar este campo apenas para testes, caso procure mais funcionalidades como filtro avan\u00e7ado contratar o scope `filter:read`, utilizando a api de filtros\n",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "400": {
            "description": "input invalido"
          },
          "404": {
            "description": "nenhum registro encontrado"
          },
          "200": {
            "description": "Lista de possiveis status de editais na plataforma\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListAuctions"
                }
              }
            }
          },
          "401": {
            "description": "N\u00e3o autorizado. Token expirado ou usu\u00e1rio bloqueado"
          },
          "403": {
            "description": "Usu\u00e1rio n\u00e3o possui credencial para acesso."
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    },
