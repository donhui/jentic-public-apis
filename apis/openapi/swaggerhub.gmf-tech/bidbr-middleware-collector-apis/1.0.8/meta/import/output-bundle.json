    "/buyer/{portal}": {
      "get": {
        "tags": [
          "buyers"
        ],
        "summary": "Lista unid. compradoras: scope-> collect:read\n",
        "description": "Tras uma lista simplificada \n",
        "parameters": [
          {
            "in": "path",
            "name": "portal",
            "description": "acronimo do portal",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "CN",
                "BEC",
                "CP",
                "CCH"
              ]
            },
            "example": "CN"
          },
          {
            "in": "query",
            "name": "page",
            "description": "numero da pagina, no qual cada pagina tera no maximo 50 elementos\n",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "in": "query",
            "name": "buyer_name",
            "description": "nome da unidade compradora, que será feito um filtro tipo LIKE\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "buyer_unit",
            "description": "id unico da unidade compradora no portal, que será feito um filtro tipo LIKE\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "org_name",
            "description": "nome do orgão dono da unid.compradora, que será feito um filtro tipo LIKE\n",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Sucesso em caso de update\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListBuyersFull"
                }
              }
            }
          },
          "400": {
