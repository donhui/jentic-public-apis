              "admin": "Bidbr admin scopes",
              "user": "Acl user",
              "billing": "Acl billing",
              "collect": "Acl collect",
              "filter": "Acl filter",
              "proposal": "Acl proposal",
              "rollback": "Acl rollback",
              "auction": "Acl auction (lances)",
              "checklist": "Acl checklist",
              "configuration": "Acl configuration",
              "report": "Acl reports",
              "data_minute": "Acl data_minute",
              "monitoring": "Acl monitoring"
            },
            "tokenUrl": "https://api-login.bidbr.com.br/v1/token"
          }
        }
      }
    },
    "schemas": {
      "Success": {
        "type": "object",
        "description": "response sucesso de operaçoes insert/update",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "status da operação",
            "example": true
          }
        }
      },
      "Portal": {
        "type": "object",
        "description": "model do portal",
        "properties": {
          "portal_acronym": {
            "type": "string",
            "description": "acronimo do portal definido pela plataforma",
            "example": "CN"
          },
          "can_collect": {
            "default": true,
            "type": "boolean",
            "description": "status se os coletores de editais estão funcionando"
          },
          "can_login": {
            "default": true,
            "type": "boolean"
          },
          "can_proposal": {
            "default": true,
            "type": "boolean"
          },
          "can_bid": {
            "default": true,
            "type": "boolean"
          },
          "can_monitoring": {
            "default": true,
            "type": "boolean"
          }
        }
      },
      "PortalDetail": {
        "type": "object",
        "properties": {
          "country": {
            "type": "string",
            "description": "acronimo para o pais, seguindo padrao internacional ONU  (https://unece.org/trade/cefact/unlocode-code-list-country-and-territory)\n",
            "example": "BR"
          },
          "portal_name": {
            "type": "string",
            "description": "nome do portal",
            "example": "ComprasNET"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Buyer": {
        "type": "object",
        "properties": {
          "buyer_unit": {
            "type": "string",
            "description": "identificador da unidade compradora referente a cada portal\n",
            "example": "988513"
          },
          "portal": {
            "type": "string",
            "description": "acronimo do portal\n",
            "example": "CN"
          },
          "buyer_name": {
            "type": "string",
            "description": "nome da unidade compradora\n",
            "example": "PREFEITURA MUNICIPAL DE ANTA GORDA"
          }
        }
      },
      "BuyerDetail": {
        "type": "object",
        "properties": {
          "org_name": {
            "type": "string",
            "description": "nome do orgao dono da unidade compradora\n",
            "example": "Estado Rio Grande do Sul"
          },
          "city": {
            "type": "string",
            "description": "nome da cidade\n",
            "example": "Anta Gorda"
          },
          "state": {
            "type": "string",
            "description": "acronimo do estado\n",
            "example": "RS"
          },
          "country": {
            "type": "string",
            "description": "acronimo do pais\n",
            "example": "BR"
          }
        }
      },
      "PortalFull": {
        "type": "object",
        "description": "model do portal",
        "allOf": [
          {
            "$ref": "#/components/schemas/Portal"
          },
          {
            "$ref": "#/components/schemas/PortalDetail"
          }
        ]
      },
      "BuyerFull": {
        "type": "object",
        "description": "model do buyer",
        "allOf": [
          {
            "$ref": "#/components/schemas/Buyer"
          },
          {
            "$ref": "#/components/schemas/BuyerDetail"
          }
        ]
      },
      "ListPortals": {
        "type": "array",
        "description": "lista de portais",
        "items": {
          "$ref": "#/components/schemas/PortalFull"
        }
      },
      "AuctionItem": {
        "type": "object",
        "description": "detalhes dos itens do edital",
        "properties": {
          "group_number": {
            "type": "string",
            "description": "Numero do grupo, e caso não seja grupo, o valor default é `NG`\n",
            "example": "NG"
          },
          "item_number": {
            "type": "string",
            "description": "Numero identificador que vem do portal, por padrão, é numerico\n",
            "example": "1"
          },
          "is_service": {
            "type": "boolean",
            "description": "Saber se é produto ou serviço.\n",
            "example": false
          },
          "is_preference_margin": {
            "type": "boolean",
            "description": "aplicabilidade da margem de preferencia\n",
            "example": false
          },
          "is_national_product": {
            "type": "boolean",
            "description": "fica obrigatorio, no caso de produto, ser um produto nacional.\n",
            "example": false
          },
          "treatment": {
            "type": "string",
            "description": "Tratamento diferenciado, apenas para visualização. campo aberto vindo do portal\n",
            "example": "Tipo I - Participação Exclusiva de ME/EPP/Equiparada"
          },
          "description": {
            "type": "string",
            "description": "descrição do item\n",
            "example": "PILHA"
          },
          "detail_description": {
            "type": "string",
            "description": "Descrição detalhada do item. em caso de não ter,  o frontend pode duplicar a descrição\n",
            "example": "PILHA, TAMANHO PALITO, TIPO COMUM, MODELO AAA"
          },
          "decimal_places": {
            "type": "integer",
            "description": "Total de casas decimais depois da virgula. Utilizado pra cadastro e lances. por padrao 4 (,0000)\n",
            "example": 4
          },
          "amount": {
            "type": "integer",
            "description": "Quantidade relacionada ao item\n",
            "example": 1450
          },
          "supply_unit": {
            "type": "string",
            "example": "Embalagem 4,00 UN",
            "description": "Unidade de fornecimento do item, relacionado ao amount\n"
          }
        },
        "allOf": [
          {
            "$ref": "#/components/schemas/AuctionItemComplement"
          }
        ],
        "example": [
          {
            "judgment_criterion": "LOWEST_PRICE",
            "estimated_price": 49.97,
            "interval_bid_price": 0.01,
            "delivery_place_state": "SP",
            "delivery_place_location": "Manaus/AM (104)",
            "group_number": "NG",
            "item_number": "1",
            "is_service": false,
            "is_preference_margin": false,
            "is_national_product": false,
            "treatment": "Tipo I - Participação Exclusiva de ME/EPP/Equiparada",
            "description": "PILHA",
            "detail_description": "PILHA, TAMANHO PALITO, TIPO COMUM, MODELO AAA",
            "decimal_places": 4,
            "amount": 1450,
            "supply_unit": "Embalagem 4,00 UN"
          }
        ]
      },
      "AuctionItemComplement": {
        "type": "object",
        "description": "Mais informações do item do edital",
        "properties": {
          "judgment_criterion": {
            "type": "string",
            "example": "LOWEST_PRICE",
            "enum": [
              "LOWEST_PRICE_EQ",
              "LOWEST_PRICE",
              "BIGGEST_DISCONT"
            ],
            "description": "criterio de jugamento -> por padrão sempre será nulo. a atualização desse campo, só será feita apos a conclusão do OCR no edital pdf. No caso do `opportunity.judgment_criterion_opportunity_item`, o robo de filtro aguardara ate 15 minutos desse preenchimento, e caso continue null, vai criar o item com valor default na opportunity_items LOWEST_PRICE_EQ = menor preço com equalização LOWEST_PRICE = padrao, sempre o menor preço BIGGEST_DISCONT = maior desconto em porcentagem\n"
          },
          "estimated_price": {
            "type": "number",
            "format": "float",
            "description": "valor de referencia do produto/serviço pelo governo Levar em consideração o descritivo da `suply_unit`\n",
            "example": 49.97
          },
          "interval_bid_price": {
            "type": "number",
            "format": "float",
            "description": "valor minimo entre lances\n",
            "example": 0.01
          },
          "delivery_place_state": {
            "type": "string",
            "example": "SP",
            "description": "acronimo do estado para entrega, por exemplo, caso BEC, é SP\n"
          },
          "delivery_place_location": {
            "type": "string",
            "description": "local de entrega completo, definido no edital/portal. No caso do CN, via OCR, vai cidade/estado e o valor a  ser entregue, ja no BEC tem no website\n",
            "example": "Manaus/AM (104)"
          }
        }
      },
