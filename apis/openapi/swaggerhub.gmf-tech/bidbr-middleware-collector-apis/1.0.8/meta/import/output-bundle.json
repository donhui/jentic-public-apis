    "/auction": {
      "get": {
        "tags": [
          "auctions"
        ],
        "summary": "tras lista de editais simplificada\n",
        "description": "Traz uma lista simplificada de todos os editais de um determinado dia. Caso não passe nenhum parametro date (ISO-8601) pega o dia de hoje\n",
        "parameters": [
          {
            "in": "query",
            "name": "dt_search",
            "description": "data de pesquisa, na qual caso não for providenciada, pegara datetime.utcnow()\n",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "in": "query",
            "name": "keyword",
            "description": "Palavra chave na busca, para filtragem simplificada. Utilizar este campo apenas para testes, caso procure mais funcionalidades como filtro avançado contratar o scope `filter:read`, utilizando a api de filtros\n",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de possiveis status de editais na plataforma\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListAuctions"
                }
              }
            }
          },
          "400": {
            "description": "input invalido"
          },
          "401": {
            "description": "Não autorizado. Token expirado ou usuário bloqueado"
          },
          "403": {
            "description": "Usuário não possui credencial para acesso."
          },
          "404": {
            "description": "nenhum registro encontrado"
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    },
