      "AuctionStatus": {
        "type": "object",
        "description": "model do status de editais na plataforma",
        "properties": {
          "status_name": {
            "type": "string",
            "enum": [
              "OPEN",
              "SUSPENDED",
              "CANCELLED",
              "ABANDONED",
              "CLOSED",
              "PENDING_RESULT",
              "ON_MINUTE",
              "COMMITMENT_PAID"
            ],
            "description": "OPEN = status padrão inicial SUSPENDED = pregao suspenso ate segunda ordem, pode voltar a vida CANCELLED = pregão cancelado ABANDONED = pregão abandonado pois nao houve propostas ou desinteresse do pregoeiro CLOSED = passou da data de acolhimento e esta pronto pra lances, não sendo possivel mais cadastrar PENDING_RESULT = terminou lances, e esta aguardando a ata sair, aqui entra monitoramento ON_MINUTE = ata saiu, aguardando a finalização de todos os itens pra pagamento COMMITMENT_PAID = saiu no portal da transparencia, esse status vai vir do database\n"
          },
          "description": {
            "type": "string",
            "description": "Descrição do status \n",
            "example": "Edital coletado"
          }
        }
      },
      "ListAuctionStatus": {
        "type": "array",
        "description": "lista de status de editais",
        "items": {
