    "/portals": {
      "put": {
        "tags": [
          "portals",
          "support"
        ],
        "summary": "Atualizar status dos portais scope: admin:write\n",
        "description": "Endpoint exclusivo para consumo do time de suporte. Garantir integridade dos robos e um pra exibir pros clientes o status de cada serviço na plataforma por portal.\n",
        "requestBody": {
          "description": "body tipo model Portal, para atualização dos status",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Portal"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sucesso em caso de update\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Success"
                }
              }
            }
          },
          "400": {
            "description": "input invalido"
          },
          "401": {
            "description": "Não autorizado. Token expirado ou usuário bloqueado"
          },
          "403": {
            "description": "Usuário não possui credencial para acesso."
          },
          "404": {
            "description": "dados não encontrado"
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      },
      "get": {
        "tags": [
          "portals",
          "opened"
        ],
        "summary": "Api que ira trazer os status dos serviços para cada portal\n",
        "description": "Neste endpoint so iremos trazer portais homologados pela plataforma aonde estará ligados diretamente aos serviços prestados (coleta,cadastro,filtro,lances,monitoração,atas,....)\n",
        "parameters": [
          {
            "in": "query",
            "name": "portal",
            "description": "acronimo do portal",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "CN",
                "BEC",
                "CP",
                "CCH"
              ]
            },
            "example": "CN"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de portais e seus respectivos status\n",
