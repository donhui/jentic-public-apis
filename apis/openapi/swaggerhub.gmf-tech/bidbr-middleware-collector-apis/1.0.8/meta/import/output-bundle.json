  "paths": {
    "/auction/attachments": {
      "put": {
        "tags": [
          "attachments"
        ],
        "summary": "Subir editais oriundos dos portais\n",
        "description": "Upload de arquivos a ser consumido por acl de robos apenas `robots:update`. Valida o hash md5 se ja existe, caso contrario so faz update do metadata. Por padrão irá para o bucket de arquivos publicos. Sem precisar de assign.\n",
        "requestBody": {
          "description": "body tipo model Attachment",
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/AttachmentUpload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Em caso de sucesso do upload.\n",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Success"
                }
              }
            }
          },
          "400": {
            "description": "input invalido"
          },
          "401": {
            "description": "Não autorizado. Token expirado ou usuário bloqueado"
          },
          "403": {
            "description": "Usuário não possui credencial para acesso."
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    },
