          },
          {
            "status_name": "CLOSED",
            "description": "Edital passou da data de acolhimento e esta pronto pra lances,  não sendo possivel mais cadastrar\n"
          },
          {
            "status_name": "PENDING_RESULT",
            "description": "terminou lances, e esta aguardando a ata sair, aqui entra monitoramento\n"
          },
          {
            "status_name": "ON_MINUTE",
            "description": "ata saiu, aguardando a finalização de todos os itens pra pagamento\n"
          },
          {
            "status_name": "COMMITMENT_PAID",
            "description": "saiu no portal da transparencia, esse status vai vir do database\n"
          }
        ]
