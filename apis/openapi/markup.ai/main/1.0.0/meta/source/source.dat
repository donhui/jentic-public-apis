    "/v1/terminology/search": {
      "get": {
        "operationId": "search-terminology",
        "summary": "Search Terminology",
        "description": "Searches the text for relevant terminology and returns matched term sets.\n\nTerm sets are matched if any word sequence (up to 5 words) in the text is similar to one of the terms of the term set.\nThe similarity measure used is a trigram similarity of 0.5 or higher between the word sequence and the term.",
        "tags": [
          "subpackage_terminology"
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "domain_ids",
            "in": "query",
            "description": "Optional domain filter",
            "required": false,
            "schema": {
              "type": [
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TerminologySearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed or no valid API key provided.",
            "content": {
