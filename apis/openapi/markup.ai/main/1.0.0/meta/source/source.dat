    "/v1/style/rewrites": {
      "post": {
        "operationId": "create-style-rewrite",
        "summary": "Create Style Rewrite",
        "description": "Rewrite text with style corrections applied.",
        "tags": [
          "subpackage_styleRewrites"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
