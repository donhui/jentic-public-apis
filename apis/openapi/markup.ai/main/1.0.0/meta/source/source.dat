                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "import-terminology",
        "summary": "Import terminology from CSV or ACTIF XML",
        "description": "Uploads a CSV or ACTIF XML file and imports terminology.\n\n**CSV Format Requirements:**\n- CSV must include columns: Prohibited, Preferred, Context-Dependent, Instructions, Domains\n- The first row must contain the column headers in the exact same order as shown above\n- Multiple values within a single cell should be separated by semicolons with a space (e.g., term1; term2; term3)\n- Empty cells are allowed\n- The CSV import format is the same as the CSV export format.",
        "tags": [
          "subpackage_terminology"
        ],
        "parameters": [
          {
            "name": "delete_existing",
            "in": "query",
            "description": "Delete all existing terms, term sets and domains before importing",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
