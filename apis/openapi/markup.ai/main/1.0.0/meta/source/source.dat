            }
          }
        ],
        "responses": {
          "202": {
            "description": "Request accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed or no valid API key provided.",
            "content": {
