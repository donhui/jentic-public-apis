    "/v1/terminology/term-sets/{term_set_id}/terms": {
      "post": {
        "operationId": "create-term",
        "summary": "Create Term",
        "description": "Create terms that should be matched in the text. The term types are:\n\n* **preferred**: this is the preferred term for the associated term set\n* **prohibited**: this term should not be used to talk about the term set\n* **context_dependent**: this term is correct in certain cases, but incorrect in others, the instructions field of the term set should explain when the term is correct and when it is incorrect",
        "tags": [
          "subpackage_terminology"
        ],
        "parameters": [
          {
            "name": "term_set_id",
            "in": "path",
            "description": "UUID of the term set",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
