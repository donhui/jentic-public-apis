{
  "openapi": "3.0.3",
  "info": {
    "title": "API Reference",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.markup.ai/openapi.json"
  },
  "paths": {
    "/v1/style-guides": {
      "get": {
        "operationId": "list-style-guides",
        "summary": "List Style Guides",
        "description": "Retrieve all style guides associated with your organization.",
        "tags": [
          "subpackage_styleGuides"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved style guides.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StyleGuideResponse"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed or no valid API key provided.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "create-style-guide",
        "summary": "Create Style Guide",
        "description": "Create a new style guide that can be used in checks, suggestions, and rewrites.",
        "tags": [
          "subpackage_styleGuides"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Style guide creation started successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StyleGuideResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed or no valid API key provided.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "A style guide with this name already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "The uploaded file exceeds the maximum allowed size.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file_upload": {
                    "type": "string",
                    "format": "binary",
                    "description": "The document to analyze. We accept PDF files (.pdf) up to 2 MB."
                  },
                  "name": {
                    "type": "string",
                    "description": "A friendly name for your style guide to help you identify it later."
                  },
                  "base_style_guide": {
                    "oneOf": [
                      {
                        "$ref": "#/components/schemas/BaseStyleGuideType"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "description": "The base style guide to extend (AP, Chicago, or Microsoft). If not provided, the style guide will be created from scratch."
                  },
                  "terminology_domain_ids": {
                    "type": [
                      "array",
                      "null"
                    ],
                    "items": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "description": "List of domain IDs to filter terminology searches by. NULL or empty list means no filtering."
                  }
                },
                "required": [
                  "file_upload",
                  "name"
                ]
              }
            }
          }
        }
      }
    },
    "/v1/style-guides/{style_guide_id}": {
      "get": {
        "operationId": "get-style-guide",
        "summary": "Get Style Guide",
        "description": "Retrieve a specific style guide by ID, including its metadata such as `name` and `status`.",
        "tags": [
          "subpackage_styleGuides"
        ],
        "parameters": [
          {
            "name": "style_guide_id",
            "in": "path",
            "description": "The ID of the style guide.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved the style guide.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StyleGuideResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed or no valid API key provided.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Style guide not found or invalid UUID format.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "delete-style-guide",
        "summary": "Delete Style Guide",
        "description": "Delete a style guide by ID.",
        "tags": [
          "subpackage_styleGuides"
        ],
        "parameters": [
          {
            "name": "style_guide_id",
            "in": "path",
            "description": "The ID of the style guide.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Style guide successfully deleted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Style Guides_deleteStyleGuide_Response_204"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed or no valid API key provided.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Cannot delete predefined style guides.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Style guide not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "update-style-guide",
        "summary": "Update Style Guide",
        "description": "Update the name and/or terminology domain IDs of an existing style guide.",
        "tags": [
          "subpackage_styleGuides"
        ],
        "parameters": [
          {
            "name": "style_guide_id",
            "in": "path",
            "description": "The ID of the style guide.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The style guide was updated successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StyleGuideResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed or no valid API key provided.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Cannot update predefined style guides.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Style guide not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "A style guide with this name already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Body_Style_Guides-update_style_guide"
              }
            }
          }
        }
      }
    },
    "/v1/style/checks": {
      "post": {
        "operationId": "create-style-check",
        "summary": "Create Style Check",
        "description": "Analyze text for grammar, style, and clarity issues.",
        "tags": [
          "subpackage_styleChecks"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Bearer authentication",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Request accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkflowResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed or no valid API key provided.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "The uploaded file exceeds the maximum allowed size.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "The request validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Token limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "dialect": {
                    "$ref": "#/components/schemas/Dialects",
                    "description": "The language variant you'd like us to use for analysis. Choose from American English, British English, or other supported dialects."
                  },
                  "tone": {
                    "oneOf": [
                      {
                        "$ref": "#/components/schemas/Tones"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "description": "The tone variation you're aiming for. Options include formal, academic, casual, and other tone variations to match your content goals."
                  },
                  "style_guide": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The style guide to follow for your content. You can use a style guide ID or choose from built-in options: `ap`, `chicago`, or `microsoft`."
                  },
                  "webhook_url": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "format": "uri",
                    "description": "A URL that results will be POSTed to once the process completes."
                  },
                  "file_upload": {
                    "type": "string",
                    "format": "binary",
                    "description": "The document to analyze. Text (.txt), Markdown (.md), HTML (.html .htm), DITA (.dita, .xml), and PDF (.pdf) files are accepted. The max file size is 1.5 MB."
                  }
                },
                "required": [
                  "dialect",
                  "style_guide",
                  "file_upload"
                ]
              }
            }
          }
        }
      }
    },
    "/v1/style/checks/{workflow_id}": {
      "get": {
        "operationId": "get-style-check",
        "summary": "Get Style Check",
        "description": "Retrieve style check results.",
