  "components": {
    "schemas": {
      "StyleGuideStatus": {
        "type": "string",
        "enum": [
          "running",
          "completed",
          "failed",
          "not_found"
        ],
        "title": "StyleGuideStatus"
      },
      "BaseStyleGuideType": {
        "type": "string",
        "enum": [
          "ap",
          "chicago",
          "microsoft"
        ],
        "title": "BaseStyleGuideType"
      },
      "StyleGuideResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "description": "The name of the style guide."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "The UTC date and time the style guide was created."
          },
          "created_by": {
            "type": "string",
            "description": "The ID of the user who created the style guide."
          },
          "status": {
            "$ref": "#/components/schemas/StyleGuideStatus",
            "description": "The status of the submitted style guide."
          },
          "updated_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "The UTC datetime that the style guide was last updated. If null, the style guide has never been updated."
          },
          "updated_by": {
            "type": [
              "string",
              "null"
            ],
            "description": "The ID of the user who last updated the style guide. If null, the style guide has never been updated."
          },
          "summary": {
            "type": [
              "string",
              "null"
            ],
            "description": "User-friendly summary of the style guide's contents and characteristics"
          },
          "base_style_guide_type": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/BaseStyleGuideType"
              },
              {
                "type": "null"
              }
            ],
            "description": "The base style guide type that this style guide extends (AP, Chicago, or Microsoft)."
          },
          "terminology_domain_ids": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "description": "List of domain IDs to filter terminology searches by. NULL or empty list means no filtering."
          },
          "has_tone_prompt": {
            "type": "boolean",
            "default": false,
            "description": "Whether this style guide has a tone prompt defined."
          }
        },
        "required": [
          "id",
          "name",
          "created_at",
          "created_by",
          "status"
        ],
        "title": "StyleGuideResponse"
      },
