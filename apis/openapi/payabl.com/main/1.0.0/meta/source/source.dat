{
  "openapi": "3.0.3",
  "info": {
    "title": "payabl. Payment Gateway API",
    "description": "Payment Gateway API for payabl. Supports card payments (authorize, pre-authorize, capture, refund, reversal, credit fund transfer), hosted payment page initiation, and Web SDK session creation. Authentication uses a SHA-1 signature parameter included in the request body.",
    "version": "1.0.0",
    "contact": {
      "name": "payabl.",
      "url": "https://docs.payabl.com/reference"
    }
  },
  "servers": [
    {
      "url": "https://paygate.payabl.com",
      "description": "Production Payment Gateway"
    }
  ],
  "tags": [
    {
      "name": "CardPayments",
      "description": "Direct card payment operations: authorize, pre-authorize, capture, refund, reversal, and credit fund transfer."
    },
    {
      "name": "HostedPayments",
      "description": "Hosted payment page initiation for redirect-based payment flows."
    },
    {
      "name": "WebSDK",
      "description": "Web SDK session management for embedded payment widgets."
    }
  ],
  "paths": {
    "/pay/backoffice/payment_authorize": {
      "post": {
        "tags": [
          "CardPayments"
        ],
        "operationId": "paymentAuthorize",
        "summary": "Authorize and charge a card",
        "description": "Performs a full authorization and charge on a card. The funds are immediately captured.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/AuthorizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pay/backoffice/payment_preauthorize": {
      "post": {
        "tags": [
          "CardPayments"
        ],
        "operationId": "paymentPreauthorize",
        "summary": "Pre-authorize (reserve funds on card)",
        "description": "Reserves funds on a card without capturing. A subsequent capture or partial capture call is required to complete the transaction.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/PreauthorizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pay/backoffice/payment_capture": {
      "post": {
        "tags": [
          "CardPayments"
        ],
        "operationId": "paymentCapture",
        "summary": "Capture a pre-authorized transaction",
        "description": "Captures the full amount of a previously pre-authorized transaction.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CaptureRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pay/backoffice/payment_partialcapture": {
      "post": {
        "tags": [
          "CardPayments"
        ],
        "operationId": "paymentPartialCapture",
        "summary": "Partially capture a pre-authorized transaction",
        "description": "Captures a partial amount of a previously pre-authorized transaction.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/PartialCaptureRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pay/backoffice/payment_refund": {
      "post": {
        "tags": [
          "CardPayments"
        ],
        "operationId": "paymentRefund",
        "summary": "Refund a transaction",
        "description": "Refunds a previously captured transaction. The amount and currency must be specified.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/RefundRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pay/backoffice/payment_reversal": {
      "post": {
        "tags": [
          "CardPayments"
        ],
        "operationId": "paymentReversal",
        "summary": "Cancel or reverse a transaction",
        "description": "Cancels or reverses a previously authorized or captured transaction.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/ReversalRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pay/backoffice/payment_cft": {
      "post": {
        "tags": [
          "CardPayments"
        ],
        "operationId": "paymentCft",
        "summary": "Credit fund transfer (payout)",
        "description": "Sends funds to a card (payout). Used for disbursements and refunds to a different card.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/CftRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transaction result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransactionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pay/payment/init": {
      "post": {
        "tags": [
          "HostedPayments"
        ],
        "operationId": "paymentInit",
        "summary": "Initiate a hosted payment page",
        "description": "Creates a hosted payment page session. The customer is redirected to a payabl.-hosted page to complete the payment.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/PaymentInitRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hosted payment page session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentInitResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/pay/payment/get_payment_widget_session": {
      "post": {
        "tags": [
          "WebSDK"
        ],
        "operationId": "getPaymentWidgetSession",
        "summary": "Get a Web SDK session ID",
        "description": "Creates a session for the payabl. Web SDK payment widget. Returns a session ID used to initialize the embedded payment form.",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/WidgetSessionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Widget session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WidgetSessionResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Signature": {
        "type": "string",
        "description": "SHA-1 hash signature for request authentication. 40-character lowercase hexadecimal string.",
        "pattern": "^[a-f0-9]{40}$",
        "example": "a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2"
      },
      "MerchantId": {
        "type": "string",
        "description": "Unique merchant identifier assigned by payabl.",
        "example": "1234567"
      },
      "TransactionId": {
        "type": "string",
        "description": "Unique transaction identifier returned by a previous transaction.",
        "example": "TXN-20260401-00001"
      },
      "Amount": {
        "type": "number",
        "format": "double",
        "description": "Transaction amount.",
        "example": 100.0
      },
      "Currency": {
        "type": "string",
        "description": "Three-letter ISO 4217 currency code.",
        "minLength": 3,
        "maxLength": 3,
        "example": "EUR"
      },
      "CardDetails": {
        "type": "object",
        "description": "Card payment details.",
        "properties": {
          "ccn": {
            "type": "string",
            "description": "Credit card number.",
            "example": "4111111111111111"
          },
          "exp_month": {
            "type": "string",
            "description": "Card expiration month (MM).",
            "example": "12"
          },
          "exp_year": {
            "type": "string",
            "description": "Card expiration year (YYYY).",
            "example": "2028"
          },
          "cvc_code": {
            "type": "string",
            "description": "Card verification code (CVV/CVC).",
            "example": "123"
          }
        }
      },
      "CardholderDetails": {
        "type": "object",
        "description": "Cardholder personal details.",
        "properties": {
          "cardholder_firstname": {
            "type": "string",
            "description": "Cardholder first name.",
            "example": "John"
          },
          "cardholder_lastname": {
            "type": "string",
            "description": "Cardholder last name.",
            "example": "Doe"
          }
        }
      },
      "CustomerDetails": {
        "type": "object",
        "description": "Customer information for fraud and notification purposes.",
        "properties": {
          "customer_email": {
            "type": "string",
            "format": "email",
            "description": "Customer email address.",
            "example": "john.doe@example.com"
          },
          "customer_ip": {
            "type": "string",
            "description": "Customer IP address.",
            "example": "203.0.113.42"
          }
        }
      },
      "AuthorizeRequest": {
        "type": "object",
        "required": [
          "merchantid",
          "amount",
          "currency",
          "payment_method",
          "signature"
        ],
        "properties": {
          "merchantid": {
            "$ref": "#/components/schemas/MerchantId"
          },
          "amount": {
            "$ref": "#/components/schemas/Amount"
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "payment_method": {
            "type": "string",
            "description": "Payment method identifier.",
            "example": "CC"
          },
          "signature": {
            "$ref": "#/components/schemas/Signature"
          },
          "ccn": {
            "type": "string",
            "description": "Credit card number.",
            "example": "4111111111111111"
          },
          "exp_month": {
            "type": "string",
            "description": "Card expiration month (MM).",
            "example": "12"
          },
          "exp_year": {
            "type": "string",
            "description": "Card expiration year (YYYY).",
            "example": "2028"
          },
          "cvc_code": {
            "type": "string",
            "description": "Card verification code (CVV/CVC).",
            "example": "123"
          },
          "cardholder_firstname": {
            "type": "string",
            "description": "Cardholder first name.",
            "example": "John"
          },
          "cardholder_lastname": {
            "type": "string",
            "description": "Cardholder last name.",
            "example": "Doe"
          },
          "customer_email": {
            "type": "string",
            "format": "email",
            "description": "Customer email address.",
            "example": "john.doe@example.com"
          },
          "customer_ip": {
            "type": "string",
            "description": "Customer IP address.",
            "example": "203.0.113.42"
          }
        }
      },
      "PreauthorizeRequest": {
        "type": "object",
        "required": [
          "merchantid",
          "amount",
          "currency",
          "payment_method",
          "signature"
        ],
        "properties": {
          "merchantid": {
            "$ref": "#/components/schemas/MerchantId"
          },
          "amount": {
            "$ref": "#/components/schemas/Amount"
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "payment_method": {
            "type": "string",
            "description": "Payment method identifier.",
            "example": "CC"
          },
          "signature": {
            "$ref": "#/components/schemas/Signature"
          },
          "ccn": {
            "type": "string",
            "description": "Credit card number.",
            "example": "4111111111111111"
          },
          "exp_month": {
            "type": "string",
            "description": "Card expiration month (MM).",
            "example": "12"
          },
          "exp_year": {
            "type": "string",
            "description": "Card expiration year (YYYY).",
            "example": "2028"
          },
          "cvc_code": {
            "type": "string",
            "description": "Card verification code (CVV/CVC).",
            "example": "123"
          },
          "cardholder_firstname": {
            "type": "string",
            "description": "Cardholder first name.",
            "example": "John"
          },
          "cardholder_lastname": {
            "type": "string",
            "description": "Cardholder last name.",
            "example": "Doe"
          }
        }
      },
      "CaptureRequest": {
        "type": "object",
        "required": [
          "merchantid",
          "transactionid",
          "signature"
        ],
        "properties": {
          "merchantid": {
            "$ref": "#/components/schemas/MerchantId"
          },
          "transactionid": {
            "$ref": "#/components/schemas/TransactionId"
          },
          "signature": {
            "$ref": "#/components/schemas/Signature"
          }
        }
      },
      "PartialCaptureRequest": {
        "type": "object",
        "required": [
          "merchantid",
          "transactionid",
          "signature",
          "amount"
        ],
        "properties": {
          "merchantid": {
            "$ref": "#/components/schemas/MerchantId"
          },
          "transactionid": {
            "$ref": "#/components/schemas/TransactionId"
          },
          "signature": {
            "$ref": "#/components/schemas/Signature"
          },
          "amount": {
            "$ref": "#/components/schemas/Amount"
          }
        }
      },
      "RefundRequest": {
        "type": "object",
        "required": [
          "merchantid",
          "transactionid",
          "amount",
          "currency",
          "signature"
        ],
        "properties": {
          "merchantid": {
            "$ref": "#/components/schemas/MerchantId"
          },
          "transactionid": {
            "$ref": "#/components/schemas/TransactionId"
          },
          "amount": {
            "$ref": "#/components/schemas/Amount"
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "signature": {
            "$ref": "#/components/schemas/Signature"
          }
        }
      },
      "ReversalRequest": {
        "type": "object",
        "required": [
          "merchantid",
          "transactionid",
          "signature"
        ],
        "properties": {
          "merchantid": {
            "$ref": "#/components/schemas/MerchantId"
          },
          "transactionid": {
            "$ref": "#/components/schemas/TransactionId"
          },
          "signature": {
            "$ref": "#/components/schemas/Signature"
          }
        }
      },
      "CftRequest": {
        "type": "object",
        "required": [
          "merchantid",
          "amount",
          "currency",
          "transactionid"
        ],
        "properties": {
          "merchantid": {
            "$ref": "#/components/schemas/MerchantId"
          },
          "amount": {
            "$ref": "#/components/schemas/Amount"
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "transactionid": {
            "$ref": "#/components/schemas/TransactionId"
          },
          "ccn": {
            "type": "string",
            "description": "Credit card number for payout.",
            "example": "4111111111111111"
          },
          "exp_month": {
            "type": "string",
            "description": "Card expiration month (MM).",
            "example": "12"
          },
          "exp_year": {
            "type": "string",
            "description": "Card expiration year (YYYY).",
            "example": "2028"
          },
          "cardholder_firstname": {
            "type": "string",
            "description": "Cardholder first name.",
            "example": "John"
          },
          "cardholder_lastname": {
            "type": "string",
            "description": "Cardholder last name.",
            "example": "Doe"
          }
        }
      },
      "PaymentInitRequest": {
        "type": "object",
        "required": [
          "merchantid",
          "amount",
          "currency",
          "signature",
          "url_return"
        ],
        "properties": {
          "merchantid": {
            "$ref": "#/components/schemas/MerchantId"
          },
          "amount": {
            "$ref": "#/components/schemas/Amount"
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "signature": {
            "$ref": "#/components/schemas/Signature"
          },
          "url_return": {
            "type": "string",
            "format": "uri",
            "description": "URL to redirect the customer to after payment completion.",
            "example": "https://merchant.example.com/payment/return"
          },
          "customer_email": {
            "type": "string",
            "format": "email",
            "description": "Customer email address.",
            "example": "john.doe@example.com"
          },
          "customer_ip": {
            "type": "string",
            "description": "Customer IP address.",
            "example": "203.0.113.42"
          },
          "cardholder_firstname": {
            "type": "string",
            "description": "Customer first name.",
            "example": "John"
          },
          "cardholder_lastname": {
            "type": "string",
            "description": "Customer last name.",
            "example": "Doe"
          }
        }
      },
      "WidgetSessionRequest": {
        "type": "object",
        "required": [
          "merchantid",
          "amount",
          "currency",
          "shop_url",
          "signature"
        ],
        "properties": {
          "merchantid": {
            "$ref": "#/components/schemas/MerchantId"
          },
          "amount": {
            "$ref": "#/components/schemas/Amount"
          },
          "currency": {
            "$ref": "#/components/schemas/Currency"
          },
          "shop_url": {
            "type": "string",
            "format": "uri",
            "description": "URL of the merchant shop where the widget is embedded.",
            "example": "https://merchant.example.com"
          },
          "cardholder_firstname": {
            "type": "string",
            "description": "Customer first name.",
            "example": "John"
          },
          "cardholder_lastname": {
            "type": "string",
            "description": "Customer last name.",
            "example": "Doe"
          },
          "signature": {
            "$ref": "#/components/schemas/Signature"
          }
        }
      },
      "TransactionResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Transaction status.",
            "example": "success"
          },
          "transactionid": {
            "type": "string",
            "description": "Unique transaction identifier.",
            "example": "TXN-20260401-00001"
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "Transaction amount.",
            "example": 100.0
          },
          "currency": {
            "type": "string",
            "description": "Three-letter ISO 4217 currency code.",
            "example": "EUR"
          },
          "error_code": {
            "type": "string",
            "description": "Error code if the transaction failed.",
            "example": "0"
          },
          "error_message": {
            "type": "string",
            "description": "Human-readable error message if the transaction failed.",
            "example": ""
          }
        }
      },
      "PaymentInitResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Request status.",
            "example": "success"
          },
          "redirect_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to redirect the customer to for payment.",
            "example": "https://paygate.payabl.com/pay/payment/page/abc123"
          },
          "transactionid": {
            "type": "string",
            "description": "Transaction identifier for tracking.",
            "example": "TXN-20260401-00002"
          }
        }
      },
      "WidgetSessionResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Request status.",
            "example": "success"
          },
          "session_id": {
            "type": "string",
            "description": "Session ID used to initialize the Web SDK payment widget.",
            "example": "sess_abc123def456"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "description": "Error status.",
            "example": "error"
          },
          "error_code": {
            "type": "string",
            "description": "Machine-readable error code.",
            "example": "INVALID_SIGNATURE"
          },
          "error_message": {
            "type": "string",
            "description": "Human-readable error description.",
            "example": "The provided signature is invalid."
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request. Missing or invalid parameters.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized. Invalid signature or merchant credentials.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "signatureAuth": {
        "type": "apiKey",
        "in": "query",
        "name": "signature",
        "description": "SHA-1 hash signature for request authentication. The signature is computed from the request parameters and merchant secret key, and included as a parameter in the request body."
      }
    }
  },
  "security": [
    {
      "signatureAuth": []
