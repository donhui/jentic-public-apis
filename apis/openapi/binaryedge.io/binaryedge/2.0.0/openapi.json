          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/torrent/search/stats": {
      "get": {
        "operationId": "queryTorrentSearchStats",
        "summary": "Torrent search statistics",
        "description": "Get aggregated statistics for a torrent search query.",
        "tags": ["Torrent"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["ports", "countries", "asn", "ips", "rdns", "categories", "names"] }
          },
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 90 }
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["desc", "asc"], "default": "desc" }
          }
        ],
        "responses": {
          "200": {
            "description": "Torrent statistics",
            "content": {
              "application/json": {
                "schema": {
