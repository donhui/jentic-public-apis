{
  "openapi": "3.0.3",
  "info": {
    "title": "BinaryEdge API",
    "description": "BinaryEdge is an internet scanning platform that provides real-time threat intelligence data. The API allows querying hosts, services, vulnerabilities, domains, torrents, dataleaks, sensors, and images across the internet.",
    "version": "2.0.0",
    "contact": {
      "name": "BinaryEdge Support",
      "url": "https://www.binaryedge.io"
    },
    "x-jentic-source-url": "https://docs.binaryedge.io/api-v2.html"
  },
  "servers": [
    {
      "url": "https://api.binaryedge.io/v2",
      "description": "BinaryEdge API v2 production server"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    { "name": "User", "description": "User account and subscription information" },
    { "name": "Host", "description": "Query host/IP information including open ports and services" },
    { "name": "Search", "description": "Search across BinaryEdge datasets" },
    { "name": "Image", "description": "Remote desktop screenshots and image search" },
    { "name": "Torrent", "description": "Torrent activity monitoring" },
    { "name": "Dataleaks", "description": "Data breach and leak information" },
    { "name": "Risk Score", "description": "IP risk scoring and CVE information" },
    { "name": "Domains", "description": "Domain and DNS intelligence" },
    { "name": "Sensors", "description": "Honeypot and sensor data from scanners" }
  ],
  "paths": {
    "/user/subscription": {
      "get": {
        "operationId": "getUserSubscription",
        "summary": "Get subscription details",
        "description": "Return details about your current subscription package.",
        "tags": ["User"],
        "responses": {
          "200": {
            "description": "Subscription details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionInfo"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/ip/{target}": {
      "get": {
        "operationId": "queryIp",
        "summary": "Query IP address",
        "description": "Details about an IP address, including open ports and associated services. Supports IPv4 and CIDR notation up to /24.",
        "tags": ["Host"],
        "parameters": [
          {
            "name": "target",
            "in": "path",
            "required": true,
            "description": "Target IP address or CIDR (up to /24)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Host information with events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HostResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/ip/historical/{target}": {
      "get": {
        "operationId": "queryIpHistorical",
        "summary": "Query IP historical data",
        "description": "Historical events for an IP address up to 6 months. Available for paid subscriptions only.",
        "tags": ["Host"],
        "parameters": [
          {
            "name": "target",
            "in": "path",
            "required": true,
            "description": "Target IP address",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Historical host information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HostResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/search": {
      "get": {
        "operationId": "querySearch",
        "summary": "Search hosts",
        "description": "Search for recent events matching a query across BinaryEdge datasets.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search query string",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number (1-1000)",
            "schema": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 1 }
          },
          {
            "name": "only_ips",
            "in": "query",
            "required": false,
            "description": "If 1, return only IP addresses in results",
            "schema": { "type": "integer", "enum": [0, 1], "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/search/stats": {
      "get": {
        "operationId": "querySearchStats",
        "summary": "Search statistics",
        "description": "Get aggregated statistics for a search query.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search query string",
            "schema": { "type": "string" }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "description": "Type of statistics to aggregate",
            "schema": { "type": "string", "enum": ["ports", "products", "versions", "tags", "services", "countries", "asn"] }
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "description": "Sort order",
            "schema": { "type": "string", "enum": ["desc", "asc"], "default": "desc" }
          }
        ],
        "responses": {
          "200": {
            "description": "Statistics results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/image/ip/{target}": {
      "get": {
        "operationId": "queryImageIp",
        "summary": "Query images by IP",
        "description": "Get remote desktop screenshots from an IP address, with OCR and face detection data.",
        "tags": ["Image"],
        "parameters": [
          {
            "name": "target",
            "in": "path",
            "required": true,
            "description": "Target IP address",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Image results for IP",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/image/search": {
      "get": {
        "operationId": "queryImageSearch",
        "summary": "Search images",
        "description": "Search for remote desktop images matching criteria.",
        "tags": ["Image"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "description": "Search query string",
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number (1-750)",
            "schema": { "type": "integer", "minimum": 1, "maximum": 750, "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Image search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/image/tags": {
      "get": {
        "operationId": "queryImageTags",
        "summary": "List image tags",
        "description": "Get a list of possible image tags.",
        "tags": ["Image"],
        "responses": {
          "200": {
            "description": "Array of available image tags",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" },
                  "example": ["RDP", "VNC", "HAS_FACES", "X11", "WINDOWS", "MOBILE"]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
