            "description": "Target domain",
            "schema": { "type": "string" }
          },
          {
            "name": "validate",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "enum": [0, 1], "default": 0 }
          },
          {
            "name": "total",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Homoglyph results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DomainResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/sensors/ip/{target}": {
      "get": {
        "operationId": "querySensorsIp",
        "summary": "Query sensor data by IP",
        "description": "Get scanner events for an IP or CIDR (up to /24) from honeypot sensors.",
        "tags": ["Sensors"],
        "parameters": [
          {
            "name": "target",
            "in": "path",
            "required": true,
            "description": "Target IP address or CIDR (up to /24)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Sensor events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SensorResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/sensors/search": {
      "get": {
        "operationId": "querySensorsSearch",
        "summary": "Search sensor data",
        "description": "Search honeypot sensor events matching a query.",
        "tags": ["Sensors"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "days",
            "in": "query",
            "required": false,
            "description": "Number of days to search back",
            "schema": { "type": "integer", "default": 30 }
          },
          {
            "name": "only_ips",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "enum": [0, 1], "default": 0 }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Sensor search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SensorResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/sensors/search/stats": {
      "get": {
        "operationId": "querySensorsSearchStats",
        "summary": "Sensor search statistics",
        "description": "Get aggregated statistics for a sensor search query.",
        "tags": ["Sensors"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["ports", "tags", "countries", "asn", "ips", "payloads", "http_path", "rdns"] }
          },
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 30 }
          },
          {
            "name": "order",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["desc", "asc"], "default": "desc" }
          }
        ],
        "responses": {
          "200": {
            "description": "Sensor statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatsResult"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    },
    "/query/sensors/tag/{tag}": {
      "get": {
        "operationId": "querySensorsTag",
        "summary": "Get IPs by sensor tag",
        "description": "Get IP addresses associated with a specific sensor tag.",
        "tags": ["Sensors"],
        "parameters": [
          {
            "name": "tag",
            "in": "path",
            "required": true,
            "description": "Tag name",
            "schema": { "type": "string" }
          },
          {
            "name": "days",
            "in": "query",
            "required": false,
            "description": "Number of days (1-60)",
            "schema": { "type": "integer", "minimum": 1, "maximum": 60, "default": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "IP addresses matching tag",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "429": { "$ref": "#/components/responses/TooManyRequests" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Key",
        "description": "BinaryEdge API key passed via X-Key header"
      }
    },
    "schemas": {
      "SubscriptionInfo": {
        "type": "object",
        "properties": {
          "subscription": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Subscription plan name" },
              "end_date": { "type": "string", "format": "date-time", "description": "Subscription end date" },
              "requests_left": { "type": "integer", "description": "Remaining API requests" }
            }
          }
        }
      },
      "HostResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer", "description": "Total number of events" },
          "query": { "type": "string" },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "port": { "type": "integer" },
          "protocol": { "type": "string" },
          "state": {
            "type": "object",
            "properties": {
              "state": { "type": "string" }
            }
          },
          "result": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "service": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "product": { "type": "string" },
                      "version": { "type": "string" },
                      "banner": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          "target": {
            "type": "object",
            "properties": {
              "ip": { "type": "string" },
              "port": { "type": "integer" }
            }
          },
          "origin": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "ts": { "type": "integer" }
            }
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "pagesize": { "type": "integer" },
          "query": { "type": "string" },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Event"
            }
          }
        }
      },
      "StatsResult": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "total": { "type": "integer" },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": { "type": "string" },
                "doc_count": { "type": "integer" }
              }
            }
          }
        }
      },
      "ImageResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "pagesize": { "type": "integer" },
          "query": { "type": "string" },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ip": { "type": "string" },
                "port": { "type": "integer" },
                "image_id": { "type": "string" },
                "thumb": { "type": "string" },
                "url": { "type": "string" },
                "tags": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "ocr": { "type": "string" },
                "has_faces": { "type": "boolean" }
              }
            }
          }
        }
      },
      "TorrentResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "query": { "type": "string" },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ip": { "type": "string" },
                "port": { "type": "integer" },
                "torrent": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "info_hash": { "type": "string" },
                    "source": { "type": "string" },
                    "category": { "type": "string" }
                  }
                },
                "peer": {
                  "type": "object",
                  "properties": {
                    "ip": { "type": "string" },
                    "port": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      },
      "DataleakEmailResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer", "description": "Total number of leaks affecting this email" },
          "events": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of leak names"
          },
          "query": { "type": "string" }
        }
      },
      "DataleakOrgResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "groups": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "leak": { "type": "string" },
                "count": { "type": "integer" }
              }
            }
          },
          "query": { "type": "string" }
        }
      },
      "DataleakInfo": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "date": { "type": "string" },
          "total_records": { "type": "integer" },
          "data_types": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "RiskScoreResult": {
        "type": "object",
        "properties": {
          "normalized_ip_score": { "type": "number" },
          "normalized_ip_score_detailed": {
            "type": "object",
            "properties": {
              "cve": { "type": "number" },
              "attack_surface": { "type": "number" },
              "encryption": { "type": "number" },
              "rms": { "type": "number" },
              "storage": { "type": "number" },
              "web": { "type": "number" },
              "torrents": { "type": "number" }
            }
          },
          "ip_address": { "type": "string" }
        }
      },
      "CveResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "query": { "type": "string" },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "cve": { "type": "string" },
                "cvss": { "type": "number" },
                "ports": {
                  "type": "array",
                  "items": { "type": "integer" }
                },
                "product": { "type": "string" }
              }
            }
          }
        }
      },
      "DomainResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "pagesize": { "type": "integer" },
          "query": { "type": "string" },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "domain": { "type": "string" },
                "A": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "AAAA": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "NS": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "MX": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "SensorResult": {
        "type": "object",
        "properties": {
          "total": { "type": "integer" },
          "page": { "type": "integer" },
          "query": { "type": "string" },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ip": { "type": "string" },
                "port": { "type": "integer" },
                "payload": { "type": "string" },
                "tags": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "extra": {
                  "type": "object",
                  "properties": {
                    "http": {
                      "type": "object",
                      "properties": {
                        "method": { "type": "string" },
                        "path": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "status": { "type": "integer" },
          "title": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - invalid query or parameters",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "TooManyRequests": {
        "description": "Rate limit exceeded",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    }
  }
}
