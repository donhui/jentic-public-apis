{
  "openapi": "3.0.3",
  "info": {
    "title": "8B World Payment API",
    "version": "1.0.0",
    "description": "8B World payment processing platform API for managing admin accounts, settlement accounts, settlement instruments, and contacts.",
    "x-jentic-source-url": "https://developerhub.8b.world/reference/"
  },
  "servers": [
    {
      "url": "https://api.8b.world",
      "description": "Production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "OAuth authentication endpoints" },
    { "name": "AdminAccounts", "description": "Admin account management" },
    { "name": "SettlementAccounts", "description": "Settlement account management" },
    { "name": "SettlementInstruments", "description": "Settlement instrument management" },
    { "name": "Contacts", "description": "Contact management" }
  ],
  "paths": {
    "/api/v1/admin-accounts/oauth/authorize": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "authorize",
        "summary": "Obtain client access token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthorizeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access token granted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizeResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Invalid credentials", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/oauth/refresh-token": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "refreshToken",
        "summary": "Refresh access token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthorizeResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Invalid refresh token", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/oauth/logout": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "logout",
        "summary": "Terminate session",
        "responses": {
          "200": {
            "description": "Session terminated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts": {
      "post": {
        "tags": ["AdminAccounts"],
        "operationId": "createAdminAccount",
        "summary": "Create an admin account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAdminAccountRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminAccount" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/{id}": {
      "get": {
        "tags": ["AdminAccounts"],
        "operationId": "getAdminAccount",
        "summary": "Retrieve admin account details",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Account details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminAccount" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "tags": ["AdminAccounts"],
        "operationId": "updateAdminAccount",
        "summary": "Update an admin account",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateAdminAccountRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminAccount" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/{id}/status": {
      "patch": {
        "tags": ["AdminAccounts"],
        "operationId": "updateAdminAccountStatus",
        "summary": "Modify admin account status",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "description": "New status value" }
                },
                "required": ["status"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AdminAccount" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/short-info": {
      "get": {
        "tags": ["AdminAccounts"],
        "operationId": "listAdminAccounts",
        "summary": "List all admin accounts (summary)",
        "responses": {
          "200": {
            "description": "List of admin accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AdminAccountSummary" }
                }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/settlement-accounts": {
      "post": {
        "tags": ["SettlementAccounts"],
        "operationId": "createSettlementAccount",
        "summary": "Create a settlement account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SettlementAccountRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settlement account created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SettlementAccount" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/settlement-accounts/{id}": {
      "get": {
        "tags": ["SettlementAccounts"],
        "operationId": "getSettlementAccount",
        "summary": "Retrieve settlement account details",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Settlement account details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SettlementAccount" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "tags": ["SettlementAccounts"],
        "operationId": "updateSettlementAccount",
        "summary": "Update a settlement account",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SettlementAccountRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settlement account updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SettlementAccount" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/settlement-instruments": {
      "post": {
        "tags": ["SettlementInstruments"],
        "operationId": "createSettlementInstrument",
        "summary": "Create a settlement instrument",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SettlementInstrumentRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settlement instrument created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SettlementInstrument" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/settlement-instruments/{id}": {
      "get": {
        "tags": ["SettlementInstruments"],
        "operationId": "getSettlementInstrument",
        "summary": "Retrieve settlement instrument details",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Settlement instrument details",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SettlementInstrument" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "put": {
        "tags": ["SettlementInstruments"],
        "operationId": "updateSettlementInstrument",
        "summary": "Update a settlement instrument",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SettlementInstrumentRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settlement instrument updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SettlementInstrument" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/settlement-accounts-contacts/contacts": {
      "post": {
        "tags": ["Contacts"],
        "operationId": "createContact",
        "summary": "Create contacts",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contacts created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/admin-accounts/settlement-accounts-contacts/{id}": {
      "patch": {
        "tags": ["Contacts"],
        "operationId": "updateContact",
        "summary": "Update a contact",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contact updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Contact" } } }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token obtained via OAuth authorize endpoint"
      }
    },
    "schemas": {
      "AuthorizeRequest": {
        "type": "object",
        "properties": {
          "login": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["login", "password"]
      },
      "RefreshTokenRequest": {
        "type": "object",
        "properties": {
          "refresh_token": { "type": "string" }
        },
        "required": ["refresh_token"]
      },
      "AuthorizeResponse": {
        "type": "object",
        "properties": {
          "access_token": { "type": "string" },
          "refresh_token": { "type": "string" },
          "token_type": { "type": "string" },
          "expires_in": { "type": "integer" }
        }
      },
      "CreateAdminAccountRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "role": { "type": "string" }
        }
      },
      "AdminAccount": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "role": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "AdminAccountSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "SettlementAccountRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "currency": { "type": "string" }
        }
      },
      "SettlementAccount": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "currency": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "SettlementInstrumentRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "settlement_account_id": { "type": "string" }
        }
      },
      "SettlementInstrument": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "settlement_account_id": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "ContactRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "role": { "type": "string" }
        }
      },
      "Contact": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "role": { "type": "string" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "message": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}