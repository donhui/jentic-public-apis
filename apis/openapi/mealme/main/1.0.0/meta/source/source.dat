{
  "openapi": "3.0.3",
  "info": {
    "title": "MealMe API",
    "version": "1.0.0",
    "description": "MealMe API for searching restaurants, managing carts, placing orders, and handling payments for food delivery and pickup.",
    "x-jentic-source-url": "https://docs.mealme.ai"
  },
  "servers": [
    {
      "url": "https://api.mealme.ai",
      "description": "MealMe Production API"
    }
  ],
  "security": [
    {
      "apiKeyAuth": []
    }
  ],
  "tags": [
    {"name": "Search", "description": "Search for stores and products"},
    {"name": "Inventory", "description": "Get store inventory and product details"},
    {"name": "Cart", "description": "Manage shopping carts"},
    {"name": "Order", "description": "Create and manage orders"},
    {"name": "Account", "description": "Account and order management"},
    {"name": "Payment", "description": "Manage payment methods"}
  ],
  "paths": {
    "/search/store/v3": {
      "get": {
        "operationId": "searchStores",
        "summary": "Search for a store",
        "description": "Search for restaurants and stores near a given location.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "description": "Latitude of the search location",
            "schema": {"type": "number", "format": "double"}
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "description": "Longitude of the search location",
            "schema": {"type": "number", "format": "double"}
          },
          {
            "name": "query",
            "in": "query",
            "description": "Search query string",
            "schema": {"type": "string"}
          },
          {
            "name": "budget",
            "in": "query",
            "description": "Budget filter",
            "schema": {"type": "string"}
          },
          {
            "name": "maximum_miles",
            "in": "query",
            "description": "Maximum distance in miles",
            "schema": {"type": "number"}
          },
          {
            "name": "open",
            "in": "query",
            "description": "Filter for currently open stores",
            "schema": {"type": "boolean"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with store results",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/StoreSearchResults"}}}
          },
          "400": {"description": "Bad request"},
          "401": {
            "description": "Unauthorized - incorrect API key",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ErrorResponse"}}}
          }
        }
      }
    },
    "/search/product/v4": {
      "get": {
        "operationId": "searchProducts",
        "summary": "Search for a product",
        "description": "Search for food products across stores.",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "latitude",
            "in": "query",
            "required": true,
            "schema": {"type": "number", "format": "double"}
          },
          {
            "name": "longitude",
            "in": "query",
            "required": true,
            "schema": {"type": "number", "format": "double"}
          },
          {
            "name": "query",
            "in": "query",
            "description": "Product search query",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with product results",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProductSearchResults"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/search/cart": {
      "get": {
        "operationId": "searchCart",
        "summary": "Search for a cart",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Cart search query",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {"application/json": {"schema": {"type": "object"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/inventory/details/v4": {
      "get": {
        "operationId": "getInventory",
        "summary": "Get store inventory",
        "description": "Get the full menu/inventory for a specific store.",
        "tags": ["Inventory"],
        "parameters": [
          {
            "name": "store_id",
            "in": "query",
            "required": true,
            "description": "Store identifier",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with inventory details",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/InventoryDetails"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/product/details/v2": {
      "get": {
        "operationId": "getProductDetails",
        "summary": "Get product details",
        "description": "Get detailed information about a specific product.",
        "tags": ["Inventory"],
        "parameters": [
          {
            "name": "product_id",
            "in": "query",
            "required": true,
            "description": "Product identifier",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with product details",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProductDetails"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/cart/create": {
      "post": {
        "operationId": "createCart",
        "summary": "Create a cart",
        "description": "Create a new shopping cart.",
        "tags": ["Cart"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CreateCartRequest"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cart created",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Cart"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/cart/add": {
      "post": {
        "operationId": "addToCart",
        "summary": "Add item to cart",
        "tags": ["Cart"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CartItemRequest"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item added to cart",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Cart"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/cart/remove": {
      "post": {
        "operationId": "removeFromCart",
        "summary": "Remove item from cart",
        "tags": ["Cart"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CartItemRequest"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item removed from cart",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Cart"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/cart/retrieve/v2": {
      "get": {
        "operationId": "retrieveCart",
        "summary": "Retrieve a cart",
        "tags": ["Cart"],
        "parameters": [
          {
            "name": "cart_id",
            "in": "query",
            "required": true,
            "description": "Cart identifier",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Cart"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/cart/list/v2": {
      "get": {
        "operationId": "listCarts",
        "summary": "List carts",
        "tags": ["Cart"],
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "description": "User identifier",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CartList"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/order/v4": {
      "post": {
        "operationId": "createOrder",
        "summary": "Create an order",
        "description": "Create a new order for delivery or pickup. Set place_order to true to immediately place or false to create for later finalization.",
        "tags": ["Order"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/CreateOrderRequest"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order created successfully",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderResponse"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/confirm/order": {
      "post": {
        "operationId": "finalizeOrder",
        "summary": "Finalize an order",
        "description": "Confirm and finalize a previously created order.",
        "tags": ["Order"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "order_id": {"type": "string", "description": "Order identifier to finalize"}
                },
                "required": ["order_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Order finalized",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderResponse"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/account/orders": {
      "get": {
        "operationId": "getOrders",
        "summary": "Get orders",
        "description": "Retrieve a list of orders for the account.",
        "tags": ["Account"],
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "description": "User identifier",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/OrderList"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/account/tracking/webhook": {
      "post": {
        "operationId": "addTrackingWebhook",
        "summary": "Add tracking webhook",
        "description": "Register a webhook URL for order tracking updates.",
        "tags": ["Account"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {"type": "string", "description": "Webhook URL for tracking updates"},
                  "user_id": {"type": "string", "description": "User identifier"}
                },
                "required": ["url"]
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Webhook registered"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/payment/create/v2": {
      "post": {
        "operationId": "createPaymentMethod",
        "summary": "Create payment method",
        "tags": ["Payment"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {"$ref": "#/components/schemas/PaymentMethodInput"}
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment method created",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentMethod"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/payment/list": {
      "get": {
        "operationId": "listPaymentMethods",
        "summary": "List payment methods",
        "tags": ["Payment"],
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "description": "User identifier",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentMethodList"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/payment/delete": {
      "post": {
        "operationId": "deletePaymentMethod",
        "summary": "Delete payment method",
        "tags": ["Payment"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "payment_method_id": {"type": "string", "description": "Payment method identifier to delete"},
                  "user_id": {"type": "string", "description": "User identifier"}
                },
                "required": ["payment_method_id"]
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Payment method deleted"},
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    },
    "/payment/intent": {
      "post": {
        "operationId": "getPaymentIntent",
        "summary": "Get payment intent",
        "tags": ["Payment"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": {"type": "string"},
                  "amount": {"type": "integer", "description": "Amount in cents"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment intent created",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/PaymentIntent"}}}
          },
          "400": {"description": "Bad request"},
          "401": {"description": "Unauthorized"}
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Id-Token",
        "description": "API key passed in the Id-Token header"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {"type": "string", "description": "Error message"}
        }
      },
      "StoreSearchResults": {
        "type": "object",
        "properties": {
          "stores": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/Store"}
          }
        }
      },
      "Store": {
        "type": "object",
        "properties": {
          "store_id": {"type": "string"},
          "name": {"type": "string"},
          "address": {"type": "string"},
          "latitude": {"type": "number"},
          "longitude": {"type": "number"},
          "rating": {"type": "number"},
          "open": {"type": "boolean"},
          "delivery_fee_cents": {"type": "integer"},
          "delivery_time_min": {"type": "integer"},
          "delivery_time_max": {"type": "integer"}
        }
      },
      "ProductSearchResults": {
        "type": "object",
        "properties": {
          "products": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/ProductSummary"}
          }
        }
      },
      "ProductSummary": {
        "type": "object",
        "properties": {
          "product_id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "price": {"type": "integer", "description": "Price in cents"},
          "store_id": {"type": "string"},
          "store_name": {"type": "string"}
        }
      },
      "InventoryDetails": {
        "type": "object",
        "properties": {
          "store_id": {"type": "string"},
          "categories": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "products": {"type": "array", "items": {"$ref": "#/components/schemas/ProductSummary"}}
              }
            }
          }
        }
      },
      "ProductDetails": {
        "type": "object",
        "properties": {
          "product_id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "price": {"type": "integer"},
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "option_id": {"type": "string"},
                "name": {"type": "string"},
                "price": {"type": "integer"},
                "quantity": {"type": "integer"}
              }
            }
          }
        }
      },
      "CreateCartRequest": {
        "type": "object",
        "properties": {
          "store_id": {"type": "string"},
          "user_id": {"type": "string"},
          "items": {
            "type": "array",
            "items": {"$ref": "#/components/schemas/OrderItem"}
          }
        },
        "required": ["store_id"]
      },
      "CartItemRequest": {
        "type": "object",
        "properties": {
          "cart_id": {"type": "string"},
          "product_id": {"type": "string"},
          "quantity": {"type": "integer"},
          "selected_options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "option_id": {"type": "string"},
                "quantity": {"type": "integer"}
              }
            }
          }
        },
        "required": ["cart_id", "product_id"]
      },
      "Cart": {
        "type": "object",
        "properties": {
          "cart_id": {"type": "string"},
          "store_id": {"type": "string"},
          "items": {"type": "array", "items": {"$ref": "#/components/schemas/OrderItem"}},
          "subtotal": {"type": "integer"},
          "total": {"type": "integer"}
        }
      },
      "CartList": {
        "type": "object",
        "properties": {
          "carts": {"type": "array", "items": {"$ref": "#/components/schemas/Cart"}}
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "product_id": {"type": "string", "description": "Encrypted product identifier"},
          "quantity": {"type": "integer"},
          "notes": {"type": "string", "description": "Special instructions"},
          "selected_options": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "option_id": {"type": "string"},
                "quantity": {"type": "integer"}
              }
            }
          }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "properties": {
          "place_order": {"type": "boolean", "description": "Whether to immediately place the order (true) or create for later finalization (false)"},
          "items": {"type": "array", "items": {"$ref": "#/components/schemas/OrderItem"}},
          "pickup": {"type": "boolean", "description": "True for pickup, false for delivery"},
          "driver_tip_cents": {"type": "integer", "description": "Driver tip in cents"},
          "user_latitude": {"type": "number"},
          "user_longitude": {"type": "number"},
          "user_street_num": {"type": "string"},
          "user_street_name": {"type": "string"},
          "user_city": {"type": "string"},
          "user_state": {"type": "string"},
          "user_country": {"type": "string"},
          "user_zipcode": {"type": "string"},
          "user_dropoff_notes": {"type": "string"},
          "user_name": {"type": "string"},
          "user_email": {"type": "string"},
          "user_phone": {"type": "integer"},
          "user_id": {"type": "string"},
          "charge_user": {"type": "boolean"},
          "include_final_quote": {"type": "boolean"},
          "disable_sms": {"type": "boolean"},
          "payment_method_id": {"type": "string", "description": "Stripe payment method ID"}
        },
        "required": ["items", "place_order"]
      },
      "OrderResponse": {
        "type": "object",
        "properties": {
          "order_placed": {"type": "boolean"},
          "order_id": {"type": "string"},
          "tracking_link": {"type": "string"},
          "final_quote": {"$ref": "#/components/schemas/FinalQuote"}
        }
      },
      "FinalQuote": {
        "type": "object",
        "properties": {
          "store": {"type": "string"},
          "store_address": {"type": "string"},
          "store_id": {"type": "string"},
          "quote": {
            "type": "object",
            "properties": {
              "subtotal": {"type": "integer"},
              "delivery_fee_cents": {"type": "integer"},
              "service_fee_cents": {"type": "integer"},
              "sales_tax_cents": {"type": "integer"},
              "total_without_tips": {"type": "integer"},
              "delivery_time_min": {"type": "integer"},
              "delivery_time_max": {"type": "integer"}
            }
          },
          "items": {"type": "array", "items": {"type": "object"}},
          "tip": {"type": "integer"},
          "total_with_tip": {"type": "integer"}
        }
      },
      "OrderList": {
        "type": "object",
        "properties": {
          "orders": {"type": "array", "items": {"$ref": "#/components/schemas/OrderResponse"}}
        }
      },
      "PaymentMethodInput": {
        "type": "object",
        "properties": {
          "user_id": {"type": "string"},
          "payment_token": {"type": "string", "description": "Stripe payment token"}
        }
      },
      "PaymentMethod": {
        "type": "object",
        "properties": {
          "payment_method_id": {"type": "string"},
          "last4": {"type": "string"},
          "brand": {"type": "string"},
          "exp_month": {"type": "integer"},
          "exp_year": {"type": "integer"}
        }
      },
      "PaymentMethodList": {
        "type": "object",
        "properties": {
          "payment_methods": {"type": "array", "items": {"$ref": "#/components/schemas/PaymentMethod"}}
        }
      },
      "PaymentIntent": {
        "type": "object",
        "properties": {
          "client_secret": {"type": "string"},
          "payment_intent_id": {"type": "string"}
        }
      }
    }
  }
}