{
  "openapi": "3.0.0",
  "info": {
    "contact": {
      "email": "info@quiputech.com"
    },
    "description": "Order and Service Management",
    "title": "OSM API",
    "version": "1.0.0",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/quiputech/api.osm/1.0.0/swagger.json"
  },
  "servers": [
    {
      "url": "https://virtserver.swaggerhub.com/quiputech/api.osm/1.0.0"
    }
  ],
  "paths": {
    "/v1/order": {
      "post": {
        "parameters": [
          {
            "in": "header",
            "name": "Security-Token",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            },
            "description": "Successful operation"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            },
            "description": "Unsuccessful operation"
          }
        },
        "tags": [
          "operation"
        ],
        "description": "request order execution",
        "operationId": "post-v1-order",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderRequest"
              }
            }
          },
          "description": "Order request to execute"
        },
        "summary": "request order execution"
      }
    },
    "/v1/order/{orderId}": {
      "get": {
        "parameters": [
          {
            "description": "Order Id to retrieve",
            "in": "path",
            "name": "orderId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrderResponse"
                }
              }
            },
            "description": "Order retrieved"
          },
          "404": {
            "description": "Order not found"
          }
        },
        "tags": [
          "operation"
        ],
        "description": "request order execution",
        "operationId": "get-v1-order-by-orderid",
        "summary": "request order execution"
      }
    }
  },
  "components": {
    "schemas": {
      "DataMap": {
        "additionalProperties": {
          "description": "Any parameter defined that needs to be exchanged in transaction\n",
          "type": "object"
        },
        "description": "Map<String, Object> of different parameters to exchange between parties. Every transaction expects and defines different set of parameters.\n",
        "properties": {
          "amount": {
            "description": "For recharge request",
            "example": "10.0",
            "type": "string"
          },
          "currency": {
            "description": "For recharge request",
            "example": "PEN",
            "type": "string"
          },
          "rechargeId": {
            "description": "For recharge response",
            "example": "UV1232-1212-AF-212",
            "type": "string"
          },
          "remainingBalance": {
            "description": "For recharge response",
            "example": "145.00",
            "type": "string"
          },
          "toNumber": {
            "description": "For recharge request",
            "example": "+51994336911",
            "type": "string"
          }
        },
        "type": "object"
      },
      "Header": {
        "properties": {
          "errorCode": {
            "description": "Transaction error code. 0 means OK, anything different is an error code.\n",
            "example": 0,
            "type": "integer"
          },
          "errorMessage": {
            "description": "Transaction execution message.\n",
            "example": "Order executed successfully",
            "type": "string"
          },
          "millis": {
            "example": 250,
            "type": "integer"
          },
          "transactionUUID": {
            "example": "212f34c6-cf79-4906-943e-659e965d3f2b",
            "type": "string"
          }
        },
        "type": "object"
      },
      "Order": {
        "properties": {
          "dataMap": {
            "$ref": "#/components/schemas/DataMap"
          },
          "executionDate": {
            "format": "date-time",
            "type": "string"
          },
          "orderId": {
            "example": "XA-213431231",
            "type": "string"
          },
          "scheduledExecutionDate": {
            "format": "date-time",
            "type": "string"
          },
          "status": {
            "enum": [
              "FULFILLED",
              "SCHEDULED",
              "RUNNING",
              "ABORTED",
              "CANCELED"
            ],
            "example": "FULFILLED",
            "type": "string"
          }
        },
        "required": [
          "orderId",
          "status"
        ],
        "type": "object"
      },
      "OrderRequest": {
        "properties": {
          "action": {
            "example": "recharge",
            "type": "string"
          },
          "channel": {
            "enum": [
              "ONLINE"
            ],
            "example": "ONLINE",
            "type": "string"
          },
          "dataMap": {
            "$ref": "#/components/schemas/DataMap"
          },
          "externalTransactionId": {
            "example": "f6489f0c-0ef8-4f5a-a5c9-a832fbb07c69",
            "type": "string"
          },
          "merchantId": {
            "example": "123456789",
            "type": "string"
          },
          "target": {
            "example": "telefonica",
            "type": "string"
          }
        },
        "type": "object"
      },
      "OrderResponse": {
        "properties": {
          "header": {
            "$ref": "#/components/schemas/Header"
          },
          "order": {
            "$ref": "#/components/schemas/Order"
          }
        },
        "type": "object"
      }
    }
  },
  "tags": [
    {
      "description": "Operations related calls",
      "name": "operation"
    }
  ]
}