{
  "openapi": "3.0.0",
  "info": {
    "description": "VisaNet OCT/AFT Project. Related to PET-1234",
    "title": "OCT/AFT",
    "version": "1.1",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/quiputech/api.visadirect/1.1/swagger.json"
  },
  "servers": [
    {
      "url": "https://virtserver.swaggerhub.com/quiputech/api.visadirect/v1"
    }
  ],
  "paths": {
    "/oct/{entityId}": {
      "post": {
        "parameters": [
          {
            "in": "path",
            "name": "entityId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OCTResponse"
                }
              }
            },
            "description": "Ok"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "tags": [
          "OCT"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OCTRequest"
              }
            }
          },
          "required": true
        }
      }
    },
    "/p2p/{entityId}": {
      "post": {
        "parameters": [
          {
            "in": "path",
            "name": "entityId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/P2PResponse"
                }
              }
            },
            "description": "Ok"
          }
        },
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "tags": [
          "P2P"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/P2PRequest"
              }
            }
          },
          "required": true
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Antifraud": {
        "properties": {
          "billTo_city": {
            "example": "Lima",
            "type": "string"
          },
          "billTo_country": {
            "example": "PE",
            "type": "string"
          },
          "billTo_postalCode": {
            "example": "Lima 30",
            "type": "string"
          },
          "billTo_state": {
            "example": "LI",
            "type": "string"
          },
          "billTo_street1": {
            "example": "Pardo 618",
            "type": "string"
          },
          "deviceFingerprintId": {
            "example": "1232132",
            "type": "string"
          },
          "merchantDefineData": {
            "$ref": "#/components/schemas/MerchantDefineData"
          }
        },
        "type": "object"
      },
      "Entity": {
        "description": "Can be a sender or a receiver",
        "properties": {
          "address": {
            "type": "string"
          },
          "captureType": {
            "enum": [
              "manual",
              "chip",
              "band",
              "contacless",
              "cardOnFile"
            ],
            "type": "string"
          },
          "cardAliasName": {
            "type": "string"
          },
          "cardNumber": {
            "description": "This is the card number",
            "example": "4242424242424242",
            "maxLength": 19,
            "minLength": 16,
            "title": "Card Number",
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "countryCode": {
            "type": "string"
          },
          "cvv2": {
            "example": 123,
            "maxLength": 3,
            "minLength": 3,
            "type": "string"
          },
          "expirationMonth": {
            "example": 12,
            "maximum": 12,
            "minimum": 1,
            "title": "Month",
            "type": "integer"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "reference": {
            "type": "string"
          },
          "stateCode": {
            "type": "string"
          },
          "tokenId": {
            "type": "string"
          }
        },
        "required": [
          "cardNumber",
          "expirationMonth",
          "captureType",
          "cvv2",
          "firstName",
          "lastName",
          "address",
          "city",
          "stateCode",
          "countryCode",
          "reference"
        ],
        "type": "object"
      },
      "Error": {
        "properties": {
          "errorCode": {
            "type": "integer"
          },
          "errorMessage": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "Header": {
        "properties": {
          "ecoreTransactionDate": {
            "format": "date",
            "type": "string"
          },
          "ecoreTransactionUUID": {
            "format": "guid",
            "type": "string"
          },
          "millis": {
            "format": "int32",
            "type": "integer"
          }
        },
        "required": [
          "ecoreTransactionUUID",
          "ecoreTransactionDate",
          "millis"
        ],
        "type": "object"
      },
      "Merchant": {
        "properties": {
          "address": {
            "type": "string"
          },
          "categoryCode": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "MerchantDefineData": {
        "additionalProperties": {
          "type": "string"
        }
      },
      "OCTRequest": {
        "properties": {
          "antifraud": {
            "$ref": "#/components/schemas/Antifraud"
          },
          "applicationId": {
            "example": "YAPE",
            "type": "string"
          },
          "channel": {
            "description": "Channel where transaction was originated\n",
            "enum": [
              "mobile",
              "web",
              "mpos",
              "host",
              "merchant terminalUnattended"
            ],
            "type": "string"
          },
          "dataMap": {
            "type": "object"
          },
          "merchant": {
            "$ref": "#/components/schemas/Merchant"
          },
          "order": {
            "$ref": "#/components/schemas/Order"
          },
          "recipient": {
            "$ref": "#/components/schemas/Entity"
          },
          "sender": {
            "$ref": "#/components/schemas/Entity"
          },
          "terminalId": {
            "example": "T12332",
            "type": "string"
          }
        },
        "required": [
          "channel",
          "applicationId",
          "order",
          "recipient",
          "sender"
        ],
        "type": "object"
      },
      "OCTResponse": {
        "properties": {
          "dataMap": {
            "type": "object"
          },
          "header": {
            "$ref": "#/components/schemas/Header"
          },
          "order": {
            "$ref": "#/components/schemas/Order"
          },
          "responseCode": {
            "type": "string"
          },
          "responseMessage": {
            "type": "string"
          }
        },
        "required": [
          "header",
          "responseCode",
          "responseMessage",
          "order"
        ],
        "type": "object"
      },
      "Order": {
        "description": "Order definition\n",
        "properties": {
          "actionCode": {
            "example": "00",
            "readOnly": true,
            "type": "string"
          },
          "amount": {
            "minimum": 0,
            "type": "number"
          },
          "approvalCode": {
            "example": "98765X",
            "readOnly": true,
            "type": "string"
          },
          "currency": {
            "enum": [
              "PEN",
              "USD"
            ],
            "type": "string"
          },
          "externalTransactionId": {
            "type": "string"
          },
          "purchaseNumber": {
            "example": "1234567890",
            "type": "string"
          },
          "responseCode": {
            "example": "5",
            "readOnly": true,
            "type": "string"
          },
          "transactionIdentifier": {
            "example": "587010322176104",
            "readOnly": true,
            "type": "string"
          },
          "transmissionDateTime": {
            "example": "2017-06-08T16:28:26.000Z",
            "format": "date",
            "readOnly": true,
            "type": "string"
          }
        },
        "required": [
          "purchaseNumber",
          "amount",
          "currency",
          "externalTransactionId"
        ],
        "type": "object"
      },
      "P2PRequest": {
        "properties": {
          "antifraud": {
            "$ref": "#/components/schemas/Antifraud"
          },
          "applicationId": {
            "example": "YAPE",
            "type": "string"
          },
          "channel": {
            "description": "Channel where transaction was originated\n",
            "enum": [
              "mobile",
              "web",
              "mpos",
              "host",
              "terminalUnattended"
            ],
            "type": "string"
          },
          "dataMap": {
            "type": "object"
          },
          "order": {
            "$ref": "#/components/schemas/Order"
          },
          "recipient": {
            "$ref": "#/components/schemas/Entity"
          },
          "sender": {
            "$ref": "#/components/schemas/Entity"
          },
          "terminalId": {
            "example": "T12332",
            "type": "string"
          }
        },
        "type": "object"
      },
      "P2PResponse": {
        "properties": {
          "dataMap": {
            "type": "object"
          },
          "header": {
            "$ref": "#/components/schemas/Header"
          },
          "order": {
            "$ref": "#/components/schemas/Order"
          },
          "responseCode": {
            "type": "string"
          },
          "responseMessage": {
            "type": "string"
          }
        },
        "required": [
          "header",
          "responseCode",
          "responseMessage",
          "order"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "in": "header",
        "name": "authorization",
        "type": "apiKey"
      },
      "BasicAuth": {
        "scheme": "basic",
        "type": "http"
      }
    }
  }
}