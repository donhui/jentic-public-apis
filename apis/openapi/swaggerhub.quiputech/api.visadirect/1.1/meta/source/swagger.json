{
  "swagger": "2.0",
  "info": {
    "version": "1.1",
    "title": "OCT/AFT",
    "description": "VisaNet OCT/AFT Project. Related to PET-1234",
    "x-jentic-source-url": "https://api.swaggerhub.com/apis/quiputech/api.visadirect/1.1/swagger.json"
  },
  "schemes": [
    "https"
  ],
  "securityDefinitions": {
    "BasicAuth": {
      "type": "basic"
    },
    "ApiKeyAuth": {
      "type": "apiKey",
      "in": "header",
      "name": "authorization"
    }
  },
  "host": "virtserver.swaggerhub.com",
  "basePath": "/quiputech/api.visadirect/v1",
  "produces": [
    "application/json"
  ],
  "consumes": [
    "application/json"
  ],
  "paths": {
    "/p2p/{entityId}": {
      "post": {
        "tags": [
          "P2P"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/P2PRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ok",
            "schema": {
              "$ref": "#/definitions/P2PResponse"
            }
          }
        }
      }
    },
    "/oct/{entityId}": {
      "post": {
        "tags": [
          "OCT"
        ],
        "security": [
          {
            "ApiKeyAuth": []
          }
        ],
        "parameters": [
          {
            "name": "entityId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/OCTRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ok",
            "schema": {
              "$ref": "#/definitions/OCTResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "OCTRequest": {
      "type": "object",
      "required": [
        "channel",
        "applicationId",
        "order",
        "recipient",
        "sender"
      ],
      "properties": {
        "channel": {
          "type": "string",
          "enum": [
            "mobile",
            "web",
            "mpos",
            "host",
            "merchant terminalUnattended"
          ],
          "description": "Channel where transaction was originated\n"
        },
        "terminalId": {
          "type": "string",
          "example": "T12332"
        },
        "applicationId": {
          "type": "string",
          "example": "YAPE"
        },
        "order": {
          "$ref": "#/definitions/Order"
        },
        "merchant": {
          "$ref": "#/definitions/Merchant"
        },
        "recipient": {
          "$ref": "#/definitions/Entity"
        },
        "sender": {
          "$ref": "#/definitions/Entity"
        },
        "antifraud": {
          "$ref": "#/definitions/Antifraud"
        },
        "dataMap": {
          "type": "object"
        }
      }
    },
    "OCTResponse": {
      "type": "object",
      "required": [
        "header",
        "responseCode",
        "responseMessage",
        "order"
      ],
      "properties": {
        "header": {
          "$ref": "#/definitions/Header"
        },
        "responseCode": {
          "type": "string"
        },
        "responseMessage": {
          "type": "string"
        },
        "order": {
          "$ref": "#/definitions/Order"
        },
        "dataMap": {
          "type": "object"
        }
      }
    },
    "P2PRequest": {
      "type": "object",
      "properties": {
        "channel": {
          "type": "string",
          "enum": [
            "mobile",
            "web",
            "mpos",
            "host",
            "terminalUnattended"
          ],
          "description": "Channel where transaction was originated\n"
        },
        "terminalId": {
          "type": "string",
          "example": "T12332"
        },
        "applicationId": {
          "type": "string",
          "example": "YAPE"
        },
        "order": {
          "$ref": "#/definitions/Order"
        },
        "recipient": {
          "$ref": "#/definitions/Entity"
        },
        "sender": {
          "$ref": "#/definitions/Entity"
        },
        "antifraud": {
          "$ref": "#/definitions/Antifraud"
        },
        "dataMap": {
          "type": "object"
        }
      }
    },
    "P2PResponse": {
      "type": "object",
      "required": [
        "header",
        "responseCode",
        "responseMessage",
        "order"
      ],
      "properties": {
        "header": {
          "$ref": "#/definitions/Header"
        },
        "responseCode": {
          "type": "string"
        },
        "responseMessage": {
          "type": "string"
        },
        "order": {
          "$ref": "#/definitions/Order"
        },
        "dataMap": {
          "type": "object"
        }
      }
    },
    "Header": {
      "type": "object",
      "required": [
        "ecoreTransactionUUID",
        "ecoreTransactionDate",
        "millis"
      ],
      "properties": {
        "ecoreTransactionUUID": {
          "type": "string",
          "format": "guid"
        },
        "ecoreTransactionDate": {
          "type": "string",
          "format": "date"
        },
        "millis": {
          "type": "integer",
          "format": "int32"
        }
      }
    },
    "Merchant": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "categoryCode": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      }
    },
    "Order": {
      "type": "object",
      "required": [
        "purchaseNumber",
        "amount",
        "currency",
        "externalTransactionId"
      ],
      "description": "Order definition\n",
      "properties": {
        "purchaseNumber": {
          "type": "string",
          "example": "1234567890"
        },
        "amount": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "enum": [
            "PEN",
            "USD"
          ]
        },
        "externalTransactionId": {
          "type": "string"
        },
        "transactionIdentifier": {
          "type": "string",
          "readOnly": true,
          "example": "587010322176104"
        },
        "actionCode": {
          "type": "string",
          "readOnly": true,
          "example": "00"
        },
        "approvalCode": {
          "type": "string",
          "readOnly": true,
          "example": "98765X"
        },
        "responseCode": {
          "type": "string",
          "readOnly": true,
          "example": "5"
        },
        "transmissionDateTime": {
          "type": "string",
          "format": "date",
          "readOnly": true,
          "example": "2017-06-08T16:28:26.000Z"
        }
      }
    },
    "Entity": {
      "type": "object",
      "description": "Can be a sender or a receiver",
      "required": [
        "cardNumber",
        "expirationMonth",
        "captureType",
        "cvv2",
        "firstName",
        "lastName",
        "address",
        "city",
        "stateCode",
        "countryCode",
        "reference"
      ],
      "properties": {
        "cardNumber": {
          "type": "string",
          "example": "4242424242424242",
          "title": "Card Number",
          "description": "This is the card number",
          "minLength": 16,
          "maxLength": 19
        },
        "expirationMonth": {
          "type": "integer",
          "example": 12,
          "title": "Month",
          "minimum": 1,
          "maximum": 12
        },
        "captureType": {
          "type": "string",
          "enum": [
            "manual",
            "chip",
            "band",
            "contacless",
            "cardOnFile"
          ]
        },
        "cvv2": {
          "type": "string",
          "example": 123,
          "minLength": 3,
          "maxLength": 3
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "stateCode": {
          "type": "string"
        },
        "countryCode": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        },
        "tokenId": {
          "type": "string"
        },
        "cardAliasName": {
          "type": "string"
        }
      }
    },
    "Antifraud": {
      "type": "object",
      "properties": {
        "billTo_city": {
          "type": "string",
          "example": "Lima"
        },
        "billTo_postalCode": {
          "type": "string",
          "example": "Lima 30"
        },
        "billTo_country": {
          "type": "string",
          "example": "PE"
        },
        "billTo_street1": {
          "type": "string",
          "example": "Pardo 618"
        },
        "billTo_state": {
          "type": "string",
          "example": "LI"
        },
        "deviceFingerprintId": {
          "type": "string",
          "example": "1232132"
        },
        "merchantDefineData": {
          "$ref": "#/definitions/MerchantDefineData"
        }
      }
    },
    "MerchantDefineData": {
      "additionalProperties": {
        "type": "string"
      }
    },
    "Error": {
      "type": "object",
      "properties": {
        "errorCode": {
          "type": "integer"
        },
        "errorMessage": {
          "type": "string"
        }
      }
    }
  }
}