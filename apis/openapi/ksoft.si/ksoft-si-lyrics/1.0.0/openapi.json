{
  "openapi": "3.0.3",
  "info": {
    "title": "KSoft.Si Lyrics API",
    "description": "The KSoft.Si API provides lyrics search, artist and album lookup, track metadata, and music recommendations. Search for song lyrics, browse artist discographies, and get personalized music recommendations.",
    "version": "1.0.0",
    "contact": {
      "name": "KSoft.Si",
      "url": "https://docs.ksoft.si"
    },
    "x-jentic-source-url": "https://docs.ksoft.si/api/lyrics-api"
  },
  "servers": [
    {
      "url": "https://api.ksoft.si",
      "description": "KSoft.Si API Production Server"
    }
  ],
  "tags": [
    { "name": "Lyrics", "description": "Lyrics search and metadata operations" },
    { "name": "Music", "description": "Music recommendation operations" }
  ],
  "security": [
    { "apiKeyAuth": [] }
  ],
  "paths": {
    "/lyrics/search": {
      "get": {
        "operationId": "searchLyrics",
        "summary": "Search lyrics",
        "description": "Search for song lyrics by query string. Returns matching tracks with lyrics, artist info, album info, and popularity data.",
        "tags": ["Lyrics"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "The search query for lyrics",
            "schema": { "type": "string" }
          },
          {
            "name": "text_only",
            "in": "query",
            "description": "When true, searches only within lyrics content rather than song/artist names",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results to return",
            "schema": { "type": "integer", "default": 10 }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful lyrics search results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LyricsSearchResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "No results found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LyricsSearchResponse" },
                "example": {
                  "total": 0,
                  "took": 5,
                  "data": []
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/lyrics/artist/{id}": {
      "get": {
        "operationId": "getArtist",
        "summary": "Get artist by ID",
        "description": "Retrieve artist information including their albums and tracks by artist ID.",
        "tags": ["Lyrics"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The artist ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with artist data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ArtistResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Artist not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": true, "message": "not found", "code": 404 }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/lyrics/album/{id}": {
      "get": {
        "operationId": "getAlbum",
        "summary": "Get album by ID",
        "description": "Retrieve album information including artist details and track listing by album ID.",
        "tags": ["Lyrics"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The album ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with album data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AlbumResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Album not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": true, "message": "not found", "code": 404 }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/lyrics/track/{id}": {
      "get": {
        "operationId": "getTrack",
        "summary": "Get track by ID",
        "description": "Retrieve track information including artist, album details, and lyrics content by track ID.",
        "tags": ["Lyrics"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "The track ID",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with track data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TrackResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Track not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": true, "message": "not found", "code": 404 }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    },
    "/music/recommendations": {
      "post": {
        "operationId": "getMusicRecommendations",
        "summary": "Get music recommendations",
        "description": "Get personalized music recommendations based on input tracks. Supports YouTube and Spotify as providers.",
        "tags": ["Music"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecommendationRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful recommendation results",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecommendationResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "500": { "$ref": "#/components/responses/InternalServerError" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key for authentication. Format: 'Bearer <your-api-key>'"
      }
    },
    "schemas": {
      "LyricsTrack": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Track ID" },
          "name": { "type": "string", "description": "Track name" },
          "artist": { "type": "string", "description": "Artist name" },
          "artist_id": { "type": "integer", "description": "Artist ID" },
          "album": { "type": "string", "description": "Album name" },
          "album_id": { "type": "integer", "description": "Album ID" },
          "album_year": { "type": "string", "description": "Album release year" },
          "lyrics": { "type": "string", "description": "Full lyrics text" },
          "search_score": { "type": "number", "description": "Search relevance score" },
          "url": { "type": "string", "format": "uri", "description": "URL to the lyrics page" }
        }
      },
      "LyricsSearchResponse": {
        "type": "object",
        "properties": {
          "total": { "type": "integer", "description": "Total number of matching results" },
          "took": { "type": "integer", "description": "Query time in milliseconds" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/LyricsTrack" },
            "description": "List of matching tracks with lyrics"
          }
        }
      },
      "ArtistResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Artist ID" },
          "name": { "type": "string", "description": "Artist name" },
          "albums": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AlbumSummary" },
            "description": "List of albums by the artist"
          },
          "tracks": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TrackSummary" },
            "description": "List of tracks by the artist"
          }
        }
      },
      "AlbumSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Album ID" },
          "name": { "type": "string", "description": "Album name" },
          "year": { "type": "string", "description": "Release year" }
        }
      },
      "TrackSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Track ID" },
          "name": { "type": "string", "description": "Track name" },
          "album_id": { "type": "integer", "description": "Album ID" }
        }
      },
      "AlbumResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Album ID" },
          "name": { "type": "string", "description": "Album name" },
          "year": { "type": "string", "description": "Release year" },
          "artist": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          },
          "tracks": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TrackSummary" },
            "description": "List of tracks in the album"
          }
        }
      },
      "TrackResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "Track ID" },
          "name": { "type": "string", "description": "Track name" },
          "artist": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          },
          "albums": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AlbumSummary" }
          },
          "lyrics": { "type": "string", "description": "Full lyrics content" },
          "url": { "type": "string", "format": "uri", "description": "URL to the lyrics page" }
        }
      },
      "RecommendationRequest": {
        "type": "object",
        "required": ["tracks", "recommend_type", "provider"],
        "properties": {
          "tracks": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Input tracks as a list of identifiers"
          },
          "youtube_token": {
            "type": "string",
            "description": "YouTube v3 API token (optional, for YouTube provider)"
          },
          "limit": {
            "type": "integer",
            "default": 5,
            "minimum": 1,
            "maximum": 5,
            "description": "Number of recommendations to return (1-5)"
          },
          "recommend_type": {
            "type": "string",
            "enum": ["track", "youtube_link", "youtube_id"],
            "description": "Type of recommendation output"
          },
          "provider": {
            "type": "string",
            "enum": ["youtube", "youtube_ids", "youtube_titles", "spotify"],
            "description": "Music provider for recommendations"
          }
        }
      },
      "RecommendationTrack": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Track name" },
          "artist": { "type": "string", "description": "Artist name" },
          "youtube_link": { "type": "string", "format": "uri", "description": "YouTube video URL" },
          "youtube_id": { "type": "string", "description": "YouTube video ID" },
          "spotify_id": { "type": "string", "description": "Spotify track ID" }
        }
      },
      "RecommendationResponse": {
        "type": "object",
        "properties": {
          "provider": { "type": "string", "description": "Provider used for recommendations" },
          "total": { "type": "integer", "description": "Number of recommendations returned" },
          "tracks": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RecommendationTrack" },
            "description": "List of recommended tracks"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "boolean", "description": "Whether an error occurred", "example": true },
          "message": { "type": "string", "description": "Error message" },
          "code": { "type": "integer", "description": "HTTP status code" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request - missing or invalid parameters",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": true, "message": "Missing required parameter", "code": 400 }
          }
        }
      },
      "Unauthorized": {
        "description": "Unauthorized - invalid or missing API key",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": true, "message": "Unauthorized", "code": 401 }
          }
        }
      },
      "InternalServerError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": { "error": true, "message": "Internal server error", "code": 500 }
          }
        }
      }
    }
  }
}
