        "operationId": "lookupArtist",
        "summary": "Look up an artist by MBID",
        "tags": [
          "Lookup"
        ],
        "parameters": [
          {
            "name": "mbid",
            "in": "path",
            "required": true,
            "description": "MusicBrainz identifier",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "$ref": "#/components/parameters/IncParam"
          },
          {
            "$ref": "#/components/parameters/FmtParam"
          }
        ],
        "responses": {
          "200": {
            "description": "Artist entity",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Artist"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "description": "Entity not found"
          },
          "401": {
            "description": "Unauthorized"
