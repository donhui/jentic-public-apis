    "/tag": {
      "post": {
        "operationId": "submitTags",
        "summary": "Submit user tags/genres",
        "tags": [
          "Submissions"
        ],
        "security": [
          {
            "digestAuth": []
          }
        ],
        "parameters": [
          {
            "name": "client",
            "in": "query",
            "required": true,
            "description": "Application client identifier",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/xml": {
              "schema": {
                "type": "string",
                "description": "XML metadata with user-tag-list elements"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tags submitted successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
