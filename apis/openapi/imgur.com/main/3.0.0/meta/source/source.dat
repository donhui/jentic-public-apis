    },
    "/gallery/{section}/{sort}/{window}/{page}": {
      "get": {
        "tags": ["Gallery"],
        "summary": "Browse gallery",
        "description": "Returns the images in the gallery.",
        "operationId": "getGallery",
        "parameters": [
          {
            "name": "section",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["hot", "top", "user"],
              "default": "hot"
            }
          },
          {
            "name": "sort",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["viral", "top", "time", "rising"],
              "default": "viral"
            }
          },
          {
            "name": "window",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["day", "week", "month", "year", "all"],
              "default": "day"
            }
          },
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "showViral",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "mature",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Gallery items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/GalleryItem"
                      }
                    },
                    "success": {
                      "type": "boolean"
                    },
                    "status": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "clientId": []
          }
        ]
      }
    },
    "/gallery/search/{sort}/{window}/{page}": {
      "get": {
        "tags": ["Gallery"],
        "summary": "Search gallery",
        "description": "Search the gallery with a given query string.",
        "operationId": "searchGallery",
        "parameters": [
          {
            "name": "sort",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["time", "viral", "top"],
              "default": "time"
            }
          },
          {
            "name": "window",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": ["all", "day", "week", "month", "year"]
            }
          },
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Query string"
          },
          {
            "name": "q_type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["jpg", "png", "gif", "anigif", "album"]
            }
          },
          {
            "name": "q_size_px",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["small", "med", "big", "lrg", "huge"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/GalleryItem"
                      }
                    },
                    "success": {
                      "type": "boolean"
                    },
                    "status": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "clientId": []
          }
        ]
      }
    },
