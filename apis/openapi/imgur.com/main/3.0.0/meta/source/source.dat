    "/gallery/{galleryHash}/comment": {
      "post": {
        "tags": ["Comment"],
        "summary": "Create a comment",
        "description": "Create a comment on a gallery item.",
        "operationId": "createComment",
        "parameters": [
          {
            "name": "galleryHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
