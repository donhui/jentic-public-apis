{
  "openapi": "3.0.3",
  "info": {
    "title": "Imgur API",
    "description": "The Imgur API provides programmatic access to the Imgur image hosting platform. Upload, manage, and share images and albums. Supports OAuth 2.0 for user-authenticated actions and client ID for anonymous operations.",
    "version": "3.0.0",
    "contact": {
      "name": "Imgur",
      "url": "https://imgur.com"
    },
    "termsOfService": "https://imgur.com/tos",
    "x-jentic-source-url": "https://apidocs.imgur.com/"
  },
  "servers": [
    {
      "url": "https://api.imgur.com/3",
      "description": "Imgur API v3 production server"
    }
  ],
  "tags": [
    {
      "name": "Account",
      "description": "Account-related operations"
    },
    {
      "name": "Image",
      "description": "Image upload and management"
    },
    {
      "name": "Album",
      "description": "Album management operations"
    },
    {
      "name": "Gallery",
      "description": "Gallery browsing and interaction"
    },
    {
      "name": "Comment",
      "description": "Comment operations"
    }
  ],
  "paths": {
    "/image": {
      "post": {
        "tags": ["Image"],
        "summary": "Upload an image",
        "description": "Upload a new image. You can upload via file, URL, or base64-encoded data.",
        "operationId": "uploadImage",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "description": "A binary file, base64 data, or a URL for an image. (up to 10MB for images, 200MB for GIFs)"
                  },
                  "album": {
                    "type": "string",
                    "description": "The deletehash of the album to add the image to (for anonymous albums)"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["file", "base64", "URL"],
                    "description": "The type of the file being sent"
                  },
                  "name": {
                    "type": "string",
                    "description": "The name of the file"
                  },
                  "title": {
                    "type": "string",
                    "description": "The title of the image"
                  },
                  "description": {
                    "type": "string",
                    "description": "The description of the image"
                  },
                  "disable_audio": {
                    "type": "integer",
                    "enum": [0, 1],
                    "description": "Set to 1 to remove audio from video files"
                  }
                },
                "required": ["image"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image uploaded successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - user banned or capacity exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "clientId": []
          },
          {
            "oauth2": []
          }
        ]
      }
    },
    "/image/{imageHash}": {
      "get": {
        "tags": ["Image"],
        "summary": "Get image information",
        "description": "Get information about an image.",
        "operationId": "getImage",
        "parameters": [
          {
            "name": "imageHash",
            "in": "path",
            "required": true,
            "description": "The ID or deletehash of the image",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Image information retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Image not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "clientId": []
          }
        ]
      },
      "post": {
        "tags": ["Image"],
        "summary": "Update image information",
        "description": "Update the title or description of an image.",
        "operationId": "updateImage",
        "parameters": [
          {
            "name": "imageHash",
            "in": "path",
            "required": true,
            "description": "The ID or deletehash of the image",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "The title of the image"
                  },
                  "description": {
                    "type": "string",
                    "description": "The description of the image"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasicResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Image not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": []
          }
        ]
      },
      "delete": {
        "tags": ["Image"],
        "summary": "Delete an image",
        "description": "Delete an image. For an anonymous image, use the deletehash. For an account image, use the image ID and authenticate.",
        "operationId": "deleteImage",
        "parameters": [
          {
            "name": "imageHash",
            "in": "path",
            "required": true,
            "description": "The ID or deletehash of the image",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Image deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasicResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Image not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "clientId": []
          },
          {
            "oauth2": []
          }
        ]
      }
    },
    "/image/{imageHash}/favorite": {
      "post": {
        "tags": ["Image"],
        "summary": "Favorite an image",
        "description": "Favorite an image with the given ID. Requires user authentication.",
        "operationId": "favoriteImage",
        "parameters": [
          {
            "name": "imageHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Image favorited/unfavorited",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasicResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": []
          }
        ]
      }
    },
    "/album/{albumHash}": {
      "get": {
        "tags": ["Album"],
        "summary": "Get album information",
        "description": "Get information about a specific album.",
        "operationId": "getAlbum",
        "parameters": [
          {
            "name": "albumHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Album information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlbumResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Album not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "clientId": []
          }
        ]
      },
      "put": {
        "tags": ["Album"],
        "summary": "Update album",
        "description": "Update the information of an album.",
        "operationId": "updateAlbum",
        "parameters": [
          {
            "name": "albumHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Image IDs to set as album contents"
                  },
                  "deletehashes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Deletehashes for anonymous images"
                  },
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "privacy": {
                    "type": "string",
                    "enum": ["public", "hidden", "secret"]
                  },
                  "cover": {
                    "type": "string",
                    "description": "Image ID to use as album cover"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Album updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasicResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Album not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": []
          }
        ]
      },
      "delete": {
        "tags": ["Album"],
        "summary": "Delete album",
        "description": "Delete an album with a given ID or deletehash.",
        "operationId": "deleteAlbum",
        "parameters": [
          {
            "name": "albumHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Album deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasicResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Album not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": []
          }
        ]
      }
    },
    "/album": {
      "post": {
        "tags": ["Album"],
        "summary": "Create album",
        "description": "Create a new album.",
        "operationId": "createAlbum",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Image IDs to add to the album"
                  },
                  "deletehashes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Deletehashes of anonymous images to add"
                  },
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "privacy": {
                    "type": "string",
                    "enum": ["public", "hidden", "secret"]
                  },
                  "cover": {
                    "type": "string",
                    "description": "Image ID to use as album cover"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Album created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "deletehash": {
                          "type": "string"
                        }
                      }
                    },
                    "success": {
                      "type": "boolean"
                    },
                    "status": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "clientId": []
          },
          {
            "oauth2": []
          }
        ]
      }
    },
    "/album/{albumHash}/images": {
      "get": {
        "tags": ["Album"],
        "summary": "Get album images",
        "description": "Get all images in an album.",
        "operationId": "getAlbumImages",
        "parameters": [
          {
            "name": "albumHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Album images",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Image"
                      }
                    },
                    "success": {
                      "type": "boolean"
                    },
                    "status": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Album not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "clientId": []
          }
        ]
      }
    },
    "/album/{albumHash}/add": {
      "post": {
        "tags": ["Album"],
        "summary": "Add images to album",
        "description": "Add images to an existing album.",
        "operationId": "addImagesToAlbum",
        "parameters": [
          {
            "name": "albumHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "deletehashes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Images added",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasicResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": []
          }
        ]
      }
    },
    "/album/{albumHash}/remove_images": {
      "post": {
        "tags": ["Album"],
        "summary": "Remove images from album",
        "description": "Remove images from an album.",
        "operationId": "removeImagesFromAlbum",
        "parameters": [
          {
            "name": "albumHash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": ["ids"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Images removed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BasicResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": []
          }
        ]
      }
    },
    "/account/{username}": {
      "get": {
        "tags": ["Account"],
        "summary": "Get account info",
        "description": "Request standard user information. If you need the username for the account that is logged in, use 'me' as the username.",
        "operationId": "getAccount",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Username or 'me' for authenticated user"
          }
        ],
        "responses": {
          "200": {
            "description": "Account information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountResponse"
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "clientId": []
          }
        ]
      }
    },
    "/account/{username}/images": {
      "get": {
        "tags": ["Account"],
        "summary": "Get account images",
        "description": "Get all images for the authenticated account. Use 'me' for the logged-in user.",
        "operationId": "getAccountImages",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User images",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Image"
                      }
                    },
                    "success": {
                      "type": "boolean"
                    },
                    "status": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "security": [
          {
            "oauth2": []
          }
        ]
      }
    },
    "/account/{username}/albums": {
      "get": {
        "tags": ["Account"],
        "summary": "Get account albums",
        "description": "Get all albums for the specified account.",
        "operationId": "getAccountAlbums",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Account albums",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Album"
                      }
                    },
                    "success": {
                      "type": "boolean"
                    },
                    "status": {
                      "type": "integer"
                    }
                  }
