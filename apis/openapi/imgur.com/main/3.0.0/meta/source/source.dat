  "components": {
    "securitySchemes": {
      "clientId": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header",
        "description": "Client ID authentication. Pass as 'Client-ID {your_client_id}'"
      },
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth 2.0 authentication for user-specific actions",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://api.imgur.com/oauth2/authorize",
            "tokenUrl": "https://api.imgur.com/oauth2/token",
            "scopes": {}
          },
          "implicit": {
            "authorizationUrl": "https://api.imgur.com/oauth2/authorize",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "Image": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The ID for the image"
          },
          "title": {
            "type": "string",
            "nullable": true,
            "description": "The title of the image"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Description of the image"
          },
          "datetime": {
            "type": "integer",
            "description": "Time inserted into the gallery (epoch time)"
          },
          "type": {
            "type": "string",
            "description": "Image MIME type"
          },
          "animated": {
            "type": "boolean",
            "description": "Is the image animated"
          },
          "width": {
            "type": "integer",
            "description": "The width of the image in pixels"
          },
          "height": {
            "type": "integer",
            "description": "The height of the image in pixels"
          },
          "size": {
            "type": "integer",
            "description": "The size of the image in bytes"
          },
          "views": {
            "type": "integer",
            "description": "The number of image views"
          },
          "bandwidth": {
            "type": "integer",
            "description": "Bandwidth consumed by the image in bytes"
          },
          "deletehash": {
            "type": "string",
            "description": "Deletehash for anonymous delete"
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "The direct link to the image"
          },
          "favorite": {
            "type": "boolean"
          },
          "nsfw": {
            "type": "boolean",
            "nullable": true
          },
          "section": {
            "type": "string",
            "nullable": true
          },
          "account_url": {
            "type": "string",
            "nullable": true
          },
          "account_id": {
            "type": "integer",
            "nullable": true
          },
          "in_most_viral": {
            "type": "boolean"
          }
        }
      },
      "Album": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "datetime": {
            "type": "integer"
          },
          "cover": {
            "type": "string",
            "description": "The ID of the album cover image"
          },
          "cover_width": {
            "type": "integer"
          },
          "cover_height": {
            "type": "integer"
          },
          "account_url": {
            "type": "string",
            "nullable": true
          },
          "account_id": {
            "type": "integer",
            "nullable": true
          },
          "privacy": {
            "type": "string",
            "enum": ["public", "hidden", "secret"]
          },
          "layout": {
            "type": "string"
          },
          "views": {
            "type": "integer"
          },
          "link": {
            "type": "string",
            "format": "uri"
          },
          "favorite": {
            "type": "boolean"
          },
          "nsfw": {
            "type": "boolean",
            "nullable": true
          },
          "images_count": {
            "type": "integer"
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Image"
            }
          },
          "deletehash": {
            "type": "string"
          }
        }
      },
      "GalleryItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "datetime": {
            "type": "integer"
          },
          "type": {
            "type": "string"
          },
          "animated": {
            "type": "boolean"
          },
          "width": {
            "type": "integer"
          },
          "height": {
            "type": "integer"
          },
          "size": {
            "type": "integer"
          },
          "views": {
            "type": "integer"
          },
          "bandwidth": {
            "type": "integer"
          },
          "link": {
            "type": "string",
            "format": "uri"
          },
          "ups": {
            "type": "integer"
          },
          "downs": {
            "type": "integer"
          },
          "points": {
            "type": "integer"
          },
          "score": {
            "type": "integer"
          },
          "is_album": {
            "type": "boolean"
          },
          "vote": {
            "type": "string",
            "nullable": true
          },
          "favorite": {
            "type": "boolean"
          },
          "nsfw": {
            "type": "boolean"
          },
          "comment_count": {
            "type": "integer"
          },
          "topic": {
            "type": "string",
            "nullable": true
          },
          "topic_id": {
            "type": "integer",
            "nullable": true
          },
          "account_url": {
            "type": "string"
          },
          "account_id": {
            "type": "integer"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "display_name": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "image_id": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "author_id": {
            "type": "integer"
          },
          "on_album": {
            "type": "boolean"
          },
          "album_cover": {
            "type": "string",
            "nullable": true
          },
          "ups": {
            "type": "integer"
          },
          "downs": {
            "type": "integer"
          },
          "points": {
            "type": "number"
          },
          "datetime": {
            "type": "integer"
          },
          "parent_id": {
            "type": "integer"
          },
          "deleted": {
            "type": "boolean"
          },
          "vote": {
            "type": "string",
            "nullable": true
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Comment"
            }
          }
        }
      },
      "ImageUploadResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Image"
          },
          "success": {
            "type": "boolean"
          },
          "status": {
            "type": "integer"
          }
        }
      },
      "ImageResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Image"
          },
          "success": {
            "type": "boolean"
          },
          "status": {
            "type": "integer"
          }
        }
      },
      "AlbumResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Album"
          },
          "success": {
            "type": "boolean"
          },
          "status": {
            "type": "integer"
          }
        }
      },
      "AccountResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "url": {
                "type": "string"
              },
              "bio": {
                "type": "string",
                "nullable": true
              },
              "avatar": {
                "type": "string"
              },
              "avatar_name": {
                "type": "string"
              },
              "cover": {
                "type": "string"
              },
              "cover_name": {
                "type": "string"
              },
              "reputation": {
                "type": "number"
              },
              "reputation_name": {
                "type": "string"
              },
              "created": {
                "type": "integer"
              },
              "pro_expiration": {
                "type": "boolean"
              },
              "user_follow": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "boolean"
                  }
                }
              }
            }
          },
          "success": {
            "type": "boolean"
          },
          "status": {
            "type": "integer"
          }
        }
      },
      "BasicResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "boolean"
          },
          "success": {
            "type": "boolean"
          },
          "status": {
            "type": "integer"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "error": {
                "type": "string",
                "description": "Error message"
              },
              "request": {
                "type": "string",
                "description": "The request URI"
              },
              "method": {
                "type": "string",
                "description": "The request method"
              }
            }
          },
          "success": {
            "type": "boolean",
            "example": false
          },
          "status": {
            "type": "integer",
            "description": "HTTP status code"
          }
        }
      }
    }
  }
}
