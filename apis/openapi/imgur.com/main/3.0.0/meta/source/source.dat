                        "UserLimit": {
                          "type": "integer"
                        },
                        "UserRemaining": {
                          "type": "integer"
                        },
                        "UserReset": {
                          "type": "integer"
                        },
                        "ClientLimit": {
                          "type": "integer"
                        },
                        "ClientRemaining": {
                          "type": "integer"
                        }
                      }
