    "/account/{username}/favorites": {
      "get": {
        "tags": ["Account"],
        "summary": "Get account favorites",
        "description": "Returns the users favorited images.",
        "operationId": "getAccountFavorites",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "favoritesSort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["oldest", "newest"],
              "default": "newest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Favorited images",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Image"
                      }
                    },
                    "success": {
                      "type": "boolean"
                    },
                    "status": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
