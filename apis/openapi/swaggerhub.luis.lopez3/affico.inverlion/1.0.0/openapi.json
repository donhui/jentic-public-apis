{
    "openapi": "3.0.0",
    "info": {
        "version": "1.0.0",
        "title": "Affico Inverlion API",
        "description": "baseURL: https://affico.inverlion.com:5056/",
        "x-jentic-source-url": "https://api.swaggerhub.com/apis/luis.lopez3/Affico.Inverlion/1.0.0/swagger.json"
    },
    "paths": {
        "/auth": {
            "post": {
                "description": "Endpoint to get authoritation token",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "PartnerId",
                                    "SecretKey",
                                    "Time",
                                    "Sign"
                                ],
                                "properties": {
                                    "PartnerId": {
                                        "type": "integer",
                                        "description": "Id provided by us"
                                    },
                                    "SecretKey": {
                                        "type": "string",
                                        "description": "Token provided by us"
                                    },
                                    "Time": {
                                        "type": "string",
                                        "description": "Unix timeStamp"
                                    },
                                    "Sign": {
                                        "type": "string",
                                        "description": "SHA256(PartnerId + Time + Secret_Key)"
                                    }
                                }
                            }
                        }
                    },
                    "description": "affiliate information provided by us"
                },
                "responses": {
                    "200": {
                        "description": "Successfully created an auth token",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "token": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "error": {
                                            "type": "string",
                                            "default": ""
                                        },
                                        "result": {
                                            "type": "integer",
                                            "default": 1
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/create": {
            "post": {
                "description": "Endpoint to create a client",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "description": "a bearer authorization header",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "default": "Bearer + token"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "firstName",
                                    "lastName",
                                    "email",
                                    "country",
                                    "phoneNumber",
                                    "phoneCountryCode",
                                    "referral",
                                    "password"
                                ],
                                "properties": {
                                    "firstName": {
                                        "type": "string"
                                    },
                                    "lastName": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string",
                                        "description": "minlength 8, maxlength 15, at least one number, lowercase and capital letter"
                                    },
                                    "country": {
                                        "type": "string",
                                        "description": "ISO alpha-2 code"
                                    },
                                    "phoneNumber": {
                                        "type": "string",
                                        "description": "max lenght 10"
                                    },
                                    "phoneCountryCode": {
                                        "type": "string",
                                        "description": "phone country code with + included"
                                    },
                                    "referral": {
                                        "type": "string",
                                        "description": "campaign where customer came from"
                                    },
                                    "source": {
                                        "type": "string",
                                        "description": "page where customer came from"
                                    }
                                }
                            }
                        }
                    },
                    "description": "Client information to create a client"
                },
                "responses": {
                    "200": {
                        "description": "Customer successfully created",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "crmId": {
                                                    "type": "string"
                                                },
                                                "tpId": {
                                                    "type": "string"
                                                },
                                                "autologinUrl": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "error": {
                                            "type": "string",
                                            "default": ""
                                        },
                                        "result": {
                                            "type": "integer",
                                            "default": 1
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/get/Multiple": {
            "get": {
                "description": "Shows all customers inserted in a range of dates",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "description": "an bearer authorization header",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "default": "Bearer + token"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "pagination number",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "startDate",
                        "in": "query",
                        "description": "start date for range in format YYYY-MM-DD",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "endDate",
                        "in": "query",
                        "description": "end date for range in format YYYY-MM-DD",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "rows",
                        "in": "query",
                        "description": "number of records you want to read",
                        "schema": {
                            "type": "integer",
                            "default": 500
                        }
                    },
                    {
                        "name": "onlyFtd",
                        "in": "query",
                        "description": "boolean to get only ftds or get every lead",
                        "schema": {
                            "type": "boolean"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "shows customers",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "country": {
                                                        "type": "string"
                                                    },
                                                    "crmId": {
                                                        "type": "string"
                                                    },
                                                    "email": {
                                                        "type": "string"
                                                    },
                                                    "firstName": {
                                                        "type": "string"
                                                    },
                                                    "ftd": {
                                                        "type": "integer"
                                                    },
                                                    "ftdDate": {
                                                        "type": "string",
                                                        "description": "date in format YYYY-MM-DD HH:mm:SS"
                                                    },
                                                    "insertDate": {
                                                        "type": "string",
                                                        "description": "date in format YYYY-MM-DD HH:mm:SS"
                                                    },
                                                    "lastName": {
                                                        "type": "string"
                                                    },
                                                    "referral": {
                                                        "type": "string"
                                                    },
                                                    "source": {
                                                        "type": "string"
                                                    },
                                                    "status": {
                                                        "type": "string"
                                                    },
                                                    "tpId": {
                                                        "type": "string"
                                                    }
                                                }
                                            }
                                        },
                                        "error": {
                                            "type": "string",
                                            "default": ""
                                        },
                                        "result": {
                                            "type": "integer",
                                            "default": 1
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/get/Single": {
            "get": {
                "description": "Show customer information",
                "parameters": [
                    {
                        "name": "Authorization",
                        "in": "header",
                        "description": "an bearer authorization header",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "default": "Bearer + token"
                        }
                    },
                    {
                        "name": "email",
                        "in": "query",
                        "description": "Customer's email",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "customer information",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "country": {
                                                    "type": "string"
                                                },
                                                "crmId": {
                                                    "type": "string"
                                                },
                                                "email": {
                                                    "type": "string"
                                                },
                                                "firstName": {
                                                    "type": "string"
                                                },
                                                "ftd": {
                                                    "type": "integer"
                                                },
                                                "ftdDate": {
                                                    "type": "string",
                                                    "description": "date in format YYYY-MM-DD HH:mm:SS"
                                                },
                                                "insertDate": {
                                                    "type": "string",
                                                    "description": "date in format YYYY-MM-DD HH:mm:SS"
                                                },
                                                "lastName": {
                                                    "type": "string"
                                                },
                                                "referral": {
                                                    "type": "string"
                                                },
                                                "source": {
                                                    "type": "string"
                                                },
                                                "status": {
                                                    "type": "string"
                                                },
                                                "tpId": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "error": {
                                            "type": "string",
                                            "default": ""
                                        },
                                        "result": {
                                            "type": "integer",
                                            "default": 1
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://affico.inverlion.com:5056"
        }
    ]
}