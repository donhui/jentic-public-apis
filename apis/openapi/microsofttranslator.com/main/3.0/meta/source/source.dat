{
  "openapi": "3.0.3",
  "info": {
    "title": "Azure Translator",
    "description": "Azure Translator is a cloud-based machine translation service. Version 3.0 provides a modern JSON-based Web API with text translation, transliteration, language detection, sentence breaking, and dictionary operations.",
    "version": "3.0",
    "x-jentic-source-url": "https://learn.microsoft.com/en-us/azure/ai-services/translator/"
  },
  "servers": [
    {
      "url": "https://api.cognitive.microsofttranslator.com",
      "description": "Global endpoint (recommended)"
    },
    {
      "url": "https://api-nam.cognitive.microsofttranslator.com",
      "description": "Americas endpoint"
    },
    {
      "url": "https://api-eur.cognitive.microsofttranslator.com",
      "description": "Europe endpoint"
    },
    {
      "url": "https://api-apc.cognitive.microsofttranslator.com",
      "description": "Asia Pacific endpoint"
    }
  ],
  "security": [
    {
      "subscriptionKey": []
    }
  ],
  "paths": {
    "/translate": {
      "post": {
        "operationId": "translateText",
        "summary": "Translate text",
        "description": "Translates text from one language to one or more other languages.",
        "tags": ["Translation"],
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "description": "Specifies the language of the output text. May be repeated for multiple target languages (e.g., to=de&to=it).",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "from",
            "in": "query",
            "description": "Specifies the language of the input text. If omitted, automatic language detection is applied.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "textType",
            "in": "query",
            "description": "Defines whether the text is plain text or HTML.",
            "schema": {
              "type": "string",
              "enum": ["plain", "html"],
              "default": "plain"
            }
          },
          {
            "name": "category",
            "in": "query",
            "description": "A string specifying the category (domain) of the translation. Default is 'general'.",
            "schema": {
              "type": "string",
              "default": "general"
            }
          },
          {
            "name": "profanityAction",
            "in": "query",
            "description": "Specifies how profanities should be treated.",
            "schema": {
              "type": "string",
              "enum": ["NoAction", "Marked", "Deleted"],
              "default": "NoAction"
            }
          },
          {
            "name": "profanityMarker",
            "in": "query",
            "description": "Specifies how profanities should be marked.",
            "schema": {
              "type": "string",
              "enum": ["Asterisk", "Tag"],
              "default": "Asterisk"
            }
          },
          {
            "name": "includeAlignment",
            "in": "query",
            "description": "Include alignment projection from source text to translated text.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "includeSentenceLength",
            "in": "query",
            "description": "Include sentence boundaries for the input and translated text.",
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "suggestedFrom",
            "in": "query",
            "description": "Fallback language if the language of the input text cannot be identified.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromScript",
            "in": "query",
            "description": "Specifies the script of the input text.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toScript",
            "in": "query",
            "description": "Specifies the script of the translated text.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "allowFallback",
            "in": "query",
            "description": "Allow fallback to a general system when a custom system does not exist.",
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInputArray"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful translation.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TranslationResult"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "description": "The request is not authorized. Check the details error message.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/detect": {
      "post": {
        "operationId": "detectLanguage",
        "summary": "Detect language",
        "description": "Identifies the language of a piece of text.",
        "tags": ["Detection"],
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInputArray"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully detected languages.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DetectResult"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/languages": {
      "get": {
        "operationId": "getLanguages",
        "summary": "Get supported languages",
        "description": "Gets the set of languages currently supported by other operations of the Translator.",
        "tags": ["Languages"],
        "security": [],
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "name": "scope",
            "in": "query",
            "description": "Comma-separated list of group names: translation, transliteration, dictionary.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "description": "The language to use for user interface strings (BCP 47 tag).",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Supported languages returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LanguagesResult"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "429": {
            "description": "Rate limit exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transliterate": {
      "post": {
        "operationId": "transliterateText",
        "summary": "Transliterate text",
        "description": "Converts text in one language from one script to another script.",
        "tags": ["Transliteration"],
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "name": "language",
            "in": "query",
            "required": true,
            "description": "Specifies the language of the text to convert.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fromScript",
            "in": "query",
            "required": true,
            "description": "Specifies the script used by the input text.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "toScript",
            "in": "query",
            "required": true,
            "description": "Specifies the output script.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInputArray"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful transliteration.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TransliterationResult"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/breaksentence": {
      "post": {
        "operationId": "breakSentence",
        "summary": "Break sentence",
        "description": "Identifies the positioning of sentence boundaries in a piece of text.",
        "tags": ["Sentence"],
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "name": "language",
            "in": "query",
            "description": "Language tag identifying the language of the input text.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "script",
            "in": "query",
            "description": "Script tag identifying the script used by the input text.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInputArray"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sentence boundaries returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BreakSentenceResult"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/dictionary/lookup": {
      "post": {
        "operationId": "dictionaryLookup",
        "summary": "Dictionary lookup",
        "description": "Provides alternative translations for a word and a few idiomatic phrases.",
        "tags": ["Dictionary"],
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "name": "from",
            "in": "query",
            "required": true,
            "description": "Specifies the language of the input text.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "description": "Specifies the language of the output text.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextInputArray"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dictionary lookup results.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DictionaryLookupResult"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/dictionary/examples": {
      "post": {
        "operationId": "dictionaryExamples",
        "summary": "Dictionary examples",
        "description": "Provides examples that show how terms in the dictionary are used in context.",
        "tags": ["Dictionary"],
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiVersion"
          },
          {
            "name": "from",
            "in": "query",
            "required": true,
            "description": "Specifies the language of the input text.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "to",
            "in": "query",
            "required": true,
            "description": "Specifies the language of the output text.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/DictionaryExampleInput"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Dictionary examples returned.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DictionaryExampleResult"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "subscriptionKey": {
        "type": "apiKey",
        "in": "header",
        "name": "Ocp-Apim-Subscription-Key",
        "description": "Azure subscription key for the Translator resource."
      }
    },
    "parameters": {
      "ApiVersion": {
        "name": "api-version",
        "in": "query",
        "required": true,
        "description": "Version of the API requested by the client. Value must be 3.0.",
        "schema": {
          "type": "string",
          "enum": ["3.0"],
          "default": "3.0"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "One of the query parameters is missing or not valid.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "The request could not be authenticated. Check that credentials are specified and valid.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "integer",
                "description": "6-digit error code combining the 3-digit HTTP status code and a 3-digit categorization number."
              },
              "message": {
                "type": "string",
                "description": "A human-readable description of the error."
              }
            }
          }
        }
      },
      "TextInput": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "The text string to process."
          }
        }
      },
      "TextInputArray": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/TextInput"
        },
        "description": "Array of text objects to process."
      },
      "TranslationResult": {
        "type": "object",
        "properties": {
          "detectedLanguage": {
            "$ref": "#/components/schemas/DetectedLanguage"
          },
          "translations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Translation"
            }
          },
          "sourceText": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              }
            }
          }
        }
      },
      "DetectedLanguage": {
        "type": "object",
        "properties": {
          "language": {
            "type": "string",
            "description": "Code of the detected language."
          },
          "score": {
            "type": "number",
            "format": "float",
            "description": "Confidence score between 0 and 1."
          }
        }
      },
      "Translation": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
            "description": "Language code of the target language."
          },
          "text": {
            "type": "string",
            "description": "The translated text."
          },
          "transliteration": {
            "type": "object",
            "properties": {
              "script": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          },
          "alignment": {
            "type": "object",
            "properties": {
              "proj": {
                "type": "string"
              }
            }
          },
          "sentLen": {
            "type": "object",
            "properties": {
              "srcSentLen": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              },
              "transSentLen": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "DetectResult": {
        "type": "object",
        "properties": {
          "language": {
            "type": "string",
            "description": "Code of the detected language."
          },
          "score": {
            "type": "number",
            "format": "float",
            "description": "Confidence score between 0 and 1."
          },
          "isTranslationSupported": {
            "type": "boolean"
          },
          "isTransliterationSupported": {
            "type": "boolean"
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "language": {
                  "type": "string"
                },
                "score": {
                  "type": "number",
                  "format": "float"
                },
                "isTranslationSupported": {
                  "type": "boolean"
                },
                "isTransliterationSupported": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      },
      "LanguagesResult": {
        "type": "object",
        "properties": {
          "translation": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/LanguageInfo"
            }
          },
          "transliteration": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/TransliterationLanguageInfo"
            }
          },
          "dictionary": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/DictionaryLanguageInfo"
            }
          }
        }
      },
      "LanguageInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "nativeName": {
            "type": "string"
          },
          "dir": {
            "type": "string",
            "enum": ["ltr", "rtl"]
          }
        }
      },
      "TransliterationLanguageInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "nativeName": {
            "type": "string"
          },
          "scripts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "nativeName": {
                  "type": "string"
                },
                "dir": {
                  "type": "string",
                  "enum": ["ltr", "rtl"]
                },
                "toScripts": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "code": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      },
                      "nativeName": {
                        "type": "string"
                      },
                      "dir": {
                        "type": "string",
                        "enum": ["ltr", "rtl"]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "DictionaryLanguageInfo": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "nativeName": {
            "type": "string"
          },
          "dir": {
            "type": "string",
            "enum": ["ltr", "rtl"]
          },
          "translations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "nativeName": {
                  "type": "string"
                },
                "dir": {
                  "type": "string",
                  "enum": ["ltr", "rtl"]
                },
                "code": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "TransliterationResult": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "The converted text."
          },
          "script": {
            "type": "string",
            "description": "The script used in the output."
          }
        }
      },
      "BreakSentenceResult": {
        "type": "object",
        "properties": {
          "sentLen": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Array of integers representing sentence lengths."
          },
          "detectedLanguage": {
            "$ref": "#/components/schemas/DetectedLanguage"
          }
        }
      },
      "DictionaryLookupResult": {
        "type": "object",
        "properties": {
          "normalizedSource": {
            "type": "string"
          },
          "displaySource": {
            "type": "string"
          },
          "translations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "normalizedTarget": {
                  "type": "string"
                },
                "displayTarget": {
                  "type": "string"
                },
                "posTag": {
                  "type": "string",
                  "enum": ["ADJ", "ADV", "CONJ", "DET", "MODAL", "NOUN", "PREP", "PRON", "VERB", "OTHER"]
                },
                "confidence": {
                  "type": "number",
                  "format": "float"
                },
                "prefixWord": {
                  "type": "string"
                },
                "backTranslations": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "normalizedText": {
                        "type": "string"
                      },
                      "displayText": {
                        "type": "string"
                      },
                      "numExamples": {
                        "type": "integer"
                      },
                      "frequencyCount": {
                        "type": "integer"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "DictionaryExampleInput": {
        "type": "object",
        "required": ["text", "translation"],
        "properties": {
          "text": {
            "type": "string",
            "description": "The source term to look up."
          },
          "translation": {
            "type": "string",
            "description": "The translated text previously returned by dictionary lookup."
          }
        }
      },
      "DictionaryExampleResult": {
        "type": "object",
        "properties": {
          "normalizedSource": {
            "type": "string"
          },
          "normalizedTarget": {
            "type": "string"
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sourcePrefix": {
                  "type": "string"
                },
                "sourceTerm": {
                  "type": "string"
                },
                "sourceSuffix": {
                  "type": "string"
