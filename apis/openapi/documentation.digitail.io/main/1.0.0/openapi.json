              2
            ],
            "description": "0=neutered, 1=normal, 2=unknown"
          },
          "avatar": {
            "type": "string",
            "format": "binary"
          },
          "crossbreed": {
            "type": "boolean"
          },
          "crossbreed_details": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "color_mask": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "distinctive_marks": {
            "type": "string"
          },
          "chip_number": {
            "type": "string"
          },
          "microchip_location": {
            "type": "string"
          },
          "insurance_number": {
            "type": "string"
          },
          "passport": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "constitution": {
            "type": "string"
          },
          "conformation": {
            "type": "string"
          },
          "allergies": {
            "type": "string"
          },
          "blood_type_id": {
            "type": "integer"
          },
          "observations": {
            "type": "string"
          }
        }
      },
      "UpdatePetRequest": {
        "type": "object",
        "properties": {
          "nickname": {
            "type": "string"
          },
          "birthday": {
            "type": "string",
            "format": "date",
            "description": "Format: Y-m-d"
          },
          "species_id": {
            "type": "integer"
          },
          "breed_id": {
            "type": "integer"
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
