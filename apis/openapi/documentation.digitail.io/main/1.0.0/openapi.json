          },
          "breeder": {
            "type": "string"
          },
          "birthday_estimated": {
            "type": "boolean"
          },
          "rabic_tag_number": {
            "type": "string"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "archive": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer"
              },
              "reason": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          },
          "patients": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "PetListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Pet"
            }
          }
        }
      },
      "CreatePetRequest": {
        "type": "object",
        "required": [
          "clinic_id",
          "vet_id",
          "owner_id",
          "nickname",
          "birthday",
          "species_id",
          "breed_id",
          "gender",
          "hormonal_status"
