            ]
          },
          "allergies": {
            "type": "string"
          },
          "nr_recs": {
            "type": "integer"
          },
          "blood_type": {
            "type": "string"
          },
          "hormonal_status": {
            "type": "integer",
            "enum": [
              0,
              1,
              2
            ],
            "description": "0=Unknown, 1=Intact, 2=Neutered"
          },
          "age": {
            "type": "string"
          },
          "age_breakdown": {
            "type": "object",
            "properties": {
              "years": {
                "type": "integer"
              },
              "months": {
                "type": "integer"
              },
              "days": {
                "type": "integer"
              }
            }
          },
          "patientNumber": {
            "type": "string"
          },
          "is_verified": {
            "type": "string",
