{
  "openapi": "3.0.3",
  "info": {
    "title": "Terrascope OpenSearch API",
    "version": "1.0.0",
    "description": "OpenSearch-based catalogue API for discovering Earth Observation data collections and products on the Terrascope platform. Supports geographic, temporal, and metadata-based filtering with GeoJSON and Atom response formats.",
    "x-jentic-source-url": "https://docs.terrascope.be/"
  },
  "servers": [
    {
      "url": "https://services.terrascope.be/catalogue"
    }
  ],
  "paths": {
    "/description": {
      "get": {
        "operationId": "getOpenSearchDescription",
        "summary": "Retrieve OpenSearch Description Document (OSDD)",
        "tags": ["Discovery"],
        "parameters": [
          {
            "name": "collection",
            "in": "query",
            "description": "Collection identifier for collection-specific OSDD",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OpenSearch Description Document",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/collections": {
      "get": {
        "operationId": "searchCollections",
        "summary": "Search for available EO data collections",
        "tags": ["Collections"],
        "parameters": [
          {
            "name": "platform",
            "in": "query",
            "description": "Satellite platform (e.g., Sentinel-2)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "resolution",
            "in": "query",
            "description": "Spatial resolution filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "description": "Keyword text search",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "abstract",
            "in": "query",
            "description": "Abstract text search",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "topicCategory",
            "in": "query",
            "description": "Topic category filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "bbox",
            "in": "query",
            "description": "Bounding box (west,south,east,north)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "geometry",
            "in": "query",
            "description": "WKT geometry filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "lat",
            "in": "query",
            "description": "Latitude for point-radius search",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "lon",
            "in": "query",
            "description": "Longitude for point-radius search",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "radius",
            "in": "query",
            "description": "Radius in meters for point-radius search",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start date for temporal filter",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date for temporal filter",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Results per page",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "startIndex",
            "in": "query",
            "description": "Pagination offset",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection search results",
            "content": {
              "application/geo+json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionSearchResult"
                }
              },
              "application/atom+xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/products": {
      "get": {
        "operationId": "searchProducts",
        "summary": "Search for products within a specific collection",
        "tags": ["Products"],
        "parameters": [
          {
            "name": "collection",
            "in": "query",
            "required": true,
            "description": "Collection URN identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "start",
            "in": "query",
            "description": "Start date for temporal filter",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date for temporal filter",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "bbox",
            "in": "query",
            "description": "Bounding box (west,south,east,north)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "geometry",
            "in": "query",
            "description": "WKT geometry filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tileId",
            "in": "query",
            "description": "Tile identifier",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cloudCover",
            "in": "query",
            "description": "Cloud cover percentage range (e.g., [0,50])",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "uid",
            "in": "query",
            "description": "Unique product identifier for direct lookup",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "productionStatus",
            "in": "query",
            "description": "Filter by production status (e.g., CANCELLED)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "modificationDate",
            "in": "query",
            "description": "Filter by modification date for polling",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "publicationDate",
            "in": "query",
            "description": "Filter by publication date",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "resolution",
            "in": "query",
            "description": "Product resolution filter",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "description": "Lucene query syntax search",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "accessedFrom",
            "in": "query",
            "description": "Access context (e.g., MEP for Terrascope platform direct access links)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Named geographic region",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Results per page",
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "startIndex",
            "in": "query",
            "description": "Pagination offset",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Product search results",
            "content": {
              "application/geo+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProductSearchResult"
                }
              },
              "application/atom+xml": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "CollectionSearchResult": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["FeatureCollection"]
          },
          "totalResults": {
            "type": "integer"
          },
          "startIndex": {
            "type": "integer"
          },
          "itemsPerPage": {
            "type": "integer"
          },
          "features": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Collection"
            }
          }
        }
      },
      "Collection": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["Feature"]
          },
          "id": {
            "type": "string",
            "description": "Collection URN"
          },
          "geometry": {
            "type": "object",
            "description": "GeoJSON geometry of the collection extent"
          },
          "properties": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "platform": {
                "type": "string"
              },
              "resolution": {
                "type": "string"
              },
              "startDate": {
                "type": "string",
                "format": "date-time"
              },
              "endDate": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      },
      "ProductSearchResult": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["FeatureCollection"]
          },
          "totalResults": {
            "type": "integer"
          },
          "startIndex": {
            "type": "integer"
          },
          "itemsPerPage": {
            "type": "integer"
          },
          "features": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Product"
            }
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["Feature"]
          },
          "id": {
            "type": "string",
            "description": "Product unique identifier"
          },
          "geometry": {
            "type": "object",
            "description": "GeoJSON geometry of the product footprint"
          },
          "properties": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "date": {
                "type": "string",
                "format": "date-time"
              },
              "cloudCover": {
                "type": "number"
              },
              "resolution": {
                "type": "string"
              },
              "productionStatus": {
                "type": "string"
              },
              "tileId": {
                "type": "string"
              }
            }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "href": {
                  "type": "string"
                },
                "rel": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}