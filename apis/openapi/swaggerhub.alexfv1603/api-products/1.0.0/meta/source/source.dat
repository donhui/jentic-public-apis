            "description": "Nombre de la aplicaci\u00f3n que hace la solicitud",
            "required": true,
            "schema": {
              "type": "string",
              "example": "FARMACIA-LATINA"
            }
          },
          {
            "in": "header",
            "name": "Usuario-Consumidor-Id",
            "description": "Identificador del usuario que consume el servicio",
            "required": true,
            "schema": {
              "type": "string",
              "example": "USRADMIN"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "datos": {
                    "type": "string",
                    "description": "JSON string con los datos del producto a actualizar",
                    "example": "{\"datos\":{\"idProducto\":5,\"nombre\":\"Xiaomi Redmi Note 10\",\"descripcion\":\"Telefono movil\",\"codigoTipoProducto\":\"P\",\"codigoBarras\":\"32323567895555\",\"idMarca\":1,\"idCategoria\":3,\"stockMinimo\":50,\"esPerecedero\":false,\"codigoTipoImpuesto\":\"01\",\"codigoUnspsc\":\"12345678\",\"detallePrecios\":[{\"idDetalle\":11,\"codigoUnidad\":\"NIU\",\"precioCompra\":350.00,\"precioVenta\":500.00,\"tipoPrecio\":\"Venta Web\",\"precioUtilidad\":20.00}]}}"
                  },
                  "multimedia": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    },
                    "description": "Archivos multimedia (im\u00e1genes o videos) del producto - Si se env\u00edan archivos, se reemplazar\u00e1n los existentes"
                  }
                },
                "required": [
