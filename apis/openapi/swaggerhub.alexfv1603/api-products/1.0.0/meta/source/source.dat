      "ProductsListResponse": {
        "type": "object",
        "properties": {
          "datos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProductCompleto"
            }
          }
        }
      },
      "ProductCompleto": {
        "type": "object",
        "properties": {
          "idProducto": {
            "type": "integer",
            "example": 1
          },
          "nombre": {
            "type": "string",
            "example": "Laptop HP - 14 Pulgadas"
          },
          "descripcion": {
            "type": "string",
            "example": "Laptop para uso empresarial"
          },
          "codigoTipoProducto": {
            "type": "string",
            "example": "BIEN"
          },
          "codigoBarras": {
            "type": "string",
            "example": "1234567890"
          },
          "idMarca": {
            "type": "integer",
            "example": 1
          },
          "idCategoria": {
            "type": "integer",
            "example": 1
          },
          "stockMinimo": {
            "type": "integer",
            "example": 10
          },
          "esPerecedero": {
            "type": "boolean",
            "example": false
          },
          "codigoTipoImpuesto": {
            "type": "string",
            "example": "IGV"
          },
          "codigoUnspsc": {
            "type": "string",
            "example": "43211503"
          },
          "detallePrecios": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DetallePrecioResponse"
            }
          },
          "multimedia": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MultimediaResponse"
            }
          }
        }
      },
      "DetallePrecioResponse": {
        "type": "object",
        "properties": {
          "idDetalle": {
            "type": "integer",
            "example": 1
          },
          "codigoUnidad": {
            "type": "string",
            "example": "NIU"
          },
          "precioCompra": {
            "type": "number",
            "format": "double",
            "example": 2500.0
          },
          "precioVenta": {
            "type": "number",
            "format": "double",
            "example": 3000.0
          },
          "tipoPrecio": {
            "type": "string",
            "example": "General"
          },
          "precioUtilidad": {
            "type": "number",
            "format": "double",
            "example": 25.5
          }
        }
      },
      "MultimediaResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "nombre": {
            "type": "string",
            "example": "laptop_hp_imagen.png"
          },
          "tipo": {
            "type": "string",
            "example": "image/png"
          },
          "url": {
            "type": "string",
            "example": "http://localhost:8080/api/multimedia/1/download"
          },
          "tamanio": {
            "type": "integer",
            "example": 524288
          },
          "extension": {
            "type": "string",
            "example": ".png"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "description": "Auth bearer token de autenticaci\u00f3n.",
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}