      "ResponseModificarMarca": {
        "type": "object",
        "properties": {
          "datos": {
            "$ref": "#/components/schemas/SalidaResponseModificarMarca"
          }
        }
      },
      "SalidaResponseModificarMarca": {
        "type": "object",
        "properties": {
