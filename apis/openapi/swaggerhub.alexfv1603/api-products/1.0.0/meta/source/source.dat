        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "idTipoPrecio": {
            "type": "integer",
            "example": 1
          },
          "codigoUnidad": {
            "type": "string",
            "example": "NIU"
          },
          "precioCompra": {
            "type": "number",
