  "components": {
    "parameters": {
      "Path-id-empresa": {
        "in": "path",
        "name": "id-empresa",
        "schema": {
          "type": "integer",
          "example": 1
        },
        "required": true,
        "description": "Id de la empresa"
      },
      "Path-id-sucursal": {
        "in": "path",
        "name": "id-sucursal",
        "schema": {
          "type": "integer",
          "example": 1
        },
        "required": true,
        "description": "Id de la sucursal de la empresa"
      },
      "Path-id-categoria": {
        "in": "path",
        "name": "id-categoria",
        "schema": {
