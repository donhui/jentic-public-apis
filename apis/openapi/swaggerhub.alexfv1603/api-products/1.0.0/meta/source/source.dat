    "/productos": {
      "post": {
        "summary": "Registro de producto por sucursal de la empresa",
        "operationId": "saveProduct",
        "tags": [
          "Gestion de Productos"
        ],
        "description": "Registro de producto por sucursal de la empresa con soporte para archivos multimedia",
        "parameters": [
          {
            "in": "header",
            "name": "Transaccion-Id",
            "description": "Identificador \u00fanico de la transacci\u00f3n",
            "required": true,
            "schema": {
              "type": "string",
              "example": "231e4567-e89b-12d3-a456-426655440000"
            }
          },
          {
            "in": "header",
            "name": "Aplicacion-Id",
            "description": "Identificador de la aplicaci\u00f3n que hace la solicitud",
            "required": true,
            "schema": {
              "type": "string",
              "example": "FARM-LAT-001"
            }
          },
          {
            "in": "header",
            "name": "Nombre-Aplicacion",
            "description": "Nombre de la aplicaci\u00f3n que hace la solicitud",
            "required": true,
            "schema": {
              "type": "string",
              "example": "FARMACIA-LATINA"
            }
          },
          {
            "in": "header",
            "name": "Usuario-Consumidor-Id",
            "description": "Identificador del usuario que consume el servicio",
            "required": true,
            "schema": {
              "type": "string",
              "example": "USRADMIN"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "datos": {
                    "type": "string",
                    "description": "JSON string con los datos del producto",
                    "example": "{\"datos\":{\"nombre\":\"Samsung Galaxy S21\",\"descripcion\":\"Telefono movil\",\"codigoTipoProducto\":\"P\",\"codigoBarras\":\"32323567895555\",\"idMarca\":1,\"idCategoria\":3,\"stockMinimo\":50,\"esPerecedero\":false,\"codigoTipoImpuesto\":\"01\",\"codigoUnspsc\":\"12345678\",\"detallePrecios\":[{\"codigoUnidad\":\"NIU\",\"precioCompra\":350.00,\"precioVenta\":500.00,\"tipoPrecio\":\"Venta Web\",\"precioUtilidad\":50.00}]}}"
                  },
                  "multimedia": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    },
                    "description": "Archivos multimedia (im\u00e1genes o videos) del producto"
                  }
                },
                "required": [
                  "datos"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "El documento ha sido registrado satisfactoriamente.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResponseSaveProducto"
                }
              }
            }
          },
          "202": {
            "description": "El registro del documento ha sido aceptado. Ser\u00e1 registrado de forma as\u00edncrona."
          },
          "400": {
            "description": "Errores de validaci\u00f3n funcional en productos: <br>\n- FN-001: Error de validaci\u00f3n de inputs (campos obligatorios faltantes) <br>\n- 003: Ya existe un producto con este c\u00f3digo de barras <br>\n- 004: C\u00f3digo de tipo de producto inv\u00e1lido (debe ser P, S o M) <br>\n- 004: C\u00f3digo de barras inv\u00e1lido (debe tener entre 8 y 64 caracteres) <br>\n- 004: El nombre no puede exceder 50 caracteres <br>\n- 004: El archivo debe tener una extensi\u00f3n v\u00e1lida <br>\n- 004: Extensi\u00f3n de archivo no permitida <br>\n- 004: Tipo de archivo no permitido (solo im\u00e1genes y videos) <br>\n- 004: Archivo excede el tama\u00f1o m\u00e1ximo permitido (50MB) <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuesta"
                }
              }
            }
          },
          "403": {
            "description": "Devuelve los siguientes errores: <br>\n- FNE-MS-001 <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuestaFuncional"
                }
              }
            }
          },
          "405": {
            "description": "Devuelve los siguientes errores: <br>\n- FNE-MS-001 <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuestaFuncional"
                }
              }
            }
          },
          "409": {
            "description": "Devuelve los siguientes errores: <br>\n- FNE-MS-002 <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuestaFuncional"
                }
              }
            }
          },
          "413": {
            "description": "Devuelve los siguientes errores: <br>\n- FNE-MS-002 <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuestaFuncional"
                }
              }
            }
          },
          "415": {
            "description": "Devuelve los siguientes errores: <br>\n- FNE-MS-002 <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuestaFuncional"
                }
              }
            }
          },
          "429": {
            "description": "Devuelve los siguientes errores: <br>\n- FNE-MS-002 <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuestaFuncional"
                }
              }
            }
          },
          "500": {
            "description": "Devuelve los siguientes errores: <br>\n- FPR-FE-002 <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuestaServer"
                }
              }
            }
          },
          "503": {
            "description": "Devuelve los siguientes errores: <br>\n- FNE-MS-002 <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuestaGateway"
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Actualizaci\u00f3n de producto por sucursal de la empresa",
        "operationId": "updateProduct",
        "tags": [
          "Gestion de Productos"
        ],
        "description": "Actualizaci\u00f3n de producto por sucursal de la empresa con soporte para archivos multimedia",
        "parameters": [
          {
            "in": "header",
            "name": "Transaccion-Id",
            "description": "Identificador \u00fanico de la transacci\u00f3n",
            "required": true,
            "schema": {
              "type": "string",
              "example": "231e4567-e89b-12d3-a456-426655440000"
