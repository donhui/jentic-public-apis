      "DatosModificarProducto": {
        "type": "object",
        "properties": {
          "datos": {
            "$ref": "#/components/schemas/DatosDataModificarProducto"
          }
        }
      },
      "DatosDataModificarProducto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "idCategoria": {
            "type": "integer",
            "example": 1
          },
          "idMarca": {
            "type": "integer",
            "example": 1
          },
          "nombre": {
            "type": "string",
            "example": "Laptop HP - 14 Pulgada"
          },
          "descripcion": {
            "type": "string",
            "example": ""
          },
          "tipoCodigoProducto": {
            "type": "string",
            "example": "Bien"
          },
          "codigoBarras": {
            "type": "string",
            "example": 1234567890
          },
          "stockMinimo": {
            "type": "number",
            "format": "double",
            "example": 10
          },
          "perecible": {
            "type": "boolean",
            "example": true
          },
          "tipoCodigoImpuesto": {
            "type": "string",
            "example": 10,
            "description": "Viene de la tabla maestra tax_types"
          },
          "codigoUnspsc": {
            "type": "string",
            "example": 1212
          },
          "precios": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DatosRequestModificarListPrecios"
            },
            "example": [
              {
                "id": 1,
                "idTipoPrecio": 1,
                "codigoUnidad": "NIU",
                "precioCompra": 2500.0,
                "precioVenta": 3000.0
              },
              {
                "id": 2,
                "idTipoPrecio": 2,
                "codigoUnidad": "BX",
                "precioCompra": 2500.0,
                "precioVenta": 3000.0
              }
            ]
          }
        }
      },
