          },
          "400": {
            "description": "Errores de validaci\u00f3n funcional en actualizaci\u00f3n de productos: <br>\n- FN-001: Error de validaci\u00f3n de inputs (campos obligatorios faltantes) <br>\n- 004: El ID del producto es obligatorio para actualizaci\u00f3n <br>\n- 002: Producto no encontrado con el ID especificado <br>\n- 004: C\u00f3digo de tipo de producto inv\u00e1lido (debe ser P, S o M) <br>\n- 004: C\u00f3digo de barras inv\u00e1lido (debe tener entre 8 y 64 caracteres) <br>\n- 004: El nombre no puede exceder 50 caracteres <br>\n- 004: Errores de archivos multimedia (extensi\u00f3n, tipo o tama\u00f1o) <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorRespuesta"
                }
              }
            }
          },
          "404": {
            "description": "Producto no encontrado: <br>\n- 002: Producto no encontrado con el ID especificado <br>",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorProductoNotFound"
                }
              }
            }
          },
          "403": {
            "description": "Devuelve los siguientes errores: <br>\n- FNE-MS-001 <br>",
            "content": {
