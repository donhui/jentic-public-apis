  "paths": {
    "/oauth/token": {
      "post": {
        "summary": "Obtenci\u00f3n de token OAuth2",
        "tags": [
          "Gestion de Logueo - Obtener Token"
        ],
        "description": "Obtiene un token de acceso utilizando las credenciales del usuario\n",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string",
                    "example": "password"
                  },
                  "username": {
                    "type": "string",
                    "example": "aly"
                  },
                  "password": {
                    "type": "string",
                    "example": "jwtpass"
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "in": "header",
            "name": "Authorization",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "Basic ZmluYW5jaXhkeGRlcmFvaDpmaW5hbmNpZXJheGR4ZHg4OWNvZGV4"
          }
        ],
        "responses": {
          "200": {
            "description": "Token generado exitosamente.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "description": "Token de acceso generado.",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..yt3JEbYi6IB4p3ygNCGIQPkZ5PP0yDpKA-YPvTrbnA0"
                    },
                    "token_type": {
                      "type": "string",
                      "description": "Tipo de token generado.",
                      "example": "bearer"
                    },
                    "expires_in": {
                      "type": "integer",
                      "description": "Tiempo de expiraci\u00f3n del token en segundos.",
                      "example": 7199
                    },
                    "scope": {
                      "type": "string",
                      "description": "Alcance del token generado.",
                      "example": "read write"
                    },
                    "jti": {
                      "type": "string",
                      "description": "Identificador unico",
                      "example": "555a44b4-703b-4478-83d6-c43f8ce0c653"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Solicitud incorrecta."
          },
          "401": {
            "description": "Autenticaci\u00f3n fallida."
          }
        }
      }
    },
