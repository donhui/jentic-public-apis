    "/v{api_version}/task/update-status/{organization_id}/{record_id}/{status}": {
      "put": {
        "operationId": "completeTask",
        "summary": "Complete Task",
        "description": "Mark a task as complete or incomplete.",
        "tags": [
          "Tasks"
        ],
        "parameters": [
          {
            "name": "api_version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "default": "1.0"
            },
            "description": "API Version"
          },
          {
            "name": "organization_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "OrganizationId of SmartTask organization"
          },
          {
            "name": "record_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "RecordId"
          },
          {
            "name": "status",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "1 - complete, 0 - incomplete"
          }
        ],
        "responses": {
          "200": {
            "description": "Task status updated successfully"
          },
          "400": {
            "description": "Bad request",
            "content": {
