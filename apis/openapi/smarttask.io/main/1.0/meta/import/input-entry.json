    "/v{api_version}/project/list/{organization_id}/{archive_flag}": {
      "post": {
        "operationId": "searchProjects",
        "summary": "Search Projects",
        "description": "Search and list projects in an organization.",
        "tags": [
          "Projects"
        ],
        "parameters": [
          {
            "name": "api_version",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "default": "1.0"
            },
            "description": "API Version"
          },
          {
            "name": "organization_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "OrganizationId"
          },
          {
            "name": "archive_flag",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "enum": [
                0,
                1
              ]
            },
            "description": "0 - active, 1 - archived"
          },
          {
            "name": "group_id",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Group ID filter"
          },
          {
            "name": "query",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "page_no",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Page number"
          },
          {
            "name": "list_size",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Number of results per page"
          },
          {
            "name": "is_template",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Filter for templates"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "except_project_ids": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Project IDs to exclude"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Projects retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Organization not found"
          }
        }
      }
    },
