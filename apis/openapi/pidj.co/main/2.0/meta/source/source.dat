    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic Authentication. Pass your Account Key as the username and the Token as the password."
      }
    },
    "schemas": {
      "SendMessageRequest": {
        "type": "object",
        "required": ["to_number", "text_body"],
        "properties": {
          "from_number": {
            "type": "string",
            "description": "Phone number to send from in E.164 format (e.g., +18885552222). Either from_number or group_id is required."
          },
          "group_id": {
            "type": "string",
            "description": "The group id to send messages from (e.g., gr:04207209-7f61-5801-a3bd-958ecff19f77). Either group_id or from_number is required."
          },
          "to_number": {
            "type": "string",
            "description": "Phone number to send to in E.164 format (e.g., +18885553333)"
          },
          "text_body": {
            "type": "string",
            "maxLength": 1600,
            "description": "The text to send. Message lengths greater than 1,600 characters will be truncated."
          }
        }
      },
      "SendMessageResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "message": {
            "type": "string"
          }
        }
      },
      "InitiateTaskRequest": {
        "type": "object",
        "required": ["channel"],
        "properties": {
          "channel": {
            "type": "string",
            "enum": ["ticket"],
            "description": "The channel (or type) to create the interaction in"
          },
          "group_id": {
            "type": "string",
            "description": "The group id to assign the task to (e.g., gr:04207209-7f61-5801-a3bd-958ecff19f77)"
          },
          "subject": {
            "type": "string",
            "description": "A brief summary or description of the purpose or type of interaction"
          },
          "topic": {
            "type": "string",
            "maxLength": 3200,
            "description": "Any description or information associated with the interaction. HTML is not allowed."
          },
          "name": {
            "type": "string",
            "description": "Will be displayed in the chatbox frame and logs/reports"
          },
          "email_address": {
            "type": "string",
            "description": "Will be displayed in the chatbox frame and logs/reports"
          },
          "phone_number": {
            "type": "string",
            "description": "Will be displayed in the chatbox frame and logs/reports"
          }
        }
      },
      "InitiateTaskResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "task": {
            "type": "string",
            "description": "The UUID of the newly created task"
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Username for the user. Duplicate usernames will result in an error."
          },
          "password": {
            "type": "string",
            "description": "Password for the user"
          },
          "phone_number": {
            "type": "string",
            "description": "Phone number in E.164 format (e.g., +18885552222)"
          },
          "email_address": {
            "type": "string",
            "description": "The user's email address"
          },
          "first_name": {
            "type": "string",
            "description": "The user's first name"
          },
          "last_name": {
            "type": "string",
            "description": "The user's last name"
          },
          "roles": {
            "type": "string",
            "description": "Pipe (|) separated list of roles: admin, manager, agent. At least one role is required."
          },
          "groups": {
            "type": "string",
            "description": "Pipe (|) separated list of groups (names or IDs)"
          },
          "timezone": {
            "type": "string",
            "description": "IANA timezone identifier (e.g., America/Los_Angeles)"
          },
          "external_id": {
            "type": "string",
            "description": "The external ID of the user from your own system"
          }
        }
      },
      "CreateUserResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "id": {
            "type": "string",
            "description": "The unique identifier for the new user record"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string"
          },
          "phone_number": {
            "type": "string"
          },
          "email_address": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "roles": {
            "type": "string"
          },
          "groups": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          }
        }
      },
      "GetUserResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "user": {
            "type": "object",
            "properties": {
              "first_name": {
                "type": "string"
              },
              "last_name": {
                "type": "string"
              },
              "business_name": {
                "type": "string"
              },
              "display_name": {
                "type": "string"
              },
              "email_address": {
                "type": "string"
              },
              "phone_number": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "username": {
                "type": "string"
              },
              "roles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "external_id": {
                "type": "string"
              }
            }
          }
        }
      },
      "PauseUserResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "paused": {
            "type": "boolean"
          }
        }
      },
      "SsoUrlRequest": {
        "type": "object",
        "properties": {
          "user_uuid": {
            "type": "string",
            "description": "The user UUID of the user to sign in (e.g., us:a33a8313-8uq7-25aq-366z-49332atkelb2). Either user_uuid or external_id is required."
          },
          "external_id": {
            "type": "string",
            "description": "The external ID of the user from your own system. Either external_id or user_uuid is required."
          },
          "next": {
            "type": "string",
            "description": "The full URL (http/https included) to redirect to after login. Must be Base64 encoded."
          }
        }
      },
      "SsoUrlResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "url": {
            "type": "string",
            "description": "The full URL to redirect to to execute the SSO. This URL expires in 60 seconds."
          }
        }
      },
      "CreateContactRequest": {
        "type": "object",
        "required": ["phone_number"],
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "Phone number in E.164 format (e.g., +18885552222)"
          },
          "email_address": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "business_name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "group": {
            "type": "string",
            "description": "Group name or group identifier (e.g., gr:04207209-7f61-5801-a3bd-958ecff19f77)"
          },
          "timezone": {
            "type": "string",
            "description": "IANA timezone identifier"
          },
          "external_id": {
            "type": "string"
          },
          "home_street_1": {
            "type": "string",
            "maxLength": 200
          },
          "home_street_2": {
            "type": "string",
            "maxLength": 200
          },
          "home_city": {
            "type": "string",
            "maxLength": 200
          },
          "home_state": {
            "type": "string",
            "description": "2 character state abbreviation"
          },
          "home_postal": {
            "type": "string",
            "description": "5 or 10 digit zipcode"
          },
          "home_country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 or alpha-3"
          },
          "business_street_1": {
            "type": "string",
            "maxLength": 200
          },
          "business_street_2": {
            "type": "string",
            "maxLength": 200
          },
          "business_city": {
            "type": "string",
            "maxLength": 200
          },
          "business_state": {
            "type": "string",
            "description": "2 character state abbreviation"
          },
          "business_postal": {
            "type": "string",
            "description": "5 or 10 digit zipcode"
          },
          "business_country": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 or alpha-3"
          }
        }
      },
      "CreateContactResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "id": {
            "type": "string",
            "description": "The unique identifier for the new contact record"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "UpdateContactRequest": {
        "type": "object",
        "properties": {
          "email_address": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "business_name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "group": {
            "type": "string"
          },
          "timezone": {
            "type": "string"
          }
        }
      },
      "GetContactResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "contact": {
            "type": "object",
            "properties": {
              "first_name": {
                "type": "string"
              },
              "last_name": {
                "type": "string"
              },
              "business_name": {
                "type": "string"
              },
              "display_name": {
                "type": "string"
              },
              "email_address": {
                "type": "string"
              },
              "phone_number": {
                "type": "string"
              },
              "phone_office": {
                "type": "string"
              },
              "phone_fax": {
                "type": "string"
              },
              "timezone": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "external_id": {
                "type": "string"
              }
            }
          }
        }
      },
      "ListGroupsResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "group_id": {
                  "type": "string"
                },
                "phone_number": {
                  "type": "string"
                },
                "color": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "SeriesSubscribeRequest": {
        "type": "object",
        "required": ["series_id", "timezone"],
        "properties": {
          "series_id": {
            "type": "string",
            "description": "The series id (e.g., ts:z81de899-207k-8ej4-ba5q-046zb73gte74)"
          },
          "timezone": {
            "type": "string",
            "description": "IANA timezone identifier"
          },
          "contact_id": {
            "type": "string",
            "description": "The contact id (e.g., co:l93a8313-kuq7-25aq-366z-49332azkelb2). Either contact_id or to_number is required."
          },
          "to_number": {
            "type": "string",
            "description": "Phone number to send to in E.164 format. Either to_number or contact_id is required."
          },
          "from_number": {
            "type": "string",
            "description": "Phone number to send from in E.164 format. Either from_number or group_id is required."
          },
          "group_id": {
            "type": "string",
            "description": "The group id. Either group_id or from_number is required."
          }
        }
      },
      "SeriesSubscribeResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ListSeriesResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "series": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "series_id": {
                  "type": "string"
                },
                "groups": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "InitiateSurveyRequest": {
        "type": "object",
        "required": ["survey_id"],
        "properties": {
          "survey_id": {
            "type": "string",
            "description": "The survey id (e.g., sv:z81de899-207k-8ej4-ba5q-046zb73gte74)"
          },
          "contact_id": {
            "type": "string",
            "description": "The contact id. Either contact_id or to_number is required."
          },
          "to_number": {
            "type": "string",
            "description": "Phone number to send to in E.164 format. Either to_number or contact_id is required."
          },
          "from_number": {
            "type": "string",
            "description": "Phone number to send from in E.164 format. Either from_number or group_id is required."
          },
          "group_id": {
            "type": "string",
            "description": "The group id. Either group_id or from_number is required."
          }
        }
      },
      "InitiateSurveyResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ListSurveysResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "surveys": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "survey_id": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "AuthCheckResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          },
          "message": {
            "type": "string"
          }
        }
      },
      "StandardResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["success", "error", "failure"]
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["error", "failure"]
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
