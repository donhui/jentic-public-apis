{
  "openapi": "3.0.3",
  "info": {
    "title": "Fleet REST API",
    "version": "1.0.0",
    "description": "Fleet provides an open-source platform for IT and security teams to manage and secure their devices. The REST API provides complete programmatic access to Fleet.",
    "x-jentic-source-url": "https://fleetdm.com/docs/rest-api/rest-api"
  },
  "servers": [
    {
      "url": "https://{instance}.fleet.com/api/v1/fleet",
      "variables": {
        "instance": {
          "default": "your-instance"
        }
      }
    }
  ],
