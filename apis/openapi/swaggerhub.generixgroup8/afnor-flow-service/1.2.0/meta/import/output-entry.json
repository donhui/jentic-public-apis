  "components": {
    "parameters": {
      "webhookUidPathParam": {
        "name": "webhookUid",
        "in": "path",
        "description": "The webhook unique ID",
        "required": true,
        "schema": {
          "$ref": "#/components/schemas/WebhookId"
        }
      },
      "organizationIdHeaderParam": {
        "name": "Organization-Id",
        "in": "header",
        "description": "The organization that is aimed in a multi tenancy context",
        "required": false,
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "NotOnlyUuid": {
        "description": "Unique identifier supporting UUID but not only, for flexibility purpose",
        "type": "string",
        "maxLength": 36
      },
      "ProcessingRule": {
        "type": "string",
        "description": "- B2B                 : e-invoicing\n- B2BInt              : International B2B e-reporting\n- B2C                 : B2C e-reporting\n- B2G                 : e-invoicing for B2G sales\n- B2GInt\n- OutOfScope          : Out of scope (not regulated flow)\n- B2GOutOfScope\n- ArchiveOnly         : Archive only, no transmission\n- NotApplicable       : Not Applicable\n",
        "enum": [
          "B2B",
          "B2BInt",
          "B2C",
          "B2G",
          "B2GInt",
          "OutOfScope",
          "B2GOutOfScope",
          "ArchiveOnly",
          "NotApplicable"
        ]
      },
      "FlowSyntax": {
        "type": "string",
        "description": "Syntax of the original file belonging to a flow",
        "enum": [
          "CII",
          "UBL",
          "Factur-X",
          "CDAR",
          "FRR"
        ],
        "example": "CII"
      },
      "FlowProfile": {
        "type": "string",
        "enum": [
          "Basic",
          "CIUS",
          "Extended-CTC-FR"
        ]
      },
      "FlowType": {
        "description": "- `CustomerInvoice`: a non-self-billed outgoing invoice or a self-billed incoming invoice\n- `SupplierInvoice`: a non-self-billed incoming invoice or self-billed outgoing invoice\n- `StateInvoice`: an invoice Flow sent to DFH\n- `CustomerInvoiceLC`: a lifecycle (CDAR) related to a customer invoice\n- `SupplierInvoiceLC`: a lifecycle (CDAR) related to supplier invoice\n- `StateCustomerInvoiceLC`: a customer invoice LC sent to DFH\n- `StateSupplierInvoiceLC`: a supplier invoice LC sent to DFH\n- `AggregatedCustomerTransactionReport` : a transaction E-Reporting flow containing aggregated B2C sales (FRR 10.3)\n- `IndividualCustomerTransactionReport`: a transaction E-Reporting flow containing international B2B sales or a B2C transaction flow reported individually (FRR 10.1)\n- `AggregatedCustomerPaymentReport` : a E-Reporting of collections flow containing collections linked to B2C sales (FRR 10.4)\n- `UnitaryCustomerPaymentReport` : an E-Reporting of collections flow containing collections linked to unit international B2B sales or B2C sales (FRR 10.2)\n- `UnitarySupplierTransactionReport`: a transaction E-Reporting flow containing international B2B purchases (FRR 10.1)\n- `MultiFlowReport`: an E-Reporting flow which contains at least 2 different flow types (FRR 10)\n",
        "type": "string",
        "enum": [
          "CustomerInvoice",
          "SupplierInvoice",
          "StateInvoice",
          "CustomerInvoiceLC",
          "SupplierInvoiceLC",
          "StateCustomerInvoiceLC",
          "StateSupplierInvoiceLC",
          "AggregatedCustomerTransactionReport",
          "UnitaryCustomerTransactionReport",
          "AggregatedCustomerPaymentReport",
          "UnitaryCustomerPaymentReport",
          "UnitarySupplierTransactionReport",
          "MultiFlowReport"
        ],
        "example": "SupplierInvoice"
      },
      "FlowDirection": {
        "type": "string",
        "description": "Direction of the flow:\n  - `In`:  Incoming flow, from the PDP to the OD\n  - `Out`: Outgoing flow, from the OD to the PDP\n",
        "enum": [
          "In",
          "Out"
        ],
        "example": "Out"
      },
      "FlowAckStatus": {
        "description": "- `Ok`: the following checks have passed:\n  - Anti virus\n  - Integrity checks\n  - Technical rules checks\n  - Unicity checks\n- `Error`: one of the previous test has failed\n- `Pending` : the flow is not yet integrated\n",
        "type": "string",
        "enum": [
          "Pending",
          "Ok",
          "Error"
        ]
      },
      "ReasonCode": {
        "description": "A predefined set of reason code values + ability to extend this set",
        "oneOf": [
          {
            "$ref": "#/components/schemas/ReasonCodeEnum"
          },
          {
            "type": "string"
          }
        ]
      },
      "ReasonCodeEnum": {
        "description": "- `EmptyAttachement`      : One or more attachments are empty. (ie IRR_VID_PJ)\n- `AttachmentTypeError`   : The type and/or extension of one or more attachments is not compliant. (ie IRR_EXT_DOC)\n- `EmptyFlow`             : The binary flow is empty. (ie IRR_VID_F)\n- `OtherTechnicalError`   : Other technical error. (ie AUTRE)\n- `InvalidSchema`         : Invalid XML schema. (ie IRR_SYNTAX)\n- `FileSizeExceeded`      : File size limit reached. (ie IRR_TAILLE_F)\n- `FlowTypeError`         : The flow type and/or extension are not compliant. (ie IRR_TYPE_F)\n- `AlreadyExistingFlow`   : The flow has already been sent and received. (ie N/A)\n- `VirusFound`            : Presence of a virus. (ie IRR_ANTIVIRUS)\n- `ChecksumMismatch`      : Checksum provided is different from computed one\n- `InvoiceLCInvalidStatus`: One or more statuses are inconsistent\n- `InvoiceLCStatusError`  : One or more statuses are incorrect or not allowed\n- `InvoiceLCRuleError`    : One or more rules are not matched\n- `InvoiceLCAccessDenied` : One of the request is not authorized and requests permissions\n- `InvoiceLCAmountError`  : One or more amounts are not consistent in regards to the VAT\n",
        "type": "string",
        "enum": [
          "EmptyAttachement",
          "AttachmentTypeError",
          "EmptyFlow",
          "OtherTechnicalError",
          "InvalidSchema",
          "FileSizeExceeded",
          "FlowTypeError",
          "AlreadyExistingFlow",
          "VirusFound",
          "ChecksumMismatch",
          "InvoiceLCInvalidStatus",
          "InvoiceLCStatusError",
          "InvoiceLCRuleError",
          "InvoiceLCAccessDenied",
          "InvoiceLCAmountError"
        ]
      },
      "Algorithm": {
        "type": "string",
        "enum": [
          "RS256",
          "HS256",
          "ECDSA",
          "EDDSA_25519",
          "RSA_PSS",
          "EDDSA_448",
          null
        ]
      },
      "CoreFlowInfo": {
        "description": "Core schema to build FlowInfo, FullFlowInfo, Flow schemas",
        "type": "object",
        "required": [
          "name",
          "flowSyntax"
        ],
        "properties": {
          "trackingId": {
            "description": "The tracking id is an external identifier and is used to track the flow by the sender",
            "allOf": [
              {
                "$ref": "#/components/schemas/NotOnlyUuid"
              }
            ]
          },
          "name": {
            "description": "Name of the file",
            "type": "string",
            "maxLength": 255
          },
          "processingRule": {
            "$ref": "#/components/schemas/ProcessingRule"
          },
          "flowSyntax": {
            "$ref": "#/components/schemas/FlowSyntax"
          },
          "flowProfile": {
            "$ref": "#/components/schemas/FlowProfile"
          }
        }
      },
      "FlowInfoExtension": {
        "description": "Extension to build the FlowInfo",
        "type": "object",
        "properties": {
          "sha256": {
            "description": "The sha256 is the fingerprint of the attached file:\n- if provided in the request: it should be checked once received\n- if not provided in the request: it may be computed and returned in the response\n",
            "type": "string",
            "format": "byte",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      },
      "FlowInfo": {
        "description": "Signaling of the flow",
        "allOf": [
          {
            "$ref": "#/components/schemas/CoreFlowInfo"
          },
          {
            "$ref": "#/components/schemas/FlowInfoExtension"
          }
        ]
      },
      "SearchFlowParams": {
        "type": "object",
        "required": [
          "where"
        ],
        "properties": {
          "limit": {
            "type": "integer",
            "maximum": 100,
            "default": 25,
            "description": "Maximum number of results that may be returned"
          },
          "where": {
            "$ref": "#/components/schemas/SearchFlowFilters"
          }
        }
      },
      "SearchFlowFilters": {
        "description": "Filtering criteria, at least one is required",
        "type": "object",
        "properties": {
          "updatedAfter": {
            "description": "The comparison with current date is strict : updatedAt > updatedAfter",
            "type": "string",
            "format": "date-time"
          },
          "updatedBefore": {
            "type": "string",
            "format": "date-time"
          },
          "processingRule": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProcessingRule"
            }
          },
          "flowType": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FlowType"
            }
          },
          "flowDirection": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FlowDirection"
            }
          },
          "trackingId": {
            "$ref": "#/components/schemas/NotOnlyUuid"
          },
          "ackStatus": {
            "$ref": "#/components/schemas/FlowAckStatus"
          }
        }
      },
      "FullFlowInfoExtension": {
        "description": "Extension schema to build FFullFlowInfo, Flow schemas",
        "type": "object",
        "required": [
          "flowId",
          "submittedAt"
        ],
        "properties": {
          "flowId": {
            "$ref": "#/components/schemas/NotOnlyUuid"
          },
          "submittedAt": {
            "description": "The flow submission date and time (the date and time when the flow was created on the system)\nThis property should be used by the API consumer as a time reference to avoid clock synchronization issues\n",
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "FullFlowInfo": {
        "description": "Identified Flow info: flow info + id + timestamp",
        "allOf": [
          {
            "$ref": "#/components/schemas/FullFlowInfoExtension"
          },
          {
            "$ref": "#/components/schemas/FlowInfo"
          }
        ]
      },
      "AcknowledgementDetail": {
        "type": "object",
        "required": [
          "level",
          "item",
          "reasonCode",
          "reasonMessage"
        ],
        "properties": {
          "level": {
            "type": "string",
            "enum": [
              "Error",
              "Warning"
            ]
          },
          "item": {
            "description": "Item on which the error refers",
            "type": "string"
          },
          "reasonCode": {
            "$ref": "#/components/schemas/ReasonCode"
          },
          "reasonMessage": {
            "type": "string"
          }
        }
      },
      "AcknowledgementDetails": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/components/schemas/AcknowledgementDetail"
        }
      },
      "Acknowledgement": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "$ref": "#/components/schemas/FlowAckStatus"
          },
          "details": {
            "$ref": "#/components/schemas/AcknowledgementDetails"
          }
        }
      },
      "FlowExtension": {
        "description": "Extension schema to build Flow schema",
        "type": "object",
        "required": [
          "updatedAt",
          "flowType",
          "processingRuleSource",
          "flowDirection",
          "acknowledgement"
        ],
        "properties": {
          "updatedAt": {
            "description": "The last update date and time of the flow. When the flow is submitted updatedAt is equal to submittedAt.\nWhen the flow acknowledgment status is changed updatedAt date and time is updated.\n",
            "type": "string",
            "format": "date-time"
          },
          "flowType": {
            "$ref": "#/components/schemas/FlowType"
          },
          "processingRuleSource": {
            "description": "Says whether the processing rule has been computed or the processing rule was an input parameter",
            "type": "string",
            "enum": [
              "Input",
              "Computed"
            ]
          },
          "flowDirection": {
            "$ref": "#/components/schemas/FlowDirection"
          },
          "acknowledgement": {
            "$ref": "#/components/schemas/Acknowledgement"
          }
        }
      },
      "Flow": {
        "description": "The properties of a Flow resource",
        "allOf": [
          {
            "$ref": "#/components/schemas/CoreFlowInfo"
          },
          {
            "$ref": "#/components/schemas/FullFlowInfoExtension"
          },
          {
            "$ref": "#/components/schemas/FlowExtension"
          }
        ]
      },
      "SearchFlowContent": {
        "description": "A set of flows matching criterias, provided into the request",
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer"
          },
          "filters": {
            "$ref": "#/components/schemas/SearchFlowFilters"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Flow"
            }
          }
        }
      },
      "CallbackParameters": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "headers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CallbackHeader"
            }
          },
          "authentication": {
            "$ref": "#/components/schemas/CallbackAuthentication"
          },
          "signature": {
            "$ref": "#/components/schemas/CallbackSignature"
          }
        }
      },
      "CallbackHeader": {
        "type": "object",
        "required": [
          "headerName",
          "headerValue"
        ],
        "properties": {
          "headerName": {
            "type": "string"
          },
          "headerValue": {
            "type": "string"
          }
        }
      },
      "OAuth2Authentication": {
        "type": "object",
        "required": [
          "tokenUrl",
          "clientId",
          "clientSecret"
        ],
        "properties": {
          "tokenUrl": {
            "type": "string",
            "format": "uri"
          },
          "clientId": {
            "type": "string"
          },
          "clientSecret": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "BasicAuthentication": {
        "type": "object",
        "required": [
          "userId",
          "userPassword"
        ],
        "properties": {
          "userId": {
            "type": "string"
          },
          "userPassword": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "CallbackAuthentication": {
        "description": "The authentication mode required for the callback call",
        "type": "object",
        "required": [
          "authType"
        ],
        "properties": {
          "authType": {
            "type": "string",
            "enum": [
              "BASIC",
              "OAUTH2"
            ]
          }
        },
        "oneOf": [
          {
            "$ref": "#/components/schemas/BasicAuthentication"
          },
          {
            "$ref": "#/components/schemas/OAuth2Authentication"
          }
        ]
      },
      "CallbackSignature": {
        "type": "object",
        "required": [
          "algo",
          "key"
        ],
        "properties": {
          "algo": {
            "$ref": "#/components/schemas/Algorithm"
          },
          "key": {
            "description": "Base 64 encoded string",
            "type": "string",
            "format": "byte"
          }
        }
      },
      "WebhookMetadata": {
        "type": "object",
        "required": [
          "flowType",
          "flowDirection"
        ],
        "properties": {
          "processingRule": {
            "$ref": "#/components/schemas/ProcessingRule"
          },
          "flowType": {
            "$ref": "#/components/schemas/FlowType"
          },
          "flowDirection": {
            "$ref": "#/components/schemas/FlowDirection"
          },
          "ackStatus": {
            "$ref": "#/components/schemas/FlowAckStatus"
          }
        }
      },
      "WebhookParams": {
        "type": "object",
        "required": [
          "callback",
          "metadata"
        ],
        "properties": {
          "callback": {
            "$ref": "#/components/schemas/CallbackParameters"
          },
          "metadata": {
            "$ref": "#/components/schemas/WebhookMetadata"
          }
        }
      },
      "WebhookId": {
        "type": "string",
        "format": "uuid"
      },
      "WebhookIdParam": {
        "type": "object",
        "properties": {
          "webhookId": {
            "$ref": "#/components/schemas/WebhookId"
          }
        }
      },
      "Webhook": {
        "allOf": [
          {
            "$ref": "#/components/schemas/WebhookIdParam"
          },
          {
            "$ref": "#/components/schemas/WebhookParams"
          }
        ]
      },
      "WebhookPatchPayload": {
        "type": "object",
        "properties": {
          "headers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CallbackHeader"
            }
          },
          "authentication": {
            "$ref": "#/components/schemas/CallbackAuthentication"
          },
          "signature": {
            "$ref": "#/components/schemas/CallbackSignature"
          }
        }
      }
    },
    "callbacks": {
      "WebhookCallback": {
        "{$request.body#/callback.url}": {
          "post": {
            "parameters": [
              {
                "name": "Signature",
                "description": "The signature field is required whenever the callback properties hold a signature block\n- what content is considered into the signature ? body, headers, timestamp\n- how is the signed content serialized ? Do we need a canonical form ?\n",
                "required": false,
                "in": "header",
                "schema": {
                  "description": "Base 64 encoded string",
                  "type": "string",
                  "format": "byte"
                }
              }
            ],
            "requestBody": {
              "required": true,
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/Flow"
                  }
                }
              }
            },
            "responses": {
              "200": {
                "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Ok200EmptyResponse"
              },
              "400": {
                "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error400Response"
              },
              "401": {
                "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error401Response"
              },
              "403": {
                "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error403Response"
              },
              "500": {
                "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error500Response"
              }
            }
          }
        }
      }
    },
    "requestBodies": {
      "FlowSearchRequest": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/SearchFlowParams"
            }
          }
        }
      },
      "FlowPostRequest": {
        "content": {
          "multipart/form-data": {
            "schema": {
              "type": "object",
              "required": [
                "flowInfo",
                "file"
              ],
              "properties": {
                "flowInfo": {
                  "$ref": "#/components/schemas/FlowInfo"
                },
                "file": {
                  "description": "Flow file: Max size = 100 MB",
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "encoding": {
              "file": {
                "contentType": "application/pdf, application/xml"
              },
              "flowInfo": {
                "contentType": "application/json"
              }
            }
          }
        }
      },
      "WebhookPostRequest": {
        "description": "Create a webhook",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/WebhookParams"
            }
          }
        }
      },
      "WebhookPatchRequest": {
        "description": "Update a webhook's technical parameters",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/WebhookPatchPayload"
            }
          }
        }
      }
    },
    "responses": {
      "FlowSearchResponse": {
        "description": "OK - Response message when returning the results of a search request.\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/SearchFlowContent"
            }
          }
        }
      },
      "FlowPostResponse": {
        "description": "OK - Response message once the flow has been uploaded.\n",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/FullFlowInfo"
            }
          }
        }
      },
      "FlowGetResponse": {
        "description": "OK - Response message once the flow has been downloaded.",
        "headers": {
          "Content-Disposition": {
            "description": "Header specifying attached file name",
            "schema": {
              "type": "string",
              "pattern": "attachment;filename=*"
            }
          }
        },
        "content": {
          "application/octet-stream": {},
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Flow"
            }
          }
        }
      },
      "WebhookLightResponse": {
        "description": "OK - Webhook Created",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/WebhookIdParam"
            }
          }
        }
      },
      "WebhookFullResponse": {
        "description": "OK - Webhook Retrieved",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Webhook"
            }
          }
        }
      },
      "WebhookListResponse": {
        "description": "OK - Webhook Id List Response",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": [
                "webhookIds"
              ],
              "properties": {
                "webhookIds": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WebhookId"
                  }
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "OAuth2": {
        "type": "oauth2",
        "description": "Implements only OAuth2 Client Credentials workflow requiring a client id/secret pair",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://auth.company.com/auth-service/{custId}/token",
            "scopes": {}
          }
        }
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    },
    {
      "OAuth2": []
    }
  ],
  "tags": [
    {
      "name": "Flow",
      "description": "Flow management"
    },
    {
      "name": "Supervisor",
      "description": "Service supervision"
    },
    {
      "name": "Webhook",
      "description": "Webhook management"
    }
  ]
