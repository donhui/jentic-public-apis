        "description": "Retrieves a set of flows matching the provided search criteria:\n  - Need at least one criterion to be specified\n  - Assuming a logical AND when combining criteria\n  - Assuming a logical OR for criteria allowing a list of values\n\nPagination works with the updatedAfter property\nThe comparison with current date is strict : updatedAt > updatedAfter\n",
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/parameters/RequestIdHeader"
          },
          {
            "$ref": "#/components/parameters/organizationIdHeaderParam"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/FlowSearchRequest"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/FlowSearchResponse"
          },
          "400": {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error400Response"
          },
          "401": {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error401Response"
          },
          "403": {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error403Response"
          },
          "429": {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error429Response"
          },
          "500": {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error500Response"
          },
          "503": {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error503Response"
          }
        },
        "tags": [
          "Flow"
        ]
      }
    },
    "/v1/flows/{flowId}": {
      "get": {
        "summary": "Download the file of a flow",
        "description": "Download a file related to a given flow:\n  - an invoice\n  - a life cycle\n  - an e-reporting\n",
        "operationId": "getFlow",
        "tags": [
          "Flow"
        ],
        "parameters": [
          {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/parameters/RequestIdHeader"
          },
          {
            "$ref": "#/components/parameters/organizationIdHeaderParam"
          },
          {
            "name": "flowId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/NotOnlyUuid"
            },
            "description": "Flow identifier"
          },
          {
            "name": "docType",
            "description": "This parameter allows to provide the type of file to be downloaded, can be either one:\n  - Metadata [Default]: provides the flow metadata as a JSON payload, no download\n  - Original: the document that has been initially sent/provided by the emitter\n  - Converted: the document that has been optionally converted by the system\n  - ReadableView: the document that has been optionally generated as the readable file\n",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "Metadata",
                "Original",
                "Converted",
                "ReadableView"
              ],
              "default": "Metadata"
            }
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/FlowGetResponse"
          },
          "400": {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error400Response"
          },
          "401": {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error401Response"
          },
          "403": {
            "$ref": "https://api.swaggerhub.com/domains/Generixgroup8/AFNOR-Common/1.0.0#/components/responses/Error403Response"
          },
          "404": {
