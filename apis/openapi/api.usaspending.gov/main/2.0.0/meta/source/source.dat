{
  "openapi": "3.0.3",
  "info": {
    "title": "USASpending API",
    "description": "The USASpending API provides access to U.S. federal government spending data including awards, agencies, recipients, and financial accounts.",
    "version": "2.0.0",
    "x-jentic-source-url": "https://api.usaspending.gov/docs/"
  },
  "servers": [
    {
      "url": "https://api.usaspending.gov",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Agency",
      "description": "Agency-related endpoints"
    },
    {
      "name": "Awards",
      "description": "Award-related endpoints"
    },
    {
      "name": "Search",
      "description": "Search and spending endpoints"
    },
    {
      "name": "Recipient",
      "description": "Recipient-related endpoints"
    },
    {
      "name": "Download",
      "description": "Data download endpoints"
    },
    {
      "name": "References",
      "description": "Reference data endpoints"
    },
    {
      "name": "Autocomplete",
      "description": "Autocomplete endpoints"
    },
    {
      "name": "Disaster",
      "description": "Disaster/emergency funding endpoints"
    }
  ],
  "paths": {
    "/api/v2/agency/{toptier_agency_code}/": {
      "get": {
        "operationId": "getagencyoverview",
        "summary": "Get agency overview",
        "description": "Returns agency overview information for the agency details page.",
        "tags": [
          "Agency"
        ],
        "parameters": [
          {
            "name": "toptier_agency_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgencyOverview"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v2/agency/{toptier_agency_code}/awards/": {
      "get": {
        "operationId": "getagencyawards",
        "summary": "Get agency awards summary",
        "description": "Returns summary of transactions and obligations for an agency.",
        "tags": [
          "Agency"
        ],
        "parameters": [
          {
            "name": "toptier_agency_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transaction_count": {
                      "type": "integer"
                    },
                    "obligated_amount": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
