    "components": {
        "schemas": {
            "Torneo": {
                "type": "object",
                "required": [
                    "idTorneo",
                    "nombre",
                    "fechaTorneo"
                ],
                "properties": {
                    "idTorneo": {
                        "type": "string",
                        "example": "t123"
                    },
                    "nombre": {
                        "type": "string",
                        "example": "Russia 2018"
                    },
                    "fechaTorneo": {
                        "type": "string",
                        "format": "int32",
                        "example": "2016-08-29T09:12:33.001Z"
                    }
                }
            },
            "Cotejo": {
                "required": [
                    "idCotejo",
                    "nombre",
                    "equipo1",
                    "equipo2",
                    "idTorneo"
                ],
                "properties": {
                    "idCotejo": {
                        "type": "string",
                        "example": "c123"
                    },
                    "nombre": {
                        "type": "string",
                        "example": "semifinal"
                    },
                    "equipo1": {
                        "type": "string",
                        "example": "Real Madrid"
                    },
                    "equipo2": {
                        "type": "string",
                        "example": "Arsenal"
                    },
                    "idTorneo": {
                        "type": "string",
                        "example": "Russia 2018"
                    }
                }
            },
            "Apuesta": {
                "required": [
                    "idApuesta",
                    "idCotejo",
                    "valor"
                ],
                "properties": {
                    "idApuesta": {
                        "type": "string",
                        "example": "a123"
                    },
                    "idCotejo": {
                        "type": "string",
                        "example": "c123"
                    },
                    "valor": {
                        "type": "integer",
                        "example": 1234
                    }
                }
