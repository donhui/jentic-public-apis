{
  "openapi": "3.0.3",
  "info": {
    "title": "ClockingApi",
    "description": "Clocking and users API. For full information about how to use all endpoints, please visit: https://docs.parim.co/en/public-apis/clocking",
    "version": "0.1.0",
    "contact": {
      "name": "Voldemar Eskola",
      "email": "voldemar@parim.co"
    },
    "x-jentic-source-url": "https://docs.parim.co/public-apis/clocking/clockingapi-prod-swagger.json"
  },
  "servers": [
    {
      "url": "https://{domain}.parim.co/api-clocking-prod",
      "description": "PARiM Clocking API Server",
      "variables": {
        "domain": {
          "default": "yourdomain",
          "description": "Your PARiM domain"
        }
      }
    }
  ],
  "tags": [
    {
      "name": "ClockEvent",
      "description": "Clock event management operations"
    },
    {
      "name": "User",
      "description": "User management operations"
    }
  ],
  "paths": {
    "/clock_events": {
      "post": {
        "tags": [
          "ClockEvent"
        ],
        "summary": "Creates a ClockEvent resource.",
        "operationId": "postClockEventCollection",
        "parameters": [
          {
            "name": "x-auth-parim-timestamp",
            "in": "header",
            "description": "Current timestamp in seconds.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-auth-parim-key",
            "in": "header",
            "description": "The Public API Key for authentication.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-PARiM-Domain",
            "in": "header",
            "description": "An internal parameter. Not provided by API consumer.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-auth-parim-nonce",
            "in": "header",
            "description": "Unique nonce.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-auth-parim-signature",
            "in": "header",
            "description": "The signature string.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "The new ClockEvent resource",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClockEvent"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "ClockEvent resource created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClockEvent"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request message or headers."
          },
          "401": {
            "description": "Request not authorized."
          },
          "404": {
            "description": "Resource not found"
          },
          "428": {
            "description": "A published shift must exist for the user at specified time, none found."
          },
          "500": {
            "description": "500 response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Retrieves the collection of User resources.",
        "operationId": "getUsers",
        "parameters": [
          {
            "name": "x-auth-parim-timestamp",
            "in": "header",
            "description": "Current timestamp in seconds.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-auth-parim-key",
            "in": "header",
            "description": "The Public API Key for authentication.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-PARiM-Domain",
            "in": "header",
            "description": "An internal parameter. Not provided by API consumer.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-auth-parim-signature",
            "in": "header",
            "description": "The signature string.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-auth-parim-nonce",
            "in": "header",
            "description": "Unique nonce.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User collection response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArrayOfUser"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request message or headers.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Request not authorized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "500 response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "PARiMAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-auth-parim-key",
        "description": "PARiM public API key. Also requires x-auth-parim-timestamp, x-auth-parim-nonce, and x-auth-parim-signature headers."
      }
    },
    "schemas": {
      "ClockEvent": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Clock event ID. Read-only.",
            "minimum": 0
          },
          "shift_id": {
            "type": "integer",
            "description": "ID of the shift the clock event applies to.",
            "minimum": 0
          },
          "user_id": {
            "type": "integer",
            "description": "User ID.",
            "minimum": 0
          },
          "action_by_user_id": {
            "type": "integer",
            "description": "Created by User ID.",
            "minimum": 0
          },
          "type": {
            "type": "string",
            "description": "Clock event type.",
            "enum": [
              "clock_in",
              "clock_out",
              "break_start",
              "break_end",
              "check_in",
              "checkpoint_check_in",
              "location_check"
            ]
          },
          "time": {
            "type": "string",
            "format": "date-time",
            "description": "Normalized value of clock event time. Read-only."
          },
          "latitude": {
            "type": "number",
            "description": "User location latitude at time of clocking. Nullable.",
            "minimum": -90,
            "maximum": 90
          },
          "longitude": {
            "type": "number",
            "description": "User location longitude at time of clocking. Nullable.",
            "minimum": -180,
            "maximum": 180
          },
          "accuracy": {
            "type": "integer",
            "description": "Accuracy of user location in meters at time of clocking. Nullable.",
            "minimum": 0,
            "maximum": 40000000
          },
          "timestamp": {
            "type": "integer",
            "description": "Normalized (exact time rounded to nearest quarter hour) value of clock event UNIX timestamp in seconds. . Read-only."
          },
          "exact_timestamp": {
            "type": "integer",
            "description": "UNIX timestamp in seconds exact time the clock event takes/took place. Defaults to time of request. Nullable."
          },
          "device": {
            "type": "string",
            "description": "Optional user device description or identifier. Nullable."
          }
        },
        "description": "A Clock Event Resource."
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "User ID. Read-only.",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "description": "User status. 'active_incomplete' - registration not completed, 'active_complete' - registration completed, 'active_approved' - approved.",
            "enum": [
              "active_incomplete",
              "active_complete",
              "active_approved"
            ]
          },
          "external_id": {
            "type": "string",
            "description": "User ID in an external system. Nullable."
          },
          "name": {
            "type": "string",
            "description": "First and last name of the person. Nullable."
          },
          "email": {
            "type": "string"
          },
          "is_candidate": {
            "type": "boolean",
            "description": "User is a member of staff."
          },
          "is_subcontractor": {
            "type": "boolean",
            "description": "User is a subcontractor."
          },
          "title": {
            "type": "string",
            "description": "Person salutation title, only applies to staff members. Nullable.",
            "enum": [
              "mr",
              "ms",
              "miss",
              "mrs",
              "dr",
              "prof"
            ]
          },
          "timezone": {
            "type": "string",
            "description": "User timezone. E.g. 'Europe/London'."
          },
          "parim_id": {
            "type": "string",
            "description": "PARiM object UUID. Read-only."
          }
        },
        "description": "A User Resource."
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message."
          }
        },
        "description": "An error response."
      },
      "ArrayOfUser": {
        "type": "array",
        "description": "List of User resources.",
        "items": {
          "$ref": "#/definitions/User"
        }
      }
    }
  },
  "security": [
    {
      "PARiMAuth": []
    }
  ]
}