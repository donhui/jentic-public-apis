{
  "openapi": "3.0.3",
  "info": {
    "title": "SAWO Labs API",
    "description": "SAWO Labs provided passwordless authentication as a service. The API enabled developers to integrate passwordless login (via email or phone OTP) into their applications. Note: SAWO Labs appears to be defunct as of 2026; the domain sawolabs.com no longer serves its original content.",
    "version": "1.0.0",
    "contact": {
      "name": "SAWO Labs",
      "url": "https://sawolabs.com"
    }
  },
  "servers": [
    {
      "url": "https://api.sawolabs.com/api/v1",
      "description": "SAWO Labs API server (defunct)"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/verify/token": {
      "post": {
        "summary": "Verify authentication token",
        "description": "Verifies a SAWO authentication token returned after a user completes passwordless login.",
        "operationId": "verifyToken",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token"],
                "properties": {
                  "token": {
                    "type": "string",
                    "description": "The authentication token received from the SAWO login widget"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token verification result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenVerificationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid token"
          },
          "401": {
            "description": "Unauthorized - invalid API key"
          }
        }
      }
    },
    "/project/get": {
      "get": {
        "summary": "Get project details",
        "description": "Retrieves details of a SAWO project including configuration settings.",
        "operationId": "getProject",
        "tags": ["Project"],
        "parameters": [
          {
            "name": "projectId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "The SAWO project ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Project details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "404": {
            "description": "Project not found"
          }
        }
      }
    },
    "/user/login": {
      "post": {
        "summary": "Initiate passwordless login",
        "description": "Initiates a passwordless login flow by sending an OTP to the user's email or phone number.",
        "operationId": "initiateLogin",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["identifier", "identifierType"],
                "properties": {
                  "identifier": {
                    "type": "string",
                    "description": "Email address or phone number"
                  },
                  "identifierType": {
                    "type": "string",
                    "enum": ["email", "phone_number_sms"],
                    "description": "Type of identifier used for authentication"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP sent successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    },
    "/user/verify-otp": {
      "post": {
        "summary": "Verify OTP",
        "description": "Verifies the one-time password sent to the user's email or phone.",
        "operationId": "verifyOtp",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["otp", "identifier"],
                "properties": {
                  "otp": {
                    "type": "string",
                    "description": "The one-time password received by the user"
                  },
                  "identifier": {
                    "type": "string",
                    "description": "Email address or phone number"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP verification result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "boolean"
                    },
                    "token": {
                      "type": "string",
                      "description": "Authentication token if OTP is valid"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid OTP"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-sawo-api-key",
        "description": "SAWO API key obtained from the dashboard"
      }
    },
    "schemas": {
      "TokenVerificationResponse": {
        "type": "object",
        "properties": {
          "valid": {
            "type": "boolean",
            "description": "Whether the token is valid"
          },
          "user_id": {
            "type": "string",
            "description": "The authenticated user's ID"
          },
          "identifier": {
            "type": "string",
            "description": "The user's email or phone number"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Project ID"
          },
          "name": {
            "type": "string",
            "description": "Project name"
          },
          "host": {
            "type": "string",
            "description": "Allowed host for the project"
          },
          "identifierType": {
            "type": "string",
            "enum": ["email", "phone_number_sms", "both"],
            "description": "Supported authentication identifier types"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authentication",
      "description": "Passwordless authentication operations"
    },
    {
      "name": "Project",
      "description": "Project management operations"
    }
  ]
}
