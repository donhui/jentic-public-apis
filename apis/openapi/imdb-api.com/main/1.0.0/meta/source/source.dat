    "/NameAwards/{apiKey}/{id}": {
      "get": {
        "tags": ["People"],
        "summary": "Get person awards",
        "description": "Retrieve awards information for a person.",
        "operationId": "getNameAwards",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Awards data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "imDbId": { "type": "string" },
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "eventTitle": { "type": "string" },
                          "nameAwardEventItems": {
                            "type": "array",
                            "items": { "type": "object" }
                          }
                        }
                      }
                    },
                    "errorMessage": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
