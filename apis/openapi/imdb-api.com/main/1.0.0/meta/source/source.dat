    "/Wikipedia/{apiKey}/{id}": {
      "get": {
        "tags": ["Title"],
        "summary": "Get Wikipedia info",
        "description": "Retrieve Wikipedia plot summary for a title.",
        "operationId": "getWikipedia",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
