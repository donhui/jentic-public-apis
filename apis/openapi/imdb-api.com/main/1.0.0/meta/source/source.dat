                    "imDbId": { "type": "string" },
                    "title": { "type": "string" },
                    "fullTitle": { "type": "string" },
                    "type": { "type": "string" },
                    "year": { "type": "string" },
                    "plotShort": {
                      "type": "object",
                      "properties": {
                        "plainText": { "type": "string" },
                        "html": { "type": "string" }
                      }
                    },
                    "plotFull": {
                      "type": "object",
                      "properties": {
                        "plainText": { "type": "string" },
                        "html": { "type": "string" }
                      }
                    },
                    "errorMessage": { "type": "string" }
