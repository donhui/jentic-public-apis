{
  "openapi": "3.0.3",
  "info": {
    "title": "IMDb-API",
    "description": "API for receiving movie, serial and cast information from IMDb. Provides search, title details, ratings, images, trailers, reviews, and more.",
    "version": "1.0.0",
    "contact": {
      "name": "IMDb-API",
      "url": "https://imdb-api.com/"
    }
  },
  "servers": [
    {
      "url": "https://imdb-api.com/en/API",
      "description": "IMDb-API Production Server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "paths": {
    "/SearchTitle/{apiKey}/{expression}": {
      "get": {
        "tags": ["Search"],
        "summary": "Search titles",
        "description": "Search for movies, TV series, and other titles by expression.",
        "operationId": "searchTitle",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "description": "Your API key",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "expression",
            "in": "path",
            "required": true,
            "description": "Search expression (e.g., movie title)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResult"
                }
              }
            }
          }
        }
      }
    },
    "/SearchMovie/{apiKey}/{expression}": {
      "get": {
        "tags": ["Search"],
        "summary": "Search movies",
        "description": "Search specifically for movies by expression.",
        "operationId": "searchMovie",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "expression",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Movie search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResult"
                }
              }
            }
          }
        }
      }
    },
    "/SearchSeries/{apiKey}/{expression}": {
      "get": {
        "tags": ["Search"],
        "summary": "Search TV series",
