    "/InTheaters/{apiKey}": {
      "get": {
        "tags": ["Charts"],
        "summary": "Get movies in theaters",
        "description": "Retrieve currently showing movies in theaters.",
        "operationId": "getInTheaters",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "In theaters data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/NewMovieData"
                      }
                    },
