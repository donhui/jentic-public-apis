    "/AdvancedSearch/{apiKey}": {
      "get": {
        "tags": ["Search"],
        "summary": "Advanced search",
        "description": "Perform an advanced search with multiple filters.",
        "operationId": "advancedSearch",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "title",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "title_type",
            "in": "query",
            "description": "e.g., feature,tv_movie,tv_series",
            "schema": { "type": "string" }
          },
          {
            "name": "release_date",
            "in": "query",
            "description": "Date range (e.g., 2020-01-01,2020-12-31)",
            "schema": { "type": "string" }
          },
          {
            "name": "user_rating",
            "in": "query",
            "description": "Rating range (e.g., 7.0,10.0)",
            "schema": { "type": "string" }
          },
          {
            "name": "genres",
            "in": "query",
            "description": "Comma-separated genres",
            "schema": { "type": "string" }
          },
          {
            "name": "countries",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "languages",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "count",
            "in": "query",
            "description": "Number of results (default 50, max 250)",
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sort field (e.g., alpha,user_rating,num_votes,boxoffice_gross_us,runtime,year,release_date)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Advanced search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdvancedSearchResult"
                }
              }
            }
          }
        }
      }
    }
  },
