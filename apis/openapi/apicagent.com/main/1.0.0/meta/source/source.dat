{
  "openapi": "3.0.3",
  "info": {
    "title": "APIC Agent API",
    "version": "1.0.0",
    "description": "User-agent string parsing API. Accepts a user-agent string and returns parsed browser, device, and OS information via GET or POST.",
    "x-jentic-source-url": "https://apicagent.com/docs"
  },
  "servers": [
    {
      "url": "https://api.apicagent.com"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "parseUserAgentGet",
        "summary": "Parse user-agent string (GET)",
        "description": "Parses a URL-encoded user-agent string passed as a query parameter.",
        "tags": ["UserAgent"],
        "parameters": [
          {
            "name": "ua",
            "in": "query",
            "required": true,
            "description": "URL-encoded user-agent string to parse.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Parsed user-agent information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserAgentResult" }
              }
            }
          },
          "400": { "description": "Invalid or missing user-agent string" },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "operationId": "parseUserAgentPost",
        "summary": "Parse user-agent string (POST)",
        "description": "Parses a user-agent string passed in a JSON request body.",
        "tags": ["UserAgent"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserAgentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parsed user-agent information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserAgentResult" }
              }
            }
          },
          "400": { "description": "Invalid or missing user-agent string" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserAgentRequest": {
        "type": "object",
        "required": ["ua"],
        "properties": {
          "ua": {
            "type": "string",
            "description": "User-agent string to parse."
          }
        }
      },
      "UserAgentResult": {
        "type": "object",
        "properties": {
          "browser_family": { "type": "string" },
          "os_family": { "type": "string" },
          "client": {
            "$ref": "#/components/schemas/ClientInfo"
          },
          "device": {
            "$ref": "#/components/schemas/DeviceInfo"
          },
          "os": {
            "$ref": "#/components/schemas/OsInfo"
          }
        }
      },
      "ClientInfo": {
        "type": "object",
        "properties": {
          "engine": { "type": "string" },
          "engine_version": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "version": { "type": "string" }
        }
      },
      "DeviceInfo": {
        "type": "object",
        "properties": {
          "brand": { "type": "string" },
          "model": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "OsInfo": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "platform": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    },
    "securitySchemes": {}
  },
  "security": []
}