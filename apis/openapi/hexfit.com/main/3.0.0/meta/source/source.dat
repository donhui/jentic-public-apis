            "$ref": "#/components/schemas/EntityId",
            "nullable": true,
            "description": "Parent folder ID, or null for root level"
          },
          "name": {
            "type": "string",
            "example": "Test"
          }
        }
      },
      "Notification": {
        "type": "object",
        "description": "In-app notification",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "user_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "date_view": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_by": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "datas": {
            "type": "array",
            "description": "Array of notification data values (e.g. [\"client:75\", \"Autre\"])",
            "items": {
              "type": "string"
            }
          },
          "template_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "link": {
            "type": "string",
            "description": "Link type (e.g. `event`, `training`)"
          },
          "link_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "completed": {
            "type": "boolean"
          },
          "notification_generator_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "discussion_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "link_element": {
            "type": "object",
            "nullable": true,
            "description": "Embedded resource object (event, training, etc.)",
            "additionalProperties": true
          },
          "ai_answer_available": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "description": "Human-readable notification message"
          },
          "type": {
            "type": "string",
            "description": "Notification event type",
            "example": "event_ended"
          }
        }
      },
      "BillingBalance": {
        "type": "object",
        "description": "Client billing balance by intervention code",
        "properties": {
          "balance": {
            "type": "object",
