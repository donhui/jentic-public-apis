                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/PaginatedList"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "list": [],
                    "has_more": false,
                    "page": 1,
                    "limit": 15
                  },
                  "version": 3
                }
              }
            }
          }
        }
      }
    },
