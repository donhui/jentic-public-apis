    "/Training/GetInfo": {
      "get": {
        "tags": [
          "Trainings"
        ],
        "summary": "Get training(s)",
        "description": "Returns training plans. Supports multiple query modes:\n\n- List mode: `limit`, `offset`, `search`, `sort_by`, `parent`, `is_template`, `is_draft`\n- Client mode: `db_id`, `db_name`, `archived`, `parent`, `sort_by`\n- Single: `training_id`\n- With seances: add `fetchseances=true`\n",
        "operationId": "v2_training_get_info",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "training_id",
            "in": "query",
            "description": "Fetch a specific training by ID",
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "db_id",
            "in": "query",
            "description": "Entity ID for client/group context",
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "db_name",
            "in": "query",
            "description": "Entity type namespace",
            "schema": {
              "$ref": "#/components/schemas/DbName"
            }
          },
          {
            "name": "parent",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "is_draft",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "is_template",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "is_standalone",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "archived",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "fetchseances",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string",
              "example": "date_modified"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Training plan(s)",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V2Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "value": {
                          "oneOf": [
                            {
                              "$ref": "#/components/schemas/Training"
                            },
                            {
                              "type": "array",
                              "items": {
                                "$ref": "#/components/schemas/Training"
                              }
                            }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
