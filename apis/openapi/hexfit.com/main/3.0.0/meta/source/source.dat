              "type": "string",
              "format": "date",
              "example": "2026-03-06"
            }
          },
          {
            "name": "endDate",
            "in": "path",
            "required": true,
            "description": "End of date range (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-03-20"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Upcoming notifications grouped by date",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "list": {
                              "type": "object",
                              "description": "Map of date string to array of notifications",
                              "additionalProperties": {
                                "type": "array",
                                "items": {
                                  "$ref": "#/components/schemas/Notification"
                                }
                              }
                            },
                            "has_more": {
                              "type": "boolean"
                            },
                            "page": {
                              "type": "integer"
                            },
                            "limit": {
                              "type": "integer"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
