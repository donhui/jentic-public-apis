      "post": {
        "tags": [
          "Interventions & Notes"
        ],
        "summary": "Send a document to a client",
        "description": "Attach and send a document to one or more clients within an intervention/note context.",
        "operationId": "v2_intervention_createdocument",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "document_id",
                  "db_id"
                ],
                "properties": {
                  "document_id": {
                    "$ref": "#/components/schemas/EntityId",
                    "description": "Document ID to send"
                  },
                  "db_id": {
                    "$ref": "#/components/schemas/DbName",
                    "description": "Instance/database ID where the document should be sent"
                  },
                  "fill_by": {
                    "type": "boolean",
                    "description": "If true, send it to the client(s) to fill in"
                  },
                  "user_id": {
                    "oneOf": [
                      {
                        "$ref": "#/components/schemas/EntityId"
                      },
                      {
                        "type": "array",
                        "items": {
                          "$ref": "#/components/schemas/EntityId"
                        }
                      }
                    ],
                    "description": "User ID or array of user IDs"
                  },
                  "template_id": {
                    "$ref": "#/components/schemas/EntityId",
                    "description": "Template ID (10 = empty)"
                  },
                  "link": {
                    "type": "string",
                    "description": "Link type"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Document creation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V2Envelope"
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/ping": {
      "get": {
        "tags": [
