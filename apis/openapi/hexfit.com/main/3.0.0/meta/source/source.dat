              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          }
        }
      }
    },
    "/Ping": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "V2 API health check",
        "description": "Returns a successful response if the API is online.",
        "operationId": "v2_ping",
        "responses": {
          "200": {
            "description": "API is online",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V2Envelope"
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
