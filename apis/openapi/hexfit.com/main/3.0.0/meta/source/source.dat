    "/notifications/today": {
      "get": {
        "tags": [
          "Professional Notifications"
        ],
        "summary": "Get today's notifications",
        "description": "Returns today's notifications, grouped into `today` and `late` sub-lists.\nPaginated.\n",
        "operationId": "v3_notifications_today",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          }
