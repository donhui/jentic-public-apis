              "schema": {
                "$ref": "#/components/schemas/CreateProfessionalRequest"
              },
              "example": {
                "email": "colleague@example.com",
                "firstname": "Coll\u00e8gue",
                "lastname": "A",
                "sexe": "m",
                "job_id": "hc4903290",
                "profile_id": "hd54286e1",
                "branch_id": [
                  "h8aa91707"
                ],
                "bundle": "mine",
                "modules": null,
                "payment_exclude": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created professional user",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V2Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "value": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "servers": [
