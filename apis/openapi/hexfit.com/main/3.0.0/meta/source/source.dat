            "type": "boolean"
          }
        }
      },
      "DataFormula": {
        "type": "object",
        "description": "A formula definition for automatically computing a data type value",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "Rule of Three"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "formatted_formula": {
            "type": "string",
            "description": "Human-readable formula string",
            "example": "% = [Masse adipeuse - g]/[Poids - g]*100"
          },
          "formula": {
            "type": "string",
            "description": "Formula using numeric references",
            "example": "[98:8]/[21:8]*100"
          },
          "encoded_formula": {
            "type": "string",
            "description": "Formula using entity ID references",
            "example": "[h42e5ad76:h9036281e]/[h33371a7d:h9036281e]*100"
          },
          "condition": {
            "type": "string",
            "nullable": true
          },
          "output_unit_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "is_activated": {
            "type": "boolean"
          }
        }
      },
      "CreateDataTypeRequest": {
        "type": "object",
