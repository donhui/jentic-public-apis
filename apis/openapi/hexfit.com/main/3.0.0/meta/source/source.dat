          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "profile_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "db_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "db_name": {
            "$ref": "#/components/schemas/DbName",
            "nullable": true
          },
          "color": {
            "type": "string",
