    "/User/GetInfo/{userId}": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get user info by path ID",
        "description": "V3 REST variant of user info. Returns a condensed user summary\nincluding `fullname`, `is_client`, `is_professional`, `lastWeight`\nand optionally extended data via the `with` query parameter.\n",
        "operationId": "v3_user_get_info",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "with",
            "in": "query",
            "description": "Comma-separated list of related resources to include",
            "schema": {
              "type": "string",
              "example": "profile,modules"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User summary",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/UserV3Summary"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "id": "h66873f21",
                    "fullname": "Dev (client) Etienne",
                    "firstname": "Dev (client)",
                    "lastname": "Etienne",
                    "is_client": true,
                    "is_professional": false,
                    "profile_picture": "https://assets.myhexfit.com/...",
                    "lastWeight": {
                      "id": "h6e9f1e89",
                      "meta_date": "2025-11-01 12:44:05",
                      "value": 220.46
                    }
                  },
                  "version": 3
                }
              }
            }
          }
        }
      }
    },
    "/user/merge/{targetUserId}": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Merge two user accounts",
        "description": "Merges the account identified by `userIdToMerge` into the `targetUserId`\naccount. The source account is deactivated after the merge.\nReturns an error if both IDs are the same.\n",
        "operationId": "v3_user_merge",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "targetUserId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "userIdToMerge"
                ],
                "properties": {
                  "userIdToMerge": {
                    "$ref": "#/components/schemas/EntityId",
                    "description": "ID of the account to merge into the target"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Merge result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          },
          "409": {
            "description": "Cannot merge same user",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          }
        }
      }
    },
    "/user/preferences/availabilities": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get availability preferences",
        "description": "Returns the professional's availability configuration used for\nappointment scheduling \u2014 buffer, warning, increment, reminder,\nweekly schedule and weekend overrides.\n",
        "operationId": "v3_user_preferences_availabilities",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Availability preferences",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/AvailabilityPreferences"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "buffer": "00:00",
                    "warning": "24:00",
                    "increment": "01:00",
                    "reminder": "24",
                    "week": [
                      {
                        "from": "09:00",
                        "to": "21:00"
                      }
                    ],
                    "weekOpen": false,
                    "weekend": {
                      "6": [
                        {
                          "from": "10:00",
                          "to": "12:00"
                        },
                        {
                          "from": "13:00",
                          "to": "18:00"
                        }
                      ],
                      "7": []
                    },
                    "weekendOpen": true
                  },
                  "version": 3
                }
              }
            }
          }
        }
      }
    },
