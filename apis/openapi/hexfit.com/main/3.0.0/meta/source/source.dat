            },
            "description": "Notification ID"
          }
        ],
        "responses": {
          "200": {
            "description": "AI-generated reply suggestion",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "message": {
                              "type": "string",
                              "description": "AI-generated message ready to send"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
