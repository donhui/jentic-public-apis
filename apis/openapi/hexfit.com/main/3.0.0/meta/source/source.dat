    "/seances/{seanceId}": {
      "post": {
        "tags": [
          "Trainings"
        ],
        "summary": "Update a seance",
        "description": "Updates metadata on a seance (workout session) within a training plan.\nAccepts fields such as `name`, `training_id`, and `recurrent` schedule\nconfiguration.\n",
        "operationId": "v3_seances_update",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "seanceId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "training_id": {
                    "$ref": "#/components/schemas/EntityId"
                  },
                  "name": {
                    "type": "string"
                  },
                  "recurrent": {
                    "type": "object",
                    "properties": {
                      "is_active": {
                        "type": "boolean"
                      },
                      "days": {
                        "type": "string",
                        "description": "Binary string (7 chars) indicating active days Mon-Sun",
                        "example": "0100100"
                      },
                      "frequency": {
                        "type": "string",
                        "example": "once"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Trainings"
        ],
        "summary": "Delete a seance",
        "description": "Soft-deletes a seance from a training plan.",
        "operationId": "v3_seances_delete",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "seanceId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "training_id": {
                    "$ref": "#/components/schemas/EntityId"
                  },
                  "is_active": {
                    "type": "boolean",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "boolean"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/seances/{seanceId}/restore": {
      "post": {
