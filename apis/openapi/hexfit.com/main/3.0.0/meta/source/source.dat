    "/billing/business/{businessId}/invoices-per-professional/{startDate}/{endDate}": {
      "get": {
        "tags": [
          "Analytics & Stats"
        ],
        "summary": "Get invoices per professional in a date range",
        "description": "Returns a breakdown of invoiced amounts grouped by professional for\na business, within the specified date range. Requires Stripe integration;\nreturns a `no-stripe-integration` error code if not configured.\n",
        "operationId": "v3_billing_invoices_per_professional",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "startDate",
            "in": "path",
            "required": true,
            "description": "Start date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2022-04-01"
            }
          },
          {
            "name": "endDate",
            "in": "path",
            "required": true,
            "description": "End date (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2022-06-01"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Invoices per professional or Stripe integration error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          }
        }
      }
    },
