    "/discussions/{discussionId}/messages/send": {
      "post": {
        "tags": [
          "Messaging & Discussions"
        ],
        "summary": "Send a message in a discussion",
        "description": "Sends a new message to a specific discussion thread.",
        "operationId": "v3_discussions_send_message",
        "parameters": [
          {
            "name": "discussionId",
            "in": "path",
            "required": true,
            "description": "Discussion entity ID or `new` to start a new conversation",
            "schema": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/EntityId"
                },
                {
                  "type": "string",
                  "enum": [
                    "new"
                  ]
                }
              ]
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "title": "Existing discussion",
                    "type": "object",
                    "required": [
                      "type",
                      "message"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": [
                          "message"
                        ],
                        "example": "message"
                      },
                      "message": {
                        "type": "string",
                        "example": "Allo ! :D"
                      }
                    }
                  },
                  {
                    "title": "New discussion",
                    "type": "object",
                    "required": [
                      "type",
                      "message",
                      "members"
                    ],
                    "properties": {
                      "type": {
                        "type": "string",
                        "enum": [
                          "message"
                        ],
                        "example": "message"
                      },
                      "message": {
                        "type": "string",
                        "example": "Hello"
                      },
                      "members": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": [
                            "id",
                            "type"
                          ],
                          "properties": {
                            "id": {
                              "$ref": "#/components/schemas/EntityId"
                            },
                            "type": {
                              "$ref": "#/components/schemas/DbName"
                            }
                          }
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Message sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          }
        }
      }
    },
