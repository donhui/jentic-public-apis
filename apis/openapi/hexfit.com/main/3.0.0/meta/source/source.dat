    "/Training/Build": {
      "get": {
        "tags": [
          "Trainings"
        ],
        "summary": "Build training PDF",
        "description": "Generate a printable PDF for a training plan with configurable layout, language, and style options.",
        "operationId": "v2_training_build",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "training_id",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            },
            "description": "Training plan ID"
          },
          {
            "name": "nbr_column",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Number of exercises per row in the PDF layout"
          },
          {
            "name": "lang",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "EN-EN",
                "FR-FR",
                "FR-CA"
              ]
            },
            "description": "Language for the PDF (defaults to professional's language)"
          },
          {
            "name": "color",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Print in colour (true) or black and white (false)"
          },
          {
            "name": "report",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Include a report/tracking sheet"
          },
          {
            "name": "note_type",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Whether to include exercise directives/notes"
          },
          {
            "name": "text_size_adjust",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Font size multiplier (e.g. 1.2 = 20% larger)"
          },
          {
            "name": "orientation",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "portrait",
                "landscape"
              ]
            },
            "description": "PDF print orientation"
          }
        ],
        "responses": {
          "200": {
            "description": "PDF file",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/Training/Download": {
      "get": {
        "tags": [
          "Trainings"
        ],
        "summary": "Download training PDF",
        "description": "Downloads the generated PDF for a training plan. Must be called after `/Training/Build` which prepares the file with the desired layout and options. The `apikey` is passed as a query parameter since this endpoint is typically used as a direct download URL (browser cannot set Authorization headers for file downloads).",
        "operationId": "v2_training_download",
        "security": [],
        "parameters": [
          {
            "name": "apikey",
            "in": "query",
            "required": true,
            "description": "Bearer JWT token (used as query param for direct download links)",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "training_id",
            "in": "query",
            "required": true,
            "description": "Training plan ID",
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "PDF file download",
            "headers": {
              "Content-Disposition": {
                "schema": {
                  "type": "string"
                },
                "example": "attachment; filename=\"My Training.pdf\""
              }
            },
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/User/SetMeta": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Create user meta",
        "description": "Create a meta entry (phone number, address, secondary email, etc.) for a user.",
        "operationId": "v2_user_setmeta",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "type",
                  "value"
                ],
                "properties": {
                  "user_id": {
                    "$ref": "#/components/schemas/EntityId",
                    "description": "Target user ID (defaults to authenticated user)"
                  },
                  "type": {
                    "type": "string",
                    "description": "Meta type to insert (e.g. phone, address, email)"
                  },
                  "value": {
                    "type": "string",
                    "description": "Meta value (e.g. \"418-780-5372\")",
                    "example": "418-780-5372"
                  },
                  "name": {
                    "type": "string",
                    "description": "Label for the meta entry (e.g. Work, Cellphone, Home)",
                    "example": "Work"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created meta entry",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V2Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "value": {
                          "$ref": "#/components/schemas/UserMeta"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/User/DeleteMeta": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Delete user meta",
        "description": "Delete a meta entry (phone, address, secondary email, etc.) for a user by its ID.",
        "operationId": "v2_user_deletemeta",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "meta_id"
                ],
                "properties": {
                  "meta_id": {
                    "$ref": "#/components/schemas/EntityId",
                    "description": "ID of the meta entry to delete"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deletion result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V2Envelope"
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/oauth2/CheckLogin": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Check login by email (partner)",
        "description": "Retrieve user information by email only. Intended for partner integrations.",
        "operationId": "oauth2_checklogin",
        "security": [
          {
            "OAuth2Basic": []
          }
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Base64-encoded [client_id:client_secret]"
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Third-party client ID"
          },
          {
            "name": "key",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Partner API key to verify identity"
          }
        ],
        "responses": {
          "200": {
            "description": "User information",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V2Envelope"
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/oauth2/Support": {
      "get": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Get temporary support password",
        "description": "Generate a temporary password for support purposes using a valid access token.",
        "operationId": "oauth2_support",
        "security": [
          {
            "OAuth2Basic": []
          }
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Base64-encoded [client_id:client_secret]"
          },
          {
            "name": "client_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Your application ID"
          },
          {
            "name": "access_token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Access token of the user you want to support"
          }
        ],
        "responses": {
          "200": {
            "description": "Temporary password",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V2Envelope"
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/oauth2/authorize": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "OAuth2 authorize",
        "description": "Verify the connection of a user and initiate the OAuth2 authorization flow.",
        "operationId": "oauth2_authorize",
        "security": [
          {
            "OAuth2Basic": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "client_id",
                  "redirect_uri",
                  "scope"
                ],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application ID"
                  },
                  "redirect_uri": {
                    "type": "string",
                    "format": "uri",
                    "description": "Where Hexfit should redirect the user after consent"
                  },
                  "scope": {
                    "type": "string",
                    "description": "Space-delimited list of requested permissions"
                  },
                  "user_id": {
                    "$ref": "#/components/schemas/EntityId",
                    "description": "User ID of the client to connect with"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Email of the client to connect with (alternative to user_id)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authorization code or redirect",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "string",
                      "description": "Authorization code to exchange for a token"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/oauth2/token": {
      "post": {
        "tags": [
          "OAuth2"
        ],
        "summary": "Exchange authorization code for token",
        "description": "Exchange an authorization code or refresh token for an access token.",
        "operationId": "oauth2_token",
        "security": [
          {
            "OAuth2Basic": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": [
                  "client_id",
                  "grant_type"
                ],
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "Your application ID"
                  },
                  "grant_type": {
                    "type": "string",
                    "enum": [
                      "authorization_code",
                      "refresh_token"
                    ],
                    "description": "Grant type"
                  },
                  "code": {
                    "type": "string",
                    "description": "Authorization code (required when grant_type=authorization_code)"
                  },
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh token (required when grant_type=refresh_token)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    },
                    "refresh_token": {
                      "type": "string"
                    },
                    "token_type": {
                      "type": "string",
                      "example": "Bearer"
                    },
                    "expires_in": {
                      "type": "integer",
                      "description": "Seconds until the access token expires"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    }
  },
  "components": {
    "schemas": {
      "EntityId": {
        "type": "string",
        "description": "Hexfit entity identifier \u2014 hexadecimal string prefixed with `h`",
        "pattern": "^h[0-9a-f]+$",
        "example": "h9036281e"
      },
      "DbName": {
        "type": "string",
        "description": "Entity type namespace for polymorphic references",
        "enum": [
          "users",
          "clientGroup",
          "business"
        ],
        "example": "users"
      },
      "V2Envelope": {
        "type": "object",
        "description": "Standard V2 API response envelope",
        "required": [
          "status",
          "value",
          "version"
        ],
        "properties": {
          "status": {
            "type": "boolean",
            "description": "Whether the request succeeded",
            "example": true
          },
          "value": {
            "description": "Response payload (type varies by endpoint)"
          },
          "version": {
            "type": "string",
            "description": "API version string",
            "example": "3.5.2"
          }
        }
      },
      "V3Envelope": {
        "type": "object",
        "description": "Standard V3 API response envelope",
        "required": [
          "success",
          "data",
          "version"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the request succeeded",
            "example": true
          },
          "data": {
            "description": "Response payload (type varies by endpoint)"
          },
          "version": {
            "type": "integer",
            "description": "API version number",
            "example": 3
          }
        }
      },
      "SystemStatus": {
        "type": "object",
        "properties": {
          "status": {
            "type": "integer",
            "description": "System status code: 1 = operational",
            "example": 1
          }
        }
      },
      "Timezone": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "America/Toronto"
          },
          "offset": {
            "type": "string",
            "example": "-05:00"
          }
        }
      },
      "User": {
        "type": "object",
        "description": "Full user profile",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "firstname": {
            "type": "string",
            "example": "Martine"
          },
          "lastname": {
            "type": "string",
            "example": "Ramsey"
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "martine@example.com"
          },
          "lang": {
            "type": "string",
            "description": "IETF language tag",
            "example": "FR-FR"
          },
          "sexe": {
            "type": "string",
            "enum": [
              "m",
              "f"
            ],
            "example": "f"
          },
          "date_created": {
            "type": "string",
            "format": "date-time",
            "example": "2015-08-08 06:42:30"
          },
          "timezone_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "unit_system": {
            "type": "integer",
            "description": "1 = metric, 2 = imperial",
            "example": 1
          },
          "receive_mail": {
            "type": "boolean"
          },
          "showtutorial": {
            "type": "boolean"
          },
          "paper_format": {
            "type": "string",
            "nullable": true
          },
          "profile_picture": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "is_active": {
            "type": "boolean"
          },
          "invite_downloaded_app": {
            "type": "boolean",
            "nullable": true
          },
          "payment_exclude": {
            "type": "boolean",
            "nullable": true
          },
          "profile_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "permit_number": {
            "type": "string",
            "nullable": true
          },
          "is_admin": {
            "type": "boolean"
          },
          "profile": {
            "$ref": "#/components/schemas/PermissionProfile"
          },
          "modules": {
            "type": "object",
            "description": "Map of module name to boolean enabled flag",
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "preferences": {
            "type": "object",
            "description": "Map of preference key to value",
            "additionalProperties": true
          },
          "branch": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "business": {
            "type": "object",
            "additionalProperties": true,
            "description": "Business account details"
          },
          "activities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Activity"
            }
          },
          "fullname": {
            "type": "string",
            "example": "Martine Ramsey"
          },
          "is_client": {
            "type": "boolean"
          },
          "is_professional": {
            "type": "boolean"
          },
          "firstLogin": {
            "type": "boolean"
          },
          "deviceFirstLogin": {
            "type": "boolean"
          },
          "apikey": {
            "type": "string",
            "description": "JWT authentication token for V2 API"
          },
          "job": {
            "type": "string",
            "nullable": true
          },
          "link": {
            "type": "string",
            "nullable": true
          },
          "business_infos": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true
          },
          "metas": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "file_number": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "nbr_pro": {
            "type": "integer",
            "nullable": true
          },
          "not_crypted": {
            "type": "boolean"
          },
          "core_user_id": {
            "type": "string",
            "nullable": true
          },
          "timezone": {
            "$ref": "#/components/schemas/Timezone"
          },
          "apikey_third_party": {
            "type": "string",
            "nullable": true
          },
          "entities": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "terms_accepted": {
            "type": "boolean",
            "nullable": true
          },
          "drango": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true
          },
          "brandingInfo": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true
          },
          "paymentInfo": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true
          }
        }
      },
      "UserSummary": {
        "type": "object",
        "description": "Abbreviated user object used in list contexts",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "firstname": {
            "type": "string"
          },
          "lastname": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "profile_picture": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "is_active": {
            "type": "boolean"
          }
        }
      },
      "CreateClientRequest": {
        "type": "object",
        "required": [
          "firstname",
          "lastname",
          "email"
        ],
        "properties": {
          "firstname": {
            "type": "string"
          },
          "lastname": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "lang": {
            "type": "string",
            "example": "FR-FR"
          },
          "birthday": {
            "type": "string",
            "example": "YYYY-MM-DD"
          },
          "sexe": {
            "type": "string",
            "enum": [
              "m",
              "f"
            ]
          },
          "unit_system": {
            "type": "integer"
          },
          "profile_id": {
            "$ref": "#/components/schemas/EntityId"
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "description": "Fields to update on a user profile (partial update)",
        "properties": {
          "user_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "firstname": {
            "type": "string"
          },
          "lastname": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "lang": {
            "type": "string"
          },
          "sexe": {
            "type": "string"
          },
          "unit_system": {
            "type": "integer"
          },
          "job": {
            "type": "string"
          },
          "permit_number": {
            "type": "string"
          },
          "file_number": {
            "type": "string"
          }
        }
      },
      "PermissionProfile": {
        "type": "object",
        "description": "User permission profile",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "Super administrateur"
          },
          "section": {
            "type": "string",
            "example": "account"
          },
          "business_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "metas": {
            "type": "object",
            "description": "Map of permission key to boolean",
            "additionalProperties": {
              "type": "boolean"
            }
          }
        }
      },
      "Actor": {
        "type": "object",
        "description": "Actor record linking a professional to a client or group",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "user_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "db_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "db_name": {
            "$ref": "#/components/schemas/DbName"
          },
          "is_active": {
            "type": "boolean"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "policies": {
            "$ref": "#/components/schemas/Policies"
          }
        }
      },
      "ClientSummary": {
        "type": "object",
        "description": "Client record as returned in list views",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "firstname": {
            "type": "string"
          },
          "lastname": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "profile_picture": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "is_active": {
            "type": "boolean"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "file_number": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ClientDetails": {
        "type": "object",
        "description": "Full client details for a professional's view",
        "allOf": [
          {
            "$ref": "#/components/schemas/UserSummary"
          },
          {
            "type": "object",
            "properties": {
              "actor": {
                "$ref": "#/components/schemas/Actor"
              },
              "metas": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ClientMeta"
                }
              },
              "objectives": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Objective"
                }
              }
            }
          }
        ]
      },
      "ClientMeta": {
        "type": "object",
        "description": "Custom attribute attached to a client",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "label": {
            "type": "string",
            "description": "Machine-readable key",
            "example": "status_du_prospect"
          },
          "value": {
            "type": "string",
            "nullable": true,
            "example": "Test"
          },
          "name": {
            "type": "string",
            "description": "Human-readable display name",
            "example": "Status du prospect"
          },
          "system_only": {
            "type": "boolean",
            "description": "If true, the attribute is system-defined and read-only",
            "example": false
          }
        }
      },
      "ClientGroup": {
        "type": "object",
        "description": "Client group record",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "Groupe A"
          },
          "long_name": {
            "type": "string",
            "example": "Groupe A"
          },
          "populate_automatically": {
            "type": "boolean"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "nbrmembers": {
            "type": "integer",
            "description": "Number of members in the group",
            "example": 19
          }
        }
      },
      "Training": {
        "type": "object",
        "description": "Training plan / program",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "TEst partage"
          },
          "parent": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "week": {
            "type": "integer",
            "nullable": true
          },
          "created_by": {
            "$ref": "#/components/schemas/UserSummary"
          },
          "is_draft": {
            "type": "boolean"
          },
          "is_template": {
            "type": "boolean"
          },
          "profile_id": {
            "oneOf": [
              {
                "$ref": "#/components/schemas/EntityId"
              },
              {
                "$ref": "#/components/schemas/PermissionProfile"
              }
            ],
            "nullable": true
          },
          "db_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "db_name": {
            "$ref": "#/components/schemas/DbName",
            "nullable": true
          },
          "days": {
            "type": "array",
            "nullable": true,
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "date_modified": {
            "type": "string",
            "format": "date-time"
          },
          "note": {
            "type": "string",
            "nullable": true
          },
          "date_start": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "date_end": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "archived": {
            "type": "boolean"
          },
          "key": {
            "type": "string",
            "description": "Share/access key (JWT)"
          },
          "recurrent": {
            "type": "boolean",
            "nullable": true
          },
          "rrule": {
            "type": "string",
            "nullable": true,
            "description": "iCalendar RRULE string"
          },
          "hide_before_start": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cover_filename": {
            "type": "string",
            "nullable": true
          },
          "is_standalone": {
            "type": "boolean"
          },
          "is_active": {
            "type": "boolean"
          },
          "is_marketplace": {
            "type": "boolean"
          },
          "policies": {
            "$ref": "#/components/schemas/Policies"
          }
        }
      },
