    "/billing/business/{businessId}/client/{clientId}/balance": {
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "Get client billing balance",
        "description": "Returns the billing balance for a client, broken down by intervention\ncode. Optionally includes detailed line items.\n",
        "operationId": "v3_billing_client_balance",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "detail",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by billing status",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Client billing balance",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/BillingBalance"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "balance": {
                      "he77245b0": {
                        "quantity": 0
                      }
                    },
                    "total": 0,
                    "formattedTotal": "0,00 $"
                  },
                  "version": 3
                }
              }
            }
          }
        }
      }
    },
