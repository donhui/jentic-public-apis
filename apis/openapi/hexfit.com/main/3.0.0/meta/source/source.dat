            "required": true,
            "description": "Start of range (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-02-05"
            }
          },
          {
            "name": "endDate",
            "in": "path",
            "required": true,
            "description": "End of range (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-03-05"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated canceled appointments",
