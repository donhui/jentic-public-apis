            "type": "string",
            "format": "email"
          },
          "firstname": {
            "type": "string"
          },
          "lastname": {
            "type": "string"
          },
          "sexe": {
            "type": "string",
            "enum": [
              "m",
              "f",
              "other"
            ]
          },
          "job_id": {
            "$ref": "#/components/schemas/EntityId",
