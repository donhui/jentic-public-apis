            "type": "number"
          },
          "unit_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "meta_date": {
            "type": "string",
            "format": "date-time"
          },
          "note": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Document": {
        "type": "object",
        "description": "Document file record",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "rapport.pdf"
          },
          "filename": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "mime_type": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "description": "File size in bytes"
          },
          "folder_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "db_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "db_name": {
            "$ref": "#/components/schemas/DbName"
          },
          "created_by": {
            "$ref": "#/components/schemas/UserSummary"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "policies": {
            "$ref": "#/components/schemas/Policies"
          }
        }
      },
      "CreateFolderRequest": {
        "type": "object",
        "required": [
          "db_id",
          "db_name",
          "name"
        ],
        "properties": {
          "db_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "db_name": {
            "$ref": "#/components/schemas/DbName"
          },
