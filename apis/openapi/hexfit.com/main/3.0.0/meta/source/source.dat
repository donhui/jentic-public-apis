    "/notifications/upcoming/{startDate}/{endDate}": {
      "get": {
        "tags": [
          "Professional Notifications"
        ],
        "summary": "Get upcoming notifications in range",
        "description": "Returns upcoming notifications grouped by date for a given date range.\nThe `list` map uses ISO date strings as keys.\n",
        "operationId": "v3_notifications_upcoming",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "startDate",
            "in": "path",
            "required": true,
            "description": "Start of date range (YYYY-MM-DD)",
