    "/billing/business/{businessId}/client/{clientId}/invoices/{invoiceId}/cancel": {
      "post": {
        "tags": [
          "Billing"
        ],
        "summary": "Cancel (void) an invoice",
        "description": "Voids the invoice in Stripe and marks it as cancelled in Hexfit.",
        "operationId": "v3_billing_invoice_cancel",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cancellation result",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "canceled": {
                              "type": "boolean"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/billing/business/{businessId}/client/{clientId}/invoices/{invoiceId}/refund": {
      "post": {
        "tags": [
          "Billing"
        ],
        "summary": "Refund a paid invoice",
        "description": "Issues a Stripe refund for the invoice and marks it as refunded in Hexfit.",
        "operationId": "v3_billing_invoice_refund",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Refund result",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "refunded": {
                              "type": "boolean",
                              "example": true
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/billing/business/{businessId}/client/{clientId}/invoices/{invoiceId}/pay": {
      "post": {
        "tags": [
          "Billing"
        ],
        "summary": "Pay or mark invoice as paid",
        "description": "Charges the client's card on file, or marks the invoice as paid out-of-band\nif paid_out_of_band=true is passed by a professional.\n",
        "operationId": "v3_billing_invoice_pay",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "note": {
                    "type": "string",
                    "description": "Optional payment note"
                  },
                  "paid_out_of_band": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, marks as paid without charging Stripe (professional only)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment result",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "paid": {
                              "type": "boolean"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/billing/business/{businessId}/client/{clientId}/cancel-transactional-intervention": {
      "post": {
        "tags": [
          "Billing"
        ],
        "summary": "Set client credit balance",
        "description": "Adds or debits credits from the client's balance per service code.\nPositive quantity = credit, negative quantity = debit.\n",
        "operationId": "v3_billing_client_set_balance",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "credits"
                ],
                "properties": {
                  "credits": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "code_id",
                        "quantity"
                      ],
                      "properties": {
                        "code_id": {
                          "$ref": "#/components/schemas/EntityId"
                        },
                        "quantity": {
                          "type": "integer",
                          "description": "Positive = add credit, negative = debit",
                          "example": 3
                        }
                      }
                    }
                  }
                }
              },
              "example": {
                "credits": [
                  {
                    "code_id": "hXXXXX",
                    "quantity": 3
                  },
                  {
                    "code_id": "hYYYYY",
                    "quantity": -1
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Array of created or updated interventions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          }
        }
      }
    },
    "/billing/business/{businessId}/client/{clientId}/balance/unpaid-transactional-interventions": {
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "List unpaid transactional interventions",
        "description": "Returns all unbilled transactional interventions for a client.",
        "operationId": "v3_billing_client_unpaid_transactional",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
