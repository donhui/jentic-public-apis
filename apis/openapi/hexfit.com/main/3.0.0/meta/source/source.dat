          },
          "profile_id": {
            "$ref": "#/components/schemas/EntityId",
            "description": "Permission profile ID"
          },
          "branch_id": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EntityId"
            },
            "description": "Branch IDs to assign"
          },
          "bundle": {
            "type": "string",
            "description": "License bundle type (e.g. \"mine\")",
            "nullable": true
          },
          "modules": {
            "type": "object",
            "nullable": true,
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "payment_exclude": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "ContactInfoType": {
