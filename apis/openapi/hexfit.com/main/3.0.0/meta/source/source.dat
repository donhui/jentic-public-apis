        "summary": "Get AI reply suggestion for a notification",
        "description": "Returns an AI-generated message suggestion based on the type of notification\n(birthday, activity completed, training comment). Only works when\nai_answer_available is true on the notification.\n",
        "operationId": "ai_notification_message",
        "parameters": [
          {
