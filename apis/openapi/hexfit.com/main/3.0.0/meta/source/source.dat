          }
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Unit group list",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/UnitGroup"
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": [
                    {
                      "id": "h74cf454b",
                      "name": "longueur",
                      "system": false,
                      "is_active": true,
                      "units": [
                        {
                          "id": "hc363651a",
                          "group_id": "h74cf454b",
                          "unit": "kilometre",
                          "unit_system": 1,
                          "abbreviation": "km",
                          "default": false
                        }
                      ]
                    }
                  ],
                  "version": 3
                }
              }
            }
          }
        }
      }
    },
    "/querybuilder/queries": {
      "get": {
        "tags": [
          "Analytics & Stats"
        ],
        "summary": "Get saved query builder queries",
        "description": "Returns the list of saved query-builder queries for the current business,\npaginated and optionally sorted.\n",
        "operationId": "v3_querybuilder_queries",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 30
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Saved queries list",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "list": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "additionalProperties": true
                              }
                            },
                            "has_more": {
                              "type": "boolean"
                            },
                            "page": {
                              "type": "integer"
                            },
                            "pages": {
                              "type": "integer"
                            },
                            "limit": {
                              "type": "integer"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "list": [],
                    "has_more": false,
                    "page": 1,
                    "pages": 1,
                    "limit": 30
                  },
                  "version": 3
                }
              }
            }
          }
        }
      }
    },
    "/billing/invoices": {
