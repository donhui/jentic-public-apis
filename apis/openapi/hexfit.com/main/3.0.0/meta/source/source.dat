            },
            "default": []
          },
          "profile_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "db_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "db_name": {
            "$ref": "#/components/schemas/DbName"
          },
          "metas": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            },
            "default": []
          },
          "color": {
            "type": "string",
            "description": "Hex color string without",
            "example": "ff9933"
          },
          "model_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "model_type": {
            "type": "string",
            "nullable": true
          },
          "all_day": {
            "type": "boolean",
            "default": false
          },
