            "additionalProperties": {
              "type": "object",
              "properties": {
                "quantity": {
                  "type": "integer"
                }
              }
            }
          },
          "total": {
            "type": "number",
            "format": "float",
            "description": "Total balance amount"
          },
          "formattedTotal": {
            "type": "string",
            "description": "Localised currency-formatted total",
            "example": "0,00 $"
          }
        }
      },
      "InvoiceBalance": {
        "type": "object",
        "description": "Total invoice balance",
        "properties": {
          "total": {
            "type": "number",
            "format": "float"
          },
          "formattedTotal": {
            "type": "string",
            "example": "0,00 $"
          }
        }
      },
      "Unit": {
        "type": "object",
        "description": "Unit of measure",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "kg"
          },
          "symbol": {
            "type": "string",
            "example": "kg"
          },
          "is_default": {
            "type": "boolean"
          },
          "data_id": {
            "$ref": "#/components/schemas/EntityId"
          }
        }
      },
      "Activity": {
        "type": "object",
        "description": "Activity type definition",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "Musculation"
          },
          "icon": {
            "type": "string",
            "nullable": true
          },
          "color": {
            "type": "string",
            "nullable": true
          },
          "is_active": {
            "type": "boolean"
          }
        }
      },
      "Policies": {
        "type": "object",
        "description": "CRUD permission flags for a resource",
        "properties": {
          "view": {
            "type": "boolean"
          },
          "create": {
            "type": "boolean"
          },
          "update": {
            "type": "boolean"
          },
          "delete": {
            "type": "boolean"
          },
          "archive": {
            "type": "boolean",
            "description": "Present on some resource types only"
          },
          "clone": {
            "type": "boolean",
            "description": "Present on some resource types only"
          }
        }
      },
      "PaginatedList": {
        "type": "object",
        "description": "Generic paginated list wrapper used by V3 API",
        "properties": {
          "list": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether more pages are available"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "limit": {
            "oneOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ],
            "description": "Items per page (may be integer or numeric string)"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "login",
          "password",
          "device_key"
        ],
        "description": "Credentials for V2 login",
        "properties": {
          "login": {
            "type": "string",
            "format": "email",
            "description": "User email address",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "Account password"
          },
          "device_key": {
            "type": "string",
            "description": "Short alphanumeric token identifying the client device",
            "example": "5C27F"
          },
          "mobile_key": {
            "type": "string",
            "description": "Push-notification registration key (mobile clients)",
            "nullable": true
          }
        }
      },
      "UserV3Summary": {
        "type": "object",
        "description": "Condensed user summary returned by the V3 REST endpoint",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "fullname": {
            "type": "string",
            "example": "Dev (client) Etienne"
          },
          "firstname": {
            "type": "string",
            "example": "Dev (client)"
          },
          "lastname": {
            "type": "string",
            "example": "Etienne"
          },
          "is_client": {
            "type": "boolean",
            "nullable": true
          },
          "is_professional": {
            "type": "boolean",
            "nullable": true
          },
          "profile_picture": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "lastWeight": {
            "type": "object",
            "nullable": true,
            "description": "Most recent weight measurement",
            "properties": {
              "id": {
                "$ref": "#/components/schemas/EntityId"
              },
              "meta_date": {
                "type": "string",
                "format": "date-time"
              },
              "value": {
                "type": "number",
                "format": "double"
              }
            }
          }
        }
      },
      "AvailabilityPreferences": {
        "type": "object",
        "description": "Professional's appointment availability configuration",
        "properties": {
          "buffer": {
            "type": "string",
            "description": "Buffer time between appointments (HH:mm)",
            "example": "00:00"
          },
          "warning": {
            "type": "string",
            "description": "Advance warning time for appointments (HH:mm)",
            "example": "24:00"
          },
          "increment": {
            "type": "string",
            "description": "Scheduling increment (HH:mm)",
            "example": "01:00"
          },
          "reminder": {
            "type": "string",
            "description": "Reminder lead time in hours",
            "example": "24"
          },
          "week": {
            "type": "array",
            "description": "Default weekly hours (applied to Mon-Fri unless overridden)",
            "items": {
              "$ref": "#/components/schemas/TimeRange"
            }
          },
          "weekOpen": {
            "type": "boolean",
            "description": "Whether weekday availability is enabled"
          },
          "weekend": {
            "type": "object",
            "description": "Override hours by ISO weekday number (6=Sat, 7=Sun)",
            "additionalProperties": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/TimeRange"
              }
            }
          },
          "weekendOpen": {
            "type": "boolean",
            "description": "Whether weekend availability is enabled"
          }
        }
      },
      "TimeRange": {
        "type": "object",
        "description": "A from-to time slot",
        "properties": {
          "from": {
            "type": "string",
            "description": "Start time (HH:mm)",
            "example": "09:00"
          },
          "to": {
            "type": "string",
            "description": "End time (HH:mm)",
            "example": "21:00"
          }
        }
      },
      "CreateProfessionalRequest": {
        "type": "object",
        "required": [
          "email",
          "firstname",
          "lastname",
          "sexe",
          "job_id",
          "profile_id"
