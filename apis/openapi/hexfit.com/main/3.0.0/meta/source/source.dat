{
  "openapi": "3.0.3",
  "info": {
    "title": "Hexfit API",
    "version": "3.0.0",
    "description": "Hexfit is a comprehensive fitness and health management platform for professionals and clients. \nThe Hexfit API provides programmatic access to a wide range of features and data within the Hexfit ecosystem, enabling seamless integration with third-party applications and custom workflows.\n\nThe structure of the API endpoint is https://[version].[environment].hexfit.io/[resource].\n\nVersion are representing the old API and the new one. We are slowly passing from v2 -> v3. Therefore, some endpoint are still in v2 and some are in v3. The v3 is the future of our API and the one we are actively developing. \n\n## Versions\n### V2 Specifications\nResponses use the envelope `{\"success\": true, \"value\": ..., \"version\": 3}`.\n\n### V3 specifications \nResponses use the envelope `{\"success\": true, \"data\": ..., \"version\": 3}`.\n\nIn case of an error, the response use the envelope : `{\"success\": false, \"message\": \"\", \"code\": 500, \"version\": 3}`.\n\n## Environments\n\nWe have two environments (you need to use the one base on your account) : \n- ca : Canada\n- eu : Europe\n\n## Authentication\n\nAuthentication is using Bearer token.\n",
    "contact": {
      "name": "Hexfit",
      "url": "https://hexfit.com"
    }
  },
  "x-v2-servers": [
    {
      "url": "https://v2.{region}.hexfit.io",
      "description": "V2 API (legacy).",
      "variables": {
        "region": {
          "default": "ca",
          "enum": [
            "ca",
            "eu"
          ]
        }
      }
    }
  ],
  "servers": [
    {
      "url": "https://v3.{region}.hexfit.io",
      "description": "V3 API",
      "variables": {
        "region": {
          "default": "ca",
          "enum": [
            "ca",
            "eu"
          ]
        }
      }
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "System",
      "description": "Health checks and status"
    },
    {
      "name": "Users",
      "description": "User account management, profile and preferences"
    },
    {
      "name": "Clients",
      "description": "Clients details"
    },
    {
      "name": "Groups",
      "description": "Client group management"
    },
    {
      "name": "Trainings",
      "description": "Training plans, programs, seances and templates"
    },
    {
      "name": "Events & Calendar",
      "description": "Calendar events, appointments and daily summaries"
    },
    {
      "name": "Physical Data & Measurements",
      "description": "Body composition, biometric and activity data"
    },
    {
      "name": "Professional Notifications",
      "description": "Notification in the Today Tab"
    },
    {
      "name": "Announcements",
      "description": "In-app notification"
    },
    {
      "name": "Tasks",
      "description": "Task management for professionals"
    },
    {
      "name": "Billing",
      "description": "Client billing balances and invoice management"
    },
    {
      "name": "Plans",
      "description": "Subscription and plan management"
    },
    {
      "name": "Analytics & Stats",
      "description": "Professional dashboard statistics and client engagement metrics"
    },
    {
      "name": "Appointments",
      "description": "Appointment event models and recurring event generators"
    },
    {
      "name": "AI",
      "description": "AI-powered features \u2014 training generation and note cleaning"
    },
    {
      "name": "Business",
      "description": "Business account settings, employees, integrations and preferences"
    },
    {
      "name": "Challenges",
      "description": "Community fitness challenges"
    },
    {
      "name": "Actors",
      "description": "Professional-to-client relationships, client listings and details"
    },
    {
      "name": "Interventions & Notes",
      "description": "Clinical notes, intervention records keyed by intervention codes"
    },
    {
      "name": "Objectives",
      "description": "Goal setting and progress tracking"
    },
    {
      "name": "Documents & Folders",
      "description": "File storage, document upload and folder organisation"
    },
    {
      "name": "Messaging & Discussions",
      "description": "Real-time messaging, discussion threads"
    },
    {
      "name": "OAuth2",
      "description": "OAuth2 authorization flows for third-party partner integrations"
    }
  ],
  "paths": {
    "/system/status": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Get system status",
        "description": "Returns the current operational status of the V3 API.",
        "operationId": "v3_system_status",
        "responses": {
          "200": {
            "description": "System status",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/SystemStatus"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "status": 1
                  },
                  "version": 3
                }
              }
            }
          }
        }
      }
    },
    "/user/preferences/{key}": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get user preference",
        "description": "Returns the value of a specific user preference key.",
        "operationId": "v3_user_get_preference",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "required": true,
            "description": "Preference key",
            "schema": {
              "type": "string",
              "example": "sidebar_collapsed"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Preference value",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "description": "Preference object",
                          "additionalProperties": true
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/user/desactivate/{userId}": {
      "post": {
        "tags": [
          "Clients"
        ],
        "summary": "Deactivate a user",
        "description": "Marks the specified user as inactive.",
        "operationId": "v3_user_deactivate",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deactivation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          }
        }
      }
    },
    "/profile": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Get permission profiles",
        "description": "Returns permission profiles. Pass `section=global` to retrieve all\navailable profiles.\n",
        "operationId": "v3_profile_get",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "section",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "global"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Permission profiles",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/PermissionProfile"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/clients/{clientId}/metas/": {
      "get": {
        "tags": [
          "Clients"
        ],
        "summary": "Get client custom attributes",
        "description": "Returns all custom meta attributes for a client.",
        "operationId": "v3_clients_get_metas",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Client meta attributes",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/ClientMeta"
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": [
                    {
                      "id": "h7e3e43b5",
                      "label": "status_du_prospect",
                      "value": "Test",
                      "name": "Status du prospect",
                      "system_only": false
                    },
                    {
                      "id": null,
                      "label": "this_is_an_attribute",
                      "value": null,
                      "name": "This is an attribute",
                      "system_only": true
                    }
                  ],
                  "version": 3
                }
              }
            }
          }
        }
      }
    },
    "/clients/{clientId}/metas/{metaKey}": {
      "put": {
        "tags": [
          "Clients"
        ],
        "summary": "Update client custom attribute",
        "description": "Updates a specific custom meta attribute for a client.",
        "operationId": "v3_clients_put_meta",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "metaKey",
            "in": "path",
            "required": true,
            "description": "Meta attribute label/key (e.g. `status_du_prospect`). Required only if using the \"update one meta\" request body format.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "title": "Update a single meta (by key in path)",
                    "type": "object",
                    "required": [
                      "value"
                    ],
                    "properties": {
                      "value": {
                        "type": "string",
                        "nullable": true
                      }
                    }
                  },
                  {
                    "title": "Update multiple metas at once",
                    "type": "object",
                    "required": [
                      "metas"
                    ],
                    "properties": {
                      "metas": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": [
                            "label",
                            "value"
                          ],
                          "properties": {
                            "label": {
                              "type": "string",
                              "example": "status_du_prospect"
                            },
                            "value": {
                              "type": "string",
                              "nullable": true,
                              "example": "Client"
                            }
                          }
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated attribute",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ClientMeta"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/groups/client/": {
      "get": {
        "tags": [
          "Groups"
        ],
        "summary": "Get client groups",
        "description": "Returns a paginated, searchable list of client groups for an actor.",
        "operationId": "v3_groups_client_get",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "actor_id",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 30
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "searchKeywords",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated client group list",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/PaginatedList"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "success": true,
                  "data": {
                    "list": [
                      {
                        "id": "had0d7c42",
                        "name": "Groupe A",
                        "populate_automatically": false,
                        "date_created": "2015-08-20 01:19:07",
                        "long_name": "Groupe A",
                        "nbrmembers": 19
                      }
                    ],
                    "has_more": false,
                    "page": 1,
                    "limit": "30"
                  },
                  "version": 3
                }
              }
            }
          }
        }
      }
    },
    "/trainings/{trainingId}/clone": {
      "post": {
        "tags": [
          "Trainings"
        ],
        "summary": "Clone a training",
        "description": "Creates a copy of an existing training plan, optionally assigned to a client.",
        "operationId": "v3_trainings_clone",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "trainingId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CloneTrainingRequest"
              },
              "example": {
                "db_id": "h22cf01d3",
                "db_name": "users",
                "is_draft": false,
                "date_start": "2026-03-05"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cloned training",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Training"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/plans/users/{userId}": {
      "get": {
        "tags": [
          "Plans"
        ],
        "summary": "Get user plans",
        "description": "Returns subscription/program plans for a user.",
        "operationId": "v3_plans_users",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User plans",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "additionalProperties": true
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/events/": {
      "post": {
        "tags": [
          "Events & Calendar"
        ],
        "summary": "Create an event",
        "description": "Creates a new calendar event.",
        "operationId": "v3_events_create",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEventRequest"
              },
              "example": {
                "name": "Test",
                "activity_id": "h80fa62f6",
                "date_start": "2026-03-05 08:00",
                "date_end": null,
                "description": "",
                "recurrent": null,
                "documents": [],
                "trainings": [],
                "profile_id": "hd5e4a392",
                "db_id": "he8c6a492",
                "db_name": "users",
                "metas": [],
                "color": "ff9933",
                "model_id": null,
                "model_type": null,
                "all_day": false,
                "force_date_change": false,
                "excludes": [],
                "invites": []
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created event",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Event"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "201": {
            "description": "Event created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Event"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/events/{eventId}": {
      "get": {
        "tags": [
          "Events & Calendar"
        ],
        "summary": "Get event details",
        "description": "Returns full details for a specific event.",
        "operationId": "v3_events_get",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "eventId",
