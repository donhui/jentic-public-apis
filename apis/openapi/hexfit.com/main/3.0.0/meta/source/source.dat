            }
          }
        }
      }
    },
    "/calendar/allEvents": {
      "get": {
        "tags": [
          "Events & Calendar"
        ],
        "summary": "Get all calendar events",
        "description": "Returns all events within a date range for an entity (user/group/business).",
        "operationId": "v3_calendar_all_events",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "db_id",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "db_name",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/DbName"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-03-01"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-03-31"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Calendar events",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Event"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/calendar/dailyDataMetaSummary": {
      "get": {
        "tags": [
          "Events & Calendar"
        ],
        "summary": "Get daily data meta summary",
        "description": "Returns aggregated physical measurement data grouped by date, for\ndisplay in the calendar view.\n",
        "operationId": "v3_calendar_daily_data_meta_summary",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "db_id",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "db_name",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/DbName"
            }
          },
          {
            "name": "start_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "end_date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daily data summary keyed by date",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "description": "Map of date string (YYYY-MM-DD) to array of daily data entries",
                          "additionalProperties": {
                            "type": "array",
                            "items": {
                              "$ref": "#/components/schemas/DailyDataEntry"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/appointment/events-model-list/": {
      "get": {
        "tags": [
          "Appointments"
        ],
        "summary": "Get appointment event model list",
        "description": "Returns paginated event models available for creating appointments.",
