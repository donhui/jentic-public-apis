              "$ref": "#/components/schemas/DataFormula"
            }
          }
        }
      },
      "DataCategoryV3": {
        "type": "object",
        "description": "Data-type category definition",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "G\u00e9n\u00e9ral"
          },
          "show_order": {
            "type": "integer"
          },
          "created_by": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "last_id_modified": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "date_modified": {
            "type": "string",
            "format": "date-time"
          },
          "business_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "secteur": {
