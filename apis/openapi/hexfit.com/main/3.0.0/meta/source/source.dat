              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of unpaid interventions",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "metas_info": {
                                "type": "object",
                                "properties": {
                                  "price": {
                                    "type": "integer"
                                  },
                                  "currency": {
                                    "type": "string"
                                  },
                                  "formatted_price": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/billing/business/{businessId}/taxes": {
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "List business tax rates",
        "description": "Returns all Stripe tax rates configured for the business.",
        "operationId": "v3_billing_taxes_list",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of tax rates",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "description": "Stripe tax rate ID",
                                "example": "txr_xxx"
                              },
                              "name": {
                                "type": "string",
                                "example": "TPS"
                              },
                              "percentage": {
                                "type": "number",
                                "example": 5
                              }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Billing"
        ],
        "summary": "Create a tax rate",
        "description": "Creates a new Stripe tax rate for the business.",
        "operationId": "v3_billing_taxes_create",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "tax_number",
                  "percentage"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Display name of the tax",
                    "example": "TPS"
                  },
                  "tax_number": {
                    "type": "string",
                    "description": "Official tax registration number",
                    "example": "123456789RT0001"
                  },
                  "percentage": {
                    "type": "number",
                    "description": "Tax rate percentage",
                    "example": 5
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tax rate created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          }
        }
      }
    },
    "/billing/business/{businessId}/taxes/{taxId}": {
      "delete": {
        "tags": [
          "Billing"
        ],
        "summary": "Delete a tax rate",
        "description": "Deletes a Stripe tax rate and removes it from any business payment preferences.",
        "operationId": "v3_billing_taxes_delete",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "taxId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Stripe tax rate ID (e.g. txr_xxx)"
          }
        ],
        "responses": {
          "200": {
            "description": "Tax rate deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/V3Envelope"
                }
              }
            }
          }
        }
      }
    },
    "/billing/business/{businessId}/invoices": {
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "List all business invoices",
        "description": "Returns paginated invoices for a business across all clients. Filterable by status and keyword.",
        "operationId": "v3_billing_business_invoices",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "open"
              ]
            },
            "description": "Omit for paid invoices; pass open for unpaid"
          },
          {
            "name": "searchKeywords",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by client name, date or amount"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of invoices",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "allOf": [
                            {
                              "$ref": "#/components/schemas/PaginatedList"
                            },
                            {
                              "type": "object",
                              "properties": {
                                "data": {
                                  "type": "array",
                                  "items": {
                                    "$ref": "#/components/schemas/HexfitInvoice"
                                  }
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/billing/business/{businessId}/balance": {
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "Get all clients' billing balances",
        "description": "Returns a paginated list of all clients with their outstanding credit balance.",
        "operationId": "v3_billing_business_balance",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Field to sort by; prefix with \"-\" for DESC (e.g. -total)"
          },
          {
            "name": "searchKeywords",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Search by client name or email"
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated client balances",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "allOf": [
                            {
                              "$ref": "#/components/schemas/PaginatedList"
                            },
                            {
                              "type": "object",
                              "properties": {
                                "data": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "client": {
                                        "$ref": "#/components/schemas/UserSummary"
                                      },
                                      "business_id": {
                                        "$ref": "#/components/schemas/EntityId"
                                      },
                                      "total": {
                                        "type": "integer"
                                      },
                                      "total_formatter": {
                                        "type": "string"
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
