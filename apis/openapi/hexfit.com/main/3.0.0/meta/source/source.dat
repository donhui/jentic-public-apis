          },
          "is_active": {
            "type": "boolean"
          },
          "is_model": {
            "type": "boolean"
          },
          "last_id_modified": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "date_modified": {
            "type": "string",
            "format": "date-time"
          },
          "date_created": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "is_new_event_type": {
            "type": "boolean"
          },
          "is_an_appointment": {
            "type": "boolean"
          },
