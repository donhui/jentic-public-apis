            "nullable": true
          },
          "code_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Document"
            }
          },
          "allDay": {
            "type": "boolean"
          },
          "scheduledEventInfo": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true
          },
          "completedEventInfo": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true
          },
          "completionRate": {
            "type": "number",
            "format": "float",
            "nullable": true
          },
          "metas": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "isRecurrent": {
            "type": "boolean"
          }
        }
      },
      "CreateEventRequest": {
        "type": "object",
