      "JobType": {
        "type": "object",
        "description": "Professional job type definition",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "example": "coach"
          }
        }
      },
      "UnitGroup": {
        "type": "object",
        "description": "A group of related units of measure",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "description": "Group name (e.g. \"longueur\", \"mass\")",
            "example": "longueur"
          },
          "system": {
            "type": "boolean",
            "description": "Whether this is a system-defined group"
          },
          "is_active": {
            "type": "boolean"
          },
          "units": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UnitInGroup"
            }
          }
        }
      },
      "UnitInGroup": {
        "type": "object",
        "description": "A single unit within a unit group",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "group_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "unit": {
            "type": "string",
            "description": "Full unit name",
            "example": "kilometre"
          },
          "unit_system": {
            "type": "integer",
            "description": "0 = imperial, 1 = metric",
            "example": 1
          },
          "abbreviation": {
            "type": "string",
            "example": "km"
          },
          "default": {
            "type": "boolean"
          }
        }
      },
      "Exercise": {
        "type": "object",
        "description": "An exercise from the exercise bank",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "name": {
            "type": "string",
            "description": "Exercise name",
            "example": "Squat"
          },
          "description": {
            "type": "string",
            "description": "Exercise instructions/description"
          },
          "lang": {
            "type": "string",
            "description": "Language of the exercise content",
            "example": "FR-CA"
          },
          "favorite": {
            "type": "boolean",
            "description": "Whether this exercise is marked as a favourite"
          },
          "muscles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Primary muscles targeted"
          },
          "category": {
            "type": "string",
            "description": "Exercise category"
          }
        }
      },
      "UserMeta": {
        "type": "object",
        "description": "A user meta entry (phone number, address, secondary email, etc.)",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "user_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "type": {
            "type": "string",
            "description": "Meta type (e.g. phone, address, email)",
            "example": "phone"
          },
          "value": {
            "type": "string",
            "description": "Meta value",
            "example": "418-780-5372"
          },
          "name": {
            "type": "string",
            "description": "Label for the meta entry",
            "example": "Work"
          }
        }
      },
      "PaymentInfo": {
        "type": "object",
        "description": "Payment method and billing address on file",
        "properties": {
          "brand": {
            "type": "string",
            "description": "Card brand",
            "example": "Visa"
          },
          "last4": {
            "type": "string",
            "description": "Last 4 digits of the card",
            "example": "4242"
          },
          "currency": {
            "type": "string",
            "example": "CAD"
          },
          "invoice_address": {
            "type": "object",
            "properties": {
              "address": {
                "type": "string"
              },
              "country": {
                "type": "string",
                "example": "CA"
              },
              "province": {
                "type": "string",
                "example": "QC"
              },
              "zip_code": {
                "type": "string",
                "example": "G1K 1A1"
              }
            }
          }
        }
      },
      "UpdateCardRequest": {
        "type": "object",
        "required": [
          "stripeToken",
          "invoice_address"
        ],
        "properties": {
          "stripeToken": {
            "type": "string",
            "description": "Stripe payment method token",
            "example": "tok_visa"
          },
          "invoice_address": {
            "type": "object",
            "required": [
              "address",
              "country",
              "zip_code"
            ],
            "properties": {
              "address": {
                "type": "string",
                "example": "123 Rue Principale"
              },
              "country": {
                "type": "string",
                "example": "CA"
              },
              "province": {
                "type": "string",
                "description": "Required when country is CA",
                "example": "QC"
              },
              "zip_code": {
                "type": "string",
                "maxLength": 20,
                "example": "G1K 1A1"
              }
            }
          }
        }
      },
      "SubscriptionInvoice": {
        "type": "object",
        "description": "Hexfit subscription invoice with pricing breakdown",
        "properties": {
          "currency": {
            "type": "string",
            "example": "CAD"
          },
          "bundle": {
            "type": "string",
            "example": "bundle_2023_professional_5"
          },
          "professional-module": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "nutrition"
            ]
          },
          "stripe-products": {
            "type": "object",
            "description": "Stripe product IDs and quantities"
          },
          "coupon": {
            "type": "string",
            "example": "PROMO2024"
          },
          "price-before-coupon": {
            "type": "string",
            "description": "Formatted price before coupon",
            "example": "99,00 $"
          },
          "price": {
            "type": "string",
            "description": "Formatted price after coupon",
            "example": "79,00 $"
          },
          "percent_off": {
            "type": "number",
            "nullable": true,
            "example": 20
          },
          "amount_off": {
            "type": "integer",
            "nullable": true,
            "description": "Fixed discount amount in cents"
          },
          "taxes": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Tax name to formatted amount mapping",
            "example": {
              "TPS": "3,95 $",
              "TVQ": "7,88 $"
            }
          },
          "total": {
            "type": "string",
            "description": "Formatted total including taxes",
            "example": "90,83 $"
          },
          "interval": {
            "type": "string",
            "enum": [
              "month",
              "year",
              "quarter"
            ]
          },
          "is-latam": {
            "type": "boolean"
          },
          "cancelled": {
            "type": "boolean"
          },
          "max-clients": {
            "type": "integer",
            "nullable": true,
            "example": 5
          }
        }
      },
      "HexfitInvoice": {
        "type": "object",
        "description": "A Hexfit-managed invoice for a client",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "business_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "db_id": {
            "$ref": "#/components/schemas/EntityId",
            "description": "Client user ID"
          },
          "db_name": {
            "type": "string",
            "example": "users"
          },
          "total": {
            "type": "integer",
            "description": "Invoice total in cents"
          },
          "total_formatted": {
            "type": "string",
            "description": "Formatted total string",
            "example": "150,00 $"
          },
          "currency": {
            "type": "string",
            "example": "CAD"
          },
          "note": {
            "type": "string",
            "nullable": true
          },
          "paid_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "cancel_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "owner": {
            "$ref": "#/components/schemas/UserSummary"
          }
        }
      },
      "StripeInvoice": {
        "type": "object",
        "description": "A Stripe invoice for the professional's own subscription",
        "properties": {
          "id": {
            "type": "string",
            "description": "Stripe invoice ID",
            "example": "in_xxx"
          },
          "total": {
            "type": "integer",
            "description": "Amount in cents"
          },
          "currency": {
            "type": "string",
            "example": "cad"
          },
          "status": {
            "type": "string",
            "example": "paid"
          },
          "created": {
            "type": "integer",
            "description": "Unix timestamp"
          },
          "invoice_pdf": {
            "type": "string",
            "format": "uri",
            "description": "URL to download the PDF"
          }
        }
      },
      "Challenge": {
        "type": "object",
        "description": "A fitness challenge assigned to a client group",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "title": {
            "type": "string",
            "example": "Most push-ups in a month!"
          },
          "description": {
            "type": "string"
          },
          "image": {
            "type": "string",
            "description": "YouTube embed URL",
            "example": "https://www.youtube.com/embed/kBX5WH9b4M4"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "data_type": {
            "type": "string",
            "enum": [
              "COUNT",
              "MAX",
              "MIN",
              "SUM"
            ]
          },
          "is_over": {
            "type": "boolean"
          },
          "is_archived": {
            "type": "boolean"
          },
          "client_group_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "data": {
            "type": "object",
            "description": "The data type being tracked"
          },
          "unit": {
            "type": "object",
            "properties": {
              "id": {
                "$ref": "#/components/schemas/EntityId"
              },
              "unit": {
                "type": "string"
              },
              "abbreviation": {
                "type": "string"
              }
            }
          },
          "creatorInfo": {
            "type": "object",
            "properties": {
              "id": {
                "$ref": "#/components/schemas/EntityId"
              },
              "fullname": {
                "type": "string"
              }
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ChallengeWithPodium": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Challenge"
          },
          {
            "type": "object",
            "properties": {
              "podium": {
                "type": "array",
                "description": "Ranked list of participants",
                "items": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "number",
                      "description": "Participant's score"
                    },
                    "podium": {
                      "type": "integer",
                      "description": "Rank position"
                    },
                    "user_info": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "$ref": "#/components/schemas/EntityId"
                        },
                        "fullname": {
                          "type": "string"
                        },
                        "firstname": {
                          "type": "string"
                        },
                        "lastname": {
                          "type": "string"
                        },
                        "profile_picture": {
                          "type": "string",
                          "format": "uri"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "ChallengeRequest": {
        "type": "object",
        "required": [
          "title",
          "description",
          "data_type",
          "data_id",
          "unit_id",
          "start_date",
          "end_date",
          "image",
          "client_group_id"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "data_type": {
            "type": "string",
            "enum": [
              "COUNT",
              "MAX",
              "MIN",
              "SUM"
            ]
          },
          "data_id": {
            "$ref": "#/components/schemas/EntityId",
            "description": "Data type ID being tracked"
          },
          "unit_id": {
            "$ref": "#/components/schemas/EntityId"
          },
          "start_date": {
            "type": "string",
            "format": "date"
          },
          "end_date": {
            "type": "string",
            "format": "date"
          },
          "image": {
            "type": "string",
            "description": "Valid YouTube URL (watch?v= or embed/ format required)",
            "example": "https://www.youtube.com/watch?v=kBX5WH9b4M4"
          },
          "client_group_id": {
            "$ref": "#/components/schemas/EntityId"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "OAuth2Basic": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic authentication where the username is client_id and\npassword is client_secret, Base64-encoded as per RFC 7617.\nUsed for OAuth2 partner endpoints.\nUsed by V3 API endpoints.\n"
      }
    }
  },
  "x-jentic-source-url": "https://docs.hexfit.com/openapi.yaml"
}