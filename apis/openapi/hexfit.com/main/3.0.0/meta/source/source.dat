    "/events-generators/{generatorId}/{date}": {
      "get": {
        "tags": [
          "Events & Calendar"
        ],
        "summary": "Get a recurring event instance",
        "description": "Returns the event generated by a recurring event generator for the\nspecified occurrence date. Used by the mobile client to load a specific\nworkout appointment from a recurring series.\n",
        "operationId": "v3_events_generators_get",
        "x-client": "mobile",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "generatorId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "date",
            "in": "path",
            "required": true,
            "description": "ISO 8601 date of the occurrence (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-03-06"
            }
          },
          {
            "name": "db_id",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "db_name",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/DbName"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event instance",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Event"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Events & Calendar"
        ],
        "summary": "Update a recurring event occurrence",
        "description": "Updates a specific occurrence of a recurring event generator (e.g. to\nreschedule a single appointment in a series). The `affect` query\nparameter controls scope: `single` updates only this occurrence.\n",
        "operationId": "v3_events_generators_patch",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "generatorId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "date",
            "in": "path",
            "required": true,
            "description": "ISO 8601 date of the occurrence to update",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-03-12"
            }
          },
          {
            "name": "affect",
            "in": "query",
            "description": "Scope of update \u2014 `single` or `all`",
            "schema": {
              "type": "string",
              "enum": [
                "single",
                "all"
              ],
              "default": "single"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "date_start": {
                    "type": "string",
                    "description": "New start date-time (YYYY-MM-DD HH:mm)",
                    "example": "2026-03-14 00:00"
                  },
                  "date_end": {
                    "type": "string",
                    "description": "New end date-time",
                    "example": "2026-03-14 01:00"
                  },
                  "force_date_change": {
                    "type": "boolean",
                    "default": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated event",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Event"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/canceled-appointments/{startDate}/{endDate}": {
      "get": {
        "tags": [
          "Appointments"
        ],
        "summary": "Get canceled appointments in range",
        "description": "Returns a paginated list of appointments that were marked as cancelled\nwithin the given date range.\n",
        "operationId": "v3_canceled_appointments",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
