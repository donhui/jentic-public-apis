          },
          "category_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "business_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "code_r_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "formula_only": {
            "type": "boolean",
            "nullable": true
          },
          "referer_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "symbol": {
            "type": "string",
            "nullable": true
          },
          "profile_id": {
            "$ref": "#/components/schemas/EntityId",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "formulas": {
            "type": "array",
