    "/ai/intervention/clean": {
      "post": {
        "tags": [
          "AI"
        ],
        "summary": "Clean and reformat a clinical note",
        "description": "Uses AI to clean and reformat a raw clinical note into a structured\nformat (generic, SOAP, or SOAPIE). The output language matches the\nauthenticated professional's language setting.\n",
        "operationId": "ai_clean_intervention",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "format",
                  "note"
                ],
                "properties": {
                  "format": {
                    "type": "string",
                    "enum": [
                      "generic",
                      "soap",
                      "soapie"
                    ],
                    "description": "Output format for the cleaned note"
                  },
                  "note": {
                    "type": "string",
                    "description": "Raw clinical note text to clean"
                  }
                }
              },
              "example": {
                "format": "soap",
                "note": "Client came in, did some exercises, felt tired at the end."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cleaned note",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "note": {
                              "type": "string",
                              "description": "AI-cleaned and reformatted note"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/ai/birthday/{client}": {
      "get": {
        "tags": [
          "AI"
        ],
        "summary": "Generate a birthday message for a client",
        "description": "Uses AI to generate a short, personalized birthday message for a client,\nwritten in the client's language and referencing the professional relationship.\n",
        "operationId": "ai_birthday",
        "parameters": [
          {
            "name": "client",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            },
            "description": "Client user ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Generated birthday message",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "message": {
                              "type": "string",
                              "description": "AI-generated birthday message ready to send"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/ai/training": {
      "post": {
        "tags": [
          "AI"
        ],
        "summary": "Generate a training program",
        "description": "Uses AI (GPT-4) to generate a complete training program based on body part,\ngoal, level and optional comments. Returns a transaction ID used to review,\nedit and save the generated program.\n",
        "operationId": "ai_generate_training",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "body_part",
                  "goal"
                ],
                "properties": {
                  "body_part": {
                    "type": "string",
                    "enum": [
                      "full",
                      "upper",
                      "lower"
                    ],
                    "description": "Target body region",
                    "example": "full"
                  },
                  "goal": {
                    "type": "string",
                    "enum": [
                      "weightloss",
                      "strength",
                      "endurance",
                      "hypertrophy"
                    ],
                    "description": "Training goal",
                    "example": "strength"
                  },
                  "level": {
                    "type": "string",
                    "enum": [
                      "beginner",
                      "intermediate",
                      "advanced"
                    ],
                    "nullable": true,
                    "description": "Client fitness level"
                  },
                  "comment": {
                    "type": "string",
                    "nullable": true,
                    "description": "Optional free-text instructions for the AI",
                    "example": "Client has a knee injury, avoid squats"
                  }
                }
              },
              "example": {
                "body_part": "full",
                "goal": "strength",
                "level": "intermediate",
                "comment": "Avoid high impact exercises"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generated training program",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "transaction_id": {
                              "type": "string",
                              "description": "Temporary ID used to edit and save the program",
                              "example": "aB3dEfGhIj"
                            },
                            "training": {
                              "type": "object",
                              "description": "Generated training session with exercises"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/ai/training/text": {
      "post": {
        "tags": [
          "AI"
        ],
        "summary": "Generate a training session from free text",
        "description": "Uses AI to generate a training session from a natural language prompt.\nEither attaches to an existing training plan (training_id, creates a new session)\nor fills an existing session (session_id).\n",
        "operationId": "ai_generate_training_from_text",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "prompt"
                ],
                "properties": {
                  "prompt": {
                    "type": "string",
                    "description": "Free-text description of the desired training session",
                    "example": "3 sets of chest and tricep exercises, moderate intensity"
                  },
                  "training_id": {
                    "type": "integer",
                    "description": "Training plan ID \u2014 a new session will be created inside it (required if session_id is absent)"
                  },
                  "session_id": {
                    "type": "integer",
                    "description": "Existing session ID to fill with AI exercises (required if training_id is absent)"
                  }
                }
              },
              "example": {
                "prompt": "Upper body push day, 4 exercises, beginner friendly",
                "training_id": 42
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created or updated session with AI-generated exercises",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Training"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/ai/training/{transactionId}": {
      "patch": {
        "tags": [
          "AI"
        ],
        "summary": "Edit an AI-generated training",
        "description": "Applies accept/reject/replace actions to exercises in an AI-generated program\nidentified by its transaction ID. If a new AI call is needed (e.g. to replace\na rejected exercise), it is performed automatically.\n",
        "operationId": "ai_edit_generated_training",
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction ID returned by POST /ai/training"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "actions"
                ],
                "properties": {
                  "actions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": [
                        "id",
                        "action"
                      ],
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "Exercise index in the generated program"
                        },
                        "action": {
                          "type": "string",
                          "description": "Action to perform on the exercise (e.g. accept, reject, replace)"
                        }
                      }
                    }
                  }
                }
              },
              "example": {
                "actions": [
                  {
                    "id": 0,
                    "action": "accept"
                  },
                  {
                    "id": 1,
                    "action": "reject"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated training output after applying actions",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "description": "Updated generated training with revised exercise list"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/ai/training/{transactionId}/save": {
      "post": {
        "tags": [
          "AI"
        ],
        "summary": "Save an AI-generated training to a plan",
        "description": "Permanently saves the AI-generated program into an existing training plan\nas a new session. Logs the AI interaction and clears the temporary transaction.\n",
        "operationId": "ai_save_generated_training",
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Transaction ID returned by POST /ai/training"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "training_id"
                ],
                "properties": {
                  "training_id": {
                    "type": "integer",
                    "description": "Training plan ID to save the generated session into"
                  }
                }
              },
              "example": {
                "training_id": 42
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Saved session object",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Training"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/ai/activity/{event}": {
      "get": {
        "tags": [
          "AI"
        ],
        "summary": "Generate an encouragement message after a client activity",
        "description": "Uses AI to generate a short, personalized encouraging message after a client\ncompletes an activity. Takes into account duration, distance, speed, calories\nand completion rate. Written in the client's language.\n",
        "operationId": "ai_end_activity",
        "parameters": [
          {
            "name": "event",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            },
            "description": "EventInstance ID of the completed activity"
          }
        ],
        "responses": {
          "200": {
            "description": "AI-generated encouragement message",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "message": {
                              "type": "string",
                              "description": "Encouraging message ready to send to the client"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/ai/message/notification/{notification}": {
