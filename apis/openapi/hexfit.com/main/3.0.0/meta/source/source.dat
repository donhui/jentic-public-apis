    "/User/Login": {
      "post": {
        "tags": [
          "Authentication / Session"
        ],
        "summary": "Log in",
        "description": "Authenticates a user with email/password and returns the full user\nprofile including the `apikey` JWT token used for subsequent V2 calls.\nAvailable on both `v2.ca.hexfit.io` (CA region) and `v2.hexfit.io`\n(global/EU region). The `device_key` is a short alphanumeric token\nidentifying the client device.\n",
        "operationId": "v2_user_login",
        "servers": [
          {
            "url": "https://v2.hexfit.io"
          }
        ],
        "security": [],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "login": "user@example.com",
                "password": "s3cret",
                "device_key": "5C27F"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login result \u2014 `status` false on bad credentials",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V2Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "value": {
                          "oneOf": [
                            {
                              "$ref": "#/components/schemas/User"
                            },
                            {
                              "type": "string",
                              "description": "Error message on failure"
                            }
                          ]
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "status": true,
                  "value": {
                    "id": "h9036281e",
                    "firstname": "Martine",
                    "lastname": "Ramsey",
                    "apikey": "eyJ..."
                  },
                  "version": "3.5.2"
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/User/Disconnect": {
      "post": {
        "tags": [
          "Authentication / Session"
        ],
        "summary": "Log out",
        "description": "Invalidates the current session and removes the push-notification\nmobile key from the device registration.\n",
        "operationId": "v2_user_disconnect",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "mobile_key": {
                    "type": "string",
                    "description": "Push-notification device key to deregister",
                    "example": "98cd91ea9bd0H9ba9082884d7b00b6c6"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logout result",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V2Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "value": {
                          "type": "boolean"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "servers": [
        {
          "url": "https://v2.{region}.hexfit.io",
          "description": "V2 API (legacy).",
          "variables": {
            "region": {
              "default": "ca",
              "enum": [
                "ca",
                "eu"
              ]
            }
          }
        }
      ]
    },
    "/User/Create/Professional": {
      "post": {
        "tags": [
          "Users"
        ],
        "summary": "Create a professional user",
        "description": "Creates a new professional (coach/therapist) user account under the\ncurrent business. Assigns a job, permission profile, and optional\nbranch membership.\n",
        "operationId": "v2_user_create_professional",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
