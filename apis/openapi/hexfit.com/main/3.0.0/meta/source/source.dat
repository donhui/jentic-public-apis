    "/billing/business/{businessId}/client/{clientId}/invoices": {
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "List client invoices",
        "description": "Returns all invoices for a client, filtered by status.",
        "operationId": "v3_billing_client_invoices",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "open"
              ]
            },
            "description": "Omit for paid invoices; pass open for unpaid"
          }
        ],
        "responses": {
          "200": {
            "description": "List of client invoices",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/HexfitInvoice"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Billing"
        ],
        "summary": "Create invoice for client",
        "description": "Creates a Hexfit invoice for a client. Lines can be a mix of:\n- existing interventions (by intervention_id)\n- credit lines (by code_id + quantity, quantity >= 1)\n- custom free-form lines (name + price in cents + quantity >= 0)\n",
        "operationId": "v3_billing_client_create_invoice",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          },
          {
            "name": "clientId",
            "in": "path",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/EntityId"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "lines"
                ],
                "properties": {
                  "lines": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "oneOf": [
                        {
                          "type": "object",
                          "required": [
                            "intervention_id"
                          ],
                          "properties": {
                            "intervention_id": {
                              "$ref": "#/components/schemas/EntityId"
                            }
                          }
                        },
                        {
                          "type": "object",
                          "required": [
                            "code_id",
                            "quantity"
                          ],
                          "properties": {
                            "code_id": {
                              "$ref": "#/components/schemas/EntityId"
                            },
                            "quantity": {
                              "type": "integer",
                              "minimum": 1
                            }
                          }
                        },
                        {
                          "type": "object",
                          "required": [
                            "name",
                            "price",
                            "quantity"
                          ],
                          "properties": {
                            "name": {
                              "type": "string"
                            },
                            "price": {
                              "type": "integer",
                              "description": "Price in cents",
                              "example": 5000
                            },
                            "quantity": {
                              "type": "integer",
                              "minimum": 0
                            }
                          }
                        }
                      ]
                    }
                  },
                  "taxes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Stripe tax rate IDs to apply",
                    "example": [
                      "txr_xxx"
                    ]
                  },
                  "note": {
                    "type": "string",
                    "description": "Optional note on the invoice"
                  },
                  "charge_now": {
                    "type": "boolean",
                    "default": false,
                    "description": "If true, immediately charges the client's card"
                  }
                }
              },
              "example": {
                "lines": [
                  {
                    "intervention_id": "hXXXXX"
                  },
                  {
                    "code_id": "hYYYYY",
                    "quantity": 2
                  },
                  {
                    "name": "Custom item",
                    "price": 5000,
                    "quantity": 1
                  }
                ],
                "taxes": [
                  "txr_xxx"
                ],
                "note": "Invoice for June sessions",
                "charge_now": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created invoice reference",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/V3Envelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "intervention_id": {
                              "$ref": "#/components/schemas/EntityId"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/billing/business/{businessId}/client/{clientId}/invoices/{invoiceId}/reminder": {
      "get": {
        "tags": [
          "Billing"
        ],
        "summary": "Send invoice payment reminder",
        "description": "Sends a push or email notification to the client reminding them to pay the invoice.",
        "operationId": "v3_billing_invoice_reminder",
