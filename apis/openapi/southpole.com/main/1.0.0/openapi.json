{
  "openapi": "3.0.3",
  "info": {
    "title": "South Pole Emissions API",
    "description": "South Pole API for calculating carbon emissions from flights, hotels, and freight transport distances. Provides emissions calculation and distance measurement services.",
    "version": "1.0.0",
    "x-jentic-source-url": "https://docs.api.southpole.com/"
  },
  "servers": [
    {
      "url": "https://api.southpole.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/token": {
      "post": {
        "operationId": "getaccesstoken",
        "summary": "Get access token",
        "description": "Authenticate and retrieve a JWT access token. Tokens expire after 55 seconds.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "client_id": {
                    "type": "string",
                    "description": "OAuth2 client ID"
                  },
                  "client_secret": {
                    "type": "string",
                    "description": "OAuth2 client secret"
                  },
                  "grant_type": {
                    "type": "string",
                    "description": "OAuth2 grant type",
                    "example": "client_credentials"
                  }
                },
                "required": [
                  "client_id",
                  "client_secret",
                  "grant_type"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/calculateflightemissions": {
      "post": {
        "operationId": "calculateflightemissionsv1",
        "summary": "Calculate flight emissions (v1)",
        "description": "Calculate CO2 emissions for flights based on origin, destination, and cabin class.",
        "tags": [
          "Emissions Calculations"
        ],
        "security": [
          {
            "bearer": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FlightEmissionsRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Emissions calculation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmissionsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
