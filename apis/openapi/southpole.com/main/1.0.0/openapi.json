  "components": {
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Bearer token obtained from the /token endpoint. Tokens expire after 55 seconds."
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://api.southpole.com/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "TokenResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "JWT access token"
          },
          "token_type": {
            "type": "string",
            "description": "Token type",
            "example": "Bearer"
          },
          "expires_in": {
            "type": "integer",
            "description": "Token expiration time in seconds",
            "example": 55
          }
        }
      },
      "FlightEmissionsRequest": {
        "type": "object",
        "properties": {
          "origin": {
            "type": "string",
            "description": "Origin airport IATA code",
            "example": "LHR"
          },
          "destination": {
            "type": "string",
            "description": "Destination airport IATA code",
            "example": "JFK"
          },
          "cabin_class": {
            "type": "string",
            "description": "Cabin class",
            "enum": [
              "economy",
              "premium_economy",
              "business",
              "first"
            ]
          }
        },
        "required": [
          "origin",
          "destination"
        ]
      },
      "FlightEmissionsRequestV2": {
        "type": "object",
        "properties": {
          "origin": {
            "type": "string",
            "description": "Origin airport IATA code",
            "example": "LHR"
          },
          "destination": {
            "type": "string",
            "description": "Destination airport IATA code",
            "example": "JFK"
          },
          "cabin_class": {
            "type": "string",
            "description": "Cabin class",
            "enum": [
              "economy",
              "premium_economy",
              "business",
              "first"
            ]
          },
          "round_trip": {
            "type": "boolean",
            "description": "Whether the flight is a round trip"
          },
          "number_of_passengers": {
            "type": "integer",
            "description": "Number of passengers",
            "minimum": 1
          }
        },
        "required": [
          "origin",
          "destination"
        ]
      },
      "HotelEmissionsRequest": {
        "type": "object",
        "properties": {
          "country": {
            "type": "string",
            "description": "Country of the hotel"
          },
          "city": {
            "type": "string",
            "description": "City of the hotel"
          },
          "nights": {
            "type": "integer",
            "description": "Number of nights stayed",
            "minimum": 1
          },
          "rating": {
            "type": "integer",
            "description": "Hotel star rating",
            "minimum": 1,
            "maximum": 5
          }
        },
        "required": [
          "country",
          "nights"
        ]
      },
      "EmissionsResponse": {
        "type": "object",
        "properties": {
          "co2_kg": {
            "type": "number",
            "format": "double",
            "description": "CO2 emissions in kilograms"
          },
          "co2_tonnes": {
            "type": "number",
            "format": "double",
            "description": "CO2 emissions in tonnes"
          },
          "methodology": {
            "type": "string",
            "description": "Description of the calculation methodology used"
          }
        }
      },
      "DistanceRequest": {
        "type": "object",
        "properties": {
          "origin": {
            "type": "string",
            "description": "Origin location code"
          },
          "destination": {
            "type": "string",
            "description": "Destination location code"
          }
        },
        "required": [
          "origin",
          "destination"
        ]
      },
      "DistanceRequestResponse": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "description": "Unique identifier for the distance calculation request"
          },
          "status": {
            "type": "string",
            "description": "Status of the request"
          }
        }
      },
      "DistanceResponse": {
        "type": "object",
        "properties": {
          "requestId": {
            "type": "string",
            "description": "Unique identifier for the distance request"
          },
          "distance_km": {
            "type": "number",
            "format": "double",
            "description": "Calculated distance in kilometers"
          },
          "origin": {
            "type": "string",
            "description": "Origin location"
          },
          "destination": {
            "type": "string",
            "description": "Destination location"
          },
          "status": {
            "type": "string",
            "description": "Status of the calculation"
          }
        }
      },
      "AirportsResponse": {
        "type": "object",
        "properties": {
          "airports": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Airport"
            }
          }
        }
      },
      "Airport": {
        "type": "object",
        "properties": {
          "iata_code": {
            "type": "string",
            "description": "IATA airport code"
          },
          "name": {
            "type": "string",
            "description": "Airport name"
          },
          "city": {
            "type": "string",
            "description": "City name"
          },
          "country": {
            "type": "string",
            "description": "Country name"
          }
        }
      },
      "LocodesResponse": {
        "type": "object",
        "properties": {
          "locodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Locode"
            }
          }
        }
      },
      "Locode": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "UN/LOCODE location code"
          },
          "name": {
            "type": "string",
            "description": "Location name"
          },
          "country": {
            "type": "string",
            "description": "Country code"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "description": "Error message"
              },
              "code": {
                "type": "string",
                "description": "Error code"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearer": []
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "Token management"
    },
    {
      "name": "Emissions Calculations",
      "description": "Calculate carbon emissions for flights and hotels"
    },
    {
      "name": "Distance Calculations",
      "description": "Calculate freight transport distances by sea, rail, road, and air"
    },
    {
      "name": "Location Datasets",
      "description": "Retrieve airport and location code datasets"
    }
  ]
}