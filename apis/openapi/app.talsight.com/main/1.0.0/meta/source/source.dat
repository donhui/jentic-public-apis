{
  "openapi": "3.0.3",
  "info": {
    "title": "TalentSight API",
    "description": "TalentSight API allows you to manage your campaigns and webhooks.",
    "x-jentic-source-url": "https://app.talsight.com/docs",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://app.talsight.com",
      "description": "Production server",
      "variables": {}
    }
  ],
  "paths": {
    "/api/v1/campaigns/{id}": {
      "delete": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Campaign ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Campaign deleted successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Campaign ID is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:delete' scope"
          },
          "500": {
            "description": "Error deleting campaign"
          }
        },
        "summary": "Delete campaign",
        "description": "Delete a campaign. Optionally delete associated messages and invites",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "deleteAssociatedData": {
                    "type": "boolean",
                    "description": "Delete associated messages and invites",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "operationId": "deleteCampaign"
      },
      "get": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Campaign ID",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeRecipients",
            "in": "query",
            "required": false,
            "description": "Include recipient details in the response",
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ],
              "default": "false"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Campaign"
                }
              }
            }
          },
          "400": {
            "description": "Campaign ID is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:read' scope"
          },
          "404": {
            "description": "Campaign not found"
          }
        },
        "summary": "Get campaign",
        "description": "Retrieve details of a specific campaign by ID",
        "operationId": "getCampaign"
      }
    },
    "/api/v1/campaigns/{id}/pause": {
      "patch": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Campaign ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign paused successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "is_active": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "Campaign paused successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Campaign ID is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:write' scope"
          },
          "404": {
            "description": "Campaign not found"
          }
        },
        "summary": "Pause campaign",
        "description": "Pause an active campaign, preventing further message sends",
        "operationId": "pauseCampaign"
      }
    },
    "/api/v1/campaigns/{id}/recipients": {
      "get": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Campaign ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of campaign recipients",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "recipient_id": {
                        "type": "string"
                      },
                      "step_id": {
                        "type": "string"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "recipient": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "full_name": {
                            "type": "string"
                          },
                          "headline": {
                            "type": "string"
                          },
                          "profile_pic_url": {
                            "type": "string"
                          },
                          "current_company": {
                            "type": "string"
                          },
                          "public_identifier": {
                            "type": "string"
                          },
                          "linkedin_url": {
                            "type": "string"
                          },
                          "company": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "name": {
                                "type": "string"
                              },
                              "logo": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      },
                      "step": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "stepOrder": {
                            "type": "number"
                          },
                          "type": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Campaign ID is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:read' scope"
          },
          "404": {
            "description": "Campaign not found"
          }
        },
        "summary": "List campaign recipients",
        "description": "Retrieve all recipients added to a specific campaign",
        "operationId": "listCampaignRecipients"
      },
      "post": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Campaign ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipients added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "description": "Added recipients data"
                    },
                    "message": {
                      "type": "string",
                      "example": "Successfully added 2 recipient(s) to campaign"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request. At least one recipient identifier is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:write' scope"
          },
          "500": {
            "description": "Error adding recipients to campaign"
          }
        },
        "summary": "Add recipients to campaign",
        "description": "Add one or more recipients to a campaign by ID or LinkedIn public identifier",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "At least one recipient identifier is required",
                "properties": {
                  "recipient_id": {
                    "type": [
                      "string",
                      "number"
                    ],
                    "description": "Single recipient ID"
                  },
                  "recipient_ids": {
                    "type": [
                      "array",
                      "string"
                    ],
                    "description": "Array of recipient IDs or JSON string",
                    "items": {
                      "type": [
                        "string",
                        "number"
                      ]
                    }
                  },
                  "public_identifier": {
                    "type": "string",
                    "description": "Single LinkedIn public identifier",
                    "example": "john-doe"
                  },
                  "public_identifiers": {
                    "type": [
                      "array",
                      "string"
                    ],
                    "description": "Array of LinkedIn public identifiers or JSON string",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "john-doe",
                      "jane-smith"
                    ]
                  },
                  "firstNameOverride": {
                    "type": "string",
                    "description": "Override first name for personalization"
                  }
                }
              }
            }
          }
        },
        "operationId": "addRecipientsToCampaign"
      }
    },
    "/api/v1/campaigns/{id}/recipients/auto": {
      "post": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Campaign ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipient added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "description": "Added recipient data"
                    },
                    "message": {
                      "type": "string",
                      "example": "Successfully added recipient to campaign"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:write' scope"
          },
          "500": {
            "description": "Error adding recipient to campaign"
          }
        },
        "summary": "Add recipient to campaign (auto-detect)",
        "description": "Add a single recipient to a campaign using either their Talentsight ID or LinkedIn public identifier. The type field determines which identifier is used.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "type",
                  "value"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "public_identifier",
                      "talentsight_id"
                    ],
                    "description": "Type of identifier: 'public_identifier' for LinkedIn username or 'talentsight_id' for internal ID"
                  },
                  "value": {
                    "type": [
                      "string",
                      "number"
                    ],
                    "description": "The identifier value (LinkedIn public identifier or Talentsight ID)"
                  },
                  "firstNameOverride": {
                    "type": "string",
                    "description": "Override first name for personalization"
                  }
                }
              }
            }
          }
        },
        "operationId": "addRecipientToCampaign(auto-detect)"
      }
    },
    "/api/v1/campaigns/{id}/recipients/by-id": {
      "post": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Campaign ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipient added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "description": "Added recipient data"
                    },
                    "message": {
                      "type": "string",
                      "example": "Successfully added recipient 123 to campaign"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Campaign ID or recipient_id is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:write' scope"
          },
          "500": {
            "description": "Error adding recipient to campaign"
          }
        },
        "summary": "Add recipient to campaign by ID",
        "description": "Add a single recipient to a campaign using their recipient ID",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "recipient_id"
                ],
                "properties": {
                  "recipient_id": {
                    "type": [
                      "string",
                      "number"
                    ],
                    "description": "Recipient ID"
                  },
                  "firstNameOverride": {
                    "type": "string",
                    "description": "Override first name for personalization"
                  }
                }
              }
            }
          }
        },
        "operationId": "addRecipientToCampaignById"
      }
    },
    "/api/v1/campaigns/{id}/recipients/by-public-identifier": {
      "post": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Campaign ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipient added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "description": "Added recipient data"
                    },
                    "message": {
                      "type": "string",
                      "example": "Successfully added recipient to campaign"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Campaign ID or public_identifier is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:write' scope"
          },
          "500": {
            "description": "Error adding recipients to campaign"
          }
        },
        "summary": "Add recipient to campaign by LinkedIn identifier",
        "description": "Add a single recipient to a campaign using their LinkedIn public identifier. If the candidate doesn't exist, it will be created automatically",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "public_identifier"
                ],
                "properties": {
                  "public_identifier": {
                    "type": "string",
                    "description": "LinkedIn public identifier (e.g., 'john-doe')",
                    "example": "john-doe"
                  },
                  "firstNameOverride": {
                    "type": "string",
                    "description": "Override first name for personalization"
                  }
                }
              }
            }
          }
        },
        "operationId": "addRecipientToCampaignByLinkedinIdentifier"
      }
    },
    "/api/v1/campaigns/{id}/resume": {
      "patch": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Campaign ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign resumed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "is_active": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Campaign resumed successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Campaign ID is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:write' scope"
          },
          "404": {
            "description": "Campaign not found"
          }
        },
        "summary": "Resume campaign",
        "description": "Resume a paused campaign, allowing message sends to continue",
        "operationId": "resumeCampaign"
      }
    },
    "/api/v1/campaigns": {
      "get": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "includeRecipients",
            "in": "query",
            "required": false,
            "description": "Include recipient details in the response",
            "schema": {
              "type": "string",
              "enum": [
                "true",
                "false"
              ],
              "default": "false"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of campaigns",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Campaign"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:read' scope"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "summary": "List campaigns",
        "description": "Retrieve a list of all campaigns for the authenticated user",
        "operationId": "listCampaigns"
      },
      "post": {
        "tags": [
          "Campaigns"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Campaign"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'campaigns:write' scope"
          }
        },
        "summary": "Create campaign",
        "description": "Create a new outreach campaign with steps, recipients, and scheduling options",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "description"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Campaign name",
                    "example": "Q1 2024 Outreach"
                  },
                  "description": {
                    "type": "string",
                    "description": "Campaign description",
                    "example": "Outreach campaign for Q1 2024"
                  },
                  "steps": {
                    "type": "array",
                    "description": "Campaign steps/messages",
                    "items": {
                      "type": "object",
                      "properties": {
                        "content": {
                          "type": "string"
                        },
                        "fallbackContent": {
                          "type": "string"
                        },
                        "signature": {
                          "type": "string"
                        },
                        "stepOrder": {
                          "type": "number"
                        }
                      }
                    }
                  },
                  "recipients": {
                    "type": "array",
                    "description": "Initial recipients to add to the campaign",
                    "items": {
                      "type": "object"
                    }
                  },
                  "slots": {
                    "type": "array",
                    "description": "Time slots for sending messages",
                    "items": {
                      "type": "object",
                      "properties": {
                        "dayOfWeek": {
                          "type": "number",
                          "description": "Day of week (0-6, 0 = Sunday)",
                          "minimum": 0,
                          "maximum": 6
                        },
                        "startTime": {
                          "type": "string",
                          "format": "time"
                        },
                        "endTime": {
                          "type": "string",
                          "format": "time"
                        }
                      }
                    }
                  },
                  "use_ai": {
                    "type": "boolean",
                    "description": "Enable AI-powered message generation",
                    "default": false
                  },
                  "message_approval": {
                    "type": "boolean",
                    "description": "Require manual approval for messages",
                    "default": false
                  },
                  "is_active": {
                    "type": "boolean",
                    "description": "Whether the campaign is active",
                    "default": false
                  },
                  "exclusion_rules": {
                    "type": "object",
                    "description": "Rules for excluding recipients"
                  },
                  "account_id": {
                    "type": [
                      "string",
                      "number"
                    ],
                    "description": "LinkedIn account ID to use for the campaign"
                  }
                }
              }
            }
          }
        },
        "operationId": "createCampaign"
      }
    },
    "/api/v1/candidates/{id}": {
      "get": {
        "tags": [
          "Candidates"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Candidate ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Candidate details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CandidateDetail"
                }
              }
            }
          },
          "400": {
            "description": "Candidate ID is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'candidates:read' scope"
          },
          "404": {
            "description": "Candidate not found"
          }
        },
        "summary": "Get candidate",
        "description": "Retrieve detailed information about a specific candidate by ID",
        "operationId": "getCandidate"
      }
    },
    "/api/v1/candidates/search": {
      "get": {
        "tags": [
          "Candidates"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Search query term",
            "schema": {
              "type": "string"
            },
            "example": "software engineer"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Number of results per page (max 100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "company",
            "in": "query",
            "required": false,
            "description": "Filter by company name",
            "schema": {
              "type": "string"
            },
            "example": "Google"
          },
          {
            "name": "location",
            "in": "query",
            "required": false,
            "description": "Filter by city or country",
            "schema": {
              "type": "string"
            },
            "example": "San Francisco"
          },
          {
            "name": "title",
            "in": "query",
            "required": false,
            "description": "Filter by job title",
            "schema": {
              "type": "string"
            },
            "example": "Senior Engineer"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Candidate"
                      }
                    },
                    "total": {
                      "type": "integer",
                      "description": "Total number of results"
                    },
                    "limit": {
                      "type": "integer",
                      "description": "Results per page"
                    },
                    "page": {
                      "type": "integer",
                      "description": "Current page number"
                    },
                    "total_pages": {
                      "type": "integer",
                      "description": "Total number of pages"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'candidates:read' scope"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "summary": "Search candidates",
        "description": "Search for candidates using various filters and search terms",
        "operationId": "searchCandidates"
      }
    },
    "/api/v1/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "API key is valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    },
                    "message": {
                      "type": "string",
                      "example": "API key is valid"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "summary": "Health check",
        "description": "Verify that your API key is valid and the API is accessible",
        "operationId": "healthCheck"
      }
    },
    "/api/v1/messages/{id}/approve": {
      "post": {
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Message ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Message approved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "is_approved": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Message approved successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Message ID is required, message is not pending, or message is already approved"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'messages:write' scope or you don't own this message"
          },
          "404": {
            "description": "Message not found"
          }
        },
        "summary": "Approve message",
        "description": "Approve a pending message, allowing it to be sent",
        "operationId": "approveMessage"
      }
    },
    "/api/v1/messages/pending": {
      "get": {
        "tags": [
          "Messages"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "campaignId",
            "in": "query",
            "required": false,
            "description": "Filter messages by campaign ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of pending messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "recipient_id": {
                        "type": "string"
                      },
                      "step_id": {
                        "type": "string"
                      },
                      "status": {
                        "type": "string",
                        "enum": [
                          "pending",
                          "scheduled"
                        ]
                      },
                      "content": {
                        "type": "string"
                      },
                      "subject": {
                        "type": "string"
                      },
                      "signature": {
                        "type": "string"
                      },
                      "scheduledDate": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "recipient": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "full_name": {
                            "type": "string"
                          },
                          "headline": {
                            "type": "string"
                          },
                          "profile_pic_url": {
                            "type": "string"
                          },
                          "current_company": {
                            "type": "string"
                          },
                          "public_identifier": {
                            "type": "string"
                          },
                          "linkedin_url": {
                            "type": "string"
                          },
                          "company": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "name": {
                                "type": "string"
                              },
                              "logo": {
                                "type": "string"
                              }
                            }
                          }
                        }
                      },
                      "campaign": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'messages:read' scope"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "summary": "List pending messages",
        "description": "Retrieve all pending messages that require approval",
        "operationId": "listPendingMessages"
      }
    },
    "/api/v1/webhooks/{id}": {
      "delete": {
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Webhook ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Webhook ID is required"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'webhooks:write' scope"
          },
          "404": {
            "description": "Webhook not found"
          }
        },
        "summary": "Delete webhook",
        "description": "Delete a webhook by ID",
        "operationId": "deleteWebhook"
      }
    },
    "/api/v1/webhooks": {
      "get": {
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Webhook ID"
                      },
                      "url": {
                        "type": "string",
                        "format": "uri"
                      },
                      "events": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "is_active": {
                        "type": "boolean"
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'webhooks:read' scope"
          },
          "400": {
            "description": "Bad request"
          }
        },
        "summary": "List webhooks",
        "description": "Retrieve all webhooks configured for the authenticated user",
        "operationId": "listWebhooks"
      },
      "post": {
        "tags": [
          "Webhooks"
        ],
        "parameters": [
          {
            "name": "api_key",
            "in": "query",
            "required": true,
            "description": "API key for authentication",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Webhook created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Webhook ID"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "events": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "is_active": {
                      "type": "boolean"
                    },
                    "created_at": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request. URL and events array are required, and events must be valid"
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Insufficient permissions. Requires 'webhooks:write' scope"
          }
        },
        "summary": "Create webhook",
        "description": "Create a new webhook to receive notifications for specific events",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "url",
                  "events"
                ],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Webhook URL to receive notifications",
                    "example": "https://example.com/webhook"
                  },
                  "events": {
                    "type": "array",
                    "description": "List of events to subscribe to",
                    "items": {
                      "type": "string",
                      "enum": [
                        "campaign.created",
                        "campaign.updated",
                        "campaign.deleted",
                        "campaign.toggled",
                        "message.scheduled",
                        "message.sent",
                        "message.replied",
                        "invite.sent",
                        "invite.accepted"
                      ]
                    },
                    "example": [
                      "campaign.created",
                      "message.sent"
                    ]
                  }
                }
              }
            }
          }
        },
        "operationId": "createWebhook"
      }
    }
  }
}