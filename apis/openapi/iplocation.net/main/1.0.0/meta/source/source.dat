{
  "openapi": "3.0.3",
  "info": {
    "title": "IP Location API",
    "version": "1.0.0",
    "description": "IP Location API provides geolocation data for IPv4 and IPv6 addresses, returning country, ISP, and other location information. Free tier available for IP country lookups without authentication.",
    "x-jentic-source-url": "https://api.iplocation.net"
  },
  "servers": [
    {
      "url": "https://api.iplocation.net"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getIpLocation",
        "summary": "Get IP geolocation data",
        "description": "Retrieves geolocation information for the specified IP address including country name, country code, and ISP details.",
        "tags": ["Geolocation"],
        "parameters": [
          {
            "name": "ip",
            "in": "query",
            "required": true,
            "description": "IPv4 or IPv6 address to look up.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cmd",
            "in": "query",
            "required": false,
            "description": "Command specification (e.g., 'ip-country').",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "key",
            "in": "query",
            "required": false,
            "description": "API authentication key for premium features.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "format",
            "in": "query",
            "required": false,
            "description": "Output format.",
            "schema": {
              "type": "string",
              "enum": ["json", "xml", "plain", "jsonp", "php", "csv", "serialized"],
              "default": "json"
            }
          },
          {
            "name": "delimiter",
            "in": "query",
            "required": false,
            "description": "Delimiter for plain format output. 1 for newline, 2 for line break.",
            "schema": {
              "type": "integer",
              "enum": [1, 2],
              "default": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful IP geolocation response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IpLocationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid IP address",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "IpLocationResponse": {
        "type": "object",
        "properties": {
          "ip": {
            "type": "string",
            "description": "The queried IP address."
          },
          "ip_number": {
            "type": "string",
            "description": "Numeric representation of the IP address."
          },
          "ip_version": {
            "type": "integer",
            "description": "IP version (4 or 6)."
          },
          "country_name": {
            "type": "string",
            "description": "Full country name."
          },
          "country_code2": {
            "type": "string",
            "description": "Two-letter ISO country code."
          },
          "isp": {
            "type": "string",
            "description": "Internet Service Provider name."
          },
          "response_code": {
            "type": "string",
            "description": "Response status code."
          },
          "response_message": {
            "type": "string",
            "description": "Response status message."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "response_code": {
            "type": "string"
          },
          "response_message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "query",
        "name": "key",
        "description": "API key for premium features. Free IP country lookup does not require authentication."
      }
    }
  },
  "security": [
    {
      "apiKeyQuery": []
    }
  ]
}