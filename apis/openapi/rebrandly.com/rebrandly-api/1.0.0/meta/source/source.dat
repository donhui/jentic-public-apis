  },
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "name": "apikey",
        "in": "header",
        "description": "API key for authentication. Obtain from the Rebrandly dashboard."
      }
    },
    "parameters": {
      "WorkspaceHeader": {
        "name": "workspace",
        "in": "header",
        "description": "Workspace ID. Required if the account has multiple workspaces; defaults to the main workspace if omitted.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "Link": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the branded short link."
          },
          "title": {
            "type": "string",
            "description": "Title of the link."
          },
          "slashtag": {
            "type": "string",
            "description": "The keyword portion of the branded short link."
          },
          "destination": {
            "type": "string",
            "format": "uri",
            "description": "The destination URL the short link points to."
          },
          "shortUrl": {
            "type": "string",
            "description": "The full branded short URL."
          },
          "domain": {
            "$ref": "#/components/schemas/DomainRef"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the link was created."
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the link was last updated."
          }
        }
      },
      "LinkCreate": {
        "type": "object",
        "required": ["destination"],
        "properties": {
          "destination": {
            "type": "string",
            "format": "uri",
            "description": "The destination URL the branded short link will point to."
          },
          "slashtag": {
            "type": "string",
            "description": "Custom keyword for the short link. Auto-generated if omitted."
          },
          "domain": {
            "$ref": "#/components/schemas/DomainRef"
          },
          "title": {
            "type": "string",
            "description": "Custom title for the link."
          }
        }
      },
      "LinkUpdate": {
        "type": "object",
        "properties": {
          "destination": {
            "type": "string",
            "format": "uri",
            "description": "Updated destination URL."
          },
          "slashtag": {
            "type": "string",
            "description": "Updated slashtag."
          },
          "title": {
            "type": "string",
            "description": "Updated title."
          },
          "domain": {
            "$ref": "#/components/schemas/DomainRef"
          }
        }
      },
      "DomainRef": {
        "type": "object",
        "description": "Reference to a branded domain. Specify id, fullName, or both.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the branded domain."
          },
          "fullName": {
            "type": "string",
            "description": "Fully qualified domain name (e.g., rebrand.ly)."
          }
        }
      },
      "Domain": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the domain."
          },
          "fullName": {
            "type": "string",
            "description": "Fully qualified domain name."
          },
          "active": {
            "type": "boolean",
            "description": "Whether the domain is currently active."
          },
          "type": {
            "type": "string",
            "description": "Type of the domain."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the domain was added."
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the domain was last updated."
          }
        }
      },
      "Tag": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the tag."
          },
          "name": {
            "type": "string",
            "description": "Name of the tag."
          },
          "color": {
            "type": "string",
            "description": "Hex color code of the tag (without #)."
          }
        }
      },
      "TagCreate": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the tag."
          },
          "color": {
            "type": "string",
            "description": "Hex color code of the tag (without #)."
          }
        }
      },
      "Script": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the retargeting script."
          },
          "name": {
            "type": "string",
            "description": "Name of the retargeting script."
          },
          "uri": {
            "type": "string",
            "format": "uri",
            "description": "URI of the retargeting script."
          }
        }
      },
      "ScriptCreate": {
        "type": "object",
        "required": ["name", "uri"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the retargeting script."
          },
          "uri": {
            "type": "string",
            "format": "uri",
            "description": "URI of the retargeting script."
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Account unique identifier."
          },
          "fullName": {
            "type": "string",
            "description": "Account display name."
          },
          "username": {
            "type": "string",
            "description": "Username or email."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address."
          },
          "avatarUrl": {
            "type": "string",
            "format": "uri",
            "description": "Profile avatar URL."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Account creation timestamp."
          },
          "subscription": {
            "type": "object",
            "description": "Subscription details.",
            "properties": {
              "createdAt": {
                "type": "string",
                "format": "date-time",
                "description": "Subscription start date."
              },
              "limits": {
                "type": "object",
                "description": "Usage limits for the account.",
                "properties": {
                  "links": {
                    "$ref": "#/components/schemas/UsageLimit"
                  },
                  "domains": {
                    "$ref": "#/components/schemas/UsageLimit"
                  },
                  "workspaces": {
                    "$ref": "#/components/schemas/UsageLimit"
                  },
                  "teammates": {
                    "$ref": "#/components/schemas/UsageLimit"
                  },
                  "tags": {
                    "$ref": "#/components/schemas/UsageLimit"
                  },
                  "scripts": {
                    "$ref": "#/components/schemas/UsageLimit"
                  }
                }
              }
            }
          }
        }
      },
      "UsageLimit": {
        "type": "object",
        "properties": {
          "used": {
            "type": "integer",
            "description": "Number of resources currently in use."
          },
          "max": {
            "type": "integer",
            "description": "Maximum number of resources allowed."
          }
        }
      },
      "Workspace": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the workspace."
          },
          "name": {
            "type": "string",
            "description": "Name of the workspace."
          }
        }
      },
      "Count": {
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "description": "Total count of resources."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "property": {
            "type": "string",
            "description": "The property that caused the error."
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message."
          },
          "code": {
            "type": "string",
            "description": "Machine-readable error code."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Links",
      "description": "Manage branded short links."
    },
    {
      "name": "Domains",
      "description": "Manage branded domains."
    },
    {
      "name": "Tags",
      "description": "Manage tags for organizing links."
    },
    {
      "name": "Scripts",
      "description": "Manage retargeting scripts."
    },
    {
      "name": "Account",
      "description": "Retrieve account information."
    },
    {
      "name": "Workspaces",
      "description": "Manage workspaces."
    }
  ]
}