    "/scripts": {
      "get": {
        "operationId": "listScripts",
        "summary": "List retargeting scripts",
        "description": "Returns a list of retargeting scripts in the workspace.",
        "tags": ["Scripts"],
        "parameters": [
          {
            "$ref": "#/components/parameters/WorkspaceHeader"
          },
          {
            "name": "orderBy",
            "in": "query",
            "description": "Sorting criteria.",
            "schema": {
              "type": "string",
              "default": "name"
            }
          },
          {
            "name": "orderDir",
            "in": "query",
            "description": "Sorting direction.",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"],
              "default": "desc"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Number of results to return (max 25).",
            "schema": {
              "type": "integer",
              "default": 25,
              "maximum": 25
            }
          },
          {
            "name": "last",
            "in": "query",
            "description": "Pagination cursor. Pass the ID of the last script from the previous page.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of scripts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Script"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createScript",
        "summary": "Create a new retargeting script",
