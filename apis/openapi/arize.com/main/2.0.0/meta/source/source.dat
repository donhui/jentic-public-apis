    "/v2/annotation-queues": {
      "get": {
        "tags": [
          "Annotation Queues"
        ],
        "operationId": "annotation_queues_list",
        "x-optic-no-examples": true,
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "List annotation queues",
        "description": "List annotation queues the user has access to.\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/SpaceIdQueryParam"
          },
          {
            "$ref": "#/components/parameters/SpaceNameQueryParam"
          },
          {
            "$ref": "#/components/parameters/NameSearchQueryParam"
          },
          {
            "$ref": "#/components/parameters/LimitQueryParamMax100"
          },
          {
            "$ref": "#/components/parameters/CursorQueryParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/AnnotationQueueList"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      },
      "post": {
        "tags": [
          "Annotation Queues"
        ],
        "operationId": "annotation_queues_create",
        "x-optic-no-examples": true,
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Create an annotation queue",
        "description": "Create a new annotation queue.\n\n**Payload Requirements**\n- The annotation queue name must be unique within the given space (among active queues).\n- At least one `annotation_config_id` is required, and all configs must belong to the specified space.\n- Do not include system-managed fields on input: `id`, `created_at`, `updated_at`.\n- If `assignment_method` is not provided, it defaults to `\"all\"`.\n- If `annotator_emails` are provided, all emails must resolve to existing users with access to the space.\n\n**Valid example**\n```json\n{\n  \"name\": \"Quality Review Queue\",\n  \"space_id\": \"spc_xyz789\",\n  \"annotation_config_ids\": [\"ac_abc123\"],\n  \"assignment_method\": \"all\"\n}\n```\n\n**Valid example with records**\n```json\n{\n  \"name\": \"Quality Review Queue\",\n  \"space_id\": \"spc_xyz789\",\n  \"annotation_config_ids\": [\"ac_abc123\"],\n  \"annotator_emails\": [\"reviewer@example.com\"],\n  \"records\": [\n    {\"record_type\": \"span\", \"project_id\": \"prj_abc\", \"start_time\": \"2024-01-15T00:00:00Z\", \"end_time\": \"2024-01-16T00:00:00Z\", \"span_ids\": [\"span_001\"]},\n    {\"record_type\": \"example\", \"dataset_id\": \"ds_xyz\", \"example_ids\": [\"ex_001\", \"ex_002\"]}\n  ]\n}\n```\n\n**Invalid example** (missing required annotation_config_ids)\n```json\n{\n  \"name\": \"My Queue\",\n  \"space_id\": \"spc_xyz789\"\n}\n```\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "requestBody": {
          "$ref": "#/components/requestBodies/CreateAnnotationQueueRequestBody"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/AnnotationQueueCreate"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    },
    "/v2/annotation-queues/{annotation_queue_id}": {
      "patch": {
        "tags": [
          "Annotation Queues"
        ],
        "operationId": "annotation_queues_update",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Update an annotation queue",
        "description": "Update an annotation queue by its ID. At least one field must be provided.\n\n**Payload Requirements:**\n- At least one of `name`, `instructions`, `annotation_config_ids`, or `annotator_emails` must be provided\n- `name` must be unique within the space (409 Conflict if duplicate)\n- `annotation_config_ids` replaces all existing config associations; all configs must belong to the same space as the queue\n- `annotator_emails` replaces all existing user assignments; all users must have active accounts\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/AnnotationQueueIdPathParam"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/UpdateAnnotationQueueRequestBody"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/AnnotationQueueUpdated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      },
      "get": {
        "tags": [
          "Annotation Queues"
        ],
        "operationId": "annotation_queues_get",
        "x-optic-no-examples": true,
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Get an annotation queue",
        "description": "Get an annotation queue object by its ID.\n\nThis includes the annotation queue's annotation configs, which define the\nstructure of annotations that can be created in this queue.\n\nThis endpoint does not include queue records or annotation progress. To\nmanage records in a queue, use the Annotation Queue Items endpoints.\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/AnnotationQueueIdPathParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/AnnotationQueue"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      },
      "delete": {
        "tags": [
          "Annotation Queues"
        ],
        "operationId": "annotation_queues_delete",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Delete an annotation queue",
        "description": "Delete an annotation queue by its ID. This operation is irreversible.\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
