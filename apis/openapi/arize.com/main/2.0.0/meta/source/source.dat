            "schema": {
              "$ref": "#/components/schemas/AiIntegration"
            },
            "example": {
              "id": "TGxtSW50ZWdyYXRpb246MTI6YUJjRA==",
              "name": "My OpenAI Integration",
              "provider": "openAI",
              "has_api_key": true,
              "model_names": [
                "gpt-4",
                "gpt-4o"
              ],
              "enable_default_models": true,
              "function_calling_enabled": true,
              "auth_type": "default",
