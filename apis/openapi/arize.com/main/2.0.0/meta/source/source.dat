{
  "openapi": "3.0.3",
  "info": {
    "title": "Arize REST API",
    "version": "2.0.0",
    "description": "API specification for the backend data server. The API is hosted globally\nat https://api.arize.com/v2 or in your own environment.\n",
    "license": {
      "name": "Apache-2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    },
    "x-jentic-source-url": "https://api.arize.com/v2/spec.yaml"
  },
  "servers": [
    {
      "description": "Global",
      "url": "https://api.arize.com"
    },
    {
      "description": "Regional",
      "url": "https://api.{region}.arize.com",
      "variables": {
        "region": {
          "default": "eu-west-1a",
          "enum": [
            "eu-west-1a",
            "ca-central-1a"
          ]
        }
      }
    },
    {
      "description": "Custom Host",
      "url": "https://{host}",
      "variables": {
        "host": {
          "default": "api.arize.com"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "AI Integrations",
      "description": "AI integrations configure access to external LLM providers (e.g. OpenAI,\nAzure OpenAI, AWS Bedrock, Vertex AI). Integrations can be scoped to the\nentire account, a specific organization, or a specific space.\n"
    },
    {
      "name": "Annotation Configs",
      "description": "Annotation configs allow you to define consistent annotation schemas that\ncan be reused across your workspace, ensuring evaluations are structured and\ncomparable over time.\n"
    },
    {
      "name": "Annotation Queues",
      "description": "Annotation queues help you organize and manage human evaluation workflows.\nUse queues to assign spans or examples to annotators for review and labeling.\n"
    },
    {
      "name": "API Keys",
      "description": "API keys are used to authenticate requests to the Arize API. List your keys\nto view metadata; the raw secret is never returned after creation.\n"
    },
    {
      "name": "Datasets",
      "description": "Datasets are structured, version-controlled example collections you use to\nrun, evaluate, and track LLM experiments.\n"
    },
    {
      "name": "Evaluators",
      "description": "Evaluators are reusable evaluation configurations used to assess the quality\nof LLM outputs. They can be template-based (using LLM judges) or code-based.\n"
    },
    {
      "name": "Experiments",
      "description": "Experiments let you systematically test prompt/model changes using datasets,\ntasks, and evaluators.\n"
    },
    {
      "name": "Projects",
      "description": "Projects represent LLM applications being monitored in Arize where you can\nobserve traces and spans.\n"
    },
    {
      "name": "Prompts",
      "description": "Prompts are reusable, versioned templates for LLM interactions. Use prompts\nto standardize and manage how you interact with LLMs across your application.\n"
    },
    {
      "name": "Resource Restrictions",
      "description": "Endpoints for restricting and unrestricting resources (projects, models).\n"
    },
    {
      "name": "Role Bindings",
      "description": "Role bindings assign a role to a user on a resource. REST currently\nsupports space- and project-scoped bindings.\n"
    },
    {
      "name": "Roles",
      "description": "Roles define sets of permissions that can be assigned to users within an\naccount. Create custom roles to tailor access control to your team's needs.\n"
    },
    {
      "name": "Spaces",
      "description": "Spaces are containers within an organization for grouping related projects,\ndatasets, and experiments, enabling collaboration or isolated experimentation\nwith role-based access control.\n"
    },
    {
      "name": "Spans",
      "description": "Spans represent individual operations within a trace. A span captures the\ntiming, status, and attributes of a single operation in your application.\n"
    },
    {
      "name": "Tasks",
      "description": "Tasks are configurable units of work that tie one or more evaluators to a\ndata source (project or dataset). Use tasks to automate evaluation of LLM\noutputs, with support for continuous evaluation and backfill runs.\n"
    }
  ],
  "paths": {
    "/v2/ai-integrations": {
      "get": {
        "tags": [
          "AI Integrations"
        ],
        "operationId": "ai_integrations_list",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "List AI integrations",
        "description": "List AI integrations the user has access to.\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/SpaceIdQueryParam"
          },
          {
            "$ref": "#/components/parameters/SpaceNameQueryParam"
          },
          {
            "$ref": "#/components/parameters/NameSearchQueryParam"
          },
          {
            "$ref": "#/components/parameters/LimitQueryParamMax100"
          },
          {
            "$ref": "#/components/parameters/CursorQueryParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/AiIntegrationList"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      },
      "post": {
        "tags": [
          "AI Integrations"
        ],
        "operationId": "ai_integrations_create",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Create an AI integration",
        "description": "Create a new AI integration for an external LLM provider.\n\n**Payload Requirements**\n- `name` and `provider` are required.\n- The integration name must be unique within the account.\n- `provider` must be one of: `openAI`, `azureOpenAI`, `awsBedrock`, `vertexAI`, `anthropic`, `custom`.\n- If `scopings` is omitted, the integration defaults to account-wide visibility.\n- `enable_default_models` defaults to `false` if not provided.\n- `function_calling_enabled` defaults to `true` if not provided.\n- `auth_type` defaults to `default` if not provided.\n- For `awsBedrock` provider, `provider_metadata` must include `role_arn`.\n- For `vertexAI` provider, `provider_metadata` must include `project_id`, `location`, and `project_access_label`.\n\n**Valid example**\n```json\n{\n  \"name\": \"Production OpenAI\",\n  \"provider\": \"openAI\",\n  \"api_key\": \"sk-abc123...\",\n  \"model_names\": [\"gpt-4\", \"gpt-4o\"],\n  \"enable_default_models\": true\n}\n```\n\n**Invalid example** (missing required `provider`)\n```json\n{\n  \"name\": \"My Integration\"\n}\n```\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "requestBody": {
          "$ref": "#/components/requestBodies/CreateAiIntegrationRequestBody"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/AiIntegration"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    },
    "/v2/ai-integrations/{integration_id}": {
      "get": {
        "tags": [
          "AI Integrations"
        ],
        "operationId": "ai_integrations_get",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Get an AI integration",
        "description": "Get a specific AI integration by its ID.\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/AiIntegrationIdPathParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/AiIntegration"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      },
      "patch": {
        "tags": [
          "AI Integrations"
        ],
        "operationId": "ai_integrations_update",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Update an AI integration",
        "description": "Update an AI integration's configuration. At least one field must be provided.\nOmitted fields are left unchanged.\n\n**Payload Requirements**\n- At least one of the updatable fields must be provided.\n- `name`, if provided, must be unique within the account.\n- `api_key` can be set to `null` to remove the existing key, or omitted to keep it unchanged.\n- `scopings`, if provided, replaces all existing scoping rules.\n- `provider_metadata`, if provided, replaces existing metadata. Set to `null` to remove.\n\n**Valid example**\n```json\n{\n  \"name\": \"Updated Integration\",\n  \"model_names\": [\"gpt-4o\", \"gpt-4o-mini\"]\n}\n```\n\n**Invalid example** (empty body)\n```json\n{}\n```\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/AiIntegrationIdPathParam"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/UpdateAiIntegrationRequestBody"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/AiIntegration"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      },
      "delete": {
        "tags": [
          "AI Integrations"
        ],
        "operationId": "ai_integrations_delete",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Delete an AI integration",
        "description": "Delete an AI integration by its ID. This operation is irreversible.\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/AiIntegrationIdPathParam"
          }
        ],
        "responses": {
          "204": {
            "$ref": "#/components/responses/AiIntegrationDeleted"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    },
    "/v2/annotation-configs": {
      "get": {
        "tags": [
          "Annotation Configs"
        ],
        "operationId": "annotation_configs_list",
        "x-optic-no-examples": true,
        "x-mint": {
          "metadata": {
            "tag": "beta"
          }
        },
        "summary": "List annotation configs",
        "description": "List annotation configs the user has access to.\n\n<Note>This endpoint is in beta, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Note>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/SpaceIdQueryParam"
          },
          {
            "$ref": "#/components/parameters/SpaceNameQueryParam"
          },
          {
            "$ref": "#/components/parameters/NameSearchQueryParam"
          },
          {
            "$ref": "#/components/parameters/LimitQueryParamMax100"
          },
          {
            "$ref": "#/components/parameters/CursorQueryParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/AnnotationConfigList"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      },
      "post": {
        "tags": [
          "Annotation Configs"
        ],
        "operationId": "annotation_configs_create",
        "x-optic-no-examples": true,
        "x-mint": {
          "metadata": {
            "tag": "beta"
          }
        },
        "summary": "Create an annotation config",
        "description": "Create a new annotation config.\n\n**Payload Requirements**\n- The annotation config name must be unique within the given space.\n\n**Valid example**\n```json\n{\n  \"name\": \"my-annotation-config\",\n  \"space_id\": \"spc_123\",\n  \"annotation_config_type\": \"categorical\",\n  \"values\": [\n    {\n      \"label\": \"value1\",\n      \"score\": 0\n    },\n    {\n      \"label\": \"value2\",\n      \"score\": 1\n    }\n  ],\n  \"optimization_direction\": \"maximize\"\n}\n```\n\n<Note>This endpoint is in beta, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Note>\n",
        "requestBody": {
          "$ref": "#/components/requestBodies/CreateAnnotationConfigRequestBody"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/AnnotationConfig"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    },
