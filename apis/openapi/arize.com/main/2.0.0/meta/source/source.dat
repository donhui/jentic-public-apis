      "CreateAnnotationConfigRequestBody": {
        "required": [
          "name",
          "space_id",
          "annotation_config_type"
        ],
        "discriminator": {
          "propertyName": "annotation_config_type",
          "mapping": {
            "continuous": "#/components/schemas/ContinuousAnnotationConfigCreate",
            "categorical": "#/components/schemas/CategoricalAnnotationConfigCreate",
            "freeform": "#/components/schemas/FreeformAnnotationConfigCreate"
          }
        },
        "oneOf": [
