          }
        },
        "summary": "List prompt versions",
        "description": "List all versions of a prompt, sorted by creation date with the most\nrecently created versions first.\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/PromptIdPathParam"
          },
          {
            "$ref": "#/components/parameters/LimitQueryParamMax100"
          },
          {
            "$ref": "#/components/parameters/CursorQueryParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/PromptVersionList"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      },
      "post": {
        "tags": [
          "Prompts"
        ],
        "operationId": "prompt_versions_create",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Create a prompt version",
        "description": "Create a new version of an existing prompt.\n\n**Payload Requirements**\n- A `commit_message` is required.\n- At least one message is required in `messages`.\n- Do not include system-managed fields on input: `id`, `commit_hash`, `created_at`, `created_by_user_id`.\n  Requests that contain these fields will be rejected.\n- `input_variable_format` and `provider` are required.\n\n**Valid example** (create)\n```json\n{\n  \"commit_message\": \"Updated system prompt for better responses\",\n  \"input_variable_format\": \"f_string\",\n  \"provider\": \"openAI\",\n  \"model\": \"gpt-4\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a helpful assistant.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello, {name}!\"\n    }\n  ]\n}\n```\n\n**Invalid example** (missing required `commit_message`)\n```json\n{\n  \"input_variable_format\": \"f_string\",\n  \"provider\": \"openAI\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Hello!\"\n    }\n  ]\n}\n```\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/PromptIdPathParam"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/CreatePromptVersionRequestBody"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/PromptVersion"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    },
    "/v2/prompt-versions/{version_id}": {
      "get": {
        "tags": [
