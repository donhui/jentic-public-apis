      "SpaceNameQueryParam": {
        "name": "space_name",
        "in": "query",
        "description": "Case-insensitive substring filter on the space name. Narrows results\nto resources in spaces whose name contains the given string. If omitted,\nno space name filtering is applied and all resources are returned.\n",
        "schema": {
          "type": "string",
          "maxLength": 255
        },
        "example": "my-space"
      },
      "DatasetIdPathParam": {
