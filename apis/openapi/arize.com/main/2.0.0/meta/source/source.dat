    "/v2/prompt-versions/{version_id}/labels": {
      "put": {
        "tags": [
          "Prompts"
        ],
        "operationId": "prompt_version_labels_set",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Set labels on a prompt version",
        "description": "Set (replace) all labels on a prompt version. This is an idempotent\noperation. If a label already exists on another version of the same\nprompt, it will be moved to this version.\n\nLabels not included in the request will be removed from this version.\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/PromptVersionIdPathParam"
          }
        ],
        "requestBody": {
