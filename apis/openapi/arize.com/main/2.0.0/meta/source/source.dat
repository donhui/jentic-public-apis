          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    },
    "/v2/api-keys/{api_key_id}/refresh": {
      "post": {
        "tags": [
          "API Keys"
        ],
        "operationId": "api_keys_refresh",
        "x-mint": {
          "metadata": {
            "tag": "alpha"
          }
        },
        "summary": "Refresh an API key",
        "description": "Atomically revoke an existing API key and issue a replacement with the same\nmetadata (name, description, and key type). Attempting to refresh a key\nyou did not create returns a `400` error.\n\nThe old key is invalidated and the new key is activated in a single transaction \u2014\nthere is no window where neither key is valid. The full new key value (`key`) is\n**only returned once** in the response. Store it securely.\n\n**Expiry behaviour:** Supply `expires_at` in the request body to set an expiration\non the replacement key. Omit `expires_at` (or send an empty body `{}`) to create\nthe replacement key with no expiration (infinite lifetime).\n\n<Warning>This endpoint is in alpha, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Warning>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/ApiKeyIdPathParam"
          }
        ],
        "requestBody": {
          "$ref": "#/components/requestBodies/RefreshApiKeyRequestBody"
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/ApiKeyCreated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      }
    },
    "/v2/datasets": {
      "get": {
        "tags": [
          "Datasets"
        ],
        "operationId": "datasets_list",
        "x-mint": {
          "metadata": {
            "tag": "beta"
          }
        },
        "summary": "List datasets",
        "description": "List datasets the user has access to.\n\nThe datasets are sorted by creation date, with the most recently created\ndatasets coming first.\n\nThe dataset versions are not included in this response. To get the\nversions of a specific dataset, use the Get Dataset by ID endpoint.\n\n<Note>This endpoint is in beta, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Note>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/SpaceIdQueryParam"
          },
          {
            "$ref": "#/components/parameters/SpaceNameQueryParam"
          },
          {
            "$ref": "#/components/parameters/NameSearchQueryParam"
          },
          {
            "$ref": "#/components/parameters/LimitQueryParamMax100"
          },
          {
            "$ref": "#/components/parameters/CursorQueryParam"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/DatasetList"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "422": {
            "$ref": "#/components/responses/BadRequest"
          },
          "429": {
            "$ref": "#/components/responses/RateLimitExceeded"
          }
        }
      },
      "post": {
        "tags": [
          "Datasets"
        ],
        "operationId": "datasets_create",
        "x-mint": {
          "metadata": {
            "tag": "beta"
          }
        },
        "summary": "Create a dataset",
        "description": "Create a new dataset with JSON examples. Empty datasets are not allowed.\n\n**Payload Requirements**\n- The dataset name must be unique within the given space.\n- Each item in `examples[]` may contain **any user-defined fields**.\n- Do not include system-managed fields on input: `id`, `created_at`, `updated_at`.\nRequests that contain these fields in any example **will be rejected**.\n- Each example **must contain at least one property** (i.e., `{}` is invalid).\n\n**Valid example** (create)\n```json\n{\n  \"name\": \"my-dataset\",\n  \"space_id\": \"spc_123\",\n  \"examples\": [\n    {\n      \"question\": \"What is 2+2?\",\n      \"answer\": \"4\",\n      \"topic\": \"math\"\n    },\n    {\n      \"question\": \"What is the capital of Spain?\",\n      \"answer\": \"Madrid\",\n      \"topic\": \"geography\"\n    },\n  ]\n}\n```\n\n**Invalid example** ('id' not allowed on create)\n```json\n{\n  \"name\": \"my-dataset\",\n  \"space_id\": \"spc_123\",\n  \"examples\": [\n    {\n      \"id\": \"ex_1\",\n      \"input\": \"Hello\"\n    }\n  ]\n}\n```\n\n<Note>This endpoint is in beta, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Note>\n",
        "requestBody": {
          "$ref": "#/components/requestBodies/CreateDatasetRequestBody"
        },
        "responses": {
          "201": {
            "$ref": "#/components/responses/Dataset"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "409": {
            "$ref": "#/components/responses/Conflict"
          }
        }
      }
    },
    "/v2/datasets/{dataset_id}": {
