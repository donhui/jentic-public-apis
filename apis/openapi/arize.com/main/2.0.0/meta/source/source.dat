        "description": "Filter by API key status.\n- active - Only return keys that are valid for use.\n- deleted - Only return keys that have been deleted.\n\nWhen not specified, defaults to `active`.\n",
        "schema": {
          "$ref": "#/components/schemas/ApiKeyStatus"
        },
        "example": "active"
      },
      "ApiKeyTypeQueryParam": {
        "name": "key_type",
        "in": "query",
        "required": false,
        "description": "Filter by API key type.\n- user - Key associated with a specific user.\n- service - Key associated with a bot user for service authentication.\n",
        "schema": {
          "type": "string",
          "enum": [
            "user",
            "service"
          ]
        },
        "example": "user"
      },
      "CursorQueryParam": {
        "name": "cursor",
        "in": "query",
        "description": "Opaque pagination cursor returned from a previous response\n(`pagination.next_cursor`). Treat it as an unreadable token; do not\nattempt to parse or construct it.\n",
        "schema": {
          "type": "string"
        }
      },
      "LimitQueryParamMax100": {
        "name": "limit",
        "in": "query",
        "description": "Maximum items to return",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 50
        }
      },
      "LimitQueryParamMax500": {
        "name": "limit",
        "in": "query",
        "description": "Maximum items to return",
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "default": 50
        }
      },
      "NameSearchQueryParam": {
        "name": "name",
        "in": "query",
        "description": "Case-insensitive substring filter on the resource name. Returns only\nresources whose name contains the given string. For example,\n`name=prod` matches \"production\", \"my-prod-dataset\", etc. If omitted,\nno name filtering is applied and all resources are returned.\n",
        "schema": {
          "type": "string",
          "maxLength": 255
        },
        "example": "production"
