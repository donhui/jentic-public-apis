    "/v2/datasets/{dataset_id}/examples": {
      "get": {
        "tags": [
          "Datasets"
        ],
        "operationId": "datasets_examples_list",
        "x-mint": {
          "metadata": {
            "tag": "beta"
          }
        },
        "summary": "List dataset examples",
        "description": "List examples for a given dataset and version.\n\nIf version is not passed, the latest version is selected. Examples are\nsorted by insertion order.\n\n**Pagination**:\n- Response includes `pagination` for forward compatibility.\n- **Currently not implemented**: `pagination.next_cursor` is omitted\n- When pagination is enabled in the future, the behavior will match\nother list endpoints (cursor-based, opaque tokens).\n\n<Note>This endpoint is in beta, read more [here](https://arize.com/docs/ax/rest-reference#api-version-stages).</Note>\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/DatasetIdPathParam"
          },
          {
            "$ref": "#/components/parameters/DatasetVersionIdQueryParam"
          },
          {
            "$ref": "#/components/parameters/LimitQueryParamMax500"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/DatasetExampleList"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "422": {
            "$ref": "#/components/responses/BadRequest"
          },
